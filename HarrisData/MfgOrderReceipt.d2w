%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Manufacturing Order Receipt ***"
  d2wName                 = "MfgOrderReceipt.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;touchScreen=Y"
  programName             = ""
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  itemNumber              = ""
  lotControlled           = "N"
  returnSla               = ""
  plantNumber             = ""
  mfgOrder                = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_pos("@@homeURL", "$(workURL)", poshomeURL)
  @dtw_replace(workURL, "@@homeURL", "$(homeURL)", "1", "a", workURL)
  @dtw_assign(baseWrk, baseVar)
  @dtw_pos("@@phpPath", "$(workURL)", posPHP)
  %if (posPHP > "0")
      @dtw_pos(".ICL", @dtw_ruppercase(baseVar), posPHP)
      @dtw_substr(baseVar, "1", posPHP, baseWrk)
      @dtw_concat(baseWrk, "php", baseWrk)
      @dtw_replace(workURL, "@@phpPath", "$(phpPath)", "1", "a", workURL)
  %else
      @dtw_replace(workURL, "@@cGIPath", "$(cGIPath)", "1", "a", workURL)
  %endif
  @dtw_replace(workURL, "@@helpPath", "$(helpPath)", "1", "a", workURL)
  @dtw_replace(workURL, "@@prfh", "@dtw_rurlescseq(profileHandle)", "1", "a", workURL)
  @dtw_replace(workURL, "@@userProfile", "$(userProfile)", "1", "a", workURL)

  @dtw_pos("@@meapid", "$(workURL)", posME)
  %if (posME != "0")
      @RtvFldDesc("HDMERL>0", "HDCTRL", "CHAR(HDMERL)", V_HDMERL)
      %if (V_HDMERL>"0")
          @dtw_assign(meapid, "ME")
      %else
          @dtw_assign(meapid, "ET")
      %endif
      @dtw_replace(workURL, "@@meapid", "$(meapid)", "1", "a", workURL)
  %endif

  @dtw_pos("?", "$(workURL)", posQ)
  %if (posQ != "0")
      @dtw_assign(workAmp, "&amp;")
  %else
      @dtw_assign(workAmp, "?")
  %endif

  %if (poshomeURL != "0")
      @dtw_pos("@@baseVar", "$(workURL)", pos)
      %if (pos == "0")
          @dtw_concat(workURL, "$(workAmp)baseVar=", workURL)
          @dtw_concat(workURL, $(baseWrk), workURL)
          @dtw_assign(workAmp, "&amp;")
          @dtw_concat(workURL, "$(workAmp)eID=", workURL)
          @dtw_concat(workURL, $(eID), workURL)
      %else
          @dtw_replace(workURL, "@@baseVar", "@dtw_rurlescseq(baseWrk)", "1", "a", workURL)
      %endif
      @dtw_pos("@@browser", "$(workURL)", pos)
      %if (pos > "0")
          @dtw_replace(workURL, "@@browser", "$(browser)", "1", "a", workURL)
      %endif
  %endif

  @dtw_replace(workURL, "@@timeStamp", "@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))", "1", "a", workURL)
  @dtw_replace(workURL, "@@plantNumber", "@dtw_rurlescseq(plantNumber)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          %if (V_CILTUS == "Y")
              @RtvFldDesc("DCTURN=$(turnaroundNumber)", "HDTRNM inner join HDIMST on IMITEM=DCPITM", "IMLOT", lotControlled)
          %endif
          @dtw_assign(formName, "Chg")	
          <script type="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.transDate.value =="" ||
                      document.Chg.qtyComplete.value =="" ||
                      document.Chg.whsNumber.value =="")
                     {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.transDate, 6, 0) &&
                      editdate(document.Chg.transDate) &&
                      editNum(document.Chg.qtyComplete, 9, 4) &&
                      editNum(document.Chg.whsNumber, 3, 0)
                      %if (lotControlled != "N")
                          && editNum(document.Chg.expireDate, 6, 0)
                          && editdate(document.Chg.expireDate)
                      %endif
                      )
                      return true;
              }
              function setCloseOrder(action) {
                  document.Chg.closeOrder.value=action;
              }
          	
              %INCLUDE "DateEdit.icl"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "KeyboardFunctionsTS.icl"
              %INCLUDE "ShowHideSelCriteria.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      @dtw_concat(stmtSQL, "Select * From HDTRNM Where DCTURN = $(turnaroundNumber)", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Receipt_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
                  
                  @dtw_assign(workURL, "")
                  %if (sfdExitOR != "")
                      @dtw_assign(workURL, sfdExitOR)
                      @Set_URL(workURL)
                      @dtw_replace(workURL, "@@mfgOrder", "@dtw_rurlescseq(mfgOrder)", "1", "a", workURL)
                  %endif
                  
                   <td>
                       <ul class="toolbarTS">
                          <li class="optionTS"><a href="$(homeURL)$(cGIPath)$(d2wName)/NOUPDATE$(d2wVarBase)">&nbsp;<br>Back</a></li>                       
                          <li class="optionTS"><a href="javascript:check(document.Chg)">&nbsp;<br>Accept</a></li>
                          <li class="optionTS"><a href="javascript:document.Chg.acceptMore.value='Y';javascript:check(document.Chg)">&nbsp;<br>Accept/More</a></li>
                          <li class="optionTS"><a href="$(homeURL)$(cGIPath)StockLocations.d2w/ENTRY$(d2wVarBase)&amp;docName=Chg&amp;forItemNumber=@dtw_rurlescseq(itemNumber)&amp;fldStkr=stockRoom&amp;fldAisle=stockAile&amp;fldLoc=stockLoc&amp;fldStkID=stockLocId&amp;fldLotNumber=lotNumber&amp;fldLotControlled=@dtw_rurlescseq(lotControlled)" onclick="$(searchWinVar)">&nbsp;<br>Stock Locations</a></li>
                          %if (workURL != "")
                              <li class="optionTS"><a href="$(workURL)&amp;touchScreen=Y" onclick="$(laborEntryWinVar)">&nbsp;<br>Exit Point</a></li>                       
                          %endif
                       </ul>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Receipt_Query (IN CHAR(64)    profileHandle,
                                     CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)

      <table $(contentTable)>
          <tr><td><h1>$(page_title)</h1></td></tr>
      </table>

      %ROW {
          @dtw_assign(plantNumber, $(V_DCPLT))
          @dtw_assign(mfgOrder, $(V_DCMORD))
           
          <table $(contentTable)>
              <colgroup>
                  <col width="20%">
                  <col width="60%">
                  <col width="15%">
              <tr><td class="hdrtitl">Order:</td>
                  <td class="hdrdata">$(V_DCMORD)</td>
              </tr>
              @RtvFldDesc("IMITEM='$(V_DCPITM)'", "HDIMST", "IMIMDS", itemDescription)
              @Format_Code($(V_DCPITM), F_itemNumber)
              @dtw_assign(itemNumber, $(V_DCPITM))
              <tr><td class="hdrtitl">Item:</td>
                  <td class="hdrdata">$(itemDescription) &nbsp; $(F_itemNumber)</td>
              </tr>
              <tr><td class="hdrtitl">Reference Number:</td>
                  <td class="hdrdata">$(V_DCRORD)</td>
                  <td><a href="javascript:void+0" onClick="showSel('selData')" onBlur="hideSel('selData')">$(smMoreInfoImage)</a></td>
              </tr>
          </table>
          @RtvFldDesc("PLPLNT=$(V_DCPLT)", "HDPLNT", "PLNAME", plantName)
          @Format_Code($(V_DCPLT), F_plantNumber)
          @RtvFldDesc("IMITEM='$(V_DCPITM)'", "HDIMST", "IMUOMS", stockingUOM)
          @RtvFldDesc("UMUOM='$(stockingUOM)'", "HDUOM", "UMUMLD", uomDescription)
          @Format_Code(stockingUOM, F_stockingUOM)

          @dtw_assign(moreInfo, "")
          @Build_More_Info("Plant", plantName, F_plantNumber, moreInfo)
          @Build_More_Info("Stocking UOM", uomDescription, F_stockingUOM, moreInfo)
          @Build_More_Info("Turnaround", turnaroundNumber, "", moreInfo)
          %INCLUDE "MoreInfo.icl"


          <div id="cloData" class="moreInfo"><p>The total received against this order is greater than or equal to<br>
          the order quantity.  The order close may be submitted at this time<br>
          or press 'No Action' to bypass.</p><table $(quickSearchTable)>
          <tr>
          <td>
                       <ul class="toolbarHTS">
                          <li class="optionHTS2"><a href="javascript:setCloseOrder('N');check(document.Chg)">&nbsp;<br>No Action</a></li>
                          <li class="optionHTS2"><a href="javascript:setCloseOrder('Y');showSel('cloPrint')">&nbsp;<br>Accept</a></li>
                          <li class="optionHTS2"><a href="javascript:hideSel('cloData')">&nbsp;<br>Back</a></li>
                      </ul>
                  </td>
              </tr>
          </table></div>

          <div id="cloPrint" class="moreInfo"><p>Select the Manufacturing Order Close Report format to print.</p><table $(quickSearchTable)>
          <tr>
          			<td>
                       <ul class="toolbarHTS">
                          <li class="optionHTS2"><a href="javascript:setCloseOrder('D');check(document.Chg)">&nbsp;<br>Detail</a></li>
                          <li class="optionHTS2"><a href="javascript:setCloseOrder('S');check(document.Chg)">&nbsp;<br>Summary</a></li>
                          <li class="optionHTS2"><a href="javascript:hideSel('cloPrint')">&nbsp;<br>Back</a></li>
                      </ul>
                  </td>
              </tr>
          </table></div>

          %if (confMessage !="")
              <div class="error">$(confMessage)</div>
              @dtw_assign(confMessage, "")
          %endif
          $(hrTagAttr)

          %if (errFound != "C")
          %INCLUDE "ErrorDisplay.icl"
          %endif
                   			
          <form class="formClass" method="post" name="Chg" onsubmit="return validate(document.Chg)"  action="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
          	  <input id="closeOrder" name="closeOrder" type="hidden">
          	  <input id="acceptMore" name="acceptMore" type="hidden">
              %INCLUDE "RequiredFieldTS.icl"

                  %if (errFound != "")
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      %if (errFound == "C")
                          @dtw_assign(errVar, "")
                      %endif
                      @DecatErr_Field("@@date", "transDate")         @dtw_assign(Err_DATE, fieldValue)
                      @DecatErr_Field("@@qtyc", "qtyComplete")       @dtw_assign(Err_QTYC, fieldValue)
                      @DecatErr_Field("@@whs@", "whsNumber")         @dtw_assign(Err_WHS,  fieldValue)
                      @DecatErr_Field("@@stkr", "stockRoom")         @dtw_assign(Err_STKR, fieldValue)
                      @DecatErr_Field("@@lotn", "lotNumber")         @dtw_assign(Err_LOTN, fieldValue)
                      @DecatErr_Field("@@dtex", "expireDate")        @dtw_assign(Err_DTEX, fieldValue)
                      @DecatErr_Field("@@udf1", "lotUdf1")           @dtw_assign(Err_UDF1, fieldValue)
                      @DecatErr_Field("@@udf2", "lotUdf2")           @dtw_assign(Err_UDF2, fieldValue)
                      @DecatErr_Field("@@udf3", "lotUdf3")           @dtw_assign(Err_UDF3, fieldValue)

                      @Decat_Field("@@turn")   @dtw_assign(V_DCTURN,  fieldValue)
                      @Decat_Field("@@date")   @dtw_assign(F_DATE,  fieldValue)
                      @Decat_Field("@@qtyc")   @dtw_assign(F_QTYC,  fieldValue)
                      @Decat_Field("@@whs@")   @dtw_assign(F_WHS,   fieldValue)
                      @Decat_Field("@@stkr")   @dtw_assign(F_STKR, fieldValue)
                      @Decat_Field("@@aile")   @dtw_assign(F_AILE, fieldValue)
                      @Decat_Field("@@sloc")   @dtw_assign(F_SLOC, fieldValue)
                      @Decat_Field("@@lotn")   @dtw_assign(F_LOTN, fieldValue)
                      @Decat_Field("@@dtex")   @dtw_assign(F_DTEX, fieldValue)
                      @Decat_Field("@@udf1")   @dtw_assign(F_UDF1, fieldValue)
                      @Decat_Field("@@udf2")   @dtw_assign(F_UDF2, fieldValue)
                      @Decat_Field("@@udf3")   @dtw_assign(F_UDF3, fieldValue)
                      @Decat_Field("@@clos")   @dtw_assign(closeBox, fieldValue)
                      @Decat_Field("@@dors")   @dtw_assign(closeOrder, fieldValue)

                      @dtw_assign(errFound, "")
                  %else
                      @DateTodayCYMD(F_DATE)
                      @DateInputFromCYMD(F_DATE)
                      %if (V_CISTKL == "Y")
                  	      @RetDefStkLoc(profileHandle, dataBaseID, "RetDefStkLoc", V_DCPLT, V_DCPITM, returnWhs, returnSla, returnStkr, returnAile, returnSloc, returnStid)
                      %endif
                  	  %if (returnSla == "Y")
                          @dtw_assign(F_WHS, "$(returnWhs)")
                          @dtw_assign(F_STKR, "$(returnStkr)")
                          @dtw_assign(F_AILE, "$(returnAile)")
                          @dtw_assign(F_SLOC, "$(returnSloc)")
                      %else
                          @RetWhsNbr(profileHandle, dataBaseID, "RetWhsNbr", V_DCPLT, V_DCPITM, returnWarehouse)
                          @dtw_assign(F_WHS, "$(returnWarehouse)")
                      %endif

                      @dtw_assign(focusField, "qtyComplete")
                  %endif
			
                  %if (closeBox == "Y" && errVar == "")
                  		<script type="text/javascript"> showSel('cloData')</script>
				  %endif

                  %if (focusField == "")
                      @dtw_assign(focusField, "qtyComplete")
                  %endif
					
                  <table $(contentTable)>

                  @SetTextOvr(Err_QTYC)
                  <tr><td class="dsphdr"><span $(textOvr)>Quantity</span></td>
                      <td class="input"><input class="input" id="qtyComplete" onfocus="kbActive(this, 'numericKeyboard');" name="qtyComplete" type="text" value="$(F_QTYC)" size="14" maxlength="14"> $(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_QTYC)

                  %if (lotControlled != "N")
                      @SetTextOvr(Err_LOTN)
                      <tr><td class="dsphdr"><span $(textOvr)>Lot Number</span></td>
                          <td class="input"><input class="input" id="lotNumber" onfocus="kbActive(this, 'keyboard');" name="lotNumber" type="text" value="$(F_LOTN)" size="15" maxlength="15"></td>
                      </tr>
                      @DspErrMsg(Err_LOTN)

                      @SetTextOvr(Err_DTEX)
                      <tr><td class="dsphdr"><span $(textOvr)>Expiration Date</span></td>
                          <td class="input"><input class="input" id="expireDate" onfocus="kbActive(this, 'dtpDiv');" name="expireDate" type="text" value="$(F_DTEX)" size="6" maxlength="6"></td>
                      </tr>
                      @DspErrMsg(Err_DTEX)

                      %if (V_CILUS1 != "")
                   	      @SetTextOvr(Err_UDF1)
                          <tr><td class="dsphdr"><span $(textOvr)>$(V_CILUS1)</span></td>
                              <td class="input"><input class="input" id="lotUdf1" onfocus="kbActive(this, 'keyboard');" name="lotUdf1" type="text" value="$(F_UDF1)" size="15" maxlength="15"></td>
                          </tr>
                          @DspErrMsg(Err_UDF1)
                      %endif

                      %if (V_CILUS2 != "")
                   	      @SetTextOvr(Err_UDF2)
                          <tr><td class="dsphdr"><span $(textOvr)>$(V_CILUS2)</span></td>
                              <td class="input"><input class="input" id="lotUdf2" onfocus="kbActive(this, 'keyboard');" name="lotUdf2" type="text" value="$(F_UDF2)" size="15" maxlength="15"></td>
                          </tr>
                          @DspErrMsg(Err_UDF2)
                      %endif

                      %if (V_CILUS3 != "")
                   	      @SetTextOvr(Err_UDF3)
                          <tr><td class="dsphdr"><span $(textOvr)>$(V_CILUS3)</span></td>
                              <td class="input"><input class="input" id="lotUdf3" onfocus="kbActive(this, 'keyboard');" name="lotUdf3" type="text" value="$(F_UDF3)" size="15" maxlength="15"></td>
                          </tr>
                          @DspErrMsg(Err_UDF3)
                      %endif
                  %endif

                  %if (V_CISTKL == "Y")
                  	  @SetTextOvr(Err_STKR)
                      <tr><td class="dsphdr"><span $(textOvr)>Stock Location</span></td>
                          <td class="input"><input class="input" id="stockRoom" onfocus="kbActive(this, 'keyboard');" name="stockRoom" type="text" value="$(F_STKR)" size="3" maxlength="3"> - <input class="input" id="stockAile" onfocus="kbActive(this, 'keyboard');" name="stockAile" type="text" value="$(F_AILE)" size="4" maxlength="4"> - <input class="input" id="stockLoc" onfocus="kbActive(this, 'keyboard');" name="stockLoc" type="text" value="$(F_SLOC)" size="8" maxlength="8">
                                            <a href="$(homeURL)$(phpPath)StockLocSearch.php$(altVarBase)&amp;docName=Chg&amp;forWhs=@dtw_rurlescseq(whsNumber)&amp;fldStkr=stockRoom&amp;fldAisle=stockAile&amp;fldLoc=stockLoc&amp;fldStkID=stockLocId&amp;touchScreen=Y" onclick="$(searchWinVar)"> $(searchDesc)</a>
                                            <input name="stockLocId" type="hidden" size="9" maxlength="9">
                          </td>
                      </tr>
                      @DspErrMsg(Err_STKR)
                  %endif

                  @RtvFldDesc("WHWHS=$(F_WHS)", "HDWHSM", "WHWHNM", warehouseName)
                  @SetTextOvr(Err_WHS)
                  <tr><td class="dsphdr"><span $(textOvr)>Warehouse</span></td>
                      <td class="input"><input class="input" id="whsNumber" onfocus="kbActive(this, 'numericKeyboard');" name="whsNumber" type="text" value="$(F_WHS)" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=whsNumber&amp;fldDesc=warehouseName&amp;touchScreen=Y" onclick="$(searchWinVar)"> $(reqFieldChar)  $(searchDesc)</a> <input class="input" name="warehouseName" value="$(warehouseName)" type="text" size="30" maxlength="30" disabled></td>
                  </tr>
                  @DspErrMsg(Err_WHS)

                  @SetTextOvr(Err_DATE)
                  <tr><td class="dsphdr"><span $(textOvr)>**</span></td>
%{-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
Changed Date field to HIDDEN to prevent mistakes from production performing MO Receipts. Also changed line above and removed the word Date inserting two astericks (**) - Bill Busch 12/06/2017
----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------- %}

                      <td class="input"><input class="input" id="transDate" onfocus="kbActive(this, 'dtpDiv');" name="transDate" type="hidden" value="$(F_DATE)" size="6" maxlength="6"> $(reqFieldChar)</td>
                      <td><input name="turnaroundNumber" type="hidden" value="$(V_DCTURN)" size="9"></td>
                  </tr>
                  @DspErrMsg(Err_DATE)  	   		
              %}	
          </table>
          %INCLUDE "KeyboardTS.icl"
          
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSITOR_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(NOUPDATE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(confMessage, "Confirm No Update")
  @dtw_assign(returnURL, "DataCollection.d2w/REPORT$(genericVarBase)")
  %INCLUDE "ReturnTS.icl"
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(stockRoom)
  @dtw_mUPPERCASE(stockAile)
  @dtw_mUPPERCASE(stockLoc)
  @dtw_mUPPERCASE(lotNumber)
  @dtw_mUPPERCASE(lotUdf1)
  @dtw_mUPPERCASE(lotUdf2)
  @dtw_mUPPERCASE(lotUdf3)

  @dtw_assign(transDate,    @dtw_rstrip(transDate))
  @dtw_assign(qtyComplete,  @dtw_rstrip(qtyComplete))
  @dtw_assign(whsNumber,    @dtw_rstrip(whsNumber))
  @dtw_assign(expireDate,   @dtw_rstrip(expireDate))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@turn", turnaroundNumber)
  @Concat_Field("@@date", transDate)
  @Concat_Field("@@qtyc", qtyComplete)
  @Concat_Field("@@whs@", whsNumber)
  @Concat_Field("@@stkr", stockRoom)
  @Concat_Field("@@aile", stockAile)
  @Concat_Field("@@sloc", stockLoc)
  @Concat_Field("@@lotn", lotNumber)
  @Concat_Field("@@dtex", expireDate)
  @Concat_Field("@@udf1", lotUdf1)
  @Concat_Field("@@udf2", lotUdf2)
  @Concat_Field("@@udf3", lotUdf3)
  @Concat_Field("@@dors", closeOrder)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, errFound, edtVar, errVar)

  %if (errFound == "")
      %if (acceptMore == "Y")
          @dtw_assign(confMessage, "Confirm Receipt: Quantity $(qtyComplete)")
          %if (stockRoom != "" || stockAile !="" || stockLoc !="")
              @dtw_concat(confMessage, " Stock Location $(stockRoom) $(stockAile) $(stockLoc)", confMessage)
          %endif
          %if (lotNumber!= "")
              @dtw_concat(confMessage, " Lot Number $(lotNumber)", confMessage)
          %endif
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;turnaroundNumber=@dtw_rurlescseq(turnaroundNumber)&amp;confMessage=@dtw_rurlescseq(confMessage)&amp;errFound=&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
      %else
          @dtw_assign(confMessage, "Confirm Manufacturing Order Receipt")
          @dtw_assign(returnURL, "DataCollection.d2w/REPORT$(genericVarBase)")
          %INCLUDE "ReturnTS.icl"
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;turnaroundNumber=@dtw_rurlescseq(turnaroundNumber)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
