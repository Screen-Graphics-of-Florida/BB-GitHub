%INCLUDE "$(baseVar)"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title		= "EEO Totals"
  d2wName              = "HRCompEEO.d2w"
  d2wVarBase           = "$(genericVarBase)&amp;hrCompany=@dtw_rurlescseq(hrCompany)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName          = "EEO"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  RPT_MAX_ROWS         = "99"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  facilityZero         = "0000"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext	        = "1"
  totalPages	        = "0"	
  attachVarKey         = ""
  attachForDesc        = ""
  quickLinksInUse      = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@hrCompany", "@dtw_rurlescseq(hrCompany)", "1", "a", workURL)
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
                  <table $(baseTable)>
                      <tr valign="top">
                          %if (formatToPrint == "")
                               @dtw_assign(pageID, "HREEOTOTALS")
                              <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                          %endif
                          <td class="content">
                              @dtw_assign(stmtSQL, "")
                              @dtw_concat(stmtSQL, "Select * From HRCOFC ", stmtSQL)
                              @dtw_concat(stmtSQL, " Where CFCOMP = $(hrCompany) and CFFACL = 0", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              @CompEEO_Query(profileHandle, dataBaseID, stmtSQL)
                              %INCLUDE "Copyright.icl"
                          </td>
                      </tr>
                  </table>
                  <!-- Start Of Trailer Code -->
                  %INCLUDE "trailer.icl"
                  <!-- End Of Trailer Code -->
          </body>
      </html>
%}

%FUNCTION(dtw_sql) CompEEO_Query (IN CHAR(64)    profileHandle,
                                     CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
           <tr><td><h1>EEO Totals</h1></td>
               %if (formatToPrint != "Y")
                   <td class="toolbar">
                       %if ((backHome != "")  && (backHome != "$(d2wName)/REPORT"))
                           <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                       %endif
                       %INCLUDE "FormatToPrint.icl"
                       %INCLUDE "HelpPage.icl"
                   </td>
               %endif
           </tr>
           @RetHrCompNam(profileHandle, dataBaseID, hrCompany, facilityZero, coFacName)
           <tr><td><H2> $(coFacName)</H2></td></tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"
      $(hrTagAttr)

      %ROW{
          <table $(contentTable)>
	       <tr>
	           <th class="colhdr">Ethnic Category</th>
	           <th class="colhdr">Male</th>
	           <th class="colhdr">Female</th>
	           <th class="colhdr">Total</th>
	       </tr>

              %INCLUDE "SetRowClass.icl"

              <tr class="$(rowClass)">
                  <td class="colalph"> Black</td>
                  <td class="colnmbr"> $(V_CFMBLK)</td>
                  <td class="colnmbr"> $(V_CFFBLK)</td>
                  @dtw_assign(totBlack, "")
                  @dtw_add(V_CFMBLK, V_CFFBLK, totBlack)
                  <td class="colnmbr"> $(totBlack)</td>
              </tr>
              <tr>
                  <td class="colalph"> Native Hawaiian/Pacific Islander</td>
                  <td class="colnmbr"> $(V_CFMNHP)</td>
                  <td class="colnmbr"> $(V_CFFNHP)</td>
                  @dtw_assign(totNativeHaw, "")
                  @dtw_add(V_CFMNHP, V_CFFNHP, totNativeHaw)
                  <td class="colnmbr"> $(totNativeHaw)</td>
              </tr>
              <tr>
                  <td class="colalph"> Asian</td>
                  <td class="colnmbr"> $(V_CFMASN)</td>
                  <td class="colnmbr"> $(V_CFFASN)</td>
                  @dtw_assign(totAsian, "")
                  @dtw_add(V_CFMASN, V_CFFASN, totAsian)
                  <td class="colnmbr"> $(totAsian)</td>
              </tr>
              <tr class="$(rowClass)">
                  <td class="colalph"> American Indian</td>
                  <td class="colnmbr"> $(V_CFMIND)</td>
                  <td class="colnmbr"> $(V_CFFIND)</td>
                  @dtw_assign(totIndian, "")
                  @dtw_add(V_CFMIND, V_CFFIND, totIndian)
                  <td class="colnmbr"> $(totIndian)</td>
              </tr>
              <tr>
                  <td class="colalph"> Hispanic</td>
                  <td class="colnmbr"> $(V_CFMHIS)</td>
                  <td class="colnmbr"> $(V_CFFHIS)</td>
                  @dtw_assign(totHispanic, "")
                  @dtw_add(V_CFMHIS, V_CFFHIS, totHispanic)
                  <td class="colnmbr"> $(totHispanic)</td>
              </tr>
              <tr>
                  <td class="colalph"> Two Or More Races</td>
                  <td class="colnmbr"> $(V_CFMMOR)</td>
                  <td class="colnmbr"> $(V_CFFMOR)</td>
                  @dtw_assign(totTwoOrMore, "")
                  @dtw_add(V_CFMMOR, V_CFFMOR, totTwoOrMore)
                  <td class="colnmbr"> $(totTwoOrMore)</td>
              </tr>
              <tr class="$(rowClass)">
                  <td class="colalph"> Non Minority</td>
                  @dtw_assign(maleNonMinority, "")
                  @dtw_subtract(V_CFTMAL, V_CFMBLK, maleNonMinority)
                  @dtw_subtract(maleNonMinority, V_CFMNHP, maleNonMinority)
                  @dtw_subtract(maleNonMinority, V_CFMASN, maleNonMinority)
                  @dtw_subtract(maleNonMinority, V_CFMIND, maleNonMinority)
                  @dtw_subtract(maleNonMinority, V_CFMHIS, maleNonMinority)
                  @dtw_subtract(maleNonMinority, V_CFMMOR, maleNonMinority)
                  <td class="colnmbr"> $(maleNonMinority)</td>
                  @dtw_assign(femaleNonMinority, "")
                  @dtw_subtract(V_CFTFEM, V_CFFBLK, femaleNonMinority)
                  @dtw_subtract(femaleNonMinority, V_CFFNHP, femaleNonMinority)
                  @dtw_subtract(femaleNonMinority, V_CFFASN, femaleNonMinority)
                  @dtw_subtract(femaleNonMinority, V_CFFIND, femaleNonMinority)
                  @dtw_subtract(femaleNonMinority, V_CFFHIS, femaleNonMinority)
                  @dtw_subtract(femaleNonMinority, V_CFFMOR, femaleNonMinority)
                  <td class="colnmbr"> $(femaleNonMinority)</td>
                  @dtw_assign(totNonMinority, "")
                  @dtw_add(maleNonMinority, femaleNonMinority, totNonMinority)
                  <td class="colnmbr"> $(totNonMinority)</td>
              </tr>
              <tr>
                  <td class="colalph"> Total</td>
                  <td class="colnmbr"> $(V_CFTMAL)</td>
                  <td class="colnmbr"> $(V_CFTFEM)</td>
                  <td class="colnmbr"> $(V_CFTEMP)</td>
              </tr>
          </table>
      %}
      $(hrTagAttr)
      %INCLUDE "PageBottom.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      @Set_SQL(stmtSQL)
  %endif
%}
