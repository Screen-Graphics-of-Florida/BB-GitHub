*********************************************************************
%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Feature Routing Maintenance"
  d2wName                 = "FeatureRoutingMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(fromPlant)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;feature=@dtw_rurlescseq(feature)&amp;featuredItem=@dtw_rurlescseq(featuredItem)&amp;featureDesc=@dtw_rurlescseq(featureDesc)&amp;sequenceNumber=@dtw_rurlescseq(sequenceNumber)&amp;maintenanceCode=D"
  programName             = "HPD021"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  plant                   = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  function validate(chgForm) {
                      if (document.Chg.sequenceNumber.value =="" ||
                          document.Chg.department.value =="" ||
                          document.Chg.workCenter.value =="" ||
                          document.Chg.rtgType.value =="" ||
                          document.Chg.altOperation.value =="")
                             {alert("$(reqFieldError)");
                              return false;}
                      if (editNum(document.Chg.sequenceNumber, 3, 0) &&
                          editNum(document.Chg.measuredHours, 3, 4) &&
                          editNum(document.Chg.crewSize, 3, 2) &&
                          editNum(document.Chg.setupHours, 3, 2) &&
                          editNum(document.Chg.perUnitRate, 8, 5) &&
                          editNum(document.Chg.transitDays, 3, 1))
                          return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
	           %INCLUDE "numedit.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "FEATUREROUTINGMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "Select * from HDMFRM", stmtSQL)
                              @dtw_concat(stmtSQL, " Where FRPLT=$(plantNumber)", stmtSQL)
                              @dtw_concat(stmtSQL, " and FRFEAT='$(feature)'", stmtSQL)
                              @dtw_concat(stmtSQL, " and FRFITM='$(featuredItem)'", stmtSQL)
                              @dtw_concat(stmtSQL, " and FRSEQN=$(sequenceNumber)", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
          @Format_Header("Plant", $(plantName), $(plantNumber))
          @Format_Header("Feature", $(featureDesc), $(feature))
          %if (featuredItem != "")
              @dtw_assign(itemDescription, "")
              @RtvFldDesc("IMITEM='$(featuredItem)'", "HDIMST", "IMIMDS", itemDescription)
              %if (itemDescription =="")
                  @RtvFldDesc("IGTYPE='F' and IGIGRP='$(featuredItem)' and IGPLT=$(plantNumber)", "HDIGPH", "IGDESC", itemDescription)
              %endif
              @Format_Header("Featured Item/Family", $(itemDescription), $(featuredItem))
          %endif
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;feature=@dtw_rurlescseq(feature)&amp;featuredItem=@dtw_rurlescseq(featuredItem)&amp;featureDesc=@dtw_rurlescseq(featureDesc)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "sequenceNumber")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@plt@", "plantNumber")        @dtw_assign(Err_FRPLT,  fieldValue)
                          @DecatErr_Field("@@feat", "feature")            @dtw_assign(Err_FRFEAT, fieldValue)
                          @DecatErr_Field("@@fitm", "featuredItem")       @dtw_assign(Err_FRFITM, fieldValue)
                          @DecatErr_Field("@@seqn", "sequenceNumber")     @dtw_assign(Err_FRSEQN, fieldValue)
                          @DecatErr_Field("@@dept", "department")         @dtw_assign(Err_FRDEPT, fieldValue)
                          @DecatErr_Field("@@wc@@", "workCenter")         @dtw_assign(Err_FRWC,   fieldValue)
                          @DecatErr_Field("@@son@", "operNumber")         @dtw_assign(Err_FRSON,  fieldValue)
                          @DecatErr_Field("@@rtyp", "rtgType")            @dtw_assign(Err_FRRTYP, fieldValue)
                          @DecatErr_Field("@@altc", "altOperation")       @dtw_assign(Err_FRALTC, fieldValue)
                          @DecatErr_Field("@@mhrs", "measuredHours")      @dtw_assign(Err_FRMHRS, fieldValue)
                          @DecatErr_Field("@@mhrc", "measHoursRef")       @dtw_assign(Err_FRMHRC, fieldValue)
                          @DecatErr_Field("@@mpon", "crewSize")           @dtw_assign(Err_FRMPON, fieldValue)
                          @DecatErr_Field("@@suhr", "setupHours")         @dtw_assign(Err_FRSUHR, fieldValue)
                          @DecatErr_Field("@@surc", "setupHoursRef")      @dtw_assign(Err_FRSURC, fieldValue)
                          @DecatErr_Field("@@psuc", "perUnitRate")        @dtw_assign(Err_FRPSUC, fieldValue)
                          @DecatErr_Field("@@lgrd", "laborGrade")         @dtw_assign(Err_FRLGRD, fieldValue)
                          @DecatErr_Field("@@mach", "machineNumber")      @dtw_assign(Err_FRMACH, fieldValue)
                          @DecatErr_Field("@@mtd@", "transitDays")        @dtw_assign(Err_FRMTD,  fieldValue)
                          @DecatErr_Field("@@fort", "factorMeasHrs")      @dtw_assign(Err_FRFORT, fieldValue)
                      %endif
                      @Decat_Field("@@plt@")   @dtw_assign(V_FRPLT,  fieldValue)
                      @Decat_Field("@@feat")   @dtw_assign(V_FRFEAT, fieldValue)
                      @Decat_Field("@@fitm")   @dtw_assign(V_FRFITM, fieldValue)
                      @Decat_Field("@@seqn")   @dtw_assign(V_FRSEQN, fieldValue)
                      @Decat_Field("@@dept")   @dtw_assign(V_FRDEPT, fieldValue)
                      @Decat_Field("@@wc@@")   @dtw_assign(V_FRWC,   fieldValue)
                      @Decat_Field("@@son@")   @dtw_assign(V_FRSON,  fieldValue)
                      @Decat_Field("@@rtyp")   @dtw_assign(V_FRRTYP, fieldValue)
                      @Decat_Field("@@altc")   @dtw_assign(V_FRALTC, fieldValue)
                      @Decat_Field("@@mhrs")   @dtw_assign(V_FRMHRS, fieldValue)
                      @Decat_Field("@@mhrc")   @dtw_assign(V_FRMHRC, fieldValue)
                      @Decat_Field("@@mpon")   @dtw_assign(V_FRMPON, fieldValue)
                      @Decat_Field("@@suhr")   @dtw_assign(V_FRSUHR, fieldValue)
                      @Decat_Field("@@surc")   @dtw_assign(V_FRSURC, fieldValue)
                      @Decat_Field("@@psuc")   @dtw_assign(V_FRPSUC, fieldValue)
                      @Decat_Field("@@lgrd")   @dtw_assign(V_FRLGRD, fieldValue)
                      @Decat_Field("@@mach")   @dtw_assign(V_FRMACH, fieldValue)
                      @Decat_Field("@@mtd@")   @dtw_assign(V_FRMTD,  fieldValue)
                      @Decat_Field("@@fort")   @dtw_assign(V_FRFORT, fieldValue)
                      @Decat_Field("@@ntcd")   @dtw_assign(V_FRNTCD, fieldValue)
                      @Decat_Field("@@fseq")   @dtw_assign(frmseq,   fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(V_FRSEQN, "")
                          @dtw_assign(V_FRRTYP, "D")
                          @dtw_assign(V_FRALTC, "P")
                          @dtw_assign(focusField, "sequenceNumber")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(frmseq, $(sequenceNumber))
                      @dtw_assign(V_FRSEQN, "")
                      @dtw_assign(focusField, "sequenceNumber")
                  %else
                      @dtw_assign(focusField, "department")
                  %endif

                  @SetTextOvr(Err_FRSEQN)
                  <tr><td class="dsphdr"><span $(textOvr)>Routing Sequence</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="sequenceNumber" type="text" value="$(V_FRSEQN)" size="5" maxlength="3"> $(reqFieldChar) </td>
                      %else
                          <td class="inputnmbr"><input name="sequenceNumber" type="hidden" value="$(V_FRSEQN)" size="5" maxlength="3">$(V_FRSEQN)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_FRSEQN)

                  <tr><td><input type="hidden" name="frmseq" value="$(frmseq)" </td></tr>

                  @Default_Zero(V_FRPLT)
                  @dtw_assign(deptwcDesc, "")
                  @RtvFldDesc("WCPLT=$(V_FRPLT) and WCDEPT='$(V_FRDEPT)' and WCWC='$(V_FRWC)'", "HDMWCM", "WCDESC", deptwcDesc)
                  @SetTextOvr(Err_FRDEPT)
                  <tr><td class="dsphdr"><span $(textOvr)>Department / Work Center</span></td>
                      <td class="inputalph"><input name="department" value="$(V_FRDEPT)" type="text" size="5" maxlength="5"> / <input name="workCenter" value="$(V_FRWC)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(plantNumber)&amp;docName=Chg&amp;flddept=department&amp;fldWC=workCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="WCDesc" value="$(deptwcDesc)"  type="text" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_FRDEPT)
  	   		
                  @RtvFldDesc("SDSON='$(V_FRSON)'", "HDMSDM", "SDDESC", operDesc)
                  @SetTextOvr(Err_FRSON)
                  <tr><td class="dsphdr"><span $(textOvr)>Operation Number</span></td>
                      <td class="inputalph"><input name="operNumber" value="$(V_FRSON)" type="text" size="5" maxlength="5"> <a href="$(homeURL)$(cGIPath)OperationSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldoper=operNumber&amp;fldDesc=operDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="operDesc" value="$(operDesc)" type="text" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_FRSON)
    	      		
                  @RtvFldDesc("FLTYPE='RTGTYPE' and FLVALU='$(V_FRRTYP)'", "SYFLAG", "FLDESC", rtypDesc)
                  @SetTextOvr(Err_FRRTYP)
                  <tr><td class="dsphdr"><span $(textOvr)>Routing Type</span></td>
                      <td class="inputalph"><input name="rtgType" type="text" value="$(V_FRRTYP)" size="5" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=RTGTYPE&amp;flagSrchHdr=@dtw_rurlescseq("Routing Type")&amp;docName=Chg&amp;fldName=rtgType&amp;fldDesc=routingtypeDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a>
                      <input disabled name="routingtypeDesc" value="$(rtypDesc)" type="text" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_FRRTYP)

                  @RtvFldDesc("FLTYPE='ALTOPER' and FLVALU='$(V_FRALTC)'", "SYFLAG", "FLDESC", altcDesc)
                  @SetTextOvr(Err_FRALTC)
                  <tr><td class="dsphdr"><span $(textOvr)>Alternate Operation</span></td>
                      <td class="inputalph"><input type="text" name="altOperation" value="$(V_FRALTC)" size="5" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=ALTOPER&amp;flagSrchHdr=@dtw_rurlescseq("Alternate Operation")&amp;docName=Chg&amp;fldName=altOperation&amp;fldDesc=alternateoperationDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a>
                      <input disabled name="alternateoperationDesc" value="$(altcDesc)" type="text" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_FRALTC)
    	   		
                  @SetTextOvr(Err_FRMHRS)
                  <tr><td class="dsphdr"><span $(textOvr)>Measured Hours</span></td>
                      <td class="inputnmbr"><input type="text" name="measuredHours" value="$(V_FRMHRS)" size="8" maxlength="8"></td>
                  </tr>
                  @DspErrMsg(Err_FRMHRS)
    	   		
                  @RtvFldDesc("FLTYPE='RTMHRC' and FLVALU='$(V_FRMHRC)'", "SYFLAG", "FLDESC", mhrcDesc)
                  @SetTextOvr(Err_FRMHRC)
                  <tr><td class="dsphdr"><span $(textOvr)>Measured Hours Ref Code</span></td>
                      <td class="inputalph"><input type="text" name="measHoursRef" value="$(V_FRMHRC)" size="5" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=RTMHRC&amp;flagSrchHdr=@dtw_rurlescseq("Measured Hours Reference Code")&amp;docName=Chg&amp;fldName=measHoursRef&amp;fldDesc=measuredhoursrefDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                      <input name="measuredhoursrefDesc" value="$(mhrcDesc)" type="text" size="30" disabled></td>
                  </tr>
                  @DspErrMsg(Err_FRMHRC)

                  @SetTextOvr(Err_FRMPON)
                  <tr><td class="dsphdr"><span $(textOvr)>Crew Size</span></td>
                      <td class="inputnmbr"><input type="text" name="crewSize" value="$(V_FRMPON)" size="6" maxlength="6"></td>
                  </tr>
                  @DspErrMsg(Err_FRMPON)
    	   		
                  @SetTextOvr(Err_FRSUHR)
                  <tr><td class="dsphdr"><span $(textOvr)>Setup Hours</span></td>
                      <td class="inputnmbr"><input type="text" name="setupHours" value="$(V_FRSUHR)" size="6" maxlength="6"></td>
                  </tr>
                  @DspErrMsg(Err_FRSUHR)
    	   		
                  @RtvFldDesc("FLTYPE='RTSURC' and FLVALU='$(V_FRSURC)'", "SYFLAG", "FLDESC", surcDesc)
                  @SetTextOvr(Err_FRSURC)
                  <tr><td class="dsphdr"><span $(textOvr)>Setup Hours Ref Code</span></td>
                      <td class="inputalph"><input type="text" name="setupHoursRef" value="$(V_FRSURC)" size="5" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=RTSURC&amp;flagSrchHdr=@dtw_rurlescseq("Setup Hours Reference Code")&amp;docName=Chg&amp;fldName=setupHoursRef&amp;fldDesc=setuphoursrefDesc" onclick="$(searchWinVar)">  $(searchImage) </a>
                      <input disabled name="setuphoursrefDesc" value="$(surcDesc)" type="text" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_FRSURC)

                  @SetTextOvr(Err_FRPSUC)
                  <tr><td class="dsphdr"><span $(textOvr)>Per Unit Rate</span></td>
                      <td class="inputnmbr"><input type="text" name="perUnitRate" value="$(V_FRPSUC)" size="14" maxlength="14"></td>
                  </tr>
                  @DspErrMsg(Err_FRPSUC)
    	   		
                  @SetTextOvr(Err_FRLGRD)
                  <tr><td class="dsphdr"><span $(textOvr)>Labor Grade</span></td>
                      <td class="inputalph"><input type="text" name="laborGrade" value="$(V_FRLGRD)" size="5" maxlength="2"></td>
                  </tr>
                  @DspErrMsg(Err_FRLGRD)

                  @SetTextOvr(Err_FRMACH)
                  <tr><td class="dsphdr"><span $(textOvr)>Machine Number</span></td>
                      <td class="inputalph"><input type="text" name="machineNumber" value="$(V_FRMACH)" size="5" maxlength="5"></td>
                  </tr>
                  @DspErrMsg(Err_FRMACH)

                  @SetTextOvr(Err_FRMTD)
                  <tr><td class="dsphdr"><span $(textOvr)>Transit Days</span></td>
                      <td class="inputnmbr"><input type="text" name="transitDays" value="$(V_FRMTD)" size="5" maxlength="5"></td>
                  </tr>
                  @DspErrMsg(Err_FRMTD)
    	   		
                  @SetTextOvr(Err_FRFORT)
                  <tr><td class="dsphdr"><span $(textOvr)>Factor Measured Hours</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_FRFORT) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "factorMeasHours", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_FRFORT)

                  @SetTextOvr(Err_FRNTCD)
                  <tr><td class="dsphdr"><span $(textOvr)>Routing Notes</span></td>
                      <td class="inputalph"><input type="hidden" name="routingNotes" value="$(V_FRNTCD)" size="1" maxlength="1">$(V_FRNTCD)</td>
                  </tr>
                  @DspErrMsg(Err_FRNTCD)

                  <script TYPE="text/javascript">
                      document.Chg.$(focusField).focus();
                  </script>
    	   		
              %}	
          </table>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar,
                                        INOUT CHAR(10)    SUBR)
{%EXEC {HPD021_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @yn01_Table_Query(profileHandle, dataBaseID, "BY        ", yn01Table)

      @Set_SQL(stmtSQL)
  %endif
%}

%FUNCTION(dtw_directcall) Validate_COPYALL(INOUT CHAR(64)    profileHandle,
                                           INOUT CHAR(2)     dataBaseID,
                                           INOUT CHAR(1)     maintenanceCode,
                                           INOUT CHAR(1)     errFound,
                                           INOUT CHAR(32000) edtVar,                             	
                                           INOUT CHAR(32000) errVar,
                                           INOUT CHAR(10)    SUBR)

{%EXEC {HPD021_W.PGM %}
%}

%HTML(COPYALL) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
	       %INCLUDE "numedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
              function validate(chgForm) {
                 if (document.Chg.toplantNumber.value =="" ||
                     document.Chg.toFeature.value =="")
                       {alert("$(reqFieldError)");
                           return false;}
                 if (editNum(document.Chg.toplantNumber, 3, 0))
                          return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "FEATUREROUTINGMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      <table $(contentTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1>Copy Feature Routing</h1></td>
                              <td class="toolbar">
                              %INCLUDE "MaintainTopNoTable.icl"
                              </td>
                          </tr>
                      </table>
                      <table $(contentTable)>
                          @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
                          @Format_Header("Plant", $(plantName), $(plantNumber))
                          @Format_Header("Feature", $(featureDesc), $(feature))
                          %if (featuredItem != "")
                              @dtw_assign(itemDescription, "")
                              @RtvFldDesc("IMITEM='$(featuredItem)'", "HDIMST", "IMIMDS", itemDescription)
                              %if (itemDescription =="")
                                  @RtvFldDesc("IGTYPE='F' and IGIGRP='$(featuredItem)' and IGPLT=$(plantNumber)", "HDIGPH", "IGDESC", itemDescription)
                              %endif
                              @Format_Header("Featured Item/Family", $(itemDescription), $(featuredItem))
                          %endif
                      </table>
                      $(hrTagAttr)
                      %INCLUDE "RequiredField.icl"
                      %INCLUDE "ErrorDisplay.icl"

                      <form class="formClass" METHOD=POST name="Chg" onSubmit="return validate(document.Chg)"
                          ACTION="$(homeURL)$(cGIPath)$(d2wName)/EDIT_COPYALL$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;feature=@dtw_rurlescseq(feature)&amp;featuredItem=@dtw_rurlescseq(featuredItem)&amp;featureDesc=@dtw_rurlescseq(featureDesc)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "toplantNumber")
                              %if (errFound != "" || maintenanceCode == "A")
                                  %if (errFound == "" && maintenanceCode == "A")
                                      @dtw_assign(edtVar, "")
                                  %else
                                      @EdtVarErr(profileHandle, typeValue, edtVar)
                                      @ErrVarErr(profileHandle, typeError, errVar)
                                      @DecatErr_Field("@@tplt", "toplantNumber")   @dtw_assign(Err_TOPLT,  fieldValue)
                                      @DecatErr_Field("@@tfea", "toFeature")       @dtw_assign(Err_TOFEAT, fieldValue)
                                      @DecatErr_Field("@@tfit", "tofeaturedItem")  @dtw_assign(Err_TOFITM, fieldValue)
                                  %endif

                                  @Decat_Field("@@tplt")   @dtw_assign(V_FRPLT,  fieldValue)
                                  @Decat_Field("@@tfea")   @dtw_assign(V_FRFEAT, fieldValue)
                                  @Decat_Field("@@tfit")   @dtw_assign(V_FRFITM, fieldValue)

                                  @dtw_assign(errFound, "")

                              %elif (maintenanceCode == "Z")
                                  @dtw_assign(V_FRPLT,  "")
                                  @dtw_assign(V_FRFEAT, "")
                                  @dtw_assign(V_FRFITM, "")
                              %endif

                              @Default_Zero(V_FRPLT)
                              @RtvFldDesc("PLPLNT=$(V_FRPLT)", "HDPLNT", "PLNAME", toplantName)
                              @SetTextOvr(Err_TOPLT)
                              <tr><td class="dsphdr"><span $(textOvr)>To Plant Number</span></td>
                                  <td class="inputnmbr"><input name="toplantNumber" value="$(V_FRPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toplantNumber&amp;fldDesc=toplantName" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="toplantName" value="$(toplantName)" type="text" size="30"></td>
                              </tr>
                              @DspErrMsg(Err_TOPLT)

                              @RtvFldDesc("FOPLT=$(V_FRPLT) and FOFPRT='$(V_FRFITM)' and FOFEAT='$(V_FRFEAT)'", "HDMFOP", "FOFDSC", tofeatureDesc)
                              %if (tofeatureDesc == "")
                                  @RtvFldDesc("FOPLT=$(V_FRPLT) and FOFPRT='' and FOFEAT='$(V_FRFEAT)'", "HDMFOP", "FOFDSC", tofeatureDesc)
                              %endif
                              @SetTextOvr(Err_TOFEAT)
                              <tr><td class="dsphdr"><span $(textOvr)>To Feature</span></td>
                                  <td class="inputalph"><input name="toFeature" type="text" value="$(V_FRFEAT)" size="15" maxlength="15"> $(reqFieldChar) <input name="tofeatureDesc" type="hidden" value="$(tofeatureDesc)">$(tofeatureDesc)</td>
                              </tr>
                              @DspErrMsg(Err_TOFEAT)

                              @dtw_assign(toitemDescription, "")
                              @RtvFldDesc("IMITEM='$(V_FRFITM)'", "HDIMST", "IMIMDS", toitemDescription)
                              %if (featuredItemDesc =="")
                                  @RtvFldDesc("IGTYPE='F' and IGIGRP='$(V_FRFITM)' and IGPLT=$(plantNumber)", "HDIGPH", "IGDESC", toitemDescription)
                              %endif
                              @SetTextOvr(Err_TOFITM)
	                       <tr><td class="dsphdr"><span $(textOvr)>To Featured Item/Family</span></td>
                                  <td class="inputalph"><input name="tofeaturedItem" value="$(V_FRFITM)" type="text" size="15" maxlength="15">
                                      @dtw_assign(searchTitle, "Item")
                                      <a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=tofeaturedItem&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a>
                                      /
                                      @dtw_assign(searchTitle, "Feature Family")
                                      <a href="$(homeURL)$(cGIPath)ItemGroupSearch.d2w/ENTRY$(genericVarBase)&amp;groupType=F&amp;docName=Chg&amp;fldName=tofeaturedItem&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a>
                                      <input disabled name="toitemDescription" value="$(toitemdescription)" type="text" size="30"></td>
                              </tr>
                              @DspErrMsg(Err_TOFITM)
                          </table>
                          %INCLUDE "MaintainBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </form>
                  </td>
              </tr>
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(EDIT_COPYALL) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(toFeature)
  @dtw_mUPPERCASE(tofeaturedItem)
  @dtw_assign(toplantNumber,@dtw_rstrip(toplantNumber))
  @dtw_assign(SUBR, "SRCpyAll")

  @dtw_assign(edtVar, "")
  @Concat_Field("@@fplt", plantNumber)
  @Concat_Field("@@ffea", feature)
  @Concat_Field("@@ffit", featuredItem)
  @Concat_Field("@@tplt", toplantNumber)
  @Concat_Field("@@tfea", toFeature)
  @Concat_Field("@@tfit", tofeaturedItem)
  @Concat_Field("@@rtgt", "F")
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_COPYALL(profileHandle, dataBaseID, maintCode, errFound, edtVar, errVar, SUBR)

  %if (errFound == "")
      @RtvFldDesc("FOPLT=$(toplantNumber) and FOFPRT='$(tofeaturedItem)' and FOFEAT='$(toFeature)'", "HDMFOP", "FOFDSC", tofeatureDesc)
      %if (tofeatureDesc == "")
          @RtvFldDesc("FOPLT=$(toplantNumber) and FOFPRT='' and FOFEAT='$(toFeature)'", "HDMFOP", "FOFDSC", tofeatureDesc)
      %endif
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)FeatureRouting.d2w/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(toplantNumber)&amp;feature=@dtw_rurlescseq(toFeature)&amp;featuredItem=@dtw_rurlescseq(tofeaturedItem)&amp;featureDesc=@dtw_rurlescseq(tofeatureDesc)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/COPYALL$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;feature=@dtw_rurlescseq(feature)&amp;featuredItem=@dtw_rurlescseq(featuredItem)&amp;featureDesc=@dtw_rurlescseq(featureDesc)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}

%FUNCTION(dtw_directcall) Validate_DELETEALL(INOUT CHAR(64)    profileHandle,
                                             INOUT CHAR(2)     dataBaseID,
                                             INOUT CHAR(1)     maintenanceCode,
                                             INOUT CHAR(1)     errFound,
                                             INOUT CHAR(32000) edtVar,                             	
                                             INOUT CHAR(32000) errVar,
                                             INOUT CHAR(10)    SUBR)
{%EXEC {HPD021_W.PGM %}
%}

%HTML(DELETEALL) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(SUBR, "SRDelAll")

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@feat", feature)
  @Concat_Field("@@fitm", featuredItem)
  @Concat_Field("@@rtgt", "F")
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_DELETEALL(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar, SUBR)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, "All Routings", "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)FeatureRouting.d2w/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;feature=@dtw_rurlescseq(feature)&amp;featuredItem=@dtw_rurlescseq(featuredItem)&amp;featureDesc=@dtw_rurlescseq(featureDesc)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @DecatErr_Field("@@plt@", "sequenceNumber")  @dtw_assign(confMessage, "$(fieldValue)")
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)FeatureRouting.d2w/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;feature=@dtw_rurlescseq(feature)&amp;featuredItem=@dtw_rurlescseq(featuredItem)&amp;featureDesc=@dtw_rurlescseq(featureDesc)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(feature)
  @dtw_mUPPERCASE(featuredItem)
  @dtw_mUPPERCASE(department)
  @dtw_mUPPERCASE(workCenter)
  @dtw_mUPPERCASE(operNumber)
  @dtw_mUPPERCASE(rtgType)
  @dtw_mUPPERCASE(altOperation)
  @dtw_mUPPERCASE(measHoursRef)
  @dtw_mUPPERCASE(setupHoursRef)
  @dtw_mUPPERCASE(laborGrade)
  @dtw_mUPPERCASE(machineNumber)
  @dtw_mUPPERCASE(factorMeasHours)

  @dtw_assign(plantNumber,   @dtw_rstrip(plantNumber))
  @dtw_assign(sequenceNumber,@dtw_rstrip(sequenceNumber))
  @dtw_assign(measuredHours, @dtw_rstrip(measuredHours))
  @dtw_assign(crewSize,      @dtw_rstrip(crewSize))
  @dtw_assign(setupHours,    @dtw_rstrip(setupHours))
  @dtw_assign(perUnitRate,   @dtw_rstrip(perUnitRate))
  @dtw_assign(transitDays,   @dtw_rstrip(transitDays))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@feat", feature)
  @Concat_Field("@@fitm", featuredItem)

  @Concat_Field("@@seqn", sequenceNumber)
  @Concat_Field("@@dept", department)
  @Concat_Field("@@wc@@", workCenter)
  @Concat_Field("@@son@", operNumber)
  @Concat_Field("@@rtyp", rtgType)
  @Concat_Field("@@altc", altOperation)
  @Concat_Field("@@mhrs", measuredHours)
  @Concat_Field("@@mhrc", measHoursRef)
  @Concat_Field("@@mpon", crewSize)
  @Concat_Field("@@suhr", setupHours)
  @Concat_Field("@@surc", setupHoursRef)
  @Concat_Field("@@psuc", perUnitRate)
  @Concat_Field("@@lgrd", laborGrade)
  @Concat_Field("@@mach", machineNumber)
  @Concat_Field("@@mtd@", transitDays)
  @Concat_Field("@@fort", factorMeasHours)
  @Concat_Field("@@ntcd", routingNotes)
  @Concat_Field("@@rtgt", "F")
  @Concat_Field("@@fseq", frmseq)
  @dtw_concat(edtVar, "}{", edtVar)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(SUBR, "")

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar, SUBR)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, "Routing Sequence", $(sequenceNumber), "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)FeatureRouting.d2w/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;feature=@dtw_rurlescseq(feature)&amp;featuredItem=@dtw_rurlescseq(featuredItem)&amp;featureDesc=@dtw_rurlescseq(featureDesc)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@dept", "department")
      @Format_ConfMsg_Desc("", "Routing Sequence", $(sequenceNumber), "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)FeatureRouting.d2w/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;feature=@dtw_rurlescseq(feature)&amp;featuredItem=@dtw_rurlescseq(featuredItem)&amp;featureDesc=@dtw_rurlescseq(featureDesc)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;feature=@dtw_rurlescseq(feature)&amp;featuredItem=@dtw_rurlescseq(featuredItem)&amp;featureDesc=@dtw_rurlescseq(featureDesc)&amp;sequenceNumber=@dtw_rurlescseq(sequenceNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
