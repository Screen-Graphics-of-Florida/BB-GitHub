%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"

%Define {	
  page_title              = "Single Level Where Used"
  d2wName                 = "ProductStructureWhereUsedInquiry.d2w"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "ALL"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}
	
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onLoad="window.focus()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      @SystemDate(todaysDate)
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select PSPPLT, PSPPN, PSSEQN, PSCPN, PSSCPP, PSQPER, PSREFN, PSFSTK, IMIMDS, IPPTYP, IMUOMS ", stmtSQL)
                      @dtw_concat(fileSQL, " HDMPSM Inner Join (HDIPLT Join HDIMST on IPITEM=IMITEM) On PSPPLT=IPPLT and PSPPN=IPITEM", fileSQL)
                      @dtw_concat(selectSQL, " PSPPLT=$(plantNumber) and PSCPN='$(itemNumber)' ", selectSQL)
                      @dtw_concat(selectSQL, " and $(todaysDate)>=PSSTDT and $(todaysDate)<=PSDSDT ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By PSPPLT, PSCPN, PSSEQN, PSPPN, PSREFN ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @WhereUsed_Inquiry(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) WhereUsed_Inquiry (IN CHAR(64)    profileHandle,
				          CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"

      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMUOMS", stockUOM)
      @RtvFldDesc("UMUOM='$(stockUOM)'", "HDUOM", "UMUMLD", stockUOMDesc)
      @RtvFldDesc("IPITEM='$(itemNumber)' and IPPLT=$(plantNumber)", "HDIPLT", "IPPTYP", partType)
      @RtvFldDesc("FLTYPE='PARTTYPE' and FLVALU='$(partType)'", "SYFLAG", "FLDESC", partTypeDesc)
      <table $(contentTable)>
          @Format_Header("Plant", $(plantName), $(plantNumber))
          @Format_Header("Item", $(itemDescription), $(itemNumber))
          @Format_Header("Part Type", $(partTypeDesc), $(partType))
          @Format_Header("Unit Of Measure", $(stockUOMDesc), $(stockUOM))
      </table>

      $(inquiryhrTagAttr)
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLRSF", plrsf)
      <table $(contentTable)>
         <tr>
              %if (plrsf == "Y")
                  <th class="colhdr">Rtg<br>Seq</th>
              %endif
              <th class="colhdr">Parent Item</th>
              <th class="colhdr">Description</th>
              <th class="colhdr">Part<br>Type</th>
              <th class="colhdr">UM</th>
              <th class="colhdr">Scrap<br>%</th>
              <th class="colhdr">Qty Per</th>
              <th class="colhdr">Eng Ref</th>
              <th class="colhdr">B<br>C</th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"
              %ROW{
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                     %if (plrsf == "Y")
                         <td class="colnmbr">$(V_PSSEQN)</td>
                     %endif
                     <td class="colalph">$(V_PSPPN)</td>
                     <td class="colalph">$(V_IMIMDS)</td>
                     <td class="colcode">$(V_IPPTYP)</td>
                     <td class="colalph">$(V_IMUOMS)</td>
                     <td class="colnmbr">$(V_PSSCPP)</td>
                     <td class="colnmbr">$(V_PSQPER)</td>
                     <td class="colalph">$(V_PSREFN)</td>
                     <td class="colalph">$(V_PSFSTK)</td>
                  </tr>

              %}
      </table>
      $(inquiryhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(RPT_MAX_ROWS, "ALL")
  @Set_SQL(stmtSQL)
%}