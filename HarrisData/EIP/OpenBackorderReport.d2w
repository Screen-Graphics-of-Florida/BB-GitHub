%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Open Backorder Report"
  d2wName                 = "OpenBackorderReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "4"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromWarehouse, 3, 0) &&
                      editNum(document.Chg.toWarehouse, 3, 0) &&
                      editNum(document.Chg.fromBillToCustomer, 7, 0) &&
                      editNum(document.Chg.toBillToCustomer, 7, 0) &&
                      editdate(document.Chg.fromRequiredDate) &&
                      editdate(document.Chg.toRequiredDate) &&
                      editFromToAll(document.Chg.fromWarehouse, document.Chg.toWarehouse, document.Chg.allWarehouse, 3) &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromBillToCustomer, document.Chg.toBillToCustomer, document.Chg.allBillToCustomer, 7) &&
                      editFromToAll(document.Chg.fromRequiredDate, document.Chg.toRequiredDate, document.Chg.allRequiredDate, "D"))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "OPENBACKORDERREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromWarehouse")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@fwhs", "fromWarehouse")        @dtw_assign(Err_N2FWHS,  fieldValue)
                                  @DecatErr_Field("@@twhs", "toWarehouse")        @dtw_assign(Err_N2TWHS,  fieldValue)
                                  @DecatErr_Field("@@awhs", "allWarehouse")        @dtw_assign(Err_N2AWHS,  fieldValue)
                                  @DecatErr_Field("@@swhs", "sortWarehouse")        @dtw_assign(Err_N2SWHS,  fieldValue)
                                  @DecatErr_Field("@@pwhs", "totalWarehouse")        @dtw_assign(Err_N2PWHS,  fieldValue)
                                  @DecatErr_Field("@@fitm", "fromItemNumber")        @dtw_assign(Err_N2FITM,  fieldValue)
                                  @DecatErr_Field("@@titm", "toItemNumber")        @dtw_assign(Err_N2TITM,  fieldValue)
                                  @DecatErr_Field("@@aitm", "allItemNumber")        @dtw_assign(Err_N2AITM,  fieldValue)
                                  @DecatErr_Field("@@sitm", "sortItemNumber")        @dtw_assign(Err_N2SITM,  fieldValue)
                                  @DecatErr_Field("@@pitm", "totalItemNumber")        @dtw_assign(Err_N2PITM,  fieldValue)
                                  @DecatErr_Field("@@fblt", "fromBillToCustomer")          @dtw_assign(Err_N2FBLT,  fieldValue)
                                  @DecatErr_Field("@@tblt", "toBillToCustomer")          @dtw_assign(Err_N2TBLT,  fieldValue)
                                  @DecatErr_Field("@@ablt", "allBillToCustomer")          @dtw_assign(Err_N2ABLT,  fieldValue)
                                  @DecatErr_Field("@@sblt", "sortBillToCustomer")          @dtw_assign(Err_N2SBLT,  fieldValue)
                                  @DecatErr_Field("@@pblt", "totalBillToCustomer")          @dtw_assign(Err_N2PBLT,  fieldValue)
                                  @DecatErr_Field("@@frdt", "fromRequiredDate")        @dtw_assign(Err_N2FRDT,  fieldValue)
                                  @DecatErr_Field("@@trdt", "toRequiredDate")        @dtw_assign(Err_N2TRDT,  fieldValue)
                                  @DecatErr_Field("@@ardt", "allRequiredDate")        @dtw_assign(Err_N2ARDT,  fieldValue)
                                  @DecatErr_Field("@@srdt", "sortRequiredDate")        @dtw_assign(Err_N2SRDT,  fieldValue)
                                  @DecatErr_Field("@@prdt", "totalRequiredDate")        @dtw_assign(Err_N2PRDT,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@fwhs")  @dtw_assign(V_N2FWHS,  fieldValue)
                                  @Decat_Field("@@twhs")  @dtw_assign(V_N2TWHS,  fieldValue)
                                  @Decat_Field("@@awhs")  @dtw_assign(V_N2AWHS,  fieldValue)
                                  @Decat_Field("@@swhs")  @dtw_assign(V_N2SWHS,  fieldValue)
                                  @Decat_Field("@@pwhs")  @dtw_assign(V_N2PWHS,  fieldValue)
                                  @Decat_Field("@@fitm")  @dtw_assign(V_N2FITM,  fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N2TITM,  fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N2AITM,  fieldValue)
                                  @Decat_Field("@@sitm")  @dtw_assign(V_N2SITM,  fieldValue)
                                  @Decat_Field("@@pitm")  @dtw_assign(V_N2PITM,  fieldValue)
                                  @Decat_Field("@@fblt")  @dtw_assign(V_N2FBLT,  fieldValue)
                                  @Decat_Field("@@tblt")  @dtw_assign(V_N2TBLT,  fieldValue)
                                  @Decat_Field("@@ablt")  @dtw_assign(V_N2ABLT,  fieldValue)
                                  @Decat_Field("@@sblt")  @dtw_assign(V_N2SBLT,  fieldValue)
                                  @Decat_Field("@@pblt")  @dtw_assign(V_N2PBLT,  fieldValue)
                                  @Decat_Field("@@frdt")  @dtw_assign(V_N2FRDT,  fieldValue)
                                  @Decat_Field("@@trdt")  @dtw_assign(V_N2TRDT,  fieldValue)
                                  @Decat_Field("@@ardt")  @dtw_assign(V_N2ARDT,  fieldValue)
                                  @Decat_Field("@@srdt")  @dtw_assign(V_N2SRDT,  fieldValue)
                                  @Decat_Field("@@prdt")  @dtw_assign(V_N2PRDT,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}

                                  %if (V_N2AWHS == "ALL")
                                      @dtw_assign(checkedallWarehouse, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallWarehouse, "")
                                  %endif
                                  %if (V_N2AITM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_N2ABLT == "ALL")
                                      @dtw_assign(checkedallBillToCustomer, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallBillToCustomer, "")
                                  %endif
                                  %if (V_N2ARDT == "ALL")
                                      @dtw_assign(checkedallRequiredDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallRequiredDate, "")
                                  %endif

                                  %if (V_N2PWHS == "Y")
                                      @dtw_assign(checkedWarehouseTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedWarehouseTotals, "")
                                  %endif
                                  %if (V_N2PITM == "Y")
                                      @dtw_assign(checkedItemNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedItemNumberTotals, "")
                                  %endif
                                  %if (V_N2PBLT == "Y")
                                      @dtw_assign(checkedBillToCustomerTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedBillToCustomerTotals, "")
                                  %endif
                                  %if (V_N2PRDT == "Y")
                                      @dtw_assign(checkedRequiredDateTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedRequiredDateTotals, "")
                                  %endif

                              %else
                                  @dtw_assign(checkedallWarehouse, "CHECKED")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallBillToCustomer, "CHECKED")
                                  @dtw_assign(checkedallRequiredDate, "CHECKED")

                                  @dtw_assign(checkedWarehouseTotals, "")
                                  @dtw_assign(checkedItemNumberTotals, "")
                                  @dtw_assign(checkedBillToCustomerTotals, "")
                                  @dtw_assign(checkedRequiredDateTotals, "")
                              %endif
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                                  <td class="colhdr">Print<br>Totals</td>
                              </tr>

                              @SetTextOvr(Err_N2FWHS)
                              %if (textOvr == "") @SetTextOvr(Err_N2TWHS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2AWHS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SWHS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2PWHS) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Warehouse</span></td>
                                  <td class="inputnmbr"><input name="fromWarehouse" value="$(V_N2FWHS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromWarehouse&amp;fldDesc=fwarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fwarehouseName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toWarehouse" value="$(V_N2TWHS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toWarehouse&amp;fldDesc=twarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="twarehouseName" type="hidden"></td>
                                  <td class="inputalph"><input name="allWarehouse" value='ALL' $(checkedallWarehouse) type="checkbox" onClick="if (this.checked) this.form.fromWarehouse.value='', this.form.toWarehouse.value='';"></td>
                                  @Build_Sort_Select("sortWarehouse", "$(V_N2SWHS)")
                                  <td align=center><input name="totalWarehouse" type="checkbox" $(checkedWarehouseTotals) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N2FWHS)
                              @DspErrMsg(Err_N2TWHS)
                              @DspErrMsg(Err_N2AWHS)
                              @DspErrMsg(Err_N2SWHS)
                              @DspErrMsg(Err_N2PWHS)

                              @SetTextOvr(Err_N2FITM)
                              %if (textOvr == "") @SetTextOvr(Err_N2TITM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2AITM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SITM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2PITM) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N2FITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N2TITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=titemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="titemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                                  @Build_Sort_Select("sortItemNumber", "$(V_N2SITM)")
                                  <td align=center><input name="totalItemNumber"  type="checkbox" $(checkedItemNumberTotals) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N2FITM)
                              @DspErrMsg(Err_N2TITM)
                              @DspErrMsg(Err_N2AITM)
                              @DspErrMsg(Err_N2SITM)
                              @DspErrMsg(Err_N2PITM)

                              @SetTextOvr(Err_N2FBLT)
                              %if (textOvr == "") @SetTextOvr(Err_N2TBLT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2ABLT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SBLT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2PBLT) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Bill-To Customer</span></td>
                                  <td class="inputnmbr"><input name="fromBillToCustomer" value="$(V_N2FBLT)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromBillToCustomer&amp;fldDesc=fcusName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="fcusName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toBillToCustomer" value="$(V_N2TBLT)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toBillToCustomer&amp;fldDesc=tcusName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="tcusName" type="hidden"></td>
                                  <td class="inputalph"><input name="allBillToCustomer" value='ALL' $(checkedallBillToCustomer) type="checkbox" onClick="if (this.checked) this.form.fromBillToCustomer.value='', this.form.toBillToCustomer.value='';"></td>
                                  @Build_Sort_Select("sortBillToCustomer", "$(V_N2SBLT)")
                                  <td align=center><input name="totalBillToCustomer" type="checkbox" $(checkedBillToCustomerTotals) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N2FBLT)
                              @DspErrMsg(Err_N2TBLT)
                              @DspErrMsg(Err_N2ABLT)
                              @DspErrMsg(Err_N2SBLT)
                              @DspErrMsg(Err_N2PBLT)

                              @SetTextOvr(Err_N2FRDT)
                              %if (textOvr == "") @SetTextOvr(Err_N2TRDT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2ARDT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SRDT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2PRDT) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Required Date</span></td>
                                  <td class="inputnmbr"><input name="fromRequiredDate" value="$(V_N2FRDT)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromRequiredDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toRequiredDate" value="$(V_N2TRDT)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toRequiredDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allRequiredDate" value='ALL' $(checkedallRequiredDate) type="checkbox" onClick="if (this.checked) this.form.fromRequiredDate.value='', this.form.toRequiredDate.value='';"></td>
                                  @Build_Sort_Select("sortRequiredDate", "$(V_N2SRDT)")
                                  <td align=center><input name="totalRequiredDate" type="checkbox" $(checkedRequiredDateTotals) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N2FRDT)
                              @DspErrMsg(Err_N2TRDT)
                              @DspErrMsg(Err_N2ARDT)
                              @DspErrMsg(Err_N2SRDT)
                              @DspErrMsg(Err_N2PRDT)
                          </table>

                          @dtw_assign(envProgram, "HOEBOR")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HOEBOS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allWarehouse)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(allBillToCustomer)
  @dtw_mUPPERCASE(allRequiredDate)

  @dtw_assign(fromWarehouse,@dtw_rstrip(fromWarehouse))
  @dtw_assign(toWarehouse,@dtw_rstrip(toWarehouse))
  @dtw_assign(sortWarehouse,@dtw_rstrip(sortWarehouse))
  @dtw_assign(sortItemNumber,@dtw_rstrip(sortItemNumber))
  @dtw_assign(fromBillToCustomer,@dtw_rstrip(fromBillToCustomer))
  @dtw_assign(toBillToCustomer,@dtw_rstrip(toBillToCustomer))
  @dtw_assign(sortBillToCustomer,@dtw_rstrip(sortBillToCustomer))
  @dtw_assign(fromRequiredDate,@dtw_rstrip(fromRequiredDate))
  @dtw_assign(toRequiredDate,@dtw_rstrip(toRequiredDate))
  @dtw_assign(sortRequiredDate,@dtw_rstrip(sortRequiredDate))


  %if (allWarehouse != "ALL")
      @dtw_assign(allWarehouse, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allBillToCustomer != "ALL")
      @dtw_assign(allBillToCustomer, "")
  %endif
  %if (allRequiredDate != "ALL")
      @dtw_assign(allRequiredDate, "")
  %endif

  %if (totalWarehouse != "Y")
      @dtw_assign(totalWarehouse, "N")
  %endif
  %if (totalItemNumber != "Y")
      @dtw_assign(totalItemNumber, "N")
  %endif
  %if (totalBillToCustomer != "Y")
      @dtw_assign(totalBillToCustomer, "N")
  %endif
  %if (totalRequiredDate != "Y")
      @dtw_assign(totalRequiredDate, "N")
  %endif


  @dtw_assign(edtVar, "")
  @Concat_Field("@@fwhs", fromWarehouse)
  @Concat_Field("@@twhs", toWarehouse)
  @Concat_Field("@@awhs", allWarehouse)
  @Concat_Field("@@swhs", sortWarehouse)
  @Concat_Field("@@pwhs", totalWarehouse)
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@sitm", sortItemNumber)
  @Concat_Field("@@pitm", totalItemNumber)
  @Concat_Field("@@fblt", fromBillToCustomer)
  @Concat_Field("@@tblt", toBillToCustomer)
  @Concat_Field("@@ablt", allBillToCustomer)
  @Concat_Field("@@sblt", sortBillToCustomer)
  @Concat_Field("@@pblt", totalBillToCustomer)
  @Concat_Field("@@frdt", fromRequiredDate)
  @Concat_Field("@@trdt", toRequiredDate)
  @Concat_Field("@@ardt", allRequiredDate)
  @Concat_Field("@@srdt", sortRequiredDate)
  @Concat_Field("@@prdt", totalRequiredDate)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}