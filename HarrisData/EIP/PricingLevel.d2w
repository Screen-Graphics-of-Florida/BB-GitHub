%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Customer Pricing Level"
  d2wName                 = "PricingLevel.d2w"
  d2wVarBase              = "$(genericVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HOEPLM_E"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchLevel, 2, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "PRICINGLEVEL")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select HDPRLC.*, upper(PVLVDS) as PVLVDSU ", stmtSQL)
                      @dtw_concat(fileSQL, " HDPRLC ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, "PVPMLV>0 ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @PricingLevel_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) PricingLevel_Query (IN CHAR(64) profileHandle,
                                          CHAR(2)   dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)PricingLevelMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">Pricing Level</th>
                  </tr>
                  <tr>
                      <td><input type="text" class="inputalph" name="srchDesc" size="20" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputnmbr" name="srchLevel" size="5" maxlength="2">
                          <input type="hidden" name="operLevel" value="=">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>
      %endif

      <table $(contentTable)>
          <tr>
              <th class="dspalph" colspan="3">%INCLUDE "WildCardPage.icl"</th>
              <th class="grphdr"  colspan="7">Category Sequence</th>
              <th class="grphdr"  colspan="8">Structure Definition</th>
          </tr>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("PVPMLV", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PricingLevel" title="Sequence By Pricing Level">Level</a></th>
              @OrderBy_Sort("PVLVDSU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Description, Pricing Level">Description</a></th>
              @OrderBy_Sort("PVWHSQ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=WhSequence" title="Sequence By Warehouse, Pricing Level">Whs</a></th>
              @OrderBy_Sort("PVITSQ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ItSequence" title="Sequence By Item Number, Pricing Level">Item<br>Number</a></th>
              @OrderBy_Sort("PVCSSQ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CsSequence" title="Sequence By Customer Number, Pricing Level">Customer<br>Number</a></th>
              @OrderBy_Sort("PVCCSQ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CcSequence" title="Sequence By Customer Class, Pricing Level">Customer<br>Class</a></th>
              @OrderBy_Sort("PVPCSQ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PcSequence" title="Sequence By Product Class, Pricing Level">Prod<br>Class</a></th>
              @OrderBy_Sort("PVRGSQ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RgSequence" title="Sequence By Region, Pricing Level">Region</a></th>
              @OrderBy_Sort("PVPGSQ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PgSequence" title="Sequence By Product Group, Pricing Level">Prod<br>Group</a></th>
              @OrderBy_Sort("PVCN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Contract" title="Sequence By Contract, Pricing Level">Contract</a></th>
              @OrderBy_Sort("PVLL", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ListLess" title="Sequence By List Less Amount, Pricing Level">List<br>Less<br>Amount</a></th>
              @OrderBy_Sort("PVCP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CostPlus" title="Sequence By Cost Plus Amount, Pricing Level">Cost<br>Plus<br>Amount</a></th>
              @OrderBy_Sort("PVDL", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DollarAmt" title="Sequence By Dollar Amount, Pricing Level">Dollar<br>Amount</a></th>
              @OrderBy_Sort("PVUP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=UsePercent" title="Sequence By Use Percentages, Pricing Level">Use<br>Pct</a></th>
              @OrderBy_Sort("PVBP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BracketQty" title="Sequence By Bracket By Quantity, Pricing Level">Bracket<br>By Qty</a></th>
              @OrderBy_Sort("PVBA", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BracketAmt" title="Sequence By Bracket By Amount, Pricing Level">Bracket<br>By Amt</a></th>
              @OrderBy_Sort("PVCOMM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Commission" title="Sequence By Commissionable, Pricing Level">Commissionable</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;pricingLevel=@dtw_rurlescseq(V_PVPMLV)&amp;levelDesc=@dtw_rurlescseq(V_PVLVDS)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_PVLVDS), $(V_PVPMLV), "", "", "", "", confirmDesc)
              %if (sec_03 == "Y")
                  @RtvFldDesc("PMPMLV=$(V_PVPMLV)", "HDPRCD", "CHAR(COUNT(PMPMLV))", detailCount)
              %endif

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)PricingLevelMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)PricingLevelMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y" && detailCount <= "0")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)PricingLevelMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  @Format_Nbr(V_PVWHSQ, F_PVWHSQ, "0", "Z", "", "", "")
                  @Format_Nbr(V_PVITSQ, F_PVITSQ, "0", "Z", "", "", "")
                  @Format_Nbr(V_PVCSSQ, F_PVCSSQ, "0", "Z", "", "", "")
                  @Format_Nbr(V_PVCCSQ, F_PVCCSQ, "0", "Z", "", "", "")
                  @Format_Nbr(V_PVPCSQ, F_PVPCSQ, "0", "Z", "", "", "")
                  @Format_Nbr(V_PVRGSQ, F_PVRGSQ, "0", "Z", "", "", "")
                  @Format_Nbr(V_PVPGSQ, F_PVPGSQ, "0", "Z", "", "", "")
                  <td class="colnmbr">$(V_PVPMLV)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)PricingDetail.d2w/LOAD$(maintainVar)" title="View Pricing Detail">$(V_PVLVDS)</a></td>
                  <td class="colcode">$(F_PVWHSQ)</td>
                  <td class="colcode">$(F_PVITSQ)</td>
                  <td class="colcode">$(F_PVCSSQ)</td>
                  <td class="colcode">$(F_PVCCSQ)</td>
                  <td class="colcode">$(F_PVPCSQ)</td>
                  <td class="colcode">$(F_PVRGSQ)</td>
                  <td class="colcode">$(F_PVPGSQ)</td>
                  %if (V_PVCN == "Y")
                      <td class="colcode">$(selectedImageSml)</td>
                  %else
                      <td class="colcode">&nbsp;</td>
                  %endif
                  %if (V_PVLL == "Y")
                      <td class="colcode">$(selectedImageSml)</td>
                  %else
                      <td class="colcode">&nbsp;</td>
                  %endif
                  %if (V_PVCP == "Y")
                      <td class="colcode">$(selectedImageSml)</td>
                  %else
                      <td class="colcode">&nbsp;</td>
                  %endif
                  %if (V_PVDL == "Y")
                      <td class="colcode">$(selectedImageSml)</td>
                  %else
                      <td class="colcode">&nbsp;</td>
                  %endif
                  %if (V_PVUP == "Y")
                      <td class="colcode">$(selectedImageSml)</td>
                  %else
                      <td class="colcode">&nbsp;</td>
                  %endif
                  %if (V_PVBP == "Y")
                      <td class="colcode">$(selectedImageSml)</td>
                  %else
                      <td class="colcode">&nbsp;</td>
                  %endif
                  %if (V_PVBA == "Y")
                      <td class="colcode">$(selectedImageSml)</td>
                  %else
                      <td class="colcode">&nbsp;</td>
                  %endif
                  <td class="colcode">$(V_PVCOMM)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select HDPRLC.*, upper(PVLVDS) as PVLVDSU ", stmtSQL)
  @dtw_concat(fileSQL, " HDPRLC ", fileSQL)
  %if (wildCardSearch!="")
      @dtw_concat(selectSQL, "PVPMLV>0 ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @PricingLevel_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) PricingLevel_XMLQuery (IN CHAR(64)    profileHandle,
                                             CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("PricingLevelList")
          %ROW{
	       @XMLIDTag(V_PVPMLV, "PricingLevel ID")
                  @XMLTag(V_PVPMLV, "PricingLevel")
                  @XMLTag(V_PVLVDS, "Description")
                  @XMLTag(V_PVWHSQ, "WarehouseSeq")
                  @XMLTag(V_PVITSQ, "ItemNumberSeq")
                  @XMLTag(V_PVCSSQ, "CustomerNumberSeq")
                  @XMLTag(V_PVCCSQ, "CustomerClassSeq")
                  @XMLTag(V_PVPCSQ, "ProductClassSeq")
                  @XMLTag(V_PVRGSQ, "RegionSeq")
                  @XMLTag(V_PVPGSQ, "ProductGroupSeq")
                  @XMLTag(V_PVCN, "ContractPricing")
                  @XMLTag(V_PVLL, "ListLessAmount")
                  @XMLTag(V_PVCP, "CostPlusAmount")
                  @XMLTag(V_PVDL, "DollarAmount")
                  @XMLTag(V_PVUP, "UsePercentages")
                  @XMLTag(V_PVBP, "BracketByQty")
                  @XMLTag(V_PVBA, "BracketByAmt")
                  @XMLTag(V_PVCOMM, "Commissionable")
              @XMLEndTag("PricingLevel")
          %}
      @XMLEndTag("PricingLevelList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Pricing Level")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "PricingLevel")
      %if (orderBy == "PVPMLV")
          @DTW_ASSIGN(orderBy, "PVPMLV DESC")
          @DTW_ASSIGN(orderByDisplay, "Pricing Level (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Pricing Level")
      %endif
  %elif (sequence == "Description")
      %if (orderBy == "PVLVDSU")
          @DTW_ASSIGN(orderBy, "PVLVDSU DESC,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Pricing Level")
      %else
          @DTW_ASSIGN(orderBy, "PVLVDSU,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Description, Pricing Level")
      %endif
  %elif (sequence == "WhSequence")
      %if (orderBy == "PVWHSQ,PVPMLV")
          @DTW_ASSIGN(orderBy, "PVWHSQ DESC,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Warehouse (descending), Pricing Level")
      %else
          @DTW_ASSIGN(orderBy, "PVWHSQ,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Warehouse, Pricing Level")
      %endif
  %elif (sequence == "ItSequence")
      %if (orderBy == "PVITSQ,PVPMLV")
          @DTW_ASSIGN(orderBy, "PVITSQ DESC,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Item Number (descending), Pricing Level")
      %else
          @DTW_ASSIGN(orderBy, "PVITSQ,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Item Number, Pricing Level")
      %endif
  %elif (sequence == "CsSequence")
      %if (orderBy == "PVCSSQ,PVPMLV")
          @DTW_ASSIGN(orderBy, "PVCSSQ DESC,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Customer Number (descending), Pricing Level")
      %else
          @DTW_ASSIGN(orderBy, "PVCSSQ,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Customer Number, Pricing Level")
      %endif
  %elif (sequence == "CcSequence")
      %if (orderBy == "PVCCSQ,PVPMLV")
          @DTW_ASSIGN(orderBy, "PVCCSQ DESC,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Customer Class (descending), Pricing Level")
      %else
          @DTW_ASSIGN(orderBy, "PVCCSQ,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Customer Class, Pricing Level")
      %endif
  %elif (sequence == "PcSequence")
      %if (orderBy == "PVPCSQ,PVPMLV")
          @DTW_ASSIGN(orderBy, "PVPCSQ DESC,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Product Class (descending), Pricing Level")
      %else
          @DTW_ASSIGN(orderBy, "PVPCSQ,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Product Class, Pricing Level")
      %endif
  %elif (sequence == "RgSequence")
      %if (orderBy == "PVRGSQ,PVPMLV")
          @DTW_ASSIGN(orderBy, "PVRGSQ DESC,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Region (descending), Pricing Level")
      %else
          @DTW_ASSIGN(orderBy, "PVRGSQ,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Region, Pricing Level")
      %endif
  %elif (sequence == "PgSequence")
      %if (orderBy == "PVPGSQ,PVPMLV")
          @DTW_ASSIGN(orderBy, "PVPGSQ DESC,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Product Group (descending), Pricing Level")
      %else
          @DTW_ASSIGN(orderBy, "PVPGSQ,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Product Group, Pricing Level")
      %endif
  %elif (sequence == "Contract")
      %if (orderBy == "PVCN,PVPMLV")
          @DTW_ASSIGN(orderBy, "PVCN DESC,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Contract (descending), Pricing Level")
      %else
          @DTW_ASSIGN(orderBy, "PVCN,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Contract, Pricing Level")
      %endif
  %elif (sequence == "ListLess")
      %if (orderBy == "PVLL,PVPMLV")
          @DTW_ASSIGN(orderBy, "PVLL DESC,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "List Less Amount (descending), Pricing Level")
      %else
          @DTW_ASSIGN(orderBy, "PVLL,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "List Less Amount, Pricing Level")
      %endif
  %elif (sequence == "CostPlus")
      %if (orderBy == "PVCP,PVPMLV")
          @DTW_ASSIGN(orderBy, "PVCP DESC,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Cost Plus Amount (descending), Pricing Level")
      %else
          @DTW_ASSIGN(orderBy, "PVCP,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Cost Plus Amount, Pricing Level")
      %endif
  %elif (sequence == "DollarAmt")
      %if (orderBy == "PVDL,PVPMLV")
          @DTW_ASSIGN(orderBy, "PVDL DESC,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Dollar Amount (descending), Pricing Level")
      %else
          @DTW_ASSIGN(orderBy, "PVDL,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Dollar Amount, Pricing Level")
      %endif
  %elif (sequence == "UsePercent")
      %if (orderBy == "PVUP,PVPMLV")
          @DTW_ASSIGN(orderBy, "PVUP DESC,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Use Percentages (descending), Pricing Level")
      %else
          @DTW_ASSIGN(orderBy, "PVUP,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Use Percentages, Pricing Level")
      %endif
  %elif (sequence == "BracketQty")
      %if (orderBy == "PVBP,PVPMLV")
          @DTW_ASSIGN(orderBy, "PVBP DESC,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Bracket By Quantity (descending), Pricing Level")
      %else
          @DTW_ASSIGN(orderBy, "PVBP,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Bracket By Quantity, Pricing Level")
      %endif
  %elif (sequence == "BracketAmt")
      %if (orderBy == "PVBA,PVPMLV")
          @DTW_ASSIGN(orderBy, "PVBA DESC,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Bracket By Amount (descending), Pricing Level")
      %else
          @DTW_ASSIGN(orderBy, "PVBA,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Bracket By Amount, Pricing Level")
      %endif
  %elif (sequence == "Commission")
      %if (orderBy == "PVCOMM,PVPMLV")
          @DTW_ASSIGN(orderBy, "PVCOMM DESC,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Commissionable (descending), Pricing Level")
      %else
          @DTW_ASSIGN(orderBy, "PVCOMM,PVPMLV")
          @DTW_ASSIGN(orderByDisplay, "Commissionable, Pricing Level")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PRICINGLEVELSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      <table $(contentTable)>
                          %INCLUDE "SearchPageTitle.icl"
                          $(hrTagAttr)
                          @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                          %INCLUDE "WildCardReset.icl"

                          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                              %INCLUDE "SearchTop.icl"

                              <tr><td class="dsphdr">Level</td>
                                  @dtw_assign(operNbr, "operLevel")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchLevel" size="5" maxlength="2"></td>
                              </tr>

                              <tr><td class="dsphdr">Description</td>
                                  @dtw_assign(operNbr, "operDesc")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchDesc" size="20" maxlength="30"></td>
                              </tr>
                      </table>

                      <fieldset class="legendBody">
                          <legend class="legendTitle">Category Sequence (0-6)</legend>
                              <table $(contentTable)>
                                  <tr><td class="dsphdr">Warehouse</td>
                                      @dtw_assign(operNbr, "operWhs")
                                      <td>%INCLUDE "opersel_num_short.icl"</td>
                                      <td class="inputnmbr"><input type="text" name="srchWhs" size="5" maxlength="2"></td>
                                  </tr>

                                  <tr><td class="dsphdr">Item Number</td>
                                      @dtw_assign(operNbr, "operItem")
                                      <td>%INCLUDE "opersel_num_short.icl"</td>
                                      <td class="inputnmbr"><input type="text" name="srchItem" size="5" maxlength="2"></td>
                                  </tr>

                                  <tr><td class="dsphdr">Customer Number</td>
                                      @dtw_assign(operNbr, "operCust")
                                      <td>%INCLUDE "opersel_num_short.icl"</td>
                                      <td class="inputnmbr"><input type="text" name="srchCust" size="5" maxlength="2"></td>
                                  </tr>

                                  <tr><td class="dsphdr">Customer Class</td>
                                      @dtw_assign(operNbr, "operClass")
                                      <td>%INCLUDE "opersel_num_short.icl"</td>
                                      <td class="inputnmbr"><input type="text" name="srchClass" size="5" maxlength="2"></td>
                                  </tr>

                                  <tr><td class="dsphdr">Product Class</td>
                                      @dtw_assign(operNbr, "operProdCls")
                                      <td>%INCLUDE "opersel_num_short.icl"</td>
                                      <td class="inputnmbr"><input type="text" name="srchProdCls" size="5" maxlength="2"></td>
                                  </tr>

                                  <tr><td class="dsphdr">Region</td>
                                      @dtw_assign(operNbr, "operRegion")
                                      <td>%INCLUDE "opersel_num_short.icl"</td>
                                      <td class="inputnmbr"><input type="text" name="srchRegion" size="5" maxlength="2"></td>
                                  </tr>

                                  <tr><td class="dsphdr">Product Group</td>
                                      @dtw_assign(operNbr, "operProdGrp")
                                      <td>%INCLUDE "opersel_num_short.icl"</td>
                                      <td class="inputnmbr"><input type="text" name="srchProdGrp" size="5" maxlength="2"></td>
                                  </tr>
                              </table>
                      </fieldset>

                      <fieldset class="legendBody">
                          <legend class="legendTitle">Structure Definition (Y,N)</legend>
                              <table $(contentTable)>
                                  <tr><td class="dsphdr">Contract</td>
                                      @dtw_assign(operNbr, "operContract")
                                      <td>%INCLUDE "opersel_alph_short.icl"</td>
                                      <td class="inputalph"><input type="text" name="srchContract" size="5" maxlength="1"></td>
                                  </tr>

                                  <tr><td class="dsphdr">List Less Amount</td>
                                      @dtw_assign(operNbr, "operListLess")
                                      <td>%INCLUDE "opersel_alph_short.icl"</td>
                                      <td class="inputalph"><input type="text" name="srchListLess" size="5" maxlength="1"></td>
                                  </tr>

                                  <tr><td class="dsphdr">Cost Plus Amount</td>
                                      @dtw_assign(operNbr, "operCostPlus")
                                      <td>%INCLUDE "opersel_alph_short.icl"</td>
                                      <td class="inputalph"><input type="text" name="srchCostPlus" size="5" maxlength="1"></td>
                                  </tr>

                                  <tr><td class="dsphdr">Dollar Amount</td>
                                      @dtw_assign(operNbr, "operDollar")
                                      <td>%INCLUDE "opersel_alph_short.icl"</td>
                                      <td class="inputalph"><input type="text" name="srchDollar" size="5" maxlength="1"></td>
                                  </tr>

                                  <tr><td class="dsphdr">Use Percentages</td>
                                      @dtw_assign(operNbr, "operUsePct")
                                      <td>%INCLUDE "opersel_alph_short.icl"</td>
                                      <td class="inputalph"><input type="text" name="srchUsePct" size="5" maxlength="1"></td>
                                  </tr>

                                  <tr><td class="dsphdr">Bracket By Quantity</td>
                                      @dtw_assign(operNbr, "operBrkQty")
                                      <td>%INCLUDE "opersel_alph_short.icl"</td>
                                      <td class="inputalph"><input type="text" name="srchBrkQty" size="5" maxlength="1"></td>
                                  </tr>

                                  <tr><td class="dsphdr">Bracket By Amount</td>
                                      @dtw_assign(operNbr, "operBrkAmt")
                                      <td>%INCLUDE "opersel_alph_short.icl"</td>
                                      <td class="inputalph"><input type="text" name="srchBrkAmt" size="5" maxlength="1"></td>
                                  </tr>

                                  <tr><td class="dsphdr">Commissionable</td>
                                      @dtw_assign(operNbr, "operComm")
                                      <td>%INCLUDE "opersel_alph_short.icl"</td>
                                      <td class="inputalph"><input type="text" name="srchComm" size="5" maxlength="1"></td>
                                  </tr>
                              </table>
                      </fieldset>

                      <table $(contentTable)>
                          <tr><td>&nbsp;</td></tr>
                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchLevel.focus();
                          </script>
                          </form>
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </table>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("PVPMLV", "Level", $(srchLevel), "", operLevel, "N")
  @Build_WildCard ("upper(PVLVDS)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("PVWHSQ", "Warehouse", $(srchWhs), "", operWhs, "N")
  @Build_WildCard ("PVITSQ", "Item Number", $(srchItem), "", operItem, "N")
  @Build_WildCard ("PVCSSQ", "Customer Number", $(srchCust), "", operCust, "N")
  @Build_WildCard ("PVCCSQ", "Customer Class", $(srchClass), "", operClass, "N")
  @Build_WildCard ("PVPCSQ", "Product Class", $(srchProdCls), "", operProdCls, "N")
  @Build_WildCard ("PVRGSQ", "Region", $(srchRegion), "", operRegion, "N")
  @Build_WildCard ("PVPGSQ", "Product Group", $(srchProdGrp), "", operProdGrp, "N")
  @Build_WildCard ("PVCN", "Contract", $(srchContract), "U", operContract, "A")
  @Build_WildCard ("PVLL", "List Less Amount", $(srchListLess), "U", operListLess, "A")
  @Build_WildCard ("PVCP", "Cost Plus Amount", $(srchCostPlus), "U", operCostPlus, "A")
  @Build_WildCard ("PVDL", "Dollar Amount", $(srchDollar), "U", operDollar, "A")
  @Build_WildCard ("PVUP", "Use Percentages", $(srchUsePct), "U", operUsePct, "A")
  @Build_WildCard ("PVBP", "Bracket By Quantity", $(srchBrkQty), "U", operBrkQty, "A")
  @Build_WildCard ("PVBA", "Bracket By Amount", $(srchBrkAmt), "U", operBrkAmt, "A")
  @Build_WildCard ("PVCOMM", "Commissionable", $(srchComm), "U", operComm, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
