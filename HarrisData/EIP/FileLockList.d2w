%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Table Lock List"
  d2wName                 = "FileLockList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "4"
  helpExt                 = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.frmMenuOpt, 2, 0) &&
                      editNum(document.Chg.toMenuOpt, 2, 0) &&
                      editFromToAll(document.Chg.frmMenuName, document.Chg.toMenuName, document.Chg.allMenuName, "A") &&
                      editFromToAll(document.Chg.frmMenuOpt, document.Chg.toMenuOpt, document.Chg.allMenuOpt, 2) &&
                      editFromToAll(document.Chg.frmFile, document.Chg.toFile, document.Chg.allFile, "A") &&
                      editFromToAll(document.Chg.frmLock, document.Chg.toLock, document.Chg.allLock, "A"))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "FILELOCKLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          @dtw_assign(focusField, "frmMenuName")
                          %if (errFound != "" || scheduleJobSwitch == "Y")
                              @dtw_assign(scheduleJobSwitch, "")
                              @EdtVarErr(profileHandle, typeValue, edtVar)
                              @dtw_assign(focusField, "")
                              @ErrVarErr(profileHandle, typeError, errVar)
                              @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule, fieldValue)
                              @DecatErr_Field("@@fmnu", "frmMenuName")       @dtw_assign(Err_N1FMNU, fieldValue)
                              @DecatErr_Field("@@tmnu", "toMenuName")        @dtw_assign(Err_N1TMNU, fieldValue)
                              @DecatErr_Field("@@amnu", "allMenuName")       @dtw_assign(Err_N1AMNU, fieldValue)
                              @DecatErr_Field("@@smnu", "srtMenuName")       @dtw_assign(Err_N1SMNU, fieldValue)
                              @DecatErr_Field("@@pmnu", "totMenuName")       @dtw_assign(Err_N1PMNU, fieldValue)
                              @DecatErr_Field("@@fmno", "frmMenuOpt")        @dtw_assign(Err_N1FMNO, fieldValue)
                              @DecatErr_Field("@@tmno", "toMenuOpt")         @dtw_assign(Err_N1TMNO, fieldValue)
                              @DecatErr_Field("@@amno", "allMenuOpt")        @dtw_assign(Err_N1AMNO, fieldValue)
                              @DecatErr_Field("@@smno", "srtMenuOpt")        @dtw_assign(Err_N1SMNO, fieldValue)
                              @DecatErr_Field("@@pmno", "totMenuOpt")        @dtw_assign(Err_N1PMNO, fieldValue)
                              @DecatErr_Field("@@ffil", "frmFile")           @dtw_assign(Err_N1FFIL, fieldValue)
                              @DecatErr_Field("@@tfil", "toFile")            @dtw_assign(Err_N1TFIL, fieldValue)
                              @DecatErr_Field("@@afil", "allFile")           @dtw_assign(Err_N1AFIL, fieldValue)
                              @DecatErr_Field("@@sfil", "srtFile")           @dtw_assign(Err_N1SFIL, fieldValue)
                              @DecatErr_Field("@@pfil", "totFile")           @dtw_assign(Err_N1PFIL, fieldValue)
                              @DecatErr_Field("@@fopn", "frmLock")           @dtw_assign(Err_N1FOPN, fieldValue)
                              @DecatErr_Field("@@topn", "toLock")            @dtw_assign(Err_N1TOPN, fieldValue)
                              @DecatErr_Field("@@aopn", "allLock")           @dtw_assign(Err_N1AOPN, fieldValue)
                              @DecatErr_Field("@@sopn", "srtLock")           @dtw_assign(Err_N1SOPN, fieldValue)
                              @DecatErr_Field("@@popn", "totLock")           @dtw_assign(Err_N1POPN, fieldValue)
                              %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                              @Decat_Field("@@fmnu")  @dtw_assign(V_N1FMNU, fieldValue)
                              @Decat_Field("@@tmnu")  @dtw_assign(V_N1TMNU, fieldValue)
                              @Decat_Field("@@amnu")  @dtw_assign(V_N1AMNU, fieldValue)
                              @Decat_Field("@@smnu")  @dtw_assign(V_N1SMNU, fieldValue)
                              @Decat_Field("@@pmnu")  @dtw_assign(V_N1PMNU, fieldValue)
                              @Decat_Field("@@fmno")  @dtw_assign(V_N1FMNO, fieldValue)
                              @Decat_Field("@@tmno")  @dtw_assign(V_N1TMNO, fieldValue)
                              @Decat_Field("@@amno")  @dtw_assign(V_N1AMNO, fieldValue)
                              @Decat_Field("@@smno")  @dtw_assign(V_N1SMNO, fieldValue)
                              @Decat_Field("@@pmno")  @dtw_assign(V_N1PMNO, fieldValue)
                              @Decat_Field("@@ffil")  @dtw_assign(V_N1FFIL, fieldValue)
                              @Decat_Field("@@tfil")  @dtw_assign(V_N1TFIL, fieldValue)
                              @Decat_Field("@@afil")  @dtw_assign(V_N1AFIL, fieldValue)
                              @Decat_Field("@@sfil")  @dtw_assign(V_N1SFIL, fieldValue)
                              @Decat_Field("@@pfil")  @dtw_assign(V_N1PFIL, fieldValue)
                              @Decat_Field("@@fopn")  @dtw_assign(V_N1FOPN, fieldValue)
                              @Decat_Field("@@topn")  @dtw_assign(V_N1TOPN, fieldValue)
                              @Decat_Field("@@aopn")  @dtw_assign(V_N1AOPN, fieldValue)
                              @Decat_Field("@@sopn")  @dtw_assign(V_N1SOPN, fieldValue)
                              @Decat_Field("@@popn")  @dtw_assign(V_N1POPN, fieldValue)
                              %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                          %else
                              @dtw_assign(V_N1AMNU, "ALL")
                              @dtw_assign(V_N1AMNO, "ALL")
                              @dtw_assign(V_N1AOPN, "ALL")
                              @dtw_assign(V_N1AFIL, "ALL")

                              @dtw_assign(V_N1PMNU, "N")
                              @dtw_assign(V_N1PMNO, "N")
                              @dtw_assign(V_N1POPN, "N")
                              @dtw_assign(V_N1PFIL, "N")
                          %endif

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                                  <td class="colhdr">Print<br>Totals</td>
                              </tr>

                              @Field_Checked(V_N1AMNU, "ALL", allChecked)
                              @Field_Checked(V_N1PMNU, "Y", totChecked)
                              @SetTextOvr(Err_N1FMNU)
                              %if (textOvr == "") @SetTextOvr(Err_N1TMNU) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AMNU) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SMNU) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PMNU) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Menu Name</span></td>
                                  <td class="inputalph"><input type="text" name="frmMenuName" value="$(V_N1FMNU)" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input type="text" name="toMenuName" value="$(V_N1TMNU)" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input type="checkbox" name="allMenuName" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmMenuName.value='', this.form.toMenuName.value='';"></td>
                                  @Build_Sort_Select("srtMenuName", "$(V_N1SMNU)")
                                  <td align=center><input type="checkbox" name="totMenuName" $(totChecked) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N1FMNU)
                              @DspErrMsg(Err_N1TMNU)
                              @DspErrMsg(Err_N1AMNU)
                              @DspErrMsg(Err_N1SMNU)
                              @DspErrMsg(Err_N1PMNU)

                              @Field_Checked(V_N1AMNO, "ALL", allChecked)
                              @Field_Checked(V_N1PMNO, "Y", totChecked)
                              @SetTextOvr(Err_N1FMNO)
                              %if (textOvr == "") @SetTextOvr(Err_N1TMNO) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AMNO) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SMNO) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PMNO) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Menu Option</span></td>
                                  <td class="inputnmbr"><input type="text" name="frmMenuOpt" value="$(V_N1FMNO)" size="10" maxlength="2"></td>
                                  <td class="inputnmbr"><input type="text" name="toMenuOpt" value="$(V_N1TMNO)" size="10" maxlength="2"></td>
                                  <td class="inputalph"><input type="checkbox" name="allMenuOpt" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmMenuOpt.value='', this.form.toMenuOpt.value='';"></td>
                                  @Build_Sort_Select("srtMenuOpt", "$(V_N1SMNO)")
                                  <td align=center><input type="checkbox" name="totMenuOpt" $(totChecked) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N1FMNO)
                              @DspErrMsg(Err_N1TMNO)
                              @DspErrMsg(Err_N1AMNO)
                              @DspErrMsg(Err_N1SMNO)
                              @DspErrMsg(Err_N1PMNO)

                              @Field_Checked(V_N1AFIL, "ALL", allChecked)
                              @Field_Checked(V_N1PFIL, "Y", totChecked)
                              @SetTextOvr(Err_N1FFIL)
                              %if (textOvr == "") @SetTextOvr(Err_N1TFIL) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AFIL) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SFIL) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PFIL) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Table</span></td>
                                  <td class="inputalph"><input type="text" name="frmFile" value="$(V_N1FFIL)" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input type="text" name="toFile" value="$(V_N1TFIL)" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input type="checkbox" name="allFile" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmFile.value='', this.form.toFile.value='';"></td>
                                  @Build_Sort_Select("srtFile", "$(V_N1SFIL)")
                                  <td align=center><input type="checkbox" name="totFile"  $(totChecked) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N1FFIL)
                              @DspErrMsg(Err_N1TFIL)
                              @DspErrMsg(Err_N1AFIL)
                              @DspErrMsg(Err_N1SFIL)
                              @DspErrMsg(Err_N1PFIL)

                              @Field_Checked(V_N1AOPN, "ALL", allChecked)
                              @Field_Checked(V_N1POPN, "Y", totChecked)
                              @SetTextOvr(Err_N1FOPN)
                              %if (textOvr == "") @SetTextOvr(Err_N1TOPN) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AOPN) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SOPN) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1POPN) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Lock State</span></td>
                                  <td class="inputalph"><input type="text" name="frmLock" value="$(V_N1FOPN)" size="10" maxlength="7"></td>
                                  <td class="inputalph"><input type="text" name="toLock" value="$(V_N1TOPN)" size="10" maxlength="7"></td>
                                  <td class="inputalph"><input type="checkbox" name="allLock" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmLock.value='', this.form.toLock.value='';"></td>
                                  @Build_Sort_Select("srtLock", "$(V_N1SOPN)")
                                  <td align=center><input type="checkbox" name="totLock"  $(totChecked) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N1FOPN)
                              @DspErrMsg(Err_N1TOPN)
                              @DspErrMsg(Err_N1AOPN)
                              @DspErrMsg(Err_N1SOPN)
                              @DspErrMsg(Err_N1POPN)
                          </table>

                          @dtw_assign(envProgram, "HSYLKL")
                          @dtw_assign(envPrinter, "HSYLKLPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSYLKS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"

  @dtw_assign(edtVar, "")
  @dtw_mUPPERCASE(frmMenuName)                                                                 @Concat_Field("@@fmnu", frmMenuName)
  @dtw_mUPPERCASE(toMenuName)                                                                  @Concat_Field("@@tmnu", toMenuName)
  @dtw_mUPPERCASE(allMenuName) %if (allMenuName != "ALL") @dtw_assign(allMenuName, "") %endif  @Concat_Field("@@amnu", allMenuName)
                                                                                               @Concat_Field("@@smnu", @dtw_rstrip(srtMenuName))
  %if (totMenuName != "Y") @dtw_assign(totMenuName, "N") %endif                                @Concat_Field("@@pmnu", totMenuName)

  @dtw_mUPPERCASE(frmMenuOpt)                                                                @Concat_Field("@@fmno", frmMenuOpt)
  @dtw_mUPPERCASE(toMenuOpt)                                                                 @Concat_Field("@@tmno", toMenuOpt)
  @dtw_mUPPERCASE(allMenuOpt) %if (allMenuOpt != "ALL") @dtw_assign(allMenuOpt, "") %endif   @Concat_Field("@@amno", allMenuOpt)
                                                                                             @Concat_Field("@@smno", @dtw_rstrip(srtMenuOpt))
  %if (totMenuOpt != "Y") @dtw_assign(totMenuOpt, "N") %endif                                @Concat_Field("@@pmno", totMenuOpt)

  @dtw_mUPPERCASE(frmFile)                                                         @Concat_Field("@@ffil", frmFile)
  @dtw_mUPPERCASE(toFile)                                                          @Concat_Field("@@tfil", toFile)
  @dtw_mUPPERCASE(allFile) %if (allFile != "ALL") @dtw_assign(allFile, "") %endif  @Concat_Field("@@afil", allFile)
                                                                                   @Concat_Field("@@sfil", @dtw_rstrip(srtFile))
  %if (totFile != "Y") @dtw_assign(totFile, "N") %endif                            @Concat_Field("@@pfil", totFile)

  @dtw_mUPPERCASE(frmLock)                                                         @Concat_Field("@@fopn", frmLock)
  @dtw_mUPPERCASE(toLock)                                                          @Concat_Field("@@topn", toLock)
  @dtw_mUPPERCASE(allLock) %if (allLock != "ALL") @dtw_assign(allLock, "") %endif  @Concat_Field("@@aopn", allLock)
                                                                                   @Concat_Field("@@sopn", @dtw_rstrip(srtLock))
  %if (totLock != "Y") @dtw_assign(totLock, "N") %endif                            @Concat_Field("@@popn", totLock)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}