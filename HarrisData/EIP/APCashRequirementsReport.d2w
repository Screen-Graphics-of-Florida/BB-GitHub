%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "A/P Cash Requirements Report"
  d2wName                 = "APCashRequirementsReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "4"
  sortBankNumber         = "1"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"

              function validate(chgForm) {
                  if  (editdate(document.Chg.currentDate) &&
                      editdate(document.Chg.firstCutoffDate) &&
                      editdate(document.Chg.secondCutoffDate) &&
                      editdate(document.Chg.thirdCutoffDate) &&
                      editNum(document.Chg.fromBankNumber, 2, 0) &&
                      editNum(document.Chg.toBankNumber, 2, 0) &&
                      editNum(document.Chg.fromVendorNumber, 7, 0) &&
                      editNum(document.Chg.toVendorNumber, 7, 0) &&
                      editFromToAll(document.Chg.fromBankNumber, document.Chg.toBankNumber, document.Chg.allBankNumber, 2) &&
                      editFromToAll(document.Chg.fromVendorNumber, document.Chg.toVendorNumber, document.Chg.allVendorNumber, 7) &&
                      editFromToAll(document.Chg.fromVendorType, document.Chg.toVendorType, document.Chg.allVendorType, "A") &&
                      editFromToAll(document.Chg.fromAlphaSequence, document.Chg.toAlphaSequence, document.Chg.allAlphaSequence, "A"))
                      return true;
              }

              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CASHREQUIREMENTSREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "currentDate")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@hld@", "includeHeldVouchers") @dtw_assign(Err_N1HLD,  fieldValue)
                                  @DecatErr_Field("@@bodd", "basedOnDiscountDate") @dtw_assign(Err_N2BODD,  fieldValue)
                                  @DecatErr_Field("@@cur@", "currentDate") @dtw_assign(Err_N3CUR,  fieldValue)
                                  @DecatErr_Field("@@cut1", "firstCutoffDate") @dtw_assign(Err_N3CUT1,  fieldValue)
                                  @DecatErr_Field("@@cut2", "secondCutoffDate") @dtw_assign(Err_N3CUT2,  fieldValue)
                                  @DecatErr_Field("@@cut3", "thirdCutoffDate") @dtw_assign(Err_N3CUT3,  fieldValue)
                                  @DecatErr_Field("@@fbnk", "fromBankNumber") @dtw_assign(Err_N3FBNK,  fieldValue)
                                  @DecatErr_Field("@@tbnk", "toBankNumber") @dtw_assign(Err_N3TBNK,  fieldValue)
                                  @DecatErr_Field("@@abnk", "allBankNumber") @dtw_assign(Err_N3ABNK,  fieldValue)
                                  @DecatErr_Field("@@sbnk", "sortBankNumber") @dtw_assign(Err_N3SBNK,  fieldValue)
                                  @DecatErr_Field("@@fvnd", "fromVendorNumber") @dtw_assign(Err_N3FVND,  fieldValue)
                                  @DecatErr_Field("@@tvnd", "toVendorNumber") @dtw_assign(Err_N3TVND,  fieldValue)
                                  @DecatErr_Field("@@avnd", "allVendorNumber")
                                  @dtw_assign(Err_N3AVND,  fieldValue)
                                  @DecatErr_Field("@@svnd", "sortVendorNumber")        @dtw_assign(Err_N3SVND,  fieldValue)
                                  @DecatErr_Field("@@fvdt", "fromVendorType") @dtw_assign(Err_N3FVDT,  fieldValue)
                                  @DecatErr_Field("@@tvdt", "toVendorType") @dtw_assign(Err_N3TVDT,  fieldValue)
                                  @DecatErr_Field("@@avdt", "allVendorType") @dtw_assign(Err_N3AVDT,  fieldValue)
                                  @DecatErr_Field("@@svdt", "sortVendorType")        @dtw_assign(Err_N3SVDT,  fieldValue)
                                  @DecatErr_Field("@@fals", "fromAlphaSequence") @dtw_assign(Err_N3FALS,  fieldValue)
                                  @DecatErr_Field("@@tals", "toAlphaSequence") @dtw_assign(Err_N3TALS,  fieldValue)
                                  @DecatErr_Field("@@aals", "allAlphaSequence") @dtw_assign(Err_N3AALS,  fieldValue)
                                  @DecatErr_Field("@@sals", "sortAlphaSequence")        @dtw_assign(Err_N3SALS,  fieldValue)

                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@hld@")  @dtw_assign(V_N1HLD,  fieldValue)
                                  @Decat_Field("@@bodd")  @dtw_assign(V_N2BODD,  fieldValue)
                                  @Decat_Field("@@cur@")  @dtw_assign(V_N3CUR,  fieldValue)
                                  @Decat_Field("@@cut1")  @dtw_assign(V_N3CUT1,  fieldValue)
                                  @Decat_Field("@@cut2")  @dtw_assign(V_N3CUT2,  fieldValue)
                                  @Decat_Field("@@cut3")  @dtw_assign(V_N3CUT3,  fieldValue)
                                  @Decat_Field("@@fbnk")  @dtw_assign(V_N3FBNK,  fieldValue)
                                  @Decat_Field("@@tbnk")  @dtw_assign(V_N3TBNK,  fieldValue)
                                  @Decat_Field("@@abnk")  @dtw_assign(V_N3ABNK,  fieldValue)
                                  @Decat_Field("@@sbnk")  @dtw_assign(V_N3SBNK,  fieldValue)
                                  @Decat_Field("@@fvnd")  @dtw_assign(V_N3FVND,  fieldValue)
                                  @Decat_Field("@@tvnd")  @dtw_assign(V_N3TVND,  fieldValue)
                                  @Decat_Field("@@avnd")  @dtw_assign(V_N3AVND,  fieldValue)
                                  @Decat_Field("@@svnd")  @dtw_assign(V_N3SVND,  fieldValue)
                                  @Decat_Field("@@fvdt")  @dtw_assign(V_N3FVDT,  fieldValue)
                                  @Decat_Field("@@tvdt")  @dtw_assign(V_N3TVDT,  fieldValue)
                                  @Decat_Field("@@avdt")  @dtw_assign(V_N3AVDT,  fieldValue)
                                  @Decat_Field("@@svdt")  @dtw_assign(V_N3SVDT,  fieldValue)
                                  @Decat_Field("@@fals")  @dtw_assign(V_N3FALS,  fieldValue)
                                  @Decat_Field("@@tals")  @dtw_assign(V_N3TALS,  fieldValue)
                                  @Decat_Field("@@aals")  @dtw_assign(V_N3AALS,  fieldValue)
                                  @Decat_Field("@@sals")  @dtw_assign(V_N3SALS,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1HLD == "02")
                                      @dtw_assign(includeHeldVouchersNo, "")
                                      @dtw_assign(includeHeldVouchersYes, "CHECKED")
                                  %else
                                      @dtw_assign(includeHeldVouchersNo, "CHECKED")
                                      @dtw_assign(includeHeldVouchersYes, "")
                                  %endif
                                  %if (V_N2BODD == "02")
                                      @dtw_assign(basedOnDiscountDateNo, "")
                                      @dtw_assign(basedOnDiscountDateYes, "CHECKED")
                                  %else
                                      @dtw_assign(basedOnDiscountDateNo, "CHECKED")
                                      @dtw_assign(basedOnDiscountDateYes, "")
                                  %endif
                                  %if (V_N3ABNK == "ALL")
                                      @dtw_assign(checkedAllBankNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllBankNumber, "")
                                  %endif
                                  %if (V_N3AVND == "ALL")
                                      @dtw_assign(checkedAllVendorNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllVendorNumber, "")
                                  %endif
                                  %if (V_N3AVDT == "ALL")
                                      @dtw_assign(checkedAllVendorType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllVendorType, "")
                                  %endif
                                  %if (V_N3AALS == "ALL")
                                      @dtw_assign(checkedAllAlphaSequence, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllAlphaSequence, "")
                                  %endif
                              %else
                                  @dtw_assign(includeHeldVouchersNo, "CHECKED")
                                  @dtw_assign(includeHeldVouchersYes, "")
                                  @dtw_assign(basedOnDiscountDateNo, "CHECKED")
                                  @dtw_assign(basedOnDiscountDateYes, "")
                                  @DateTodayCYMD(V_N3CUR)
                                  @DateInputFromCYMD(V_N3CUR)
                                  @dtw_assign(checkedAllBankNumber, "CHECKED")
                                  @dtw_assign(checkedAllVendorNumber, "CHECKED")
                                  @dtw_assign(checkedAllVendorType, "CHECKED")
                                  @dtw_assign(checkedAllAlphaSequence, "CHECKED")
                              %endif

                              @SetTextOvr(Err_N1HLD)
                              <tr><td class="dsphdr"><span $(textOvr)>Include Held Vouchers</span></td>
                                  <td class="inputnmbr"><input type="radio" name="includeHeldVouchers" VALUE='01' $(includeHeldVouchersNo)>No</td>
                              </tr>
                              @DspErrMsg(Err_N1HLD)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input type="radio" name="includeHeldVouchers" VALUE='02' $(includeHeldVouchersYes)>Yes</td>
                              </tr>

                              @SetTextOvr(Err_N2BODD)
                              <tr><td class="dsphdr"><span $(textOvr)>Based On Discount Date</span></td>
                                  <td class="inputnmbr"><input type="radio" name="basedOnDiscountDate" VALUE='01' $(basedOnDiscountDateNo)>No</td>
                              </tr>
                              @DspErrMsg(Err_N2BODD)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input type="radio" name="basedOnDiscountDate" VALUE='02' $(basedOnDiscountDateYes)>Yes</td>
                              </tr>

                              @SetTextOvr(Err_N3CUR)
                              <tr><td class="dsphdr"><span $(textOvr)>Current Date</span></td>
                                  <td class="inputnmbr"><input type="text" name="currentDate" value="$(V_N3CUR)" size="6" maxlength="6">
                                                        <a href="javascript:calWindow('currentDate');">$(calendarImage)</a></td>
                              </tr>
                              @DspErrMsg(Err_N3CUR)

                              @SetTextOvr(Err_N3CUT1)
                              <tr><td class="dsphdr"><span $(textOvr)>First Cutoff Date</span></td>
                                  <td class="inputnmbr"><input type="text" name="firstCutoffDate" value="$(V_N3CUT1)" size="6" maxlength="6">
                                                        <a href="javascript:calWindow('firstCutoffDate');">$(calendarImage)</a></td>
                              </tr>
                              @DspErrMsg(Err_N3CUT1)

                              @SetTextOvr(Err_N3CUT2)
                              <tr><td class="dsphdr"><span $(textOvr)>Second Cutoff Date</span></td>
                                  <td class="inputnmbr"><input type="text" name="secondCutoffDate" value="$(V_N3CUT2)" size="6" maxlength="6">
                                                        <a href="javascript:calWindow('secondCutoffDate');">$(calendarImage)</a></td>
                              </tr>
                              @DspErrMsg(Err_N3CUT2)

                              @SetTextOvr(Err_N3CUT3)
                              <tr><td class="dsphdr"><span $(textOvr)>Third Cutoff Date</span></td>
                                  <td class="inputnmbr"><input type="text" name="thirdCutoffDate" value="$(V_N3CUT3)" size="6" maxlength="6">
                                                        <a href="javascript:calWindow('thirdCutoffDate');">$(calendarImage)</a></td>
                              </tr>
                              @DspErrMsg(Err_N3CUT3)
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                              </tr>

                              @SetTextOvr(Err_N3FBNK)
                              %if (textOvr == "") @SetTextOvr(Err_N3TBNK) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N3ABNK) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N3SBNK) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Bank</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromBankNumber" value="$(V_N3FBNK)" size="7" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)BankSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromBankNumber&amp;fldDesc=bankName" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="bankName"></td>
                                  <td class="inputnmbr"><input type="text" name="toBankNumber" value="$(V_N3TBNK)" size="7" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)BankSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toBankNumber&amp;fldDesc=bankName" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="bankName"></td>
                                  <td class="inputalph"><input type="checkbox" name="allBankNumber" value='ALL' $(checkedAllBankNumber) onClick="if (this.checked) this.form.fromBankNumber.value='', this.form.toBankNumber.value='';"></td>
                                  <td class="colcode"><input type="hidden" name="sortBankNumber" Value="$(sortBankNumber)" size="1" maxlength="1">$(sortBankNumber)</td>
                              </tr>
                              @DspErrMsg(Err_N3FBNK)
                              @DspErrMsg(Err_N3TBNK)
                              @DspErrMsg(Err_N3ABNK)
                              @DspErrMsg(Err_N3SBNK)

                              @SetTextOvr(Err_N3FVND)
                              %if (textOvr == "") @SetTextOvr(Err_N3TVND) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N3AVND) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N3SVND) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Vendor</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromVendorNumber" value="$(V_N3FVND)" size="7" maxlength="7">
                                                        <a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="vendorName"></td>
                                  <td class="inputnmbr"><input type="text" name="toVendorNumber" value="$(V_N3TVND)" size="7" maxlength="7">
                                                        <a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="vendorName"></td>
                                  <td class="inputalph"><input type="checkbox" name="allVendorNumber" value='ALL' $(checkedAllVendorNumber) onClick="if (this.checked) this.form.fromVendorNumber.value='', this.form.toVendorNumber.value='';"></td>
                                  @Build_Sort_Select("sortVendorNumber", "$(V_N3SVND)")
                              </tr>
                              @DspErrMsg(Err_N3FVND)
                              @DspErrMsg(Err_N3TVND)
                              @DspErrMsg(Err_N3AVND)
                              @DspErrMsg(Err_N3SVND)

                              @SetTextOvr(Err_N3FVDT)
                              %if (textOvr == "") @SetTextOvr(Err_N3TVDT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N3AVDT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N3SVDT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Vendor Type</span></td>
                                  <td class="inputalph"><input type="text" name="fromVendorType" value="$(V_N3FVDT)" size="7" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)VendorTypeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromVendorType&amp;fldDesc=vendorTypeDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="vendorTypeDesc"></td>
                                  <td class="inputalph"><input type="text" name="toVendorType" value="$(V_N3TVDT)" size="7" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)VendorTypeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toVendorType&amp;fldDesc=vendorTypeDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="vendorTypeDesc"></td>
                                  <td class="inputalph"><input type="checkbox" name="allVendorType" value='ALL' $(checkedAllVendorType) onClick="if (this.checked) this.form.fromVendorType.value='', this.form.toVendorType.value='';"></td>
                                  @Build_Sort_Select("sortVendorType", "$(V_N3SVDT)")
                              </tr>
                              @DspErrMsg(Err_N3FVDT)
                              @DspErrMsg(Err_N3TVDT)
                              @DspErrMsg(Err_N3AVDT)
                              @DspErrMsg(Err_N3SVDT)

                              @SetTextOvr(Err_N3FALS)
                              %if (textOvr == "") @SetTextOvr(Err_N3TALS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N3AALS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N3SALS) %endif
                                  <tr><td class="dsphdr"><span $(textOvr)>Alpha Sequence</span></td>
                                      <td class="inputalph"><input type="text" name="fromAlphaSequence" value="$(V_N3FALS)" size="7" maxlength="4"></td>
                                      <td class="inputalph"><input type="text" name="toAlphaSequence" value="$(V_N3TALS)" size="7" maxlength="4"></td>
                                      <td class="inputalph"><input type="checkbox" name="allAlphaSequence" value='ALL' $(checkedAllAlphaSequence) onClick="if (this.checked) this.form.fromAlphaSequence.value='', this.form.toAlphaSequence.value='';"></td>
                                      @Build_Sort_Select("sortAlphaSequence", "$(V_N3SALS)")
                                  </tr>
                                  @DspErrMsg(Err_N3FALS)
                                  @DspErrMsg(Err_N3TALS)
                                  @DspErrMsg(Err_N3AALS)
                                  @DspErrMsg(Err_N3SALS)

                          </table>

                          @dtw_assign(envProgram, "HAPREQ")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                          %if (focusField != "")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HAPCRQ_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allBankNumber)
  @dtw_mUPPERCASE(allVendorNumber)
  @dtw_mUPPERCASE(fromVendorType)
  @dtw_mUPPERCASE(toVendorType)
  @dtw_mUPPERCASE(allVendorType)
  @dtw_mUPPERCASE(fromAlphaSequence)
  @dtw_mUPPERCASE(toAlphaSequence)
  @dtw_mUPPERCASE(allAlphaSequence)

  @dtw_assign(currentDate,@dtw_rstrip(currentDate))
  @dtw_assign(firstCutoffDate,@dtw_rstrip(firstCutoffDate))
  @dtw_assign(secondCutoffDate,@dtw_rstrip(secondCutoffDate))
  @dtw_assign(thirdCutoffDate,@dtw_rstrip(thirdCutoffDate))
  @dtw_assign(fromBankNumber,@dtw_rstrip(fromBankNumber))
  @dtw_assign(toBankNumber,@dtw_rstrip(toBankNumber))
  @dtw_assign(sortBankNumber,@dtw_rstrip(sortBankNumber))
  @dtw_assign(fromVendorNumber,@dtw_rstrip(fromVendorNumber))
  @dtw_assign(toVendorNumber,@dtw_rstrip(toVendorNumber))
  @dtw_assign(sortVendorNumber,@dtw_rstrip(sortVendorNumber))
  @dtw_assign(sortVendorType,@dtw_rstrip(sortVendorType))
  @dtw_assign(sortAlphaSequence,@dtw_rstrip(sortAlphaSequence))

  %if (allBankNumber != "ALL")
      @dtw_assign(allBankNumber, "")
  %endif
  %if (allVendorNumber != "ALL")
      @dtw_assign(allVendorNumber, "")
  %endif
  %if (allVendorType != "ALL")
      @dtw_assign(allVendorType, "")
  %endif
  %if (allAlphaSequence != "ALL")
      @dtw_assign(allAlphaSequence, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@hld@", includeHeldVouchers)
  @Concat_Field("@@bodd", basedOnDiscountDate)
  @Concat_Field("@@cur@", currentDate)
  @Concat_Field("@@cut1", firstCutoffDate)
  @Concat_Field("@@cut2", secondCutoffDate)
  @Concat_Field("@@cut3", thirdCutoffDate)
  @Concat_Field("@@fbnk", fromBankNumber)
  @Concat_Field("@@tbnk", toBankNumber)
  @Concat_Field("@@abnk", allBankNumber)
  @Concat_Field("@@sbnk", sortBankNumber)
  @Concat_Field("@@fvnd", fromVendorNumber)
  @Concat_Field("@@tvnd", toVendorNumber)
  @Concat_Field("@@avnd", allVendorNumber)
  @Concat_Field("@@svnd", sortVendorNumber)
  @Concat_Field("@@fvdt", fromVendorType)
  @Concat_Field("@@tvdt", toVendorType)
  @Concat_Field("@@avdt", allVendorType)
  @Concat_Field("@@svdt", sortVendorType)
  @Concat_Field("@@fals", fromAlphaSequence)
  @Concat_Field("@@tals", toAlphaSequence)
  @Concat_Field("@@aals", allAlphaSequence)
  @Concat_Field("@@sals", sortAlphaSequence)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}