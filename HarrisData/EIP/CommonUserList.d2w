%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Common User List"
  d2wName                 = "CommonUserList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "2"
  helpExt                 = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (editFromToAll(document.Chg.frmIndividual, document.Chg.toIndividual, document.Chg.allIndividual, "A") &&
                      editFromToAll(document.Chg.frmCommon, document.Chg.toCommon, document.Chg.allCommon, "A"))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "COMMONUSERLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          @dtw_assign(focusField, "frmIndividual")
                          %if (errFound != "" || scheduleJobSwitch == "Y")
                              @dtw_assign(scheduleJobSwitch, "")
                              @EdtVarErr(profileHandle, typeValue, edtVar)
                              @dtw_assign(focusField, "")
                              @ErrVarErr(profileHandle, typeError, errVar)
                              @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule, fieldValue)
                              @DecatErr_Field("@@fius", "frmIndividual")     @dtw_assign(Err_N1FIUS, fieldValue)
                              @DecatErr_Field("@@tius", "toIndividual")      @dtw_assign(Err_N1TIUS, fieldValue)
                              @DecatErr_Field("@@aius", "allIndividual")     @dtw_assign(Err_N1AIUS, fieldValue)
                              @DecatErr_Field("@@sius", "srtIndividual")     @dtw_assign(Err_N1SIUS, fieldValue)
                              @DecatErr_Field("@@fcus", "frmCommon")         @dtw_assign(Err_N1FCUS, fieldValue)
                              @DecatErr_Field("@@tcus", "toCommon")          @dtw_assign(Err_N1TCUS, fieldValue)
                              @DecatErr_Field("@@acus", "allCommon")         @dtw_assign(Err_N1ACUS, fieldValue)
                              @DecatErr_Field("@@scus", "srtCommon")         @dtw_assign(Err_N1SCUS, fieldValue)
                              %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                              @Decat_Field("@@fius")  @dtw_assign(V_N1FIUS, fieldValue)
                              @Decat_Field("@@tius")  @dtw_assign(V_N1TIUS, fieldValue)
                              @Decat_Field("@@aius")  @dtw_assign(V_N1AIUS, fieldValue)
                              @Decat_Field("@@sius")  @dtw_assign(V_N1SIUS, fieldValue)
                              @Decat_Field("@@fcus")  @dtw_assign(V_N1FCUS, fieldValue)
                              @Decat_Field("@@tcus")  @dtw_assign(V_N1TCUS, fieldValue)
                              @Decat_Field("@@acus")  @dtw_assign(V_N1ACUS, fieldValue)
                              @Decat_Field("@@scus")  @dtw_assign(V_N1SCUS, fieldValue)
                              %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                          %else
                              @dtw_assign(V_N1AIUS, "ALL")
                              @dtw_assign(V_N1ACUS, "ALL")
                          %endif

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                              </tr>

                              @Field_Checked(V_N1AIUS, "ALL", allChecked)
                              @SetTextOvr(Err_N1FIUS)
                              %if (textOvr == "") @SetTextOvr(Err_N1TIUS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AIUS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SIUS) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Individual User Profile</span></td>
                                  <td class="inputalph"><input type="text" name="frmIndividual" value="$(V_N1FIUS)" size="10" maxlength="10">
                                                        <a href="$(homeURL)$(phpPath)UserSearch.php$(altVarBase)&amp;docName=Chg&amp;userFld=frmIndividual&amp;descFld=frmIndividualDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="frmIndividualDesc"></td>
                                  <td class="inputalph"><input type="text" name="toIndividual" value="$(V_N1TIUS)" size="10" maxlength="10">
                                                        <a href="$(homeURL)$(phpPath)UserSearch.php$(altVarBase)&amp;docName=Chg&amp;userFld=toIndividual&amp;descFld=toIndividualDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="toIndividualDesc"></td>
                                  <td class="inputalph"><input type="checkbox" name="allIndividual" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmIndividual.value='', this.form.toIndividual.value='';"></td>
                                  @Build_Sort_Select("srtIndividual", "$(V_N1SIUS)")
                              </tr>
                              @DspErrMsg(Err_N1FIUS)
                              @DspErrMsg(Err_N1TIUS)
                              @DspErrMsg(Err_N1AIUS)
                              @DspErrMsg(Err_N1SIUS)

                              @Field_Checked(V_N1ACUS, "ALL", allChecked)
                              @SetTextOvr(Err_N1FCUS)
                              %if (textOvr == "") @SetTextOvr(Err_N1TCUS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ACUS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SCUS) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Common User Profile</span></td>
                                  <td class="inputalph"><input type="text" name="frmCommon" value="$(V_N1FCUS)" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input type="text" name="toCommon" value="$(V_N1TCUS)" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input type="checkbox" name="allCommon" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmCommon.value='', this.form.toCommon.value='';"></td>
                                  @Build_Sort_Select("srtCommon", "$(V_N1SCUS)")
                              </tr>
                              @DspErrMsg(Err_N1FCUS)
                              @DspErrMsg(Err_N1TCUS)
                              @DspErrMsg(Err_N1ACUS)
                              @DspErrMsg(Err_N1SCUS)
                          </table>

                          @dtw_assign(envProgram, "HSYCUL")
                          @dtw_assign(envPrinter, "HSYCULPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSYCUS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"

  @dtw_assign(edtVar, "")
  @dtw_mUPPERCASE(frmIndividual)                                                                     @Concat_Field("@@fius", frmIndividual)
  @dtw_mUPPERCASE(toIndividual)                                                                      @Concat_Field("@@tius", toIndividual)
  @dtw_mUPPERCASE(allIndividual) %if (allIndividual != "ALL") @dtw_assign(allIndividual, "") %endif  @Concat_Field("@@aius", allIndividual)
                                                                                                     @Concat_Field("@@sius", @dtw_rstrip(srtIndividual))

  @dtw_mUPPERCASE(frmCommon)                                                             @Concat_Field("@@fcus", frmCommon)
  @dtw_mUPPERCASE(toCommon)                                                              @Concat_Field("@@tcus", toCommon)
  @dtw_mUPPERCASE(allCommon) %if (allCommon != "ALL") @dtw_assign(allCommon, "") %endif  @Concat_Field("@@acus", allCommon)
                                                                                         @Concat_Field("@@scus", @dtw_rstrip(srtCommon))


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}