%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Flexible Spending Accounts"
  d2wName                 = "EmployeeFSA.d2w"
  d2wVarBase              = "$(genericVarBase)$(employeeVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  DTW_PAD_PGM_PARMS       = "YES"
  rowIndexNext            = "1"
  totalPages              = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @dtw_assign(applicationID, "PE")
  @dtw_assign(UVPREmpl, "00000")
  %INCLUDE "EmplUV.icl"
  @dtw_assign(peUserPass, userPass)

  %if (peUserPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function goToPage(selectedPage) {if (selectedPage != "") {self.location=selectedPage;}}
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "EMPLOYEEFSA")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, "SELECT FSCOMP, FSFACL, FSEMPL, FSCOVR, FSPLAN, FSANUL, FSYTDC, ", stmtSQL)
                          @dtw_concat(stmtSQL, "       FSYTDP, FSPYRC, FSPYRP, CVANEG, CVDESC", stmtSQL)
                          @dtw_concat(fileSQL, " PEJLF25 ", fileSQL)
                          @dtw_concat(selectSQL, "FSCOMP=$(prCompany) and FSFACL=$(prFacility) and FSEMPL=$(hrEmployee)", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By FSCOVR,FSPLAN ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @FSA_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) FSA_Query (IN  CHAR(64) profileHandle,
				   CHAR(2)   dataBaseID,
                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
             <col width="80%">
             <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/report") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
          @Ret_Format_EmplName(prCompany, prFacility, UVPREmpl, hrCompany, hrEmployee, "H", F_EmpName)
          <tr><td><h2>$(F_EmpName)</h2></td></tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"
      $(hrTagAttr)

      %if (formatToPrint != "Y")
           %INCLUDE "AssignPageValue.icl"
      %endif

      <table $(contentTable)>
          <tr><th class="colhdr">Benefit<br>Code</th>
              <th class="colhdr">Plan<br>Code</th>
              <th class="colhdr">Annual<br>Contribution</th>
              <th class="colhdr">YTD<br>Contributions</th>
              <th class="colhdr">YTD<br>Payments</th>
              <th class="colhdr">YTD<br>Balance</th>
              <th class="colhdr">YTD<br>Available</th>
              <th class="colhdr">Current<br>Available</th>
              <th class="colhdr">Prior Year<br>Remaining Balance</th>
          </tr>		
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;benefitCode=@dtw_rurlescseq(V_FSCOVR)&amp;planCode=@dtw_rurlescseq(V_FSPLAN)")
              %INCLUDE "SetRowClass.icl"
              @dtw_assign(ytdBalance, "")
              @dtw_subtract(V_FSYTDC, V_FSYTDP, ytdBalance)
              @dtw_assign(ytdAvailable, "")
              @dtw_subtract(V_FSANUL, V_FSYTDP, ytdAvailable)
              @dtw_assign(currentAvailable, "")
              %if (V_CVANEG == "Y")
                  @dtw_assign(currentAvailable, ytdAvailable)
              %else
                  @dtw_assign(currentAvailable, ytdBalance)
              %endif
              @dtw_assign(priorYearBalance, "")
              @dtw_subtract(V_FSPYRC, V_FSPYRP, priorYearBalance)
              <tr class="$(rowClass)">
                  <td class="colcode"><a href="$(homeURL)$(cGIPath)employeeClaims.d2w/REPORT$(maintainVar)" title="View Claims">$(V_FSCOVR)</a></td>
                  <td class="colcode">$(V_FSPLAN)</td>
                  @Format_Nbr($(V_FSANUL), F_FSANUL, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_FSANUL)</td>
                  @Format_Nbr($(V_FSYTDC), F_FSYTDC, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_FSYTDC)</td>
                  @Format_Nbr($(V_FSYTDP), F_FSYTDP, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_FSYTDP)</td>
                  @Format_Nbr($(ytdBalance), F_ytdBalance, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_ytdBalance)</td>
                  @Format_Nbr($(ytdAvailable), F_ytdAvailable, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_ytdAvailable)</td>
                  @Format_Nbr($(currentAvailable), F_currentAvailable, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_currentAvailable)</td>
                  @Format_Nbr($(priorYearBalance), F_priorYearBalance, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_priorYearBalance)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(programName, "HPEFSM")
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (sec_05 == "N")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)ProgOptSecError.d2w/DISPLAY$(genericVarBase)&amp;page_title=@dtw_rurlescseq(page_title)">
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      @Set_SQL(stmtSQL)
  %endif
%}
