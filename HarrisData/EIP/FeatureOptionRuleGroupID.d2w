%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Features And Options Rule Group ID"
  d2wName                 = "FeatureOptionRuleGroupID.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;plantName=@dtw_rurlescseq(plantName)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HHDRGM_E"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  plantNumber             = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @dtw_assign(userPass, "")
  %if (plantNumber > "0")
      @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %endif
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script type="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
                  %INCLUDE "CheckEnterSearch.icl"
                  %INCLUDE "Menu.js"
                  %INCLUDE "numedit.icl"
                  %if (plantNumber > "0")
                      function validate(searchForm) {
                          if (editNum(document.Search.srchPlant, 3, 0))
                              return true;
                      }
                  %else
                      %INCLUDE "NoFormValidate.icl"
                  %endif
               </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                          @dtw_assign(pageID, "FEATOPTRULEGROUPID")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          @dtw_assign(uv_PlantName, "RGPLT")
                          %INCLUDE "userview.icl"

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, "Select RGPLT, RGGPID, RGTFET, RGTOPT, RGRGDS, RGRULE, RGRGDSU ", stmtSQL)
                          %if (plantNumber == "")
                              @dtw_concat(stmtSQL, " , coalesce(PLNAME,' ') as PLNAME, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(upper(PLNAME),' ') as PLNAMEU ", stmtSQL)
                          %endif
                          @dtw_concat(fileSQL, " HDRGID ", fileSQL)
                          %if (plantNumber == "")
                              @dtw_concat(fileSQL, " left join HDPLNT on RGPLT=PLPLNT ", fileSQL)
                          %endif
                          %if (wildCardSearch!="" || plantNumber>"0" || uv_Sql!="")
                              @dtw_concat(selectSQL, "RGGPID>' ' ", selectSQL)
                          %endif
                          %if (plantNumber > "0")
                              @dtw_concat(selectSQL, " and RGPLT=$(plantNumber) ", selectSQL)
                          %endif
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order BY $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @RuleGroupID_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) RuleGroupID_Query (IN  CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (plantNumber > "0")
          @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      %endif
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)FeatureOptionRuleGroupIDMaintain.d2w/MAINTAIN$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(plantNumber)&amp;fromName=@dtw_rurlescseq(plantName)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      %if (plantNumber > "0")
          <table $(contentTable)>
              @Format_Header_URL("Plant", $(plantName), $(plantNumber), "$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(d2wVarBase)")
          </table>
      %endif
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Group ID</th>
                      <th class="colhdr">Description</th>
                      %if (plantNumber == "")
                          <th class="colhdr">Plant</th>
                      %endif
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchGroupID" size="5" maxlength="5">
                          <input type="hidden" name="operGroupID" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchGroupDesc" size="15" maxlength="30">
                          <input type="hidden" name="operGroupDesc" value="LIKE">
                      </td>
                      %if (plantNumber == "")
                          <td><input type="text" class="inputnmbr" name="srchPlant" size="5" maxlength="3">
                              <input type="hidden" name="operPlant" value="=">
                          </td>
                      %endif
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchGroupID.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("RGGPID", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=GroupID" title="Sequence By Group ID"> Group ID</a></th>
              @OrderBy_Sort("RGRGDSU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=GroupDesc" title="Sequence By Description, Group ID"> Description</a></th>
              @OrderBy_Sort("RGTFET", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TargetFeature" title="Sequence By Target Feature, Group ID"> Target<br>Feature</a></th>
              @OrderBy_Sort("RGTOPT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TargetOption" title="Sequence By Target Option, Group ID"> Target<br>Option</a></th>
              @OrderBy_Sort("RGRULE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=IeRule" title="Sequence By Rule, Group ID"> Rule</a></th>
              %if (plantNumber == "")
                  @OrderBy_Sort("RGPLT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlantNumber" title="Sequence By Plant">Plant</a></th>
                  @OrderBy_Sort("PLNAMEU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlantName" title="Sequence By Plant Name">Plant Name</a></th>
              %endif
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(plantNumber)&amp;fromName=@dtw_rurlescseq(plantName)&amp;plantNumber=@dtw_rurlescseq(V_RGPLT)&amp;groupID=@dtw_rurlescseq(V_RGGPID)&amp;targetFeature=@dtw_rurlescseq(V_RGTFET)&amp;targetOption=@dtw_rurlescseq(V_RGTOPT)&amp;groupDesc=@dtw_rurlescseq(V_RGRGDS)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_RGRGDS), $(V_RGGPID), "", "", "", "", confirmDesc)
              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)FeatureOptionRuleGroupIDMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)FeatureOptionRuleGroupIDMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)FeatureOptionRuleGroupIDMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_RGGPID)</td>
                  <td class="colalph">$(V_RGRGDS)</td>
                  <td class="colalph">$(V_RGTFET)</td>
                  <td class="colalph">$(V_RGTOPT)</td>
                  @RtvFldDesc("(FLTYPE='RULE' and FLVALU='$(V_RGRULE)')", "SYFLAG", "FLDESC", ruleDesc)
                  <td class="colcode" $(helpCursor)><span title="$(ruleDesc)">$(V_RGRULE)</span></td>
                  %if (plantNumber == "")
                      <td class="colnmbr">$(V_RGPLT)</td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(V_RGPLT)&amp;plantName=@dtw_rurlescseq(V_PLNAME)" title="View Plant">$(V_PLNAME)</a></td>
                  %endif
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "Select RGPLT, RGGPID, RGTFET, RGTOPT, RGRGDS, RGRULE, RGRGDSU  ", stmtSQL)
  %if (plantNumber == "")
      @dtw_concat(stmtSQL, " , coalesce(PLNAME,' ') as PLNAME, ", stmtSQL)
      @dtw_concat(stmtSQL, " coalesce(upper(PLNAME),' ') as PLNAMEU ", stmtSQL)
  %endif
  @dtw_concat(fileSQL, " HDRGID ", fileSQL)
  %if (plantNumber == "")
      @dtw_concat(fileSQL, " left join HDPLNT on RGPLT=PLPLNT ", fileSQL)
  %endif
  %if (wildCardSearch!="" || plantNumber>"0" || uv_Sql!="")
      @dtw_concat(selectSQL, "RGGPID>' ' ", selectSQL)
  %endif
  %if (plantNumber > "0")
      @dtw_concat(selectSQL, " and RGPLT=$(plantNumber) ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @RuleGroupID_XMLQuery(profileHandle, dataBaseID, stmtSQL)

%}

%FUNCTION(dtw_sql) RuleGroupID_XMLQuery (IN  CHAR(64)    profileHandle,
			                      CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("FeatureOptionRuleGroupIDList")
      %if (plantNumber > "0")
	   @XMLIDTag(plantNumber, "Plant ID")
              @XMLTag(plantNumber, "PlantNumber")
              @XMLTag(plantName, "PlantName")
      %endif		

      %ROW{
          @XMLIDTag("$(V_RGGPID)", "RuleGroup ID")
              @XMLTag(V_RGGPID, "RuleGroup")
              @XMLTag(V_RGRGDS, "GroupDescription")
              @XMLTag(V_RGTFET, "TargetFeature")
              @XMLTag(V_RGTOPT, "TargetOption")
              @XMLTag(V_RGRULE, "IncludeExcludeRule")
              %if (plantNumber == "")
                  @XMLTag(V_RGPLT, "PlantNumber")
                  @XMLTag(V_PLNAME, "PlantName")
              %endif
          @XMLEndTag("RuleGroup")
      %}
      %if (plantNumber > "0")
          @XMLEndTag("Plant")
      %endif
      @XMLEndTag("FeatureOptionRuleGroupIDList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (plantNumber > "0" && orderBy == "PLNAMEU,RGGPID")
          @dtw_assign(orderBy, "")
      %endif
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "RGRGDSU")
          @DTW_ASSIGN(orderByDisplay, "Description")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "GroupID")
      %if (orderBy == "RGGPID")
          @DTW_ASSIGN(orderBy, "RGGPID DESC")
          @DTW_ASSIGN(orderByDisplay, "Group ID (descending)")
      %else
          @DTW_ASSIGN(orderBy, "RGGPID")
          @DTW_ASSIGN(orderByDisplay, "Group ID")
      %endif
  %elif (sequence == "GroupDesc")
      %if (orderBy == "RGRGDSU,RGGPID")
          @DTW_ASSIGN(orderBy, "RGRGDSU DESC,RGGPID")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Group ID")
      %else
          @DTW_ASSIGN(orderBy, "RGRGDSU,RGGPID")
          @DTW_ASSIGN(orderByDisplay, "Description, Group ID")
      %endif
  %elif (sequence == "TargetFeature")
      %if (orderBy == "RGTFET,RGGPID")
          @DTW_ASSIGN(orderBy, "RGTFET DESC,RGGPID")
          @DTW_ASSIGN(orderByDisplay, "Target Feature (descending), Group ID")
      %else
          @DTW_ASSIGN(orderBy, "RGTFET,RGGPID")
          @DTW_ASSIGN(orderByDisplay, "Target Feature, Group ID")
      %endif
  %elif (sequence == "TargetOption")
      %if (orderBy == "RGTOPT,RGGPID")
          @DTW_ASSIGN(orderBy, "RGTOPT DESC,RGGPID")
          @DTW_ASSIGN(orderByDisplay, "Target Option (descending), Group ID")
      %else
          @DTW_ASSIGN(orderBy, "RGTOPT,RGGPID")
          @DTW_ASSIGN(orderByDisplay, "Target Option, Group ID")
      %endif
  %elif (sequence == "IeRule")
      %if (orderBy == "RGRULE,RGGPID")
          @DTW_ASSIGN(orderBy, "RGRULE DESC,RGGPID")
          @DTW_ASSIGN(orderByDisplay, "Rule (descending), Group ID")
      %else
          @DTW_ASSIGN(orderBy, "RGRULE,RGGPID")
          @DTW_ASSIGN(orderByDisplay, "Rule, Group ID")
      %endif
  %elif (sequence == "PlantNumber")
      %if (orderBy == "RGPLT,RGGPID")
          @DTW_ASSIGN(orderBy, "RGPLT DESC,RGGPID")
          @DTW_ASSIGN(orderByDisplay, "Plant Number (descending), Group ID")
      %else
          @DTW_ASSIGN(orderBy, "RGPLT,RGGPID")
          @DTW_ASSIGN(orderByDisplay, "Plant Number, Group ID")
      %endif
  %elif (sequence == "PlantName")
      %if (orderBy == "PLNAMEU,RGGPID")
          @DTW_ASSIGN(orderBy, "PLNAMEU DESC,RGGPID")
          @DTW_ASSIGN(orderByDisplay, "Plant Name (descending), Group ID")
      %else
          @DTW_ASSIGN(orderBy, "PLNAMEU,RGGPID")
          @DTW_ASSIGN(orderByDisplay, "Plant Name, Group ID")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
	       %INCLUDE "numedit.icl"
              %if (plantNumber == "")
                  function validate(searchForm) {
                      if (editNum(document.Search.srchPlant, 3, 0))
                          return true;
                  }
              %else
                  %INCLUDE "NoFormValidate.icl"
              %endif
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "FEATOPTRULEGROUPIDSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Group ID</td>
                              @dtw_assign(operNbr, "operGroupID")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchGroupID" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operGroupDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchGroupDesc" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Target Feature</td>
                              @dtw_assign(operNbr, "operTargetFeature")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchTargetFeature" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">Target Option</td>
                              @dtw_assign(operNbr, "operTargetOption")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchTargetOption" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">Rule</td>
                              @dtw_assign(operNbr, "operIeRule")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchIeRule" size="5" maxlength="1"></td>
                          </tr>

                          %if (plantNumber == "")
                              <tr><td class="dsphdr">Plant Number</td>
                                  @dtw_assign(operNbr, "operPlant")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchPlant" size="5" maxlength="3"></td>
                              </tr>

                              <tr><td class="dsphdr">Plant Name</td>
                                  @dtw_assign(operNbr, "operName")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"> <input type="text" name="srchName" size="15" maxlength="26"></td>
                              </tr>
                          %endif

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchGroupID.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("RGGPID", "Group ID", $(srchGroupID), "U", operGroupID, "A")
  @Build_WildCard ("RGRGDSU", "Description", $(srchGroupDesc), "U", operGroupDesc, "A")
  @Build_WildCard ("RGTFET", "Target Feature", $(srchTargetFeature), "U", operTargetFeature, "A")
  @Build_WildCard ("RGTOPT", "Target Option", $(srchTargetOption), "U", operTargetOption, "A")
  @Build_WildCard ("RGRULE", "Rule", $(srchIeRule), "U", operIeRule, "A")
  %if (plantNumber == "")
      @Build_WildCard ("RGPLT", "Plant Number", $(srchPlant), "", operPlant, "N")
      @Build_WildCard ("upper(PLNAME)", "Plant Name", $(srchName), "U", operName, "A")
  %endif

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
