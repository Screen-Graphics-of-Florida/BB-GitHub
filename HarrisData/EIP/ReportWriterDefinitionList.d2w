%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Report Writer Definition List"
  d2wName                 = "ReportWriterDefinitionList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)&amp;content=@dtw_rurlescseq(content)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  content                 = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  %if (content == "1")
      @dtw_assign(page_title, "Report Writer Definition List - Detail")
  %else
      @dtw_assign(page_title, "Report Writer Definition List - Summary")
  %endif
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"

              function validate(chgForm) {
                  if   (editFromToAll(document.Chg.fromReportName, document.Chg.toReportName, document.Chg.allReportName, "A") &&
                      editFromToAll(document.Chg.fromUserID, document.Chg.toUserID, document.Chg.allUserID, "A") &&
                      editFromToAll(document.Chg.fromCategory, document.Chg.toCategory, document.Chg.allCategory, "A"))
                      return true;
              }

              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "REPORTWRITERDEFINITIONLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromReportName")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@prac", "notUsedAccounts") @dtw_assign(Err_N1PRAC,  fieldValue)
                                  @DecatErr_Field("@@pdac", "duplicateAccounts") @dtw_assign(Err_N1PDAC,  fieldValue)
                                  @DecatErr_Field("@@fgrn", "fromReportName") @dtw_assign(Err_N1FGRN,  fieldValue)
                                  @DecatErr_Field("@@tgrn", "toReportName") @dtw_assign(Err_N1TGRN,  fieldValue)
                                  @DecatErr_Field("@@agrn", "allReportName") @dtw_assign(Err_N1AGRN,  fieldValue)
                                  @DecatErr_Field("@@fuse", "fromUserID") @dtw_assign(Err_N1FUSE,  fieldValue)
                                  @DecatErr_Field("@@tuse", "toUserID") @dtw_assign(Err_N1TUSE,  fieldValue)
                                  @DecatErr_Field("@@ause", "allUserID") @dtw_assign(Err_N1AUSE,  fieldValue)
                                  @DecatErr_Field("@@fcat", "fromCategory") @dtw_assign(Err_N1FCAT,  fieldValue)
                                  @DecatErr_Field("@@tcat", "toCategory") @dtw_assign(Err_N1TCAT,  fieldValue)
                                  @DecatErr_Field("@@acat", "allCategory") @dtw_assign(Err_N1ACAT,  fieldValue)

                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@prac")  @dtw_assign(V_N1PRAC,  fieldValue)
                                  @Decat_Field("@@pdac")  @dtw_assign(V_N1PDAC,  fieldValue)
                                  @Decat_Field("@@fgrn")  @dtw_assign(V_N1FGRN,  fieldValue)
                                  @Decat_Field("@@tgrn")  @dtw_assign(V_N1TGRN,  fieldValue)
                                  @Decat_Field("@@agrn")  @dtw_assign(V_N1AGRN,  fieldValue)
                                  @Decat_Field("@@fuse")  @dtw_assign(V_N1FUSE,  fieldValue)
                                  @Decat_Field("@@tuse")  @dtw_assign(V_N1TUSE,  fieldValue)
                                  @Decat_Field("@@ause")  @dtw_assign(V_N1AUSE,  fieldValue)
                                  @Decat_Field("@@fcat")  @dtw_assign(V_N1FCAT,  fieldValue)
                                  @Decat_Field("@@tcat")  @dtw_assign(V_N1TCAT,  fieldValue)
                                  @Decat_Field("@@acat")  @dtw_assign(V_N1ACAT,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (content == "1")
                                      %if (V_N1PRAC == "1")
                                          @dtw_assign(checkedNotUsedAccounts, "CHECKED")
                                      %else
                                          @dtw_assign(checkedNotUsedAccounts, "")
                                      %endif
                                      %if (V_N1PDAC == "1")
                                          @dtw_assign(checkedDuplicateAccounts, "CHECKED")
                                      %else
                                          @dtw_assign(checkedDuplicateAccounts, "")
                                      %endif
                                  %endif
                                  %if (V_N1AGRN == "ALL")
                                      @dtw_assign(checkedAllReportName, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllReportName, "")
                                  %endif
                                  %if (V_N1AUSE == "ALL")
                                      @dtw_assign(checkedAllUserID, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllUserID, "")
                                  %endif
                                  %if (V_N1ACAT == "ALL")
                                      @dtw_assign(checkedAllCategory, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllCategory, "")
                                  %endif
                              %else
                                  %if (content == "1")
                                      @dtw_assign(checkedNotUsedAccounts, "CHECKED")
                                      @dtw_assign(checkedDuplicateAccounts, "CHECKED")
                                  %endif
                                  @dtw_assign(checkedAllReportName, "CHECKED")
                                  @dtw_assign(checkedAllUserID, "CHECKED")
                                  @dtw_assign(checkedAllCategory, "CHECKED")
                              %endif

                              %if (content == "1")
                                  @SetTextOvr(Err_N1PRAC)
                                  %if (textOvr == "") @SetTextOvr(Err_N1PRAC) %endif
                                      <tr><td class="dsphdr"><span $(textOvr)>Select Options</span></td>
                                          <td class="inputnmbr"><input type="checkbox" name="notUsedAccounts" VALUE='1' $(checkedNotUsedAccounts)>Print G/L Accounts Not Used</td>
                                      </tr>
                                      @DspErrMsg(Err_N1PRAC)

                                      <tr><td>&nbsp;</td>
                                          <td class="inputnmbr"><input type="checkbox" name="duplicateAccounts" VALUE='1' $(checkedDuplicateAccounts)>Print Duplicate G/L Accounts</td>
                                      </tr>
                              %endif
                          </table>

                          <table $(contentTable)>

                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_N1FGRN)
                              %if (textOvr == "") @SetTextOvr(Err_N1TGRN) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AGRN) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Report Name</span></td>
                                  <td class="inputalph"><input type="text" name="fromReportName" value="$(V_N1FGRN)" size="15" maxlength="10">
                                                        <a href="$(homeURL)$(phpPath)GLReportWriterReportSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromReportName&amp;fldDesc=none" onclick="$(searchWinVar)">$(searchImage)</a></td>
                                  <td class="inputalph"><input type="text" name="toReportName" value="$(V_N1TGRN)" size="15" maxlength="10">
                                                        <a href="$(homeURL)$(phpPath)GLReportWriterReportSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toReportName&amp;fldDesc=none" onclick="$(searchWinVar)">$(searchImage)</a></td>
                                  <td class="inputalph"><input type="checkbox" name="allReportName" value='ALL' $(checkedAllReportName) onClick="if (this.checked) this.form.fromReportName.value='', this.form.toReportName.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FGRN)
                              @DspErrMsg(Err_N1TGRN)
                              @DspErrMsg(Err_N1AGRN)

                              @SetTextOvr(Err_N1FUSE)
                              %if (textOvr == "") @SetTextOvr(Err_N1TUSE) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AUSE) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>User ID</span></td>
                                  <td class="inputalph"><input type="text" name="fromUserID" value="$(V_N1FUSE)" size="15" maxlength="10"></td>
                                  <td class="inputalph"><input type="text" name="toUserID" value="$(V_N1TUSE)" size="15" maxlength="10"></td>
                                  <td class="inputalph"><input type="checkbox" name="allUserID" value='ALL' $(checkedAllUserID) onClick="if (this.checked) this.form.fromallUserID.value='', this.form.toallUserID.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FUSE)
                              @DspErrMsg(Err_N1TUSE)
                              @DspErrMsg(Err_N1AUSE)

                              @SetTextOvr(Err_N1FCAT)
                              %if (textOvr == "") @SetTextOvr(Err_N1TCAT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ACAT) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Category</span></td>
                                  <td class="inputalph"><input type="text" name="fromCategory" value="$(V_N1FCAT)" size="15" maxlength="4"></td>
                                  <td class="inputalph"><input type="text" name="toCategory" value="$(V_N1TCAT)" size="15" maxlength="4"></td>
                                  <td class="inputalph"><input type="checkbox" name="allCategory" value='ALL' $(checkedAllCategory) onClick="if (this.checked) this.form.fromallCategory.value='', this.form.toallCategory.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FCAT)
                              @DspErrMsg(Err_N1TCAT)
                              @DspErrMsg(Err_N1ACAT)
                          </table>

                          @dtw_assign(envProgram, "HGLRWL")
                          @dtw_assign(envPrinter, "HGLRWLPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                          %if (focusField != "")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HGLRWK_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(fromReportName)
  @dtw_mUPPERCASE(toReportName)
  @dtw_mUPPERCASE(allReportName)
  @dtw_mUPPERCASE(fromUserID)
  @dtw_mUPPERCASE(toUserID)
  @dtw_mUPPERCASE(allUserID)
  @dtw_mUPPERCASE(fromCategory)
  @dtw_mUPPERCASE(toCategory)
  @dtw_mUPPERCASE(allCategory)

  %if (allReportName != "ALL")
      @dtw_assign(allReportName, "")
  %endif
  %if (allUserID != "ALL")
      @dtw_assign(allUserID, "")
  %endif
  %if (allCategory != "ALL")
      @dtw_assign(allCategory, "")
  %endif

  @dtw_assign(edtVar, "")
  %if (content == "1")
      @Concat_Field("@@sel0", "01")
      @Concat_Field("@@prac", notUsedAccounts)
      @Concat_Field("@@pdac", duplicateAccounts)
  %endif
  %if (content == "2")
      @Concat_Field("@@sel0", "02")
  %endif
  @Concat_Field("@@fgrn", fromReportName)
  @Concat_Field("@@tgrn", toReportName)
  @Concat_Field("@@agrn", allReportName)
  @Concat_Field("@@fuse", fromUserID)
  @Concat_Field("@@tuse", toUserID)
  @Concat_Field("@@ause", allUserID)
  @Concat_Field("@@fcat", fromCategory)
  @Concat_Field("@@tcat", toCategory)
  @Concat_Field("@@acat", allCategory)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}