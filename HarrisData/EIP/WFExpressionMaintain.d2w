%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Condition Expression Maintenance"
  d2wName                 = "WFExpressionMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfCondition=@dtw_rurlescseq(wfCondition)&amp;fromWfExpressionId=@dtw_rurlescseq(fromWfExpressionId)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;updRecNbr=@dtw_rurlescseq(updRecNbr)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;wfExpressionId=@dtw_rurlescseq(wfExpressionId)&amp;maintenanceCode=D"
  programName             = "HWFCNE"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  editVariables           = ""
  parmEdtVar              = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function confirmDelete() {return confirm("$(delRecordConf)")}
              function validate(chgForm) {
                  if (editNum(document.Chg.testSequence, 6, 1) &&
                      editNum(document.Chg.validationId, 15, 0)
                      )
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                   @dtw_assign(pageID, "WFEXPRESSIONMAINT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                      %INCLUDE "MaintainTop.icl"
                      <table $(contentTable)>
                          @RtvFldDesc("CMCOND=$(wfCondition)", "WFCNDM", "CMDESC", wfConditionDescription)
                          @Format_Code(wfCondition, F_wfCondition)
                          <tr><td><h2>$(wfConditionDescription) $(F_wfCondition)</h2></td>
                          </tr>
                      </table>
                      $(hrTagAttr)

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select WFCNDE.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(FLDESC,' ') as FLDESC ", stmtSQL)
                      @dtw_concat(fileSQL, " WFCNDE ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG on FLTYPE='WFCNDCONT' and FLVALU=CEANOR ", fileSQL)
                      @dtw_concat(selectSQL, " CECOND=$(wfCondition) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By CECOND,CETSSQ ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)

                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " WFCNDE ", fileSQL)
                          @dtw_concat(selectSQL, " CECOND=$(wfCondition) and CEEXID=$(wfExpressionId)", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <fieldset class="legendBody">
          <legend class="legendTitle">Expressions for this condition</legend>
          <table $(contentTable)>
              %ROW{
                  @Format_Code(V_CETSSQ, F_CETSSQ)
                  <tr><td class="colalph">$(F_CETSSQ) $(V_FLDESC) $(V_CECONDE)</td></tr>
              %}
          </table>
      </fieldset>
  %}
%}


%FUNCTION(dtw_sql) Maintain_Query (IN  CHAR(64)    profileHandle,
				        CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)

      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          %ROW {
              %if (errFound != "" || maintenanceCode == "A")
                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(edtVar, "")
                      @dtw_assign(focusField, "testSequence")
                  %else
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@tssq", "testSequence")         @dtw_assign(Err_CETSSQ, fieldValue)
                      @DecatErr_Field("@@anor", "expressionSeparator")  @dtw_assign(Err_CEANOR, fieldValue)
                      @DecatErr_Field("@@ptyp", "parmType")             @dtw_assign(Err_CEPTYP, fieldValue)
                      @DecatErr_Field("@@pext", "parmExternalFile")     @dtw_assign(Err_CEPEXT, fieldValue)
                      @DecatErr_Field("@@pwhr", "parmWhereStatement")   @dtw_assign(Err_CEPWHR, fieldValue)
                      @DecatErr_Field("@@pfld", "parmField")            @dtw_assign(Err_CEPFLD, fieldValue)
                      @DecatErr_Field("@@oper", "operand")              @dtw_assign(Err_CEOPER, fieldValue)
                      @DecatErr_Field("@@vtyp", "valueType")            @dtw_assign(Err_CEVTYP, fieldValue)
                      @DecatErr_Field("@@vext", "valueExternalFile")    @dtw_assign(Err_CEVEXT, fieldValue)
                      @DecatErr_Field("@@vwhr", "valueWhereStatement")  @dtw_assign(Err_CEVWHR, fieldValue)
                      @DecatErr_Field("@@vfld", "valueField")           @dtw_assign(Err_CEVFLD, fieldValue)
                      @DecatErr_Field("@@val1", "valueOne")             @dtw_assign(Err_CEVAL1, fieldValue)
                      @DecatErr_Field("@@val2", "valueTwo")             @dtw_assign(Err_CEVAL2, fieldValue)
                      @DecatErr_Field("@@vpgm", "vldProgram")           @dtw_assign(Err_CEVPGM, fieldValue)
                      @DecatErr_Field("@@vlid", "validationId")         @dtw_assign(Err_CEVLID, fieldValue)
                  %endif

                  @Decat_Field("@@exid")   @dtw_assign(V_CEEXID, fieldValue)
                  @Decat_Field("@@tssq")   @dtw_assign(V_CETSSQ, fieldValue)
                  @Decat_Field("@@anor")   @dtw_assign(V_CEANOR, fieldValue)
                  @Decat_Field("@@ptyp")   @dtw_assign(V_CEPTYP, fieldValue)
                  @Decat_Field("@@pext")   @dtw_assign(V_CEPEXT, fieldValue)
                  @Decat_Field("@@pwhr")   @dtw_assign(V_CEPWHR, fieldValue)
                  @Decat_Field("@@pfld")   @dtw_assign(V_CEPFLD, fieldValue)
                  @Decat_Field("@@oper")   @dtw_assign(V_CEOPER, fieldValue)
                  @Decat_Field("@@vtyp")   @dtw_assign(V_CEVTYP, fieldValue)
                  @Decat_Field("@@vext")   @dtw_assign(V_CEVEXT, fieldValue)
                  @Decat_Field("@@vwhr")   @dtw_assign(V_CEVWHR, fieldValue)
                  @Decat_Field("@@vfld")   @dtw_assign(V_CEVFLD, fieldValue)
                  @Decat_Field("@@val1")   @dtw_assign(V_CEVAL1, fieldValue)
                  @Decat_Field("@@val2")   @dtw_assign(V_CEVAL2, fieldValue)
                  @Decat_Field("@@vpgm")   @dtw_assign(V_CEVPGM, fieldValue)
                  @Decat_Field("@@vlid")   @dtw_assign(V_CEVLID, fieldValue)

                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(V_CEEXID, "0")
                      @dtw_assign(V_CETSSQ, "")
                      @dtw_assign(V_CEVLID, "")
                      @dtw_assign(focusField, "testSequence")
                  %endif

                  @dtw_assign(errFound, "")

              %else
                  @dtw_assign(focusField, "testSequence")

                  @RtvFldDesc("PMPARM='$(V_CEPFLD)'", "WFPARM", "PMTYPE", V_PMTYPE)
                  %if (V_PMTYPE == "D")
                      @DateInputFromCYMD(V_CEVAL1)
                      @DateInputFromCYMD(V_CEVAL2)
                  %elif (V_PMTYPE == "L")
                      @DateInputFromISO(V_CEVAL1)
                      @DateInputFromISO(V_CEVAL2)
                  %elif (V_PMTYPE == "P")
                      @PeriodInputFromCYP(V_CEVAL1)
                      @PeriodInputFromCYP(V_CEVAL2)
                  %endif

                  %if (maintenanceCode == "Z")
                      @dtw_assign(V_CEEXID, "0")
                  %endif
              %endif


              <table $(contentTable)>
                  <tr><td><input type="hidden" name="wfExpressionId" value=$(V_CEEXID)></td></tr>

                  @SetTextOvr(Err_CETSSQ)
                  <tr><td class="dsphdr"><span $(textOvr)>Test Sequence</span></td>
                      <td class="inputnmbr"><input type="text" name="testSequence" value="$(V_CETSSQ)" size="8" maxlength="8"></td>
                  </tr>
                  @DspErrMsg(Err_CETSSQ)

                  @RtvFldDesc("FLTYPE='WFCNDCONT' and FLVALU='$(V_CEANOR)'", "SYFLAG", "FLDESC", fieldDesc)
                  @SetTextOvr(Err_CEANOR)
                  <tr><td class="dsphdr"><span $(textOvr)>Expression Separator</span></td>
                      <td class="inputalph"><input type="text" name="expressionSeparator" value="$(V_CEANOR)" size="1" maxlength="1">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=WFCNDCONT&amp;flagSrchHdr=@dtw_rurlescseq("Expression Separator")&amp;docName=Chg&amp;fldName=expressionSeparator&amp;fldDesc=expressionSeparatorDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                                            <input type="text" disabled name="expressionSeparatorDesc" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_CEANOR)
              </table>

              <fieldset class="legendBody">
                  <legend class="legendTitle">Parameter:</legend>
                  <table $(contentTable)>
                      <tr><td class="dsphdr">&nbsp;</td>
                          <td class="colhdr">Parameter</td>
                          <td class="colhdr">Value</td>
                      </tr>

                      @SetTextOvr(Err_CEPTYP) %if (textOvr=="") @SetTextOvr(Err_CEVTYP) %endif
                      <tr><td class="dsphdr"><span $(textOvr)>Type</span></td>
                          @RtvFldDesc("FLTYPE='WFCNDPTYP' and FLVALU='$(V_CEPTYP)'", "SYFLAG", "FLDESC", fieldDesc)
                          <td class="inputalph"><input type="text" name="parmType" value="$(V_CEPTYP)" size="10" maxlength="1">
                                                <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=WFCNDPTYP&amp;flagSrchHdr=@dtw_rurlescseq("Parameter Type")&amp;docName=Chg&amp;fldName=parmType&amp;fldDesc=parmTypeDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                                                <input type="text" disabled name="parmTypeDesc" value="$(fieldDesc)" size="20"></td>

                          @RtvFldDesc("FLTYPE='WFCNDVTYP' and FLVALU='$(V_CEVTYP)'", "SYFLAG", "FLDESC", fieldDesc)
                          <td class="inputalph"><input type="text" name="valueType" value="$(V_CEVTYP)" size="10" maxlength="1">
                                                <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=WFCNDVTYP&amp;flagSrchHdr=@dtw_rurlescseq("Value Type")&amp;docName=Chg&amp;fldName=valueType&amp;fldDesc=valueTypeDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                                                <input type="text" disabled name="valueTypeDesc" value="$(fieldDesc)" size="20"></td>
                      </tr>
                      @DspErrMsg(Err_CEPTYP)
                      @DspErrMsg(Err_CEVTYP)

                      @SetTextOvr(Err_CEPEXT) %if (textOvr=="") @SetTextOvr(Err_CEVEXT) %endif
                      <tr><td class="dsphdr"><span $(textOvr)>External Table</span></td>
                          <td class="inputalph"><input type="text" name="parmExternalFile" value="$(V_CEPEXT)" size="10" maxlength="10"></td>
                          <td class="inputalph"><input type="text" name="valueExternalFile" value="$(V_CEVEXT)" size="10" maxlength="10"></td>
                      </tr>
                      @DspErrMsg(Err_CEPEXT)
                      @DspErrMsg(Err_CEVEXT)

                      @SetTextOvr(Err_CEPWHR) %if (textOvr=="") @SetTextOvr(Err_CEVWHR) %endif
                      <tr><td class="dsphdr"><span $(textOvr)>Where</span></td>
                          <td class="inputalph"><input type="text" name="parmWhereStatement" value="$(V_CEPWHR)" size="30" maxlength="1000"></td>
                          <td class="inputalph"><input type="text" name="valueWhereStatement" value="$(V_CEVWHR)" size="30" maxlength="1000"></td>
                      </tr>
                      @DspErrMsg(Err_CEPWHR)
                      @DspErrMsg(Err_CEVWHR)

                      @SetTextOvr(Err_CEPFLD) %if (textOvr=="") @SetTextOvr(Err_CEVFLD) %endif
                      <tr><td class="dsphdr"><span $(textOvr)>Column</span></td>
                          @RtvFldDesc("PMPARM='$(V_CEPFLD)'", "WFPARM", "PMPRMD", fieldDesc)
                          <td class="inputalph"><input type="text" name="parmField" value="$(V_CEPFLD)" size="10" maxlength="10"><a href="$(homeURL)$(cGIPath)WFParameterSearch.d2w/REPORT$(genericVarBase)&amp;docName=Chg&amp;fldName=parmField&amp;fldDesc=parmFieldDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                                                <input type="text" disabled name="parmFieldDesc" value="$(fieldDesc)" size="20"></td>

                          @RtvFldDesc("PMPARM='$(V_CEVFLD)'", "WFPARM", "PMPRMD", fieldDesc)
                          <td class="inputalph"><input type="text" name="valueField" value="$(V_CEVFLD)" size="10" maxlength="10"><a href="$(homeURL)$(cGIPath)WFParameterSearch.d2w/REPORT$(genericVarBase)&amp;docName=Chg&amp;fldName=valueField&amp;fldDesc=valueFieldDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                                                <input type="text" disabled name="valueFieldDesc" value="$(fieldDesc)" size="20"></td>
                      </tr>
                      @DspErrMsg(Err_CEPFLD)
                      @DspErrMsg(Err_CEVFLD)

                      @RtvFldDesc("FLTYPE='OPERALPH2' and FLVALU='$(V_CEOPER)'", "SYFLAG", "FLDESC", fieldDesc)
                      @SetTextOvr(Err_CEOPER)
                      <tr><td class="dsphdr"><span $(textOvr)>Operand</span></td>
                          <td class="inputalph"><input type="text" name="operand" value="$(V_CEOPER)" size="10" maxlength="10">
                                                <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=OPERALPH2&amp;flagSrchHdr=@dtw_rurlescseq("Operand")&amp;docName=Chg&amp;fldName=operand&amp;fldDesc=operandDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                                                <input type="text" disabled name="operandDesc" value="$(fieldDesc)" size="20"></td>
                      </tr>
                      @DspErrMsg(Err_CEOPER)

                      @SetTextOvr(Err_CEVAL1)
                      <tr><td class="dsphdr"><span $(textOvr)>Value One</span></td>
                          <td class="inputalph">&nbsp;</td>
                          <td class="inputalph"><input type="text" name="valueOne" value="$(V_CEVAL1)" size="30" maxlength="1000"> 		
                                                <a href="javascript:calWindow('valueOne');">$(calendarImage)</a></td>
                      </tr>
                      @DspErrMsg(Err_CEVAL1)

                      @SetTextOvr(Err_CEVAL2)
                      <tr><td class="dsphdr"><span $(textOvr)>Value Two</span></td>
                          <td class="inputalph">&nbsp;</td>
                          <td class="inputalph"><input type="text" name="valueTwo" value="$(V_CEVAL2)" size="30" maxlength="1000"> 		
                                                <a href="javascript:calWindow('valueTwo');">$(calendarImage)</a></td>
                      </tr>
                      @DspErrMsg(Err_CEVAL2)

                  </table>
              </fieldset>

              <fieldset class="legendBody">
                  <legend class="legendTitle">Validation:</legend>
                  <table $(contentTable)>
                      @SetTextOvr(Err_CEVLID)
                      @RtvFldDesc("VIVPGM='$(V_CEVPGM)' and VIVLID=$(V_CEVLID)", "WFVLID", "VIDESC", fieldDesc)
                      <tr><td class="dsphdr"><span $(textOvr)>Validation Program/ID</span></td>
                          <td class="inputnmbr"><input type="text" name="vldProgram" value="$(V_CEVPGM)" size="10" maxlength="10">
                                                <input type="text" name="validationId" value="$(V_CEVLID)" size="15" maxlength="15">
                                                <a href="$(homeURL)$(cGIPath)WFValidationIdSearch.d2w/REPORT$(genericVarBase)&amp;wfVldProgram=@dtw_rurlescseq(vldProgram)&amp;docName=Chg&amp;fldVldProgram=vldProgram&amp;fldVldId=validationId&amp;fldDesc=validationIdDesc" onclick="$(searchWinVar)"> $(searchImage)</a>
                                                <input type="text" disabled name="validationIdDesc" value="$(fieldDesc)" size="40"></td>
                      </tr>
                      @DspErrMsg(Err_CEVLID)
                  </table>
              </fieldset>
          %}
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HWFCNE_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @dtw_mUPPERCASE(expressionSeparator)
  @dtw_mUPPERCASE(parmType)
  @dtw_mUPPERCASE(parmExternalFile)
  @dtw_mUPPERCASE(valueType)
  @dtw_mUPPERCASE(valueExternalFile)
  @dtw_mUPPERCASE(operand)
  @dtw_mUPPERCASE(vldProgram)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@frm1", fromWfExpressionId)
  @Concat_Field("@@cond", wfCondition)
  @Concat_Field("@@exid", wfExpressionId)
  @Concat_Field("@@tssq", testSequence)
  @Concat_Field("@@anor", expressionSeparator)
  @Concat_Field("@@ptyp", parmType)
  @Concat_Field("@@pext", parmExternalFile)
  @Concat_Field("@@pwhr", parmWhereStatement)
  @Concat_Field("@@pfld", parmField)
  @Concat_Field("@@oper", operand)
  @Concat_Field("@@vtyp", valueType)
  @Concat_Field("@@vext", valueExternalFile)
  @Concat_Field("@@vwhr", valueWhereStatement)
  @Concat_Field("@@vfld", valueField)
  @Concat_Field("@@val1", valueOne)
  @Concat_Field("@@val2", valueTwo)
  @Concat_Field("@@vpgm", vldProgram)
  @Concat_Field("@@vlid", validationId)
  @dtw_concat(edtVar, "}{", edtVar)

  %if (maintenanceCode != "A")
      @RtvFldDesc("CECOND=$(wfCondition) and CEEXID=$(wfExpressionId) ", "WFCNDE", "CECONDE", V_CECONDE)
  %endif

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (maintenanceCode == "A")
      @Decat_Field("@@exid")   @dtw_assign(wfExpressionId, fieldValue)
      @RtvFldDesc("CECOND=$(wfCondition) and CEEXID=$(wfExpressionId) ", "WFCNDE", "CECONDE", V_CECONDE)
  %endif

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(V_CECONDE), "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)WFExpression.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)&amp;maintenanceCode=C">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@tssq", "testSequence")
      @Format_ConfMsg_Desc("", $(V_CECONDE), "", "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)WFExpression.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)&amp;maintenanceCode=C">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;wfExpressionId=@dtw_rurlescseq(wfExpressionId)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
