%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Workflow Script Maintenance"
  d2wName                 = "WFD2WMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromWFD2W=@dtw_rurlescseq(fromWFD2W)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;backHome=@dtw_rurlescseq(backHome)&amp;updRecNbr=@dtw_rurlescseq(updRecNbr)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;wfD2W=@dtw_rurlescseq(wfD2W)&amp;maintenanceCode=D"
  programName             = "HWFD2M"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function confirmDelete() {return confirm("$(delRecordConf)")}
              function validate(chgForm) {
                  if (document.Chg.wfD2W.value =="" ||
                      document.Chg.wfD2WDescription.value =="")
                         {alert("$(reqFieldError)"); return false;}
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFD2WMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " WFD2WN", fileSQL)
                          @dtw_concat(selectSQL, " D2D2W  = '$(wfD2W)'", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=150")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "wfD2W")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@d2w@", "wfD2W")                   @dtw_assign(Err_D2D2W , fieldValue)
                          @DecatErr_Field("@@desc", "wfD2WDescription")        @dtw_assign(Err_D2DESC, fieldValue)
                          @DecatErr_Field("@@optp", "optionTransitionPass")    @dtw_assign(Err_D2OPTP, fieldValue)
                          @DecatErr_Field("@@optf", "optionTransitionFail")    @dtw_assign(Err_D2OPTF, fieldValue)
                          @DecatErr_Field("@@accp", "partAccessPass")          @dtw_assign(Err_D2ACCP, fieldValue)
                      %endif

                      @Decat_Field("@@d2w@")   @dtw_assign(V_D2D2W , fieldValue)
                      @Decat_Field("@@desc")   @dtw_assign(V_D2DESC, fieldValue)
                      @Decat_Field("@@optp")   @dtw_assign(V_D2OPTP, fieldValue)
                      @Decat_Field("@@optf")   @dtw_assign(V_D2OPTF, fieldValue)
                      @Decat_Field("@@accp")   @dtw_assign(V_D2ACCP, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "wfD2W")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "wfD2W")
                  %else
                      @dtw_assign(focusField, "wfD2WDescription")
                  %endif

                  @SetTextOvr(Err_D2D2W )
                  <tr><td class="dsphdr"><span $(textOvr)>Script</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="wfD2W" type="text" value="$(V_D2D2W)" size="50" maxlength="100"> $(reqFieldChar) </td>
                      %else
                          <td class="inputalph"><input name="wfD2W" type="hidden" value="$(V_D2D2W)">$(V_D2D2W)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_D2D2W )

                  @SetTextOvr(Err_D2DESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="wfD2WDescription" type="text" value="$(V_D2DESC)" size="50" maxlength="50"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_D2DESC)

                  @RtvFldDesc("FLTYPE='BY' and FLVALU='$(V_D2OPTP)'", "SYFLAG", "FLDESC", fieldDesc)
                  @SetTextOvr(Err_D2OPTP)
                  <tr><td class="dsphdr"><span $(textOvr)>Allow Optional Transition For Pass</span></td>
                      <td class="inputalph"><input name="optionTransitionPass" type="text" value="$(V_D2OPTP)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=BY&amp;flagSrchHdr=@dtw_rurlescseq("Allow Optional Transition For Pass")&amp;docName=Chg&amp;fldName=optionTransitionPass&amp;fldDesc=optionTransitionPassDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                            <input name="optionTransitionPassDesc" value="$(fieldDesc)" type="text" size="30" disabled></td>
                  </tr>
                  @DspErrMsg(Err_D2OPTP)

                  @RtvFldDesc("FLTYPE='BY' and FLVALU='$(V_D2OPTF)'", "SYFLAG", "FLDESC", fieldDesc)
                  @SetTextOvr(Err_D2OPTF)
                  <tr><td class="dsphdr"><span $(textOvr)>Allow Optional Transition For Fail</span></td>
                      <td class="inputalph"><input name="optionTransitionFail" type="text" value="$(V_D2OPTF)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=BY&amp;flagSrchHdr=@dtw_rurlescseq("Allow Optional Transition For Fail")&amp;docName=Chg&amp;fldName=optionTransitionFail&amp;fldDesc=optionTransitionFailDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                            <input name="optionTransitionFailDesc" value="$(fieldDesc)" type="text" size="30" disabled></td>
                  </tr>
                  @DspErrMsg(Err_D2OPTF)

                  @RtvFldDesc("FLTYPE='WFD2WACCSS' and FLVALU='$(V_D2ACCP)'", "SYFLAG", "FLDESC", fieldDesc)
                  @SetTextOvr(Err_D2ACCP)
                  <tr><td class="dsphdr"><span $(textOvr)>Participant Access For Pass</span></td>
                      <td class="inputalph"><input name="partAccessPass" type="text" value="$(V_D2ACCP)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=WFD2WACCSS&amp;flagSrchHdr=@dtw_rurlescseq("Participant Access For Pass")&amp;docName=Chg&amp;fldName=partAccessPass&amp;fldDesc=partAccessPassDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                            <input name="partAccessPassDesc" value="$(fieldDesc)" type="text" size="30" disabled></td>
                  </tr>
                  @DspErrMsg(Err_D2ACCP)
              %}
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HWFD2M_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  %if (wfD2WDescription == "")
      @RtvFldDesc("D2D2W ='$(wfD2W)' ", "WFD2WN", "D2DESC", wfD2WDescription)
  %endif

  @dtw_mUPPERCASE(wfD2W)
  @dtw_mUPPERCASE(optionTransitionPass)
  @dtw_mUPPERCASE(optionTransitionFail)
  @dtw_mUPPERCASE(partAccessPass)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@frm1", fromWFD2W)
  @Concat_Field("@@d2w@", wfD2W)
  @Concat_Field("@@desc", wfD2WDescription)
  @Concat_Field("@@optp", optionTransitionPass)
  @Concat_Field("@@optf", optionTransitionFail)
  @Concat_Field("@@accp", partAccessPass)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(wfD2WDescription), $(wfD2W), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@d2w@", "wfD2W")
          @Format_ConfMsg_Desc("", $(wfD2WDescription), $(wfD2W), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=150&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;wfD2W=@dtw_rurlescseq(wfD2W)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
