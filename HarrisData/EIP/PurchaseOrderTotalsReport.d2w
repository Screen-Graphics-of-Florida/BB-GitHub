%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Purchase Order Totals Report"
  d2wName                 = "PurchaseOrderTotalsReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if  (editdate(document.Chg.fromRequiredDate) &&
                      editdate(document.Chg.toRequiredDate) &&
                      editFromToAll(document.Chg.fromRequiredDate, document.Chg.toRequiredDate, document.Chg.allRequiredDate, "D"))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PURCHASEORDERTOTALSREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromRequiredDate")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@selc", "reportContent")     @dtw_assign(Err_N1SEL,  fieldValue)
                                  @DecatErr_Field("@@frtd", "fromRequiredDate")      @dtw_assign(Err_N2FRTD,  fieldValue)
                                  @DecatErr_Field("@@totd", "toRequiredDate")        @dtw_assign(Err_N2TOTD,  fieldValue)
                                  @DecatErr_Field("@@altd", "allRequiredDate")       @dtw_assign(Err_N2ALTD,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@selc")  @dtw_assign(V_N1SEL,  fieldValue)
                                  @Decat_Field("@@frtd")  @dtw_assign(V_N2FRTD,  fieldValue)
                                  @Decat_Field("@@totd")  @dtw_assign(V_N2TOTD,  fieldValue)
                                  @Decat_Field("@@altd")  @dtw_assign(V_N2ALTD,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1SEL == "02")
                                      @dtw_assign(byDay, "")
                                      @dtw_assign(byMonth, "CHECKED")
                                  %else
                                      @dtw_assign(byDay, "CHECKED")
                                      @dtw_assign(byMonth, "")
                                  %endif
                                  %if (V_N2ALTD == "ALL")
                                      @dtw_assign(checkedallRequiredDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallRequiredDate, "")
                                  %endif
                              %else
                                  @dtw_assign(byDay, "CHECKED")
                                  @dtw_assign(byMonth, "")
                                  @dtw_assign(checkedallRequiredDate, "CHECKED")
                              %endif

                              @SetTextOvr(Err_N1SEL)
                              <tr><td class="dsphdr"><span $(textOvr)>Report Content Selection</span></td>
                                  <td class="inputnmbr"><input name="reportContent" type="radio" VALUE='01' $(byDay)>By Day</td>
                              </tr>
                              @DspErrMsg(Err_N1SEL)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="reportContent" type="radio" VALUE='02' $(byMonth)>By Month</td>
                              </tr>

                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_N2FRTD)
                              %if (textOvr == "") @SetTextOvr(Err_N2TOTD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2ALTD) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Required Date</span></td>
                               <td class="inputnmbr"><input name="fromRequiredDate" value="$(V_N2FRTD)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromRequiredDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toRequiredDate" value="$(V_N2TOTD)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toRequiredDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allRequiredDate" value='ALL' $(checkedallRequiredDate) type="checkbox" onClick="if (this.checked) this.form.fromRequiredDate.value='', this.form.toRequiredDate.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N2FRTD)
                              @DspErrMsg(Err_N2TOTD)
                              @DspErrMsg(Err_N2ALTD)

                          </table>

                          @dtw_assign(envProgram, "HPOOTR")
                          @dtw_assign(envPrinter, "HPOOTRPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HPOOTS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allRequiredDate)

  @dtw_assign(fromRequiredDate,@dtw_rstrip(fromRequiredDate))
  @dtw_assign(toRequiredDate,@dtw_rstrip(toRequiredDate))

  %if (allRequiredDate != "ALL")
      @dtw_assign(allRequiredDate, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@selc", reportContent)
  @Concat_Field("@@frtd", fromRequiredDate)
  @Concat_Field("@@totd", toRequiredDate)
  @Concat_Field("@@altd", allRequiredDate)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}