%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%INCLUDE "APControl$(dataBaseID).icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%if (V_HDMCRL == "0")
    @dtw_assign(V_CPPRMC, "N")
%endif

%Define {
  page_title              = "Vendor Purchase History Report"
  d2wName                 = "VendorPurchaseHistoryReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"

              function validate(chgForm) {
                  if  (editNum(document.Chg.fromVendorNumber, 7, 0) &&
                      editNum(document.Chg.toVendorNumber, 7, 0) &&
                      editdate(document.Chg.fromInvoiceDate) &&
                      editdate(document.Chg.toInvoiceDate) &&
                      editFromToAll(document.Chg.fromAlphaSequence, document.Chg.toAlphaSequence, document.Chg.allAlphaSequence, "A") &&
                      editFromToAll(document.Chg.fromVendorNumber, document.Chg.toVendorNumber, document.Chg.allVendorNumber, 7) &&
                      editFromToAll(document.Chg.fromInvoiceDate, document.Chg.toInvoiceDate, document.Chg.allInvoiceDate, "D") &&
                      editFromToAll(document.Chg.fromVendorType, document.Chg.toVendorType, document.Chg.allVendorType, "A"))
                      return true;
              }

              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "VENDORPURCHASEHISTORYREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromAlphaSequence")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@seqn", "reportSequence") @dtw_assign(Err_N1SEQN,  fieldValue)
                                  @DecatErr_Field("@@fma@", "fromAlphaSequence") @dtw_assign(Err_N2FMA,  fieldValue)
                                  @DecatErr_Field("@@toa@", "toAlphaSequence") @dtw_assign(Err_N2TOA,  fieldValue)
                                  @DecatErr_Field("@@alla", "allAlphaSequence") @dtw_assign(Err_N2ALLA,  fieldValue)
                                  @DecatErr_Field("@@fmv@", "fromVendorNumber") @dtw_assign(Err_N2FMV,  fieldValue)
                                  @DecatErr_Field("@@tov@", "toVendorNumber") @dtw_assign(Err_N2TOV,  fieldValue)
                                  @DecatErr_Field("@@allv", "allVendorNumber") @dtw_assign(Err_N2ALLV,  fieldValue)
                                  @DecatErr_Field("@@fmd@", "fromInvoiceDate") @dtw_assign(Err_N2FMD,  fieldValue)
                                  @DecatErr_Field("@@tod@", "toInvoiceDate") @dtw_assign(Err_N2TOD,  fieldValue)
                                  @DecatErr_Field("@@alld", "allInvoiceDate") @dtw_assign(Err_N2ALLD,  fieldValue)
                                  @DecatErr_Field("@@fmt@", "fromVendorType") @dtw_assign(Err_N2FMT,  fieldValue)
                                  @DecatErr_Field("@@tot@", "toVendorType") @dtw_assign(Err_N2TOT,  fieldValue)
                                  @DecatErr_Field("@@allt", "allVendorType") @dtw_assign(Err_N2ALLT,  fieldValue)
                                  %if (V_CPPRMC == "Y")
                                      @DecatErr_Field("@@iod@", "currencyID") @dtw_assign(Err_N2IOD,  fieldValue)
                                      @DecatErr_Field("@@curt", "currencyType") @dtw_assign(Err_N2CURT,  fieldValue)
                                  %endif

                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@seqn")  @dtw_assign(V_N1SEQN,  fieldValue)
                                  @Decat_Field("@@fma@")  @dtw_assign(V_N2FMA,  fieldValue)
                                  @Decat_Field("@@toa@")  @dtw_assign(V_N2TOA,  fieldValue)
                                  @Decat_Field("@@alla")  @dtw_assign(V_N2ALLA,  fieldValue)
                                  @Decat_Field("@@fmv@")  @dtw_assign(V_N2FMV,  fieldValue)
                                  @Decat_Field("@@tov@")  @dtw_assign(V_N2TOV,  fieldValue)
                                  @Decat_Field("@@allv")  @dtw_assign(V_N2ALLV,  fieldValue)
                                  @Decat_Field("@@fmd@")  @dtw_assign(V_N2FMD,  fieldValue)
                                  @Decat_Field("@@tod@")  @dtw_assign(V_N2TOD,  fieldValue)
                                  @Decat_Field("@@alld")  @dtw_assign(V_N2ALLD,  fieldValue)
                                  @Decat_Field("@@fmt@")  @dtw_assign(V_N2FMT,  fieldValue)
                                  @Decat_Field("@@tot@")  @dtw_assign(V_N2TOT,  fieldValue)
                                  @Decat_Field("@@allt")  @dtw_assign(V_N2ALLT,  fieldValue)
                                  %if (V_CPPRMC == "Y")
                                      @Decat_Field("@@iod@")  @dtw_assign(V_N2IOD,  fieldValue)
                                      @Decat_Field("@@curt")  @dtw_assign(V_N2CURT,  fieldValue)
                                  %endif
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1SEQN == "02")
                                      @dtw_assign(alpha, "")
                                      @dtw_assign(vendorNumber, "CHECKED")
                                  %else
                                      @dtw_assign(alpha, "CHECKED")
                                      @dtw_assign(vendorNumber, "")
                                  %endif
                                  %if (V_N2ALLA == "ALL")
                                      @dtw_assign(checkedAllAlphaSequence, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllAlphaSequence, "")
                                  %endif
                                  %if (V_N2ALLV == "ALL")
                                      @dtw_assign(checkedAllVendorNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllVendorNumber, "")
                                  %endif
                                  %if (V_N2ALLD == "ALL")
                                      @dtw_assign(checkedAllInvoiceDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllInvoiceDate, "")
                                  %endif
                                  %if (V_N2ALLT == "ALL")
                                      @dtw_assign(checkedAllVendorType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllVendorType, "")
                                  %endif
                              %else
                                  @dtw_assign(alpha, "CHECKED")
                                  @dtw_assign(vendorNumber, "")
                                  @dtw_assign(checkedAllAlphaSequence, "CHECKED")
                                  @dtw_assign(checkedAllVendorNumber, "CHECKED")
                                  @dtw_assign(checkedAllInvoiceDate, "CHECKED")
                                  @dtw_assign(checkedAllVendorType, "CHECKED")
                                  %if (V_CPPRMC == "Y")
                                      @dtw_assign(V_N2IOD, "I")
                                      @dtw_assign(currencyType, "")
                                  %endif
                              %endif

                              @SetTextOvr(Err_N1SEQN)
                              <tr><td  class="dsphdr"><span $(textOvr)>Report Sequence</span></td>
                                  <td class="inputnmbr"><input type="radio" name="reportSequence" VALUE='01' $(alpha)>Alpha</td>
                              </tr>
                              @DspErrMsg(Err_N1SEQN)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input type="radio" name="reportSequence" VALUE='02' $(vendorNumber)>Vendor Number</td>
                              </tr>

                          </table>

                          <table $(contentTable)>
                              <td><input type="hidden" name="multiCurrency" value="$(V_CPPRMC)"></td>

                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_N2FMA)
                              %if (textOvr == "") @SetTextOvr(Err_N2TOA) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2ALLA) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Alpha Sequence</span></td>
                                  <td class="inputalph"><input type="text" name="fromAlphaSequence" value="$(V_N2FMA)" size="7" maxlength="4"></td>
                                  <td class="inputalph"><input type="text" name="toAlphaSequence" value="$(V_N2TOA)" size="7" maxlength="4"></td>
                                  <td class="inputalph"><input type="checkbox" name="allAlphaSequence" value='ALL' $(checkedAllAlphaSequence) onClick="if (this.checked) this.form.fromAlphaSequence.value='', this.form.toAlphaSequence.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N2FMA)
                              @DspErrMsg(Err_N2TOA)
                              @DspErrMsg(Err_N2ALLA)

                              @SetTextOvr(Err_N2FMV)
                              %if (textOvr == "") @SetTextOvr(Err_N2TOV) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2ALLV) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Vendor</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromVendorNumber" value="$(V_N2FMV)" size="7" maxlength="7">
                                                        <a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="vendorName"></td>
                                  <td class="inputnmbr"><input type="text" name="toVendorNumber" value="$(V_N2TOV)" size="7" maxlength="7">
                                                        <a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="vendorName"></td>
                                  <td class="inputalph"><input type="checkbox" name="allVendorNumber" value='ALL' $(checkedAllVendorNumber) onClick="if (this.checked) this.form.fromVendorNumber.value='', this.form.toVendorNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N2FMV)
                              @DspErrMsg(Err_N2TOV)
                              @DspErrMsg(Err_N2ALLV)

                              @SetTextOvr(Err_N2FMD)
                              %if (textOvr == "") @SetTextOvr(Err_N2TOD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2ALLD) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Invoice Date</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromInvoiceDate" value="$(V_N2FMD)" size="7" maxlength="6">
                                                        <a href="javascript:calWindow('fromInvoiceDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input type="text" name="toInvoiceDate" value="$(V_N2TOD)" size="7" maxlength="6">
                                                        <a href="javascript:calWindow('toInvoiceDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input type="checkbox" name="allInvoiceDate" value='ALL' $(checkedAllInvoiceDate) onClick="if (this.checked) this.form.fromInvoiceDate.value='', this.form.toInvoiceDate.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N2FMD)
                              @DspErrMsg(Err_N2TOD)
                              @DspErrMsg(Err_N2ALLD)

                              @SetTextOvr(Err_N2FMT)
                              %if (textOvr == "") @SetTextOvr(Err_N2TOT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2ALLT) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Vendor Type</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromVendorType" value="$(V_N2FMT)" size="7" maxlength="7">
                                                        <a href="$(homeURL)$(phpPath)VendorTypeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromVendorType&amp;fldDesc=vendorTypeDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="vendorTypeDesc"></td>
                                  <td class="inputnmbr"><input type="text" name="toVendorType" value="$(V_N2TOT)" size="7" maxlength="7">
                                                        <a href="$(homeURL)$(phpPath)VendorTypeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toVendorType&amp;fldDesc=vendorTypeDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="vendorTypeDesc"></td>
                                  <td class="inputalph"><input type="checkbox" name="allVendorType" value='ALL' $(checkedAllVendorType) onClick="if (this.checked) this.form.fromVendorType.value='', this.form.toVendorType.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N2FMT)
                              @DspErrMsg(Err_N2TOT)
                              @DspErrMsg(Err_N2ALLT)

                              %if (V_CPPRMC == "Y")
                                  @SetTextOvr(Err_N2IOD)
                                  <tr><td class="dsphdr"><span $(textOvr)>Invoice/Domestic Currency (I,D)</span></td>
                                      <td class="inputalph"><input type="text" name="currencyID" value="$(V_N2IOD)" size="3" maxlength="1">
                                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=INVDOM&amp;flagSrchHdr=@dtw_rurlescseq("Invoice/Domestic Currency")&amp;docName=Chg&amp;fldName=currencyID&amp;fldDesc=currencyIDDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                            <input type="hidden" name="currencyIDDesc"></td>
                                  </tr>
                                  @DspErrMsg(Err_N2IOD)

                                 <tr><td  class="dsphdr">--OR--</td></tr>

                                  @SetTextOvr(Err_N2CURT)
                                  <tr><td class="dsphdr"><span $(textOvr)>Convert To Currency Type</span></td>
                                      <td class="inputalph"><input type="text" name="currencyType" value="$(V_N2CURT)" size="3" maxlength="3">
                                                            <a href="$(homeURL)$(phpPath)CurrencyTypeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=currencyType&amp;fldDesc=currencyTypeDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                            <input type="hidden" name="currencyTypeDesc"></td>
                                  </tr>
                                  @DspErrMsg(Err_N2CURT)
                              %endif
                          </table>

                          @dtw_assign(envProgram, "HAPVPH")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                          %if (focusField != "")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HAPVAS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(fromAlphaSequence)
  @dtw_mUPPERCASE(toAlphaSequence)
  @dtw_mUPPERCASE(allAlphaSequence)
  @dtw_mUPPERCASE(allVendorNumber)
  @dtw_mUPPERCASE(allInvoiceDate)
  @dtw_mUPPERCASE(fromVendorType)
  @dtw_mUPPERCASE(toVendorType)
  @dtw_mUPPERCASE(allVendorType)
  @dtw_mUPPERCASE(currencyID)
  @dtw_mUPPERCASE(currencyType)

  @dtw_assign(fromVendorNumber,@dtw_rstrip(fromVendorNumber))
  @dtw_assign(toVendorNumber,@dtw_rstrip(toVendorNumber))
  @dtw_assign(fromInvoiceDate,@dtw_rstrip(fromInvoiceDate))
  @dtw_assign(toInvoiceDate,@dtw_rstrip(toInvoiceDate))

  %if (allAlphaSequence != "ALL")
      @dtw_assign(allAlphaSequence, "")
  %endif
  %if (allVendorNumber != "ALL")
      @dtw_assign(allVendorNumber, "")
  %endif
  %if (allInvoiceDate != "ALL")
      @dtw_assign(allInvoiceDate, "")
  %endif
  %if (allVendorType != "ALL")
      @dtw_assign(allVendorType, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@mult", multiCurrency)
  @Concat_Field("@@seqn", reportSequence)
  @Concat_Field("@@fma@", fromAlphaSequence)
  @Concat_Field("@@toa@", toAlphaSequence)
  @Concat_Field("@@alla", allAlphaSequence)
  @Concat_Field("@@fmv@", fromVendorNumber)
  @Concat_Field("@@tov@", toVendorNumber)
  @Concat_Field("@@allv", allVendorNumber)
  @Concat_Field("@@fmd@", fromInvoiceDate)
  @Concat_Field("@@tod@", toInvoiceDate)
  @Concat_Field("@@alld", allInvoiceDate)
  @Concat_Field("@@fmt@", fromVendorType)
  @Concat_Field("@@tot@", toVendorType)
  @Concat_Field("@@allt", allVendorType)
  @Concat_Field("@@iod@", currencyID)
  @Concat_Field("@@curt", currencyType)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}