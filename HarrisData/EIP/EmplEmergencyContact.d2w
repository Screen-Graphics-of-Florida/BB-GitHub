%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title 	        = "Emergency Contact"
  d2wName              = "EmplEmergencyContact.d2w"
  d2wVarBase           = "$(genericVarBase)$(employeeVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName          = "HPEECI"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  RPT_MAX_ROWS         = "99"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext	        = "1"
  totalPages	        = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	

 %INCLUDE "$(docType)"
 <html>
     <head>
	  %INCLUDE "$(headInclude)"
         <script TYPE="text/javascript">
             %INCLUDE "NewWindowOpen.icl"
         </script>
         %INCLUDE "$(genericHead)"
     </head>
     <body $(bodyTagAttr)>
         <!-- Start Of Banner Code -->
         %INCLUDE "banner.icl"
         <!-- End Of Banner Code -->
         <table $(baseTable)>
             <tr valign="top">
                 %if (formatToPrint == "")
                      @dtw_assign(pageID, "EMPLOYEEEMERGENCY")
                     <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                 %endif
                 <td class="content">

                     @dtw_assign(uv_HRCompanyName, "EMPECP")
                     @dtw_assign(uv_HomeDepartmentName, "EMDEPT")
                     @dtw_assign(uv_HRLocationName, "EMLOC")
                     %INCLUDE "userview.icl"

                     @dtw_assign(stmtSQL, "")
                     @dtw_concat(stmtSQL, "Select * From PEJLF01 ", stmtSQL)
                     @dtw_concat(stmtSQL, " WHERE EMCOMP=$(prCompany) and EMFACL=$(prFacility) and ", stmtSQL)
                     @dtw_concat(stmtSQL, " EMPECP=$(hrCompany) and EMEMPL=$(prEmployee) and EMPEMP=$(hrEmployee)", stmtSQL)
                     %if (uv_Sql != "")
                         @dtw_concat(stmtSQL, " and $(uv_Sql) ", stmtSQL)
                     %endif
                     %INCLUDE "stmtSQLEnd.icl"
                     @Emergency_Contact_Query(profileHandle, dataBaseID, stmtSQL)
                 </td>
             </tr>
         </table>
         <!-- Start Of Trailer Code -->
         %INCLUDE "trailer.icl"
         <!-- Start Of Trailer Code -->
     </body>
 </html>
%}

%FUNCTION(dtw_sql) Emergency_Contact_Query (IN CHAR(64)    profileHandle,
				                CHAR(2)     dataBaseID,
                                               CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitleWithPrint.icl"

      <table $(contentTable)>
          @RetHrCompNam(profileHandle, dataBaseID, prCompany, prFacility, coFacName)
          @Format_HRCoFac("$(prCompany)", "$(prFacility)", "", F_CoFac)
          @Format_Header("Company/Facility", $(coFacName), $(F_CoFac))
          @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
          @Format_Header_URL("Employee Number", $(F_EmpName), $(prEmployee), "$(homeURL)$(cGIPath)EmployeeProfile.d2w/REPORT$(d2wVarBase)")
          @RtvFldDesc("EMPECP=$(hrCompany) and EMPEMP=$(hrEmployee) ", "HREMPL", "EMLOC", location)
          @RtvFldDesc("ODCOMP=$(hrCompany) and ODTYPE='O' and ODCODE='$(location)' ", "PECODE", "ODDESC", HrCodeDesc)
          @Format_Header("Location", $(HrCodeDesc), $(location))
          @RtvFldDesc("EMPECP=$(hrCompany) and EMPEMP=$(hrEmployee) ", "HREMPL", "EMDEPT", department)
          @RtvFldDesc("EADEPT='$(department)' ", "PREXAC", "EANAME", deptName)
          @Format_Header("Department", $(deptName), "$(department)")
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      <table $(contentTable)>
	   		
          %ROW {
              %if (V_EPCNME == "" && V_EPCNA2 == "")		
                  <tr><td class="dsphdr">No emergency contact information on file</td></tr>
              %else
                  %if (V_EPCNME != "")		
                      %if (V_EPC2NM == "")		
                          <tr><td class="dsphdr">Emergency Contact</td>
                      %else
                          <tr><td class="dsphdr">Emergency Contact One</td>
                      %endif
                          <td class="dspalph">$(V_EPCNME)</td>
                      </tr>

                      %if (V_EPCADR!= "")		
                          <tr><td class="dsphdr">Address</td>
                              <td class="dspalph">$(V_EPCADR)</td>
                          </tr>
                      %endif

                      %if (V_EPCAD2 != "")		
                          <tr><td class="dsphdr"></td>
                              <td class="dspalph">$(V_EPCAD2)</td>
                          </tr>
                      %endif

                      %if (V_EPCPHN != "")		
                          @EditPhoneNumber(V_EPCPHN)
                          <tr><td class="dsphdr">Phone Number</td>
                              <td class="dspnmbr">$(V_EPCPHN)</td>
                          </tr>
                      %endif
                  %endif
 	   		
                  %if (V_EPC2NM != "")		
                      <tr><td class="dsphdr">Emergency Contact Two</td>
                          <td class="dspalph">$(V_EPC2NM)</td>
                      </tr>

                      %if (V_EPC2A1 != "")		
                          <tr><td class="dsphdr">Address</td>
                              <td class="dspalph">$(V_EPC2A1)</td>
                          </tr>
                      %endif

                      %if (V_EPC2A2 != "")		
                          <tr><td class="dsphdr"></td>
                              <td class="dspalph">$(V_EPC2A2)</td>
                          </tr>
                      %endif

                      %if (V_EPC2PH != "")		
                          @EditPhoneNumber(V_EPC2PH)
                          <tr><td class="dsphdr">Phone Number</td>
                              <td class="dspnmbr">$(V_EPC2PH)</td>
                          </tr>
                      %endif
                  %endif
              %endif

              %if (V_EPPHYS != "")		
                  <tr><td class="dsphdr">Physician Name</td>
                      <td class="dspalph">$(V_EPPHYS)</td>
                  </tr>
                  @EditPhoneNumber(V_EPPPHN)
	   	   <tr><td class="dsphdr">Physician Phone Number</td>
                      <td class="dspnmbr">$(V_EPPPHN)</td>
                  </tr>
              %endif

              %if (V_EPBLOD != "")		
                  <tr><td class="dsphdr">Blood Type</td>
                      <td class="dspalph">$(V_EPBLOD)</td>
                  </tr>
              %endif

              %if (V_EPLBD != "0")		
                  @Format_Date(V_EPLBD, "H", F_EPLBD)
                  <tr><td class="dsphdr">Last Blood Donation</td>
                      <td class="dspdate">$(F_EPLBD)</td>
                  </tr>
              %endif
      %}
      </table>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (sec_05 == "N")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)progOptSecError.d2w/DISPLAY$(genericVarBase)&amp;page_title=@dtw_rurlescseq(page_title)">
  %else
      @Set_SQL(stmtSQL)
  %endif
%}