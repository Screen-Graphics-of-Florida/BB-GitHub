%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"

%Define {	
  page_title              = "Property Type Inquiry"
  d2wName                 = "FAPropertyInquiry.d2w"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
%}
	
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onLoad="window.focus()" onBlur="window.close()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      @dtw_assign(uv_PropertyTypeName, "PTTYPE")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "SELECT * ", stmtSQL)
                      @dtw_concat(fileSQL, " FAPROP ", fileSQL)
                      @dtw_concat(selectSQL, " PTTYPE='$(propertyType)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      @Display_Inquiry(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) Display_Inquiry (IN CHAR(64) profileHandle,
                                       CHAR(2)   dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(displayCloseIcon, "Y")
      %INCLUDE "PageTitle.icl"

      $(inquiryhrTagAttr)

      <table $(contentTable)>
          %ROW{
              <tr><td class="dsphdr">Property Type</td>
                  <td class="dspalph">$(V_PTTYPE)</td></tr>

              <tr><td class="dsphdr">Property Description</td>
                  <td class="dspalph">$(V_PTDESC)</td></tr>

              <tr><td class="dsphdr">G/L Asset Account</td>
                  @Format_Acct("$(V_PTAAAC)", "$(V_PTAASU)", "Y", F_AcctSub)
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>	

              <tr><td class="dsphdr">G/L Accumulated Depreciation Account</td>
                  @Format_Acct("$(V_PTADAC)", "$(V_PTADSU)", "Y", F_AcctSub)
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>	

              <tr><td class="dsphdr">G/L Depreciation Expense Account</td>
                  @Format_Acct("$(V_PTDEAC)", "$(V_PTDESU)", "Y", F_AcctSub)
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>	

              <tr><td class="dsphdr">G/L Gain/Loss Account</td>
                  @Format_Acct("$(V_PTGLAC)", "$(V_PTGLSU)", "Y", F_AcctSub)
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>	

              <tr><td class="dsphdr">G/L Cash Or AR Account</td>
                  @Format_Acct("$(V_PTCAAC)", "$(V_PTCASU)", "Y", F_AcctSub)
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>	

              <tr><td class="dsphdr">G/L Transfers Balancing Account</td>
                  @Format_Acct("$(V_PTTRAC)", "$(V_PTTRSU)", "Y", F_AcctSub)
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>	
          %}
      </table>
      $(inquiryhrTagAttr)
      %INCLUDE "CloseWindow.icl"
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}