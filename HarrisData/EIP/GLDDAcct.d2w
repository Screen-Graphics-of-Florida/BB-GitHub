%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "WildCardAcct.icl"

%Define {
  page_title              = "Drill Down Accounts"
  d2wName                 = "GLDDAcct.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;ddReport=@dtw_rurlescseq(ddReport)&amp;ddCompany=@dtw_rurlescseq(ddCompany)&amp;ddFacility=@dtw_rurlescseq(ddFacility)&amp;downloadProfileHandle=@dtw_rurlescseq(downloadProfileHandle)&amp;ddRow=@dtw_rurlescseq(ddRow)&amp;ddAccount=@dtw_rurlescseq(ddAccount)&amp;ddSubAccount=@dtw_rurlescseq(ddSubAccount)&amp;accountNumber=@dtw_rurlescseq(accountNumber)&amp;subAccount=@dtw_rurlescseq(subAccount)&amp;coNumber=@dtw_rurlescseq(coNumber)&amp;facNumber=@dtw_rurlescseq(facNumber)&amp;columnNumber=@dtw_rurlescseq(columnNumber)&amp;ddYear=@dtw_rurlescseq(ddYear)&amp;ddQtr=@dtw_rurlescseq(ddQtr)&amp;ddPer=@dtw_rurlescseq(ddPer)&amp;ddAmount=@dtw_rurlescseq(ddAmount)&amp;fieldSize=@dtw_rurlescseq(fieldSize)&amp;decimalSize=@dtw_rurlescseq(decimalSize)&amp;rowDescr=@dtw_rurlescseq(rowDescr)&amp;openBalFlag=@dtw_rurlescseq(openBalFlag)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  hdsUserName             = ""
  heading1                = ""
  heading2                = ""
  heading3                = ""
  headingPeriod           = ""
  amtHeading              = ""
  fieldSize               = ""
  decimalSize             = ""
  editCode                = ""
  columnValue             = ""
  uv_Sql                  = ""
  PrimaryOrderBy          = "DRXHND,DRGRSN,DRRCO,DRRFAC,DRGRR#,"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"

  @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
  @dtw_assign(SAVE_MAX_ROWS, RPT_MAX_ROWS)
  @dtw_assign(START_ROW_NUM, "1")
  @dtw_assign(RPT_MAX_ROWS, "9999")
  %INCLUDE "stmtSQLClear.icl"
  @dtw_assign(appendUserView, "N")
  @dtw_assign(appendWildCard, "N")
  @dtw_concat(stmtSQL, "SELECT * ", stmtSQL)
  @dtw_concat(fileSQL, " GLDDHD ", fileSQL)
  @dtw_concat(selectSQL, " DHGRSN='$(ddReport)' ", selectSQL)
  @dtw_concat(selectSQL, " and DHCO=$(ddCompany) and DHFAC=$(ddFacility) ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " order by DHGRSN  ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  %INCLUDE "stmtSQLTotalRows.icl"
  @RptHdg_Query(profileHandle, dataBaseID, stmtSQL)
  @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
  @dtw_assign(RPT_MAX_ROWS, SAVE_MAX_ROWS)

  @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
  @dtw_assign(SAVE_MAX_ROWS, RPT_MAX_ROWS)
  @dtw_assign(START_ROW_NUM, "1")
  @dtw_assign(RPT_MAX_ROWS, "9999")
  %INCLUDE "stmtSQLClear.icl"
  @dtw_assign(appendUserView, "N")
  @dtw_assign(appendWildCard, "N")
  @dtw_concat(stmtSQL, "SELECT * ", stmtSQL)
  @dtw_concat(fileSQL, " GLDWCL ", fileSQL)
  @dtw_concat(selectSQL, " DCXHND='$(downloadProfileHandle)' and DCGRSN='$(ddReport)' and DCGRC#=$(columnNumber) and DCYEAR='$(ddYear)'", selectSQL)
  @dtw_concat(selectSQL, " and DCQTR=$(ddQtr) and DCPERN=$(ddPer)", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " order by DCGRC#  ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  %INCLUDE "stmtSQLTotalRows.icl"
  @ColHdg_Query(profileHandle, dataBaseID, stmtSQL)
  @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
  @dtw_assign(RPT_MAX_ROWS, SAVE_MAX_ROWS)

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <link rel=stylesheet type="text/css" href="$(homeURL)$(homePath)$(GLDDStyleSheet)">
          <script TYPE="text/javascript">
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (%if (accountNumber == "0")
                          editNum(document.Search.srchAcct, 4, 0) &&
                          editNum(document.Search.srchSub, 4, 0) &&
                      %endif
                      editNum(document.Search.srchCo, 2, 0) &&
                      editNum(document.Search.srchFac, 4, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      @dtw_assign(uv_CompanyName, "DRCO")
                      @dtw_assign(uv_FacilityName, "DRFAC")
                      @dtw_assign(uv_AccountName, "DRACCT")
                      @dtw_assign(uv_SubaccountName, "DRSUB")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_assign(appendUserView, "")
                      @dtw_assign(appendWildCard, "")
                      @dtw_concat(stmtSQL, "SELECT DRXHND,DRGRSN,DRRCO,DRRFAC,DRGRR#, ", stmtSQL)
                      @dtw_concat(stmtSQL, " DRCO,DRFAC,DRACCT,DRSUB,DRAMT,DRFPER,DRTPER,DRGRFT,DRNMBR, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(CFCFNM,' ') as CFCFNM, coalesce(CFCFNMU,' ') as CFCFNMU,", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(CHCHDS,' ') as CHCHDS, coalesce(CHCHDSU,' ') as CHCHDSU ", stmtSQL)
                      @dtw_concat(fileSQL, " GLDWRW ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDCFAC b on DRCO=CFCO# and DRFAC=CFFAC# ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDCHRT c on DRACCT=CHACCT and DRSUB=CHSUB ", fileSQL)
                      @dtw_concat(selectSQL, " DRXHND='$(downloadProfileHandle)' and DRGRSN='$(ddReport)' ", selectSQL)
                      @dtw_concat(selectSQL, " and DRRCO=$(ddCompany) and DRRFAC=$(ddFacility) ", selectSQL)
                      @dtw_concat(selectSQL, " and DRGRR#=$(ddRow) and DRMACC=$(ddAccount) and DRMSUB=$(ddSubAccount) ", selectSQL)
                      %if (accountNumber != "0")
                          @dtw_concat(selectSQL, " and DRACCT=$(accountNumber) and DRSUB=$(subAccount) ", selectSQL)
                      %else
                          @dtw_concat(selectSQL, " and DRACCT>0 ", selectSQL)
                      %endif
                      %if (coNumber != "0")
                          @dtw_concat(selectSQL, " and DRCO=$(coNumber) and DRFAC=$(facNumber) ", selectSQL)
                      %else
                          @dtw_concat(selectSQL, " and DRCO>0 ", selectSQL)
                      %endif
                      @dtw_concat(selectSQL, " and DRGRC#=$(columnNumber) and DRYEAR='$(ddYear)'", selectSQL)
                      @dtw_concat(selectSQL, " and DRQTR=$(ddQtr) and DRPERN=$(ddPer) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) List_Query (IN  CHAR(64) profileHandle,
                                   CHAR(2)   dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("DRXHND='$(downloadProfileHandle)' and DRGRSN='$(ddReport)' and DRGRC#=$(columnNumber) and DRYEAR='$(ddYear)' and DRQTR=$(ddQtr) and DRPERN=$(ddPer)", "GLDWRW", "Max(DRGRFT)", V_DRGRFT)
      %if (sql_Record_Count != "1" || openBalFlag=="Y" || V_DRGRFT !="B")
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if (ddReport!="")
                              <a href="$(homeURL)$(cGIPath)GLDDReport.d2w/REPORT$(genericVarBase)$(glDDVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))" title="Return To Drill Down Report">$(portalHome)</a>
                          %endif
                          <a href="$(homeURL)$(cGIPath)$(d2wName)/ENTRY$(d2wVarBase)&amp;formatToPrint=Y" target=_blank>$(formatPrintDesc)</a>
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
              <tr><td><h2>$(hdsUserName)</h2></td></tr>
              %if (V_DHGRH1 != "")
                  <tr><td><h2>$(heading1)</h2></td></tr>
              %endif
              %if (V_DHGRH2 != "")
                  <tr><td><h2>$(heading2)</h2></td></tr>
              %endif
              %if (V_DHGRH3 != "")
                  <tr><td><h2>$(heading3)</h2></td></tr>
              %endif
              <tr><td><h2>$(headingPeriod)</h2></td></tr>

              <tr><td><h2>
                  $(rowDescr)
                  %if (accountNumber != "0")
                      @Format_Acct("$(accountNumber)", "$(subAccount)", "", F_AcctSub)
                      $(F_AcctSub)
                  %endif

                  @Format_Nbr($(ddAmount), F_ddAmount, decimalSize, $(editCode), "Y", "", "")
                  &nbsp; - &nbsp; $(F_ddAmount)
              </h2></td></tr>

              %if (uv_Sql != "")
                  <tr><td><h3> You may not be authorized to view some accounts </h3></td></tr>
              %endif
          </table>

          $(inquiryhrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST name="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr"> Co</th>
                          <th class="colhdr"> Fac</th>
                          %if (accountNumber == "0")
                              <th class="colhdr">Account</th>
                          %endif
                      </tr>
                      <tr><td><input type="text" class="inputnmbr"  name="srchCo" size="2" maxlength="2">
                              <input type="hidden" name="operCo" value="=">
                          </td>
                          <td><input type="text" class="inputnmbr"  name="srchFac" size="4" maxlength="4">
                              <input type="hidden" name="operFac" value="=">
                          </td>
                          %if (accountNumber == "0")
                              <td><input type="text" class="inputnmbr"  name="srchAcct" size="4" maxlength="4">
                                  <input type="text" class="inputnmbr"  name="srchSub" size="4" maxlength="4">
                                  <input type="hidden" name="operAcct" value="=">
                              </td>
                          %endif
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchCo.focus();
                  </script>
              </form>

              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("$(PrimaryOrderBy)DRCO", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CoFac" title="Sequence By Company/Facility, Account">Co/Fac</a></th>
                  @OrderBy_Sort("$(PrimaryOrderBy)CFCFNMU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CoFacName" title="Sequence By Name, Company/Facility, Account">  Name</a></th>
                  %if (accountNumber == "0")
                      @OrderBy_Sort("$(PrimaryOrderBy)DRACCT", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Account" title="Sequence By Account, Company/Facility">Account</a></th>
                      @OrderBy_Sort("$(PrimaryOrderBy)CHCHDSU", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=AccountDesc" title="Sequence By Description, Account, Company/Facility">Description</a></th>
                  %endif
                  @OrderBy_Sort("$(PrimaryOrderBy)DRAMT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Amount" title="Sequence By Amount, Company/Facility, Account">$(amtHeading)</a></th>
                  <th class="colhdr">% of Total</th>
              </tr>

              %INCLUDE "NoRecordsFound.icl"
      %endif

              %ROW{
                  @RtvFldDesc("OBCO=$(V_DRCO) and OBFAC=$(V_DRFAC) and OBACCT=$(V_DRACCT) and OBSUB=$(V_DRSUB) ", "GLTROB", "CHAR(COUNT(OBCO))", AccountSetUp)
                  @Format_Nbr($(V_DRAMT), F_DRAMT, decimalSize, $(editCode), "Y", "", "")
                  %if (sql_Record_Count == "1" && openBalFlag =="" && V_DRGRFT=="B")
                      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)GLDDBudget.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;accountNumber=@dtw_rurlescseq(V_DRACCT)&amp;subAccount=@dtw_rurlescseq(V_DRSUB)&amp;coNumber=@dtw_rurlescseq(V_DRCO)&amp;facNumber=@dtw_rurlescseq(V_DRFAC)&amp;accountAmount=@dtw_rurlescseq(F_DRAMT)&amp;fromPer=@dtw_rurlescseq(V_DRFPER)&amp;toPer=@dtw_rurlescseq(V_DRTPER)&amp;planNumber=@dtw_rurlescseq(V_DRNMBR)">
                      @dtw_exit()
                  %else

                      %INCLUDE "SetRowClass.icl"
                      @Format_Acct("$(V_DRACCT)", "$(V_DRSUB)", "", F_AcctSub)
                      @Format_CoFac("$(V_DRCO)", "$(V_DRFAC)", "", F_CoFac)
                      <tr class="$(rowClass)">
                          %if (openBalFlag=="Y" || V_DRGRFT=="B" || accountNumber == "0" || AccountSetUp=="0")
                              <td class="colnmbr">$(F_CoFac)</td>
                          %else
                              <td class="colnmbr"><a href="$(homeURL)$(cGIPath)GLDDAcctJrnl.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;accountNumber=@dtw_rurlescseq(V_DRACCT)&amp;subAccount=@dtw_rurlescseq(V_DRSUB)&amp;coNumber=@dtw_rurlescseq(V_DRCO)&amp;facNumber=@dtw_rurlescseq(V_DRFAC)&amp;accountAmount=@dtw_rurlescseq(F_DRAMT)&amp;fromPer=@dtw_rurlescseq(V_DRFPER)&amp;toPer=@dtw_rurlescseq(V_DRTPER)&amp;columnValue=@dtw_rurlescseq(columnValue)" title="View Account Journals">$(F_CoFac)</a></td>
                          %endif

                          <td class="colalph">$(V_CFCFNM)</td>

                          %if (accountNumber == "0")
                              %if (openBalFlag=="Y" || V_DRGRFT=="B" || AccountSetUp=="0")
                                  <td class="colalph">$(F_AcctSub)</td>
                              %else
                                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)GLDDAcctJrnl.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;accountNumber=@dtw_rurlescseq(V_DRACCT)&amp;subAccount=@dtw_rurlescseq(V_DRSUB)&amp;coNumber=@dtw_rurlescseq(V_DRCO)&amp;facNumber=@dtw_rurlescseq(V_DRFAC)&amp;accountAmount=@dtw_rurlescseq(F_DRAMT)&amp;fromPer=@dtw_rurlescseq(V_DRFPER)&amp;toPer=@dtw_rurlescseq(V_DRTPER)&amp;columnValue=@dtw_rurlescseq(columnValue)" title="View Account Journals">$(F_AcctSub)</a></td>
                              %endif
                              <td class="colalph">$(V_CHCHDS)</td>
                          %endif

                          %if (openBalFlag=="Y" || AccountSetUp=="0")
                              <td class="colnmbr">$(F_DRAMT)</td>
                          %elif (V_DRGRFT=="B")
                              <td class="colnmbr"><a href="$(homeURL)$(cGIPath)GLDDBudget.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;accountNumber=@dtw_rurlescseq(V_DRACCT)&amp;subAccount=@dtw_rurlescseq(V_DRSUB)&amp;coNumber=@dtw_rurlescseq(V_DRCO)&amp;facNumber=@dtw_rurlescseq(V_DRFAC)&amp;accountAmount=@dtw_rurlescseq(F_DRAMT)&amp;fromPer=@dtw_rurlescseq(V_DRFPER)&amp;toPer=@dtw_rurlescseq(V_DRTPER)&amp;planNumber=@dtw_rurlescseq(V_DRNMBR)" title="View Budget Detail">$(F_DRAMT)</a></td>
                          %else
                              <td class="colnmbr"><a href="$(homeURL)$(phpPath)GLDDSubsystem.php$(altVarBase)$(glDDVarBase)&amp;tag=REPORT&amp;accountNumber=@dtw_rurlescseq(V_DRACCT)&amp;subAccount=@dtw_rurlescseq(V_DRSUB)&amp;coNumber=@dtw_rurlescseq(V_DRCO)&amp;facNumber=@dtw_rurlescseq(V_DRFAC)&amp;accountAmount=@dtw_rurlescseq(F_DRAMT)&amp;fromPer=@dtw_rurlescseq(V_DRFPER)&amp;toPer=@dtw_rurlescseq(V_DRTPER)&amp;columnValue=@dtw_rurlescseq(columnValue)" title="View Drill Down Subsystem Entries">$(F_DRAMT)</a></td>
                          %endif
                          @Format_Nbr("@dtw_rMultiply(@dtw_rDivide(V_DRAMT, ddAmount), "100")", Percent, "3", $(editCode), "Y", "", "")
                          <td class="colnmbr">$(Percent)</td>
                      </tr>
                  %endif
              %}
          </table>
          %if (sql_Record_Count != "1" || openBalFlag=="Y" || V_DRGRFT!="B")
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(inquiryhrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
  %}
%}
%FUNCTION(dtw_sql) RptHdg_Query (IN  CHAR(64) profileHandle,
                                     CHAR(2)   dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %ROW{
          @DTW_ASSIGN(hdsUserName, V_DHUSRN)
          @DTW_ASSIGN(heading1, V_DHGRH1)
          @DTW_ASSIGN(heading2, V_DHGRH2)
          @DTW_ASSIGN(heading3, V_DHGRH3)
          @DTW_ASSIGN(headingPeriod, V_DHGRHP)
      %}
  %}
%}

%FUNCTION(dtw_sql) ColHdg_Query (IN  CHAR(64) profileHandle,
                                     CHAR(2)   dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count == "0")
          @DTW_EXIT()
      %endif

      %ROW{
          @dtw_assign(amtHeading, V_DCHDG)
          @dtw_assign(fieldSize, "$(V_DCFLDS)")
          @dtw_assign(decimalSize, "$(V_DCFLDD)")
          @dtw_assign(editCode, "$(V_DCEDCD)")
          @dtw_assign(columnValue, "$(V_DCBSVL)")
      %}
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %if (downloadProfileHandle == "")
      @dtw_assign(downloadProfileHandle, profileHandle)
  %else
      @dtw_assign(profileHandle, downloadProfileHandle)
  %endif

  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "DRXHND,DRGRSN,DRRCO,DRRFAC,DRGRR#,DRCO,DRFAC,DRACCT,DRSUB")
          @DTW_ASSIGN(orderByDisplay, "Company/Facility")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "CoFac")
      %if (orderBy == "DRXHND,DRGRSN,DRRCO,DRRFAC,DRGRR#,DRCO,DRFAC,DRACCT,DRSUB")
          @DTW_ASSIGN(orderBy, "DRXHND,DRGRSN,DRRCO,DRRFAC,DRGRR#,DRCO DESC,DRFAC DESC,DRACCT,DRSUB")
          @DTW_ASSIGN(orderByDisplay, "Company/Facility (descending), Account")
      %else
          @DTW_ASSIGN(orderBy, "DRXHND,DRGRSN,DRRCO,DRRFAC,DRGRR#,DRCO,DRFAC,DRACCT,DRSUB")
          @DTW_ASSIGN(orderByDisplay, "Company/Facility, Account")
      %endif
  %elif (sequence == "CoFacName")
      %if (orderBy == "DRXHND,DRGRSN,DRRCO,DRRFAC,DRGRR#,CFCFNMU,DRCO,DRFAC,DRACCT,DRSUB")
          @DTW_ASSIGN(orderBy, "DRXHND,DRGRSN,DRRCO,DRRFAC,DRGRR#,CFCFNMU DESC,DRCO,DRFAC,DRACCT,DRSUB")
          @DTW_ASSIGN(orderByDisplay, "Name (descending), Company/Facility, Account")
      %else
          @DTW_ASSIGN(orderBy, "DRXHND,DRGRSN,DRRCO,DRRFAC,DRGRR#,CFCFNMU,DRCO,DRFAC,DRACCT,DRSUB")
          @DTW_ASSIGN(orderByDisplay, "Name, Company/Facility, Account")
      %endif
  %elif (sequence == "Account")
      %if (orderBy == "DRXHND,DRGRSN,DRRCO,DRRFAC,DRGRR#,DRACCT,DRSUB,DRCO,DRFAC")
          @DTW_ASSIGN(orderBy, "DRXHND,DRGRSN,DRRCO,DRRFAC,DRGRR#,DRACCT DESC,DRSUB DESC,DRCO,DRFAC")
          @DTW_ASSIGN(orderByDisplay, "Account (descending), Company/Facility")
      %else
          @DTW_ASSIGN(orderBy, "DRXHND,DRGRSN,DRRCO,DRRFAC,DRGRR#,DRACCT,DRSUB,DRCO,DRFAC")
          @DTW_ASSIGN(orderByDisplay, "Account, Company/Facility")
      %endif
  %elif (sequence == "AccountDesc")
      %if (orderBy == "DRXHND,DRGRSN,DRRCO,DRRFAC,DRGRR#,CHCHDSU,DRACCT,DRSUB,DRCO,DRFAC")
          @DTW_ASSIGN(orderBy, "DRXHND,DRGRSN,DRRCO,DRRFAC,DRGRR#,CHCHDSU DESC,DRACCT,DRSUB,DRCO,DRFAC")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Account, Company/Facility")
      %else
          @DTW_ASSIGN(orderBy, "DRXHND,DRGRSN,DRRCO,DRRFAC,DRGRR#,CHCHDSU,DRACCT,DRSUB,DRCO,DRFAC")
          @DTW_ASSIGN(orderByDisplay, "Description, Account, Company/Facility")
      %endif
  %elif (sequence == "Amount")
      %if (orderBy == "DRXHND,DRGRSN,DRRCO,DRRFAC,DRGRR#,DRAMT,DRCO,DRFAC,DRACCT,DRSUB")
          @DTW_ASSIGN(orderBy, "DRXHND,DRGRSN,DRRCO,DRRFAC,DRGRR#,DRAMT DESC,DRCO,DRFAC,DRACCT,DRSUB")
          @DTW_ASSIGN(orderByDisplay, "Amount (descending), Company/Facility, Account")
      %else
          @DTW_ASSIGN(orderBy, "DRXHND,DRGRSN,DRRCO,DRRFAC,DRGRR#,DRAMT,DRCO,DRFAC,DRACCT,DRSUB")
          @DTW_ASSIGN(orderByDisplay, "Amount, Company/Facility, Account")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <link rel=stylesheet type="text/css" href="$(homeURL)$(homePath)$(GLDDStyleSheet)">
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchCo, 2, 0) &&
                      editNum(document.Search.srchFac, 4, 0) &&
                      %if (accountNumber == "0")
                          editNum(document.Search.srchAcct, 4, 0) &&
                          editNum(document.Search.srchSub, 4, 0) &&
                      %endif
                      editNum(document.Search.srchAmt, 13, 2))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      %INCLUDE "SearchPageTitle.icl"
                      $(inquiryhrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                              <tr><td class="dsphdr">Company</td>
                                  @dtw_assign(operNbr, "operCo")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"> <input type="text" name="srchCo" size="2" maxlength="2"></td>
                              </tr>

                              <tr><td class="dsphdr">Facility</td>
                                  @dtw_assign(operNbr, "operFac")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"> <input type="text" name="srchFac" size="4" maxlength="4"></td>
                              </tr>

                              <tr><td class="dsphdr">Name</td>
                                  @dtw_assign(operNbr, "operCoFacName")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchCoFacName" size="30" maxlength="30"></td>
                              </tr>

                              %if (accountNumber == "0")
                                  <tr><td class="dsphdr">Account</td>
                                      @dtw_assign(operNbr, "operAcct")
                                      <td>%INCLUDE "opersel_num_short.icl"</td>
                                      <td class="inputnmbr"><input type="text" name="srchAcct" size="4" maxlength="4"><input type="text" name="srchSub" size="4" maxlength="4"></td>
                                  </tr>

                                  <tr><td class="dsphdr">Description</td>
                                      @dtw_assign(operNbr, "operAcctDesc")
                                      <td>%INCLUDE "opersel_alph_short.icl"</td>
                                      <td class="inputalph"><input type="text" name="srchAcctDesc" size="30" maxlength="30"></td>
                                  </tr>
                              %endif

                              <tr><td class="dsphdr">Amount</td>
                                  @dtw_assign(operNbr, "operAmt")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchAmt" size="17" maxlength="17"></td>
                              </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchCo.focus();
                          </script>
                      </form>
                      $(inquiryhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("DRCO", "Company", $(srchCo), "", $(operCo), "N")
  @Build_WildCard ("DRFAC", "Facility", $(srchFac), "", $(operFac), "N")
  @Build_WildCard ("CFCFNMU", "Name", $(srchCoFacName), "U", $(operCoFacName), "A")
  @Build_WildCard ("DRAMT", "Amount", $(srchAmt), "", $(operAmt), "N")
  @Build_WildCard ("CHCHDSU", "Description", $(srchAcctDesc), "U", $(operAcctDesc), "A")
  @Build_WildCard_Acct ("DRACCT", "DRSUB", "Account", $(srchAcct), $(srchSub), $(operAcct))

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
