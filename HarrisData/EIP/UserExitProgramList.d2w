%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "User Exit Program"
  d2wName                 = "UserExitProgramList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "2"
  helpExt                 = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (editFromToAll(document.Chg.frmExitPoint, document.Chg.toExitPoint, document.Chg.allExitPoint, "A") &&
                      editFromToAll(document.Chg.frmExitProgram, document.Chg.toExitProgram, document.Chg.allExitProgram, "A"))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "USEREXITPGMLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          @dtw_assign(focusField, "frmExitPoint")
                          %if (errFound != "" || scheduleJobSwitch == "Y")
                              @dtw_assign(scheduleJobSwitch, "")
                              @EdtVarErr(profileHandle, typeValue, edtVar)
                              @dtw_assign(focusField, "")
                              @ErrVarErr(profileHandle, typeError, errVar)
                              @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                              @DecatErr_Field("@@sel@", "printComment")     @dtw_assign(Err_N0SEL,  fieldValue)
                              @DecatErr_Field("@@fexp", "frmExitPoint")     @dtw_assign(Err_N1FEXP,  fieldValue)
                              @DecatErr_Field("@@texp", "toExitPoint")      @dtw_assign(Err_N1TEXP,  fieldValue)
                              @DecatErr_Field("@@aexp", "allExitPoint")     @dtw_assign(Err_N1AEXP,  fieldValue)
                              @DecatErr_Field("@@sexp", "srtExitPoint")     @dtw_assign(Err_N1SEXP,  fieldValue)
                              @DecatErr_Field("@@fuxp", "frmExitProgram")   @dtw_assign(Err_N1FUXP,  fieldValue)
                              @DecatErr_Field("@@tuxp", "toExitProgram")    @dtw_assign(Err_N1TUXP,  fieldValue)
                              @DecatErr_Field("@@auxp", "allExitProgram")   @dtw_assign(Err_N1AUXP,  fieldValue)
                              @DecatErr_Field("@@suxp", "srtExitProgram")   @dtw_assign(Err_N1SUXP,  fieldValue)
                              %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                              @Decat_Field("@@sel@")  @dtw_assign(V_N0SEL ,  fieldValue)
                              @Decat_Field("@@fexp")  @dtw_assign(V_N1FEXP,  fieldValue)
                              @Decat_Field("@@texp")  @dtw_assign(V_N1TEXP,  fieldValue)
                              @Decat_Field("@@aexp")  @dtw_assign(V_N1AEXP,  fieldValue)
                              @Decat_Field("@@sexp")  @dtw_assign(V_N1SEXP,  fieldValue)
                              @Decat_Field("@@fuxp")  @dtw_assign(V_N1FUXP,  fieldValue)
                              @Decat_Field("@@tuxp")  @dtw_assign(V_N1TUXP,  fieldValue)
                              @Decat_Field("@@auxp")  @dtw_assign(V_N1AUXP,  fieldValue)
                              @Decat_Field("@@suxp")  @dtw_assign(V_N1SUXP,  fieldValue)
                              %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                          %else
                              @dtw_assign(V_N0SEL , "01")
                              @dtw_assign(V_N1AEXP, "ALL")
                              @dtw_assign(V_N1AUXP, "ALL")
                          %endif

                          <table $(contentTable)>
                              %if (V_N0SEL == "02")
                                  @dtw_assign(printNo, "")
                                  @dtw_assign(printYes, "CHECKED")
                              %else
                                  @dtw_assign(printNo, "CHECKED")
                                  @dtw_assign(printYes, "")
                              %endif
                              @SetTextOvr(Err_N0SEL)
                              <tr><td class="dsphdr"><span $(textOvr)>Print Comments</span></td>
                                  <td class="inputnmbr"><input name="printComment" type="radio" VALUE='01' $(printNo)>No</td>
                              </tr>
                              @DspErrMsg(Err_N0SEL)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="printComment" type="radio" VALUE='02' $(printYes)>Yes</td>
                              </tr>
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                              </tr>

                              @Field_Checked(V_N1AEXP, "ALL", allChecked)
                              @SetTextOvr(Err_N1FEXP)
                              %if (textOvr == "") @SetTextOvr(Err_N1TEXP) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AEXP) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SEXP) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Exit Point</span></td>
                                  <td class="inputalph"><input type="text" name="frmExitPoint" value="$(V_N1FEXP)" size="15" maxlength="15"></td>
                                  <td class="inputalph"><input type="text" name="toExitPoint" value="$(V_N1TEXP)" size="15" maxlength="15"></td>
                                  <td class="inputalph"><input type="checkbox" name="allExitPoint" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmExitPoint.value='', this.form.toExitPoint.value='';"></td>
                                  @Build_Sort_Select("srtExitPoint", "$(V_N1SEXP)")
                              </tr>
                              @DspErrMsg(Err_N1FEXP)
                              @DspErrMsg(Err_N1TEXP)
                              @DspErrMsg(Err_N1AEXP)
                              @DspErrMsg(Err_N1SEXP)

                              @Field_Checked(V_N1AUXP, "ALL", allChecked)
                              @SetTextOvr(Err_N1FUXP)
                              %if (textOvr == "") @SetTextOvr(Err_N1TUXP) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AUXP) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SUXP) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Exit Program</span></td>
                                  <td class="inputalph"><input type="text" name="frmExitProgram" value="$(V_N1FUXP)" size="15" maxlength="10"></td>
                                  <td class="inputalph"><input type="text" name="toExitProgram" value="$(V_N1TUXP)" size="15" maxlength="10"></td>
                                  <td class="inputalph"><input type="checkbox" name="allExitProgram" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmExitProgram.value='', this.form.toExitProgram.value='';"></td>
                                  @Build_Sort_Select("srtExitProgram", "$(V_N1SUXP)")
                              </tr>
                              @DspErrMsg(Err_N1FUXP)
                              @DspErrMsg(Err_N1TUXP)
                              @DspErrMsg(Err_N1AUXP)
                              @DspErrMsg(Err_N1SUXP)
                          </table>

                          @dtw_assign(envProgram, "HSYUXL")
                          @dtw_assign(envPrinter, "HSYUXLPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSYUXS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"

  @dtw_assign(edtVar, "")
  @Concat_Field("@@sel@", printComment)

                                                                                                  @Concat_Field("@@fexp", frmExitPoint)
                                                                                                  @Concat_Field("@@texp", toExitPoint)
  @dtw_mUPPERCASE(allExitPoint) %if (allExitPoint != "ALL") @dtw_assign(allExitPoint, "") %endif  @Concat_Field("@@aexp", allExitPoint)
                                                                                                  @Concat_Field("@@sexp", @dtw_rstrip(srtExitPoint))

  @dtw_mUPPERCASE(frmExitProgram)                                                                       @Concat_Field("@@fuxp", frmExitProgram)
  @dtw_mUPPERCASE(toExitProgram)                                                                        @Concat_Field("@@tuxp", toExitProgram)
  @dtw_mUPPERCASE(allExitProgram) %if (allExitProgram != "ALL") @dtw_assign(allExitProgram, "") %endif  @Concat_Field("@@auxp", allExitProgram)
                                                                                                        @Concat_Field("@@suxp", @dtw_rstrip(srtExitProgram))

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}