%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Process Search"
  d2wName                 = "WFProcessSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectProcess(wfProcess, wfProcessDescription){
                  window.opener.document.$(docName).$(fldName).value = wfProcess;
                  window.opener.document.$(docName).$(fldDesc).value = wfProcessDescription;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select WFPRHD.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(USDESC,' ') as USDESC, coalesce(USDESCU,' ') as USDESCU  ", stmtSQL)
                      @dtw_concat(fileSQL, " WFPRHD ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYUSER on USUSER=PRPART ", fileSQL)
                      %if (moreInfo == "Y")
                          @dtw_assign(START_ROW_NUM, "1")
                          @dtw_assign(RPT_MAX_ROWS, "9999")
                          @dtw_concat(selectSQL, " PRPROC='$(wfProcess)'", selectSQL)
                      %elif (wildCardSearch!="")
                          @dtw_concat(selectSQL, " PRPROC>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"

      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Description</th>
                      <th class="colhdr">Process</th>
                  </tr>
                  <tr><td class="inputalph">
                          <input type="text" name="srchDesc" size="15" maxlength="50">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td class="inputalph">
                          <input type="text" name="srchProcess" size="15" maxlength="30">
                          <input type="hidden" name="operProcess" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("PRDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description"    title="Sequence By Description, Process">Description</a></th>
                  @OrderBy_Sort("PRPROC", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Process"  title="Sequence By Process">Process</a></th>
                  @OrderBy_Sort("USDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Participant" title="Sequence By Participant In Charge, Process">Participant In Charge</a></th>
              </tr>

              %INCLUDE "NoRecordsFound.icl"
      %endif		

              %ROW{
                  @Format_Quote(V_PRPROC, F_PRPROC)
                  @Format_Quote(V_PRDESC, F_PRDESC)

                  %if (moreInfo != "Y")	
                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          <td class="colalph"><a href="javascript:selectProcess('$(F_PRPROC)','$(F_PRDESC)')" title="Select Process">$(V_PRDESC)</a></td>
                          <td class="colalph">$(V_PRPROC)</td>
                          <td class="colalph" $(helpCursor)><span title="$(V_PRPART)">$(V_USDESC)</span></td>
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;wfProcess=@dtw_rurlescseq(V_PRPROC)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                      </tr>

                  %else
                      <table $(contentTable)>
                          <tr><td><a href="javascript:selectProcess('$(F_PRPROC)','$(F_PRDESC)')" title="Select Process">$(selectImageLrg)</a>
                              </td>
                          </tr>

                          <tr><td class="dsphdr">Process</td>
                              <td class="dspalph">$(V_PRPROC)</td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              <td class="dspalph">$(V_PRDESC)</td></tr>

                          @RtvFldDesc("USUSER='$(V_PRPART)' ", "SYUSER", "USDESC", fieldDesc)
                          <tr><td class="dsphdr">Participant In Charge</td>
                              @Format_Code(V_PRPART, F_PRPART)
                              <td class="dspalph">$(fieldDesc) $(F_PRPART)</td>
                          </tr>

                          @RtvFldDesc("PDPROC='$(V_PRPROC)' and PDPONT=$(V_PRPSPT) and PDSEQ=$(V_PRPSSQ)", "WFPRDT", "PDDESC", fieldDesc)
                          <tr><td class="dsphdr">Completion Detail Point</td>
                              @Format_Code("$(V_PRPSPT)-$(V_PRPSSQ)", F_PRPSPT)
                              <td class="dspnmbr">$(fieldDesc) $(F_PRPSPT)</td>
                          </tr>
                      </table>

                      <fieldset class="legendBody">
                          <legend class="legendTitle">Maximum Work Item</legend>
                          <table $(contentTable)>
                              @RtvFldDesc("VIVPGM='$(V_PRMXVP)' and VIVLID=$(V_PRMXVL) ", "WFVLID", "VIDESC", fieldDesc)
                              <tr><td class="dsphdr">Validation Program/ID</td>
                                  @Format_Code("$(V_PRMXVP)-$(V_PRMXVL)", F_PRMXVL)
                                  <td class="dspalph">$(fieldDesc) $(F_PRMXVL)</td>
                              </tr>

                              @RtvFldDesc("PDPROC='$(V_PRPROC)' and PDPONT=$(V_PRMXPT) and PDSEQ=$(V_PRMXSQ)", "WFPRDT", "PDDESC", fieldDesc)
                              <tr><td class="dsphdr">Detail Point</td>
                                  @Format_Code("$(V_PRMXPT)-$(V_PRMXSQ)", F_PRMXPT)
                                  <td class="dspalph">$(fieldDesc) $(F_PRMXPT)</td>
                              </tr>
                          </table>
                      </fieldset>
                  %endif
              %}

      %if (moreInfo != "Y")	
          </table>
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
      %endif	   	
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "PRDESCU,PRPROC")
      @DTW_ASSIGN(orderByDisplay, "Description, Process")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Description")
      %if (orderBy == "PRDESCU,PRPROC")
          @DTW_ASSIGN(orderBy, "PRDESCU DESC,PRPROC")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Process")
      %else
          @DTW_ASSIGN(orderBy, "PRDESCU,PRPROC")
          @DTW_ASSIGN(orderByDisplay, "Description, Process")
      %endif
  %elif (sequence == "Process")
      %if (orderBy == "PRPROC")
          @DTW_ASSIGN(orderBy, "PRPROC DESC")
          @DTW_ASSIGN(orderByDisplay, "Process (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PRPROC")
          @DTW_ASSIGN(orderByDisplay, "Process")
      %endif
  %elif (sequence == "Participant")
      %if (orderBy == "USDESCU,PRPROC")
          @DTW_ASSIGN(orderBy, "USDESCU DESC,PRPROC")
          @DTW_ASSIGN(orderByDisplay, "Participant In Charge (descending), Process")
      %else
          @DTW_ASSIGN(orderBy, "USDESCU,PRPROC")
          @DTW_ASSIGN(orderByDisplay, "Participant In Charge, Process")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "processSearch")
                  <td>
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Process</td>
                              @dtw_assign(operNbr, "operProcess")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchProcess" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Participant In Charge</td>
                              @dtw_assign(operNbr, "operParticipant")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchParticipant" size="15" maxlength="30"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDesc.focus();
                          </script>
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("PRDESCU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("PRPROC", "Process", $(srchProcess), "U", operProcess, "A")
  @Build_WildCard ("coalesce(USDESCU,' ')", "Participant In Charge", $(srchParticipant), "U", operParticipant, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
