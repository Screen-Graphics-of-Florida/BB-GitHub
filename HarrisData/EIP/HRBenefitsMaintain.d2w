                  </tr>
                  @DspErrMsg(Err_CVCMNT)

                  @SetTextOvr(Err_CVTRDA)
                  <tr><td class="dsphdr"><span $(textOvr)>Terminate Coverage When 'NNN' Days Overdue</span></td>
                      <td class="inputnmbr"><input name="terminateWhenOverdue" type="text" value="$(V_CVTRDA)" size="3" maxlength="3"></td>
                  </tr>
                  @DspErrMsg(Err_CVTRDA)

                  @SetTextOvr(Err_CVVPOL)
                  <tr><td class="dsphdr"><span $(textOvr)>Conversion Policy Available</span></td>
                      @dtw_tb_rows(conversionTable, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(conversionTable, x, "1") != V_CVVPOL) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(conversionTable, "conversionPolicy", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_CVVPOL)

                  @SetTextOvr(Err_CVVPRE)
                  <tr><td class="dsphdr"><span $(textOvr)>Conversion Policy Premium</span></td>
                      <td class="inputnmbr"><input name="conversionPremium" type="text" value="$(V_CVVPRE)" size="8" maxlength="8"></td>
                  </tr>
                  @DspErrMsg(Err_CVVPRE)

                  @SetTextOvr(Err_CVVCST)
                  <tr><td class="dsphdr"><span $(textOvr)>Conversion Policy Cost</span></td>
                      <td class="inputnmbr"><input name="conversionCost" type="text" value="$(V_CVVCST)" size="8" maxlength="8"></td>
                  </tr>
                  @DspErrMsg(Err_CVVCST)
              </table>
          </fieldset>

          <a name="contributions"></a>
          <fieldset class="legendBody">
              <legend class="legendTitle">Employee Contributions</legend>
              <div class="quickLinksTop">
                  <a href="#top">$(topOfFormImage)</a>
              </div>
              <table $(contentTable)>
                  @RtvFldDesc("HVDDNO=$(V_CVDEDN)", "HRDEDM", "HVDDNM", dedName)
                  @SetTextOvr(Err_CVDEDN)
                  <tr><td class="dsphdr"><span $(textOvr)>Payroll Deduction</span></td>
                      <td class="inputalph"><input name="payrollDeduction" type="text" value="$(V_CVDEDN)" size="3" maxlength="3"><a href="$(homeURL)$(cGIPath)DeductionSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Chg&amp;fldName=payrollDeduction&amp;fldDesc=payrollDeductionName" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="payrollDeductionName" value="$(dedName)"  type="text" size="20" maxlength="20"></td>
                  </tr>
                  @DspErrMsg(Err_CVDEDN)

                  @SetTextOvr(Err_CVEMPW)
                  <tr><td class="dsphdr"><span $(textOvr)>Employee Contribution Amount - Weekly</span></td>
                      <td class="inputnmbr"><input name="employeeWkly" type="text" value="$(V_CVEMPW)" size="8" maxlength="8"></td>
                  </tr>
                  @DspErrMsg(Err_CVEMPW)

                  @SetTextOvr(Err_CVEMPB)
                  <tr><td class="dsphdr"><span $(textOvr)>Employee Contribution Amount - Bi-Weekly</span></td>
                      <td class="inputnmbr"><input name="employeeBiWkly" type="text" value="$(V_CVEMPB)" size="8" maxlength="8"></td>
                  </tr>
                  @DspErrMsg(Err_CVEMPB)

                  @SetTextOvr(Err_CVEMPS)
                  <tr><td class="dsphdr"><span $(textOvr)>Employee Contribution Amount - Semi-Monthly</span></td>
                      <td class="inputnmbr"><input name="employeeSemiMon" type="text" value="$(V_CVEMPS)" size="8" maxlength="8"></td>
                  </tr>
                  @DspErrMsg(Err_CVEMPS)

                  @SetTextOvr(Err_CVEMPM)
                  <tr><td class="dsphdr"><span $(textOvr)>Employee Contribution Amount - Monthly</span></td>
                      <td class="inputnmbr"><input name="employeeMon" type="text" value="$(V_CVEMPM)" size="8" maxlength="8"></td>
                  </tr>
                  @DspErrMsg(Err_CVEMPM)

                  @SetTextOvr(Err_CVEMPP)
                  <tr><td class="dsphdr"><span $(textOvr)>Employee Contribution - Percent</span></td>
                      <td class="inputnmbr"><input name="employeePct" type="text" value="$(V_CVEMPP)" size="6" maxlength="6"></td>
                  </tr>
                  @DspErrMsg(Err_CVEMPP)

                  <tr><td class="dsphdr"><span $(textOvr)>Update Employee Deductions</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != groupUpdate) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "groupUpdate", "2", "1", "N", "", x, "1")</td>
                  </tr>
              </table>
          </fieldset>

          <a name="cost"></a>
          <fieldset class="legendBody">
              <legend class="legendTitle">Benefit Cost</legend>
              <div class="quickLinksTop">
                  <a href="#top">$(topOfFormImage)</a>
              </div>
              <table $(contentTable)>
                  @SetTextOvr(Err_CVCSTW)
                  <tr><td class="dsphdr"><span $(textOvr)>Employer Cost Of Coverage - Weekly</span></td>
                      <td class="inputnmbr"><input name="employerWkly" type="text" value="$(V_CVCSTW)" size="8" maxlength="8"></td>
                  </tr>
                  @DspErrMsg(Err_CVCSTW)

                  @SetTextOvr(Err_CVCSTB)
                  <tr><td class="dsphdr"><span $(textOvr)>Employer Cost Of Coverage - Bi-Weekly</span></td>
                      <td class="inputnmbr"><input name="employerBiWkly" type="text" value="$(V_CVCSTB)" size="8" maxlength="8"></td>
                  </tr>
                  @DspErrMsg(Err_CVCSTB)

                  @SetTextOvr(Err_CVCSTS)
                  <tr><td class="dsphdr"><span $(textOvr)>Employer Cost Of Coverage - Semi-Monthly</span></td>
                      <td class="inputnmbr"><input name="employerSemiMon" type="text" value="$(V_CVCSTS)" size="8" maxlength="8"></td>
                  </tr>
                  @DspErrMsg(Err_CVCSTS)

                  @SetTextOvr(Err_CVCSTM)
                  <tr><td class="dsphdr"><span $(textOvr)>Employer Cost Of Coverage - Monthly</span></td>
                      <td class="inputnmbr"><input name="employerMon" type="text" value="$(V_CVCSTM)" size="8" maxlength="8"></td>
                  </tr>
                  @DspErrMsg(Err_CVCSTM)

              </table>
          </fieldset>
    	   %}

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64) profileHandle,
                                                INOUT CHAR(2) dataBaseID,
                                                INOUT CHAR(1) maintenanceCode,
                                                INOUT CHAR(1) errFound,
                                                INOUT CHAR(32000) edtVar,
                                                INOUT CHAR(32000) errVar)
  {%EXEC {HPECVU_W.PGM %}
%}

%HTML(hrBenefits) {

  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Benefit_Function_Query(profileHandle, dataBaseID, benefitFunctionTable)	
    	   @dtw_tb_insertrow(benefitFunctionTable, "0", "1")
          @dtw_tb_setv(benefitFunctionTable, "", "1", "1")
      @Benefit_Type_Query(profileHandle, dataBaseID, benefitTypeTable)	
    	   @dtw_tb_insertrow(benefitTypeTable, "0", "1")
          @dtw_tb_setv(benefitTypeTable, "", "1", "1")
      @Carrier_Code_Query(profileHandle, dataBaseID, carrierCodeTable)	
    	   @dtw_tb_insertrow(carrierCodeTable, "0", "1")
          @dtw_tb_setv(carrierCodeTable, "", "1", "1")
      @payment_Frequency_Query(profileHandle, dataBaseID, "PAYFREQ   ", paymentFrequencyTable)
      @core_Table_Query(profileHandle, dataBaseID, "CORE      ", coreTable)
      @continuation_Table_Query(profileHandle, dataBaseID, "BYN       ", continuationTable)
      @conversion_Table_Query(profileHandle, dataBaseID, "BYN       ", conversionTable)
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
    	   @dtw_tb_insertrow(yn01Table, "0", "1")
          @dtw_tb_setv(yn01Table, "", "1", "1")
      @CoFac_Deduction_Query(profileHandle, dataBaseID, prCompany, prFacility, coFacDeductionTable)	
	   @dtw_tb_insertrow(coFacDeductionTable, "0", "1")
	   @dtw_tb_setv(coFacDeductionTable, "", "1", "2")
      @DayOfWeek_Query(profileHandle, dataBaseID, "DAYOFWEEK ",  dayOfWeekTable)	
    	   @dtw_tb_insertrow(dayOfWeekTable, "0", "1")
    	   @dtw_tb_setv(dayOfWeekTable, "", "1", "1")
      @EnrollEmpl_Query(profileHandle, dataBaseID, "ENROLLEMPL",  enrollEmplTable)	
    	   @dtw_tb_insertrow(enrollEmplTable, "0", "1")
    	   @dtw_tb_setv(enrollEmplTable, "", "1", "1")
      @EnrollDep_Query(profileHandle, dataBaseID, "ENROLLDEP ",  enrollDepTable)	
    	   @dtw_tb_insertrow(enrollDepTable, "0", "1")
    	   @dtw_tb_setv(enrollDepTable, "", "1", "1")

      %if (maintenanceCode == "A" || maintenanceCode == "Z")
          @PlanCode_Query(profileHandle, dataBaseID, planCodeTable)	
              @dtw_tb_insertrow(planCodeTable, "0", "1")
              @dtw_tb_setv(planCodeTable, "", "1", "1")
      %endif

      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(benefitCode)
  @dtw_mUPPERCASE(invoiceComment)
  @dtw_assign(submitUpdate, "")
  @dtw_assign(scheduleUpdate, "")

  @dtw_assign(effectiveDate,@dtw_rstrip(effectiveDate))
  @dtw_assign(expirationDate,@dtw_rstrip(expirationDate))
  @dtw_assign(premiumAmount,@dtw_rstrip(premiumAmount))
  @dtw_assign(premiumAdjPercent,@dtw_rstrip(premiumAdjPercent))
  @dtw_assign(dateCobraEffective,@dtw_rstrip(dateCobraEffective))
  @dtw_assign(terminateWhenOverdue,@dtw_rstrip(terminateWhenOverdue))
  @dtw_assign(conversionPremium,@dtw_rstrip(conversionPremium))
  @dtw_assign(conversionCost,@dtw_rstrip(conversionCost))
  @dtw_assign(dependentAge,@dtw_rstrip(dependentAge))
  @dtw_assign(studentAge,@dtw_rstrip(studentAge))
  @dtw_assign(payrollDeduction,@dtw_rstrip(payrollDeduction))
  @dtw_assign(deductible,@dtw_rstrip(deductible))
  @dtw_assign(coPaymentOne,@dtw_rstrip(coPaymentOne))
  @dtw_assign(coPaymentTwo,@dtw_rstrip(coPaymentTwo))
  @dtw_assign(coPaymentThree,@dtw_rstrip(coPaymentThree))
  @dtw_assign(outofPocketInd,@dtw_rstrip(outofPocketInd))
  @dtw_assign(outofPocketFam,@dtw_rstrip(outofPocketFam))
  @dtw_assign(amtperEmp,@dtw_rstrip(amtperEmp))
  @dtw_assign(amtperDep,@dtw_rstrip(amtperDep))
  @dtw_assign(enrollEmpl,@dtw_rstrip(enrollEmpl))
  @dtw_assign(enrollDep,@dtw_rstrip(enrollDep))
  @dtw_assign(eligplusDays,@dtw_rstrip(eligplusDays))
  @dtw_assign(eligplusMos,@dtw_rstrip(eligplusMos))
  @dtw_assign(elighrsofSvc,@dtw_rstrip(elighrsofSvc))
  @dtw_assign(eligAge,@dtw_rstrip(eligAge))
  @dtw_assign(effdayofMon,@dtw_rstrip(effdayofMon))
  @dtw_assign(enrollmentperStrt,@dtw_rstrip(enrollmentperStrt))
  @dtw_assign(enrollmentperEnd,@dtw_rstrip(enrollmentperEnd))
  @dtw_assign(employeeWkly,@dtw_rstrip(employeeWkly))
  @dtw_assign(employeeBiWkly,@dtw_rstrip(employeeBiWkly))
  @dtw_assign(employeeSemiMon,@dtw_rstrip(employeeSemiMon))
  @dtw_assign(employeeMon,@dtw_rstrip(employeeMon))
  @dtw_assign(employeePct,@dtw_rstrip(employeePct))
  @dtw_assign(employerWkly,@dtw_rstrip(employerWkly))
  @dtw_assign(employerBiWkly,@dtw_rstrip(employerBiWkly))
  @dtw_assign(employerSemiMon,@dtw_rstrip(employerSemiMon))
  @dtw_assign(employerMon,@dtw_rstrip(employerMon))
  @dtw_assign(unitValue,@dtw_rstrip(unitValue))
  @dtw_assign(negElectRate,@dtw_rstrip(negElectRate))
  @dtw_assign(groupUpdate,@dtw_rstrip(groupUpdate))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  %if (maintenanceCode == "A")
      @dtw_assign(prCompany, prCompanyFld)
      @dtw_assign(prFacility, prFacilityFld)
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@comp", prCompany)
  @Concat_Field("@@facl", prFacility)
  @Concat_Field("@@covr", benefitCode)
  @Concat_Field("@@plan", planCode)
  @Concat_Field("@@desc", benefitDescription)
  @Concat_Field("@@carr", providerCode)
  @Concat_Field("@@polc", policyNumber)
  @Concat_Field("@@npi@", providerID)
  @Concat_Field("@@effd", effectiveDate)
  @Concat_Field("@@expd", expirationDate)
  @Concat_Field("@@admn", planAdministrator)
  @Concat_Field("@@freq", paymentFrequency)
  @Concat_Field("@@prem", premiumAmount)
  @Concat_Field("@@adj@", premiumAdjPercent)
  @Concat_Field("@@cmnt", invoiceComment)
  @Concat_Field("@@dcef", dateCobraEffective)
  @Concat_Field("@@core", coreNoncore)
  @Concat_Field("@@creq", continuationRequired)
  @Concat_Field("@@trda", terminateWhenOverdue)
  @Concat_Field("@@vpol", conversionPolicy)
  @Concat_Field("@@vpre", conversionPremium)
  @Concat_Field("@@vcst", conversionCost)
  @Concat_Field("@@dage", dependentAge)
  @Concat_Field("@@sage", studentAge)
  @Concat_Field("@@dedn", payrollDeduction)
  @Concat_Field("@@aneg", allowNegative)
  @Concat_Field("@@fnct", benefitFunction)
  @Concat_Field("@@type", benefitType)
  @Concat_Field("@@ddct", deductible)
  @Concat_Field("@@cop1", coPaymentOne)
  @Concat_Field("@@cop2", coPaymentTwo)
  @Concat_Field("@@cop3", coPaymentThree)
  @Concat_Field("@@pcki", outofpocketInd)
  @Concat_Field("@@pckf", outofpocketFam)
  @Concat_Field("@@amte", amtperEmp)
  @Concat_Field("@@amtd", amtperDep)
  @Concat_Field("@@aute", enrollEmpl)
  @Concat_Field("@@autd", enrollDep)
  @Concat_Field("@@elgd", eligplusDays)
  @Concat_Field("@@elgm", eligplusMos)
  @Concat_Field("@@elgh", elighrsofSvc)
  @Concat_Field("@@elga", eligAge)
  @Concat_Field("@@cefd", calcDtEff)
  @Concat_Field("@@eldm", effdayofMon)
  @Concat_Field("@@eldw", effdayofWk)
  @Concat_Field("@@enrc", enrollmentCmnt)
  @Concat_Field("@@eben", enterBen)
  @Concat_Field("@@eddp", enterDedPct)
  @Concat_Field("@@enst", enrollmentperStrt)
  @Concat_Field("@@enen", enrollmentperEnd)
  @Concat_Field("@@urli", benefitURL)
  @Concat_Field("@@img@", benefitURLImg)
  @Concat_Field("@@empw", employeeWkly)
  @Concat_Field("@@empb", employeeBiWkly)
  @Concat_Field("@@emps", employeeSemiMon)
  @Concat_Field("@@empm", employeeMon)
  @Concat_Field("@@empp", employeePct)
  @Concat_Field("@@cstw", employerWkly)
  @Concat_Field("@@cstb", employerBiWkly)
  @Concat_Field("@@csts", employerSemiMon)
  @Concat_Field("@@cstm", employerMon)
  @Concat_Field("@@unit", unitValue)
  @Concat_Field("@@npct", negElectRate)
  @Concat_Field("@@F08@", groupUpdate)
  @Concat_Field("@@sbmt", submitUpdate)
  @Concat_Field("@@schd", scheduleUpdate)
  @Concat_Field("@@tstp", timeStamp)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)
  @DecatErr_Field("@@covr", "benefitCode")           @dtw_assign(Err_CVCOVR, fieldValue)
  
  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(benefitDescription), $(benefitCode), "Plan", $(planCode), "", "", confMessage)
      %if (maintenanceCode == "D")
          %if ((fromD2w != "") && (fromD2w != "HRBenefitSelect.d2w"))
              <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;benefitCode=@dtw_rurlescseq(benefitCode)&amp;planCode=@dtw_rurlescseq(planCode)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %else
              <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)hrbenefits.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %endif
      %elif (fromD2w != "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;benefitCode=@dtw_rurlescseq(benefitCode)&amp;planCode=@dtw_rurlescseq(planCode)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)hrbenefits.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %elif ((maintenanceCode == "C" || maintenanceCode == "D") && errFound != "" && fieldValue != "")
      @Format_ConfMsg_Desc("E", $(benefitDescription), $(benefitCode), "Plan", $(planCode), "<br>$(fieldValue)", "", confMessage)
      %if (fromD2w != "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)hrBenefits.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/hrBenefits$(d2wVarBase)&amp;benefitCode=@dtw_rurlescseq(benefitCode)&amp;planCode=@dtw_rurlescseq(planCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}