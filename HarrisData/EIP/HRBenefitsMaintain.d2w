                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_CVCEFD) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "calcDtEff", "2", "1", "N", "", x, "1") $(reqFieldChar) </td>
