                  </tr>
                  @DspErrMsg(Err_CVELDW)

                  @SetTextOvr(Err_CVENST)
                  <tr><td class="dsphdr"><span $(textOvr)>Enrollment Period Start Date</span></td>
                      <td class="inputnmbr"><input name="enrollmentperStrt" type="text" value="$(V_CVENST)" size="6" maxlength="6">
                              <a href="javascript:calWindow('enrollmentperStrt');"> $(calendarImage) </a></td>
                  </tr>
