%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "hrbenefitsMaintain.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "ynFlagTable.icl"

%Define {
  page_title 		= "Benefit Maintenance"
  d2wName              = "HRBenefitsMaintain.d2w"
  d2wVarBase           = "$(genericVarBase)$(hrCoFacVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  deleteURL            = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;benefitCode=@dtw_rurlescseq(benefitCode)&amp;planCode=@dtw_rurlescseq(planCode)&amp;maintenanceCode=D"
  programName          = "HPECVU"
  classification       = ""
  groupUpdate          = "N"
  fsaMaint             = ""
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  UVPREmpl             = "00000"
  prCompany            = "00"
  prFacility           = "0000"
  prCompanyFld         = "00"
  prFacilityFld        = "0000"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "HrCoFacURL.icl"
  @dtw_replace(workURL, "@@benefitCode", "@dtw_rurlescseq(benefitCode)", "1", "a", workURL)
  @dtw_replace(workURL, "@@planCode", "@dtw_rurlescseq(planCode)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @CoFacUserView(profileHandle, dataBaseID, userPass, prCompany, prFacility)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script type="text/javascript">
                  %INCLUDE "calendar.icl"
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "dateedit.icl"
                  %INCLUDE "Menu.js"
                  %INCLUDE "numedit.icl"
                  function confirmDelete() {return confirm("$(delRecordConf)")}
                  function validate(chgForm) {
                      if (document.Chg.benefitCode.value =="" ||
                          document.Chg.planCode.value =="" ||
                          document.Chg.benefitDescription.value =="" ||
                          document.Chg.providerCode.value =="" ||
                          document.Chg.policyNumber.value =="" ||
                          document.Chg.effectiveDate.value =="" ||
                          document.Chg.expirationDate.value =="" ||
                          document.Chg.allowNegative.value =="" ||
                          document.Chg.planAdministrator.value =="" ||
                          document.Chg.calcDtEff.value =="" ||
                          document.Chg.enterBen.value =="" ||
                          document.Chg.enterDedPct.value =="" ||
                          document.Chg.enrollEmpl.value =="" ||
                          document.Chg.enrollDep.value =="")
                         {alert("$(reqFieldError)"); return false;}
                      if (editdate(document.Chg.effectiveDate) &&
                          editdate(document.Chg.expirationDate) &&
                          editNum(document.Chg.premiumAmount, 5, 2) &&
                          editNum(document.Chg.premiumAdjPercent, 3, 3) &&
                          editdate(document.Chg.dateCobraEffective) &&
                          editNum(document.Chg.terminateWhenOverdue, 3, 0) &&
                          editNum(document.Chg.conversionPremium, 5, 2) &&
                          editNum(document.Chg.conversionCost, 5, 2) &&
                          editNum(document.Chg.dependentAge, 2, 0) &&
                          editNum(document.Chg.studentAge, 2, 0) &&
                          editNum(document.Chg.payrollDeduction, 3, 0) &&
                          editNum(document.Chg.deductible, 5, 2) &&
                          editNum(document.Chg.coPaymentOne, 5, 2) &&
                          editNum(document.Chg.coPaymentTwo, 5, 2) &&
                          editNum(document.Chg.coPaymentThree, 5, 2) &&
                          editNum(document.Chg.outofpocketInd, 5, 2) &&
                          editNum(document.Chg.outofpocketFam, 5, 2) &&
                          editNum(document.Chg.amtperEmp, 7, 0) &&
                          editNum(document.Chg.amtperDep, 7, 0) &&
                          editNum(document.Chg.eligplusDays, 3, 0) &&
                          editNum(document.Chg.eligplusMos, 2, 0) &&
                          editNum(document.Chg.elighrsofSvc, 5, 0) &&
                          editNum(document.Chg.eligAge, 2, 0) &&
                          editNum(document.Chg.effdayofMon, 2, 0) &&
                          editdate(document.Chg.enrollmentperStrt) &&
                          editdate(document.Chg.enrollmentperEnd) &&
                          editNum(document.Chg.employeeWkly, 5, 2) &&
                          editNum(document.Chg.employeeBiWkly, 5, 2) &&
                          editNum(document.Chg.employeeSemiMon, 5, 2) &&
                          editNum(document.Chg.employeeMon, 5, 2) &&
                          editNum(document.Chg.employeePct, 2, 3) &&
                          editNum(document.Chg.employerWkly, 5, 2) &&
                          editNum(document.Chg.employerBiWkly, 5, 2) &&
                          editNum(document.Chg.employerSemiMon, 5, 2) &&
                          editNum(document.Chg.employerMon, 5, 2) &&
                          editNum(document.Chg.unitValue, 5, 2) &&
                          editNum(document.Chg.negElectRate, 2, 3))
                          return true;
                  }
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->

              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "BENEFITMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                         @dtw_assign(stmtSQL, "")
                         %if (maintenanceCode == "A")
                             %INCLUDE "AddRecordSQL.icl"
                         %else
                             %INCLUDE "stmtSQLClear.icl"
                             @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                             @dtw_concat(fileSQL, " CBCOVR inner join CBCODE on CVPLAN=CCCODE ", fileSQL)
                             @dtw_concat(selectSQL, " CVCOMP=$(prCompany) and CVFACL=$(prFacility) and CVCOVR='$(benefitCode)' and CVPLAN='$(planCode)' ", selectSQL)
                             %INCLUDE "stmtSQLSelect.icl"
                         %endif
                         %INCLUDE "stmtSQLEnd.icl"
                         @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)

{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)

      <table $(quickLinkTable)>
           %if (genEmplImage != "" && quicklinkDspImage == "Y")
              <tr>
                  <td><a href="#definition">$(definitionImage)</a></td>
                  <td><a href="#eligibility">$(eligibilityImage)</a></td>
                  <td><a href="#links">$(linksImage)</a></td>
                  <td><a href="#cobra">$(cobraImage)</a></td>
              </tr>
              <tr><td><a href="#contributions">$(contributionsImage)</a></td>
                  <td><a href="#cost">$(costImage)</a></td>
              </tr>
           %else
              <tr>
                  <td class="quickLinkTabs"><a href="#definition">Benefit Definition</a></td>
                  <td class="quickLinkTabs"><a href="#eligibility">Eligibility And Enrollment</a></td>
                  <td class="quickLinkTabs"><a href="#links">Links</a></td>
                  <td class="quickLinkTabs"><a href="#cobra">COBRA</a></td>
              </tr>
              <tr>
                  <td class="quickLinkTabs"><a href="#contributions">Employee Contribution</a></td>
                  <td class="quickLinkTabs"><a href="#cost">Benefit Cost</a></td>
              </tr>
           %endif
              <tr><td>&nbsp;</td></tr>
      </table>

      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST name="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                   %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "prCompanyFld")
                          @RtvFldDesc("CFCOMP=$(prCompany) and CFFACL=$(prFacility) ", "HRCOFC", "CFNAME", fieldDesc)
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@facl", "prFacilityFld")         @dtw_assign(Err_CVFACL, fieldValue)
                          @DecatErr_Field("@@covr", "benefitCode")           @dtw_assign(Err_CVCOVR, fieldValue)
                          @DecatErr_Field("@@plan", "planCode")              @dtw_assign(Err_CVPLAN, fieldValue)
                          @DecatErr_Field("@@desc", "benefitDescription")    @dtw_assign(Err_CVDESC, fieldValue)
                          @DecatErr_Field("@@carr", "providerCode")          @dtw_assign(Err_CVCARR,   fieldValue)
                          @DecatErr_Field("@@polc", "policyNumber")          @dtw_assign(Err_CVPOLC, fieldValue)
                          @DecatErr_Field("@@npi@", "providerID")            @dtw_assign(Err_CVNPI, fieldValue)
                          @DecatErr_Field("@@effd", "effectiveDate")         @dtw_assign(Err_CVEFFD,  fieldValue)
                          @DecatErr_Field("@@expd", "expirationDate")        @dtw_assign(Err_CVEXPD, fieldValue)
                          @DecatErr_Field("@@admn", "planAdministrator")     @dtw_assign(Err_CVADMN, fieldValue)
                          @DecatErr_Field("@@freq", "paymentFrequency")      @dtw_assign(Err_CVFREQ, fieldValue)
                          @DecatErr_Field("@@prem", "premiumAmount")         @dtw_assign(Err_CVPREM, fieldValue)
                          @DecatErr_Field("@@adj@", "premiumAdjPercent")     @dtw_assign(Err_CVADJ, fieldValue)
                          @DecatErr_Field("@@cmnt", "invoiceComment")        @dtw_assign(Err_CVCMNT, fieldValue)
                          @DecatErr_Field("@@dcef", "dateCobraEffective")    @dtw_assign(Err_CVDCEF, fieldValue)
                          @DecatErr_Field("@@core", "coreNoncore")           @dtw_assign(Err_CVCORE, fieldValue)
                          @DecatErr_Field("@@creq", "continuationRequired")  @dtw_assign(Err_CVCREQ, fieldValue)
                          @DecatErr_Field("@@trda", "terminateWhenOverdue")  @dtw_assign(Err_CVTRDA, fieldValue)
                          @DecatErr_Field("@@vpol", "conversionPolicy")      @dtw_assign(Err_CVVPOL, fieldValue)
                          @DecatErr_Field("@@vpre", "conversionPremium")     @dtw_assign(Err_CVVPRE, fieldValue)
                          @DecatErr_Field("@@vcst", "conversionCost")        @dtw_assign(Err_CVVCST, fieldValue)
                          @DecatErr_Field("@@dage", "dependentAge")          @dtw_assign(Err_CVDAGE, fieldValue)
                          @DecatErr_Field("@@sage", "studentAge")            @dtw_assign(Err_CVSAGE, fieldValue)
                          @DecatErr_Field("@@dedn", "payrollDeduction")      @dtw_assign(Err_CVDEDN, fieldValue)
                          @DecatErr_Field("@@aneg", "allowNegative")         @dtw_assign(Err_CVANEG, fieldValue)
                          @DecatErr_Field("@@fnct", "benefitFunction")       @dtw_assign(Err_CVFNCT, fieldValue)
                          @DecatErr_Field("@@type", "benefitType")           @dtw_assign(Err_CVTYPE, fieldValue)
                          @DecatErr_Field("@@ddct", "deductible")            @dtw_assign(Err_CVDDCT, fieldValue)
                          @DecatErr_Field("@@cop1", "coPaymentOne")          @dtw_assign(Err_CVCOP1, fieldValue)
                          @DecatErr_Field("@@cop2", "coPaymentTwo")          @dtw_assign(Err_CVCOP2, fieldValue)
                          @DecatErr_Field("@@cop3", "coPaymentThree")        @dtw_assign(Err_CVCOP3, fieldValue)
                          @DecatErr_Field("@@pcki", "outofpocketInd")        @dtw_assign(Err_CVPCKI, fieldValue)
                          @DecatErr_Field("@@pckf", "outofpocketFam")        @dtw_assign(Err_CVPCKF, fieldValue)
                          @DecatErr_Field("@@amte", "amtperEmp")             @dtw_assign(Err_CVAMTE, fieldValue)
                          @DecatErr_Field("@@amtd", "amtperDep")             @dtw_assign(Err_CVAMTD, fieldValue)
                          @DecatErr_Field("@@aute", "enrollEmpl")            @dtw_assign(Err_CVAUTE, fieldValue)
                          @DecatErr_Field("@@autd", "enrollDep")             @dtw_assign(Err_CVAUTD, fieldValue)
                          @DecatErr_Field("@@elgd", "eligplusDays")          @dtw_assign(Err_CVELGD, fieldValue)
                          @DecatErr_Field("@@elgm", "eligplusMos")           @dtw_assign(Err_CVELGM, fieldValue)
                          @DecatErr_Field("@@elgh", "elighrsofSvc")          @dtw_assign(Err_CVELGH, fieldValue)
                          @DecatErr_Field("@@elga", "eligAge")               @dtw_assign(Err_CVELGA, fieldValue)
                          @DecatErr_Field("@@cefd", "calcDtEff")             @dtw_assign(Err_CVCEFD, fieldValue)
                          @DecatErr_Field("@@eldm", "effdayofMon")           @dtw_assign(Err_CVELDM, fieldValue)
                          @DecatErr_Field("@@eldw", "effdayofWk")            @dtw_assign(Err_CVELDW, fieldValue)
                          @DecatErr_Field("@@enrc", "enrollmentCmnt")        @dtw_assign(Err_CVENRC, fieldValue)
                          @DecatErr_Field("@@eben", "enterBen")              @dtw_assign(Err_CVEBEN, fieldValue)
                          @DecatErr_Field("@@eddp", "enterDedPct")           @dtw_assign(Err_CVEDDP, fieldValue)
                          @DecatErr_Field("@@enst", "enrollmentperStrt")     @dtw_assign(Err_CVENST, fieldValue)
                          @DecatErr_Field("@@enen", "enrollmentperEnd")      @dtw_assign(Err_CVENEN, fieldValue)
                          @DecatErr_Field("@@urli", "benefitURL")            @dtw_assign(Err_CVURLI, fieldValue)
                          @DecatErr_Field("@@img@", "benefitURLImg")         @dtw_assign(Err_CVIMG, fieldValue)
                          @DecatErr_Field("@@empw", "employeeWkly")          @dtw_assign(Err_CVEMPW, fieldValue)
                          @DecatErr_Field("@@empb", "employeeBiWkly")        @dtw_assign(Err_CVEMPB, fieldValue)
                          @DecatErr_Field("@@emps", "employeeSemiMon")       @dtw_assign(Err_CVEMPS, fieldValue)
                          @DecatErr_Field("@@empm", "employeeMon")           @dtw_assign(Err_CVEMPM, fieldValue)
                          @DecatErr_Field("@@empp", "employeePct")           @dtw_assign(Err_CVEMPP, fieldValue)
                          @DecatErr_Field("@@cstw", "employerWkly")          @dtw_assign(Err_CVCSTW, fieldValue)
                          @DecatErr_Field("@@cstb", "employerBiWkly")        @dtw_assign(Err_CVCSTB, fieldValue)
                          @DecatErr_Field("@@csts", "employerSemiMon")       @dtw_assign(Err_CVCSTS, fieldValue)
                          @DecatErr_Field("@@cstm", "employerMon")           @dtw_assign(Err_CVCSTM, fieldValue)
                          @DecatErr_Field("@@unit", "unitValue")             @dtw_assign(Err_CVUNIT, fieldValue)
                          @DecatErr_Field("@@npct", "negElectRate")          @dtw_assign(Err_CVNPCT, fieldValue)
                          @DecatErr_Field("@@tstp", "timeStamp")             @dtw_assign(Err_TSTP, fieldValue)
                      %endif

                      @Decat_Field("@@comp")   @dtw_assign(V_CVCOMP, fieldValue)
                      @Decat_Field("@@facl")   @dtw_assign(V_CVFACL, fieldValue)
                      @Decat_Field("@@covr")   @dtw_assign(V_CVCOVR, fieldValue)
                      @Decat_Field("@@plan")   @dtw_assign(V_CVPLAN, fieldValue)
                      @Decat_Field("@@desc")   @dtw_assign(V_CVDESC, fieldValue)
                      @Decat_Field("@@carr")   @dtw_assign(V_CVCARR, fieldValue)
                      @Decat_Field("@@polc")   @dtw_assign(V_CVPOLC, fieldValue)
                      @Decat_Field("@@npi@")   @dtw_assign(V_CVNPI,  fieldValue)
                      @Decat_Field("@@effd")   @dtw_assign(V_CVEFFD, fieldValue)
                      @Decat_Field("@@expd")   @dtw_assign(V_CVEXPD, fieldValue)
                      @Decat_Field("@@admn")   @dtw_assign(V_CVADMN, fieldValue)
                      @Decat_Field("@@freq")   @dtw_assign(V_CVFREQ, fieldValue)
                      @Decat_Field("@@prem")   @dtw_assign(V_CVPREM, fieldValue)
                      @Decat_Field("@@adj@")   @dtw_assign(V_CVADJ,  fieldValue)
                      @Decat_Field("@@cmnt")   @dtw_assign(V_CVCMNT, fieldValue)
                      @Decat_Field("@@dcef")   @dtw_assign(V_CVDCEF, fieldValue)
                      @Decat_Field("@@core")   @dtw_assign(V_CVCORE, fieldValue)
                      @Decat_Field("@@creq")   @dtw_assign(V_CVCREQ, fieldValue)
                      @Decat_Field("@@trda")   @dtw_assign(V_CVTRDA, fieldValue)
                      @Decat_Field("@@vpol")   @dtw_assign(V_CVVPOL, fieldValue)
                      @Decat_Field("@@vpre")   @dtw_assign(V_CVVPRE, fieldValue)
                      @Decat_Field("@@vcst")   @dtw_assign(V_CVVCST, fieldValue)
                      @Decat_Field("@@dage")   @dtw_assign(V_CVDAGE, fieldValue)
                      @Decat_Field("@@sage")   @dtw_assign(V_CVSAGE, fieldValue)
                      @Decat_Field("@@dedn")   @dtw_assign(V_CVDEDN, fieldValue)
                      @Decat_Field("@@aneg")   @dtw_assign(V_CVANEG, fieldValue)
                      @Decat_Field("@@fnct")   @dtw_assign(V_CVFNCT, fieldValue)
                      @Decat_Field("@@type")   @dtw_assign(V_CVTYPE, fieldValue)
                      @Decat_Field("@@ddct")   @dtw_assign(V_CVDDCT, fieldValue)
                      @Decat_Field("@@cop1")   @dtw_assign(V_CVCOP1, fieldValue)
                      @Decat_Field("@@cop2")   @dtw_assign(V_CVCOP2, fieldValue)
                      @Decat_Field("@@cop3")   @dtw_assign(V_CVCOP3, fieldValue)
                      @Decat_Field("@@pcki")   @dtw_assign(V_CVPCKI, fieldValue)
                      @Decat_Field("@@pckf")   @dtw_assign(V_CVPCKF, fieldValue)
                      @Decat_Field("@@amte")   @dtw_assign(V_CVAMTE, fieldValue)
                      @Decat_Field("@@amtd")   @dtw_assign(V_CVAMTD, fieldValue)
                      @Decat_Field("@@aute")   @dtw_assign(V_CVAUTE, fieldValue)
                      @Decat_Field("@@autd")   @dtw_assign(V_CVAUTD, fieldValue)
                      @Decat_Field("@@elgd")   @dtw_assign(V_CVELGD, fieldValue)
                      @Decat_Field("@@elgm")   @dtw_assign(V_CVELGM, fieldValue)
                      @Decat_Field("@@elgh")   @dtw_assign(V_CVELGH, fieldValue)
                      @Decat_Field("@@elga")   @dtw_assign(V_CVELGA, fieldValue)
                      @Decat_Field("@@cefd")   @dtw_assign(V_CVCEFD, fieldValue)
                      @Decat_Field("@@eldm")   @dtw_assign(V_CVELDM, fieldValue)
                      @Decat_Field("@@eldw")   @dtw_assign(V_CVELDW, fieldValue)
                      @Decat_Field("@@enrc")   @dtw_assign(V_CVENRC, fieldValue)
                      @Decat_Field("@@eben")   @dtw_assign(V_CVEBEN, fieldValue)
                      @Decat_Field("@@eddp")   @dtw_assign(V_CVEDDP, fieldValue)
                      @Decat_Field("@@enst")   @dtw_assign(V_CVENST, fieldValue)
                      @Decat_Field("@@enen")   @dtw_assign(V_CVENEN, fieldValue)
                      @Decat_Field("@@urli")   @dtw_assign(V_CVURLI, fieldValue)
                      @Decat_Field("@@img@")   @dtw_assign(V_CVIMG,  fieldValue)
                      @Decat_Field("@@empw")   @dtw_assign(V_CVEMPW, fieldValue)
                      @Decat_Field("@@empb")   @dtw_assign(V_CVEMPB, fieldValue)
                      @Decat_Field("@@emps")   @dtw_assign(V_CVEMPS, fieldValue)
                      @Decat_Field("@@empm")   @dtw_assign(V_CVEMPM, fieldValue)
                      @Decat_Field("@@empp")   @dtw_assign(V_CVEMPP, fieldValue)
                      @Decat_Field("@@cstw")   @dtw_assign(V_CVCSTW, fieldValue)
                      @Decat_Field("@@cstb")   @dtw_assign(V_CVCSTB, fieldValue)
                      @Decat_Field("@@csts")   @dtw_assign(V_CVCSTS, fieldValue)
                      @Decat_Field("@@cstm")   @dtw_assign(V_CVCSTM, fieldValue)
                      @Decat_Field("@@unit")   @dtw_assign(V_CVUNIT, fieldValue)
                      @Decat_Field("@@npct")   @dtw_assign(V_CVNPCT, fieldValue)
                      @Decat_Field("@@tstp")   @dtw_assign(V_CVTSTP, fieldValue)

                      %if (groupUpdate == "")
                          @dtw_assign(groupUpdate, "N")
                      %endif

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(effectiveDate, "000000")
                          @dtw_assign(expirationDate, "000000")
                          @dtw_assign(paymentFrequency, "M")
                          @dtw_assign(premiumAmount, "0000000")
                          @dtw_assign(premiumAdjPercent, "00000")
                          @dtw_assign(dateCobraEffective, "000000")
                          @dtw_assign(terminateWhenOverdue, "000")
                          @dtw_assign(conversionPremium, "0000000")
                          @dtw_assign(conversionCost, "0000000")
                          @dtw_assign(dependentAge, "000")
                          @dtw_assign(studentAge, "000")
                          @dtw_assign(payrollDeduction, "000")
                          @dtw_assign(deductible, "0000000")
                          @dtw_assign(coPaymentOne, "0000000")
                          @dtw_assign(coPaymentTwo, "0000000")
                          @dtw_assign(coPaymentThree, "0000000")
                          @dtw_assign(outofpocketInd, "0000000")
                          @dtw_assign(outofpocketFam, "0000000")
                          @dtw_assign(amtperEmp, "0000000")
                          @dtw_assign(amtperDep, "0000000")
                          @dtw_assign(eligplusDays, "000")
                          @dtw_assign(eligplusMos, "00")
                          @dtw_assign(elighrsofSvc, "00000")
                          @dtw_assign(eligAge, "00")
                          @dtw_assign(effdayofMon, "00")
                          @dtw_assign(enrollmentperStrt, "0000000")
                          @dtw_assign(enrollmentperEnd, "0000000")
                          @dtw_assign(employeeWkly, "0000000")
                          @dtw_assign(employeeBiWkly, "0000000")
                          @dtw_assign(employeeSemiMon, "0000000")
                          @dtw_assign(employeeMon, "0000000")
                          @dtw_assign(employeePct, "00000")
                          @dtw_assign(employerWkly, "0000000")
                          @dtw_assign(employerBiWkly, "0000000")
                          @dtw_assign(employerSemiMon, "0000000")
                          @dtw_assign(employerMon, "0000000")
                          @dtw_assign(unitValue, "0000000")
                          @dtw_assign(negElectRate, "00000")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "prCompanyFld")
                      @RtvFldDesc("CFCOMP=$(prCompany) and CFFACL=$(prFacility) ", "HRCOFC", "CFNAME", fieldDesc)
                      @dtw_assign(V_CVADJ, "@dtw_rformat(@dtw_rmultiply(V_CVADJ, "100"),"","3")")
                      @dtw_assign(V_CVEMPP, "@dtw_rformat(@dtw_rmultiply(V_CVEMPP, "100"),"","3")")
                      @dtw_assign(V_CVNPCT, "@dtw_rformat(@dtw_rmultiply(V_CVNPCT, "100"),"","3")")
                      @DateInputFromCYMD(V_CVEFFD)
                      @DateInputFromCYMD(V_CVEXPD)
                      @DateInputFromCYMD(V_CVENST)
                      @DateInputFromCYMD(V_CVENEN)
                      @DateInputFromCYMD(V_CVDCEF)
                  %elif (maintenanceCode != "A")
                      @dtw_assign(focusField, "benefitDescription")
                      @dtw_assign(V_CVADJ, "@dtw_rformat(@dtw_rmultiply(V_CVADJ, "100"),"","3")")
                      @dtw_assign(V_CVEMPP, "@dtw_rformat(@dtw_rmultiply(V_CVEMPP, "100"),"","3")")
                      @dtw_assign(V_CVNPCT, "@dtw_rformat(@dtw_rmultiply(V_CVNPCT, "100"),"","3")")
                      @DateInputFromCYMD(V_CVEFFD)
                      @DateInputFromCYMD(V_CVEXPD)
                      @DateInputFromCYMD(V_CVENST)
                      @DateInputFromCYMD(V_CVENEN)
                      @DateInputFromCYMD(V_CVDCEF)
                  %endif
          </table>

          <a name="definition"></a>
          <fieldset class="legendBody">
              <legend class="legendTitle">Benefit Definition</legend>
              <div class="quickLinksTop">
                  <a href="#top">$(topOfFormImage)</a>
              </div>
              <table $(contentTable)>
                  <colgroup>
                      <col width="40%">
        	       <col width="60%">


                  @SetTextOvr(Err_TSTP)
                  <tr><td class="dsphdr"><span $(textOvr)>.</span></td>
                      <td><input name="timeStamp" type="hidden" value="$(V_CVTSTP)"></td>
                  </tr>
                  @DspErrMsg(Err_TSTP)
                  @SetTextOvr(Err_CVFACL)
                  <tr><td class="dsphdr"><span $(textOvr)>Company/Facility</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="prCompanyFld" value=$(prCompany) type="text" size="2" maxlength="2"> / <input name="prFacilityFld" value=$(prFacility) type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=prCompanyFld&amp;fldFac=prFacilityFld&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="coFacDesc" value="$(fieldDesc)"  type="text" size="30" maxlength="30"></td>
                      %else
                          @Format_HRCoFac(V_CVCOMP, V_CVFACL, "F", F_CoFac)
                          <td class="dspnmbr">$(returnFldDesc) &nbsp; $(F_CoFac)</td>
                          <td class="inputnmbr"><input name="prCompanyFld" type="hidden" value="$(V_CVCOMP)" size="2" maxlength="2">
                              <input name="prFacilityFld" type="hidden" value="$(V_CVFACL)" size="4" maxlength="4"></td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_CVFACL)

                  @SetTextOvr(Err_CVCOVR)
                  <tr><td class="dsphdr"><span $(textOvr)>Benefit Code</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="benefitCode" type="text" value="$(V_CVCOVR)" size="2" maxlength="2"> $(reqFieldChar) </td>
                      %else
                          <td class="inputalph"><input name="benefitCode" type="hidden" value="$(V_CVCOVR)" size="2" maxlength="2">$(V_CVCOVR)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_CVCOVR)

                  @SetTextOvr(Err_CVPLAN)
                  <tr><td class="dsphdr"><span $(textOvr)>Plan Code</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          @dtw_tb_rows(planCodeTable, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(planCodeTable, x, "1") != V_CVPLAN) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                              <td>@dtw_tb_select(planCodeTable, "planCode", "2", "1", "N", "", x, "1") $(reqFieldChar) </td>
                      %else
                          @Format_Code(V_CVPLAN, F_CVPLAN)
                          <td class="inputalph"><input name="planCode" type="hidden" value="$(V_CVPLAN)" size="3" maxlength="3">$(V_CCDESC) &nbsp; $(F_CVPLAN)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_CVPLAN)

                  @SetTextOvr(Err_CVDESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Benefit Description</span></td>
                      <td class="inputalph"><input name="benefitDescription" type="text" value="$(V_CVDESC)" size="15" maxlength="15"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_CVDESC)

                  @SetTextOvr(Err_CVCARR)
                  <tr><td class="dsphdr"><span $(textOvr)>Benefit Provider</span></td>
                      @dtw_tb_rows(carrierCodeTable, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(carrierCodeTable, x, "1") != V_CVCARR) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(carrierCodeTable, "providerCode", "2", "1", "N", "", x, "1") $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_CVCARR)

                  @SetTextOvr(Err_CVPOLC)
                  <tr><td class="dsphdr"><span $(textOvr)>Policy Number</span></td>
                      <td class="inputalph"><input name="policyNumber" type="text" value="$(V_CVPOLC)" size="10" maxlength="10"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_CVPOLC)

                  @SetTextOvr(Err_CVNPI)
                  <tr><td class="dsphdr"><span $(textOvr)>National Provider Identifier</span></td>
                      <td class="inputalph"><input name="providerID" type="text" value="$(V_CVNPI)" size="10" maxlength="10"></td>
                  </tr>
                  @DspErrMsg(Err_CVNPI)

                  @SetTextOvr(Err_CVEFFD)
                  <tr><td class="dsphdr"><span $(textOvr)>Effective Date</span></td>
                      <td class="inputnmbr"><input name="effectiveDate" type="text" value="$(V_CVEFFD)" size="6" maxlength="6"> $(reqFieldChar)
                              <a href="javascript:calWindow('effectiveDate');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_CVEFFD)
    		
                  @SetTextOvr(Err_CVEXPD)
                  <tr><td class="dsphdr"><span $(textOvr)>Expiration Date</span></td>
                      <td class="inputnmbr"><input name="expirationDate" type="text" value="$(V_CVEXPD)" size="6" maxlength="6"> $(reqFieldChar)
                              <a href="javascript:calWindow('expirationDate');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_CVEXPD)
    		
                  @SetTextOvr(Err_CVADMN)
                  <tr><td class="dsphdr"><span $(textOvr)>Plan Administrator</span></td>
                      <td class="inputalph"><input name="planAdministrator" type="text" value="$(V_CVADMN)" size="23" maxlength="23"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_CVADMN)

                  @SetTextOvr(Err_CVFNCT)
                  <tr><td class="dsphdr"><span $(textOvr)>Benefit Function</span></td>
                      @dtw_tb_rows(benefitFunctionTable, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(benefitFunctionTable, x, "1") != V_CVFNCT) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(benefitFunctionTable, "benefitFunction", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_CVFNCT)

                  @SetTextOvr(Err_CVTYPE)
                  <tr><td class="dsphdr"><span $(textOvr)>Benefit Type</span></td>
                      @dtw_tb_rows(benefitTypeTable, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(benefitTypeTable, x, "1") != V_CVTYPE) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(benefitTypeTable, "benefitType", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_CVTYPE)

                  @SetTextOvr(Err_CVANEG)
                  <tr><td class="dsphdr"><span $(textOvr)>Allow Negative Balance</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_CVANEG) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "allowNegative", "2", "1", "N", "", x, "1") $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_CVANEG)

                  @SetTextOvr(Err_CVDAGE)
                  <tr><td class="dsphdr"><span $(textOvr)>Dependent Age Limit</span></td>
                      <td class="inputnmbr"><input name="dependentAge" type="text" value="$(V_CVDAGE)" size="2" maxlength="2"></td>
                  </tr>
                  @DspErrMsg(Err_CVDAGE)

                  @SetTextOvr(Err_CVSAGE)
                  <tr><td class="dsphdr"><span $(textOvr)>Student Age Limit</span></td>
                      <td class="inputnmbr"><input name="studentAge" type="text" value="$(V_CVSAGE)" size="2" maxlength="2"></td>
                  </tr>
                  @DspErrMsg(Err_CVSAGE)

                  @SetTextOvr(Err_CVDDCT)
                  <tr><td class="dsphdr"><span $(textOvr)>Deductible</span></td>
                      <td class="inputnmbr"><input name="deductible" type="text" value="$(V_CVDDCT)" size="9" maxlength="9"></td>
                  </tr>
                  @DspErrMsg(Err_CVDDCT)

                  @SetTextOvr(Err_CVCOP1)
                  <tr><td class="dsphdr"><span $(textOvr)>Co-Payment 1</span></td>
                      <td class="inputnmbr"><input name="coPaymentOne" type="text" value="$(V_CVCOP1)" size="9" maxlength="9"></td>
                  </tr>
                  @DspErrMsg(Err_CVCOP1)

                  @SetTextOvr(Err_CVCOP2)
                  <tr><td class="dsphdr"><span $(textOvr)>Co-Payment 2</span></td>
                      <td class="inputnmbr"><input name="coPaymentTwo" type="text" value="$(V_CVCOP2)" size="9" maxlength="9"></td>
                  </tr>
                  @DspErrMsg(Err_CVCOP2)

                  @SetTextOvr(Err_CVCOP3)
                  <tr><td class="dsphdr"><span $(textOvr)>Co-Payment 3</span></td>
                      <td class="inputnmbr"><input name="coPaymentThree" type="text" value="$(V_CVCOP3)" size="9" maxlength="9"></td>
                  </tr>
                  @DspErrMsg(Err_CVCOP3)

                  @SetTextOvr(Err_CVPCKI)
