                      <td class="inputnmbr"><input name="enrollmentperEnd" type="text" value="$(V_CVENEN)" size="6" maxlength="6">
                              <a href="javascript:calWindow('enrollmentperEnd');"> $(calendarImage) </a></td>
                  </tr>
                  @DspErrMsg(Err_CVENEN)

                  @SetTextOvr(Err_CVAUTE)
                  <tr><td class="dsphdr"><span $(textOvr)>Enroll Employees</span></td>
                      @dtw_tb_rows(enrollEmplTable, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(enrollEmplTable, x, "1") != V_CVAUTE) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(enrollEmplTable, "enrollEmpl", "2", "1", "N", "", x, "1") $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_CVAUTE)

                  @SetTextOvr(Err_CVAUTD)
