%INCLUDE "$(baseVar)"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "VarBase.icl"

%Define {	
  d2wName                 = "OrderEntryFeatureOptionUpdate.d2w"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  DTW_HTML_TABLE          = "NO"
%}

%MACRO_FUNCTION Display_SmartPart (IN smartPart) {

        $(smartPart)
        |

%}

%HTML(UPDATE) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_assign(stmtSQL, "")
  @dtw_assign(UpdSP, "")
  @Features_Options_Update(orderControlNumber, lineNumber, UpdSP, V_CIUVCT, smartPart)
  %if (V_CIUSMP == "Y")
      @Display_SmartPart(smartPart)
  %endif
%}

%HTML(UPDATEW) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " $(updateStmt) @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)
%}
