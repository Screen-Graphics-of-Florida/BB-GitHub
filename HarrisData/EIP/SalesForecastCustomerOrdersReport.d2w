%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Sales Forecast/Customer Orders Report"
  page_title1             = " By Plant/Item"
  page_title2             = " By Forecast Type"
  page_title3             = " Consolidated"
  d2wName                 = "SalesForecastCustomerOrdersReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)&amp;reportSel=@dtw_rurlescseq(reportSel)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %if (reportSel == "1")
              @dtw_assign(sortSeqMax, "7")
              @dtw_concat(page_title, page_title1, page_title)
          %elif (reportSel == "2")
              @dtw_assign(sortSeqMax, "7")
              @dtw_concat(page_title, page_title2, page_title)
          %else
              @dtw_assign(sortSeqMax, "4")
              @dtw_concat(page_title, page_title3, page_title)
          %endif
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromPlantNumber, 3, 0) &&
                      editNum(document.Chg.toPlantNumber, 3, 0) &&
                      editNum(document.Chg.fromForecastType, 3, 0) &&
                      editNum(document.Chg.toForecastType, 3, 0) &&
                      editNum(document.Chg.fromForecastYear, 4, 0) &&
                      editNum(document.Chg.toForecastYear, 4, 0) &&
                      editNum(document.Chg.fromBuyerAnalyst, 7, 0) &&
                      editNum(document.Chg.toBuyerAnalyst, 7, 0) &&
                      editdate(document.Chg.fromDate) &&
                      editdate(document.Chg.toDate) &&
                      editFromToAll(document.Chg.fromPlantNumber, document.Chg.toPlantNumber, document.Chg.allPlantNumber, 3) &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      %if (reportSel != "3")
                          editFromToAll(document.Chg.fromForecastType, document.Chg.toForecastType, document.Chg.allForecastType, 3) &&
                          editFromToAll(document.Chg.fromReference, document.Chg.toReference, document.Chg.allReference, "A") &&
                          editFromToAll(document.Chg.fromForecastYear, document.Chg.toForecastYear, document.Chg.allForecastYear, 4) &&
                      %endif
                      editFromToAll(document.Chg.fromBuyerAnalyst, document.Chg.toBuyerAnalyst, document.Chg.allBuyerAnalyst, 7) &&
                      editFromToAll(document.Chg.fromPartType, document.Chg.toPartType, document.Chg.allPartType, "A") &&
                      editFromToAll(document.Chg.fromDate, document.Chg.toDate, document.Chg.allDate, "D")
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "SALESFORECASTREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromPlantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@fplt", "fromPlantNumber")     @dtw_assign(Err_N2FPLT,  fieldValue)
                                  @DecatErr_Field("@@splt", "sortPlantNumber")     @dtw_assign(Err_N2SPLT,  fieldValue)
                                  @DecatErr_Field("@@sitm", "sortItemNumber")      @dtw_assign(Err_N2SITM,  fieldValue)
                                  @DecatErr_Field("@@styp", "sortForecastType")    @dtw_assign(Err_N2STYP,  fieldValue)
                                  @DecatErr_Field("@@sref", "sortReference")       @dtw_assign(Err_N2SREF,  fieldValue)
                                  @DecatErr_Field("@@syr@", "sortForecastYear")    @dtw_assign(Err_N2SYR,   fieldValue)
                                  @DecatErr_Field("@@sbac", "sortBuyerAnalyst")    @dtw_assign(Err_N2SBAC,  fieldValue)
                                  @DecatErr_Field("@@spty", "sortPartType")        @dtw_assign(Err_N2SPTY,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@dmnd")  @dtw_assign(V_N2DMND,  fieldValue)
                                  @Decat_Field("@@hist")  @dtw_assign(V_N2HIST,  fieldValue)
                                  @Decat_Field("@@frmt")  @dtw_assign(V_N2FRMT,  fieldValue)
                                  @Decat_Field("@@per@")  @dtw_assign(V_N2PER,   fieldValue)
                                  @Decat_Field("@@actf")  @dtw_assign(V_N2ACTF,  fieldValue)

                                  @Decat_Field("@@fplt")  @dtw_assign(V_N2FPLT,  fieldValue)
                                  @Decat_Field("@@tplt")  @dtw_assign(V_N2TPLT,  fieldValue)
                                  @Decat_Field("@@aplt")  @dtw_assign(V_N2APLT,  fieldValue)
                                  @Decat_Field("@@splt")  @dtw_assign(V_N2SPLT,  fieldValue)
                                  @Decat_Field("@@pplt")  @dtw_assign(V_N2PPLT,  fieldValue)

                                  @Decat_Field("@@fitm")  @dtw_assign(V_N2FITM,  fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N2TITM,  fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N2AITM,  fieldValue)
                                  @Decat_Field("@@sitm")  @dtw_assign(V_N2SITM,  fieldValue)
                                  @Decat_Field("@@pitm")  @dtw_assign(V_N2PITM,  fieldValue)

                                  @Decat_Field("@@ftyp")  @dtw_assign(V_N2FTYP,  fieldValue)
                                  @Decat_Field("@@ttyp")  @dtw_assign(V_N2TTYP,  fieldValue)
                                  @Decat_Field("@@atyp")  @dtw_assign(V_N2ATYP,  fieldValue)
                                  @Decat_Field("@@styp")  @dtw_assign(V_N2STYP,  fieldValue)
                                  @Decat_Field("@@ptyp")  @dtw_assign(V_N2PTYP,  fieldValue)

                                  @Decat_Field("@@fref")  @dtw_assign(V_N2FREF,  fieldValue)
                                  @Decat_Field("@@tref")  @dtw_assign(V_N2TREF,  fieldValue)
                                  @Decat_Field("@@aref")  @dtw_assign(V_N2AREF,  fieldValue)
                                  @Decat_Field("@@sref")  @dtw_assign(V_N2SREF,  fieldValue)
                                  @Decat_Field("@@pref")  @dtw_assign(V_N2PREF,  fieldValue)

                                  @Decat_Field("@@fyr@")  @dtw_assign(V_N2FYR,  fieldValue)
                                  @Decat_Field("@@tyr@")  @dtw_assign(V_N2TYR,  fieldValue)
                                  @Decat_Field("@@ayr@")  @dtw_assign(V_N2AYR,  fieldValue)
                                  @Decat_Field("@@syr@")  @dtw_assign(V_N2SYR,  fieldValue)
                                  @Decat_Field("@@pyr@")  @dtw_assign(V_N2PYR,  fieldValue)

                                  @Decat_Field("@@fbac")  @dtw_assign(V_N2FBAC,  fieldValue)
                                  @Decat_Field("@@tbac")  @dtw_assign(V_N2TBAC,  fieldValue)
                                  @Decat_Field("@@abac")  @dtw_assign(V_N2ABAC,  fieldValue)
                                  @Decat_Field("@@sbac")  @dtw_assign(V_N2SBAC,  fieldValue)
                                  @Decat_Field("@@pbac")  @dtw_assign(V_N2PBAC,  fieldValue)

                                  @Decat_Field("@@fpty")  @dtw_assign(V_N2FPTY,  fieldValue)
                                  @Decat_Field("@@tpty")  @dtw_assign(V_N2TPTY,  fieldValue)
                                  @Decat_Field("@@apty")  @dtw_assign(V_N2APTY,  fieldValue)
                                  @Decat_Field("@@spty")  @dtw_assign(V_N2SPTY,  fieldValue)
                                  @Decat_Field("@@ppty")  @dtw_assign(V_N2PPTY,  fieldValue)

                                  @Decat_Field("@@fdte")  @dtw_assign(V_N2FDTE,  fieldValue)
                                  @Decat_Field("@@tdte")  @dtw_assign(V_N2TDTE,  fieldValue)
                                  @Decat_Field("@@adte")  @dtw_assign(V_N2ADTE,  fieldValue)

                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}

                                  %if (V_N2DMND == "Y")
                                      @dtw_assign(demandNo, "")
                                      @dtw_assign(demandYes, "CHECKED")
                                  %else
                                      @dtw_assign(demandNo, "CHECKED")
                                      @dtw_assign(demandYes, "")
                                  %endif

                                  %if (V_N2HIST == "Y")
                                      @dtw_assign(historyNo, "")
                                      @dtw_assign(historyYes, "CHECKED")
                                  %else
                                      @dtw_assign(historyNo, "CHECKED")
                                      @dtw_assign(historyYes, "")
                                  %endif

                                  %if (V_N2FRMT == "U")
                                      @dtw_assign(units, "CHECKED")
                                      @dtw_assign(cost, "")
                                      @dtw_assign(list, "")
                                  %elif (V_N2FRMT == "C")
                                      @dtw_assign(units, "")
                                      @dtw_assign(cost, "CHECKED")
                                      @dtw_assign(list, "")
                                  %elif (V_N2FRMT == "L")
                                      @dtw_assign(units, "")
                                      @dtw_assign(cost, "")
                                      @dtw_assign(list, "CHECKED")
                                  %endif

                                  %if (V_N2PER == "W")
                                      @dtw_assign(week, "CHECKED")
                                      @dtw_assign(month, "")
                                      @dtw_assign(quarter, "")
                                  %elif (V_N2PER == "M")
                                      @dtw_assign(week, "")
                                      @dtw_assign(month, "CHECKED")
                                      @dtw_assign(quarter, "")
                                  %elif (V_N2PER == "Q")
                                      @dtw_assign(week, "")
                                      @dtw_assign(month, "")
                                      @dtw_assign(quarter, "CHECKED")
                                  %endif

                                  %if (V_N2ACTF == "A")
                                      @dtw_assign(active, "CHECKED")
                                      @dtw_assign(inactive, "")
                                      @dtw_assign(all, "")
                                  %elif (V_N2ACTF == "I")
                                      @dtw_assign(active, "")
                                      @dtw_assign(inactive, "CHECKED")
                                      @dtw_assign(all, "")
                                  %elif (V_N2ACTF == "X")
                                      @dtw_assign(active, "")
                                      @dtw_assign(inactive, "")
                                      @dtw_assign(all, "CHECKED")
                                  %endif

                                  %if (V_N2APLT == "ALL")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPlantNumber, "")
                                  %endif
                                  %if (V_N2AITM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_N2ATYP == "ALL")
                                      @dtw_assign(checkedallForecastType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallForecastType, "")
                                  %endif
                                  %if (V_N2AREF == "ALL")
                                      @dtw_assign(checkedallReference, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallReference, "")
                                  %endif
                                  %if (V_N2AYR == "ALL")
                                      @dtw_assign(checkedallForecastYear, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallForecastYear, "")
                                  %endif
                                  %if (V_N2ABAC == "ALL")
                                      @dtw_assign(checkedallBuyerAnalyst, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallBuyerAnalyst, "")
                                  %endif
                                  %if (V_N2APTY == "ALL")
                                      @dtw_assign(checkedallPartType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPartType, "")
                                  %endif
                                  %if (V_N2ADTE == "ALL")
                                      @dtw_assign(checkedallDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallDate, "")
                                  %endif

                                  %if (V_N2PPLT == "Y")
                                      @dtw_assign(checkedPlantNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedPlantNumberTotals, "")
                                  %endif
                                  %if (V_N2PITM == "Y")
                                      @dtw_assign(checkedItemNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedItemNumberTotals, "")
                                  %endif
                                  %if (V_N2PTYP == "Y")
                                      @dtw_assign(checkedForecastTypeTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedForecastTypeTotals, "")
                                  %endif
                                  %if (V_N2PREF == "Y")
                                      @dtw_assign(checkedReferenceTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedReferenceTotals, "")
                                  %endif
                                  %if (V_N2PYR == "Y")
                                      @dtw_assign(checkedForecastYearTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedForecastYearTotals, "")
                                  %endif
                                  %if (V_N2PBAC == "Y")
                                      @dtw_assign(checkedBuyerAnalystTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedBuyerAnalystTotals, "")
                                  %endif
                                  %if (V_N2PPTY == "Y")
                                      @dtw_assign(checkedPartTypeTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedPartTypeTotals, "")
                                  %endif
                              %else
                                  @dtw_assign(demandNo, "")
                                  @dtw_assign(demandYes, "CHECKED")
                                  @dtw_assign(historyNo, "CHECKED")
                                  @dtw_assign(historyYes, "")
                                  @dtw_assign(units, "CHECKED")
                                  @dtw_assign(cost, "")
                                  @dtw_assign(list, "")
                                  @dtw_assign(week, "")
                                  @dtw_assign(month, "CHECKED")
                                  @dtw_assign(quarter, "")
                                  @dtw_assign(active, "CHECKED")
                                  @dtw_assign(inactive, "")
                                  @dtw_assign(all, "")

                                  @RtvDftPlant(plantNumber, plantName)
                                  %if (plantNumber == "0")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(V_N2FPLT, plantNumber)
                                      @dtw_assign(V_N2TPLT, plantNumber)
                                      @dtw_assign(checkedallPlantNumber, "")
                                      @dtw_assign(focusField, "fromItemNumber")
                                  %endif
                                  @dtw_assign(checkedallItemNumber,   "CHECKED")
                                  @dtw_assign(V_N2ATYP, "ALL")
                                  @dtw_assign(checkedallForecastType, "CHECKED")
                                  @dtw_assign(V_N2AREF, "ALL")
                                  @dtw_assign(checkedallReference,    "CHECKED")
                                  @dtw_assign(V_N2AYR , "ALL")
                                  @dtw_assign(checkedallForecastYear, "CHECKED")
                                  @dtw_assign(checkedallBuyerAnalyst, "CHECKED")
                                  @dtw_assign(checkedallPartType,     "CHECKED")
                                  @dtw_assign(checkedallDate,         "CHECKED")

                                  %if (reportSel == "1" || reportSel == "3")
                                      @dtw_assign(V_N2SPLT, "1")
                                      @dtw_assign(V_N2SITM, "2")
                                      @dtw_assign(V_N2PPLT, "Y")
                                      @dtw_assign(V_N2PITM, "Y")
                                      @dtw_assign(checkedForecastTypeTotals, "")
                                      @dtw_assign(checkedReferenceTotals,    "")
                                      @dtw_assign(checkedForecastYearTotals, "")
                                  %else
                                      @dtw_assign(V_N2STYP, "1")
                                      @dtw_assign(V_N2SREF, "2")
                                      @dtw_assign(V_N2SYR,  "3")
                                      @dtw_assign(V_N2PTYP, "Y")
                                      @dtw_assign(V_N2PREF, "Y")
                                      @dtw_assign(V_N2PYR , "Y")
                                      @dtw_assign(checkedPlantNumberTotals,  "")
                                      @dtw_assign(checkedItemNumberTotals,   "")
                                  %endif

                                  @dtw_assign(checkedBuyerAnalystTotals, "")
                                  @dtw_assign(checkedPartTypeTotals, "")
                              %endif

                              <tr><td class="dsphdr"><span $(textOvr)>Print Customer Demand </span></td>
                                  <td class="inputcode"><input name="custDemand" type="radio" VALUE='Y' $(demandYes)>Yes</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputcode"><input name="custDemand" type="radio" VALUE='N' $(demandNo)>No</td>
                              </tr>

                              <tr><td class="dsphdr"><span $(textOvr)>Print Sales History </span></td>
                                  <td class="inputcode"><input name="salesHistory" type="radio" VALUE='Y' $(historyYes)>Yes</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputcode"><input name="salesHistory" type="radio" VALUE='N' $(historyNo)>No</td>
                              </tr>

                              <tr><td class="dsphdr"><span $(textOvr)>Display Format</span></td>
                                  <td class="inputcode"><input name="displayFormat" type="radio" VALUE='U' $(units)>Units</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputcode"><input name="displayFormat" type="radio" VALUE='C' $(cost)>Cost</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputcode"><input name="displayFormat" type="radio" VALUE='L' $(list)>List</td>
                              </tr>

                              <tr><td class="dsphdr"><span $(textOvr)>Period Format</span></td>
                                  <td class="inputcode"><input name="periodFormat" type="radio" VALUE='W' $(week)>Weekly</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputcode"><input name="periodFormat" type="radio" VALUE='M' $(month)>Monthly</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputcode"><input name="periodFormat" type="radio" VALUE='Q' $(quarter)>Quarterly</td>
                              </tr>

                              <tr><td class="dsphdr"><span $(textOvr)>Forecast Activity</span></td>
                                  <td class="inputcode"><input name="forecastAct" type="radio" VALUE='A' $(active)>Active</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputcode"><input name="forecastAct" type="radio" VALUE='I' $(inactive)>Inactive</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputcode"><input name="forecastAct" type="radio" VALUE='X' $(all)>All</td>
                              </tr>
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                                  <td class="colhdr">Print<br>Totals</td>
                              </tr>

                              @SetTextOvr(Err_N2FPLT)
                              %if (textOvr == "") @SetTextOvr(Err_N2SPLT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                  <td class="inputnmbr"><input name="fromPlantNumber" value="$(V_N2FPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromPlantNumber&amp;fldDesc=fplantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fplantName"  type="hidden"></td>
                                  <td class="inputnmbr"><input name="toPlantNumber" value="$(V_N2TPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toPlantNumber&amp;fldDesc=tplantName" onclick="$(searchWinVar)">  $(searchImage) </a><input name="tplantName"  type="hidden"></td>
                                  <td class="inputalph"><input name="allPlantNumber" value='ALL' $(checkedallPlantNumber) type="checkbox" onClick="if (this.checked) this.form.fromPlantNumber.value='', this.form.toPlantNumber.value='';"></td>
                                  %if (reportSel == "1" || reportSel == "3")
                                      <td class="colcode"><input name="sortPlantNumber" type="hidden"  Value="$(V_N2SPLT)" size="1" maxlength="1">$(V_N2SPLT)</td>
                                      <td align=center ><input name="totalPlantNumber" type="hidden" Value="$(V_N2PPLT)">$(wfActivityImage)</td>
                                  %else
                                      @Build_Sort_Select("sortPlantNumber", "$(V_N2SPLT)")
                                      <td align=center ><input name="totalPlantNumber" type="checkbox" $(checkedPlantNumberTotals) VALUE='Y'></td>
                                  %endif
                              </tr>
                              @DspErrMsg(Err_N2FPLT)
                              @DspErrMsg(Err_N2SPLT)

                              @SetTextOvr(Err_N2SITM)
                              <tr><td  class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N2FITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N2TITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                                  %if (reportSel == "1" || reportSel == "3")
                                      <td class="colcode"><input name="sortItemNumber" type="hidden"  Value="$(V_N2SITM)" size="1" maxlength="1">$(V_N2SITM)</td>
                                      <td align=center ><input name="totalItemNumber" type="hidden" Value="$(V_N2PITM)">$(wfActivityImage)</td>
                                  %else
                                      @Build_Sort_Select("sortItemNumber", "$(V_N2SITM)")
                                      <td align=center ><input name="totalItemNumber" type="checkbox" $(checkedItemNumberTotals) VALUE='Y'></td>
                                  %endif
                              </tr>
                              @DspErrMsg(Err_N2SITM)

                              @SetTextOvr(Err_N2STYP)
                              <tr><td  class="dsphdr"><span $(textOvr)>Forecast Type</span></td>
                                  %if (reportSel == "3")
                                      <td class="inputnmbr"><input name="fromForecastType" type="hidden" value="$(V_N2FTYP)" size="3" maxlength="3"></td>
                                      <td class="inputnmbr"><input name="toForecastType" type="hidden" value="$(V_N2TTYP)" size="3" maxlength="3"></td>
                                      <td class="inputalph"><input name="allForecastType" type="hidden" Value="$(V_N2ATYP)">$(wfActivityImage)</td>
                                  %else
                                      <td class="inputnmbr"><input name="fromForecastType" value="$(V_N2FTYP)" type="text" size="3" maxlength="3"></td>
                                      <td class="inputnmbr"><input name="toForecastType" value="$(V_N2TTYP)" type="text" size="3" maxlength="3"></td>
                                      <td class="inputalph"><input name="allForecastType" value='ALL' $(checkedallForecastType) type="checkbox" onClick="if (this.checked) this.form.fromForecastType.value='', this.form.toForecastType.value='';"></td>
                                  %endif
                                  %if (reportSel == "1")
                                      @Build_Sort_Select("sortForecastType", "$(V_N2STYP)")
                                      <td align=center ><input name="totalForecastType" type="checkbox" $(checkedForecastTypeTotals) VALUE='Y'></td>
                                  %else
                                      <td class="colcode"><input name="sortForecastType" type="hidden"  Value="$(V_N2STYP)" size="1" maxlength="1">$(V_N2STYP)</td>
                                      <td align=center ><input name="totalForecastType" type="hidden" Value="$(V_N2PTYP)"> %if (reportSel == "2") $(wfActivityImage) %endif </td>
                                  %endif
                              </tr>
                              @DspErrMsg(Err_N2STYP)

                              @SetTextOvr(Err_N2SREF)
                              <tr><td  class="dsphdr"><span $(textOvr)>Reference</span></td>
                                  %if (reportSel == "3")
                                      <td class="inputalph"><input name="fromReference" type="hidden" value="$(V_N2FREF)" size="8" maxlength="8"></td>
                                      <td class="inputalph"><input name="toReference" type="hidden" value="$(V_N2TREF)" size="8" maxlength="8"></td>
                                      <td class="inputalph"><input name="allReference" type="hidden"  Value="$(V_N2AREF)">$(wfActivityImage)</td>
                                  %else
                                      <td class="inputalph"><input name="fromReference" value="$(V_N2FREF)" type="text" size="8" maxlength="8"></td>
                                      <td class="inputalph"><input name="toReference" value="$(V_N2TREF)" type="text" size="8" maxlength="8"></td>
                                      <td class="inputalph"><input name="allReference" value='ALL' $(checkedallReference) type="checkbox" onClick="if (this.checked) this.form.fromReference.value='', this.form.toReference.value='';"></td>
                                  %endif
                                  %if (reportSel == "1")
                                      @Build_Sort_Select("sortReference", "$(V_N2SREF)")
                                      <td align=center ><input name="totalReference" type="checkbox" $(checkedReferenceTotals) VALUE='Y'></td>
                                  %else
                                      <td class="colcode"><input name="sortReference" type="hidden"  Value="$(V_N2SREF)" size="1" maxlength="1">$(V_N2SREF)</td>
                                      <td align=center ><input name="totalReference" type="hidden" Value="$(V_N2PREF)"> %if (reportSel == "2") $(wfActivityImage) %endif </td>
                                  %endif
                              </tr>
                              @DspErrMsg(Err_N2SREF)

                              @SetTextOvr(Err_N2SYR)
                              <tr><td  class="dsphdr"><span $(textOvr)>Forecast Year</span></td>
                                  %if (reportSel == "3")
                                      <td class="inputnmbr"><input name="fromForecastYear" type="hidden" value="$(V_N2FYR)" size="4" maxlength="4"></td>
                                      <td class="inputnmbr"><input name="toForecastYear" type="hidden" value="$(V_N2TYR)" size="4" maxlength="4"></td>
                                      <td class="inputalph"><input name="allForecastYear" type="hidden"  Value="$(V_N2AYR)">$(wfActivityImage)</td>
                                  %else
                                      <td class="inputnmbr"><input name="fromForecastYear" value="$(V_N2FYR)" type="text" size="4" maxlength="4"></td>
                                      <td class="inputnmbr"><input name="toForecastYear" value="$(V_N2TYR)" type="text" size="4" maxlength="4"></td>
                                      <td class="inputalph"><input name="allForecastYear" value='ALL' $(checkedallForecastYear) type="checkbox" onClick="if (this.checked) this.form.fromForecastYear.value='', this.form.toForecastYear.value='';"></td>
                                  %endif
                                  %if (reportSel == "1")
                                      @Build_Sort_Select("sortForecastYear", "$(V_N2SYR)")
                                      <td align=center ><input name="totalForecastYear" type="checkbox" $(checkedForecastYearTotals) VALUE='Y'></td>
                                  %else
                                      <td class="colcode"><input name="sortForecastYear" type="hidden"  Value="$(V_N2SYR)" size="1" maxlength="1">$(V_N2SYR)</td>
                                      <td align=center ><input name="totalForecastYear" type="hidden" Value="$(V_N2PYR)"> %if (reportSel == "2") $(wfActivityImage) %endif </td>
                                  %endif
                              </tr>
                              @DspErrMsg(Err_N2SYR)

                              @SetTextOvr(Err_N2SBAC)
                              <tr><td  class="dsphdr"><span $(textOvr)>Buyer/Analyst</span></td>
                                  <td class="inputnmbr"><input name="fromBuyerAnalyst" value="$(V_N2FBAC)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)BuyerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromBuyerAnalyst&amp;fldDesc=fanalystName&amp;buyerAnalyst=Analyst" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fanalystName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toBuyerAnalyst" value="$(V_N2TBAC)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)BuyerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toBuyerAnalyst&amp;fldDesc=tanalystName&amp;buyerAnalyst=Analyst" onclick="$(searchWinVar)"> $(searchImage) </a><input name="tanalystName" type="hidden"></td>
                                  <td class="inputalph"><input name="allBuyerAnalyst" value='ALL' $(checkedallBuyerAnalyst) type="checkbox" onClick="if (this.checked) this.form.fromBuyerAnalyst.value='', this.form.toBuyerAnalyst.value='';"></td>
                                  @Build_Sort_Select("sortBuyerAnalyst", "$(V_N2SBAC)")
                                  <td align=center ><input name="totalBuyerAnalyst" type="checkbox" $(checkedBuyerAnalystTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2SBAC)

                              @SetTextOvr(Err_N2SPTY)
                              <tr><td  class="dsphdr"><span $(textOvr)>Part Type</span></td>
                                  <td class="inputalph"><input name="fromPartType" value="$(V_N2FPTY)" type="text" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=PARTTYPE&amp;flagSrchHdr=@dtw_rurlescseq("Part Type")&amp;docName=Chg&amp;fldName=fromPartType&amp;fldDesc=fPartTypeDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fPartTypeDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="toPartType" value="$(V_N2TPTY)" type="text" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=PARTTYPE&amp;flagSrchHdr=@dtw_rurlescseq("Part Type")&amp;docName=Chg&amp;fldName=toPartType&amp;fldDesc=tPartTypeDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="tPartTypeDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allPartType" value='ALL' $(checkedallPartType) type="checkbox" onClick="if (this.checked) this.form.fromPartType.value='', this.form.toPartType.value='';"></td>
                                  @Build_Sort_Select("sortPartType", "$(V_N2SPTY)")
                                  <td align=center ><input name="totalPartType" type="checkbox" $(checkedPartTypeTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2SPTY)

                              <tr><td class="dsphdr">Date Range</td>
                                  <td class="inputnmbr"><input name="fromDate" value="$(V_N2FDTE)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toDate" value="$(V_N2TDTE)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allDate" value='ALL' $(checkedallDate) type="checkbox" onClick="if (this.checked) this.form.fromDate.value='', this.form.toDate.value='';"></td>
                              </tr>

                          </table>

                          @dtw_assign(envProgram, "HMS120")
                          @dtw_assign(envPrinter, "HMS120PF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HMSSFS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(SELECT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "SALESFORECASTREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      <table $(contentTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1>$(page_title)</h1></td>
                              <td class="toolbar">
                                  %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                                      <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                                  %endif
                                  %INCLUDE "HelpPage.icl"
                              </td>
                          </tr>
                      </table>
                      $(hrTagAttr)

                      <form class="formClass" METHOD=POST name=Select ACTION="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)">
                          <table $(contentTable)>
                              <tr><td class="dsphdr">Report Selection</td>
                                  <td class="inputcode"><input onClick="javascript:document.Select.submit()" name="reportSel" type="radio" VALUE='1'> By Plant/Item </td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputcode"><input onClick="javascript:document.Select.submit()" name="reportSel" type="radio" VALUE='2'> By Forecast Type </td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputcode"><input onClick="javascript:document.Select.submit()" name="reportSel" type="radio" VALUE='3'> Consolidated </td>
                              </tr>
                          </table>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allPlantNumber)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(allForecastType)
  @dtw_mUPPERCASE(fromReference)
  @dtw_mUPPERCASE(toReference)
  @dtw_mUPPERCASE(allReference)
  @dtw_mUPPERCASE(allForecastYear)
  @dtw_mUPPERCASE(allBuyerAnalyst)
  @dtw_mUPPERCASE(fromPartType)
  @dtw_mUPPERCASE(toPartType)
  @dtw_mUPPERCASE(allPartType)
  @dtw_mUPPERCASE(allDate)

  @dtw_assign(fromPlantNumber,@dtw_rstrip(fromPlantNumber))
  @dtw_assign(toPlantNumber,@dtw_rstrip(toPlantNumber))
  @dtw_assign(sortPlantNumber,@dtw_rstrip(sortPlantNumber))
  @dtw_assign(sortItemNumber,@dtw_rstrip(sortItemNumber))
  @dtw_assign(fromForecastType,@dtw_rstrip(fromForecastType))
  @dtw_assign(toForecastType,@dtw_rstrip(toForecastType))
  @dtw_assign(sortForecastType,@dtw_rstrip(sortForecastType))
  @dtw_assign(sortReference,@dtw_rstrip(sortReference))
  @dtw_assign(fromForecastYear,@dtw_rstrip(fromForecastYear))
  @dtw_assign(toForecastYear,@dtw_rstrip(toForecastYear))
  @dtw_assign(sortForecastYear,@dtw_rstrip(sortForecastYear))
  @dtw_assign(fromBuyerAnalyst,@dtw_rstrip(fromBuyerAnalyst))
  @dtw_assign(toBuyerAnalyst,@dtw_rstrip(toBuyerAnalyst))
  @dtw_assign(sortBuyerAnalyst,@dtw_rstrip(sortBuyerAnalyst))
  @dtw_assign(sortPartType,@dtw_rstrip(sortPartType))
  @dtw_assign(fromDate,@dtw_rstrip(fromDate))
  @dtw_assign(toDate,@dtw_rstrip(toDate))

  %if (allPlantNumber != "ALL")
      @dtw_assign(allPlantNumber, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allForecastType != "ALL")
      @dtw_assign(allForecastType, "")
  %endif
  %if (allReference != "ALL")
      @dtw_assign(allReference, "")
  %endif
  %if (allForecastYear != "ALL")
      @dtw_assign(allForecastYear, "")
  %endif
  %if (allBuyerAnalyst != "ALL")
      @dtw_assign(allBuyerAnalyst, "")
  %endif
  %if (allPartType != "ALL")
      @dtw_assign(allPartType, "")
  %endif
  %if (allDate != "ALL")
      @dtw_assign(allDate, "")
  %endif

  %if (totalPlantNumber != "Y")
      @dtw_assign(totalPlantNumber, "N")
  %endif
  %if (totalItemNumber != "Y")
      @dtw_assign(totalItemNumber, "N")
  %endif
  %if (totalForecastType != "Y")
      @dtw_assign(totalForecastType, "N")
  %endif
  %if (totalReference != "Y")
      @dtw_assign(totalReference, "N")
  %endif
  %if (totalForecastYear != "Y")
      @dtw_assign(totalForecastYear, "N")
  %endif
  %if (totalBuyerAnalyst != "Y")
      @dtw_assign(totalBuyerAnalyst, "N")
  %endif
  %if (totalPartType != "Y")
      @dtw_assign(totalPartType, "N")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@sel@", reportSel)
  @Concat_Field("@@dmnd", custDemand)
  @Concat_Field("@@hist", salesHistory)
  @Concat_Field("@@frmt", displayFormat)
  @Concat_Field("@@per@", periodFormat)
  @Concat_Field("@@actf", forecastAct)

  @Concat_Field("@@fplt", fromPlantNumber)
  @Concat_Field("@@tplt", toPlantNumber)
  @Concat_Field("@@aplt", allPlantNumber)
  @Concat_Field("@@splt", sortPlantNumber)
  @Concat_Field("@@pplt", totalPlantNumber)

  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@sitm", sortItemNumber)
  @Concat_Field("@@pitm", totalItemNumber)

  @Concat_Field("@@ftyp", fromForecastType)
  @Concat_Field("@@ttyp", toForecastType)
  @Concat_Field("@@atyp", allForecastType)
  @Concat_Field("@@styp", sortForecastType)
  @Concat_Field("@@ptyp", totalForecastType)

  @Concat_Field("@@fref", fromReference)
  @Concat_Field("@@tref", toReference)
  @Concat_Field("@@aref", allReference)
  @Concat_Field("@@sref", sortReference)
  @Concat_Field("@@pref", totalReference)

  @Concat_Field("@@fyr@", fromForecastYear)
  @Concat_Field("@@tyr@", toForecastYear)
  @Concat_Field("@@ayr@", allForecastYear)
  @Concat_Field("@@syr@", sortForecastYear)
  @Concat_Field("@@pyr@", totalForecastYear)

  @Concat_Field("@@fbac", fromBuyerAnalyst)
  @Concat_Field("@@tbac", toBuyerAnalyst)
  @Concat_Field("@@abac", allBuyerAnalyst)
  @Concat_Field("@@sbac", sortBuyerAnalyst)
  @Concat_Field("@@pbac", totalBuyerAnalyst)

  @Concat_Field("@@fpty", fromPartType)
  @Concat_Field("@@tpty", toPartType)
  @Concat_Field("@@apty", allPartType)
  @Concat_Field("@@spty", sortPartType)
  @Concat_Field("@@ppty", totalPartType)

  @Concat_Field("@@fdte", fromDate)
  @Concat_Field("@@tdte", toDate)
  @Concat_Field("@@adte", allDate)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}