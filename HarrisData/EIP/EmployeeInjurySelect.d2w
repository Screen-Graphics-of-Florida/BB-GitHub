%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "QuickLink.icl"

%Define {
  page_title 	        = "Injury/Illness"
  page_title_301       = "Form 301 - Injury/Illness Report"
  d2wName              = "EmployeeInjurySelect.d2w"
  attachFolder         = "EmployeeInjury"
  d2wVarBase           = "$(genericVarBase)$(employeeVarBase)&amp;caseNumber=@dtw_rurlescseq(caseNumber)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(d2wName)"
  programName          = "HPEIIM"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  RPT_MAX_ROWS         = "999"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext	        = "1"
  totalPages	        = "0"	
  sec_06               = ""
  showError            = "N"
  quickLinkByUser         = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
   @dtw_replace(workURL, "@@caseNumber", "@dtw_rurlescseq(caseNumber)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @dtw_assign(applicationID, "PR")
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                       @dtw_assign(pageID, "EMPLOYEEINJR")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">

                      @dtw_assign(uv_CompanyName, "EMCOMP")
                      @dtw_assign(uv_FacilityName, "EMFACL")
                      @dtw_assign(uv_PREmployeeName, "EMEMPL")
                      @dtw_assign(uv_HRCompanyName, "EMPECP")
                      @dtw_assign(uv_HREmployeeName, "EMPEMP")
                      @dtw_assign(uv_HomeDepartmentName, "INDEPT")
                      @dtw_assign(uv_HRLocationName, "INLOC")
                      @dtw_assign(uv_PayTypeName, "EMTYPE")
                      %INCLUDE "userview.icl"

%{ QuickLink Table %}     %INCLUDE "QuickLinkTable.icl"

%{ QuickLink By User %}   %INCLUDE "QuickLinkByUser.icl"

%{ Injury Illness Heading %}
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " PEINJR inner join HREMPL on INCOMP=EMPECP and INEMPL=EMPEMP ", fileSQL)
                      @dtw_concat(selectSQL, " INCOMP=$(hrCompany) and INEMPL=$(hrEmployee) and INCASE=$(caseNumber) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @InjIll_Select_Header(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Begin %}     %INCLUDE "QuickLinkBegLoop.icl"

    %{ injillinformation %}
                          %if (quicklinkRef == "injillinformation")
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                              @dtw_concat(fileSQL, " PEINJR inner join HREMPL on INCOMP=EMPECP and INEMPL=EMPEMP ", fileSQL)
                              @dtw_concat(selectSQL, " INCOMP=$(hrCompany) and INEMPL=$(hrEmployee) and INCASE=$(caseNumber) ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %INCLUDE "stmtSQLEnd.icl"
                              @InjIll_Select_Information(profileHandle, dataBaseID, stmtSQL)

    %{ injillbefore %}
                          %elif (quicklinkRef == "injillbefore")
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, "SELECT * ", stmtSQL)
                              @dtw_concat(fileSQL, " PEICM1 ", fileSQL)
                              @dtw_concat(selectSQL, " IBCOMP=$(hrCompany) and IBEMPL=$(hrEmployee) and IBCASE=$(caseNumber)", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @InjIll_Select_Before(profileHandle, dataBaseID, stmtSQL)

    %{ injilldescribe %}
                          %elif (quicklinkRef == "injilldescribe")
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                              @dtw_concat(fileSQL, " PEICM2 ", fileSQL)
                              @dtw_concat(selectSQL, " IDCOMP=$(hrCompany) and IDEMPL=$(hrEmployee) and IDCASE=$(caseNumber)", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @InjIll_Select_Describe(profileHandle, dataBaseID, stmtSQL)

    %{ injillafter %}
                          %elif (quicklinkRef == "injillafter")
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                              @dtw_concat(fileSQL, " PEICM3 ", fileSQL)
                              @dtw_concat(selectSQL, " IACOMP=$(hrCompany) and IAEMPL=$(hrEmployee) and IACASE=$(caseNumber)", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @InjIll_Select_After(profileHandle, dataBaseID, stmtSQL)
                          %endif

    %{ Attachments %}     %INCLUDE "AttachmentSQL.icl"

%{ Quicklink End %}       %INCLUDE "QuickLinkEndLoop.icl"

                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) InjIll_Select_Header (IN CHAR(64)    profileHandle,
				             CHAR(2)     dataBaseID,
                                            CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_tb_setcols(quicklinkSeqTable, "5")

      %if ((sql_Record_Count == "0") || (V_INPRVT == "Y" && sec_06 == "N"))
          @Remove_Quick_Link("INJILLINFORMATION")
          @Remove_Quick_Link("INJILLBEFORE")
          @Remove_Quick_Link("INJILLDESCRIBE")
          @Remove_Quick_Link("INJILLAFTER")
          @Remove_Quick_Link("INJILLCOMMENTS")
          @Remove_Quick_Link("ATTACHMENTS")
          %INCLUDE "ProgSecurityError.icl"
      %elif (formatToPrint == "3")
          @Remove_Quick_Link("INJILLAFTER")
          @Remove_Quick_Link("ATTACHMENTS")
      %endif

      %ROW {
          @Ret_Format_EmplName(UVPRCo, UVPRFa, UVPREmpl, hrCompany, hrEmployee, "H", F_EmpName)
          %if (V_INPRVT != "Y" || sec_06 == "Y")
              <table $(contentTable)>
                  <colgroup>
                      <col width="80%">
                      <col width="15%">

                  %if (formatToPrint == "3")
                      <tr><td><h1>$(page_title_301)</h1></td>
                  %else
                      <tr><td><h1>$(page_title)</h1></td>
                  %endif
                      @dtw_assign(caseNumberFilled, "$(caseNumber)")
                      %while(@dtw_rlength(caseNumberFilled) != "4") {@dtw_insert("0", caseNumberFilled, caseNumberFilled)%}
                      @dtw_assign(attVar, "$(caseNumberFilled)")
                      %INCLUDE "emplAttachment.icl"
                      @dtw_assign(attachForDesc, "$(F_EmpName) Case Number $(caseNumber)")
                      @dtw_assign(attachPrg1, "HREMPL inner join PEINJR on EMCOMP=INCOMP and EMFACL=INFACL and EMEMPL=INEMPL Where EMEMID=$(employeeID) and INCASE=$(caseNumber)")

                      %if (formatToPrint == "")
                          <td class="toolbar">
                              %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                                  <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Return To Employee">$(portalHome)</a>
                              %endif
                              %INCLUDE "Attachment.icl"
                              %INCLUDE "FormatToPrint.icl"
                              <a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;formatToPrint=3" target=_blank>$(form301)</a>
                              %INCLUDE "HelpPage.icl"
                          </td>
                      %endif
                  </tr>

                  <tr><td><h2>$(F_EmpName)</h2></td></tr>
              </table>
          %endif
          %INCLUDE "ConfMessageDisplay.icl"
          $(hrTagAttr)
          %INCLUDE "QuickLinkDisplay.icl"
      %}
  %}
%}

%FUNCTION(dtw_sql) InjIll_Select_Information (IN  CHAR(64)    profileHandle,
				                   CHAR(2)     dataBaseID,
                                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="injillinformation"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %ROW{
              %if(V_INPRVT == "Y")
                  <tr><th class="dsphdr"> <br>WARNING - PRIVACY CASE</th></tr>
              %endif

              <tr><td class="dsphdr">Case Number</td>
                  <td class="dspalph">$(V_INCASE)</td>
              </tr>
              <tr><td class="dsphdr">Location</td>
                  @RtvFldDesc("ODCOMP=$(V_INCOMP) and ODTYPE='O' and ODCODE='$(V_INLOC)' ", "PECODE", "ODDESC", CodeDesc)
                  @Format_Code(V_INLOC, F_INLOC)
                  <td class="dspalph">$(CodeDesc)</td>
                  <td class="dspalph">$(F_INLOC)</td>
              </tr>
              <tr><td class="dsphdr">Department</td>
                  @RtvFldDesc("EADEPT='$(V_INDEPT)' ", "PREXAC", "EANAME", deptName)
                  @Format_Code(V_INDEPT, F_INDEPT)
                  <td class="dspalph">$(deptName)</td>
                  <td class="dspalph">$(F_INDEPT)</td>
              </tr>
              <tr><td class="dsphdr">Job Code</td>
                  @RtvFldDesc("ODCOMP=$(V_INCOMP) and ODTYPE='J' and ODCODE='$(V_INJOB)' ", "PECODE", "ODDESC", CodeDesc)
                  @Format_Code(V_INJOB, F_INJOB)
                  <td class="dspalph">$(CodeDesc)</td>
                  <td class="dspalph">$(F_INJOB)</td>
              </tr>
              <tr><td class="dsphdr">OSHA Reportable</td>
                  @RtvYNDesc($(V_INOSHA), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Privacy Case</td>
                  @RtvYNDesc($(V_INPRVT), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Date Employer Notfied</td>
                  @Format_Date(V_INDNOT, "H", F_INDNOT)
                  <td class="dspdate">$(F_INDNOT)</td>
              </tr>
              <tr><td class="dsphdr">Date Of Injury/Illness</td>
                  @Format_Date(V_ININDT, "H", F_ININDT)
                  <td class="dspdate">$(F_ININDT)</td>
              </tr>
              <tr><td class="dsphdr">Time Of Injury/Illness</td>
                  %if(V_INTMAP == "A")
                      @dtw_assign(timeAMPM, "AM")
                  %elif(V_INTMAP == "P")
                      @dtw_assign(timeAMPM, "PM")
                  %else
                      @dtw_assign(timeAMPM, "")
                  %endif
                  %if(V_INTIME != "0")
                      @EditHrsMin(V_INTIME)
                      <td class="dspalph">$(V_INTIME) &nbsp; $(timeAMPM)</td>
                  %else
                      <td class="dspalph">Time Cannot Be Determined</td>
                  %endif
              </tr>
              %if(V_INSTAP == "A")
                  @dtw_assign(startAMPM, "AM")
              %elif(V_INSTAP == "P")
                  @dtw_assign(startAMPM, "PM")
              %else
                  @dtw_assign(startAMPM, "")
              %endif
              <tr><td class="dsphdr">Time Employee Started Work</td>
                  @EditHrsMin(V_INSTRT)
                  <td class="dspalph">$(V_INSTRT) &nbsp; $(startAMPM)</td>
              </tr>
              <tr><td class="dsphdr">Where Event Occurred</td>
                  <td class="dspalph">$(V_INWHER)</td>
              </tr>
              <tr><td class="dsphdr">Injury/Type Of Illness</td>
                  @dtw_assign(cyy, "@dtw_rsubstr(V_ININDT, "1", "3")")
                  %if(cyy >= "104")
                      @dtw_assign(injIllYear, "2004")
                  %else
                      @dtw_assign(injIllYear, "2002")
                  %endif
                  @RtvFldDesc("IIYEAR=$(injIllYear) and IITYPE='$(V_INIITY)'", "PEIITY", "IIDESC", transDesc)
                  @Format_Code(V_INIITY, F_INIITY)
                  <td class="dspalph"> $(transDesc)</td>
                  <td class="dspalph">$(F_INIITY)</td>
              </tr>
              <tr><td class="dsphdr">Injured Body Part</td>
                  @RtvFldDesc("ODCOMP=$(V_INCOMP) and ODTYPE='X' and ODCODE='$(V_INIBP)' ", "PECODE", "ODDESC", IBPDesc)
                  @Format_Code(V_INIBP, F_INIBP)
                  <td class="dspalph">$(IBPDesc)</td>
                  <td class="dspalph">$(F_INIBP)</td>
              </tr>
              <tr><td class="dsphdr">Cause</td>
                  @RtvFldDesc("ODCOMP=$(V_INCOMP) and ODTYPE='F' and ODCODE='$(V_INCAUS)' ", "PECODE", "ODDESC", CauseDesc)
                  @Format_Code(V_INCAUS, F_INCAUS)
                  <td class="dspalph">$(CauseDesc)</td>
                  <td class="dspalph">$(F_INCAUS)</td>
              </tr>
              <tr><td class="dsphdr">Description 1</td>
                  <td class="dspalph">$(V_INDESC)</td>
              </tr>
              %if(V_INDSC2 != "")
                  <tr><td class="dsphdr">Description 2</td>
                      <td class="dspalph">$(V_INDSC2)</td>
                  </tr>
              %endif
              <tr><td class="dsphdr">Job Title</td>
                  <td class="dspalph">$(V_INTITL)</td>
              </tr>
              <tr><td class="dsphdr">Days Transferred/Resticted</td>
                  <td class="dspalph"> $(V_INNDR)</td>
              </tr>
              <tr><td class="dsphdr">Days Away</td>
                  <td class="dspalph">$(V_INNDO)</td>
              </tr>
              %if(V_INDOD != "0" || formatToPrint == "3")
                  @Format_Date(V_INDOD, "H", F_INDOD)
                  <tr><td class="dsphdr">Date Of Death</td>
                      <td class="dspdate">$(F_INDOD)</td>
                  </tr>
              %endif
              @Format_Date(V_INEFF, "H", F_INEFF)
              <tr><td class="dsphdr">Injury Effective Date</td>
                  <td class="dspdate">$(F_INEFF)</td>
              </tr>
              <tr><td class="dsphdr">Return Date</td>
                   @Format_Date(V_INRET, "H", F_INRET)
                  <td class="dspdate">$(F_INRET)</td>
              </tr>
              <tr><td class="dsphdr">Name Of Physician</td>
                  <td class="dspalph">$(V_INPHYS)</td>
              </tr>
              <tr><td class="dsphdr">Treated In Emergency Room</td>
                  @RtvYNDesc($(V_INEMRG), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Hospitalized Overnight</td>
                  @RtvYNDesc($(V_INHOSP), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              %if(V_INTRFA != ""  || formatToPrint == "3")
                  <tr><td class="dsphdr">Where Was Treatment Given</td>
                       <td class="dspalph">$(V_INTRFA)</td>
                  </tr>
                  <tr><td class="dsphdr"> </td>
                       <td class="dspalph">$(V_INTRAD)</td>
                  </tr>
                  <tr><td class="dsphdr"> </td>
                      %if(V_INTRCT != "")
                           <td class="dspalph">$(V_INTRCT) &nbsp; $(V_INTRST), &nbsp; $(V_INTRZP)</td>
                      %endif
                  </tr>
              %endif
              <tr><td class="dsphdr">Form 301 Completed By</td>
                  <td class="dspalph">$(V_INCBNM)</td>
              </tr>
              <tr><td class="dsphdr"> </td>
                  <td class="dspalph">$(V_INCBTL)</td>
              </tr>
              <tr><td class="dsphdr"> </td>
                  @EditPhoneNumber(V_INCBPH)
                  <td class="dspalph">$(V_INCBPH)</td>
              </tr>
              <tr><td class="dsphdr"> </td>
                  @Format_Date(V_INCBDT, "H", F_INCBDT)
                  <td class="dspdate">$(F_INCBDT)</td>
              </tr>
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) InjIll_Select_Before (IN  CHAR(64)    profileHandle,
				              CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="injillbefore"></a>
      @dtw_assign(displayMaxRowsMsg, "Y")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          <tr><td class="colalph">What was the employee doing just before the incident occurred?</td></tr>
          <tr><td class="dspalph">&nbsp;</td></tr>

          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %endif

          %ROW {
	       <tr><td class="colalph">$(V_IBDESC)</td></tr>
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) InjIll_Select_Describe (IN  CHAR(64)    profileHandle,
				                CHAR(2)     dataBaseID,
                                               CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="injilldescribe"></a>
      @dtw_assign(displayMaxRowsMsg, "Y")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          <tr><td class="colalph">What happened?  Tell how the injury/illness occurred.</td></tr>
              <tr><td class="dspalph">&nbsp;</td></tr>

          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %endif

          %ROW {
	       <tr><td class="colalph">$(V_IDDESC)</td></tr>
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) InjIll_Select_After (IN CHAR(64)    profileHandle,
				            CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

      %REPORT{
      <a name="injillafter"></a>
      @dtw_assign(displayMaxRowsMsg, "Y")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %endif

          %ROW {
	       <tr><td class="colalph">$(V_IADESC)</td></tr>
          %}	
      </table>
      </fieldset>
  %}
%}

%INCLUDE "AttachmentSelect.icl"

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
  %}