%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "EIP Icons Maintenance"
  d2wName                 = "EIPIconsMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fileName=@dtw_rurlescseq(fileName)&amp;fileNameU=@dtw_rurlescseq(fileNameU)&amp;fileNameDesc=@dtw_rurlescseq(fileNameDesc)&amp;resvRec=@dtw_rurlescseq(resvRec)&amp;updRecNbr=@dtw_rurlescseq(updRecNbr)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;iconName=@dtw_rurlescseq(iconName)&amp;iconNameU=@dtw_rurlescseq(iconNameU)&amp;maintenanceCode=D"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  programName             = "HSYECH_E"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.iconName.value =="")
                     {alert("$(reqFieldError)"); return false;}
                     return true;
                  }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "EIPICONMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From SYICON ", stmtSQL)
                          @dtw_concat(stmtSQL, "Where EIFILEU='$(fileNameU)' and EIICONU='$(iconNameU)' ", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (resvRec == "Y")
          @dtw_assign(sec_03, "N")
      %endif
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          @Format_Header("Table", $(fileNameDesc), $(fileName))
      </table>
      $(hrTagAttr)
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" NAME="Chg" METHOD=POST ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "iconName")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@icon", "iconName")          @dtw_assign(Err_EIICON, fieldValue)
                          @DecatErr_Field("@@imgn", "iconImage")         @dtw_assign(Err_EIIMGN, fieldValue)
                          @DecatErr_Field("@@titl", "iconTitle")         @dtw_assign(Err_EITITL, fieldValue)
                          @DecatErr_Field("@@altt", "iconAltText")       @dtw_assign(Err_EIALTT, fieldValue)
                      %endif

                      @Decat_Field("@@icon")   @dtw_assign(V_EIICON, fieldValue)
                      @Decat_Field("@@imgn")   @dtw_assign(V_EIIMGN, fieldValue)
                      @Decat_Field("@@titl")   @dtw_assign(V_EITITL, fieldValue)
                      @Decat_Field("@@altt")   @dtw_assign(V_EIALTT, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "iconName")
                      %endif
                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_EDFILE,  "")
                      @dtw_assign(focusField, "iconName")
                  %else
                      @dtw_assign(focusField, "iconImage")
                  %endif

                  @SetTextOvr(Err_EIICON)
    	           <tr><td class="dsphdr"><span $(textOvr)>Icon Name</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="iconName" type="text" value="$(V_EIICON)" size="50" maxlength="50"> $(reqFieldChar)</td>
                      %else
                          <td class="inputalph"><input name="iconName" type="hidden" value="$(V_EIICON)" size="50" maxlength="50">$(V_EIICON)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_EIICON)

                  @SetTextOvr(Err_EIIMGN)
    	           <tr><td class="dsphdr"><span $(textOvr)>Image</span></td>
                      <td class="inputalph"><input name="iconImage" type="text" value="$(V_EIIMGN)" size="50" maxlength="50"></td>
                  </tr>
                  @DspErrMsg(Err_EIIMGN)

                  @SetTextOvr(Err_EITITL)
    	           <tr><td class="dsphdr"><span $(textOvr)>Title</span></td>
                      <td class="inputalph"><input name="iconTitle" type="text" value="$(V_EITITL)" size="100" maxlength="3000"></td>
                  </tr>
                  @DspErrMsg(Err_EITITL)

                  @SetTextOvr(Err_EIALTT)
    	           <tr><td class="dsphdr"><span $(textOvr)>Alternate Text</span></td>
                      <td class="inputalph"><input name="iconAltText" type="text" value="$(V_EIALTT)" size="50" maxlength="50"></td>
                  </tr>
                  @DspErrMsg(Err_EIALTT)
              %}
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSYECI_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_replace(iconTitle, "<", "&lt;", "1", "a", iconTitle)
  @dtw_replace(iconTitle, ">", "&gt;", "1", "a", iconTitle)
  @dtw_replace(iconTitle, """", "&quot;", "1", "a", iconTitle)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@file", fileNameU)
  @Concat_Field("@@icon", iconName)
  @Concat_Field("@@imgn", iconImage)
  @Concat_Field("@@titl", iconTitle)
  @Concat_Field("@@altt", iconAltText)
  @Concat_Field("@@user", userProfile)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, "Icon Name", "$(iconName)", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)EIPIcons.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;iconNameU=@dtw_rurlescseq(iconNameU)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
