%INCLUDE "BaseConfiguration.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Select Environment"
  d2wName                 = "SignonSelect.d2w"
  d2wVarBase              = "?baseVar=@dtw_rurlescseq(baseVar)"
  nextPrevVar             = "$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="menu">&nbsp;</td>
                  <td class="content">
                      @dtw_assign(perPos, @dtw_rlastpos(".", pgmLibrary))
                      @dtw_assign(fromLibrary, @dtw_rsubstr(pgmLibrary, "1", @dtw_rsubtract(perPos, "1")))
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select DBDBID, DBBSVN, DBDBDS, upper(DBDBDS) as DBDBDSU ", stmtSQL)
                      @dtw_concat(fileSQL, " $(fromLibrary)/SYDBID ", fileSQL)
                      @dtw_concat(selectSQL, "DBBSVN>' ' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Signon_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Signon_Query (IN CHAR(64)    profileHandle,
                                    CHAR(2)     dataBaseID,
                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count != "1")
          %INCLUDE "PageTitle.icl"
          $(hrTagAttr)

              <table $(contentTable)>
                  <tr><td>  %INCLUDE "AssignPageValue.icl" </td></tr>
              </table>
          %endif

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("DBDBID", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DBID" title="Sequence By Database ID"> DBID</a></th>
                  @OrderBy_Sort("DBDBDSU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description"> Description</a></th>
                  @OrderBy_Sort("DBBSVN", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Base" title="Sequence By Base Variable Name"> Base Variable Name</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
          %ROW{
              %if (sql_Record_Count == "1")
                  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)SignonEntry.d2w/SELECT?baseVar=@dtw_rurlescseq(baseVar)">
              %else
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colalph">$(V_DBDBID)</a></td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)SignonEntry.d2w/SELECT?baseVar=@dtw_rurlescseq(V_DBBSVN)" title="Select Environment">$(V_DBDBDS)</a></td>
                      <td class="colalph">$(V_DBBSVN)</a></td>
                  </tr>
              %endif
          %}
      </table>
      %if (sql_Record_Count != "1")
          %INCLUDE "PageBottom.icl"
          $(hrTagAttr)
          %INCLUDE "Copyright.icl"
      %endif
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(orderBy, "DBDBID")
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %if (sequence == "DBID")
      @DTW_ASSIGN(orderBy, "DBDBID")
  %elseif (sequence == "Desc")
      @DTW_ASSIGN(orderBy, "DBDBDSU")
  %elseif (sequence == "Base")
      @DTW_ASSIGN(orderBy, "DBBSVN")
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}
