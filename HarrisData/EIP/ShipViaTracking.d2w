%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Tracking.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Ship Via Tracking"
  d2wName                 = "ShipViaTracking.d2w"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_Tracking_URL(shipVia, trackingBy, trackDftRef, trackDftOrder, trackDftInv, trackDftCust, dftLeadZero, dftSeparator, trackingURL)
  %if (trackingBy != "T" && trackingBy != "R")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)ShipViaInquiry.d2w/DISPLAY$(genericVarBase)&amp;shipVia=$(shipVia)">
  %else
%if (trackingBy == "T")
   @RtvFldDesc("THORD#=$(orderNumber) and THSSEQ=$(orderSequence)", "OETNHM", "THTRCK", trackingNumber)
%endif
     %if (trackingURL != "")
         %if (V_HHDSHP > "0")
             @RtvFldDesc("DSVCF='C' and DSVNCS=$(shipToNumber) and DSNMBR=$(dropShipNumber)", "HDDSHP", "DSZIP", zipCode)
         %else
             @RtvFldDesc("CMCUST=$(shipToNumber)", "HDCUST", "CMZIP", zipCode)
         %endif
         @Update_Tracking_URL(trackingNumber, dateShipped, zipCode, shipToNumber, orderNumber, invoiceNumber, refNumber, trackingURL)
         %if (trackingNumber != "")
               <meta http-equiv="refresh" content="0; URL=$(trackingURL)">
		    @dtw_exit()
         %endif
     %endif
     <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)ShipViaInquiry.d2w/DISPLAY$(genericVarBase)&amp;shipVia=$(shipVia)">
   %endif

%}