%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Option Search"
  d2wName                 = "OrderEntryOptionSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;lineNumber=@dtw_rurlescseq(lineNumber)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;vendCustItemsFound=@dtw_rurlescseq(vendCustItemsFound)&amp;reliefCode=@dtw_rurlescseq(reliefCode)&amp;addToOrder=@dtw_rurlescseq(addToOrder)&amp;price=@dtw_rurlescseq(price)&amp;orderTypeDesc=@dtw_rurlescseq(orderTypeDesc)&amp;catalogVarName=@dtw_rurlescseq(catalogVarName)&amp;featureGroup=@dtw_rurlescseq(featureGroup)&amp;featureGroupDesc=@dtw_rurlescseq(featureGroupDesc)&amp;feature=@dtw_rurlescseq(feature)&amp;featureDesc=@dtw_rurlescseq(featureDesc)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
  displayCloseIcon        = "Y"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select e.SADESC as SAFDSC, e.SAMAND as SAFMAN, e.SAMULT as SAFMUL, e.SAVARQ as SAFVAR, upper(a.SADESC) as SADESCU, a.* ", stmtSQL)
                      @dtw_concat(fileSQL, " HDOPWW  a join HDOPWW e on a.SAOCTL=e.SAOCTL and a.SAFEAT=e.SAFEAT and ' '=e.SAOPTN and ' '=e.SABLVL and 'Y'<>e.SASELC ", fileSQL)
                      @dtw_concat(selectSQL, "a.SAOCTL=$(orderControlNumber) and a.SAFEAT='$(feature)' and a.SAOPTN<>' ' and a.SASELC<>'Y' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Option_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Option_Search (IN CHAR(64)    profileHandle,
     	                              CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (displayQtyAvail != "N")
          @RtvFldDesc("O1OCTL=$(orderControlNumber) and O1ORL#=$(lineNumber)", "OEDTWK", "char(O1WH)", whsNumber)
      %endif
      @RtvFldDesc("O1OCTL=$(orderControlNumber) and O1ORL#=$(lineNumber)", "OEDTWK", "char(O1PLT)", plantNumber)
      %INCLUDE "PageTitle.icl"
      <table $(contentTable)>
          @Format_Header("Feature", $(featureDesc), $(feature))
      </table>
      $(searchhrTagAttr)
      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr>
                  <th class="colhdr">Bi-Level</th>
                  <th class="colhdr">Option</th>
                  <th class="colhdr">Description</th>
              </tr>
              <tr>
                  <td><input type="text" class="inputalph"  name="srchBiLevel" size="15" maxlength="15">
                      <input type="hidden" name="operBiLevel" value="LIKE">
                  </td>
                  <td><input type="text" class="inputalph"  name="srchOption" size="15" maxlength="15">
                      <input type="hidden" name="operOption" value="LIKE">
                  </td>
                  <td><input type="text" class="inputalph"  name="srchDesc" size="15" maxlength="30">
                      <input type="hidden" name="operDesc" value="LIKE">
                  </td>

                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
          <script TYPE="text/javascript">
              document.Search.srchOption.focus();
          </script>
      </form>
	
      %INCLUDE "WildCardPage.icl"

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              @OrderBy_Sort("SABLVL", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=biLevel" title="Sequence By Bi-Level">Bi-Level</a></th>
              @OrderBy_Sort("SAOPTN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=option" title="Sequence By Option">Option</a></th>
              @OrderBy_Sort("SADESCU", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=optionDesc" title="Sequence By Description">Description</a></th>
              <th class="colhdr">Extra<br>Charge</th>
              <th class="colhdr">Quantity<br>Available</th>
              <th class="colhdr">Prompt<br>Value</th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

      %ROW{
          %if (productCfgOptionSel == "A" && sql_Record_Count == "1")
              <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)&amp;option=@dtw_rurlescseq(V_SAOPTN)">
          %endif
          %INCLUDE "SetRowClass.icl"
          @Format_Quote(V_SABLVL, F_SABLVL)
          @Format_Quote(V_SAOPTN, F_SAOPTN)
          @Format_Quote(V_SADESC, F_SADESC)
          @Format_Nbr(V_SAXCHG, F_SAXCHG, "5", "4", "Y", "$", "")

          <tr class="$(rowClass)">
              <td class="colalph">$(V_SABLVL)</td>
              <td class="colalph">$(V_SAOPTN)</td>
              <td class="colalph">
                  %if (V_SAMNCD == "S")
                      $(V_SADESC)
                  %else
                      <a href="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)&amp;option=@dtw_rurlescseq(V_SAOPTN)&amp;optionDesc=@dtw_rurlescseq(V_SADESC)&amp;biLevel=@dtw_rurlescseq(V_SABLVL)&amp;prompt=@dtw_rurlescseq(V_SASCRP)" title="Select Option">$(V_SADESC)</a>
                  %endif
              </td>
              <td class="colnmbr">$(F_SAXCHG)</td>
              %if ((displayQtyAvail == "Y" || displayQtyAvail == "Z") && V_SAVCAT != "Y")
                  @dtw_assign(qtyAvailable, "0")
                  @Get_Qty_Avail(profileHandle, dataBaseID, V_SAOPTN, whsNumber, qtyAvailable)
                  %if (displayQtyAvail == "Z" && qtyAvailable < "0")
                      @dtw_assign(qtyAvailable, "0")
                  %endif
                  @Format_Nbr(qtyAvailable, F_qtyAvailable, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                  <td class="colnmbr">$(F_qtyAvailable)</td>
              %elif (displayQtyAvail == "Y" || displayQtyAvail == "Z")
                  <td>&nbsp;</td>
              %endif
              <td class="colalph">
                  %if (V_SASCRP != "" && V_SAMNCD == "S")
                      <a href="$(homeURL)$(cGIPath)FeatureOptionScreenPrompt.d2w/MAINTAIN$(d2wVarBase)&amp;option=@dtw_rurlescseq(V_SAOPTN)&amp;optionDesc=@dtw_rurlescseq(V_SADESC)&amp;biLevel=@dtw_rurlescseq(V_SABLVL)">&nbsp;Y</a>
                  %endif
              </td>
          </tr>
      %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      %INCLUDE "CloseWindow.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Update_Feature_Option (INOUT CHAR(64)    profileHandle,
                                                 INOUT CHAR(32000) edtVar,
                                                 INOUT CHAR(32000) errVar,
                                                 INOUT CHAR(1)     errFound,
                                                 INOUT DEC(13,5)   price)
{%EXEC {HHDFO2_W.PGM %}
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(maintenanceCode, "S")
  @dtw_assign(edtVar, "")
  @Concat_Field("@@octl", orderControlNumber)
  @Concat_Field("@@orl#", lineNumber)
  @Concat_Field("@@mncd", maintenanceCode)
  @Concat_Field("@@ucat", productCfgOptionDesc)
  @Concat_Field("@@feat", feature)
  @Concat_Field("@@optn", option)

  @dtw_concat(edtVar, "}{", edtVar)
  @Update_Feature_Option(profileHandle, edtVar, errVar, errFound, price)

  %if (prompt == "")
      <script TYPE="text/javascript">
          opener.location.href='$(homeURL)$(cGIPath)$(fromD2w)$(genericVarBase)&customerNumber=@dtw_rurlescseq(customerNumber)&customerName=@dtw_rurlescseq(customerName)&orderControlNumber=@dtw_rurlescseq(orderControlNumber)&lineNumber=@dtw_rurlescseq(lineNumber)&orderNumber=@dtw_rurlescseq(orderNumber)&vendCustItemsFound=@dtw_rurlescseq(vendCustItemsFound)&reliefCode=@dtw_rurlescseq(reliefCode)&addToOrder=@dtw_rurlescseq(addToOrder)&price=@dtw_rurlescseq(price)&orderTypeDesc=@dtw_rurlescseq(orderTypeDesc)&catalogVarName=@dtw_rurlescseq(catalogVarName)&featureGroup=@dtw_rurlescseq(featureGroup)&featureGroupDesc=@dtw_rurlescseq(featureGroupDesc)&feature=@dtw_rurlescseq(feature)&featureDesc=@dtw_rurlescseq(featureDesc)&timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))';
          opener.focus();
          self.close();
      </script>
  %else
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)FeatureOptionScreenPrompt.d2w/MAINTAIN$(d2wVarBase)&amp;option=@dtw_rurlescseq(option)&amp;optionDesc=@dtw_rurlescseq(optionDesc)&amp;biLevel=@dtw_rurlescseq(biLevel)">
  %endif
%}

%HTML(LOAD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @Concat_Field("@@octl", orderControlNumber)
  @Concat_Field("@@orl#", lineNumber)
  @Concat_Field("@@mncd", maintenanceCode)
  @Concat_Field("@@ucat", productCfgOptionDesc)
  @Concat_Field("@@feat", feature)
  @dtw_concat(edtVar, "}{", edtVar)

  @Update_Feature_Option(profileHandle, edtVar, errVar, errFound, price)

  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/ENTRY$(d2wVarBase)&amp;updateRowNum=@dtw_rurlescseq(updateRowNum)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  @DTW_ASSIGN(orderBy, "SADESCU, SAOPTN")
  @DTW_ASSIGN(orderByDisplay, "Description")
  @dtw_assign(wildCardSearch, "")
  @dtw_assign(wildCardDisplay, "")
  @Save_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %if (productCfgOptionSel == "A")
      @dtw_assign(wildCardSearch, "")
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "option")
      %if (orderBy == "SAOPTN")
          @DTW_ASSIGN(orderBy, "SAOPTN DESC")
          @DTW_ASSIGN(orderByDisplay, "Option (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SAOPTN")
          @DTW_ASSIGN(orderByDisplay, "Option")
      %endif
  %elif (sequence == "optionDesc")
      %if (orderBy == "SADESCU, SAOPTN")
          @DTW_ASSIGN(orderBy, "SADESCU DESC, SAOPTN")
          @DTW_ASSIGN(orderByDisplay, "Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SADESCU, SAOPTN")
          @DTW_ASSIGN(orderByDisplay, "Description")
      %endif
  %elif (sequence == "biLevel")
      %if (orderBy == "SABLVL, SAOPTN")
          @DTW_ASSIGN(orderBy, "SABLVL DESC, SAOPTN")
          @DTW_ASSIGN(orderByDisplay, "Bi-Level (descending), Option")
      %else
          @DTW_ASSIGN(orderBy, "SABLVL, SAOPTN")
          @DTW_ASSIGN(orderByDisplay, "Bi-Level, Option")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("a.SABLVL", "Bi-Level", $(srchBiLevel), "U", operBiLevel, "A")
  @Build_WildCard ("a.SAOPTN", "Option", $(srchOption), "U", operOption, "A")
  @Build_WildCard ("upper(a.SADESC)", "Description", $(srchDesc), "U", operDesc, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}