%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Change Role"
  d2wName                 = "RoleSelect.d2w"
  d2wVarBase              = "$(genericVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  advanceSearch           = "N"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectRole(role){
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select SYROLU.*, RMDESC, RMDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " SYROLU inner join SYROLM on RUROLE=RMROLE ", fileSQL)
                      @dtw_concat(selectSQL, " RUUSER='$(userProfile)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @RoleSelect_Query(profileHandle, dataBaseID, stmtSQL)
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) RoleSelect_Query (IN CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"

      $(searchhrTagAttr)
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Role</th>
                  </tr>
                  <tr><td class="inputalph">
                          <input type="text" name="srchRole" size="10" maxlength="10">
                          <input type="hidden" name="operRole" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchRole.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              <tr>	
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("RUROLE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=role" title="Sequence By Role">Role</a></th>
                  @OrderBy_Sort("RMDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=description" title="Sequence By Description, Role">Description</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"

              %ROW{
                  %INCLUDE "SetRowClass.icl"

                  <tr class="$(rowClass)">
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(genericVarBase)&amp;newRole=@dtw_rurlescseq(V_RUROLE)" title="Select Role">$(V_RUROLE)</a></td>
                      <td class="colalph"> $(V_RMDESC)</td>
                  </tr>
              %}
          </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "RUROLE")
      @DTW_ASSIGN(orderByDisplay, "Role")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "description")
      %if (orderBy == "RMDESCU,RUROLE")
          @DTW_ASSIGN(orderBy, "RMDESCU DESC,RUROLE")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Role")
      %else
          @DTW_ASSIGN(orderBy, "RMDESCU,RUROLE")
          @DTW_ASSIGN(orderByDisplay, "Description, Role")
      %endif
  %elseif (sequence == "role")
      %if (orderBy == "RUROLE")
          @DTW_ASSIGN(orderBy, "RUROLE DESC")
          @DTW_ASSIGN(orderByDisplay, "Role (descending)")
      %else
          @DTW_ASSIGN(orderBy, "RUROLE")
          @DTW_ASSIGN(orderByDisplay, "Role")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("RUROLE", "Role", $(srchRole), "U", operRole, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_SetCookie("role_cookie", "$(newRole)", "path=/")
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Update SYHAND Set HNROLE='$(newRole)' Where HNXHND='$(profileHandle)' @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)

  <script TYPE="text/javascript">
      opener.location.href=opener.location.href;
      window.close()
  </script>
%}