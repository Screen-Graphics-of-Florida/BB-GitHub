%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Common Table List"
  d2wName                 = "CommonFileList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (editFromToAll(document.Chg.frmFile, document.Chg.toFile, document.Chg.allFile, "A"))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "COMMONFILELIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          @dtw_assign(focusField, "frmFile")
                          %if (errFound != "" || scheduleJobSwitch == "Y")
                              @dtw_assign(scheduleJobSwitch, "")
                              @EdtVarErr(profileHandle, typeValue, edtVar)
                              @dtw_assign(focusField, "")
                              @ErrVarErr(profileHandle, typeError, errVar)
                              @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                              @DecatErr_Field("@@loc@", "fileLocated")     @dtw_assign(Err_N1LOC,  fieldValue)
                              @DecatErr_Field("@@ffid", "frmFile")           @dtw_assign(Err_N1FFID, fieldValue)
                              @DecatErr_Field("@@tfid", "toFile")            @dtw_assign(Err_N1TFID, fieldValue)
                              @DecatErr_Field("@@afid", "allFile")           @dtw_assign(Err_N1AFID, fieldValue)
                              %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                              @Decat_Field("@@loc@")   @dtw_assign(V_N1LOC,  fieldValue)
                              @Decat_Field("@@ffid")  @dtw_assign(V_N1FFID, fieldValue)
                              @Decat_Field("@@tfid")  @dtw_assign(V_N1TFID, fieldValue)
                              @Decat_Field("@@afid")  @dtw_assign(V_N1AFID, fieldValue)
                              %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                          %else
                              @dtw_assign(V_N1LOC, "01")
                              @dtw_assign(V_N1AFID, "ALL")
                          %endif

                          <table $(contentTable)>
                              %if (V_N1LOC == "02")
                                  @dtw_assign(locNo, "")
                                  @dtw_assign(locYes, "CHECKED")
                              %else
                                  @dtw_assign(locNo, "CHECKED")
                                  @dtw_assign(locYes, "")
                              %endif
                              @SetTextOvr(Err_N1LOC)
                              <tr><td  class="dsphdr"><span $(textOvr)>Print Where Table Is Located</span></td>
                                  <td class="inputnmbr"><input name="fileLocated" type="radio" VALUE='01' $(locNo)>No</td>
                              </tr>
                              @DspErrMsg(Err_N1LOC)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="fileLocated" type="radio" VALUE='02' $(locYes)>Yes</td>
                              </tr>

                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @Field_Checked(V_N1AFID, "ALL", allChecked)
                              @SetTextOvr(Err_N1FFID)
                              %if (textOvr == "") @SetTextOvr(Err_N1TFID) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AFID) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Table</span></td>
                                  <td class="inputalph"><input type="text" name="frmFile" value="$(V_N1FFID)" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input type="text" name="toFile" value="$(V_N1TFID)" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input type="checkbox" name="allFile" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmFile.value='', this.form.toFile.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FFID)
                              @DspErrMsg(Err_N1TFID)
                              @DspErrMsg(Err_N1AFID)
                          </table>

                          @dtw_assign(envProgram, "HSYCML")
                          @dtw_assign(envPrinter, "HSYCMLPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSYCMS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"

  @dtw_assign(edtVar, "")
  @Concat_Field("@@loc@", fileLocated)

  @dtw_mUPPERCASE(frmFile)                                                         @Concat_Field("@@ffid", frmFile)
  @dtw_mUPPERCASE(toFile)                                                          @Concat_Field("@@tfid", toFile)
  @dtw_mUPPERCASE(allFile) %if (allFile != "ALL") @dtw_assign(allFile, "") %endif  @Concat_Field("@@afid", allFile)
                                                                                   @Concat_Field("@@sfid", @dtw_rstrip(srtFile))
  %if (totFile != "Y") @dtw_assign(totFile, "N") %endif                            @Concat_Field("@@pfid", totFile)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}