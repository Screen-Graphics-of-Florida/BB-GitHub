  @Concat_Field("@@act8", glAcct8)
  @Concat_Field("@@act9", glAcct9)
  @Concat_Field("@@ac10", glAcct10)
  @Concat_Field("@@sub1", glSubAcct1)
  @Concat_Field("@@sub2", glSubAcct2)
  @Concat_Field("@@sub3", glSubAcct3)
  @Concat_Field("@@sub4", glSubAcct4)
  @Concat_Field("@@sub5", glSubAcct5)
  @Concat_Field("@@sub6", glSubAcct6)
  @Concat_Field("@@sub7", glSubAcct7)
  @Concat_Field("@@sub8", glSubAcct8)
  @Concat_Field("@@sub9", glSubAcct9)
  @Concat_Field("@@su10", glSubAcct10)
  @Concat_Field("@@tstp", timeStamp)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)
  @DecatErr_Field("@@comp", "coNumber")            @dtw_assign(Err_WDCOMP, fieldValue)
  
  %if (errFound == "")
      @Ret_Format_EmplName(coNumber, facNumber, emplNumber, "", "", "H", F_EmpName)
      @RtvFldDesc("CFCOMP=$(coNumber) and CFFACL=$(facNumber)", "HRCOFC", "CFNAME", fieldDesc)
      @Format_HRCoFac(coNumber, facNumber, "", F_CoFac)
      @Format_ConfMsg_Desc(maintenanceCode, $(F_EmpName), $(emplNumber), $(fieldDesc), $(F_CoFac), "", "", confMessage)
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=190&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %elif ((maintenanceCode == "C" || maintenanceCode == "D") && errFound != "" && fieldValue != "")
      @Ret_Format_EmplName(coNumber, facNumber, emplNumber, "", "", "H", F_EmpName)
      @RtvFldDesc("CFCOMP=$(coNumber) and CFFACL=$(facNumber)", "HRCOFC", "CFNAME", fieldDesc)
      @Format_HRCoFac(coNumber, facNumber, "", F_CoFac)
      @Format_ConfMsg_Desc("E", $(F_EmpName), $(emplNumber), $(fieldDesc), $(F_CoFac), "<br>$(fieldValue)", "", confMessage)
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=190&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;coNumber=@dtw_rurlescseq(coNumber)&amp;facNumber=@dtw_rurlescseq(facNumber)&amp;emplNumber=@dtw_rurlescseq(emplNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}