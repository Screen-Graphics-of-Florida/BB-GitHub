%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "YNFlagTable.icl"
%INCLUDE "NumFormat.icl"

%Define {
  page_title              = "Wage Distribution Tables Maintenance"
  d2wName                 = "WageDistributionMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;coNumber=@dtw_rurlescseq(coNumber)&amp;facNumber=@dtw_rurlescseq(facNumber)&amp;emplNumber=@dtw_rurlescseq(emplNumber)&amp;maintenanceCode=D"
  programName             = "HPRWDM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  function validate(chgForm) {
                      if (document.Chg.coNumber.value =="" ||
                          document.Chg.facNumber.value =="" ||
                          document.Chg.emplNumber.value =="")
                         {alert("$(reqFieldError)"); return false;}
                      if (editNum(document.Chg.coNumber,          2, 0) &&
                          editNum(document.Chg.facNumber,         4, 0) &&
                          editNum(document.Chg.emplNumber,        5, 0) &&
                          editNum(document.Chg.pct1,              3, 2) &&
                          editNum(document.Chg.pct2,              3, 2) &&
                          editNum(document.Chg.pct3,              3, 2) &&
                          editNum(document.Chg.pct4,              3, 2) &&
                          editNum(document.Chg.pct5,              3, 2) &&
                          editNum(document.Chg.pct6,              3, 2) &&
                          editNum(document.Chg.pct7,              3, 2) &&
                          editNum(document.Chg.pct8,              3, 2) &&
                          editNum(document.Chg.pct9,              3, 2) &&
                          editNum(document.Chg.pct10,             3, 2) &&
                          editNum(document.Chg.glAcct1,           4, 0) &&
                          editNum(document.Chg.glAcct2,           4, 0) &&
                          editNum(document.Chg.glAcct3,           4, 0) &&
                          editNum(document.Chg.glAcct4,           4, 0) &&
                          editNum(document.Chg.glAcct5,           4, 0) &&
                          editNum(document.Chg.glAcct6,           4, 0) &&
                          editNum(document.Chg.glAcct7,           4, 0) &&
                          editNum(document.Chg.glAcct8,           4, 0) &&
                          editNum(document.Chg.glAcct9,           4, 0) &&
                          editNum(document.Chg.glAcct10,          4, 0) &&
                          editNum(document.Chg.glSubAcct1,        4, 0) &&
                          editNum(document.Chg.glSubAcct2,        4, 0) &&
                          editNum(document.Chg.glSubAcct3,        4, 0) &&
                          editNum(document.Chg.glSubAcct4,        4, 0) &&
                          editNum(document.Chg.glSubAcct5,        4, 0) &&
                          editNum(document.Chg.glSubAcct6,        4, 0) &&
                          editNum(document.Chg.glSubAcct7,        4, 0) &&
                          editNum(document.Chg.glSubAcct8,        4, 0) &&
                          editNum(document.Chg.glSubAcct9,        4, 0) &&
                          editNum(document.Chg.glSubAcct10,       4, 0))
                          return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
	           %INCLUDE "numedit.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "WAGEDISTRIBUTIONMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "SELECT * FROM PRWGDS WHERE WDCOMP=$(coNumber) and WDFACL=$(facNumber) and WDEMPL=$(emplNumber) ", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=190")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "coNumber")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@comp", "coNumber")            @dtw_assign(Err_WDCOMP, fieldValue)
                          @DecatErr_Field("@@facl", "facNumber")           @dtw_assign(Err_WDFACL, fieldValue)
                          @DecatErr_Field("@@empl", "emplNumber")          @dtw_assign(Err_WDEMPL, fieldValue)
                          @DecatErr_Field("@@dpt1", "dept1")               @dtw_assign(Err_WDDPT1, fieldValue)
                          @DecatErr_Field("@@dpt2", "dept2")               @dtw_assign(Err_WDDPT2, fieldValue)
                          @DecatErr_Field("@@dpt3", "dept3")               @dtw_assign(Err_WDDPT3, fieldValue)
                          @DecatErr_Field("@@dpt4", "dept4")               @dtw_assign(Err_WDDPT4, fieldValue)
                          @DecatErr_Field("@@dpt5", "dept5")               @dtw_assign(Err_WDDPT5, fieldValue)
                          @DecatErr_Field("@@dpt6", "dept6")               @dtw_assign(Err_WDDPT6, fieldValue)
                          @DecatErr_Field("@@dpt7", "dept7")               @dtw_assign(Err_WDDPT7, fieldValue)
                          @DecatErr_Field("@@dpt8", "dept8")               @dtw_assign(Err_WDDPT8, fieldValue)
                          @DecatErr_Field("@@dpt9", "dept9")               @dtw_assign(Err_WDDPT9, fieldValue)
                          @DecatErr_Field("@@dp10", "dept10")              @dtw_assign(Err_WDDP10, fieldValue)
                          @DecatErr_Field("@@pct1", "pct1")                @dtw_assign(Err_WDPCT1, fieldValue)
                          @DecatErr_Field("@@pct2", "pct2")                @dtw_assign(Err_WDPCT2, fieldValue)
                          @DecatErr_Field("@@pct3", "pct3")                @dtw_assign(Err_WDPCT3, fieldValue)
                          @DecatErr_Field("@@pct4", "pct4")                @dtw_assign(Err_WDPCT4, fieldValue)
                          @DecatErr_Field("@@pct5", "pct5")                @dtw_assign(Err_WDPCT5, fieldValue)
                          @DecatErr_Field("@@pct6", "pct6")                @dtw_assign(Err_WDPCT6, fieldValue)
                          @DecatErr_Field("@@pct7", "pct7")                @dtw_assign(Err_WDPCT7, fieldValue)
                          @DecatErr_Field("@@pct8", "pct8")                @dtw_assign(Err_WDPCT8, fieldValue)
                          @DecatErr_Field("@@pct9", "pct9")                @dtw_assign(Err_WDPCT9, fieldValue)
                          @DecatErr_Field("@@pc10", "pc10")                @dtw_assign(Err_WDPC10, fieldValue)
                          @DecatErr_Field("@@act1", "glAcct1")             @dtw_assign(Err_WDACT1, fieldValue)
                          @DecatErr_Field("@@act2", "glAcct2")             @dtw_assign(Err_WDACT2, fieldValue)
                          @DecatErr_Field("@@act3", "glAcct3")             @dtw_assign(Err_WDACT3, fieldValue)
                          @DecatErr_Field("@@act4", "glAcct4")             @dtw_assign(Err_WDACT4, fieldValue)
                          @DecatErr_Field("@@act5", "glAcct5")             @dtw_assign(Err_WDACT5, fieldValue)
                          @DecatErr_Field("@@act6", "glAcct6")             @dtw_assign(Err_WDACT6, fieldValue)
                          @DecatErr_Field("@@act7", "glAcct7")             @dtw_assign(Err_WDACT7, fieldValue)
                          @DecatErr_Field("@@act8", "glAcct8")             @dtw_assign(Err_WDACT8, fieldValue)
                          @DecatErr_Field("@@act9", "glAcct9")             @dtw_assign(Err_WDACT9, fieldValue)
                          @DecatErr_Field("@@ac10", "glAcct10")            @dtw_assign(Err_WDAC10, fieldValue)
                          @DecatErr_Field("@@sub1", "glSubAcct1")          @dtw_assign(Err_WDSUB1, fieldValue)
                          @DecatErr_Field("@@sub2", "glSubAcct2")          @dtw_assign(Err_WDSUB2, fieldValue)
                          @DecatErr_Field("@@sub3", "glSubAcct3")          @dtw_assign(Err_WDSUB3, fieldValue)
                          @DecatErr_Field("@@sub4", "glSubAcct4")          @dtw_assign(Err_WDSUB4, fieldValue)
                          @DecatErr_Field("@@sub5", "glSubAcct5")          @dtw_assign(Err_WDSUB5, fieldValue)
                          @DecatErr_Field("@@sub6", "glSubAcct6")          @dtw_assign(Err_WDSUB6, fieldValue)
                          @DecatErr_Field("@@sub7", "glSubAcct7")          @dtw_assign(Err_WDSUB7, fieldValue)
                          @DecatErr_Field("@@sub8", "glSubAcct8")          @dtw_assign(Err_WDSUB8, fieldValue)
                          @DecatErr_Field("@@sub9", "glSubAcct9")          @dtw_assign(Err_WDSUB9, fieldValue)
                          @DecatErr_Field("@@su10", "glSubAcct10")         @dtw_assign(Err_WDSU10, fieldValue)
                          @DecatErr_Field("@@tstp", "timeStamp")           @dtw_assign(Err_WDTSTP, fieldValue)


                      %endif

                      @Decat_Field("@@comp")   @dtw_assign(V_WDCOMP, fieldValue)
                      @Decat_Field("@@facl")   @dtw_assign(V_WDFACL, fieldValue)
                      @Decat_Field("@@empl")   @dtw_assign(V_WDEMPL, fieldValue)
                      @Decat_Field("@@dpt1")   @dtw_assign(V_WDDPT1, fieldValue)
                      @Decat_Field("@@dpt2")   @dtw_assign(V_WDDPT2, fieldValue)
                      @Decat_Field("@@dpt3")   @dtw_assign(V_WDDPT3, fieldValue)
                      @Decat_Field("@@dpt4")   @dtw_assign(V_WDDPT4, fieldValue)
                      @Decat_Field("@@dpt5")   @dtw_assign(V_WDDPT5, fieldValue)
                      @Decat_Field("@@dpt6")   @dtw_assign(V_WDDPT6, fieldValue)
                      @Decat_Field("@@dpt7")   @dtw_assign(V_WDDPT7, fieldValue)
                      @Decat_Field("@@dpt8")   @dtw_assign(V_WDDPT8, fieldValue)
                      @Decat_Field("@@dpt9")   @dtw_assign(V_WDDPT9, fieldValue)
                      @Decat_Field("@@dp10")   @dtw_assign(V_WDDP10, fieldValue)
                      @Decat_Field("@@pct1")   @dtw_assign(V_WDPCT1, fieldValue)
                      @Decat_Field("@@pct2")   @dtw_assign(V_WDPCT2, fieldValue)
                      @Decat_Field("@@pct3")   @dtw_assign(V_WDPCT3, fieldValue)
                      @Decat_Field("@@pct4")   @dtw_assign(V_WDPCT4, fieldValue)
                      @Decat_Field("@@pct5")   @dtw_assign(V_WDPCT5, fieldValue)
                      @Decat_Field("@@pct6")   @dtw_assign(V_WDPCT6, fieldValue)
                      @Decat_Field("@@pct7")   @dtw_assign(V_WDPCT7, fieldValue)
                      @Decat_Field("@@pct8")   @dtw_assign(V_WDPCT8, fieldValue)
                      @Decat_Field("@@pct9")   @dtw_assign(V_WDPCT9, fieldValue)
                      @Decat_Field("@@pc10")   @dtw_assign(V_WDPC10, fieldValue)
                      @Decat_Field("@@act1")   @dtw_assign(V_WDACT1, fieldValue)
                      @Decat_Field("@@act2")   @dtw_assign(V_WDACT2, fieldValue)
                      @Decat_Field("@@act3")   @dtw_assign(V_WDACT3, fieldValue)
                      @Decat_Field("@@act4")   @dtw_assign(V_WDACT4, fieldValue)
                      @Decat_Field("@@act5")   @dtw_assign(V_WDACT5, fieldValue)
                      @Decat_Field("@@act6")   @dtw_assign(V_WDACT6, fieldValue)
                      @Decat_Field("@@act7")   @dtw_assign(V_WDACT7, fieldValue)
                      @Decat_Field("@@act8")   @dtw_assign(V_WDACT8, fieldValue)
                      @Decat_Field("@@act9")   @dtw_assign(V_WDACT9, fieldValue)
                      @Decat_Field("@@ac10")   @dtw_assign(V_WDAC10, fieldValue)
                      @Decat_Field("@@sub1")   @dtw_assign(V_WDSUB1, fieldValue)
                      @Decat_Field("@@sub2")   @dtw_assign(V_WDSUB2, fieldValue)
                      @Decat_Field("@@sub3")   @dtw_assign(V_WDSUB3, fieldValue)
                      @Decat_Field("@@sub4")   @dtw_assign(V_WDSUB4, fieldValue)
                      @Decat_Field("@@sub5")   @dtw_assign(V_WDSUB5, fieldValue)
                      @Decat_Field("@@sub6")   @dtw_assign(V_WDSUB6, fieldValue)
                      @Decat_Field("@@sub7")   @dtw_assign(V_WDSUB7, fieldValue)
                      @Decat_Field("@@sub8")   @dtw_assign(V_WDSUB8, fieldValue)
                      @Decat_Field("@@sub9")   @dtw_assign(V_WDSUB9, fieldValue)
                      @Decat_Field("@@su10")   @dtw_assign(V_WDSU10, fieldValue)
                      @Decat_Field("@@tstp")   @dtw_assign(V_WDTSTP, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "coNumber")
                          @dtw_assign(V_WDCOMP, "0")
                          @dtw_assign(V_WDFACL, "0")
                          @dtw_assign(V_WDEMPL, "0")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "coNumber")
                      @dtw_assign(V_WDPCT1, "@dtw_rformat(@dtw_rmultiply(V_WDPCT1, "100"),"","2")")
                      @dtw_assign(V_WDPCT2, "@dtw_rformat(@dtw_rmultiply(V_WDPCT2, "100"),"","2")")
                      @dtw_assign(V_WDPCT3, "@dtw_rformat(@dtw_rmultiply(V_WDPCT3, "100"),"","2")")
                      @dtw_assign(V_WDPCT4, "@dtw_rformat(@dtw_rmultiply(V_WDPCT4, "100"),"","2")")
                      @dtw_assign(V_WDPCT5, "@dtw_rformat(@dtw_rmultiply(V_WDPCT5, "100"),"","2")")
                      @dtw_assign(V_WDPCT6, "@dtw_rformat(@dtw_rmultiply(V_WDPCT6, "100"),"","2")")
                      @dtw_assign(V_WDPCT7, "@dtw_rformat(@dtw_rmultiply(V_WDPCT7, "100"),"","2")")
                      @dtw_assign(V_WDPCT8, "@dtw_rformat(@dtw_rmultiply(V_WDPCT8, "100"),"","2")")
                      @dtw_assign(V_WDPCT9, "@dtw_rformat(@dtw_rmultiply(V_WDPCT9, "100"),"","2")")
                      @dtw_assign(V_WDPC10, "@dtw_rformat(@dtw_rmultiply(V_WDPC10, "100"),"","2")")
                  %else
                      @dtw_assign(focusField, "dept1")
                      @dtw_assign(V_WDPCT1, "@dtw_rformat(@dtw_rmultiply(V_WDPCT1, "100"),"","2")")
                      @dtw_assign(V_WDPCT2, "@dtw_rformat(@dtw_rmultiply(V_WDPCT2, "100"),"","2")")
                      @dtw_assign(V_WDPCT3, "@dtw_rformat(@dtw_rmultiply(V_WDPCT3, "100"),"","2")")
                      @dtw_assign(V_WDPCT4, "@dtw_rformat(@dtw_rmultiply(V_WDPCT4, "100"),"","2")")
                      @dtw_assign(V_WDPCT5, "@dtw_rformat(@dtw_rmultiply(V_WDPCT5, "100"),"","2")")
                      @dtw_assign(V_WDPCT6, "@dtw_rformat(@dtw_rmultiply(V_WDPCT6, "100"),"","2")")
                      @dtw_assign(V_WDPCT7, "@dtw_rformat(@dtw_rmultiply(V_WDPCT7, "100"),"","2")")
                      @dtw_assign(V_WDPCT8, "@dtw_rformat(@dtw_rmultiply(V_WDPCT8, "100"),"","2")")
                      @dtw_assign(V_WDPCT9, "@dtw_rformat(@dtw_rmultiply(V_WDPCT9, "100"),"","2")")
                      @dtw_assign(V_WDPC10, "@dtw_rformat(@dtw_rmultiply(V_WDPC10, "100"),"","2")")
                  %endif


              	  @SetTextOvr(Err_WDTSTP)
                  <tr><td class="dsphdr"><span $(textOvr)>.</span></td>
                  	  <td><input name="timeStamp" type="hidden" value="$(V_WDTSTP)"></td> 
                  </tr>
                  @DspErrMsg(Err_WDTSTP)
                  @dtw_assign(totalPercent, "0")
                  @Format_HRCoFac("$(V_WDCOMP)", "$(V_WDFACL)", "", F_CoFac)
                  @RtvFldDesc("CFCOMP=$(V_WDCOMP) and CFFACL=$(V_WDFACL)", "HRCOFC", "CFNAME", fieldDesc)
                  @SetTextOvr(Err_WDCOMP)
                  <tr><td class="dsphdr"><span $(textOvr)>Company/Facility</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="coNumber" value="$(V_WDCOMP)" type="text" size="4" maxlength="2"> / <input name="facNumber" value="$(V_WDFACL)" type="text" size="4" maxlength="4"> $(reqFieldChar) <a href="$(homeURL)$(phpPath)HRCoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=coNumber&amp;fldFac=facNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="coFacDesc" value="$(fieldDesc)"  type="text" size="30" maxlength="30"></td>
                      %else
                          <td class="dspalph"><input name="coNumber" value="$(V_WDCOMP)" type="hidden" size="4" maxlength="2"> <input name="facNumber" value="$(V_WDFACL)" type="hidden" size="4" maxlength="4">$(fieldDesc)</td>
                          @Format_Code(F_CoFac, F2_CoFac)
                          <td class="dspalph">$(F2_CoFac)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_WDCOMP)
                  @DspErrMsg(Err_WDFACL)

                  @SetTextOvr(Err_WDEMPL)
                  @Ret_Format_EmplName(coNumber, facNumber, emplNumber, "", "", "H", F_EmpName)
                  <tr><td class="dsphdr"><span $(textOvr)>Employee Number</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input type="text" name="emplNumber" value="$(V_WDEMPL)" size="5" maxlength="5"> $(reqFieldChar) <a href="$(homeURL)$(phpPath)EmployeeSearch.php$(altVarBase)&amp;docName=Chg&amp;fromD2w=@dtw_rurlescseq($(d2wName))&amp;fldCo=coNumber&amp;fldFacl=facNumber&amp;fldEmpl=emplNumber&amp;fldHRCo=hrCompany&amp;fldHREmpl=hrEmployee&amp;fldEmplName=emplName&amp;fldHRCoName=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input disabled name="emplName" value="$(F_EmpName)"  type="text" size="30" maxlength="30"><input name="hrEmployee" type="hidden"><input name="hrCompany"  type="hidden"></td>
                      %else
                          <td class="dspalph"><input type="hidden" name="emplNumber" value="$(V_WDEMPL)" size="5" maxlength="5">$(F_EmpName)</td>
                          @Format_Code(V_WDEMPL, F_WDEMPL)
                          <td class="dspalph">$(F_WDEMPL)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_WDEMPL)

                  <tr><td>&nbsp;</td></tr>


                  <table $(contentTable)>
                     <tr><td class="colhdr">Department</td>
                         <td class="colhdr">Dist<br> Percent</td>
                         <td class="colhdr">Override Account</td>
                     </tr>

                  @DTW_ASSIGN(totalPercent, @dtw_radd(totalPercent, V_WDPCT1))
                  @Default_Zero(V_WDPCT1)
                  @Default_Zero(V_WDACT1)
                  @Default_Zero(V_WDSUB1)
                  @RtvFldDesc("CHACCT=$(V_WDACT1) and CHSUB=$(V_WDSUB1) ", "HDCHRT", "CHCHDS", acctDesc1)
                  @RtvFldDesc("EADEPT='$(V_WDDPT1)' ", "PREXAC", "EANAME", fieldDesc1)
                  @SetTextOvr(Err_WDDPT1)
                  @SetTextOvr(Err_WDPCT1)
                  @SetTextOvr(Err_WDACT1)
                  @SetTextOvr(Err_WDSUB1)
                  <tr>
                      <td class="inputalph"><input type="text" name="dept1" value="$(V_WDDPT1)" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=dept1&amp;fldDesc=deptDesc1" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="deptDesc1" value="$(fieldDesc1)"  type="text" size="20" maxlength="20"></td>
                      <td class="inputnmbr"><input type="text" name="pct1" value="$(V_WDPCT1)" size="5" maxlength="5"></td>
                      <td class="inputnmbr"><input name="glAcct1" value="$(V_WDACT1)" type="text" size="4" maxlength="4"> - <input name="glSubAcct1" value="$(V_WDSUB1)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=glAcct1&amp;subFld=glSubAcct1&amp;descFld=ovrAcctDesc1" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="ovrAcctDesc1" value="$(acctDesc1)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_WDDPT1)
                  @DspErrMsg(Err_WDPCT1)
                  @DspErrMsg(Err_WDACT1)
                  @DspErrMsg(Err_WDSUB1)

                  @DTW_ASSIGN(totalPercent, @dtw_radd(totalPercent, V_WDPCT2))
