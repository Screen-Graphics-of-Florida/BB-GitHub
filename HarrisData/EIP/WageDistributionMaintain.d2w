  @dtw_mUPPERCASE(dept8)
  @dtw_mUPPERCASE(dept9)
  @dtw_mUPPERCASE(dept10)

  @dtw_assign(coNumber,@dtw_rstrip(coNumber))
  @dtw_assign(facNumber,@dtw_rstrip(facNumber))
  @dtw_assign(emplNumber,@dtw_rstrip(emplNumber))
  @dtw_assign(dept1,@dtw_rstrip(dept1))
  @dtw_assign(dept2,@dtw_rstrip(dept2))
  @dtw_assign(dept3,@dtw_rstrip(dept3))
  @dtw_assign(dept4,@dtw_rstrip(dept4))
  @dtw_assign(dept5,@dtw_rstrip(dept5))
  @dtw_assign(dept6,@dtw_rstrip(dept6))
  @dtw_assign(dept7,@dtw_rstrip(dept7))
  @dtw_assign(dept8,@dtw_rstrip(dept8))
  @dtw_assign(dept9,@dtw_rstrip(dept9))
