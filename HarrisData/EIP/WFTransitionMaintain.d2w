%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Transition Maintenance"
  d2wName                 = "WFTransitionMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfProcess=@dtw_rurlescseq(wfProcess)&amp;passedWfPoint=@dtw_rurlescseq(passedWfPoint)&amp;passedWfSequence=@dtw_rurlescseq(passedWfSequence)&amp;passedWFFromTo=@dtw_rurlescseq(passedWFFromTo)&amp;fromTransitionId=@dtw_rurlescseq(fromTransitionId)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;updRecNbr=@dtw_rurlescseq(updRecNbr)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;wfTransitionId=@dtw_rurlescseq(wfTransitionId)&amp;maintenanceCode=D"
  programName             = "HWFTRM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function confirmDelete() {return confirm("$(delRecordConf)")}
              function validate(chgForm) {
                  if (document.Chg.wfFromPoint.value =="" ||
                      document.Chg.wfFromSequence.value =="" ||
                      document.Chg.passFail.value =="" ||
                      document.Chg.andSplit.value =="")
                         {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.wfFromPoint, 4, 3) &&
                      editNum(document.Chg.wfFromSequence, 4, 3) &&
                      editNum(document.Chg.andSplit, 6, 1) &&
                      editNum(document.Chg.wfToPoint, 4, 3) &&
                      editNum(document.Chg.wfToSequence, 4, 3) &&
                      editNum(document.Chg.conditionId, 15, 0) &&
                      editNum(document.Chg.validationId, 15, 0) &&
                      editdate(document.Chg.fromDate) &&
                      editdate(document.Chg.toDate)
                      )
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFTRANSITIONMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " WFPRTR ", fileSQL)
                          @dtw_concat(selectSQL, " TRPROC='$(wfProcess)' and TRTRID=$(wfTransitionId) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          @RtvFldDesc("PRPROC='$(wfProcess)'", "WFPRHD", "PRDESC", wfProcessDescription)
          @Format_Header("", $(wfProcessDescription), $(wfProcess))
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          %ROW {
              %if (errFound != "" || maintenanceCode == "A")
                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(edtVar, "")
                      @dtw_assign(focusField, "wfFromPoint")
                  %else
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@fpnt", "wfFromPoint")           @dtw_assign(Err_TRFPNT, fieldValue)
                      @DecatErr_Field("@@fseq", "wfFromSequence")        @dtw_assign(Err_TRFSEQ, fieldValue)
                      @DecatErr_Field("@@fail", "passFail")              @dtw_assign(Err_TRFAIL, fieldValue)
                      @DecatErr_Field("@@levl", "andSplit")              @dtw_assign(Err_TRLEVL, fieldValue)
                      @DecatErr_Field("@@opt@", "optTransition")         @dtw_assign(Err_TROPT, fieldValue)
                      @DecatErr_Field("@@tpnt", "wfToPoint")             @dtw_assign(Err_TRTPNT, fieldValue)
                      @DecatErr_Field("@@tseq", "wfToSequence")          @dtw_assign(Err_TRTSEQ, fieldValue)
                      @DecatErr_Field("@@cond", "conditionId")           @dtw_assign(Err_TRCOND, fieldValue)
                      @DecatErr_Field("@@vpgm", "vldProgram")            @dtw_assign(Err_TRVPGM, fieldValue)
                      @DecatErr_Field("@@vlid", "validationId")          @dtw_assign(Err_TRVLID, fieldValue)
                      @DecatErr_Field("@@efdt", "fromDate")              @dtw_assign(Err_TREFDT, fieldValue)
                      @DecatErr_Field("@@etdt", "toDate")                @dtw_assign(Err_TRETDT, fieldValue)
                  %endif

                  @Decat_Field("@@trid")   @dtw_assign(V_TRTRID, fieldValue)
                  @Decat_Field("@@fpnt")   @dtw_assign(V_TRFPNT, fieldValue)
                  @Decat_Field("@@fseq")   @dtw_assign(V_TRFSEQ, fieldValue)
                  @Decat_Field("@@fail")   @dtw_assign(V_TRFAIL, fieldValue)
                  @Decat_Field("@@levl")   @dtw_assign(V_TRLEVL, fieldValue)
                  @Decat_Field("@@opt@")   @dtw_assign(V_TROPT, fieldValue)
                  @Decat_Field("@@tpnt")   @dtw_assign(V_TRTPNT, fieldValue)
                  @Decat_Field("@@tseq")   @dtw_assign(V_TRTSEQ, fieldValue)
                  @Decat_Field("@@cond")   @dtw_assign(V_TRCOND, fieldValue)
                  @Decat_Field("@@vpgm")   @dtw_assign(V_TRVPGM, fieldValue)
                  @Decat_Field("@@vlid")   @dtw_assign(V_TRVLID, fieldValue)
                  @Decat_Field("@@efdt")   @dtw_assign(V_TREFDT, fieldValue)
                  @Decat_Field("@@etdt")   @dtw_assign(V_TRETDT, fieldValue)

                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(focusField, "wfFromPoint")
                      @dtw_assign(V_TRTRID, "0")
                      @dtw_assign(V_TRFPNT, "0")
                      @dtw_assign(V_TRFSEQ, "0")
                      @dtw_assign(V_TRTPNT, "0")
                      @dtw_assign(V_TRTSEQ, "0")
                      @dtw_assign(V_TRCOND, "0")
                      @dtw_assign(V_TRVLID, "0")
                      @dtw_assign(V_TRLEVL, "1")
                      @dtw_assign(V_TRFAIL, "P")

                  %endif

                  @dtw_assign(errFound, "")

              %elif (maintenanceCode == "Z")
                  @dtw_assign(focusField, "wfFromPoint")
                  @dtw_assign(V_TRTRID, "0")
                  @DateInputFromCYMD(V_TREFDT)
                  @DateInputFromCYMD(V_TRETDT)
              %else
                  @dtw_assign(focusField, "wfFromPoint")
                  @DateInputFromCYMD(V_TREFDT)
                  @DateInputFromCYMD(V_TRETDT)
              %endif

              <table $(contentTable)>
                  <tr><td><input type="hidden" name="wfTransitionId" value="$(V_TRTRID)"></td></tr>

                  @Default_Zero(V_TRFPNT)
                  @Default_Zero(V_TRFSEQ)
                  @SetTextOvr(Err_TRFPNT)
                  @RtvFldDesc("PDPROC='$(wfProcess)' and PDPONT=$(V_TRFPNT) and PDSEQ=$(V_TRFSEQ) ", "WFPRDT", "PDDESC", fieldDesc)
                  <tr><td class="dsphdr"><span $(textOvr)>From Detail Point</span></td>
                      <td class="inputnmbr"><input type="text" name="wfFromPoint" value="$(V_TRFPNT)" size="8" maxlength="8">
                                            <input type="text" name="wfFromSequence" value="$(V_TRFSEQ)" size="8" maxlength="8">
                                            <a href="$(homeURL)$(cGIPath)WFDetailSearch.d2w/REPORT$(genericVarBase)&amp;docName=Chg&amp;specificWFProcess=@dtw_rurlescseq(wfProcess)&amp;fldPoint=wfFromPoint&amp;fldSequence=wfFromSequence&amp;fldDesc=wfFromSequenceDesc" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage)</a>
                                            <input type="text" disabled name="wfFromSequenceDesc" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_TRFPNT)

                  @SetTextOvr(Err_TRFAIL)
                  @RtvFldDesc("FLTYPE='WFPASSFAIL' and FLVALU='$(V_TRFAIL)'", "SYFLAG", "FLDESC", fieldDesc)
                  <tr><td class="dsphdr"><span $(textOvr)>Pass/Fail</span></td>
                      <td class="inputalph"><input type="text" name="passFail" value="$(V_TRFAIL)" size="23" maxlength="1">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=WFPASSFAIL&amp;flagSrchHdr=@dtw_rurlescseq("Pass/Fail")&amp;docName=Chg&amp;fldName=passFail&amp;fldDesc=passFailDesc" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage)</a>
                                            <input type="text" disabled name="passFailDesc" value="$(fieldDesc)"size="30"></td>
                  </tr>
                  @DspErrMsg(Err_TRFAIL)

                  @SetTextOvr(Err_TRLEVL)
                  <tr><td class="dsphdr"><span $(textOvr)>And Split Level</span></td>
                      <td class="inputnmbr"><input type="text" name="andSplit" value="$(V_TRLEVL)" size="23" maxlength="8">$(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_TRLEVL)

                  @SetTextOvr(Err_TROPT)
                  @RtvFldDesc("FLTYPE='WFOPTTRANS' and FLVALU='$(V_TROPT)'", "SYFLAG", "FLDESC", fieldDesc)
                  <tr><td class="dsphdr"><span $(textOvr)>Optional Transition</span></td>
                      <td class="inputalph"><input type="text" name="optTransition" value="$(V_TROPT)" size="23" maxlength="1">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=WFOPTTRANS&amp;flagSrchHdr=@dtw_rurlescseq("Optional Transition")&amp;docName=Chg&amp;fldName=optTransition&amp;fldDesc=optTransitionDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                            <input type="text" disabled name="optTransitionDesc" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_TROPT)

                  @Default_Zero(V_TRTPNT)
                  @Default_Zero(V_TRTSEQ)
                  @SetTextOvr(Err_TRTPNT)
                  @RtvFldDesc("PDPROC='$(wfProcess)' and PDPONT=$(V_TRTPNT) and PDSEQ=$(V_TRTSEQ)", "WFPRDT", "PDDESC", fieldDesc)
                  <tr><td class="dsphdr"><span $(textOvr)>To Detail Point</span></td>
                      <td class="inputnmbr"><input type="text" name="wfToPoint" value="$(V_TRTPNT)" size="8" maxlength="8">
                                            <input type="text" name="wfToSequence" value="$(V_TRTSEQ)" size="8" maxlength="8">
                                            <a href="$(homeURL)$(cGIPath)WFDetailSearch.d2w/REPORT$(genericVarBase)&amp;docName=Chg&amp;specificWFProcess=@dtw_rurlescseq(wfProcess)&amp;fldPoint=wfToPoint&amp;fldSequence=wfToSequence&amp;fldDesc=wfToSequenceDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                            <input type="text" disabled name="wfToSequenceDesc" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_TRTPNT)

                  @Default_Zero(V_TRCOND)
                  @SetTextOvr(Err_TRCOND)
                  @RtvFldDesc("CMCOND=$(V_TRCOND)", "WFCNDM", "CMDESC", fieldDesc)
                  <tr><td class="dsphdr"><span $(textOvr)>Condition ID</span></td>
                      <td class="inputnmbr"><input type="text" name="conditionId" value="$(V_TRCOND)" size="23" maxlength="15">
                                            <a href="$(homeURL)$(cGIPath)WFConditionSearch.d2w/REPORT$(genericVarBase)&amp;docName=Chg&amp;fldName=conditionId&amp;fldDesc=conditionIdDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                            <input type="text" disabled name="conditionIdDesc" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_TRCOND)

                  @Default_Zero(V_TRVLID)
                  @SetTextOvr(Err_TRVLID)
                  @RtvFldDesc("VIVPGM='$(V_TRVPGM)' and VIVLID=$(V_TRVLID)", "WFVLID", "VIDESC", fieldDesc)
                  <tr><td class="dsphdr"><span $(textOvr)>Validation Program/ID</span></td>
                      <td class="inputalph"><input type="text" name="vldProgram" value="$(V_TRVPGM)" size="10" maxlength="10">
                                            <input type="text" name="validationId" value="$(V_TRVLID)" size="15" maxlength="15">
                                            <a href="$(homeURL)$(cGIPath)WFValidationIdSearch.d2w/REPORT$(genericVarBase)&amp;specificWFProcess=@dtw_rurlescseq(wfProcess)&amp;docName=Chg&amp;fldVldProgram=vldProgram&amp;fldVldId=validationId&amp;fldDesc=validationIdDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                            <input type="text" disabled name="validationIdDesc" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_TRVLID)
              </table>

              <table $(contentTable)>
                  <tr><td class="dsphdr">&nbsp;</td>
                      <td class="colhdr">From</td>
                      <td class="colhdr">To</td>
                  </tr>

                  @SetTextOvr(Err_TREFDT)
                  <tr><td class="dsphdr"><span $(textOvr)>Effective Date</span></td>
                      <td class="inputnmbr"><input type="text" name="fromDate" value="$(V_TREFDT)" size="6" maxlength="6"> 		
                                            <a href="javascript:calWindow('fromDate');">$(calendarImage)</a></td>
                      <td class="inputnmbr"><input type="text" name="toDate" value="$(V_TRETDT)" size="6" maxlength="6"> 		
                                            <a href="javascript:calWindow('toDate');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_TREFDT)
              </table>
          %}

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      %INCLUDE "MaintainBottom.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HWFTRM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  %if (wfFromPoint == "")
      @RtvFldDesc("TRPROC='$(wfProcess)' and TRTRID=$(wfTransitionId) ", "WFPRTR", "CHAR(TRFPNT)", wfFromPoint)
      @RtvFldDesc("TRPROC='$(wfProcess)' and TRTRID=$(wfTransitionId) ", "WFPRTR", "CHAR(TRFSEQ)", wfFromSequence)
      @RtvFldDesc("TRPROC='$(wfProcess)' and TRTRID=$(wfTransitionId) ", "WFPRTR", "CHAR(TRTPNT)", wfToPoint)
      @RtvFldDesc("TRPROC='$(wfProcess)' and TRTRID=$(wfTransitionId) ", "WFPRTR", "CHAR(TRTSEQ)", wfToSequence)
  %endif
  @RtvFldDesc("PDPROC='$(wfProcess)' and PDPONT=$(wfFromPoint) and PDSEQ=$(wfFromSequence) ", "WFPRDT", "PDDESC", V_PDDESC_FR)
  @RtvFldDesc("PDPROC='$(wfProcess)' and PDPONT=$(wfToPoint) and PDSEQ=$(wfToSequence) ", "WFPRDT", "PDDESC", V_PDDESC_TO)

  @dtw_mUPPERCASE(wfProcess)
  @dtw_mUPPERCASE(passFail)
  @dtw_mUPPERCASE(optTransition)
  @dtw_mUPPERCASE(vldProgram)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@frm1", fromTransitionId)
  @Concat_Field("@@proc", wfProcess)
  @Concat_Field("@@trid", wfTransitionId)
  @Concat_Field("@@fpnt", wfFromPoint)
  @Concat_Field("@@fseq", wfFromSequence)
  @Concat_Field("@@fail", passFail)
  @Concat_Field("@@levl", andSplit)
  @Concat_Field("@@opt@", optTransition)
  @Concat_Field("@@tpnt", wfToPoint)
  @Concat_Field("@@tseq", wfToSequence)
  @Concat_Field("@@cond", conditionId)
  @Concat_Field("@@vpgm", vldProgram)
  @Concat_Field("@@vlid", validationId)
  @Concat_Field("@@efdt", fromDate)
  @Concat_Field("@@etdt", toDate)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)
  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, "$(V_PDDESC_FR) to $(V_PDDESC_TO)", "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@fpnt", "wfFromPoint")
      @Format_ConfMsg_Desc(maintenanceCode, "$(V_PDDESC_FR) to $(V_PDDESC_TO)", "", "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;wfTransitionId=@dtw_rurlescseq(wfTransitionId)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
