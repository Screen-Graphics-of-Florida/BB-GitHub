%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "EIP Configuration Maintenance"
  d2wName                 = "EIPCfgDetailMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fileName=@dtw_rurlescseq(fileName)&amp;fileNameU=@dtw_rurlescseq(fileNameU)&amp;fileNameDesc=@dtw_rurlescseq(fileNameDesc)&amp;resvRec=@dtw_rurlescseq(resvRec)&amp;updRecNbr=@dtw_rurlescseq(updRecNbr)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;parmName=@dtw_rurlescseq(parmName)&amp;parmNameU=@dtw_rurlescseq(parmNameU)&amp;maintenanceCode=D"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  programName             = "HSYECH_E"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.parmName.value =="")
                     {alert("$(reqFieldError)"); return false;}
                     return true;
                  }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "EIPCFGDETAILMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From SYECFD ", stmtSQL)
                          @dtw_concat(stmtSQL, "Where EDFILEU='$(fileNameU)' and EDPARMU='$(parmNameU)' ", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (resvRec == "Y")
          @dtw_assign(sec_03, "N")
      %endif
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          @Format_Header("File", $(fileNameDesc), $(fileName))
      </table>
      $(hrTagAttr)
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" NAME="Chg" METHOD=POST ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "parmName")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@pnam", "parmName")          @dtw_assign(Err_EDPARM, fieldValue)
                          @DecatErr_Field("@@desc", "parmDesc")          @dtw_assign(Err_EDDESC, fieldValue)
                          @DecatErr_Field("@@pval", "parmValue")         @dtw_assign(Err_EDVALU, fieldValue)
                          @DecatErr_Field("@@pcmt", "parmCmt")           @dtw_assign(Err_EDCMNT, fieldValue)
                      %endif

                      @Decat_Field("@@pnam")   @dtw_assign(V_EDPARM, fieldValue)
                      @Decat_Field("@@desc")   @dtw_assign(V_EDDESC, fieldValue)
                      @Decat_Field("@@pval")   @dtw_assign(V_EDVALU, fieldValue)
                      @Decat_Field("@@pcmt")   @dtw_assign(V_EDCMNT, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "parmName")
                      %endif
                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_EDFILE,  "")
                      @dtw_assign(focusField, "parmName")
                  %else
                      @dtw_assign(focusField, "parmDesc")
                  %endif

                  @SetTextOvr(Err_EDPARM)
    	           <tr><td class="dsphdr"><span $(textOvr)>Parameter</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="parmName" type="text" value="$(V_EDPARM)" size="50" maxlength="256"> $(reqFieldChar)</td>
                      %else
                          <td class="inputalph"><input name="parmName" type="hidden" value="$(V_EDPARM)" size="50" maxlength="256">$(V_EDPARM)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_EDPARM)

                  @SetTextOvr(Err_EDDESC)
    	           <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="parmDesc" type="text" value="$(V_EDDESC)" size="50" maxlength="100"></td>
                  </tr>
                  @DspErrMsg(Err_EDDESC)

                  @SetTextOvr(Err_EDVALU)
    	           <tr><td class="dsphdr"><span $(textOvr)>Value</span></td>
                      <td class="inputalph"><input name="parmValue" type="text" value="$(V_EDVALU)" size="200" maxlength="3000"></td>
                  </tr>
                  @DspErrMsg(Err_EDVALU)

                  <tr><td class="dsphdr">Comments</td>
                      <td>
                          %if ("$(V_EDCMNT)" != "")
                              <textarea name="parmCmt" ROWS=15 COLS=60 WRAP="hard">$(V_EDCMNT)</textarea>
                          %else
                              <textarea name="parmCmt" ROWS=15 COLS=60 WRAP="hard"></textarea>
                          %endif
                      </td>
                  </tr>
              %}
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSYECD_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_replace(parmValue, "<", "&lt;", "1", "a", parmValue)
  @dtw_replace(parmValue, ">", "&gt;", "1", "a", parmValue)
  @dtw_replace(parmValue, """", "&quot;", "1", "a", parmValue)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@file", fileNameU)
  @Concat_Field("@@pnam", parmName)
  @Concat_Field("@@desc", parmDesc)
  @Concat_Field("@@pval", parmValue)
  @Concat_Field("@@pcmt", parmCmt)
  @Concat_Field("@@user", userProfile)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, "Parameter", "$(parmName)", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)EIPCfgDetail.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;parmNameU=@dtw_rurlescseq(parmNameU)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
