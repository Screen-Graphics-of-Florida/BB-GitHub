%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Features And Options Rule Group ID Maintenance"
  d2wName                 = "FeatureOptionRuleGroupIDMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(fromPlant)&amp;fromName=@dtw_rurlescseq(fromName)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;groupID=@dtw_rurlescseq(groupID)&amp;targetFeature=@dtw_rurlescseq(targetFeature)&amp;targetOption=@dtw_rurlescseq(targetOption)&amp;groupDesc=@dtw_rurlescseq(groupDesc)&amp;maintenanceCode=D"
  programName             = "HHDRGM_E"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
	       %INCLUDE "NumEdit.icl"
              function validate(chgForm) {
                  if (document.Chg.plantNumber.value =="" ||
                      document.Chg.groupID.value =="" ||
                      document.Chg.targetFeature.value =="" ||
                      document.Chg.groupDesc.value =="" ||
                      document.Chg.ieRule.value =="")
                     {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.plantNumber, 3, 0))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "FORULEGROUPIDMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "SELECT * FROM HDRGID ", stmtSQL)
                          @dtw_concat(stmtSQL, "WHERE RGPLT = $(plantNumber) and RGGPID = '$(groupID)' and RGTFET = '$(targetFeature)' and RGTOPT = '$(targetOption)' ", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "groupID")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@plt@", "plantNumber")    @dtw_assign(Err_RGPLT,  fieldValue)
                          @DecatErr_Field("@@gpid", "groupID")        @dtw_assign(Err_RGGPID, fieldValue)
                          @DecatErr_Field("@@rgds", "groupDesc")      @dtw_assign(Err_RGRGDS, fieldValue)
                          @DecatErr_Field("@@tfet", "targetFeature")  @dtw_assign(Err_RGTFET, fieldValue)
                          @DecatErr_Field("@@topt", "targetOption")   @dtw_assign(Err_RGTOPT, fieldValue)
                          @DecatErr_Field("@@rule", "ieRule")         @dtw_assign(Err_RGRULE, fieldValue)
                      %endif

                      @Decat_Field("@@plt@")   @dtw_assign(V_RGPLT,  fieldValue)
                      @Decat_Field("@@gpid")   @dtw_assign(V_RGGPID, fieldValue)
                      @Decat_Field("@@rgds")   @dtw_assign(V_RGRGDS, fieldValue)
                      @Decat_Field("@@tfet")   @dtw_assign(V_RGTFET, fieldValue)
                      @Decat_Field("@@topt")   @dtw_assign(V_RGTOPT, fieldValue)
                      @Decat_Field("@@rule")   @dtw_assign(V_RGRULE, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          %if (fromPlant > "0")
                              @dtw_assign(V_RGPLT, fromPlant)
                          %else
                              @RtvDftPlant(V_RGPLT, plantName)
                          %endif
                          %if (V_RGPLT > "0")
                              @dtw_assign(focusField, "groupID")
                          %else
                              @dtw_assign(focusField, "plantNumber")
                          %endif
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_RGGPID, "")
                      @dtw_assign(focusField, "groupID")
                  %else
                      @dtw_assign(focusField, "groupDesc")
                  %endif

                  @Default_Zero(V_RGPLT)
                  @RtvFldDesc("PLPLNT=$(V_RGPLT)", "HDPLNT", "PLNAME", plantName)
                  @SetTextOvr(Err_RGPLT)
                  <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr" colspan="2"><input name="plantNumber" type="text" value="$(V_RGPLT)" size="5" maxlength="3"> $(reqFieldChar) <a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=plantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="plantName" value="$(plantName)" type="text" size="25"></td>
                      %else
                          <td class="inputnmbr" colspan="2"><input name="plantNumber" type="hidden" value="$(V_RGPLT)">$(V_RGPLT) &nbsp; $(plantName)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_RGPLT)

                  @SetTextOvr(Err_RGGPID)
                  <tr><td class="dsphdr"><span $(textOvr)>Group ID</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="groupID" type="text" value="$(V_RGGPID)" size="5" maxlength="5"> $(reqFieldChar) </td>
                      %else
                          <td class="inputalph"><input name="groupID" type="hidden" value="$(V_RGGPID)" size="5" maxlength="5">$(V_RGGPID)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_RGGPID)

                  @SetTextOvr(Err_RGTFET)
                  <tr><td class="dsphdr"><span $(textOvr)>Target Feature</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="targetFeature" type="text" value="@dtw_rqhtmlencode($(V_RGTFET))" size="15" maxlength="15"> $(reqFieldChar) <a href="$(homeURL)$(cGIPath)FeatureSearch.d2w/ENTRY$(genericVarBase)&amp;includeBiLevels=Y&amp;docName=Chg&amp;fldPlant=plantNumber&amp;fldPltName=plantName&amp;fldName=targetFeature&amp;fldDesc=targetFeatureDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input disabled name="targetFeatureDesc" value="$(targetFeatureDesc)"  type="text" size="30"> </td>
                      %else
                          <td class="inputalph"><input name="targetFeature" type="hidden" value="@dtw_rqhtmlencode($(V_RGTFET))" size="15" maxlength="15">$(V_RGTFET)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_RGTFET)

                  @SetTextOvr(Err_RGTOPT)
                  <tr><td class="dsphdr"><span $(textOvr)>Target Option</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="targetOption" type="text" value="@dtw_rqhtmlencode($(V_RGTOPT))" size="15" maxlength="15"><a href="$(homeURL)$(cGIPath)OptionSearch.d2w/ENTRY$(genericVarBase)&amp;includeBiLevels=Y&amp;docName=Chg&amp;fldPlant=plantNumber&amp;fldPltName=plantName&amp;fldName=targetOption&amp;fldDesc=targetOptionDesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input disabled name="targetOptionDesc" value="$(targetOptionDesc)"  type="text" size="30"></td>
                      %else
                          <td class="inputalph"><input name="targetOption" type="hidden" value="@dtw_rqhtmlencode($(V_RGTOPT))" size="15" maxlength="15">$(V_RGTOPT)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_RGTOPT)

                  @SetTextOvr(Err_RGRGDS)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="groupDesc" type="text" value="@dtw_rqhtmlencode($(V_RGRGDS))" size="25" maxlength="30"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_RGRGDS)

                  @RtvFldDesc("FLTYPE='RULE' and FLVALU='$(V_RGRULE)'", "SYFLAG", "FLDESC", ruledesc)
                  @SetTextOvr(Err_RGRULE)
                  <tr><td class="dsphdr"><span $(textOvr)>Include/Exclude</span></td>
                      <td class="inputalph"><input name="ieRule" type="text" value="$(V_RGRULE)" size="5" maxlength="1"> $(reqFieldChar) <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=RULE&amp;flagSrchHdr=@dtw_rurlescseq("Include/Exclude Rule")&amp;docName=Chg&amp;fldName=ieRule&amp;fldDesc=ruledesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="ruledesc" value="$(ruledesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_RGRULE)

              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(10)    userProfile,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDRGM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(groupID)
  @dtw_mUPPERCASE(targetFeature)
  @dtw_mUPPERCASE(targetOption)
  @dtw_mUPPERCASE(ieRule)

  @dtw_assign(plantNumber, @dtw_rstrip(plantNumber))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@gpid", groupID)
  @Concat_Field("@@tfet", targetFeature)
  @Concat_Field("@@topt", targetOption)
  @Concat_Field("@@rgds", groupDesc)
  @Concat_Field("@@rule", ieRule)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(userProfile, maintenanceCode, errFound, edtVar, errVar)

  @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(groupDesc), $(groupID), $(plantName), $(plantNumber), "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)FeatureOptionRuleGroupID.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(fromPlant)&amp;plantName=@dtw_rurlescseq(fromName)&amp;backHome=@dtw_rurlescseq(backHome)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@plt@", "plantNumber")
      @Format_ConfMsg_Desc("", $(groupDesc), $(groupID), $(plantName), $(plantNumber), "<br>$(fieldValue)", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)FeatureOptionRuleGroupID.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(fromPlant)&amp;plantName=@dtw_rurlescseq(fromName)&amp;backHome=@dtw_rurlescseq(backHome)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;groupID=@dtw_rurlescseq(groupID)&amp;targetFeature=@dtw_rurlescseq(targetFeature)&amp;targetOption=@dtw_rurlescseq(targetOption)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
