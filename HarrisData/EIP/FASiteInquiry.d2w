%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"

%Define {	
  page_title              = "Asset Site Inquiry"
  d2wName                 = "FASiteInquiry.d2w"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
%}
	
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onLoad="window.focus()" onBlur="window.close()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      @dtw_assign(uv_SiteName, "ACLOCN")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "SELECT * ", stmtSQL)
                      @dtw_concat(fileSQL, " FASITE ", fileSQL)
                      @dtw_concat(selectSQL, " ACLOCN=$(siteNumber) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      @Display_Inquiry(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) Display_Inquiry (IN CHAR(64) profileHandle,
                                       CHAR(2)   dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(displayCloseIcon, "Y")
      %INCLUDE "PageTitle.icl"

      $(inquiryhrTagAttr)

      <table $(contentTable)>
          %ROW{
              <tr><td class="dspalph">$(V_ACLONM)</td>
                  <td class="dsphdr">Asset Site:</td>
                  <td class="dspnmbr">$(V_ACLOCN)</td></tr>

              @Format_CoFac("$(V_ACCO#)", "$(V_ACFAC#)", "", F_CoFac)
              <tr><td class="dspalph">$(V_ACLOAD)</td>
                  <td class="dsphdr">Company/Facility: </td>
                  <td class="dspnmbr">$(F_CoFac)</td></tr>

              <tr><td class="dspalph">$(V_ACLOA2)</td></tr>

              <tr><td class="dspalph">$(V_ACLOCT), $(V_ACLOST) $(V_ACLOZP)</td></tr>
          %}
      </table>
      $(inquiryhrTagAttr)
      %INCLUDE "CloseWindow.icl"
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}