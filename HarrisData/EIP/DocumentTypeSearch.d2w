%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Document Type Search"
  d2wName                 = "DocumentTypeSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;vendCustFlag=@dtw_rurlescseq(vendCustFlag)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectDocType(documentType, desc){
                  window.opener.document.$(docName).$(fldName).value = documentType;
                  window.opener.document.$(docName).$(fldDesc).value = desc;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select DODOCT, DOAPID, DODESC, upper(DODESC) as DODESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " DOPGID, DOPSEG, DOPLOD, DOPLOC, DOFCPY, DOPBCD,  ", stmtSQL)
                      @dtw_concat(stmtSQL, " DOQDEC, DOQEDT, DOPDEC, DOPEDT, DOCPTL, DOCPT1,  ", stmtSQL)
                      @dtw_concat(stmtSQL, " DOCPT2, DOCPT3, DOCPF1, DOCPF2, DOCPF3, DOCPCL  ", stmtSQL)
                      @dtw_concat(fileSQL, " HDDOCT ", fileSQL)
                      %if (vendCustFlag == "C")
                          @dtw_concat(selectSQL, " (DOAPID='OE' or DOAPID='AR') ", selectSQL)
                      %else
                          @dtw_concat(selectSQL, " (DOAPID='PO' or DOAPID='AP') ", selectSQL)
                      %endif
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, " and DODOCT='$(documentType)'", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Doc_Type_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Doc_Type_Search (IN CHAR(64)    profileHandle,
				        CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr"> Description</th>
                      <th class="colhdr"> Document <br> Type</th>
                  </tr>
                  <tr><td class="inputalph">
                          <input type="text" name="srchDesc" size="30" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td class="inputalph">
                          <input type="text" name="srchDocType" size="7" maxlength="3">
                          <input type="hidden" name="operDocType" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("DODOCT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=documentType" title="Sequence By Document Type"> Document<br>Type</a></th>
                  @OrderBy_Sort("DODESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=desc" title="Sequence By Description, Document Type"> Description</a></th>
                  @OrderBy_Sort("DOPGID", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=progName" title="Sequence By Program Name, Document Type"> Program<br>Name</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %else
          <table $(contentTable)>
      %endif		

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Quote(V_DODOCT, F_DODOCT)
              @Format_Quote(V_DODESC, F_DODESC)

              %if (moreInfo != "Y")	
                  <tr class="$(rowClass)">
                      <td class="colalph">$(V_DODOCT)</td>
                      <td class="colalph"><a href="javascript:selectDocType('$(F_DODOCT)','$(F_DODESC)')" title="Select Document Type">$(V_DODESC)</a></td>
                      <td class="colcode">$(V_DOPGID)</td>
                      <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;documentType=@dtw_rurlescseq(V_DODOCT)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                  </tr>

              %else

                  <tr><td><a href="javascript:selectDocType('$(F_DODOCT)','$(F_DODESC)')" title="Select Document Type">$(selectImageLrg)</a>
                  </td></tr>

                  <tr><td class="dsphdr">Document Type</td>
                      <td class="dspalph">$(V_DODOCT)</td>
                  </tr>
	   		
                  <tr><td class="dsphdr">Description</td>
                      <td class="dspalph">$(V_DODESC)</td>
                  </tr>
    			
                  <tr><td class="dsphdr">Program Name</td>
                      <td class="dspalph">$(V_DOPGID)</td>
                  </tr>
    			
                  <tr><td class="dsphdr">Page Segment Name</td>
                      <td class="dspalph">$(V_DOPSEG)</td>
                  </tr>
    			
                  @RtvYNDesc($(V_DOPLOD), fieldDesc)
                  <tr><td class="dsphdr">Print Location On Document</td>
                      <td class="dspalph">$(fieldDesc)</td>
                  </tr>
               			
                  @RtvYNDesc($(V_DOPLOC), fieldDesc)
                  <tr><td class="dsphdr">Print Location On Faxed Document</td>
                      <td class="dspalph">$(fieldDesc)</td>
                  </tr>
               			
                  @RtvYNDesc($(V_DOFCPY), fieldDesc)
                  <tr><td class="dsphdr">Print File Copy</td>
                      <td class="dspalph">$(fieldDesc)</td>
                  </tr>
               			
                  @RtvYNDesc($(V_DOPBCD), fieldDesc)
                  <tr><td class="dsphdr">Print Bar Codes</td>
                      <td class="dspalph">$(fieldDesc)</td>
                  </tr>
              </table>
			
              <table $(contentTable)>
                  <tr><td class="dsphdr">Print Editing:</td>
                      <td class="dsphdr">Number<br>Of<br>Decimals</td>
                      <td class="dsphdr">Edit<br>Code</td>
                  </tr>
	      		
                  @RtvFldDesc("FLTYPE='EDITCODE' and FLVALU='$(V_DOQEDT)'", "SYFLAG", "FLDESC", fieldDesc)
                  <tr><td class="dsphdr">Quantity</td>
                      <td class="dspalph">$(V_DOQDEC)</td>
                      <td class="dspalph">$(fieldDesc)</td>
                  </tr>
	   		
                  <tr><td class="dsphdr">Price/Cost</td>
                      <td class="dspalph">$(V_DOPDEC)</td>
                      <td class="dspalph">$(fieldDesc)</td>
                  </tr>
              </table>       			

  	           <table $(contentTable)>
                  <tr><td class="dsphdr">Cover Page</td></tr>
	   		
                  <tr><td class="dsphdr">Title Line</td>
                      <td class="dspalph">$(V_DOCPTL)</td>
                  </tr>
	   		
                  <tr><td class="dsphdr">To Line 1</td>
                      <td class="dspalph">$(V_DOCPT1)</td>
                  </tr>
	   		
                  <tr><td class="dsphdr">To Line 2</td>
                      <td class="dspalph">$(V_DOCPT2)</td>
                  </tr>
	   		
                  <tr><td class="dsphdr">To Line 3</td>
                      <td class="dspalph">$(V_DOCPT3)</td>
                  </tr>
	   		
                  <tr><td class="dsphdr">From Line 1</td>
                      <td class="dspalph">$(V_DOCPF1)</td>
                  </tr>
	   		
                  <tr><td class="dsphdr">From Line 2</td>
                      <td class="dspalph">$(V_DOCPF2)</td>
                  </tr>
	   		
                  <tr><td class="dsphdr">From Line 3</td>
                      <td class="dspalph">$(V_DOCPF3)</td>
                  </tr>
	   		
                  <tr><td class="dsphdr">Comment Line</td>
                      <td class="dspalph">$(V_DOCPCL)</td>
                  </tr>
              %endif
          %}
      </table>
      %if (moreInfo != "Y")	
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
      %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "DODESCU,DODOCT")
      @DTW_ASSIGN(orderByDisplay, "Description, Document Type")
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "documentType")
      %if (orderBy == "DODOCT")
          @DTW_ASSIGN(orderBy, "DODOCT DESC")
          @DTW_ASSIGN(orderByDisplay, "Document Type (descending)")
      %else
          @DTW_ASSIGN(orderBy, "DODOCT")
          @DTW_ASSIGN(orderByDisplay, "Document Type")
      %endif
  %elif (sequence == "desc")
      %if (orderBy == "DODESCU,DODOCT")
          @DTW_ASSIGN(orderBy, "DODESCU DESC,DODOCT")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Document Type")
      %else
          @DTW_ASSIGN(orderBy, "DODESCU,DODOCT")
          @DTW_ASSIGN(orderByDisplay, "Description, Document Type")
      %endif
  %elif (sequence == "progName")
      %if (orderBy == "DOPGID,DODOCT")
          @DTW_ASSIGN(orderBy, "DOPGID DESC,DODOCT")
          @DTW_ASSIGN(orderByDisplay, "Program Name (descending), Document Type")
      %else
          @DTW_ASSIGN(orderBy, "DOPGID,DODOCT")
          @DTW_ASSIGN(orderByDisplay, "Program Name, Document Type")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Document Type</td>
                              @dtw_assign(operNbr, "operDocType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchDocType" type="text" size="3" maxlength="3"></td>
                          </tr>
        			
                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchDesc" type="text" size="30" maxlength="30"></td>
                          </tr>
        			
                          <tr><td class="dsphdr">Program Name</td>
                              @dtw_assign(operNbr, "operProgName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchProgName" type="text" size="10" maxlength="10"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDocType.focus();
                          </script>
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("DODOCT", "Document Type", $(srchDocType), "U", operDocType, "A")
  @Build_WildCard ("upper(DODESC)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("DOPGID", "Program Name", $(srchProgName), "U", operProgName, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}