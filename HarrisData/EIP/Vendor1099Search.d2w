%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Vendor 1099 Search"
  d2wName                 = "Vendor1099Search.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
  advanceSearch           = "N"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function select1099Code(v1099Code, v1099Desc){
                  window.opener.document.$(docName).$(fldName).value = v1099Code;
                  window.opener.document.$(docName).$(fldDesc).value = v1099Desc;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select PTPTCD, PTTPDS, PTFOR#, PTBOX#, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(PTTPDS) as PTTPDSU ", stmtSQL)
                      @dtw_concat(fileSQL, " APP109 ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, " PTPTCD<>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Ship_Via_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Ship_Via_Search (IN  CHAR(64) profileHandle,
				         CHAR(2)   dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr">Description</th>
                  <th class="colhdr">1099<br>Code</th>
                  <th class="colhdr">IRS<br>Form</th>
                  <th class="colhdr">Box</th>
              </tr>
              <tr><td class="inputalph">
                      <input type="text" name="srchDesc" size="15" maxlength="25">
                      <input type="hidden" name="operDesc" value="LIKE">
                  </td>
                  <td class="inputalph">
                      <input type="text" name="srch1099Code" size="2" maxlength="2">
                      <input type="hidden" name="oper1099Code" value="LIKE">
                  </td>
                  <td class="inputalph">
                      <input type="text" name="srchForm" size="10" maxlength="10">
                      <input type="hidden" name="operForm" value="LIKE">
                  </td>
                  <td class="inputalph">
                      <input type="text" name="srchBox" size="3" maxlength="3">
                      <input type="hidden" name="operBox" value="LIKE">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
          <script TYPE="text/javascript">
              document.Search.srchDesc.focus();
          </script>
      </form>

      %INCLUDE "WildCardPage.icl"

      <table $(contentTable)>
          <tr>	
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("PTTPDSU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=description" title="Sequence By Description, 1099 Code">Description</a></th>
              @OrderBy_Sort("PTPTCD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=v1099Code" title="Sequence By 1099 Code">1099<br>Code</a></th>
              @OrderBy_Sort("PTFOR#", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=form" title="Sequence By IRS Form, 1099 Code">IRS<br>Form</a></th>
              @OrderBy_Sort("PTBOX#", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=box" title="Sequence By Box, 1099 Code">Box</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Quote(V_PTPTCD, F_PTPTCD)
              @Format_Quote(V_PTTPDS, F_PTTPDS)

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="javascript:select1099Code('$(F_PTPTCD)','$(F_PTTPDS)')" title="Select 1099 Code">$(V_PTTPDS)</a></td>
                  <td class="colcode">$(V_PTPTCD)</td>
                  <td class="colalph">$(V_PTFOR#)</td>
                  <td class="colcode">$(V_PTBOX#)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "PTTPDSU,PTPTCD")
      @DTW_ASSIGN(orderByDisplay, "Description, 1099 Code")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "description")
      %if (orderBy == "PTTPDSU,PTPTCD")
          @DTW_ASSIGN(orderBy, "PTTPDSU DESC,PTPTCD")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), 1099 Code")
      %else
          @DTW_ASSIGN(orderBy, "PTTPDSU,PTPTCD")
          @DTW_ASSIGN(orderByDisplay, "Description, 1099 Code")
      %endif
  %elseif (sequence == "v1099Code")
      %if (orderBy == "PTPTCD")
          @DTW_ASSIGN(orderBy, "PTPTCD DESC")
          @DTW_ASSIGN(orderByDisplay, "1099 Code (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PTPTCD")
          @DTW_ASSIGN(orderByDisplay, "1099 Code")
      %endif
  %elseif (sequence == "form")
      %if (orderBy == "PTFOR#,PTPTCD")
          @DTW_ASSIGN(orderBy, "PTFOR# DESC,PTPTCD")
          @DTW_ASSIGN(orderByDisplay, "IRS Form (descending), 1099 Code")
      %else
          @DTW_ASSIGN(orderBy, "PTFOR#,PTPTCD")
          @DTW_ASSIGN(orderByDisplay, "IRS Form, 1099 Code")
      %endif
  %elseif (sequence == "box")
      %if (orderBy == "PTBOX#,PTPTCD")
          @DTW_ASSIGN(orderBy, "PTBOX# DESC,PTPTCD")
          @DTW_ASSIGN(orderByDisplay, "Box (descending), 1099 Code")
      %else
          @DTW_ASSIGN(orderBy, "PTBOX#,PTPTCD")
          @DTW_ASSIGN(orderByDisplay, "Box, 1099 Code")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("upper(PTTPDS)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("PTPTCD", "1099 Code", $(srch1099Code), "U", oper1099Code, "A")
  @Build_WildCard ("PTFOR#", "IRS Form", $(srchForm), "U", operForm, "A")
  @Build_WildCard ("PTBOX#", "Box Number", $(srchBox), "U", operBox, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}