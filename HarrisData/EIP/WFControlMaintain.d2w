%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Workflow Control Maintenance"
  d2wName                 = "WFControlMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName             = "HWFCTU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function confirmDelete() {return confirm("$(delRecordConf)")}
              function validate(chgForm) {
                  if (document.Chg.dataQueueJobs.value =="" ||
                      document.Chg.maxWorkItems.value =="" ||
                      document.Chg.maxDelegate.value =="" ||
                      document.Chg.medium.value =="" ||
                      document.Chg.sendNotify.value ==""  )
                         {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.dataQueueJobs, 2, 0) &&
                      editNum(document.Chg.maxWorkItems, 5, 0) &&
                      editNum(document.Chg.maxDelegate, 5, 0)
                      )
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFCONTROLMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " WFCTRL ", fileSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @dtw_assign(sec_01, sec_02)

      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "dataQueueJobs")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@dqjb", "dataQueueJobs")         @dtw_assign(Err_WFDQJB, fieldValue)
                          @DecatErr_Field("@@maxi", "maxWorkItems")          @dtw_assign(Err_WFMAXI, fieldValue)
                          @DecatErr_Field("@@maxd", "maxDelegate")           @dtw_assign(Err_WFMAXD, fieldValue)
                          @DecatErr_Field("@@medm", "medium")                @dtw_assign(Err_WFMEDM, fieldValue)
                          @DecatErr_Field("@@send", "sendNotify")            @dtw_assign(Err_WFSEND, fieldValue)
                          @DecatErr_Field("@@dprt", "defaultParticipant")    @dtw_assign(Err_WFDPRT, fieldValue)
                          @DecatErr_Field("@@urlp", "urlPath")               @dtw_assign(Err_WFURLP, fieldValue)
                          @DecatErr_Field("@@base", "wfBaseVariable")        @dtw_assign(Err_WFBASE, fieldValue)
                      %endif

                      @Decat_Field("@@dqjb")   @dtw_assign(V_WFDQJB, fieldValue)
                      @Decat_Field("@@maxi")   @dtw_assign(V_WFMAXI, fieldValue)
                      @Decat_Field("@@maxd")   @dtw_assign(V_WFMAXD, fieldValue)
                      @Decat_Field("@@medm")   @dtw_assign(V_WFMEDM, fieldValue)
                      @Decat_Field("@@send")   @dtw_assign(V_WFSEND, fieldValue)
                      @Decat_Field("@@dprt")   @dtw_assign(V_WFDPRT, fieldValue)
                      @Decat_Field("@@urlp")   @dtw_assign(V_WFURLP, fieldValue)
                      @Decat_Field("@@base")   @dtw_assign(V_WFBASE, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "dataQueueJobs")
                          @dtw_assign(V_WFMAXD, "1")
                          @dtw_assign(V_WFMEDM, "*NONE")
                          @dtw_assign(V_WFSEND, "A")
                      %endif

                      @dtw_assign(errFound, "")

                  %else
                      @dtw_assign(focusField, "dataQueueJobs")
                  %endif

                  @SetTextOvr(Err_WFDQJB)
                  <tr><td class="dsphdr"><span $(textOvr)>Number Of Data Queue Processing Jobs</span></td>
                      <td class="inputnmbr"><input type="text" name="dataQueueJobs" value="$(V_WFDQJB)" size="10" maxlength="2">$(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_WFDQJB)

                  @SetTextOvr(Err_WFMAXI)
                  <tr><td class="dsphdr"><span $(textOvr)>Maximum Work Items For An Instance</span></td>
                      <td class="inputnmbr"><input type="text" name="maxWorkItems" value="$(V_WFMAXI)" size="10" maxlength="5">$(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_WFMAXI)

                  @SetTextOvr(Err_WFMAXD)
                  <tr><td class="dsphdr"><span $(textOvr)>Maximum Attempts For Delegation</span></td>
                      <td class="inputnmbr"><input type="text" name="maxDelegate" value="$(V_WFMAXD)" size="10" maxlength="5">$(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_WFMAXD)

                  @RtvFldDesc("MDMEDM='$(V_WFMEDM)'", "WFMEDM", "MDDESC", fieldDesc)
                  @SetTextOvr(Err_WFMEDM)
                  <tr><td class="dsphdr"><span $(textOvr)>Medium</span></td>
                      <td class="inputalph"><input type="text" name="medium" value="$(V_WFMEDM)" size="10" maxlength="10">
                                            <a href="$(homeURL)$(cGIPath)WFMediumSearch.d2w/REPORT$(genericVarBase)&amp;docName=Chg&amp;fldName=medium&amp;fldDesc=mediumDesc" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage)</a>
                                            <input type="text" disabled name="mediumDesc" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_WFMEDM)

                  @RtvFldDesc("FLTYPE='WFSEND' and FLVALU='$(V_WFSEND)'", "SYFLAG", "FLDESC", fieldDesc)
                  @SetTextOvr(Err_WFSEND)
                  <tr><td class="dsphdr"><span $(textOvr)>Send Notification</span></td>
                      <td class="inputalph"><input type="text" name="sendNotify" value="$(V_WFSEND)" size="10" maxlength="1">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=WFSEND&amp;flagSrchHdr=@dtw_rurlescseq("Send Notification")&amp;docName=Chg&amp;fldName=sendNotify&amp;fldDesc=sendNotifyDesc" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage)</a>
                                            <input type="text" disabled name="sendNotifyDesc" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_WFSEND)

                  @SetTextOvr(Err_WFDPRT)
                  @RtvFldDesc("USUSER='$(V_WFDPRT)' ", "SYUSER", "USDESC", fieldDesc)
                  <tr><td class="dsphdr"><span $(textOvr)>Default Participant</span></td>
                      <td class="inputalph"><input type="text" name="defaultParticipant" value="$(V_WFDPRT)" size="10" maxlength="10">
                                            <a href="$(homeURL)$(phpPath)UserSearch.php$(altVarBase)&amp;docName=Chg&amp;userFld=defaultParticipant&amp;descFld=userName" onclick="$(searchWinVar)">$(searchImage)</a>
                                            <input type="text" disabled name="userName" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_WFDPRT)

                  @SetTextOvr(Err_WFURLP)
                  <tr><td class="dsphdr"><span $(textOvr)>URL Path</span></td>
                      <td class="inputalph"><input type="text" name="urlPath" value="$(V_WFURLP)" size="50" maxlength="512"></td>
                  </tr>
                  @DspErrMsg(Err_WFURLP)

                  @SetTextOvr(Err_WFBASE)
                  <tr><td class="dsphdr"><span $(textOvr)>Base Variable</span></td>
                      <td class="inputalph"><input type="text" name="wfBaseVariable" value="$(V_WFBASE)" size="50" maxlength="50"></td>
                  </tr>
                  @DspErrMsg(Err_WFBASE)
              %}
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HWFCTU_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (sec_02 == "N")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @RtvFldDesc("", "WFCTRL", "Char(Count(*))", RecCount)
      %if (RecCount>"0")
          @dtw_assign(maintenanceCode,"C")
      %else
          @dtw_assign(maintenanceCode,"A")
      %endif

      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @dtw_mUPPERCASE(medium)
  @dtw_mUPPERCASE(sendNotify)
  @dtw_mUPPERCASE(defaultParticipant)

  @dtw_assign(dataQueueJobs,@dtw_rstrip(dataQueueJobs))
  @dtw_assign(maxWorkItems,@dtw_rstrip(maxWorkItems))
  @dtw_assign(maxDelegate,@dtw_rstrip(maxDelegate))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@dqjb", dataQueueJobs)
  @Concat_Field("@@maxi", maxWorkItems)
  @Concat_Field("@@maxd", maxDelegate)
  @Concat_Field("@@medm", medium)
  @Concat_Field("@@send", sendNotify)
  @Concat_Field("@@dprt", defaultParticipant)
  @Concat_Field("@@urlp", urlPath)
  @Concat_Field("@@base", wfBaseVariable)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, "", "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(backHome)$(genericVarBase)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
