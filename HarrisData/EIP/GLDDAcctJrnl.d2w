%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Account Journals"
  d2wName                 = "GLDDAcctJrnl.d2w"
  d2wVarBase              = "$(genericVarBase)$(glDDVarBase)&amp;accountNumber=@dtw_rurlescseq(accountNumber)&amp;subAccount=@dtw_rurlescseq(subAccount)&amp;coNumber=@dtw_rurlescseq(coNumber)&amp;facNumber=@dtw_rurlescseq(facNumber)&amp;accountAmount=@dtw_rurlescseq(accountAmount)&amp;fromPer=@dtw_rurlescseq(fromPer)&amp;toPer=@dtw_rurlescseq(toPer)&amp;columnValue=@dtw_rurlescseq(columnValue)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  acctName                = ""
  balanceIncome           = ""
  currencyUnit            = ""
  currencyType            = ""
  uv_Sql                  = ""
  V_DDUNPS                = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %if (ddReport == "") 
      @dtw_assign(V_DDUNPS, "N") 
  %else 
      @RtvFldDesc("DDGRSN='$(ddReport)'", "GLDDRP", "DDUNPS", V_DDUNPS)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <link rel=stylesheet type="text/css" href="$(homeURL)$(homePath)$(GLDDStyleSheet)">
          <script TYPE="text/javascript">
	       %INCLUDE "DateEdit.icl"
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchPeriod, 4, 0) &&
                      editdate(document.Search.srchDate) &&
                      editNum(document.Search.srchAmt, 13, 2))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      @dtw_assign(uv_CompanyName, "TDCO")
                      @dtw_assign(uv_FacilityName, "TDFAC")
                      @dtw_assign(uv_AccountName, "TDACCT")
                      @dtw_assign(uv_SubaccountName, "TDSUB")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "SELECT GLTRDT.*, FLDESC, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(TJTTYP,' ') as TJTTYP ", stmtSQL)
                      @dtw_concat(fileSQL, " GLTRDT ", fileSQL)
                      @dtw_concat(fileSQL, " left join GLTRJL on TJJRNL=TDJRNL and TJPER#=TDPER# and TJTDTE=TDTDTE and TJJSEQ=TDJSEQ ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG on FLTYPE='GLTRANTYP' and FLVALU=TJTTYP ", fileSQL)
                      @dtw_concat(selectSQL, " TDCO=$(coNumber) and TDFAC=$(facNumber) ", selectSQL)
                      @dtw_concat(selectSQL, " and TDACCT=$(accountNumber) and TDSUB=$(subAccount) ", selectSQL)
                      @dtw_concat(selectSQL, " and TDPER# between $(fromPer) and $(toPer) ", selectSQL)

                      %if (V_DDUNPS == "N")
                          @dtw_concat(selectSQL, " and TJSTAT='P'", selectSQL)
                      %endif

                      @RtvFldDesc("DDGRSN='$(ddReport)'", "GLDDRP", "DDEOYA", V_DDEOYA)
                      %if (V_DDEOYA == "N")
                          @dtw_concat(selectSQL, " and TJTTYP<>'YE'", selectSQL)
                      %endif

                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64) profileHandle,
                                   CHAR(2)   dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %if (ddReport != "")
                          <a href="$(homeURL)$(cGIPath)GLDDReport.d2w/REPORT$(genericVarBase)$(glDDVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))" title="Return To Drill Down Report">$(portalHome)</a>
                      %endif
                      <a href="$(homeURL)$(cGIPath)$(d2wName)/ENTRY$(d2wVarBase)&amp;formatToPrint=Y" target=_blank>$(formatPrintDesc)</a>
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
          %if (uv_Sql != "")
              <tr><td><h3> You may not be authorized to view some transactions </h3></td></tr>
          %endif
      </table>

      $(inquiryhrTagAttr)

      <table $(contentTable)>
          <tr><th class="colhdr">Co/Fac</th>
              <th class="colhdr">Name</th>
              <th class="colhdr">Account</th>
              <th class="colhdr">Account Name</th>
              <th class="colhdr">Type</th>
              <th class="colhdr">Usage</th>
              %if (V_HDMCRL > "0")
                  <th class="colhdr">Cur</th>
              %endif
              <th class="colhdr">Amount</th>
              %if (columnValue=="")
                  <th class="colhdr"> Opening Balance</th>
              %endif
          </tr>

          @Retrieve_AcctJrnl_Data(profileHandle,
                                 dataBaseID,
                                 coNumber,
                                 facNumber,
                                 accountNumber,
                                 subAccount,
                                 fromPer,
                                 toPer,
                                 V_DDUNPS,
                                 acctName,
                                 coFacName,
                                 balanceIncome,
                                 currencyUnit,
                                 currencyType,
                                 beginBal)

          @Format_Acct("$(accountNumber)", "$(subAccount)", "", F_AcctSub)
          @Format_CoFac("$(coNumber)", "$(facNumber)", "", F_CoFac)
          %INCLUDE "SetRowClass.icl"
          <tr class="$(rowClass)">
              <td class="colnmbr">$(F_CoFac)</td>
              <td class="colalph">$(coFacName)</td>
              <td class="colnmbr">$(F_AcctSub)</td>
              <td class="colalph">$(acctName)</td>
              <td class="colalph">$(balanceIncome)</td>
              <td class="colalph">$(currencyUnit) </td>
              %if (V_HDMCRL > "0")
                  <td class="colalph">$(currencyType) </td>
              %endif
              <td class="colnmbr">$(accountAmount)</td>
              %if (columnValue=="")
                  @Format_Nbr($(beginBal), F_beginBal, "2", $(amtEditCode), "Y", "", "")
                  <td class="colnmbr">$(F_beginBal)</td>
              %endif
          </tr>
      </table>

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST name="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Journal</th>
                      <th class="colhdr">Type</th>
                      <th class="colhdr">Reference</th>
                      <th class="colhdr">Period</th>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">Date</th>
                      <th class="colhdr">Amount</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchJrnl" size="6" maxlength="6">
                          <input type="hidden" name="operJrnl" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchType" size="2" maxlength="2">
                          <input type="hidden" name="operType" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchRef" size="7" maxlength="7">
                          <input type="hidden" name="operRef" value="LIKE">
                      </td>
                      <td><input type="text" class="inputnmbr"  name="srchPeriod" size="4" maxlength="4">
                          <input type="hidden" name="operPeriod" value="=">
                      </td>
                      <td><input type="text" class="inputalph" name="srchDesc" size="20" maxlength="20">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputnmbr"  name="srchDate" size="6" maxlength="6">
                          <input type="hidden" name="operDate" value="=">
                      </td>
                      <td><input type="text" class="inputnmbr"  name="srchAmt" size="15" maxlength="15">
                          <input type="hidden" name="operAmt" value="=">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchJrnl.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
     %endif

      <table $(contentTable)>
          <tr>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("TDJRNL", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Journal" title="Sequence By Journal, Date, Sequence"> Journal</a></th>
              @OrderBy_Sort("TJTTYP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Type" title="Sequence By Transaction Type, Date, Journal, Sequence"> Type</a></th>
              @OrderBy_Sort("TDREF", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Reference" title="Sequence By Reference, Date, Journal, Sequence"> Reference</a></th>
              @OrderBy_Sort("TDPER#", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Period" title="Sequence By Period, Date, Journal, Sequence"> Period</a></th>
              @OrderBy_Sort("TDDESC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Description, Date, Journal, Sequence"> Description</a></th>
              @OrderBy_Sort("TDTDTE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Date" title="Sequence By Date, Journal, Sequence"> Date</a></th>
              @OrderBy_Sort("TDAMT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Amount" title="Sequence By Amount, Date, Journal, Sequence"> Amount</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{

              %INCLUDE "SetRowClass.icl"

              @dtw_assign(glDate, V_TDTDTE)
              @dtw_assign(glPer, V_TDPER#)

              @PeriodFromCYP(V_TDPER#)
              @Format_Nbr($(V_TDAMT), F_TDAMT, "2", $(amtEditCode), "Y", "", "")
              @Format_Date(V_TDTDTE, "D", F_TDTDTE)

              %if (V_TDAPID=="IV" || V_TDAPID=="PO")
                  @RtvFldDesc("TTTYPE='$(V_TDREF)'", "HDTTYP", "TTDESC", referenceDesc)
              %else
                  @RtvFldDesc("FLTYPE='$(V_TDAPID)FEED' and FLVALU='$(V_TDREF)'", "SYFLAG", "FLDESC", referenceDesc)
                  %if (referenceDesc == "" && V_TDAPID=="AP")
                      @RtvFldDesc("VMVEND=$(V_TDREF)", "HDVEND", "VMVNA1", referenceDesc)
                  %elif (referenceDesc == "" && V_TDAPID=="AR")
                      @RtvFldDesc("CMCUST=$(V_TDREF)", "HDCUST", "CMCNA1", referenceDesc)
                  %endif
              %endif

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)GLDDGLJrnl.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;glJrnl=@dtw_rurlescseq(V_TDJRNL)&amp;glPer=@dtw_rurlescseq(glPer)&amp;glDate=@dtw_rurlescseq(glDate)&amp;glJrnlSeq=@dtw_rurlescseq(V_TDJSEQ)" title="View General Ledger Journal">$(V_TDJRNL)</a></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_FLDESC)">$(V_TJTTYP)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(referenceDesc)">$(V_TDREF)</span></td>
                  <td class="colnmbr">$(V_TDPER#)</td>
                  <td class="colalph">$(V_TDDESC)</td>
                  <td class="coldate">$(F_TDTDTE)</td>
                  %if (V_TDDDSQ != "0" && V_TDDDPG == "")
                      @RtvFldDesc("DPAPID='$(V_TDAPID)' and DPDDFL='$(V_TDDDFL)'", "GLDDPG", "DPPGM", V_DPPGM)
                      %if (V_DPPGM != "")
                          @RtvFldDesc("DPAPID='$(V_TDAPID)' and DPDDFL='$(V_TDDDFL)'", "GLDDPG", "DPTITL", V_DPTITL)
                          <td class="colnmbr"><a href="$(homeURL)$(phpPath)$(V_DPPGM).php$(altVarBase)$(glDDVarBase)&amp;glJrnl=@dtw_rurlescseq(V_TDJRNL)&amp;glPer=@dtw_rurlescseq(glPer)&amp;glDate=@dtw_rurlescseq(glDate)&amp;glJrnlSeq=@dtw_rurlescseq(V_TDJSEQ)&amp;glJrnlRec=@dtw_rurlescseq(V_TDREC)&amp;glDDSeq=@dtw_rurlescseq(V_TDDDSQ)&amp;glDDAp=@dtw_rurlescseq(V_TDAPID)&amp;glDDFile=@dtw_rurlescseq(V_TDDDFL)" title="$(V_DPTITL)">$(F_TDAMT)</a></td>
                      %else
                          <td class="colnmbr">$(F_TDAMT)</td>
                      %endif
                  %else
                      <td class="colnmbr">$(F_TDAMT)</td>
                  %endif
                  %if (V_TDSEQ# != "0")
                      <td class="colicon"><a href="$(homeURL)$(cGIPath)GLDDAcctJrnlComment.d2w/ENTRY$(genericVarBase)&amp;glJrnl=@dtw_rurlescseq(V_TDJRNL)&amp;glPer=@dtw_rurlescseq(glPer)&amp;glDate=@dtw_rurlescseq(glDate)&amp;glJrnlSeq=@dtw_rurlescseq(V_TDJSEQ)&amp;glJrnlRec=@dtw_rurlescseq(V_TDREC)&amp;glLdSeq=@dtw_rurlescseq(V_TDSEQ#)" onclick="$(commentWinVar)">$(commentView)</a></td>
                  %endif
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(inquiryhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderByDisplay, "Date, Journal, Sequence")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Journal")
      %if (orderBy == "TDJRNL,TDTDTE,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderBy, "TDJRNL DESC,TDTDTE DESC,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderByDisplay, "Journal (descending), Date (descending), Sequence")
      %else
          @DTW_ASSIGN(orderBy, "TDJRNL,TDTDTE,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderByDisplay, "Journal, Date, Sequence")
      %endif
  %elif (sequence == "Type")
      %if (orderBy == "TJTTYP,TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderBy, "TJTTYP DESC,TDTDTE DESC,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderByDisplay, "Transaction Type (descending), Date (descending), Journal, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "TJTTYP,TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderByDisplay, "Transaction Type, Date, Journal, Sequence")
      %endif
  %elif (sequence == "Reference")
      %if (orderBy == "TDREF,TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderBy, "TDREF DESC,TDTDTE DESC,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderByDisplay, "Reference (descending), Date (descending), Journal, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "TDREF,TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderByDisplay, "Reference, Date, Journal, Sequence")
      %endif
  %elif (sequence == "Period")
      %if (orderBy == "TDPER#,TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderBy, "TDPER# DESC,TDTDTE DESC,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderByDisplay, "Period (descending), Date (descending), Journal, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "TDPER#,TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderByDisplay, "Period, Date, Journal, Sequence")
      %endif
  %elif (sequence == "Description")
      %if (orderBy == "TDDESC,TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderBy, "TDDESC DESC,TDTDTE DESC,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Date (descending), Journal, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "TDDESC,TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderByDisplay, "Description, Date, Journal, Sequence")
      %endif
  %elif (sequence == "Date")
      %if (orderBy == "TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderBy, "TDTDTE DESC,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderByDisplay, "Date (descending), Journal, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderByDisplay, "Date, Journal, Sequence")
      %endif
  %elif (sequence == "Amount")
      %if (orderBy == "TDAMT,TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderBy, "TDAMT DESC,TDTDTE DESC,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderByDisplay, "Amount (descending), Date (descending), Journal, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "TDAMT,TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(orderByDisplay, "Amount, Date, Journal, Sequence")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <link rel=stylesheet type="text/css" href="$(homeURL)$(homePath)$(GLDDStyleSheet)">
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchPeriod, 4, 0) &&
                      editdate(document.Search.srchDate) &&
                      editNum(document.Search.srchAmt, 13, 2))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      %INCLUDE "SearchPageTitle.icl"
                      $(inquiryhrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Journal</td>
                              @dtw_assign(operNbr, "operJrnl")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchJrnl" size="6" maxlength="6"></td>
                          </tr>

                          <tr><td class="dsphdr">Type</td>
                              @dtw_assign(operNbr, "operType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchType" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Reference</td>
                              @dtw_assign(operNbr, "operRef")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchRef" size="7" maxlength="7"></td>
                          </tr>

                          <tr><td class="dsphdr">Period</td>
                              @dtw_assign(operNbr, "operPeriod")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchPeriod" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Date</td>
                              @dtw_assign(operNbr, "operDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchDate" size="6" maxlength="6"><a href="javascript:calWindow('srchDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Amount</td>
                              @dtw_assign(operNbr, "operAmt")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchAmt" size="15" maxlength="15"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchJrnl.focus();
                          </script>
                      </form>
                      $(inquiryhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("TDJRNL", "Journal", $(srchJrnl), "U", operJrnl, "A")
  @Build_WildCard ("TJTTYP", "Type", $(srchType), "U", operType, "A")
  @Build_WildCard ("TDREF", "Reference", $(srchRef), "U", operRef, "A")
  @Build_WildCard ("TDPER#", "Period", $(srchPeriod), "", operPeriod, "DP")
  @Build_WildCard ("upper(TDDESC)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("TDTDTE", "Date", $(srchDate), "", operDate, "D")
  @Build_WildCard ("TDAMT", "Amount", $(srchAmt), "", operAmt, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
