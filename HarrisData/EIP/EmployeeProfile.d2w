%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "QuickLink.icl"

%Define {
  page_title           = "Employee Profile"
  d2wName              = "EmployeeProfile.d2w"
  attachFolder         = "Employee"
  d2wVarBase           = "$(genericVarBase)$(employeeVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(d2wName)"
  deactivateURL        = "$(homeURL)$(cGIPath)EmplMaintainDem.d2w/Edit_Data$(d2wVarBase)&amp;reportName=@dtw_rurlescseq(reportName)&amp;maintenanceCode=Y"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  RPT_MAX_ROWS	        = "99"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  imageExists          = ""
  prtMaxRows           = "$(prtMaxRowsDft)"
  prUserPass           = ""
  rowIndexNext	        = "1"
  showError            = "N"
  totalPages	        = "0"	
  EMU_01               = ""
  EMU_02               = ""
  EMU_03               = ""
  EMU_05               = ""
  EMU_06               = ""
  EMU_07               = ""
  EMU_08               = ""
  EMU_09               = ""
  EMU_10               = ""
  EMU_11               = ""
  EMU_12               = ""
  PTE_01               = ""
  PTE_05               = ""
  PTE_14               = ""
  SDU_05               = ""
  ECU_05               = ""
  EDM_05               = ""
  EDM_06               = ""
  EDM_07               = ""
  quickLinkByUser      = "Y"
  dataType             = "SSNO"
  modeD                = "D"
  modeI                = "I"

%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @dtw_assign(applicationID, "PR")
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>

          <head>  	
              @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
              @dtw_assign(title, $(F_EmpName))
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
                  function confirmDeactivatePR() {return confirm("OK to deactivate in Payroll?")}
                  function confirmDeactivateHR() {return confirm("OK to deactivate in Human Resources?")}
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "EMPLOYEEPROFILE")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          @dtw_assign(programName, "HPEPTE")
                          @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                          @dtw_assign(PTE_01, sec_01)
                          @dtw_assign(PTE_05, sec_05)
                          @dtw_assign(PTE_14, sec_14)

                          @dtw_assign(programName, "HPESDU")
                          @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                          @dtw_assign(SDU_05, sec_05)

                          @dtw_assign(programName, "HPEECU")
                          @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                          @dtw_assign(ECU_05, sec_05)

                          @dtw_assign(programName, "HHREDM")
                          @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                          @dtw_assign(EDM_05, sec_05)
                          @dtw_assign(EDM_06, sec_06)
                          @dtw_assign(EDM_07, sec_07)

%{ QuickLink Table %}     %INCLUDE "QuickLinkTable.icl"

%{ QuickLink By User %}   %INCLUDE "QuickLinkByUser.icl"

%{ Employee Heading %}
                          @dtw_assign(RPT_MAX_ROWS, "99")
                          @dtw_assign(dspMaxRows, "10")
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select *", stmtSQL)
                          @dtw_concat(fileSQL, " HREMPL inner join PEEMPL on EMPECP=EPCOMP and EMPEMP=EPEMPL ", fileSQL)
                          @dtw_concat(selectSQL, " EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMPECP=$(hrCompany) and EMEMPL=$(prEmployee) and EMPEMP=$(hrEmployee)", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Employee_Profile_Header(profileHandle, dataBaseID, stmtSQL)

                          @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMTYPE", PAYTYPECODE)
%{ Quicklink Begin %}     %INCLUDE "QuickLinkBegLoop.icl"

     %{demographics - H/R %}
                              %if (quicklinkRef == "demographics")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select EMCOMP, EMFACL, EMEMPL, EMPECP, EMPEMP, EMRNAM, EMLNAM, EMFNAM, EMMIDI, EMADR1, EMADR2, EMCITY, EMSTAT, EMZIP, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " EMCNTR, EMPROV, EMPHON, EMLOC, EMDEPT, EMDOB, EMSSNO, EMSSSF, EMGNDR, EMMSTA, EMNODP, EMHIRE, EMSTRT, EMSENR, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " EMCTZN, EMALRG, EMJOB, EMEEO, EMUNCD, EMUNMN, EMSHFT, EMANHR, EMSCHD, EMPLNT, EMMDPT, EMWC, EMHGRP, EMUSR1, EMUSR2, EMUSR3, EMUSR4, EMUSR5, EMUSR6 ", stmtSQL)
                                  @dtw_concat(fileSQL, " HREMPL ", fileSQL)
                                  @dtw_concat(selectSQL, " EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMPECP=$(hrCompany) and EMEMPL=$(prEmployee) and EMPEMP=$(hrEmployee)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Employee_Profile_Demographics(profileHandle, dataBaseID, stmtSQL)

     %{accruals - H/R %}
                              %elif ((EMU_08 == "Y") &&  (quicklinkRef == "accruals"))
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HREMPL ", fileSQL)
                                  @dtw_concat(selectSQL, " EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMPECP=$(hrCompany) and EMEMPL=$(prEmployee) and EMPEMP=$(hrEmployee)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Employee_Profile_Accruals(profileHandle, dataBaseID, stmtSQL)

     %{vacationsick %}
                              %elif ((EMU_05 == "Y") &&  (quicklinkRef == "vacationsick"))
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HREMPL ", fileSQL)
                                  @dtw_concat(selectSQL, " EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMPECP=$(hrCompany) and EMEMPL=$(prEmployee) and EMPEMP=$(hrEmployee)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Employee_Profile_VacationSick(profileHandle, dataBaseID, stmtSQL)

     %{payinformation - H/R %}
                              %elif (((PAYTYPECODE == "H" && EMU_06 == "Y") || (PAYTYPECODE != "H" && EMU_07 == "Y")) && (quicklinkRef == "payinformation"))
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "Select EMCOMP, EMFACL, EMEMPL, EMPECP, EMPEMP, EMTYPE, EMEXMT, EMFREQ, EMAMT, EMSRCD, EMHCE, EMDLIN, EMOVTM, EMOFCR, EMKEYE, EMBGRP ", stmtSQL)
                                  @dtw_concat(fileSQL, " HREMPL ", fileSQL)
                                  @dtw_concat(selectSQL, " EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMPECP=$(hrCompany) and EMEMPL=$(prEmployee) and EMPEMP=$(hrEmployee)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Employee_Profile_Payinformation(profileHandle, dataBaseID, stmtSQL)

     %{cobra - H/R %}
                              %elif ((EMU_09 == "Y") && (quicklinkRef == "cobra"))
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "Select EMCOMP, EMFACL, EMEMPL, EMPECP, EMPEMP, EMMGN, EMMCN, EMMVN, EMGNID, EMGNLN, EMCBAC, EMCBTD, EMCBTC, EMCACP ", stmtSQL)
                                  @dtw_concat(fileSQL, " HREMPL ", fileSQL)
                                  @dtw_concat(selectSQL, " EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMPECP=$(hrCompany) and EMEMPL=$(prEmployee) and EMPEMP=$(hrEmployee)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Employee_Profile_Cobra(profileHandle, dataBaseID, stmtSQL)

     %{humanresources - H/R %}
                              %elif ((EMU_10 == "Y") && (quicklinkRef == "humanresources"))
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " PEEMPL ", fileSQL)
                                  @dtw_concat(selectSQL, " EPCOMP=$(hrCompany) and EPEMPL=$(hrEmployee)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Employee_Profile_HumanResources(profileHandle, dataBaseID, stmtSQL)

     %{payrolltax %}
                              %elif ((EMU_11 == "Y") && (quicklinkRef == "payrolltaxes"))
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT PREMPL.*, coalesce(RXLPE1,0) as RXLPE1, coalesce(RXLPE2,0) as RXLPE2, coalesce(RXERES,'') as RXERES, coalesce(RXW420,'') as RXW420, coalesce(RXSTP2,'') as RXSTP2, coalesce(RXCDAM,0) as RXCDAM, coalesce(RXOTHI,0) as RXOTHI, coalesce(RXDED,0) as RXDED", stmtSQL)
                                  @dtw_concat(fileSQL, "PREMPL left outer join HREMPL on ERCOMP=EMCOMP and ERFACL=EMFACL and EREMPL=EMEMPL left outer join PREMPLE on EMEMID=RXEMID ", fileSQL)
                                  @dtw_concat(selectSQL, " ERCOMP=$(prCompany) and ERFACL=$(prFacility) and EREMPL=$(prEmployee)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Employee_Profile_PayrollTax(profileHandle, dataBaseID, stmtSQL)

     %{deduction %}
                              %elif ((EDM_05 == "Y") && (quicklinkRef == "payrolldeductions"))
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HREDED inner join HRDEDM on EDDDNO=HVDDNO  ", fileSQL)
                                  @dtw_concat(selectSQL, " EDCOMP=$(prCompany) and EDFACL=$(prFacility) and EDEMPL=$(prEmployee)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Employee_Profile_Deductions(profileHandle, dataBaseID, stmtSQL)

     %{dependent %}
                              %elif ((SDU_05 == "Y") && (quicklinkRef == "dependents"))
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select SDCOMP,SDFACL,SDEMPL,SDLNAM,SDFNAM,SDMIDI,SDREL,SDDOB,SDCLAS, SDSPDP", stmtSQL)
                                  @dtw_concat(fileSQL, " HRSPDP ", fileSQL)
                                  @dtw_concat(selectSQL, " SDCOMP=$(prCompany) and SDFACL=$(prFacility) and SDEMPL=$(hrEmployee)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Employee_Profile_Dependents(profileHandle, dataBaseID, stmtSQL)

     %{benefits %}
                              %elif ((ECU_05 == "Y") && (quicklinkRef == "selectedbenefits"))
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select ECCOVR, CVDESC, ECPLAN, CCDESC, ECEMPL, ECDCE, ECDCT, ECSPDP, CVURLI", stmtSQL)
                                  @dtw_concat(fileSQL, " HREMCV inner join CBCOVR on ECCOMP=CVCOMP and ECFACL=CVFACL and ECCOVR=CVCOVR and ECPLAN=CVPLAN ", fileSQL)
                                  @dtw_concat(fileSQL, "        inner join CBCODE on CVPLAN=CCCODE ", fileSQL)
                                  @dtw_concat(selectSQL, " ECCOMP=$(prCompany) and ECFACL=$(prFacility) and ECEMPL=$(hrEmployee) and ECSPDP=0", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Employee_Profile_Benefits(profileHandle, dataBaseID, stmtSQL)

     %{available benefits %}
                              %elif ((ECU_05 == "Y") && (quicklinkRef == "availablebenefits"))
                                  @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee) ", "HREMPL", "EMBGRP", emplBenefitGroup)
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HRBGRD left outer join CBCOVR on CVCOMP=BDCOMP AND CVFACL=BDFACL AND CVCOVR=BDCOVR and CVPLAN=BDPLAN left join HREMCV on ECCOVR=BDCOVR and ECPLAN=BDPLAN and ECEMPL=$(hrEmployee) and ECSPDP=0", fileSQL)
                                  @dtw_concat(selectSQL, " BDCOMP=$(prCompany) and BDFACL=$(prFacility) and BDBGRP='$(emplBenefitGroup)'", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_concat(stmtSQL, " Order By BDCOVR,BDPLAN ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Employee_Profile_AvailableBenefits(profileHandle, dataBaseID, stmtSQL)

     %{hrtransactions %}
                              %elif ((PTE_05 == "Y") && (quicklinkRef == "hrtransactions"))
                                  @dtw_assign(programName, "HPEPTE")
                                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " PEHIST ", fileSQL)
                                  @dtw_concat(selectSQL, " HICOMP = $(hrCompany) and HIEMPL=$(hrEmployee) ", selectSQL)
                                  @dtw_concat(selectSQL, " AND ((HITRCD = 'AC' and '$(sec_06)' = 'Y')", selectSQL)
                                  @dtw_concat(selectSQL, " OR (HITRCD = 'BD' and '$(sec_07)' = 'Y')", selectSQL)
                                  @dtw_concat(selectSQL, " OR (HITRCD = 'HI' and '$(sec_08)' = 'Y')", selectSQL)
                                  @dtw_concat(selectSQL, " OR (HITRCD = 'PR' and '$(sec_09)' = 'Y')", selectSQL)
                                  @dtw_concat(selectSQL, " OR (HITRCD = 'RE' and '$(sec_10)' = 'Y')", selectSQL)
                                  @dtw_concat(selectSQL, " OR (HITRCD = 'RH' and '$(sec_11)' = 'Y')", selectSQL)
                                  @dtw_concat(selectSQL, " OR (HITRCD = 'SC' and '$(sec_12)' = 'Y')", selectSQL)
                                  @dtw_concat(selectSQL, " OR (HITRCD = 'ST' and '$(sec_13)' = 'Y')", selectSQL)
                                  @dtw_concat(selectSQL, " OR (HITRCD = 'TE' and '$(sec_14)' = 'Y')", selectSQL)
                                  @dtw_concat(selectSQL, " OR (HITRCD = 'TR' and '$(sec_15)' = 'Y'))", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Employee_Profile_HRTransactions(profileHandle, dataBaseID, stmtSQL)

     %{comments %}
                              %elif ((EMU_12  == "Y") && (quicklinkRef == "comments"))
                                  @dtw_assign(comments, "")
                                  @Get_Empl_Comments(profileHandle, dataBaseID, hrCompany, hrEmployee, fromDate, fromSeq, comment)
                                  <a name="comments"></a>
                                  @dtw_assign(displayMaxRowsMsg, "N")
                                  @dtw_assign(moreURL, "")
                                  %INCLUDE "QuickLinkTopOfForm.icl"
                                  %if (allRowsPos == "0" && (formatToPrint == "" || formatToPrint == "N"))
                                      @dtw_assign(displayMaxRows, quicklinkMaxRows)
                                  %else
                                      @RtvFldDesc("CMCOMP=$(hrCompany) and CMEMPL=$(hrEmployee)", "PEEACM", "char(count(CMSEQ#))", displayMaxRows)
                                  %endif

                                      <table $(contentTable)>
                                          <tr><td><input type="hidden" name="cmtSelection"></td>
                                              <td>
                                                  %if (comment != "")
                                                      <textarea name="comments" ROWS=$(displayMaxRows) COLS=72 WRAP="hard" readonly>$(comment)</textarea>
                                                  %else
                                                      %INCLUDE "QuickLinkNoInfoMsg.icl"
                                                  %endif
                                              </td>
                                          </tr>
                                      </table>
                                  </fieldset>

     %{emergency contact %}
                              %elif ((quicklinkRef == "emergencycontact"))
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HREMPL inner join PEEMPL on EMPECP=EPCOMP and EMPEMP=EPEMPL ", fileSQL)
                                  @dtw_concat(selectSQL, " EMCOMP=$(prCompany) and EMFACL=$(prFacility) and  EMPECP=$(hrCompany) and EMEMPL=$(prEmployee) and EMPEMP=$(hrEmployee)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Emergency_Contact_Query(profileHandle, dataBaseID, stmtSQL)
                              %endif

     %{ Attachments %}        %INCLUDE "AttachmentSQL.icl"

%{ Quicklink End %}       %INCLUDE "QuickLinkEndLoop.icl"

                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Employee_Profile_Header (IN CHAR(64)    profileHandle,
				                CHAR(2)     dataBaseID,
                                               CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_tb_setcols(quicklinkSeqTable, "5")

      @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMTYPE", PAYTYPECODE)
      %if ((PAYTYPECODE == "H" && EMU_06 == "N") || (PAYTYPECODE != "H" && EMU_07 == "N"))
          @Remove_Quick_Link("PAYINFORMATION")
      %endif

      @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMVASC", ACCRUALCODE)
      %if (ACCRUALCODE == "")
          @Remove_Quick_Link("VACATIONSICK")
      %endif

      %if (EMU_08 == "N")
          @Remove_Quick_Link("ACCRUALS")
      %endif

      %if (EMU_09 == "N")
          @Remove_Quick_Link("COBRA")
      %endif

      %if (EMU_10 == "N")
          @Remove_Quick_Link("HUMANRESOURCES")
      %endif

      %if (EMU_11 == "N")
          @Remove_Quick_Link("PAYROLLTAXES")
      %endif

      %if (ECU_05 == "N")
          @Remove_Quick_Link("SELECTEDBENEFITS")
          @Remove_Quick_Link("AVAILABLEBENEFITS")
      %endif

      %if (SDU_05 == "N")
          @Remove_Quick_Link("DEPENDENTS")
      %endif

      %if (PTE_05 == "N")
          @Remove_Quick_Link("HRTRANSACTIONS")
      %endif

      %if (EDM_05 == "N")
          @Remove_Quick_Link("PAYROLLDEDUCTIONS")
      %endif

      %if (EMU_12 == "N")
          @Remove_Quick_Link("COMMENTS")
      %endif

      %ROW {
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
                  @dtw_assign(attVar, "")
                  %INCLUDE "emplAttachment.icl"
                  @dtw_assign(attachForDesc, "$(F_EmpName)")
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if (formatToPrint != "Y")
                              <a href="$(homeURL)$(cGIPath)EmployeeCalendar.d2w/CALENDAR$(d2wVarBase)&amp;reload=Y">$(calendarImageLrg)</a>
                          %endif
                          %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                          %endif
                          %if (EMU_02 == "Y")
                              <a href="$(homeURL)$(cGIPath)EmployeeMaintainSelect.d2w/REPORT$(d2wVarBase)&amp;maintenanceCode=C">$(changeImageLrg)</a>
                          %endif
                          %INCLUDE "Attachment.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                          %if (PTE_14 == "Y" && V_EMTRCD =="" && V_EMEMPL != "99999")
                              <a href="$(homeURL)$(cGIPath)EmplMaintainTransTermination.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=A&amp;forceUpdEmpl=Y">$(termImageLrg)</a>
                          %endif
                          %if (PTE_14 == "Y" && V_EMTRCD !="" && V_EMACT =="" && V_EMPRAC =="" && V_EMPEAC =="" && V_EMEMPL != "99999" && V_EMTSUS != "DEFAULT")
                              <a onClick="return confirmDeactivatePR()" href="$(deactivateURL)">$(smNoPay)</a>
                          %endif
                          %if (PTE_14 == "Y" && V_EMTRCD !="" && V_EMACT =="" && V_EMPRAC =="D" && V_EMPEAC ==""  && V_EMEMPL != "99999" && DEMPROFILE != "DEFAULT")
                              <a onClick="return confirmDeactivateHR()" href="$(deactivateURL)">$(deactivateSml)</a>
                          %endif
                          @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMTSUS", DEMPROFILE)

                      </td>
                  %endif
              </tr>
              <tr><td>
                  <h2>$(F_EmpName)
                  </h2>
              </td></tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"
          $(hrTagAttr)

          %if (formatToPrint != "Y")
           	  %if (V_EMSSNO != "" && V_EMSSNO != "000000000")
          	  	  @RtvColVal("EMEMID='$(V_EMEMID)'", "HREMPL", "(EMSSNO)", "D", xsocsec) 
                  @dtw_assign(V_EMSSNO, xsocsec) 
              %endif	         	
              %while(@dtw_rlength(V_EMSSNO) != "9") {@dtw_insert("0", V_EMSSNO, V_EMSSNO)%}
              @dtw_assign(emplImage, "$(V_EMLNAM)@dtw_rsubstr(V_EMSSNO,"4","6")$(emplImageExt)")
              @dtwf_exists(emplImage, imageExists)
              %if (imageExists == "Y")
                  <table $(contentTable)>
                      <tr><td><img src="$(homeURL)$(emplImage)"></td></tr>
                  </table>
              %endif
          %endif

          <table $(contentTable)>
              <tr>
                  %if (V_EMPRAC == "" && V_EMTRDT == "0")
                      <td class="dsphdr">Employee Status</td>
                      <td class="dspalph">Active</td>
                  %else
                      <td class="dsphdr">Payroll Status</td>
                      %if (V_EMPRAC == "")
                          <td class="dspalph">Active</td>
                      %else
                          <td class="dspalph">Deleted</td>
                      %endif
                      <td class="dsphdr">Human Resources Status</td>
                      %if (V_EMTRDT != "0")
                          <td class="dspalph">Terminated</td>
                      %endif
                      %if (V_EMTRDT == "0")
                          %if (V_EMPEAC == "")
                              <td class="dspalph">Active</td>
                          %else
                              <td class="dspalph">Deleted</td>
                          %endif
                      %endif
                  %endif
              </tr>
              %if (V_EMTRDT != "0")
                 @Format_Date(V_EMTRDT, "H", F_EMTRDT)
              <tr><td class="dsphdr">Termination Date</td>
                  <td class="dspdate">$(F_EMTRDT)</td></tr>
              %endif
              %if (V_EMTRCD != "")
                  <tr><td class="dsphdr">Termination Reason</td>
                  @RtvFldDesc("ODCOMP=$(hrCompany) and ODTYPE='T' and ODCODE='$(V_EMTRCD)' ", "PECODE", "ODDESC", HrCodeDesc)
                  <td class="dspalph">$(HrCodeDesc)</td></tr>
              %endif
              @DateTodayCYMD(todaysDate)
              %if ((V_EPLVDT <= todaysDate) && (V_EPLVRT >= todaysDate))
                  <tr><td class="dsphdr">Employee Is On Leave For</td>
                      @RtvFldDesc("ODCOMP=$(hrCompany) and ODTYPE='R' and ODCODE='$(V_EPLVRE)' ", "PECODE", "ODDESC", HrCodeDesc)
                      <td class="dspalph">$(HrCodeDesc)</td></tr>
                  @Format_Date(V_EPLVDT, "H", F_EPLVDT)
                  @Format_Date(V_EPLVRT, "H", F_EPLVRT)
                  <tr><td class="dsphdr">Leave Date / Expected Return</td>
                     <td class="dspdate">$(F_EPLVDT) / $(F_EPLVRT)</td></tr>
              %endif

          </table>
          $(hrTagAttr)
          %INCLUDE "QuickLinkDisplay.icl"
      %}
  %}
%}


%FUNCTION(dtw_sql) Employee_Profile_Demographics (IN  CHAR(64)    profileHandle,
				                       CHAR(2)     dataBaseID,
                                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="demographics"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %ROW{
              @Format_HRCoFac("$(V_EMCOMP)", "$(V_EMFACL)", "F", F_CoFac)
              <tr><td class="dsphdr">Company/Facility</td>
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_CoFac)</td>
              </tr>
              <tr><td class="dsphdr">Employee Number</td>
                  <td class="dspnmbr">$(V_EMEMPL)</td></tr>
              %if(V_EMCOMP != V_EMPECP)
                  <tr><td class="dsphdr">H/R Company</td>
                      <td class="dspalph">$(V_EMPECP)</td></tr>
              %endif
              %if(V_EMEMPL != V_EMPEMP)
                  <tr><td class="dsphdr">H/R Employee Number</td>
                      <td class="dspalph">$(V_EMPEMP)</td></tr>
              %endif
              <tr><td class="dsphdr">Report Name</td>
                  <td class="dspalph">$(V_EMRNAM)</td></tr>
              <tr><td class="dsphdr">Last Name</td>
                  <td class="dspalph">$(V_EMLNAM)</td></tr>
              <tr><td class="dsphdr">First Name</td>
                  <td class="dspalph">$(V_EMFNAM)</td></tr>
              <tr><td class="dsphdr">Middle Initial</td>
                  <td class="dspalph">$(V_EMMIDI)</td></tr>
              <tr><td class="dsphdr">Address 1</td>
                  <td class="dspalph">$(V_EMADR1)</td></tr>
              %if (V_EMADR2 != "")
                  <tr><td class="dsphdr">Address 2</td>
                      <td class="dspalph">$(V_EMADR2)</td></tr>
              %endif
              <tr><td class="dsphdr">City, State Zip</td>
                  <td class="dspalph">$(V_EMCITY), $(V_EMSTAT) $(V_EMZIP)</td></tr>
              %if (V_EMCNTR != "US")
                  <tr><td class="dsphdr">Country</td>
                      <td class="dspalph">$(V_EMCNTR)</td></tr>
              %endif
              %if (V_EMPROV != "")
                  <tr><td class="dsphdr">Canadian Province</td>
                      <td class="dspalph">$(V_EMPROV)</td></tr>
              %endif
              %if (V_EMPHON > "0")
                  @EditPhoneNumber(V_EMPHON)
              %endif
              <tr><td class="dsphdr">Home Phone Number</td>
                  <td class="dspnmbr">$(V_EMPHON)</td>
              </tr>

              <tr><td class="dsphdr">Location</td>
                  @RtvFldDesc("ODCOMP=$(hrCompany) and ODTYPE='O' and ODCODE='$(V_EMLOC)' ", "PECODE", "ODDESC", HrCodeDesc)
                  @Format_Code(V_EMLOC, F_EMLOC)
                  <td class="dspalph">$(HrCodeDesc)</td>
                  <td class="dspalph">$(F_EMLOC)</td>
              </tr>
              <tr><td class="dsphdr">Department</td>
                  @RtvFldDesc("EADEPT='$(V_EMDEPT)' ", "PREXAC", "EANAME", deptName)
                  @Format_Code(V_EMDEPT, F_EMDEPT)
                  <td class="dspalph">$(deptName)</td>
                  <td class="dspalph">$(F_EMDEPT)</td>
              </tr>
              @Format_Date(V_EMDOB, "H", F_EMDOB)
              <tr><td class="dsphdr">Date Of Birth</td>
                  <td class="dspdate">$(F_EMDOB)</td></tr>
			
              @RtvColVal("EMEMID=$(V_EMEMID)", "HREMPL", "(EMSSNO)", "I", xsocsec)
              @dtw_assign(V_EMSSNO, xsocsec)    	
          	       	
              @Format_SSN(V_EMSSNO, F_EMSSNO)
              <tr><td class="dsphdr">Social Security Number</td>
                  <td class="dspalph">$(F_EMSSNO)</td></tr>
              %if (V_EMSSSF != "")
                  <tr><td class="dsphdr">Social Security Suffix</td>
                      <td class="dspalph">$(V_EMSSSF)</td></tr>
              %endif
              <tr><td class="dsphdr">Gender</td>
                  @RtvFldDesc("FLTYPE='GENDER' and FLVALU='$(V_EMGNDR)'", "SYFLAG", "FLDESC", syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td></tr>
              <tr><td class="dsphdr">Marital Status</td>
                  @RtvFldDesc("FLTYPE='MARITALSTS' and FLVALU='$(V_EMMSTA)'", "SYFLAG", "FLDESC", syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td></tr>
              <tr><td class="dsphdr">Number Of Dependents</td>
                 <td class="dspnmbr">$(V_EMNODP)</td></tr>
              @Format_Date(V_EMHIRE, "H", F_EMHIRE)
              <tr><td class="dsphdr">Hire Date</td>
                 <td class="dspdate">$(F_EMHIRE)</td></tr>
              @Format_Date(V_EMSTRT, "H", F_EMSTRT)
              <tr><td class="dsphdr">Start Date</td>
                 <td class="dspdate">$(F_EMSTRT)</td></tr>
              %if (V_EMSENR != "0")
                  @Format_Date(V_EMSENR, "H", F_EMSENR)
                  <tr><td class="dsphdr">Seniority Date</td>
                      <td class="dspdate">$(F_EMSENR)</td></tr>
              %endif
              <tr><td class="dsphdr">Citizenship</td>
                  @RtvYNDesc($(V_EMCTZN), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td></tr>
              %if (V_EMALRG != "")
                  <tr><td class="dsphdr">Alien Registration Number</td>
                      <td class="dspalph">$(V_EMALRG)</td></tr>
              %endif
              <tr><td class="dsphdr">Job Code</td>
                  @RtvFldDesc("ODCOMP=$(hrCompany) and ODTYPE='J' and ODCODE='$(V_EMJOB)' ", "PECODE", "ODDESC", HrCodeDesc)
                  @Format_Code(V_EMJOB, F_EMJOB)
                  <td class="dspalph">$(HrCodeDesc)</td>
                  <td class="dspalph">$(F_EMJOB)</td>
              </tr>
              <tr><td class="dsphdr">EEO-1 Job Category</td>
                  @dtw_assign(T_EEO, "")
                  @CvtEEO(V_EMEEO, T_EEO)
                  @RtvFldDesc("ODCOMP=$(hrCompany) and ODTYPE='Y' and ODCODE='$(T_EEO)' ", "PECODE", "ODDESC", HrCodeDesc)
                  @Format_Code(V_EMEEO, F_EMEEO)
                  <td class="dspalph">$(HrCodeDesc)</td>
                  <td class="dspalph">$(F_EMEEO)</td>
              </tr>
              <tr><td class="dsphdr">Union</td>
                  @RtvFldDesc("ODCOMP=$(hrCompany) and ODTYPE='U' and ODCODE='$(V_EMUNCD)' ", "PECODE", "ODDESC", HrCodeDesc)
                  @Format_Code(V_EMUNCD, F_EMUNCD)
                  <td class="dspalph">$(HrCodeDesc)</td>
                  <td class="dspalph">$(F_EMUNCD)</td>
              </tr>
              %if (V_EMUNMN != "")
                  <tr><td class="dsphdr">Union Membership Number</td>
                      <td class="dspalph">$(V_EMUNMN)</td></tr>
              %endif
              %if (V_EMSHFT != "")
                  <tr><td class="dsphdr">Shift</td>
                      <td class="dspalph">$(V_EMSHFT)</td></tr>
              %endif
              <tr><td class="dsphdr">Standard Annual Hours</td>
                  <td class="dspnmbr">$(V_EMANHR)</td></tr>
              %if (V_EMSCHD != "")
                  <tr><td class="dsphdr">Schedule</td>
                      @RtvFldDesc("SMSCHD=$(V_EMSCHD) ", "HDSCHM", "SMDESC", scheduleDesc)
                      @Format_Code(V_EMSCHD, F_EMSCHD)
                      <td class="dspalph">$(scheduleDesc)</td>
                      <td class="dspalph">$(F_EMSCHD)</td>
                  </tr>
              %endif
              %if (V_EMPLNT != "0")
                  <tr><td class="dsphdr">Home Plant Number</td>
                      @RtvFldDesc("PLPLNT=$(V_EMPLNT) ", "HDPLNT", "PLNAME", plantDesc)
                      @Format_Code(V_EMPLNT, F_EMPLNT)
                      <td class="dspalph">$(plantDesc)</td>
                      <td class="dspalph">$(F_EMPLNT)</td>
                  </tr>
              %endif
              %if (V_EMMDPT != "")
                  <tr><td class="dsphdr">Mfg Department/Work Center</td>
                      @RtvFldDesc("WCPLT=$(V_EMPLNT) AND WCDEPT='$(V_EMMDPT)' and WCWC='$(V_EMWC)' ", "HDMWCM", "WCDESC", deptwcDesc)
                      @Format_Code("$(V_EMMDPT) / $(V_EMWC)", F_EMDPWC)
                      <td class="dspalph">$(deptwcDesc)</td>
                      <td class="dspalph">$(F_EMDPWC)</td>
                  </tr>
              %endif
              %if (V_EMHGRP != "0")
                  <tr><td class="dsphdr">Home Group Number</td>
                      @RtvFldDesc("BBGRP#=$(V_EMHGRP) ", "HDGRPM", "BBDESC", groupDesc)
                      @Format_Code(V_EMHGRP, F_EMHGRP)
                      <td class="dspalph">$(groupDesc)</td>
                      <td class="dspalph">$(F_EMHGRP)</td>
                  </tr>
              %endif
              @RtvFldDesc("PRU1DS<>' '", "PRCTRL", "PRU1DS", UDF1)
              @RtvFldDesc("PRU2DS<>' '", "PRCTRL", "PRU2DS", UDF2)
              @RtvFldDesc("PRU3DS<>' '", "PRCTRL", "PRU3DS", UDF3)
              @RtvFldDesc("PRU4DS<>' '", "PRCTRL", "PRU4DS", UDF4)
              @RtvFldDesc("PRU5DS<>' '", "PRCTRL", "PRU5DS", UDF5)
              @RtvFldDesc("PRU6DS<>' '", "PRCTRL", "PRU6DS", UDF6)
              %if($(UDF1) != "")
                  <tr><td class="dsphdr">$(UDF1)</td>
                      <td class="dspnmbr">$(V_EMUSR1)</td></tr>
              %endif
              %if($(UDF2) != "")
                  <tr><td class="dsphdr">$(UDF2)</td>
                      <td class="dspnmbr">$(V_EMUSR2)</td></tr>
              %endif
              %if($(UDF3) != "")
                  <tr><td class="dsphdr">$(UDF3)</td>
                      <td class="dspnmbr">$(V_EMUSR3)</td></tr>
              %endif
              %if($(UDF4) != "")
                  <tr><td class="dsphdr">$(UDF4)</td>
                      <td class="dspnmbr">$(V_EMUSR4)</td></tr>
              %endif
              %if($(UDF5) != "")
                  <tr><td class="dsphdr">$(UDF5)</td>
                      <td class="dspnmbr">$(V_EMUSR5)</td></tr>
              %endif
              %if($(UDF6) != "")
                  <tr><td class="dsphdr">$(UDF6)</td>
                      <td class="dspnmbr">$(V_EMUSR6)</td></tr>
              %endif
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Employee_Profile_Accruals (IN  CHAR(64)    profileHandle,
				                   CHAR(2)     dataBaseID,
                                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="accruals"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMTYPE", PAYTYPECODE)
          %ROW{

                  @Format_Date(V_EMACDT, "H", F_EMACDT)
                  @Format_Nbr(@dtw_rsubtract(V_EMVHA, V_EMVHT), F_netVacHours, "2", $(hrsEditCode), "Y", "", "")
                  @Format_Nbr(@dtw_rsubtract(V_EMSHA, V_EMSHT), F_netSickHours, "2", $(hrsEditCode), "Y", "", "")
                  @Format_Nbr(@dtw_rsubtract(V_EMMHA, V_EMMHT), F_netMiscHours, "2", $(hrsEditCode), "Y", "", "")
                  @Format_Nbr(@dtw_rsubtract(V_EMVDA, V_EMVDP), F_netVacDollars, "2", $(amtEditCode), "Y", "", "")
                  @Format_Nbr(@dtw_rsubtract(V_EMSDA, V_EMSDP), F_netSickDollars, "2", $(amtEditCode), "Y", "", "")
                  @Format_Nbr(@dtw_rsubtract(V_EMMDA, V_EMMDP), F_netMiscDollars, "2", $(amtEditCode), "Y", "", "")
                  @Format_Nbr($(V_EMACVH), F_EMACVH, "2", $(hrsEditCode), "", "", "")
                  @Format_Nbr($(V_EMASH), F_EMASH, "2", $(hrsEditCode), "", "", "")
                  @Format_Nbr($(V_EMAMH), F_EMAMH, "2", $(hrsEditCode), "", "", "")
                  @Format_Nbr($(V_EMACVD), F_EMACVD, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EMASD), F_EMASD, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EMAMD), F_EMAMD, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EMVHT), F_EMVHT, "2", $(hrsEditCode), "", "", "")
                  @Format_Nbr($(V_EMSHT), F_EMSHT, "2", $(hrsEditCode), "", "", "")
                  @Format_Nbr($(V_EMMHT), F_EMMHT, "2", $(hrsEditCode), "", "", "")
                  @Format_Nbr($(V_EMVHA), F_EMVHA, "2", $(hrsEditCode), "", "", "")
                  @Format_Nbr($(V_EMSHA), F_EMSHA, "2", $(hrsEditCode), "", "", "")
                  @Format_Nbr($(V_EMMHA), F_EMMHA, "2", $(hrsEditCode), "", "", "")
                  @Format_Nbr($(V_EMVDP), F_EMVDP, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EMSDP), F_EMSDP, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EMMDP), F_EMMDP, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EMVDA), F_EMVDA, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EMSDA), F_EMSDA, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EMMDA), F_EMMDA, "2", $(amtEditCode), "", "", "")

                  <tr><th class="dsphdr" colspan="3">Accrual Code And Dates</th></tr>

                  <tr><td class="dsphdr">Vacation/Sick</td>
                      <td class="dspalph">$(V_EMVASC)</td>
                  </tr>

                  %if (V_EMMSAC != "")
                      <tr><td class="dsphdr">Miscellaneous</td>
                          <td class="dspalph">$(V_EMMSAC)</td>
                      </tr>
                  %endif

                  <tr><td class="dsphdr">Accrual Date</td>
                     <td class="dspdate">$(F_EMACDT)</td>
                  </tr>

                  <tr><td>&nbsp;</td></tr>
                  <tr><td class="dsphdr">&nbsp;</td><td class="dsphdr">Hours</td>
                      %if (((PAYTYPECODE == "H" && EMU_06 == "Y") || (PAYTYPECODE != "H" && EMU_07 == "Y")))
                          <td class="dsphdr">Dollars</td>
                      %endif
                  </tr>

                  <tr><th class="dsphdr">Vacation</th></tr>

                  <tr><td class="dsphdr">YTD Accrued</td>
                      <td class="colnmbr">$(F_EMACVH)</td>
                      %if (((PAYTYPECODE == "H" && EMU_06 == "Y") || (PAYTYPECODE != "H" && EMU_07 == "Y")))
                          <td class="colnmbr">$(F_EMACVD)</td>
                      %endif
                  </tr>
                  <tr><td class="dsphdr">YTD Available</td>
                      <td class="colnmbr">$(F_EMVHA)</td>
                      %if (((PAYTYPECODE == "H" && EMU_06 == "Y") || (PAYTYPECODE != "H" && EMU_07 == "Y")))
                          <td class="colnmbr">$(F_EMVDA)</td>
                      %endif
                  </tr>

                  <tr><td class="dsphdr">YTD Taken</td>
                      <td class="colnmbr">$(F_EMVHT)</td>
                      %if (((PAYTYPECODE == "H" && EMU_06 == "Y") || (PAYTYPECODE != "H" && EMU_07 == "Y")))
                          <td class="colnmbr">$(F_EMVDP)</td>
                      %endif
                  </tr>
                  <tr><td class="dsphdr">Net Available</td>
                      <td class="colnmbr">$(F_netVacHours)</td>
                      %if (((PAYTYPECODE == "H" && EMU_06 == "Y") || (PAYTYPECODE != "H" && EMU_07 == "Y")))
                          <td class="colnmbr">$(F_netVacDollars)</td>
                      %endif
                  </tr>

                  <tr><td>&nbsp;</td></tr>
                  <tr><th class="dsphdr">Sick</th></tr>
                      <td class="dsphdr">YTD Accrued</td>
                      <td class="colnmbr">$(F_EMASH)</td>
                      %if (((PAYTYPECODE == "H" && EMU_06 == "Y") || (PAYTYPECODE != "H" && EMU_07 == "Y")))
                          <td class="colnmbr">$(F_EMASD)</td>
                      %endif
                  </tr>
                  <tr><td class="dsphdr">YTD Available</td>
                      <td class="colnmbr">$(F_EMSHA)</td>
                      %if (((PAYTYPECODE == "H" && EMU_06 == "Y") || (PAYTYPECODE != "H" && EMU_07 == "Y")))
                          <td class="colnmbr">$(F_EMSDA)</td>
                      %endif
                  </tr>
                  <tr><td class="dsphdr">YTD Taken</td>
                      <td class="colnmbr">$(F_EMSHT)</td>
                      %if (((PAYTYPECODE == "H" && EMU_06 == "Y") || (PAYTYPECODE != "H" && EMU_07 == "Y")))
                          <td class="colnmbr">$(F_EMSDP)</td>
                      %endif
                  </tr>
                  <tr><td class="dsphdr">Net Available</td>
                      <td class="colnmbr">$(F_netSickHours)</td>
                      %if (((PAYTYPECODE == "H" && EMU_06 == "Y") || (PAYTYPECODE != "H" && EMU_07 == "Y")))
                          <td class="colnmbr">$(F_netSickDollars)</td>
                      %endif
                  </tr>


                  %if (V_EMMSAC != "")
	               <tr><td>&nbsp;</td></tr>
                      <tr><th class="dsphdr">Miscellaneous</th></tr>
                          <td class="dsphdr">YTD Accrued</td>
                          <td class="colnmbr">$(F_EMAMH)</td>
                          %if (((PAYTYPECODE == "H" && EMU_06 == "Y") || (PAYTYPECODE != "H" && EMU_07 == "Y")))
                              <td class="colnmbr">$(F_EMAMD)</td>
                          %endif
                      </tr>
                      <tr><td class="dsphdr">YTD Available</td>
                          <td class="colnmbr">$(F_EMMHA)</td>
                          %if (((PAYTYPECODE == "H" && EMU_06 == "Y") || (PAYTYPECODE != "H" && EMU_07 == "Y")))
                              <td class="colnmbr">$(F_EMMDA)</td>
                          %endif
                      </tr>
                      <tr><td class="dsphdr">YTD Taken</td>
                          <td class="colnmbr">$(F_EMMHT)</td>
                          %if (((PAYTYPECODE == "H" && EMU_06 == "Y") || (PAYTYPECODE != "H" && EMU_07 == "Y")))
                              <td class="colnmbr">$(F_EMMDP)</td>
                          %endif
                      </tr>
                      <tr><td class="dsphdr">Net Available</td>
                          <td class="colnmbr">$(F_netMiscHours)</td>
                          %if (((PAYTYPECODE == "H" && EMU_06 == "Y") || (PAYTYPECODE != "H" && EMU_07 == "Y")))
                              <td class="colnmbr">$(F_netMiscDollars)</td>
                          %endif
                      </tr>
                  %endif
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Employee_Profile_VacationSick (IN  CHAR(64)    profileHandle,
				                       CHAR(2)     dataBaseID,
                                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="vacationsick"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMTYPE", PAYTYPECODE)
          %ROW{
              @Format_Nbr($(V_EMVHT), F_EMVHT, "2", $(hrsEditCode), "", "", "")
              @Format_Nbr($(V_EMSHT), F_EMSHT, "2", $(hrsEditCode), "", "", "")
              @Format_Nbr($(V_EMMHT), F_EMMHT, "2", $(hrsEditCode), "", "", "")
              @Format_Nbr(@dtw_rsubtract(V_EMVHA, V_EMVHT), F_netVacHours, "2", $(hrsEditCode), "Y", "", "")
              @Format_Nbr(@dtw_rsubtract(V_EMSHA, V_EMSHT), F_netSickHours, "2", $(hrsEditCode), "Y", "", "")
              @Format_Nbr(@dtw_rsubtract(V_EMMHA, V_EMMHT), F_netMiscHours, "2", $(hrsEditCode), "Y", "", "")

              <tr><td class="dsphdr">Vacation Hours Taken</td>
                  <td class="colnmbr">$(F_EMVHT)</td></tr>
              <tr><td class="dsphdr">Vacation Hours Available</td>
                  <td class="colnmbr">$(F_netVacHours)</td></tr>

              <tr><td class="dsphdr">Sick Hours Taken</td>
                  <td class="colnmbr">$(F_EMSHT)</td></tr>
              <tr><td class="dsphdr">Sick Hours Available</td>
                  <td class="colnmbr">$(F_netSickHours)</td></tr>
              %if (V_EMMSAC != "")
                  <tr><td class="dsphdr">Miscellaneous Hours Taken</td>
                      <td class="colnmbr">$(F_EMMHT)</td></tr>
                  <tr><td class="dsphdr">Miscellaneous Hours Available </td>
                      <td class="colnmbr">$(F_netMiscHours)</td></tr>
              %endif
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Employee_Profile_Payinformation (IN  CHAR(64)    profileHandle,
				                         CHAR(2)     dataBaseID,
                                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="payinformation"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %ROW{

              %if ((V_EMTYPE == "H" && EMU_06 == "Y") || (V_EMTYPE != "H" && EMU_07 == "Y"))

                  <tr><td class="dsphdr">Pay Type</td>
                      @RtvFldDesc("FLTYPE='PAYTYPE' and FLVALU='$(V_EMTYPE)'", "SYFLAG", "FLDESC", syFlagDesc)
                      @Format_Code(V_EMTYPE, F_EMTYPE)
                      <td class="dspalph">$(syFlagDesc)</td>
                      <td class="dspalph">$(F_EMTYPE)</td>
                  </tr>
                  %if (V_EMTYPE == "S")
                     <tr><td class="dsphdr">Exempt/Nonexempt</td>
                          @RtvFldDesc("FLTYPE='EXEMPT' and FLVALU='$(V_EMEXMT)'", "SYFLAG", "FLDESC", syFlagDesc)
                          <td class="dspalph">$(syFlagDesc)</td>
                      </tr>
                  %endif
                  <tr><td class="dsphdr">Pay Frequency</td>
                      @RtvFldDesc("FLTYPE='EMPLFREQ' and FLVALU='$(V_EMFREQ)'", "SYFLAG", "FLDESC", syFlagDesc)
                      @Format_Code(V_EMFREQ, F_EMFREQ)
                      <td class="dspalph">$(syFlagDesc)</td>
                      <td class="dspalph">$(F_EMFREQ)</td>
                  </tr>
                  @Format_Nbr($(V_EMAMT), F_EMAMT, $(rteNbrDec), $(rteEditCode), "", "", "")
                  <tr><td class="dsphdr">Pay Rate/Salary Amount</td>
                     <td class="dspalph">$(F_EMAMT)</td>
                  </tr>
                  %if (V_EMTYPE == "S")
                     <tr><td class="dsphdr">Salary Amount Code</td>
                      @RtvFldDesc("FLTYPE='PAYROLLFRQ' and FLVALU='$(V_EMSRCD)'", "SYFLAG", "FLDESC", syFlagDesc)
                      @Format_Code(V_EMSRCD, F_EMSRCD)
                      <td class="dspalph">$(syFlagDesc)</td>
                      <td class="dspalph">$(F_EMSRCD)</td>
                  </tr>
                  %endif
                  %if (V_EMDLIN != "0")
                      @Format_Date(V_EMDLIN, "H", F_EMDLIN)
                      <tr><td class="dsphdr">Last Salary Change Date</td>
                         <td class="dspdate">$(F_EMDLIN)</td>
                      </tr>
                  %endif
                  <tr><td class="dsphdr">Overtime Calculation Method</td>
                      @RtvFldDesc("FLTYPE='OVERTIME' and FLVALU='$(V_EMOVTM)'", "SYFLAG", "FLDESC", syFlagDesc)
                      @Format_Code(V_EMOVTM, F_EMOVTM)
                      <td class="dspalph">$(syFlagDesc)</td>
                      <td class="dspalph">$(F_EMOVTM)</td>
                  </tr>
                  <tr><td class="dsphdr">Highly Compensated Employee</td>
                      @RtvYNDesc($(V_EMHCE), syFlagDesc)
                      <td class="dspalph">$(syFlagDesc)</td>
                  </tr>
                  <tr><td class="dsphdr">Corporate Officer</td>
                      @RtvYNDesc($(V_EMOFCR), syFlagDesc)
                      <td class="dspalph">$(syFlagDesc)</td>
                  </tr>
                  <tr><td class="dsphdr">Key Employee</td>
                      @RtvYNDesc($(V_EMKEYE), syFlagDesc)
                      <td class="dspalph">$(syFlagDesc)</td>
                  </tr>
                  <tr><td class="dsphdr">Benefit Group</td>
                      @RtvFldDesc("BHCOMP=$(V_EMCOMP) AND BHFACL=$(V_EMFACL) AND BHBGRP='$(V_EMBGRP)' ", "HRBGRH", "BHNAME", bengroupDesc)
                      @Format_Code(V_EMBGRP, F_EMBGRP)
                      <td class="dspalph">$(bengroupDesc)</td>
                      <td class="dspalph">$(F_EMBGRP)</td>
                  </tr>
              %endif
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Employee_Profile_Cobra (IN  CHAR(64)    profileHandle,
