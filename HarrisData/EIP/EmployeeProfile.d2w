                  <td class="dspalph">$(syFlagDesc)</td></tr>
              <tr><td class="dsphdr">Manual Continuation Notice</td>
                  @RtvYNDesc($(V_EMMCN), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td></tr>
              <tr><td class="dsphdr">Manual Conversion Notice</td>
                  @RtvYNDesc($(V_EMMVN), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td></tr>
              <tr><td class="dsphdr">General Notice Issue Date</td>
                  @Format_Date(V_EMGNID, "H", F_EMGNID)
                  <td class="dspdate">$(F_EMGNID)</td></tr>
              <tr><td class="dsphdr">General Notice Letter Number</td>
                  <td class="dspalph">$(V_EMGNLN)</td></tr>
              <tr><td class="dsphdr">COBRA Active</td>
                  %if (V_EMCBAC == "")
                      @dtw_assign(V_EMCBAC, "N")
                  %endif
                  @RtvYNDesc($(V_EMCBAC), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td></tr>
              %if (V_EMCBTD > "0")
                  @Format_Date(V_EMCBTD, "H", F_EMCBTD)
              <tr><td class="dsphdr">COBRA Termination Date</td>
                  <td class="dspdate">$(F_EMCBTD)</td></tr>
                  <tr><td class="dsphdr">COBRA Termination Code</td>
                     <td class="dspalph">$(V_EMCBTC)</td></tr>
              %endif
              %if (V_EMCACP > "Y")
                  <tr><td class="dsphdr">Active Conversion Policy</td>
                     <td class="dspalph">Yes</td></tr>
              %endif
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Employee_Profile_HumanResources (IN  CHAR(64)    profileHandle,
				                         CHAR(2)     dataBaseID,
                                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="humanresources"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %ROW{
              <tr><th class="dsphdr"> General Employment</th></tr>

              %if (V_EPLEVL > "0")
                  <tr><td class="dsphdr">Organization Level / Sequence</td>
                      <td class="dspalph">$(V_EPLEVL) / $(V_EPOSEQ)</td></tr>
              %endif
              <tr><td class="dsphdr">Title</td>
                  <td class="dspalph">$(V_EPTITL)</td>
              </tr>
              <tr><td class="dsphdr">Ethnic ID</td>
                  @RtvFldDesc("FLTYPE='ETHNICID' and FLVALU='$(V_EPETHN)'", "SYFLAG", "FLDESC", syFlagDesc)
                  @Format_Code(V_EPETHN, F_EPETHN)
                  <td class="dspalph">$(syFlagDesc)</td>
                  <td class="dspalph">$(F_EPETHN)</td>
              </tr>
              %if (V_EPOTID != "")
                  <tr><td class="dsphdr">Visa/Other ID</td>
                      <td class="dspalph">$(V_EPOTID)</td>
                  </tr>
              %endif
              %if (V_EPHIRE != "")
                  <tr><td class="dsphdr">Hire Source</td>
                      @RtvFldDesc("ODCOMP=$(hrCompany) and ODTYPE='W' and ODCODE='$(V_EPHIRE)' ", "PECODE", "ODDESC", HrCodeDesc)
                      @Format_Code(V_EPHIRE, F_EPHIRE)
                      <td class="dspalph">$(HrCodeDesc)</td>
                      <td class="dspalph">$(F_EPHIRE)</td>
                  </tr>
              %endif
              %if (V_EPFASC > "0")
                  @Format_Date(V_EPFASC, "H", F_EPFASC)
                  <tr><td class="dsphdr">First Association Date</td>
                     <td class="dspdate">$(F_EPFASC)</td>
                  </tr>
              %endif
              %if (V_EPSDEP != "")
                  <tr><td class="dsphdr">Sub-Department</td>
                      @RtvFldDesc("ODCOMP=$(hrCompany) and ODTYPE='Q' and ODCODE='$(V_EPSDEP)' ", "PECODE", "ODDESC", HrCodeDesc)
                      @Format_Code(V_EPSDEP, F_EPSDEP)
                      <td class="dspalph">$(HrCodeDesc)</td>
                      <td class="dspalph">$(F_EPSDEP)</td>
                  </tr>
              %endif
              <tr><td class="dsphdr">Status</td>
                  @RtvFldDesc("ODCOMP=$(hrCompany) and ODTYPE='S' and ODCODE='$(V_EPSTAT)' ", "PECODE", "ODDESC", HrCodeDesc)
                  @Format_Code(V_EPSTAT, F_EPSTAT)
                  <td class="dspalph">$(HrCodeDesc)</td>
                  <td class="dspalph">$(F_EPSTAT)</td>
              </tr>
              %if (V_EPPENS != "")
                  <tr><td class="dsphdr">Pension</td>
                      @RtvFldDesc("ODCOMP=$(hrCompany) and ODTYPE='2' and ODCODE='$(V_EPPENS)' ", "PECODE", "ODDESC", HrCodeDesc)
                      @Format_Code(V_EPPENS, F_EPPENS)
                      <td class="dspalph">$(HrCodeDesc)</td>
                      <td class="dspalph">$(F_EPPENS)</td>
                  </tr>
              %endif
              %if (V_EPLABC != "")
                  <tr><td class="dsphdr">Labor Category</td>
                      @RtvFldDesc("ODCOMP=$(hrCompany) and ODTYPE='M' and ODCODE='$(V_EPLABC)' ", "PECODE", "ODDESC", HrCodeDesc)
                      @Format_Code(V_EPLABC, F_EPLABC)
                      <td class="dspalph">$(HrCodeDesc)</td>
                      <td class="dspalph">$(F_EPLABC)</td>
                  </tr>
              %endif
              %if (V_EPMAIL != "")
                  <tr><td class="dsphdr">Mail Group</td>
                      @RtvFldDesc("ODCOMP=$(hrCompany) and ODTYPE='G' and ODCODE='$(V_EPMAIL)' ", "PECODE", "ODDESC", HrCodeDesc)
                      @Format_Code(V_EPMAIL, F_EPMAIL)
                      <td class="dspalph">$(HrCodeDesc)</td>
                      <td class="dspalph">$(F_EPMAIL)</td>
                  </tr>
              %endif
              %if (V_EPMILT != "")
                  <tr><td class="dsphdr">Military Status</td>
                      @RtvFldDesc("ODCOMP=$(hrCompany) and ODTYPE='V' and ODCODE='$(V_EPMILT)' ", "PECODE", "ODDESC", HrCodeDesc)
                      @Format_Code(V_EPMILT, F_EPMILT)
                      <td class="dspalph">$(HrCodeDesc)</td>
                      <td class="dspalph">$(F_EPMILT)</td>
                  </tr>
              %endif
              %if (V_EPWCMP > "0")
                  <tr><td class="dsphdr">Workers' Compensation Number</td>
                      <td class="dspnmbr">$(V_EPWCMP)</td>
                  </tr>
              %endif
              %if (V_EPPHON > "0")
                  @EditPhoneNumber(V_EPPHON)
                  <tr><td class="dsphdr">Work Phone Number</td>
                      <td class="dspalph">$(V_EPPHON)</td>
                  </tr>
              %endif
              %if (V_EPEXTN != "0")
                  <tr><td class="dsphdr">Work Extension</td>
                      <td class="dspalph">$(V_EPEXTN)</td>
                  </tr>
              %endif
              %if (V_EPCLAS != "")
                  <tr><td class="dsphdr">Classification</td>
                      @RtvFldDesc("ODCOMP=$(hrCompany) and ODTYPE='C' and ODCODE='$(V_EPCLAS)' ", "PECODE", "ODDESC", HrCodeDesc)
                      @Format_Code(V_EPCLAS, F_EPCLAS)
                      <td class="dspalph">$(HrCodeDesc)</td>
                      <td class="dspalph">$(F_EPCLAS)</td>
                  </tr>
              %endif


              %if (V_EPLVDT > "0")
                  @Format_Date(V_EPLVDT, "H", F_EPLVDT)
                  @Format_Date(V_EPLVRT, "H", F_EPLVRT)
                  <tr><td class="dsphdr">Leave Date/Expected Return</td>
                      <td class="dspdate">$(F_EPLVDT) / $(F_EPLVRT)</td></tr>
                  <tr><td class="dsphdr">Leave Reason</td>
                      @RtvFldDesc("ODCOMP=$(hrCompany) and ODTYPE='R' and ODCODE='$(V_EPLVRE)' ", "PECODE", "ODDESC", HrCodeDesc)
                      @Format_Code(V_EPLVRE, F_EPLVRE)
                      <td class="dspalph">$(HrCodeDesc)</td>
                      <td class="dspalph">$(F_EPLVRE)</td>
                  </tr>
              %endif
              <tr><td>&nbsp;</td></tr>
              <tr><th class="dsphdr"> Supervision</th></tr>

              %if (V_EPRTEM > "0")
                  <tr><td class="dsphdr">Reports To Employee</td>
                      <td class="dspnmbr">$(V_EPRTEM)</td>
                  </tr>
              %endif
              %if (V_EPRVEM > "0")
                  <tr><td class="dsphdr">Reviewer Employee</td>
                      <td class="dspnmbr">$(V_EPRVEM)</td>
                  </tr>
              %endif
              <tr><td class="dsphdr">Temporary Employee</td>
                  @RtvYNDesc($(V_EPTEMP), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              %if (V_EPSBHR > "0")
                  <tr><td class="dsphdr">Weekly Standard Budget Hours</td>
                      <td class="dspalph">$(V_EPSBHR)</td>
                  </tr>
              %endif

              <tr><th class="dsphdr"> <br>Security</th></tr>

              %if (V_EPSCCL != "")
                  @Format_Code(V_EPSCCL, F_EPSCCL)
                  <tr><td class="dsphdr">Security Clearance</td>
                      @RtvFldDesc("ODCOMP=$(hrCompany) and ODTYPE='1' and ODCODE='$(V_EPSCCL)' ", "PECODE", "ODDESC", HrCodeDesc)
                      <td class="dspalph">$(HrCodeDesc)</td>
                     <td class="dspalph">$(F_EPSCCL)</td>
                  </tr>
                  <tr><td class="dsphdr">Security ID</td>
                     <td class="dspalph">$(V_EPSCID)</td>
                  </tr>
              %endif
              %if (V_EPSCDT > "0")
                  @Format_Date(V_EPSCDT, "H", F_EPSCDT)
                  @Format_Date(V_EPSCEX, "H", F_EPSCEX)
                  <tr><td class="dsphdr">Security Issue / Expiration</td>
                     <td class="dspdate">$(F_EPSCDT) / $(F_EPSCEX)</td>
                  </tr>
              %endif
              %if (V_EPPARK != "")
                  <tr><td class="dsphdr">Assigned Parking Space</td>
                     <td class="dspalph">$(V_EPPARK)</td>
                  </tr>
              %endif
              %if (V_EPLCPL != "")
                  <tr><td class="dsphdr">Licsense Plate State / Number</td>
                      <td class="dspalph">$(V_EPLCST) / $(V_EPLCPL)</td>
                  </tr>
              %endif

              <tr><th class="dsphdr"> <br>Highest Education</th></tr>

              %if (V_EPGRAD > "0")
                  <tr><td class="dsphdr">Year Graduated</td>
                      <td class="dspalph">$(V_EPGRAD)</td>
                  </tr>
              %endif
              %if (V_EPDGRE != "")
                  <tr><td class="dsphdr">Degree</td>
                      <td class="dspalph">$(V_EPDGRE)</td>
                  </tr>
              %endif
              %if (V_EPSUBJ != "")
                  <tr><td class="dsphdr">Subject/Major</td>
                      <td class="dspalph">$(V_EPSUBJ)</td>
                  </tr>
              %endif
              %if (V_EPSCHL != "")
                  <tr><td class="dsphdr">School (Latest)</td>
                      <td class="dspalph">$(V_EPSCHL)</td>
                  </tr>
              %endif

              <tr><th class="dsphdr"> <br>Latest Employment Changes</th></tr>

              %if (V_EPPDPT != "")
                  @Format_Date(V_EPDPCD, "H", F_EPDPCD)
                  <tr><td class="dsphdr">Previous Department / Change Date</td>
                      <td class="dspalph">$(V_EPPDPT) / $(F_EPDPCD)</td>
                  </tr>
              %endif
              %if (V_EPPJOB != "")
                  @Format_Date(V_EPJBCD, "H", F_EPJBCD)
                  <tr><td class="dsphdr">Previous Job Code / Change Date</td>
                      <td class="dspalph">$(V_EPPJOB) / $(F_EPJBCD)</td>
                  </tr>
              %endif
              %if (V_EPPSTS != "")
                  @Format_Date(V_EPSTCD, "H", F_EPSTCD)
                  <tr><td class="dsphdr">Previous Status / Change Date</td>
                      <td class="dspalph">$(V_EPPSTS) / $(F_EPSTCD)</td>
                  </tr>
              %endif
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Employee_Profile_Dependents (IN  CHAR(64)    profileHandle,
				                     CHAR(2)     dataBaseID,
                                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="dependents"></a>
      @dtw_assign(displayMaxRowsMsg, "Y")
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)emplDependents.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  <th class="colhdr">Name</th>
        	       <th class="colhdr">Relationship</th>
                  <th class="colhdr">Date Of Birth</th>
        	       <th class="colhdr">Age</th>
        	   </tr>
          %endif

          %ROW {
              @Format_EmplName(V_SDFNAM, V_SDLNAM, V_SDMIDI, "", "", "D", F_dependentName)
              %if (V_SDDOB > "0")
                  %while(@dtw_rlength(V_SDDOB) != "7")
                      {@dtw_insert("0", V_SDDOB, V_SDDOB)%}
                  %if (V_SDCLAS == "D")
                      @Calc_Years(profileHandle, dataBaseID, V_SDDOB, "", years)
                  %else
                      @dtw_assign(years, "")
                  %endif
              %endif
              @Format_Date(V_SDDOB, "D", F_SDDOB)
              @dtw_assign(dependentVar, "$(d2wVarBase)&amp;dependentNbr=@dtw_rurlescseq(V_SDSPDP)")
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph"> <a href="$(homeURL)$(cGIPath)EmplDependentsSelect.d2w/REPORT$(dependentVar)" title="View Dependent">$(F_dependentName)</a></td>
                  <td class="colalph"> $(V_SDREL)</td>
    	           <td class="coldate"> $(F_SDDOB)</td>
    	           <td class="colnmbr"> $(years)</td>
    	       </tr>
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Employee_Profile_Benefits (IN  CHAR(64)    profileHandle,
				                   CHAR(2)     dataBaseID,
                                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="selectedbenefits"></a>
      @dtw_assign(displayMaxRowsMsg, "Y")
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)emplBenefits.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
    	       <tr>
                  <th class="colhdr">&nbsp;</th>
    		   <th class="colhdr">Benefit</th>
    		   <th class="colhdr">Plan</th>
                  <th class="colhdr">Date<br>Effective</th>
    	           <th class="colhdr">Termination<br>Date</th>
              </tr>
          %endif

          %ROW{
              @Format_Date(V_ECDCE, "D", F_ECDCE)
              @Format_Date(V_ECDCT, "D", F_ECDCT)
              %if (V_ECCLAS == "S")
                  @dtw_assign(V_SDDOB, "")
              %endif
              %if (V_ECCLAS == "E")
                  @dtw_assign(V_SDDOB, "")
              %endif

              @dtw_assign(benefitVar, "$(d2wVarBase)&amp;benefitCode=@dtw_rurlescseq(V_ECCOVR)&amp;planCode=@dtw_rurlescseq(V_ECPLAN)&amp;dependentNbr=0")
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">
                      %if (formatToPrint != "Y")
                          <a href="$(homeURL)$(cGIPath)HRBenefitSelect.d2w/REPORT$(benefitVar)">$(benefitInfoImage)</a>
                          %if (V_CVURLI != "")
                              <a href="$(V_CVURLI)">$(planDocImage)</a>
                           %endif
                      %endif
                  </td>

                  %if (ECU_05 == "Y")
                      <td class="colalph"> <a href="$(homeURL)$(cGIPath)emplBenefitSelect.d2w/REPORT$(benefitVar)" title="View Benefit">$(V_CVDESC)</a></td>
                  %else
    	               <td class="colalph"> $(V_CVDESC)</td>
                  %endif
    	           <td class="colalph"> $(V_CCDESC)</td>
    	           <td class="coldate"> $(F_ECDCE)</td>
	           <td class="coldate"> $(F_ECDCT)</td>
	       </tr>
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Employee_Profile_AvailableBenefits (IN  CHAR(64)    profileHandle,
				                   CHAR(2)     dataBaseID,
                                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="availablebenefits"></a>
      @dtw_assign(displayMaxRowsMsg, "Y")
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)emplBenefits.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
        	   <th class="colhdr">&nbsp;</th>
                  <th class="colhdr">Benefit</th>
                  <th class="colhdr">Plan</th>
                  <th class="colhdr">Enrolled</th>
                  <th class="colhdr">Date<br>Effective</th>
        	   <th class="colhdr">Termination<br>Date</th>
              </tr>
          %endif

          %ROW{
              @RtvFldDesc("CCCODE='$(V_BDPLAN)' ", "CBCODE", "CCDESC", PlanDesc)
              @Format_Date(V_ECDCE, "D", F_ECDCE)
              @Format_Date(V_ECDCT, "D", F_ECDCT)
              %if (V_ECCLAS == "S")
                  @dtw_assign(V_SDDOB, "")
              %endif
              %if (V_ECCLAS == "E")
                  @dtw_assign(V_SDDOB, "")
              %endif

              @dtw_assign(benefitVar, "$(d2wVarBase)&amp;benefitCode=@dtw_rurlescseq(V_CVCOVR)&amp;planCode=@dtw_rurlescseq(V_CVPLAN)&amp;dependentNbr=0")
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">
                      %if (formatToPrint != "Y")
                          <a href="$(homeURL)$(cGIPath)HRBenefitSelect.d2w/REPORT$(benefitVar)">$(benefitInfoImage)</a>
                          %if (V_CVURLI != "")
                              <a href="$(V_CVURLI)">$(planDocImage)</a>
                           %endif
                      %endif
                  </td>

                  %if (ECU_05 == "Y")
                      <td class="colalph"> <a href="$(homeURL)$(cGIPath)emplBenefitSelect.d2w/REPORT$(benefitVar)" title="View Benefit">$(V_CVDESC)</a></td>
                  %else
    	               <td class="colalph"> $(V_CVDESC)</td>
                  %endif
    	           <td class="colalph"> $(PlanDesc)</td>
                  %if ((V_ECDCE != "0" && V_ECDCT == "0") || (V_CVAUTE == "N"))
                      %if (formatToPrint == "")
    	     	           <td class="colcode"> $(selectedImage)</td>
                      %else
    	     	           <td class="colcode"> Yes</td>
                      %endif
                  %else
                      %if (formatToPrint == "")
    	                   <td class="colalph"></td>
                      %else
    	     	           <td class="colcode"> No</td>
                      %endif
                  %endif
    	           <td class="coldate"> $(F_ECDCE)</td>
	           <td class="coldate"> $(F_ECDCT)</td>
	       </tr>
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Employee_Profile_PayrollTax (IN  CHAR(64)    profileHandle,
				                     CHAR(2)     dataBaseID,
                                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="payrolltaxes"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %ROW{
              <tr><th class="dsphdr"> <br>Federal</th></tr>
              @Format_Acct("$(V_ERACCT)", "$(V_ERSACT)", "F", F_AcctSub)
              <tr><td class="dsphdr">G/L Wages Expense Account</td>
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              %INCLUDE "SetRowClass.icl"
              <tr><td class="dsphdr">Exempt From Federal Income Tax</td>
                  @RtvFldDesc("FLTYPE='TAXEXEMPT' and FLVALU='$(V_ERXFIT)'", "SYFLAG", "FLDESC", syFlagDesc)
                  @Format_Code(V_ERXFIT, F_ERXFIT)
                  <td class="dspalph">$(syFlagDesc)</td>
                  <td class="dspalph">$(F_ERXFIT)</td>
              </tr>
              <tr><td class="dsphdr">Exempt From FICA</td>
                  @RtvYNDesc($(V_ERXFIC), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td></tr>
              <tr><td class="dsphdr">Exempt From FUI/SUI</td>
                  @RtvYNDesc($(V_EREXSU), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td></tr>
              <tr><td class="dsphdr">Federal Withholding Status</td>
                  @RtvFldDesc("FLTYPE='FEDERALWH' and FLVALU='$(V_ERFWHS)'", "SYFLAG", "FLDESC", syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td></tr>
              <tr><td class="dsphdr">Number Of Federal Dependents</td>
                  <td class="dspnmbr">$(V_ERDFDP)</td></tr>
              %if (V_ERFDAP > "0")
                  <tr><td class="dsphdr">Additional Withholding Percent</td>
                      <td class="dspnmbr">$(V_ERFDAP)</td></tr>
              %endif
              %if (V_ERFDAA > "0")
                  @Format_Nbr($(V_ERFDAA), F_ERFDAA, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Additional Withholding Amount</td>
                      <td class="dspnmbr">$(F_ERFDAA)</td></tr>
              %endif
              %if (V_ERCFTP > "0")
                  @Format_Nbr($(V_ERCFTP), F_ERCFTP, "1", $(pctEditCode), "", "", "")
                  <tr><td class="dsphdr">Commission Withholding Percent</td>
                      <td class="dspnmbr">$(F_ERCFTP)</td></tr>
              %endif
              %if (V_ERBFTP > "0")
                  @Format_Nbr($(V_ERBFTP), F_ERBFTP, "1", $(pctEditCode), "", "", "")
                  <tr><td class="dsphdr">Bonus Withholding Percent</td>
                      <td class="dspnmbr">$(F_ERBFTP)</td></tr>
              %endif
              <tr><td class="dsphdr">Qualified For Earned Income Credit</td>
                  @RtvFldDesc("FLTYPE='EIC' and FLVALU='$(V_EREIC)'", "SYFLAG", "FLDESC", syFlagDesc)
                  @Format_Code(V_EREIC, F_EREIC)
                  <td class="dspalph">$(syFlagDesc)</td>
                  <td class="dspalph">$(F_EREIC)</td>
              </tr>
              %if (V_ERGWGS > "0")
                  @Format_Nbr($(V_ERGWGS), F_ERGWGS, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Guaranteed Wage Amount</td>
                      <td class="dspnmbr">$(F_ERGWGS)</td></tr>
              %endif
              %if (V_ERGPCT > "0")
                  @Format_Nbr($(V_ERGPCT), F_ERGPCT, "3", $(pctEditCode), "", "", "")
                  <tr><td class="dsphdr">Guaranteed Wage Percent</td>
                      <td class="dspnmbr">$(F_ERGPCT)</td></tr>
              %endif
              <tr><td class="dsphdr">W4 2020 Filed</td>
                  @RtvFldDesc("FLTYPE='W42020FIT' and FLVALU='$(V_RXW420)'", "SYFLAG", "FLDESC", syFlagDesc)
                  @Format_Code(V_RXW420, F_RXW420)
                  <td class="dspalph">$(syFlagDesc)</td>
                  <td class="dspalph">$(F_RXW420)</td>
              </tr>
              <tr><td class="dsphdr">W4 2020 Step 2 Box Checked</td>
                  @RtvFldDesc("FLTYPE='W42020FST' and FLVALU='$(V_RXSTP2)'", "SYFLAG", "FLDESC", syFlagDesc)
                  @Format_Code(V_RXSTP2, F_RXSTP2)
                  <td class="dspalph">$(syFlagDesc)</td>
                  <td class="dspalph">$(F_RXSTP2)</td>
              </tr>
              %if (V_RXCDAM > "0")
                  @Format_Nbr($(V_RXCDAM), F_RXCDAM, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">W4 2020 Claim Dependents Amount</td>
                      <td class="dspnmbr">$(F_RXCDAM)</td></tr>
              %endif
              %if (V_RXOTHI > "0")
                  @Format_Nbr($(V_RXOTHI), F_RXOTHI, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">W4 2020 Other Income Amount</td>
                      <td class="dspnmbr">$(F_RXOTHI)</td></tr>
              %endif
              %if (V_RXDED > "0")
                  @Format_Nbr($(V_RXDED), F_RXDED, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">W4 2020 Deductions Amount</td>
                      <td class="dspnmbr">$(F_RXDED)</td></tr>
              %endif
              

              <tr><th class="dsphdr"> <br>State Income Tax</th></tr>
              <tr><td class="dsphdr">Exempt From State Income Tax</td>
              @RtvFldDesc("FLTYPE='TAXEXEMPT' and FLVALU='$(V_EREXST)'", "SYFLAG", "FLDESC", syFlagDesc)
                  @Format_Code(V_EREXST, F_EREXST)
                  <td class="dspalph">$(syFlagDesc)</td>
                  <td class="dspalph">$(F_EREXST)</td>
              </tr>
              <tr><td class="dsphdr">State Income Tax ID</td>
                  <td class="dspalph">$(V_ERSTID)</td></tr>

              %if (V_ERSDC > "0")
                  <tr><td class="dsphdr">Standard Deduction Category</td>
                      <td class="dspnmbr">$(V_ERSDC)</td></tr>
              %endif
                  <tr><td class="dsphdr">Number Of State Dependents</td>
                      <td class="dspnmbr">$(V_ERSTDP)</td></tr>
              %if (V_ERPEC > "0")
                  <tr><td class="dsphdr">Personal Exemption</td>
                      <td class="dspnmbr">$(V_ERPEC)</td></tr>
              %endif
              %if (V_ERAEC > "0")
                  <tr><td class="dsphdr">Additional Exemption</td>
                      <td class="dspnmbr">$(V_ERAEC)</td></tr>
              %endif
              %if (V_EREXAM > "0")
                  @Format_Nbr($(V_EREXAM), F_EREXAM, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Exemption Amount</td>
                      <td class="dspnmbr">$(F_EREXAM)</td></tr>
              %endif
                  <tr><td class="dsphdr">State Tax Withholding Category</td>
                      <td class="dspnmbr">$(V_ERTAXC)</td></tr>
              %if (V_ERCRC > "0")
                  <tr><td class="dsphdr">Tax Credit</td>
                      <td class="dspnmbr">$(V_ERCRC)</td></tr>
              %endif
              %if (V_ERADC > "0")
                  <tr><td class="dsphdr">Number Of Additional Credits</td>
                      <td class="dspnmbr">$(V_ERADC)</td></tr>
              %endif
              %if (V_ERSTAP > "0")
                  @Format_Nbr($(V_ERSTAP), F_ERSTAP, "3", $(pctEditCode), "", "", "")
                  <tr><td class="dsphdr">Additional Withholding Percent</td>
                      <td class="dspnmbr">$(F_ERSTAP)</td></tr>
              %endif
              %if (V_ERSTAA > "0")
                  @Format_Nbr($(V_ERSTAA), F_ERSTAA, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Additional Withholding Amount</td>
                      <td class="dspnmbr">$(F_ERSTAA)</td></tr>
              %endif
              %if (V_ERCSTP > ".0")
                  @Format_Nbr($(V_ERCSTP), F_ERCSTP, "3", $(pctEditCode), "", "", "")
                  <tr><td class="dsphdr">Commission Withholding Percent</td>
                      <td class="dspnmbr">$(F_ERCSTP)</td></tr>
              %endif
              %if (V_ERBSTP > ".0")
                  @Format_Nbr($(V_ERBSTP), F_ERBSTP, "3", $(pctEditCode), "", "", "")
                  <tr><td class="dsphdr">Bonus Withholding Percent</td>
                      <td class="dspnmbr">$(F_ERBSTP)</td></tr>
              %endif
              <tr><th class="dsphdr"> <br>State Unemployment Insurance</th></tr>
                  <tr><td class="dsphdr">State Unemployment Insurance ID</td>
                      <td class="dspalph">$(V_ERSUID)</td></tr>

              <tr><th class="dsphdr"> <br>State Workers' Compensation</th></tr>
              %if (V_ERSWID == "")
                  <tr><td class="colalph">Employee Is Not Set Up For State Workers' Compensation</td></tr>
              %else
                  <tr><td class="dsphdr">Exempt From State Workers' Compensation</td>
                      @RtvYNDesc($(V_EREXWC), syFlagDesc)
                      <td class="dspalph">$(syFlagDesc)</td></tr>

                  <tr><td class="dsphdr">State Workers' Compensation ID</td>
                      <td class="dspalph">$(V_ERSWID)</td></tr>
                  <tr><td class="dsphdr">Job Class</td>
                      <td class="dspalph">$(V_ERJBCL)</td></tr>
              %endif
              <tr><th class="dsphdr"> <br>State Disability Insurance</th></tr>
              %if (V_ERSDID == "")
                  <tr><td class="colalph">Employee Is Not Set Up For State Disability Insurance</td></tr>
              %else
                  <tr><td class="dsphdr">State Disability Insurance ID</td>
                      <td class="dspalph">$(V_ERSDID)</td></tr>
              %endif
              <tr><th class="dsphdr"> <br>Local Income Tax</th></tr>
              %if (V_ERLOC1 == "")
                  <tr><td class="colalph">Employee Is Not Set Up For Local Tax</td></tr>
              %else
                  @DateTodayCYMD(today)
                  @dtw_assign(currentyear, "@dtw_rsubstr(today, "1", "3")")
                  @RtvFldDesc("TLYEAR=$(currentyear) and TLID='$(V_ERLOC1)'", "PRLTAX", "TLLCNM", fieldDesc)
                  <tr><td class="dsphdr">Local Tax 1 ID</td>
                      @Format_Code(V_ERLOC1, F_ERLOC1)
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_ERLOC1)</td></tr>
                  <tr><td class="dsphdr">Local Tax 1 Dependents</td>
                      <td class="dspnmbr">$(V_ERLDP1)</td></tr>
                  <tr><td class="dsphdr">Local Tax 1 Personal Exemptions</td>
                      <td class="dspnmbr">$(V_RXLPE1)</td></tr>

                  %if (V_ERLOC2 != "")
                      @DateTodayCYMD(today)
                      @dtw_assign(currentyear, "@dtw_rsubstr(today, "1", "3")")
                      @RtvFldDesc("TLYEAR=$(currentyear) and TLID='$(V_ERLOC2)'", "PRLTAX", "TLLCNM", fieldDesc)

                      <tr><td class="dsphdr">Local Tax 2 ID</td>
                          @Format_Code(V_ERLOC2, F_ERLOC2)
                          <td class="dspalph">$(fieldDesc)</td>
                          <td class="dspalph">$(F_ERLOC2)</td></tr>
                      <tr><td class="dsphdr">Local Tax 2 Dependents</td>
                          <td class="dspnmbr">$(V_ERLDP2)</td></tr>
                      <tr><td class="dsphdr">Local Tax 2 Personal Exemptions</td>
                          <td class="dspnmbr">$(V_RXLPE2)</td></tr>
                  %endif
                  
                  @DateTodayCYMD(today)
                  @dtw_assign(currentyear, "@dtw_rsubstr(today, "1", "3")")
                  @RtvFldDesc("TLYEAR=$(currentyear) and TLID='$(V_RXERES)'", "PRLTAX", "TLLCNM", fieldDesc)
                  <tr><td class="dsphdr">Employee Resident Local Tax ID</td>
                      @Format_Code(V_RXERES, F_RXERES)
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_RXERES)</td></tr>
              %endif
              <tr><th class="dsphdr"> <br>Tax Reporting Defaults</th></tr>
              <tr><td class="dsphdr">Covered By Qualified Pension</td>
                  @RtvYNDesc($(V_ERPEN), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td></tr>

              <tr><td class="dsphdr">Employment Type</td>
                  @RtvFldDesc("FLTYPE='EMPLOYMENT' and FLVALU='$(V_ERTYPE)'", "SYFLAG", "FLDESC", syFlagDesc)
                  @Format_Code(V_ERTYPE, F_ERTYPE)
                  <td class="dspalph">$(syFlagDesc)</td>
                  <td class="dspalph">$(F_ERTYPE)</td>
              </tr>
              %if (V_ERINDS > "0")
                  <tr><td class="dsphdr">Occupation/Industry Code</td>
                      <td class="dspalph">$(V_ERINDS)</td></tr>
              %endif
              %if (V_EROPCD != "")
                   <tr><td class="dsphdr">Area Classification</td>
                       <td class="dspalph">$(V_EROPCD)</td></tr>
              %endif
              %if (V_ERNQPC != "")
                   <tr><td class="dsphdr">Nonqualified Plan Code</td>
                       <td class="dspalph">$(V_ERNQPC)</td></tr>
              %endif
              %if (V_ERSTEM != "")
                   <tr><td class="dsphdr">Statutory Employee</td>
                   @RtvFldDesc("FLTYPE='STATUTORY' and FLVALU='$(V_ERSTEM)'", "SYFLAG", "FLDESC", syFlagDesc)
                   <td class="dspalph">$(syFlagDesc)</td></tr>
              %endif
              %if (V_ERLGRP != "")
                   <tr><td class="dsphdr">Legal Representative</td>
                       @RtvYNDesc($(V_ERLGRP), syFlagDesc)
                       <td class="dspalph">$(syFlagDesc)</td></tr>
              %endif
              %if (V_ERPBCD != "")
                   <tr><td class="dsphdr">Probationary Code</td>
                       <td class="dspalph">$(V_ERPBCD)</td></tr>
              %endif
              %if (V_ERPBDT > "0")
                   @Format_Date(V_ERPBDT, "H", F_ERPBDT)
                   <tr><td class="dsphdr">Probationary Date</td>
                      <td class="dspdate">$(F_ERPBDT)</td></tr>
              %endif
              %if (V_ERCNTY > "0")
                   <tr><td class="dsphdr">County Code</td>
                      <td class="dspnmbr">$(V_ERCNTY)</td></tr>
              %endif
              %if (V_EREHLT > "0")
                   <tr><td class="dsphdr">Employee Health Insurance Code</td>
                      <td class="dspnmbr">$(V_EREHLT)</td></tr>
              %endif
              %if (V_ERRHLT > "0")
                   <tr><td class="dsphdr">Employer Health Insurance Code</td>
                      <td class="dspnmbr">$(V_ERRHLT)</td></tr>
              %endif
              %if (V_ERWGPC != "")
                   <tr><td class="dsphdr">Wage Plan Code</td>
                      <td class="dspalph">$(V_ERWGPC)</td></tr>
              %endif
              %if (V_ERSEAS != "")
                   <tr><td class="dsphdr">Seasonal Indicator</td>
                      <td class="dspalph">$(V_ERSEAS)</td></tr>
              %endif
              %if (V_ERUNIT != "")
                   <tr><td class="dsphdr">Unit/Div/Loc/Plant Code</td>
                      <td class="dspalph">$(V_ERUNIT)</td></tr>
              %endif
              %if (V_ERDCDT > "0")
                  @Format_Date(V_ERDCDT, "H", F_ERDCDT)
                  <tr><td class="dsphdr">Date Deceased</td>
                      <td class="dspdate">$(F_ERDCDT)</td></tr>
              %endif
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Employee_Profile_HRTransactions (IN  CHAR(64)    profileHandle,
				                         CHAR(2)     dataBaseID,
                                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="hrTransactions"></a>
      @dtw_assign(displayMaxRowsMsg, "Y")
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)EmployeeTransactions.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  <th class="colhdr">Transaction Type</th>
    	       <th class="colhdr">Date</th>
    	       <th class="colhdr">Comment</th>
       	   </tr>
          %endif

         %ROW {
             @Format_Date(V_HITRDT, "D", F_HITRDT)
             %INCLUDE "SetRowClass.icl"
             <tr class="$(rowClass)">
                 @dtw_assign(transactionVar, "$(d2wVarBase)&amp;sequenceNbr=@dtw_rurlescseq(V_HISEQ)")
                 @RtvFldDesc("TCTRCD='$(V_HITRCD)'", "PETRCD", "TCTRDS", transactionDesc)
                 <td class="colalph"><a href="$(homeURL)$(cGIPath)empltransselect.d2w/report$(transactionVar)" title="View Transaction">$(transactionDesc)</a></td>
                 <td class="coldate">$(F_HITRDT)</td>
	          <td class="colalph">$(V_HICMNT)</td>
	      </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Employee_Profile_Deductions (IN CHAR(64)    profileHandle,
				                    CHAR(2)     dataBaseID,
                                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="payrolldeductions"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMTYPE", PAYTYPECODE)
              <tr>
                  <th class="colhdr">Deduction<br>Number</th>
  	           <th class="colhdr">Deduction<br>Name</th>
    	           <th class="colhdr">Calculation<br>Method</th>
    	           <th class="colhdr">Priority</th>    	
    	           <th class="colhdr">Cycle</th>    	              	             	
                  <th class="colhdr">Deduction<br>Amt/Pct</th>
                  %if ((PAYTYPECODE == "H" && EDM_06 == "Y") || (PAYTYPECODE != "H" && EDM_07 == "Y"))
                      <th class="colhdr">Year To Date</th>
    	                  <th class="colhdr">Inception To Date</th>
                  %endif
    	              <th class="colhdr">Limit</th>
    	              <th class="colhdr">Effective<br>Date</th>
                  <th class="colhdr">Expiration<br>Date</th>
    	              <th class="colhdr">Accumulated<br>Amount Due</th>
              </tr>
          %endif

          %ROW{
              @Format_Date(V_EDEFDT, "D", F_EDEFDT)
              @Format_Date(V_EDEXDT, "D", F_EDEXDT)


              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
    	           <td class="colcode">$(V_EDDDNO)</td>

                  <td class="colalph"><a href="$(homeURL)$(cGIPath)EmployeeDedSelect.d2w/report$(d2wVarBase)&amp;deductionNumber=@dtw_rurlescseq(V_EDDDNO)" title="View Deduction">$(V_HVDDNM)</a></td>
                  @dtw_assign(cMethod,$(V_EDMTHD))
                  %while(@dtw_rlength(cMethod) != "2") {@dtw_insert("0", cMethod, cMethod)%}
 	              @RtvFldDesc("FLTYPE='DEDCALCMTH' and FLVALU='$(cMethod)'", "SYFLAG", "FLDESC", fieldDesc) 	
    	          <td class="colcode" $(helpCursor)><span title="$(fieldDesc)">$(V_EDMTHD)</td>    	            	
    	          <td class="colnmbr">$(V_HVPRTY)</td>
    	          <td class="colnmbr">$(V_HVCYCL)</td>                      	              	              	
    	
                  %if (V_EDAMT > ".00")
                      @Format_Nbr($(V_EDAMT), F_EDAMT, "2", $(amtEditCode), "", "$", "")
    	               <td class="colnmbr">$(F_EDAMT)</td>
                  %else
                      @Format_Nbr("@dtw_rmultiply(V_EDPCT, "100")", F_EDPCT, "3", $(pctEditCode), "", "", "%")
    	               <td class="colnmbr">$(F_EDPCT)</td>
                  %endif
                  %if ((PAYTYPECODE == "H" && EDM_06 == "Y") || (PAYTYPECODE != "H" && EDM_07 == "Y"))
                      @Format_Nbr($(V_EDYTD), F_EDYTD, "2", $(amtEditCode), "", "", "")
    	               <td class="colnmbr">$(F_EDYTD)</td>
                      @Format_Nbr($(V_EDITD), F_EDITD, "2", $(amtEditCode), "", "", "")
    	               <td class="colnmbr">$(F_EDITD)</td>
                  %endif
                  @Format_Nbr($(V_EDLIMT), F_EDLIMT, "2", $(amtEditCode), "", "", "")
    	           <td class="colnmbr">$(F_EDLIMT)</td>
    	           <td class="coldate">$(F_EDEFDT)</td>
    	           <td class="coldate">$(F_EDEXDT)</td>
                  @Format_Nbr($(V_EDACUM), F_EDACUM, "2", $(amtEditCode), "", "", "")
    	           <td class="colnmbr">$(F_EDACUM)</td>
    	       </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Emergency_Contact_Query (IN  CHAR(64)    profileHandle,
                                                CHAR(2)     dataBaseID,
                                                CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="emergencycontact"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %ROW {
              <tr><th class="dsphdr"> <br>Emergency</th></tr>

              <tr><td class="dsphdr">Disability</td>
                  @RtvFldDesc("ODCOMP=$(hrCompany) and ODTYPE='H' and ODCODE='$(V_EPHNDC)' ", "PECODE", "ODDESC", HrCodeDesc)
                  @Format_Code(V_EPHNDC, F_EPHNDC)
                  <td class="dspalph">$(HrCodeDesc)</td>
                  <td class="dspalph">$(F_EPHNDC)</td>
              </tr>
              <tr><td class="dsphdr">Physician Name</td>
                  <td class="dspalph">$(V_EPPHYS)</td>
              </tr>
              %if (V_EPPPHN != "0")		
                  @EditPhoneNumber(V_EPPPHN)
	            <tr><td class="dsphdr">Physician Phone Number</td>
                     <td class="dspnmbr">$(V_EPPPHN)</td>
                  </tr>
              %endif

              %if (V_EPBLOD != "")		
                  <tr><td class="dsphdr">Blood Type</td>
                      <td class="dspalph">$(V_EPBLOD)</td>
                  </tr>
              %endif

              %if (V_EPLBD != "0")		
                  @Format_Date(V_EPLBD, "H", F_EPLBD)
                  <tr><td class="dsphdr">Last Blood Donation</td>
                      <td class="dspdate">$(F_EPLBD)</td>
                  </tr>
              %endif

              %if (V_EPCNME != "")		
                  %if (V_EPC2NM == "")		
                      <tr><th class="dsphdr"> <br>Contact</th></tr>
                  %else
                      <tr><th class="dsphdr"> <br>Contact One</th></tr>
                  %endif
                  <tr><td class="dsphdr">Name</td>
                      <td class="dspalph">$(V_EPCNME)</td>
                  </tr>

                  %if (V_EPCADR!= "")		
                      <tr><td class="dsphdr">Address</td>
                          <td class="dspalph">$(V_EPCADR)</td>
                      </tr>
                  %endif

                  %if (V_EPCAD2 != "")		
                      <tr><td class="dsphdr"></td>
                          <td class="dspalph">$(V_EPCAD2)</td>
                      </tr>
                  %endif
                  <tr><td class="dsphdr"></td>
                      <td class="dspalph">$(V_EPC1CT) $(V_EPC1ST) $(V_EPC1ZP)</td>
                  </tr>

                  %if (V_EPCPHN != "")		
                      @EditPhoneNumber(V_EPCPHN)
                      <tr><td class="dsphdr">Phone Number</td>
                          <td class="dspnmbr">$(V_EPCPHN)</td>
                      </tr>
                  %endif
              %endif
	      		
              %if (V_EPC2NM != "")		
                  <tr><th class="dsphdr"> <br>Contact Two</th></tr>
                  <tr><td class="dsphdr">Name</td>
                      <td class="dspalph">$(V_EPC2NM)</td>
                  </tr>

                  %if (V_EPC2A1 != "")		
                      <tr><td class="dsphdr">Address</td>
                          <td class="dspalph">$(V_EPC2A1)</td>
                      </tr>
                  %endif

                  %if (V_EPC2A2 != "")		
                      <tr><td class="dsphdr"></td>
                          <td class="dspalph">$(V_EPC2A2)</td>
                      </tr>
                  %endif
                  <tr><td class="dsphdr"></td>
                      <td class="dspalph">$(V_EPC2CT) $(V_EPC2ST) $(V_EPC2ZP)</td>
                  </tr>

                  %if (V_EPC2PH != "")		
                      @EditPhoneNumber(V_EPC2PH)
                      <tr><td class="dsphdr">Phone Number</td>
                          <td class="dspnmbr">$(V_EPC2PH)</td>
                      </tr>
                  %endif
              %endif
          %}
      </table>
      </fieldset>
  %}
%}

%INCLUDE "AttachmentSelect.icl"

%FUNCTION(DTW_directcall) Get_Empl_Comments(INOUT CHAR(64)     profileHandle,
				                   CHAR(2)      dataBaseID,
					           DEC(2,0)     hrCompany,
					           DEC(9,0)     hrFacility,
					           DEC(7,0)     fromDate,
					           DEC(4,0)     fromSeq,
				                   char(32000)  comment)
{%EXEC {HHRECM_P.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(programName, "HHREMU")
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (sec_05 == "N")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @dtw_assign(EMU_01, sec_01)
      @dtw_assign(EMU_02, sec_02)
      @dtw_assign(EMU_03, sec_03)
      @dtw_assign(EMU_05, sec_05)
      @dtw_assign(EMU_06, sec_06)
      @dtw_assign(EMU_07, sec_07)
      @dtw_assign(EMU_08, sec_08)
      @dtw_assign(EMU_09, sec_09)
      @dtw_assign(EMU_10, sec_10)
      @dtw_assign(EMU_11, sec_11)
      @dtw_assign(EMU_12, sec_12)
      @Set_SQL(stmtSQL)
  %endif
%}

