%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Participant"
  d2wName                 = "WFParticipant.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfProcess=@dtw_rurlescseq(wfProcess)&amp;passedWfPoint=@dtw_rurlescseq(passedWfPoint)&amp;passedWfSequence=@dtw_rurlescseq(passedWfSequence)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HWFPTM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  noMsg                   = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
              %INCLUDE "numedit.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              function validate(searchForm) {
                  if (editNum(document.Search.srchPoint, 4, 3))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "WFPARTICIPANT")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select WFPRPT.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(PDDESC,' ') as PDDESC, coalesce(PDDESCU,' ') as PDDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(PDRATE,0) as PDRATE, ", stmtSQL)
                      %if (formatToPrint == "Y")
                         @dtw_concat(stmtSQL, " coalesce(b.USDESC,CUUSER) as b_USDESC, coalesce(b.USDESCU,CUUSER) as b_USDESCU, ", stmtSQL)
                         @dtw_concat(stmtSQL, " SYCUSF.*, ", stmtSQL)
                      %endif
                      @dtw_concat(stmtSQL, " coalesce(a.USDESC,PAPART) as USDESC, coalesce(a.USDESCU,PAPART) as USDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " WFPRPT  ", fileSQL)
                      @dtw_concat(fileSQL, " left join WFPRDT on PDPROC=PAPROC and PDPONT=PAPONT and PDSEQ=PASEQ", fileSQL)
                      %if (formatToPrint == "Y")
                          @dtw_concat(fileSQL, " left join SYCUSF on CUCUSR=PAPART and (PDRATE=0 or ((CUFRAT=0 or PDRATE>=CUFRAT) and (CUTRAT=0 or PDRATE<=CUTRAT))) ", fileSQL)
                          @dtw_concat(fileSQL, " left join SYUSER b on b.USUSER=CUUSER", fileSQL)
                      %endif
                      @dtw_concat(fileSQL, " left join SYUSER a on a.USUSER=PAPART", fileSQL)
                      @dtw_concat(selectSQL, " PAPROC='$(wfProcess)' ", selectSQL)
                      %if (passedWfPoint != "")
                          @dtw_concat(selectSQL, " and PAPONT=$(passedWfPoint) and PASEQ=$(passedWfSequence) ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %if (formatToPrint == "Y")
                          @dtw_concat(stmtSQL, ", b_USDESC ", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)WFParticipantMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      <table $(contentTable)>
          @RtvFldDesc("PRPROC='$(wfProcess)'", "WFPRHD", "PRDESC", V_PRDESC)
          @Format_Header_URL("Process", $(V_PRDESC), $(wfProcess), "$(homeURL)$(cGIPath)WFProcessSelect.d2w/REPORT$(d2wVarBase)")

          %if (passedWfPoint != "")
              @RtvFldDesc("PDPROC='$(wfProcess)' and PDPONT=$(passedWfPoint) and PDSEQ=$(passedWfSequence)", "WFPRDT", "PDDESC", V_PDDESC)
              @Format_Header_URL("Detail Point", $(V_PDDESC), "$(passedWfPoint)-$(passedWfSequence)", "$(homeURL)$(cGIPath)WFDetailSelect.d2w/REPORT$(d2wVarBase)")
          %endif
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint == "")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Detail Point Description</th>
                      <th class="colhdr">Point</th>
                      <th class="colhdr">Participant</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="15" maxlength="50">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputnmbr" name="srchPoint" size="8" maxlength="8">
                          <input type="hidden" name="operPoint" value="=">
                      </td>
                      <td><input type="text" class="inputalph" name="srchUser" size="15" maxlength="30">
                          <input type="hidden" name="operUser" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("PDDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Detail Point, Detail Point">Detail Point Description</a></th>
              @OrderBy_Sort("PAPONT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Point"       title="Sequence By Detail Point">Detail Point</a></th>
              @OrderBy_Sort("PDRATE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ComplexRate" title="Sequence By Detail Point Complexity Rating, Detail Point">Detail Point<br>Complexity Rating</a></th>
              @OrderBy_Sort("USDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Participant" title="Sequence By Participant, Detail Point">Participant</a></th>
              %if (formatToPrint == "Y")
                  <th class="colhdr">User Profile</th>
                  <th class="colhdr">From Complexity Rating</th>
                  <th class="colhdr">To Complexity Rating</th>
              %endif
          </tr>

          %INCLUDE "NoRecordsFound.icl"
          @dtw_assign(test_PAPONT, "")
          @dtw_assign(test_PASEQ, "")
          @dtw_assign(test_PAPAID, "")

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;wfPoint=@dtw_rurlescseq(V_PAPONT)&amp;wfSequence=@dtw_rurlescseq(V_PASEQ)&amp;wfParticipantId=@dtw_rurlescseq(V_PAPAID)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;updRecNbr=@dtw_rurlescseq(START_ROW_NUM)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc("$(V_PDDESC)-$(V_USDESC)", "$(V_PAPONT)-$(V_PASEQ)-$(PAPART)", "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)WFParticipantMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)WFParticipantMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromPoint=@dtw_rurlescseq(V_PAPONT)&amp;fromSequence=@dtw_rurlescseq(V_PASEQ)&amp;fromParticipantId=@dtw_rurlescseq(V_PAPAID)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)WFParticipantMaintain.d2w/EDIT_DATA$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  %if (test_PAPONT!=V_PAPONT || test_PASEQ!=V_PASEQ || test_PAPAID!=V_PAPAID)
                      @dtw_assign(test_PAPONT, V_PAPONT)
                      @dtw_assign(test_PASEQ, V_PASEQ)
                      @dtw_assign(test_PAPAID, V_PAPAID)
                      <td class="colalph">$(V_PDDESC)</td>
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)WFDetailSelect.d2w/REPORT$(d2wVarBase)&amp;passedWfPoint=@dtw_rurlescseq(V_PAPONT)&amp;passedWfSequence=@dtw_rurlescseq(V_PASEQ)" title="View Detail Point">$(V_PAPONT)-$(V_PASEQ)</a></td>
                      <td class="colnmbr">$(V_PDRATE)</td>                                      	
                      @RtvFldDesc("CUCUSR='$(V_PAPART)'", "SYCUSF", "Char(Count(*))", RecCount)
                      %if (RecCount>"0")
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)CommonUserInquiry.d2w/REPORT$(d2wVarBase)&amp;commonUser=@dtw_rurlescseq(V_PAPART)&amp;complexityRating=@dtw_rurlescseq(V_PDRATE)" title="Common User Quickview" onclick="$(inquiryWinVar)">$(V_USDESC)</a></td>
                      %else
                          <td class="colalph" $(helpCursor)><span title="$(V_PAPART)">$(V_USDESC)</span></td>
                      %endif
                  %else
                      <td class="colalph">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>                                      	
                      <td class="colnmbr">&nbsp;</td>                                      	
                      <td class="colalph">&nbsp;</td>
                  %endif
                  %if (formatToPrint == "Y")
                      <td class="colalph">$(V_b_USDESC)</td>                                      	
                      <td class="colnmbr">$(V_CUFRAT)</td>                                      	
                      <td class="colnmbr">$(V_CUTRAT)</td>                                      	
                  %endif
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select WFPRPT.*, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(PDDESC,' ') as PDDESC, coalesce(PDDESCU,' ') as PDDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(PDRATE,0) as PDRATE, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(USDESC,PAPART) as USDESC, coalesce(USDESCU,PAPART) as USDESCU ", stmtSQL)
  @dtw_concat(fileSQL, " WFPRPT  ", fileSQL)
  @dtw_concat(fileSQL, " left join WFPRDT on PDPROC=PAPROC and PDPONT=PAPONT and PDSEQ=PASEQ", fileSQL)
  @dtw_concat(fileSQL, " left join SYUSER on USUSER=PAPART", fileSQL)
  @dtw_concat(selectSQL, " PAPROC='$(wfProcess)' ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_XMLQuery (IN  CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("WFParticipantList")
          %ROW{
              @XMLIDTag("$(V_PAPROC)-$(V_PAPONT)-$(V_PASEQ)-$(V_PAPAID)", "Participant ID")
                  @XMLTag(V_PAPROC, "Process")
                  @XMLTag(V_PAPONT, "Point")
                  @XMLTag(V_PASEQ, "Sequence")
                  @XMLTag(V_PAPAID, "ParticipantId")
                  @XMLTag(V_PAPART, "Participant")
              @XMLEndTag("Participant")
          %}
      @XMLEndTag("WFParticipantList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "PDDESCU,PAPONT,PASEQ")
          @DTW_ASSIGN(orderByDisplay, "Detail Point Description, Detail Point")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %if (updRecNbr > "0")
      @dtw_assign(START_ROW_NUM, updRecNbr)
      @dtw_assign(updRecNbr, "")
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Description")
      %if (orderBy == "PDDESCU,PAPONT,PASEQ")
          @DTW_ASSIGN(orderBy, "PDDESCU DESC,PAPONT,PASEQ")
          @DTW_ASSIGN(orderByDisplay, "Detail Point Description (descending), Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "PDDESCU,PAPONT,PASEQ")
          @DTW_ASSIGN(orderByDisplay, "Detail Point Description, Detail Point")
      %endif
  %elif (sequence == "Point")
      %if (orderBy == "PAPONT,PASEQ")
          @DTW_ASSIGN(orderBy, "PAPONT DESC,PASEQ DESC")
          @DTW_ASSIGN(orderByDisplay, "Detail Point (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PAPONT,PASEQ")
          @DTW_ASSIGN(orderByDisplay, "Detail Point")
      %endif
  %elif (sequence == "PointActivity")
      %if (orderBy == "ATDESCU,PAPONT,PASEQ")
          @DTW_ASSIGN(orderBy, "ATDESCU DESC,PAPONT,PASEQ")
          @DTW_ASSIGN(orderByDisplay, "Point Activity (descending), Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "ATDESCU,PAPONT,PASEQ")
          @DTW_ASSIGN(orderByDisplay, "Point Activity, Detail Point")
      %endif
 %elif (sequence == "PointProcess")
      %if (orderBy == "PRDESCU,PAPONT,PASEQ")
          @DTW_ASSIGN(orderBy, "PRDESCU DESC,PAPONT,PASEQ")
          @DTW_ASSIGN(orderByDisplay, "Point Process (descending), Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "PRDESCU,PAPONT,PASEQ")
          @DTW_ASSIGN(orderByDisplay, "Point Process, Detail Point")
      %endif
 %elif (sequence == "Participant")
      %if (orderBy == "USDESCU,PAPONT,PASEQ")
          @DTW_ASSIGN(orderBy, "USDESCU DESC,PAPONT,PASEQ")
          @DTW_ASSIGN(orderByDisplay, "Participant (descending), Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "USDESCU,PAPONT,PASEQ")
          @DTW_ASSIGN(orderByDisplay, "Participant, Detail Point")
      %endif
 %elif (sequence == "ComplexRate")
      %if (orderBy == "PDRATE,PAPONT,PASEQ")
          @DTW_ASSIGN(orderBy, "PDRATE DESC,PAPONT,PASEQ")
          @DTW_ASSIGN(orderByDisplay, "Detail Point Complexity Rating (descending), Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "PDRATE,PAPONT,PASEQ")
          @DTW_ASSIGN(orderByDisplay, "Detail Point Complexity Rating, Detail Point")
      %endif
  %endif
	
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchPoint, 4, 3) &&
                      editNum(document.Search.srchSequence, 4, 3))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFPARTICIPANTSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Detail Point Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Point</td>
                              @dtw_assign(operNbr, "operPoint")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchPoint" size="8" maxlength="8"></td>
                          </tr>

                          <tr><td class="dsphdr">Sequence</td>
                              @dtw_assign(operNbr, "operSequence")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchSequence" size="8" maxlength="8"></td>
                          </tr>

                          <tr><td class="dsphdr">Participant</td>
                              @dtw_assign(operNbr, "operUser")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchUser" size="15" maxlength="30"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDesc.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("PDDESCU", "Detail Point Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("PAPONT",  "Point", $(srchPoint), "", operPoint, "N")
  @Build_WildCard ("PASEQ",   "Sequence", $(srchSequence), "", operSequence, "N")
  @Build_WildCard ("coalesce(USDESCU,PAPART)", "Participant", $(srchUser), "U", operUser, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}