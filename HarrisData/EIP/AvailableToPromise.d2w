%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Available To Promise"
  d2wName                 = "AvailableToPromise.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;plantName=@dtw_rurlescseq(plantName)&amp;itemDescription=@dtw_rurlescseq(itemDescription)"
  nextPrevVar             = "$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  haveHeader              = ""
  headerTable             = %table
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@plantNumber", "@dtw_rurlescseq(plantNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@itemNumber", "@dtw_rurlescseq(itemNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@itemDescription", "@dtw_rurlescseq(itemDescription)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL () {	
  %if (plantNumber != "")
      @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
      @dtw_assign(userPass, "Y")
  %else
      @dtw_assign(userPass, "Y")
  %endif

  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
               <script TYPE="text/javascript">
                  function goToPage(selectedPage) {if (selectedPage != "") {self.location=selectedPage;}}
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
               </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                          @dtw_assign(pageID, "AVAILABLETOPROMISE")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                          @dtw_assign(START_ROW_NUM, "1")
                          @MS230A_Query(profileHandle, dataBaseID, plantNumber, itemNumber, headerTable)
                          %if (@DTW_TB_rROWS(headerTable)>"0")
                              @dtw_assign(haveHeader, "Y")
                          %else
                              @dtw_assign(haveHeader, "")
                          %endif
                          @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " MS230W ", fileSQL)
                          @dtw_concat(selectSQL, "E_PLNT=$(plantNumber) and E_ITEM='$(itemNumber)' and E_XHND='$(profileHandle)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Avail_To_Promise(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Avail_To_Promise (IN CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
	   <colgroup>
	       <col width="80%">
	       <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
                      %if (backURL != "")
                          <a href="$(backURL)" title="BackHome">$(portalHome)</a>
                      %else
                          <a href="$(homeURL)$(cGIPath)ItemPlantSelect.d2w/REPORT$(d2wVarBase)" title="BackHome">$(portalHome)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      <table $(contentTable)>
          @Format_Header_URL("Plant", $(plantName), $(plantNumber), "$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(d2wVarBase)")
          @Format_Header_URL("Item", $(itemDescription), $(itemNumber), "$(homeURL)$(cGIPath)ItemSelect.d2w/REPORT$(d2wVarBase)&amp;itemDescription=@dtw_rurlescseq(itemDescription)")
      </table>

      $(hrTagAttr)

      <table $(contentTable)>
          <tr><td class="colhdr">Lead<br>Time</td>
              <td class="colhdr">Part<br>Type</td>
              <td class="colhdr">UM</td>
              <td class="colhdr">On Hand</td>
              <td class="colhdr">Released</td>
              <td class="colhdr">Firm</td>
              <td class="colhdr">Demand</td>
              <td class="colhdr">Sold MTD</td>
              <td class="colhdr">Analyst<br>Number</td>
              <td class="colhdr">ABC</td>
              <td class="colhdr">MPS</td>
              <td class="colhdr">Demand</td>
          </tr>

          %if (haveHeader == "Y")
              @dtw_tb_getv(headerTable, "1", "7", partType)
              @RtvFldDesc("FLTYPE='PARTTYPE' and FLVALU='$(partType)'", "SYFLAG", "FLDESC", partTypeDesc)
              @dtw_tb_getv(headerTable, "1", "8", uom)
              @RtvFldDesc("UMUOM='$(uom)'", "HDUOM", "UMUMLD", uomDesc)
              @dtw_tb_getv(headerTable, "1", "14", analyst)
              @RtvFldDesc("BMBUYR=$(analyst)", "HDBUYR", "BMBNA1", analystName)
              @dtw_tb_getv(headerTable, "1", "17", demandCode)
              @RtvFldDesc("FLTYPE='SCHDDEMAND' and FLVALU='$(demandCode)'", "SYFLAG", "FLDESC", demandCodeDesc)
              @Format_Nbr("@dtw_tb_rgetv(headerTable, "1", "9")", onHand, "0", $(qtyEditCode), "", "", "")
              @Format_Nbr("@dtw_tb_rgetv(headerTable, "1", "10")", released, "0", $(qtyEditCode), "", "", "")
              @Format_Nbr("@dtw_tb_rgetv(headerTable, "1", "11")", firm, "0", $(qtyEditCode), "", "", "")
              @Format_Nbr("@dtw_tb_rgetv(headerTable, "1", "12")", demand, "0", $(qtyEditCode), "", "", "")
              @Format_Nbr("@dtw_tb_rgetv(headerTable, "1", "13")", soldMTD, "0", $(qtyEditCode), "", "", "")
              <tr><td class="colnmbr">@dtw_tb_rgetv(headerTable, "1", "6")</td>
                  <td class="colcode" $(helpCursor)><span title="$(partTypeDesc)">$(partType)</span></td>
                  <td class="colcode" $(helpCursor)><span title="$(uomDesc)">$(uom)</span></td>
                  <td class="colnmbr">$(onHand)</td>
                  <td class="colnmbr">$(released)</td>
                  <td class="colnmbr">$(firm)</td>
                  <td class="colnmbr">$(demand)</td>
                  <td class="colnmbr">$(soldMTD)</td>
                  <td class="colnmbr" $(helpCursor)><span title="$(analystName)">$(analyst)</span></td>
                  <td class="colcode">@dtw_tb_rgetv(headerTable, "1", "15")</td>
                  <td class="colcode">@dtw_tb_rgetv(headerTable, "1", "16")</td>
                  <td class="colcode" $(helpCursor)><span title="$(demandCodeDesc)">$(demandCode)</span></td>
              </tr>
          %endif
          <br>
      </table>

          %if (formatToPrint != "Y")
              <table $(contentTable)>
                  <tr><td> %INCLUDE "AssignPageValue.icl" </td>
                  </tr>
              </table>
          %endif

	   <table $(contentTable)>

              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("E_DATE", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=date" title="Sequence By Date"> Date</a></th>
              @OrderBy_Sort("E_FOR", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=salesForecast" title="Sequence By Sales Forecast"> Sales <br> Forecast</a></th>
              @OrderBy_Sort("E_COR", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=customerDemand" title="Sequence By Customer Demand"> Customer <br> Demand</a></th>
              @OrderBy_Sort("E_PEG", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=peggedRequirement" title="Sequence By Pegged Requirement"> Pegged <br> Requirements</a></th>
              @OrderBy_Sort("E_AVL", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=availableToPromise" title="Sequence By Available To Promise"> Available <br> To <br> Promise</a></th>
              @OrderBy_Sort("E_REC", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=releaseFirm" title="Sequence By Released/Firm"> Released/ <br> Firm</a></th>
              @OrderBy_Sort("E_PLN", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=plannedOrders" title="Sequence By Planned Orders"> Planned <br> Orders</a></th>

              %INCLUDE "NoRecordsFound.icl"

          %ROW {
	       %INCLUDE "SetRowClass.icl"

              %if (V_E_PAST == "Y")
                  @dtw_assign(F_E_DATE, "Past Due")
                  @dtw_assign(once, "Y")
              %elif (V_E_DATE == "9999999")
                  @dtw_assign(F_E_DATE, "Future")
              %else
                  @Format_Date(V_E_DATE, "D", F_E_DATE)
              %endif

              @Format_Nbr(V_E_FOR, F_E_FOR, "0", $(qtyEditCode), "", "", "")
              @Format_Nbr(V_E_COR, F_E_COR, "0", $(qtyEditCode), "", "", "")
              @Format_Nbr(V_E_PEG, F_E_PEG, "0", $(qtyEditCode), "", "", "")
              @Format_Nbr(V_E_AVL, F_E_AVL, "0", $(qtyEditCode), "", "", "")
              @Format_Nbr(V_E_REC, F_E_REC, "0", $(qtyEditCode), "", "", "")
              @Format_Nbr(V_E_PLN, F_E_PLN, "0", $(qtyEditCode), "", "", "")

	       <tr class="$(rowClass)">
                  <td class="coldate">$(F_E_DATE)</td>
                  <td class="colnmbr">$(F_E_FOR)</td>
                  <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=184&amp;fKey1=ODITEM&amp;fVal1=@dtw_rurlescseq(itemNumber)&amp;fDsc1=@dtw_rurlescseq(itemDescription)" title="All Open Items"> $(F_E_COR)</a></td>
                  <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=522&amp;fKey1=PGCPN&amp;fVal1=@dtw_rurlescseq(itemNumber)&amp;fDsc1=@dtw_rurlescseq(itemDescription)&amp;fKey2=PGPPLT&amp;fVal2=@dtw_rurlescseq(plantNumber)&amp;fDsc2=@dtw_rurlescseq(plantName)" title="Pegged Requirements"> $(F_E_PEG)</a></td>
                  <td class="colnmbr">$(F_E_AVL)</td>
                  %if (partType == "M")
                      <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=445&amp;fKey1=OHPN&amp;fVal1=@dtw_rurlescseq(itemNumber)&amp;fDsc1=@dtw_rurlescseq(itemDescription)&amp;fKey2=OHPLT&amp;fVal2=@dtw_rurlescseq(plantNumber)&amp;fDsc2=@dtw_rurlescseq(plantName)" title="Mfg Orders"> $(F_E_REC)</a></td>
                  %else
                      <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=186&amp;fKey1=PDITEM&amp;fVal1=@dtw_rurlescseq(itemNumber)&amp;fDsc1=@dtw_rurlescseq(itemDescription)" title="All Open Items"> $(F_E_REC)</a></td>
                  %endif
                  <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=460&amp;fKey1=PLPN&amp;fVal1=@dtw_rurlescseq(itemNumber)&amp;fDsc1=@dtw_rurlescseq(itemDescription)&amp;fKey2=PLPLT&amp;fVal2=@dtw_rurlescseq(plantNumber)&amp;fDsc2=@dtw_rurlescseq(plantName)" title="MRP Planned Orders"> $(F_E_PLN)</a></td>
	       </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
  @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)

  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "E_DATE,E_PAST DESC")
          @DTW_ASSIGN(orderByDisplay, "Date")
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif

  @Fill_ATP_Work_File(profileHandle,dataBaseID,plantNumber,itemNumber)
  @Set_SQL()
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL()
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "date")
      %if (orderBy == "E_DATE,E_PAST DESC")
          @DTW_ASSIGN(orderBy, "E_DATE DESC,E_PAST DESC")
          @DTW_ASSIGN(orderByDisplay, "Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "E_DATE,E_PAST DESC")
          @DTW_ASSIGN(orderByDisplay, "Date")
      %endif
  %elif (sequence == "salesForecast")
      %if (orderBy == "E_FOR,E_DATE,E_PAST")
          @DTW_ASSIGN(orderBy, "E_FOR DESC,E_DATE,E_PAST")
          @DTW_ASSIGN(orderByDisplay, "Sales Forecast (descending)")
      %else
          @DTW_ASSIGN(orderBy, "E_FOR,E_DATE,E_PAST")
          @DTW_ASSIGN(orderByDisplay, "Sales Forecast")
      %endif
  %elif (sequence == "customerDemand")
      %if (orderBy == "E_COR,E_DATE,E_PAST")
          @DTW_ASSIGN(orderBy, "E_COR DESC,E_DATE,E_PAST")
          @DTW_ASSIGN(orderByDisplay, "Customer Demand (descending)")
      %else
          @DTW_ASSIGN(orderBy, "E_COR,E_DATE,E_PAST")
          @DTW_ASSIGN(orderByDisplay, "Customer Demand")
      %endif
  %elif (sequence == "peggedRequirement")
      %if (orderBy == "E_PEG,E_DATE,E_PAST")
          @DTW_ASSIGN(orderBy, "E_PEG DESC,E_DATE,E_PAST")
          @DTW_ASSIGN(orderByDisplay, "Pegged Requirement (descending)")
      %else
          @DTW_ASSIGN(orderBy, "E_PEG,E_DATE,E_PAST")
          @DTW_ASSIGN(orderByDisplay, "Pegged Requirement")
      %endif
  %elif (sequence == "availableToPromise")
      %if (orderBy == "E_AVL,E_DATE,E_PAST")
          @DTW_ASSIGN(orderBy, "E_AVL DESC,E_DATE,E_PAST")
          @DTW_ASSIGN(orderByDisplay, "Available To Promise (descending)")
      %else
          @DTW_ASSIGN(orderBy, "E_AVL,E_DATE,E_PAST")
          @DTW_ASSIGN(orderByDisplay, "Available To Promise")
      %endif
  %elif (sequence == "releaseFirm")
      %if (orderBy == "E_REC,E_DATE,E_PAST")
          @DTW_ASSIGN(orderBy, "E_REC DESC,E_DATE,E_PAST")
          @DTW_ASSIGN(orderByDisplay, "Released/Firm (descending)")
      %else
          @DTW_ASSIGN(orderBy, "E_REC,E_DATE,E_PAST")
          @DTW_ASSIGN(orderByDisplay, "Released/Firm")
      %endif
  %elif (sequence == "plannedOrders")
      %if (orderBy == "E_PLN,E_DATE,E_PAST")
          @DTW_ASSIGN(orderBy, "E_PLN DESC,E_DATE,E_PAST")
          @DTW_ASSIGN(orderByDisplay, "Planned Orders (descending)")
      %else
          @DTW_ASSIGN(orderBy, "E_PLN,E_DATE,E_PAST")
          @DTW_ASSIGN(orderByDisplay, "Planned Orders")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL()
%}