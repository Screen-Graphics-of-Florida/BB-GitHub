%Define {
  page_title              = "Open Order Report"
  d2wName                 = "OpenClosedOrderReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportselection=@dtw_rurlescseq(reportselection)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "17"
  helpExt                 = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      %if (reportselection == "O")
         @dtw_assign(helpExt, " (Open)")
         @dtw_assign(page_title, "Open Order Report")
      %else
         @dtw_assign(helpExt, " (Closed)")
         @dtw_assign(page_title, "Closed Order Report")
         @dtw_assign(N1OPEN, "0")
      %endif
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromOrderNumber, 8, 0) &&
                      editNum(document.Chg.toOrderNumber, 8, 0) &&
                      editNum(document.Chg.fromBillToCustomer, 7, 0) &&
                      editNum(document.Chg.toBillToCustomer, 7, 0) &&
                      editNum(document.Chg.fromShipToCustomer, 7, 0) &&
                      editNum(document.Chg.toShipToCustomer, 7, 0) &&
                      editdate(document.Chg.fromRequiredDate) &&
                      editdate(document.Chg.toRequiredDate) &&
                      editdate(document.Chg.fromUserDate2) &&
                      editdate(document.Chg.toUserDate2) &&
                      editdate(document.Chg.fromUserDate3) &&
                      editdate(document.Chg.toUserDate3) &&
                      editdate(document.Chg.fromUserDate4) &&
                      editdate(document.Chg.toUserDate4) &&
                      editNum(document.Chg.fromWarehouse, 3, 0) &&
                      editNum(document.Chg.toWarehouse, 3, 0) &&
                      editNum(document.Chg.fromLocationNumber, 3, 0) &&
                      editNum(document.Chg.toLocationNumber, 3, 0) &&
                      editNum(document.Chg.fromSalesmanNumber, 7, 0) &&
                      editNum(document.Chg.toSalesmanNumber, 7, 0) &&
                      editdate(document.Chg.fromExpirationDate) &&
                      editdate(document.Chg.toExpirationDate) &&
                      editdate(document.Chg.fromLastInvoiceDate) &&
                      editdate(document.Chg.toLastInvoiceDate) &&
                      editdate(document.Chg.fromOrderDate) &&
                      editdate(document.Chg.toOrderDate) &&
                      editdate(document.Chg.RecurringThroughDate) &&
                      editFromToAll(document.Chg.fromOrderNumber, document.Chg.toOrderNumber, document.Chg.allOrderNumber, 8) &&
                      editFromToAll(document.Chg.fromBillToCustomer, document.Chg.toBillToCustomer, document.Chg.allBillToCustomer, 7) &&
                      editFromToAll(document.Chg.fromShipToCustomer, document.Chg.toShipToCustomer, document.Chg.allShipToCustomer, 7) &&
                      editFromToAll(document.Chg.fromRequiredDate, document.Chg.toRequiredDate, document.Chg.allRequiredDate, "D") &&
                      editFromToAll(document.Chg.fromUserDate2, document.Chg.toUserDate2, document.Chg.allUserDate2, "D") &&
                      editFromToAll(document.Chg.fromUserDate3, document.Chg.toUserDate3, document.Chg.allUserDate3, "D") &&
                      editFromToAll(document.Chg.fromUserDate4, document.Chg.toUserDate4, document.Chg.allUserDate4, "D") &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromWarehouse, document.Chg.toWarehouse, document.Chg.allWarehouse, 3) &&
                      editFromToAll(document.Chg.fromLocationNumber, document.Chg.toLocationNumber, document.Chg.allLocationNumber, 3) &&
                      editFromToAll(document.Chg.fromOrderTypes, document.Chg.toOrderTypes, document.Chg.allOrderTypes, "A") &&
                      editFromToAll(document.Chg.fromSalesmanNumber, document.Chg.toSalesmanNumber, document.Chg.allSalesmanNumber, 3) &&
                      editFromToAll(document.Chg.fromExpirationDate, document.Chg.toExpirationDate, document.Chg.allExpirationDate, "D") &&
                      editFromToAll(document.Chg.fromLastInvoiceDate, document.Chg.toLastInvoiceDate, document.Chg.allLastInvoiceDate, "D") &&
                      editFromToAll(document.Chg.fromOrderDate, document.Chg.toOrderDate, document.Chg.allOrderDate, "D") &&
                      editFromToAll(document.Chg.fromUserID, document.Chg.toUserID, document.Chg.allUserID, "A") &&
                      editFromToAll(document.Chg.fromHoldCode, document.Chg.toHoldCode, document.Chg.allHoldCode, "A"))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "OPENORDERREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromOrderNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule, fieldValue)
                                  @DecatErr_Field("@@cmnt", "printOrderComments")    @dtw_assign(Err_N0CMNT, fieldValue)
                                  @DecatErr_Field("@@open", "printOpenLinesOnly")    @dtw_assign(Err_N1OPEN, fieldValue)
                                  @DecatErr_Field("@@ford", "fromOrderNumber")       @dtw_assign(Err_N2FORD, fieldValue)
                                  @DecatErr_Field("@@tord", "toOrderNumber")         @dtw_assign(Err_N2TORD, fieldValue)
                                  @DecatErr_Field("@@aord", "allOrderNumber")        @dtw_assign(Err_N2AORD, fieldValue)
                                  @DecatErr_Field("@@sord", "sortOrderNumber")       @dtw_assign(Err_N2SORD, fieldValue)
                                  @DecatErr_Field("@@pord", "totalOrderNumber")      @dtw_assign(Err_N2PORD, fieldValue)
                                  @DecatErr_Field("@@fblt", "fromBillToCustomer")    @dtw_assign(Err_N2FBLT, fieldValue)
                                  @DecatErr_Field("@@tblt", "toBillToCustomer")      @dtw_assign(Err_N2TBLT, fieldValue)
                                  @DecatErr_Field("@@ablt", "allBillToCustomer")     @dtw_assign(Err_N2ABLT, fieldValue)
                                  @DecatErr_Field("@@sblt", "sortBillToCustomer")    @dtw_assign(Err_N2SBLT, fieldValue)
                                  @DecatErr_Field("@@pblt", "totalBillToCustomer")   @dtw_assign(Err_N2PBLT, fieldValue)
                                  @DecatErr_Field("@@fcus", "fromShipToCustomer")    @dtw_assign(Err_N2FCUS, fieldValue)
                                  @DecatErr_Field("@@tcus", "toShipToCustomer")      @dtw_assign(Err_N2TCUS, fieldValue)
