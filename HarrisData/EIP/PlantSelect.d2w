%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Plant"
  d2wName                 = "PlantSelect.d2w"
  attachFolder            = "Plant"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;plantName=@dtw_rurlescseq(plantName)&amp;fromSel=Y"
  programName             = "HHDPLU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  scheduleNumber          = ""
  salesTotal              = ""
  purchasesTotal          = ""
  quickLinkByUser         = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@plantName", "@dtw_rurlescseq(plantName)", "1", "a", workURL)
  @dtw_replace(workURL, "@@plantNumber", "@dtw_rurlescseq(plantNumber)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              @dtw_assign(title, @dtw_rconcat(plantNumber, @dtw_rconcat(" ", plantName)))
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- Start Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "PLANTSELECT")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">

%{ QuickLink Table %}     %INCLUDE "QuickLinkTable.icl"

                          %if (V_HDSCRL == "0")
                              @Remove_Quick_Link("costmanagement")
                          %endif

                          %if (V_HDMPRL == "0")
                              @Remove_Quick_Link("mpsmrp")
                          %endif

%{ QuickLink By User %}   %INCLUDE "QuickLinkByUser.icl"

%{ Plant Heading %}
                          @dtw_assign(uv_Sql, "")  %{ No user view security. %}
                          @dtw_assign(wildCardSearch, "")  %{ No wildCardSearch %}
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " HDPLNT ", fileSQL)
                          @dtw_concat(selectSQL, "PLPLNT=$(plantNumber) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                          @Plant_Select_Header(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Begin %}     %INCLUDE "QuickLinkBegLoop.icl"

    %{ General Data %}
                              %if (quicklinkRef == "generaldata")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDPLNT ", fileSQL)
                                  @dtw_concat(selectSQL, "PLPLNT = $(plantNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Plant_Select_General_Data(profileHandle, dataBaseID, stmtSQL)

    %{ Product Data Base %}
                              %elif (quicklinkRef == "productdatabase")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDPLNT ", fileSQL)
                                  @dtw_concat(selectSQL, "PLPLNT=$(plantNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Plant_Select_Product_Data_Base(profileHandle, dataBaseID, stmtSQL)

    %{ Default Routing %}
                              %elif (quicklinkRef == "defaultrouting")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDPLTE ", fileSQL)
                                  @dtw_concat(selectSQL, "PEPLT=$(plantNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Plant_Select_Default_Routing(profileHandle, dataBaseID, stmtSQL)
    %{ Cost Management %}
                              %elif (quicklinkRef == "costmanagement")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDPLNT ", fileSQL)
                                  @dtw_concat(selectSQL, "PLPLNT=$(plantNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Plant_Select_Cost_Management(profileHandle, dataBaseID, stmtSQL)

    %{ MPS/MRP %}
                              %elif (quicklinkRef == "mpsmrp")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDPLNT ", fileSQL)
                                  @dtw_concat(selectSQL, "PLPLNT=$(plantNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Plant_Select_MPS_MRP(profileHandle, dataBaseID, stmtSQL)

    %{ Shop Floor Control %}
                              %elif (quicklinkRef == "shopfloorcontrol")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDPLNT ", fileSQL)
                                  @dtw_concat(selectSQL, "PLPLNT=$(plantNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Plant_Select_Shop_Floor_Control(profileHandle, dataBaseID, stmtSQL)

    %{ Cycle Count %}
                              %elif (quicklinkRef == "cyclecount")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDPLNT ", fileSQL)
                                  @dtw_concat(selectSQL, "PLPLNT=$(plantNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Plant_Select_Cycle_Count(profileHandle, dataBaseID, stmtSQL)

    %{ Account Numbers %}
                              %elif (quicklinkRef == "accountnumbers")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDPLNT ", fileSQL)
                                  @dtw_concat(selectSQL, "PLPLNT=$(plantNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Plant_Select_Account_Numbers(profileHandle, dataBaseID, stmtSQL)

    %{ Warehouse Supply %}
                              %elif (quicklinkRef == "warehousesupply")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select  WSTYPE,  WSSORD, WSSEQ#, WSWH, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " WHCO#,  WHFAC#, WHWHNM, WHWHCT, WHWHST, WHHWZP ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDWSPM inner join HDWHSM on WSTYPE='P' and WSWH=WHWHS ", fileSQL)
                                  @dtw_concat(selectSQL, "WSPLWH=$(plantNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_assign(orderBy, "WSSEQ#")
                                  @dtw_assign(orderByDisplay, "Priority Sequence")
                                  @dtw_concat(stmtSQL, " Order By $(orderBy)", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Plant_Select_Warehouse_Supply(profileHandle, dataBaseID, stmtSQL)

    %{ Departments/Work Centers %}
                              %elif (quicklinkRef == "departmentsworkcenters")
                                  %INCLUDE "QuickLinkClear.icl"
                                  @dtw_assign(uv_PlantName, "WCPLT")
                                  @dtw_assign(uv_MfgDepartmentName, "WCDEPT")
                                  @dtw_assign(uv_WorkCenterName, "WCWC")
                                  @dtw_assign(uv_CompanyName, "WCCO")
                                  @dtw_assign(uv_FacilityName, "WCFAC")
                                  @dtw_assign(uv_ScheduleName, "WCSCHD")
                                  %INCLUDE "userview.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDMWCM ", fileSQL)
                                  @dtw_concat(selectSQL, "WCPLT=$(plantNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %if (orderBy == "")
                                      @dtw_assign(orderBy, "WCDEPT,WCWC")
                                      @dtw_assign(orderByDisplay, "Department, Work Center")
                                  %endif
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Plant_Select_Departments_WorkCenters(profileHandle, dataBaseID, stmtSQL)

    %{ Top Vendors %}
                              %elif (quicklinkRef == "lastyeartopvendors" || quicklinkRef == "ytdtopvendors")
                                  %INCLUDE "QuickLinkClear.icl"
                                  @dtw_date("S", sysDateYYYYMMDD)
                                  @dtw_substr(sysDateYYYYMMDD,"3","2",sysYearYY)
                                  %if (quicklinkRef == "lastyeartopvendors")
                                      @dtw_subtract(sysYearYY,"1",yearYY)
                                  %else
                                      @dtw_assign(yearYY, sysYearYY)
                                  %endif
                                  @Build_Date_Range(yearYY, startCMD, endCMD)
                                  @RtvFldDesc("PIPLT=$(plantNumber) and PHLRDT>=$(startCMD) and PHLRDT<=$(endCMD)", "POPOHH inner join POPOHD on PHPO=PIPO and PHSEQ#=PISEQ#", "char(SUM((PIDSCC*PITRQT)/PIPCPB))", purchasesTotal)

                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(distinctSQL, "PHVEND ", distinctSQL)
                                  @dtw_concat(stmtSQL, " Select PHVEND, SUM((PIDSCC*PITRQT)/PIPCPB) as PURCHASES ", stmtSQL)
                                  @dtw_concat(fileSQL, " POPOHH inner join POPOHD on PHPO=PIPO and PHSEQ#=PISEQ# ", fileSQL)
                                  @dtw_concat(selectSQL, "PIPLT=$(plantNumber) and PHLRDT>=$(startCMD) and PHLRDT<=$(endCMD) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_concat(stmtSQL, " GROUP BY PHVEND", stmtSQL)
                                  @dtw_assign(orderBy, "PURCHASES Desc")
                                  @dtw_assign(orderByDisplay, "Purchases (descending)")
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Plant_Select_Top_Vendors(profileHandle, dataBaseID, stmtSQL)

    %{ Top Customers %}
                              %elif (quicklinkRef == "lastyeartopcustomers" || quicklinkRef == "ytdtopcustomers")
                                  %INCLUDE "QuickLinkClear.icl"
                                  @dtw_date("S", sysDateYYYYMMDD)
                                  @dtw_substr(sysDateYYYYMMDD,"3","2",sysYearYY)
                                  %if (quicklinkRef == "lastyeartopcustomers")
                                      @dtw_subtract(sysYearYY,"1",yearYY)
                                  %else
                                      @dtw_assign(yearYY, sysYearYY)
                                  %endif
                                  @Build_Date_Range(yearYY, startCMD, endCMD)
                                  @RtvFldDesc("DHSEQ#>0 and DHPLT=$(plantNumber) and DHRQDT>=$(startCMD) and DHRQDT<=$(endCMD)", "OEORDH", "char(SUM((DHQSTC*DHSLPR)/DHORUF))", salesTotal)

                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(distinctSQL, "DHSHTO ", distinctSQL)
                                  @dtw_concat(stmtSQL, " Select DHSHTO, SUM((DHQSTC*DHSLPR)/DHORUF) as SALES ", stmtSQL)
                                  @dtw_concat(fileSQL, " OEORDH ", fileSQL)
                                  @dtw_concat(selectSQL, "DHSEQ#>0 and DHPLT=$(plantNumber) and DHRQDT>=$(startCMD) and DHRQDT<=$(endCMD)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_concat(stmtSQL, " GROUP BY DHSHTO", stmtSQL)
                                  @dtw_assign(orderBy, "SALES Desc")
                                  @dtw_assign(orderByDisplay, "Sales (descending)")
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Plant_Select_Top_Customers(profileHandle, dataBaseID, stmtSQL)

    %{ Top Items %}
                              %elif (quicklinkRef == "lastyeartopitems" || quicklinkRef == "ytdtopitems")
                                  %INCLUDE "QuickLinkClear.icl"
                                  @dtw_date("S", sysDateYYYYMMDD)
                                  @dtw_substr(sysDateYYYYMMDD,"3","2",sysYearYY)
                                  %if (quicklinkRef == "lastyeartopitems")
                                      @dtw_subtract(sysYearYY,"1",yearYY)
                                  %else
                                      @dtw_assign(yearYY, sysYearYY)
                                  %endif
                                  @Build_Date_Range(yearYY, startCMD, endCMD)
                                  @RtvFldDesc("DHSEQ#>0 and DHPLT=$(plantNumber) and DHRQDT>=$(startCMD) and DHRQDT<=$(endCMD)", "OEORDH", "char(SUM((DHQSTC*DHSLPR)/DHORUF))", salesTotal)

                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(distinctSQL, "DHITEM ", distinctSQL)
                                  @dtw_concat(stmtSQL, " Select DHITEM, SUM((DHQSTC*DHSLPR)/DHORUF) as SALES, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " SUM(DHQSTC) as QTYSHIPPED ", stmtSQL)
                                  @dtw_concat(fileSQL, " OEORDH ", fileSQL)
                                  @dtw_concat(selectSQL, "DHSEQ#>0 and DHPLT=$(plantNumber) ", selectSQL)
                                  @dtw_concat(selectSQL, "and DHRQDT>=$(startCMD) and DHRQDT<=$(endCMD) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_concat(stmtSQL, " GROUP BY DHITEM", stmtSQL)
                                  @dtw_assign(orderBy, "SALES Desc")
                                  @dtw_assign(orderByDisplay, "Sales (descending)")
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Plant_Select_Top_Items(profileHandle, dataBaseID, stmtSQL)
                              %endif

    %{ Attachments %}         %INCLUDE "AttachmentSQL.icl"

%{ Quicklink End %}       %INCLUDE "QuickLinkEndLoop.icl"

                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Plant_Select_Header (IN  CHAR(64)    profileHandle,
                                            CHAR(2)     dataBaseID,
                                            CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              @dtw_assign(attachVarKey, plantNumber)
              @dtw_assign(attachForDesc, plantName)
              @dtw_assign(attachPrg1, "HDPLNT Where PLPLNT=$(plantNumber)")
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  @dtw_assign(maintainVar, "$(d2wVarBase)")
                  <td class="toolbar">
                      %while(@dtw_rlength(attachVarKey) != "3") {@dtw_insert("0", attachVarKey, attachVarKey)%}
                      %INCLUDE "Attachment.icl"
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)plantmaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (sec_01=="Y" && sec_04=="Y")
                          <a href="$(homeURL)$(cGIPath)plantmaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageLrg)</a>
                      %endif
                      %if (sec_02 == "Y" || sec_03 == "Y")
                          <a href="$(homeURL)$(cGIPath)plantmaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageLrg)</a>
                      %endif
                      %if (sec_03 == "Y")
                          @Format_Confirm_Desc($(plantName), $(plantNumber), "", "", "", "", confirmDesc)
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)plantmaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %ROW{
          @dtw_assign(scheduleNumber, V_PLSCHD)  %{ Capture the Schedule for later use. %}
          <table $(contentTable)>
              <colgroup>
                  <col width="60%">
                  <col width="20%">

              <tr><td class="dspalph">$(V_PLNAME)</td>
                  <td class="dsphdr">Plant Number</td>
                  <td class="dspnmbr">$(V_PLPLNT)</td>
              </tr>

              <tr><td class="dspalph">$(V_PLADR1)</td>
              </tr>

              <tr><td class="dspalph">$(V_PLADR2)</td>
              </tr>
	   			
              <tr><td class="dspalph">$(V_PLCITY), $(V_PLST) $(V_PLZIP)</td>
              </tr>

              %if (V_HDCTCD != V_PLCTRY && V_PLCTRY != "")
                 @RtvFldDesc("CNCTCD='$(V_PLCTRY)'", "HDCTRY", "CNCDES", fieldDesc)
                 @Format_Code(V_PLCTRY, F_PLCTRY)
                 <tr><td class="dsphdr">Country</td>
                     <td class="dspalph">$(fieldDesc)</td>
                     <td class="dspalph">$(F_PLCTRY)</td>
                 </tr>
              %endif

          </table>
          $(hrTagAttr)	

          %INCLUDE "QuickLinkDisplay.icl"
      %}
  %}
%}

%FUNCTION(dtw_sql) Plant_Select_General_Data (IN  CHAR(64)    profileHandle,
				                   CHAR(2)     dataBaseID,
                                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="generaldata"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      %ROW{
         <table $(contentTable)>
              @Format_CoFac("$(V_PLCO#)", "$(V_PLFAC#)", "F", F_CoFac)
              <tr><td class="dsphdr">Company/Facility</td>
                  <td class="dspalph">$(returnFldDesc)</td>
                  <td class="dspalph">$(F_CoFac)</td>
              </tr>

              @RtvFldDesc("SMSCHD=$(V_PLSCHD)", "HDSCHM", "SMDESC",fieldDesc )
              @Format_Code(V_PLSCHD, F_PLSCHD)
              <tr><td class="dsphdr">Schedule</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_PLSCHD)</td>
              </tr>
          </table>
      %}
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Plant_Select_Product_Data_Base (IN  CHAR(64)    profileHandle,
				                        CHAR(2)     dataBaseID,
                                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="productdatabase"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      %ROW{
          <table $(contentTable)>
              <tr><td class="dsphdr">Default Product Structure Routing Sequence</td>
                  <td class="dspalph">$(V_PLRSEQ)</td>
              </tr>
    	   		        		
              @RtvYNDesc($(V_PLRSF), fieldDesc)
              <tr><td class="dsphdr">Product Structure Interfaces With Routing</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>
          </table>
      %}
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Plant_Select_Default_Routing (IN  CHAR(64)    profileHandle,
				                                     CHAR(2)     dataBaseID,
                                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="defaultrouting"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      %ROW{
          <table $(contentTable)>
              @RtvFldDesc("WCPLT=$(V_PEPLT) and WCDEPT='$(V_PEDDPT)' and WCWC='$(V_PEDWC)'", "HDMWCM", "WCDESC", fieldDesc)
              <tr><td class="dsphdr">Default Department</td>
                  <td class="dspalph">$(V_PEDDPT)</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              <tr><td class="dsphdr">Default Work Center</td>
                  <td class="dspalph">$(V_PEDWC)</td>
              </tr>
          </table>
      %}
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Plant_Select_Cost_Management (IN  CHAR(64)    profileHandle,
				                      CHAR(2)     dataBaseID,
                                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="costmanagement"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      %ROW{
          <table $(contentTable)>
              <tr><td class="colhdr">Cost Category</td>
                  <td class="colhdr">Description</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">One</td>
                  <td class="dspalph">$(V_PLC1LD)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Two</td>
                  <td class="dspalph">$(V_PLC2LD)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Three</td>
                  <td class="dspalph">$(V_PLC3LD)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Four</td>
                  <td class="dspalph">$(V_PLC4LD)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Five</td>
                  <td class="dspalph">$(V_PLC5LD)</td>
              </tr>
              <tr><td>&nbsp;</td></tr>
          </table>

          <table $(contentTable)>
              <tr><td class="colhdr">Cost Simulation</td>
                  <td class="colhdr">Description</td>
                  <td class="colhdr">% Value</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Dollar One</td>
                  <td class="dspalph">$(V_PLDOL1)</td>
                  <td class="dspalph">&nbsp;</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Dollar Two</td>
                  <td class="dspalph">$(V_PLDOL2)</td>
                  <td class="dspalph">&nbsp;</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Percent One</td>
                  <td class="dspalph">$(V_PLPCT1)</td>
                  <td class="dspnmbr">$(V_PLPCA1)%</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Percent Two</td>
                  <td class="dspalph">$(V_PLPCT2)</td>
                  <td class="dspnmbr">$(V_PLPCA2)%</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Percent Three</td>
                  <td class="dspalph">$(V_PLPCT3)</td>
                  <td class="dspnmbr">$(V_PLPCA3)%</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Percent Four</td>
                  <td class="dspalph">$(V_PLPCT4)</td>
                  <td class="dspnmbr">$(V_PLPCA4)%</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">S&M % Mfg Cost</td>
                  <td class="dspalph"></td>
                  <td class="dspnmbr">$(V_PLSPCT)%</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">G&A % Mfg Cost</td>
                  <td class="dspalph">&nbsp;</td>
                  <td class="dspnmbr">$(V_PLGPCT)%</td>
              </tr>

              @RtvFldDesc("FLTYPE='FIXOVERHD' AND FLVALU='$(V_PLFXEL)'", "SYFLAG", "FLDESC", fieldDesc)
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Fixed Overhead Category</td>
                  <td class="dspalph">$(V_PLFXEL)</td>
                  <td class="dspalph">&nbsp;</td>
              </tr>
          </table>
      %}
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Plant_Select_MPS_MRP (IN  CHAR(64)    profileHandle,
				              CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="mpsmrp"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      %ROW{
          <table $(contentTable)>
              @Format_Date_ISO(V_PLDCP, "H", F_PLDCP)
              <tr><td class="dsphdr">Planning Horizon Date</td>
                  <td class="dspalph">$(F_PLDCP)</td>
              </tr>
              @PeriodFromCYP(V_PLFCM)
              <tr><td class="dsphdr">Current Fiscal Period</td>
                  <td class="dspalph">$(V_PLFCM)</td> 		
              </tr>

              <tr><td class="dsphdr"># Weeks Of Daily Periods</td>
                  <td class="dspalph">$(V_PL#WDD)</td>
              </tr>

              <tr><td class="dsphdr"># Weeks Of Weekly Periods</td>
                  <td class="dspalph">$(V_PL#WWD)</td>
              </tr>

              <tr><td class="dsphdr">Standard Hours/Day</td>
                  <td class="dspalph">$(V_PLSHR)</td>
              </tr>

              <tr><td class="dsphdr">Period Length In Days</td>
                  <td class="dspalph">$(V_PLPL)</td>
              </tr>

              <tr><td class="dsphdr">Fixed Time Periods Weeks</td>
                  <td class="dspalph">$(V_PLNTP)</td>
              </tr>

              @RtvYNDesc($(V_PLSSS), fieldDesc)
              <tr><td class="dsphdr">Include Safety Stock</td>
                  <td class="dspalph">$(fieldDesc)</td> 		
              </tr>

              @RtvYNDesc($(V_PLSCS), fieldDesc)
              <tr><td class="dsphdr">Include Scrap Percent</td>
                  <td class="dspalph">$(fieldDesc)</td> 		
              </tr>

              @RtvYNDesc($(V_PLSPS), fieldDesc)
              <tr><td class="dsphdr">Increase Order Quantities By Shrinkage Percentage</td>
                  <td class="dspalph">$(fieldDesc)</td> 		
              </tr>

              @RtvYNDesc($(V_PLPEGR), fieldDesc)
              <tr><td class="dsphdr">Create Pegged Requirements For Non MRP Items</td>
                  <td class="dspalph">$(fieldDesc)</td> 		
              </tr>

              <tr><td>&nbsp;</td></tr>

              <tr>
                  <td><table $(contentTable)>
                      <tr><td>&nbsp;</td>
                          <td class="colhdr">Manufacturing</td>
                          <td class="colhdr">Purchasing</td>
                      </tr>

                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          <td class="dsphdr">Order Action Periods</td>
                          <td class="colcode">$(V_PLMOA)</td>
                          <td class="colcode">$(V_PLPOA)</td>
                      </tr>

                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          <td class="dsphdr">Defer Damper Periods</td>
                          <td class="colcode">$(V_PLMDD)</td>
                          <td class="colcode">$(V_PLPDD)</td>
                      </tr>
                  </table></td>
              </tr>

              <tr><td>&nbsp;</td></tr>

              @RtvYNDesc($(V_PLMRPF), fieldDesc)
              <tr><td class="dsphdr">Use Prod Plan As MRP Input</td>
                  <td class="dspalph">$(fieldDesc)</td> 		
              </tr>

              @RtvFldDesc("FLTYPE='FORECASTDF' AND FLVALU='$(V_PLFDTF)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_PLFDTF, F_PLFDTF)
              <tr><td class="dsphdr">Forecast Date Format</td>
                  <td class="dspalph">$(fieldDesc)</td> 		
                  <td class="dspalph">$(F_PLFDTF)</td> 		
              </tr>

              @RtvFldDesc("FLTYPE='FORECASTSP' AND FLVALU='$(V_PLFSPR)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_PLFSPR, F_PLFSPR)
              <tr><td class="dsphdr">Forecast Spreaders</td>
                  <td class="dspalph">$(fieldDesc)</td> 		
                  <td class="dspalph">$(F_PLFSPR)</td> 		
              </tr>

              @RtvFldDesc("TFDEF='$(V_PLTFND)'", "HDMTFM", "TFDESC", fieldDesc)
              @Format_Code(V_PLTFND, F_PLTFND)
              <tr><td class="dsphdr">Time Fence Definition</td>
                  <td class="dspalph">$(fieldDesc)</td> 		
                  <td class="dspalph">$(F_PLTFND)</td> 		
              </tr>

              <tr><td class="dsphdr">Periods To Retain Forecast</td>
                  <td class="dspnmbr">$(V_PLPFCT)</td> 		
              </tr>

              <tr><td class="dsphdr">Periods To Consume Forecast</td>
                  <td class="dspnmbr">$(V_PLCFCT)</td> 		
              </tr>
          </table>
      %}
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Plant_Select_Shop_Floor_Control (IN  CHAR(64)    profileHandle,
				                         CHAR(2)     dataBaseID,
                                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="shopfloorcontrol"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      %ROW{
          <table $(contentTable)>
              @RtvYNDesc($(V_PLBKOP), fieldDesc)
              <tr><td class="dsphdr">Backflush Components By Operation</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              <tr><td class="dsphdr">Next Labor Sequence</td>
                  <td class="dspalph">$(V_PLLESQ)</td>
              </tr>

              <tr><td class="dsphdr">Last Mfg Order Number</td>
                  <td class="dspalph">$(V_PLNMO)</td>
              </tr>

              @RtvFldDesc("FLTYPE='DATANCHDFT' AND FLVALU='$(V_PLDFTA)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_PLDFTA, F_PLDFTA)
              <tr><td class="dsphdr">Default Date Anchor</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_PLDFTA)</td>
              </tr>

              @RtvFldDesc("FLTYPE='BY' AND FLVALU='$(V_PLUMFG)'", "SYFLAG", "FLDESC", fieldDesc)
              <tr><td class="dsphdr">Update Mfg Order Dates</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>
                            
              @RtvYNDesc($(V_PLORCL), fieldDesc)
              <tr><td class="dsphdr">Close Orders At Receipt Entry (OR)</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              @RtvFldDesc("FLTYPE='PIECEREWRK' AND FLVALU='$(V_PLDPRW)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_PLDPRW, F_PLDPRW)
              <tr><td class="dsphdr">Display Pieces To Rework Field</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_PLDPRW)</td>
              </tr>

              @RtvFldDesc("FLTYPE='HOURWRKFMT' AND FLVALU='$(V_PLHWKF)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_PLHWKF, F_PLHWKF)
              <tr><td class="dsphdr">Hours Worked Format</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_PLHWKF)</td>
              </tr>

              %if (V_PLCPDF == "")
                  @dtw_assign(V_PLCPDF, "N")
              %endif
              @RtvFldDesc("FLTYPE='COMPLPIECE' AND FLVALU='$(V_PLCPDF)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_PLCPDF, F_PLCPDF)
              <tr><td class="dsphdr">Completed Pieces Default</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_PLCPDF)</td>
              </tr>

              @RtvYNDesc($(V_PLRCPP), fieldDesc)
              <tr><td class="dsphdr">Recalculate Completed Pieces</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              @RtvYNDesc($(V_PLBCDC), fieldDesc)
              <tr><td class="dsphdr">Bar Code/Data Collection</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              @RtvYNDesc($(V_PLPRCD), fieldDesc)
              <tr><td class="dsphdr">Add Order Process Day</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              @RtvFldDesc("FLTYPE='AUTOEXPLPO' AND FLVALU='$(V_PLACPO)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_PLACPO, F_PLACPO)
              <tr><td class="dsphdr">Auto Explode Purchase Orders</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_PLACPO)</td>
              </tr>

              @RtvYNDesc($(V_PLAELV), fieldDesc)
              <tr><td class="dsphdr">Auto Explode All Levels</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              @RtvYNDesc($(V_PLAENT), fieldDesc)
              <tr><td class="dsphdr">Activate Auto Explode Netting</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              @RtvFldDesc("FLTYPE='KANBANPO' AND FLVALU='$(V_PLKPOC)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_PLKPOC, F_PLKPOC)
              <tr><td class="dsphdr">Kanban Purchase Order Code</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_PLKPOC)</td>
              </tr>

              @RtvFldDesc("FLTYPE='KANBANDOC' AND FLVALU='$(V_PLKBDD)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_PLKBDD, F_PLKBDD)
              <tr><td class="dsphdr">Kanban Document Definition</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_PLKBDD)</td>
              </tr>

              @RtvYNDesc($(V_PLSFLG), fieldDesc)
              <tr><td class="dsphdr">Place Order With Shortage On Hold</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              @RtvFldDesc("FLTYPE='STDMILITRY' AND FLVALU='$(V_PLHRSF)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_PLHRSF, F_PLHRSF)
              <tr><td class="dsphdr">Standard Or Military Hours</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_PLHRSF)</td>
              </tr>

              @RtvFldDesc("FLTYPE='TIMEENTFMT' AND FLVALU='$(V_PLTEF)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_PLTEF, F_PLTEF)
              <tr><td class="dsphdr">Time Entry Format</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_PLTEF)</td>
              </tr>

              %if (V_PLJCC == "")
                  @dtw_assign(V_PLJCC, "W")
              %endif
              @RtvFldDesc("FLTYPE='LBRRATEUSG' AND FLVALU='$(V_PLJCC)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_PLJCC, F_PLJCC)
              <tr><td class="dsphdr">WIP Labor Rate Usage Code</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_PLJCC)</td>
              </tr>

              @RtvYNDesc($(V_PLCNVS), fieldDesc)
              <tr><td class="dsphdr">Convert Labor Entry Shift</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              <tr><td>&nbsp;</td></tr>
          </table>


          <table $(contentTable)>
              <tr><td class="dsphdr">Labor Entry Shift Override</td>
                  <td class="colhdr">Regular</td>
                  <td class="colhdr">Piece Rate</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Shift Code 1</td>
                  <td class="colcode">$(V_PLRSO1)</td>
                  <td class="colcode">$(V_PLPSO1)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Shift Code 2</td>
                  <td class="colcode">$(V_PLRSO2)</td>
                  <td class="colcode">$(V_PLPSO2)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Shift Code 3</td>
                  <td class="colcode">$(V_PLRSO3)</td>
                  <td class="colcode">$(V_PLPSO3)</td>
              </tr>

              <tr><td>&nbsp;</td></tr>
          </table>

          <table $(contentTable)>
              @RtvFldDesc("C2COMP=$(V_PLCO#) and C2FACL=$(V_PLFAC#) and C2CODE='$(V_PLPRPC)'", "PRCODE", "C2DESC", fieldDesc)
              @Format_Code(V_PLPRPC, F_PLPRPC)
              <tr><td class="dsphdr">Piece Rate Pay Code Default</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_PLPRPC)</td>
              </tr>

              @RtvFldDesc("C2COMP=$(V_PLCO#) and C2FACL=$(V_PLFAC#) and C2CODE='$(V_PLPRHC)'", "PRCODE", "C2DESC", fieldDesc)
              @Format_Code(V_PLPRHC, F_PLPRHC)
              <tr><td class="dsphdr">Piece Rate Hours Pay Code</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_PLPRHC)</td>
              </tr>

              @RtvYNDesc($(V_PLRLCD), fieldDesc)
              <tr><td class="dsphdr">Restrict Labor Code Usage</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              @RtvFldDesc("FLTYPE='HALTERROR' AND FLVALU='$(V_PLHLDH)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_PLHLDH, F_PLHLDH)
              <tr><td class="dsphdr">Place Halt Errors On Hold</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_PLHLDH)</td>
              </tr>

              @RtvFldDesc("EVTYPE='X' AND EVCODE='$(V_PLSUPA)'", "HDEVNT", "EVDESC", fieldDesc)
              @Format_Code(V_PLSUPA, F_PLSUPA)
              <tr><td class="dsphdr">Supervisor Approval Code</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_PLSUPA)</td>
              </tr>
          </table>
      %}
      </fieldset>
  %}
%}

