%FUNCTION(dtw_sql) Plant_Select_Warehouse_Supply (IN  CHAR(64)    profileHandle,
				                       CHAR(2)     dataBaseID,
                                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="warehousesupply"></a>
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("WSSEQ#", "Priority<br>Sequence")
                  @Format_Column_Header("WSWH", "Whs")
                  @Format_Column_Header("WHWHNM", "Warehouse Name")
                  @Format_Column_Header("WHWHCT", "City")
                  @Format_Column_Header("WHWHST", "State")
                  @Format_Column_Header("WHHWZP", "Zip")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_WSSEQ#)</td>
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)WarehouseInquiry.d2w/DISPLAY$(genericVarBase)&amp;warehouseNumber=@dtw_rurlescseq(V_WSWH)" onclick="$(inquiryWinVar)" title="Warehouse Quickview">$(V_WSWH)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)WarehouseSelect.d2w/REPORT$(genericVarBase)&amp;warehouseNumber=@dtw_rurlescseq(V_WSWH)&amp;warehouseName=@dtw_rurlescseq(V_WHWHNM)" title="View Warehouse">$(V_WHWHNM)</a></td>
                  <td class="colalph">$(V_WHWHCT)</td>
                  <td class="colcode">$(V_WHWHST)</td>
                  <td class="colalph">$(V_WHHWZP)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Plant_Select_Departments_WorkCenters (IN  CHAR(64)    profileHandle,
				                              CHAR(2)     dataBaseID,
                                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="departmentsworkcenters"></a>
      @dtw_assign(moreURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=218&amp;fKey1=WCPLT&amp;fVal1=@dtw_rurlescseq(plantNumber)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  <th>&nbsp;</th>
                  <th>&nbsp;</th>
                  <th>&nbsp;</th>
                  <th class="colhdr" colspan="3">Hours Per Day</th>
                  <th class="colhdr" colspan="2">Utilization %</th>
                  <th class="colhdr">Efficiency %</th>
              </tr>
              <tr>
                  @Format_Column_Header("WCDEPT", "Dept")
                  @Format_Column_Header("WCWC", "Work<br>Center")
                  @Format_Column_Header("WCDESC", "Description")
                  <th class="colhdr">Labor</th>
                  <th class="colhdr">Machine</th>
                  <th class="colhdr">Setup</th>
                  <th class="colhdr">Labor</th>
                  <th class="colhdr">Machine</th>
                  <th class="colhdr">Labor</th>
                  @Format_Column_Header("WCKLCD", "Key<br>Load")
                  @Format_Column_Header("WCSCHD", "Schedule")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Nbr(V_WCLHRD, F_WCLHRD, "0", $(hrsEditCode), "", "", "")
              @Format_Nbr(V_WCMHRD, F_WCMHRD, "0", $(hrsEditCode), "", "", "")
              @Format_Nbr(V_WCSHRD, F_WCSHRD, "0", $(hrsEditCode), "", "", "")
              @Format_Nbr(@dtw_rformat(@dtw_rmultiply(V_WCLAUT, "100")), F_WCLAUT, "0", $(pctEditCode), "", "", "")
              @Format_Nbr(@dtw_rformat(@dtw_rmultiply(V_WCMAUT, "100")), F_WCMAUT, "0", $(pctEditCode), "", "", "")
              @Format_Nbr(@dtw_rformat(@dtw_rmultiply(V_WCLAEF, "100")), F_WCLAEF, "0", $(pctEditCode), "", "", "")
              <tr class="$(rowClass)">
                  <td class="colalph">$(V_WCDEPT)</td>
                  <td class="colalph">$(V_WCWC)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)WorkCenterSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;department=@dtw_rurlescseq(V_WCDEPT)&amp;workCenter=@dtw_rurlescseq(V_WCWC)&amp;description=@dtw_rurlescseq(V_WCDESC)" title="View Work Center">$(V_WCDESC)</a></td>
                  <td class="colnmbr">$(F_WCLHRD)</td>
                  <td class="colnmbr">$(F_WCMHRD)</td>
                  <td class="colnmbr">$(F_WCSHRD)</td>
                  <td class="colnmbr">$(F_WCLAUT)</td>
                  <td class="colnmbr">$(F_WCMAUT)</td>
                  <td class="colnmbr">$(F_WCLAEF)</td>
                  %if (V_WCKLCD == "N")
                      <td class="colcode">&nbsp;</td>
                  %else
                      <td class="colcode">$(V_WCKLCD)</td>
                  %endif
                  <td class="colnmbr">$(V_WCSCHD)</td>
              </td>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Plant_Select_Top_Customers (IN CHAR(64)    profileHandle,
				                   CHAR(2)     dataBaseID,
                                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (quicklinkRef == "ytdtopcustomers" )
          <a name="ytdtopcustomers"></a>
      %else
          <a name="lastyeartopcustomers"></a>
      %endif
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

          %if (sql_Record_Count == "0")
              <table $(contentTable)>
                  %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              @Format_Nbr(salesTotal, F_salesTotal, "2", $(amtEditCode), "", "$", "")
              <div class="page">
                   Total Sales: $(F_salesTotal)
              </div>

              <table $(contentTable)>
                  <tr>
                      @Format_Column_Header("DHSHTO", "Customer<br>Number")
                      @Format_Column_Header("xxx", "Customer Name")
                      @Format_Column_Header("SALES", "Sales")
                      @Format_Column_Header("xxx", "Percent<br>of Total")
                  </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              %if (salesTotal > "0")
                  @dtw_multiply(V_SALES, "100", percentOfTotal)
                  @dtw_divide(percentOfTotal, salesTotal, percentOfTotal)
                  @Format_Nbr($(percentOfTotal), F_percentOfTotal, "2", $(pctEditCode), "Y", "", "%")
              %else
                  @dtw_assign(F_percentOfTotal, "")
              %endif
              @Format_Nbr($(V_SALES), F_SALES, "2", $(amtEditCode), "", "", "")
              @RtvFldDesc("CMCUST=$(V_DHSHTO)", "HDCUST", "CMCNA1", fieldDesc)
              <tr class="$(rowClass)">
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)CustomerInquiry.d2w/DISPLAY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(V_DHSHTO)" onclick="$(inquiryWinVar)" title="Customer Quickview">$(V_DHSHTO)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)CustomerSelect.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(V_DHSHTO)&amp;customerName=@dtw_rurlescseq(fieldDesc)" title="View Customer">$(fieldDesc)</a></td>
                  <td class="colnmbr">$(F_SALES)</td>
                  <td class="colnmbr">$(F_percentOfTotal)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Plant_Select_Top_Items (IN CHAR(64)    profileHandle,
				               CHAR(2)     dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (quicklinkRef == "ytdtopitems" )
          <a name="ytdtopitems"></a>
      %else
          <a name="lastyeartopitems"></a>
      %endif
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

          %if (sql_Record_Count == "0")
              <table $(contentTable)>
                   %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              @Format_Nbr(salesTotal, F_salesTotal, "2", $(amtEditCode), "", "$", "")
              <div class="page">
                   Total Sales: $(F_salesTotal)
              </div>

              <table $(contentTable)>
                  <tr>
                      @Format_Column_Header("DHITEM", "Item Number")
                      @Format_Column_Header("xxx", "Item Description")
                      @Format_Column_Header("SALES", "Sales")
                      @Format_Column_Header("xxx", "Percent<br>of Total")
                      @Format_Column_Header("QTYSHIPPED", "Quantity")
                  </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              %if (salesTotal > "0")
                  @dtw_multiply(V_SALES, "100", percentOfTotal)
                  @dtw_divide(percentOfTotal, salesTotal, percentOfTotal)
                  @Format_Nbr($(percentOfTotal), F_percentOfTotal, "2", $(pctEditCode), "Y", "", "%")
              %else
                  @dtw_assign(F_percentOfTotal, "")
              %endif
              @Format_Nbr(V_QTYSHIPPED, F_QTYSHIPPED, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_SALES), F_SALES, "2", $(amtEditCode), "", "", "")
              @RtvFldDesc("IMITEM='$(V_DHITEM)'", "HDIMST", "IMIMDS", fieldDesc)
              <tr class="$(rowClass)">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemInquiry.d2w/DISPLAY$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq($(V_DHITEM))" onclick="$(inquiryWinVar)" title="Item Quickview">$(V_DHITEM)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_DHITEM)&amp;itemDescription=@dtw_rurlescseq(fieldDesc)" title="View Item">$(fieldDesc)</a></td>
                  <td class="colnmbr">$(F_SALES)</td>
                  <td class="colnmbr">$(F_percentOfTotal)</td>
                  <td class="colnmbr">$(F_QTYSHIPPED)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

