%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Item List"
  d2wName                 = "ItemList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)&amp;apid=@dtw_rurlescseq(apid)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "4"
  userdef                 = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          @dtw_assign(userdef, "")
          %if (V_HDINRL > "0")
              %if (V_CIIAS1 != "")
                  @dtw_assign(userdef, "Y")
              %elif (V_CIIAS2 != "")
                  @dtw_assign(userdef, "Y")
              %elif (V_CIIAS3 != "")
                  @dtw_assign(userdef, "Y")
              %elif (V_CIIAS4 != "")
                  @dtw_assign(userdef, "Y")
              %elif (V_CIIAS5 != "")
                  @dtw_assign(userdef, "Y")
              %elif (V_CIINS1 != "")
                  @dtw_assign(userdef, "Y")
              %elif (V_CIINS2 != "")
                  @dtw_assign(userdef, "Y")
              %elif (V_CIINS3 != "")
                  @dtw_assign(userdef, "Y")
              %elif (V_CIINS4 != "")
                  @dtw_assign(userdef, "Y")
              %elif (V_CIINS5 != "")
                  @dtw_assign(userdef, "Y")
              %endif
          %endif
          %if (V_HDPDRL > "0")
              @dtw_assign(sortSeqMax, "4")
          %else
              @dtw_assign(sortSeqMax, "3")
          %endif
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if  (editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromProductClass, document.Chg.toProductClass, document.Chg.allProductClass, "A") &&
                      editFromToAll(document.Chg.fromInventoryType, document.Chg.toInventoryType, document.Chg.allInventoryType, "A")
                      %if (V_HDPDRL > "0")
                          && editFromToAll(document.Chg.fromPartType, document.Chg.toPartType, document.Chg.allPartType, "A")
                      %endif
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ITEMLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromItemNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@cont", "reportContent")     @dtw_assign(Err_N1SEL,  fieldValue)
                                  @DecatErr_Field("@@gndt", "generalData")
 @dtw_assign(Err_N2GNDT,  fieldValue)
                                  @DecatErr_Field("@@exds", "extendeddescription") @dtw_assign(Err_N2EXDS,  fieldValue)
                                  @DecatErr_Field("@@usdt", "userDefinedData")     @dtw_assign(Err_N2USDT,  fieldValue)
                                  @DecatErr_Field("@@sitm", "sortItemNumber")        @dtw_assign(Err_N2SITM,  fieldValue)
                                  @DecatErr_Field("@@spcl", "sortProductClass")        @dtw_assign(Err_N2SPCL,  fieldValue)
                                  @DecatErr_Field("@@sitc", "sortInventoryType")          @dtw_assign(Err_N2SITC,  fieldValue)
                                  @DecatErr_Field("@@sptp", "sortPartType")          @dtw_assign(Err_N2SPTP,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@cont")  @dtw_assign(V_N1SEL,  fieldValue)
                                  @Decat_Field("@@gndt")  @dtw_assign(V_N2GNDT,  fieldValue)
                                  @Decat_Field("@@exds")  @dtw_assign(V_N2EXDS,  fieldValue)
                                  @Decat_Field("@@usdt")  @dtw_assign(V_N2USDT,  fieldValue)
                                  @Decat_Field("@@fitm")  @dtw_assign(V_N2FITM,  fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N2TITM,  fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N2AITM,  fieldValue)
                                  @Decat_Field("@@sitm")  @dtw_assign(V_N2SITM,  fieldValue)
                                  @Decat_Field("@@fpcl")  @dtw_assign(V_N2FPCL,  fieldValue)
                                  @Decat_Field("@@tpcl")  @dtw_assign(V_N2TPCL,  fieldValue)
                                  @Decat_Field("@@apcl")  @dtw_assign(V_N2APCL,  fieldValue)
                                  @Decat_Field("@@spcl")  @dtw_assign(V_N2SPCL,  fieldValue)
                                  @Decat_Field("@@fitc")  @dtw_assign(V_N2FITC,  fieldValue)
                                  @Decat_Field("@@titc")  @dtw_assign(V_N2TITC,  fieldValue)
                                  @Decat_Field("@@aitc")  @dtw_assign(V_N2AITC,  fieldValue)
                                  @Decat_Field("@@sitc")  @dtw_assign(V_N2SITC,  fieldValue)
                                  @Decat_Field("@@fptp")  @dtw_assign(V_N2FPTP,  fieldValue)
                                  @Decat_Field("@@tptp")  @dtw_assign(V_N2TPTP,  fieldValue)
                                  @Decat_Field("@@aptp")  @dtw_assign(V_N2APTP,  fieldValue)
                                  @Decat_Field("@@sptp")  @dtw_assign(V_N2SPTP,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1SEL == "02")
                                      @dtw_assign(detail, "")
                                      @dtw_assign(summary, "CHECKED")
                                  %else
                                      @dtw_assign(detail, "CHECKED")
                                      @dtw_assign(summary, "")
                                  %endif
                                  %if (V_N2GNDT == "1")
                                      @dtw_assign(checkedGeneralData, "CHECKED")
                                  %else
                                      @dtw_assign(checkedGeneralData, "")
                                  %endif
                                  %if (V_N2EXDS == "1")
                                      @dtw_assign(checkedExtendedDescription, "CHECKED")
                                  %else
                                      @dtw_assign(checkedExtendedDescription, "")
                                  %endif
                                  %if (V_N2USDT == "1")
                                      @dtw_assign(checkedUserDefinedData, "CHECKED")
                                  %else
                                      @dtw_assign(checkedUserDefinedData, "")
                                  %endif
                                  %if (V_N2AITM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_N2APCL == "ALL")
                                      @dtw_assign(checkedallProductClass, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallProductClass, "")
                                  %endif
                                  %if (V_N2AITC == "ALL")
                                      @dtw_assign(checkedallInventoryType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallInventoryType, "")
                                  %endif
                                  %if (V_N2APTP == "ALL")
                                      @dtw_assign(checkedallPartType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPartType, "")
                                  %endif
                              %else
                                  @dtw_assign(detail, "CHECKED")
                                  @dtw_assign(summary, "")
                                  @dtw_assign(checkedGeneralData, "CHECKED")
                                  @dtw_assign(checkedExtendedDescription, "CHECKED")
                                  @dtw_assign(checkedUserDefinedData, "CHECKED")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallProductClass, "CHECKED")
                                  @dtw_assign(checkedallInventoryType, "CHECKED")
                                  @dtw_assign(checkedallPartType, "CHECKED")
                              %endif

                              <tr><td><input type="hidden" name="dspPartType" value="$(V_HDPDRL)"></td></tr>

                              @SetTextOvr(Err_N1SEL)
                              <tr><td  class="dsphdr"><span $(textOvr)>Report Content Selection</span></td>
                                  <td class="inputnmbr"><input name="reportContent" type="radio" VALUE='01' $(detail)>Detail</td>
                              </tr>
                              @DspErrMsg(Err_N1SEL)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="reportContent" type="radio" VALUE='02' $(summary)>Summary</td>
                              </tr>

                              @SetTextOvr(Err_N2GNDT)
                              <tr><td class="dsphdr"><span $(textOvr)>Options For Detail Selection</span></td>
                                  <td class="inputnmbr"><input name="generalData" type="checkbox" VALUE='1' $(checkedGeneralData)>General Data</td>
                              </tr>
                              @DspErrMsg(Err_N2GNDT)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="extendedDescription" type="checkbox" VALUE='1' $(checkedExtendedDescription)>Extended Description</td>
                              </tr>

                              %if (userdef == "Y")
                                  <tr><td>&nbsp;</td>
                                      <td class="inputnmbr"><input name="userDefinedData" type="checkbox" VALUE='1' $(checkedUserDefinedData)>User-Defined Data</td>
                                  </tr>
                              %endif

                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                              </tr>

                              @SetTextOvr(Err_N2FITM)
                              %if (textOvr == "") @SetTextOvr(Err_N2SITM) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N2FITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N2TITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                                  @Build_Sort_Select("sortItemNumber", "$(V_N2SITM)")
                              </tr>
                              @DspErrMsg(Err_N2SITM)

                              @SetTextOvr(Err_N2FPCL)
                              %if (textOvr == "") @SetTextOvr(Err_N2SPCL) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Product Class</span></td>
                                  <td class="inputalph"><input name="fromProductClass" value="$(V_N2FPCL)" type="text" size="8" maxlength="4"><a href="$(homeURL)$(cGIPath)ProdClassSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromProductClass&amp;fldDesc=fproductClassDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="fproductClassDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="toProductClass" value="$(V_N2TPCL)" type="text" size="8" maxlength="4"><a href="$(homeURL)$(cGIPath)ProdClassSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toProductClass&amp;fldDesc=tproductClassDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="tproductClassDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allProductClass" value='ALL' $(checkedallProductClass) type="checkbox" onClick="if (this.checked) this.form.fromProductClass.value='', this.form.toProductClass.value='';"></td>
                                  @Build_Sort_Select("sortProductClass", "$(V_N2SPCL)")
                              </tr>
                              @DspErrMsg(Err_N2SPCL)

                              @SetTextOvr(Err_N2FITC)
                              %if (textOvr == "") @SetTextOvr(Err_N2SITC) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Inventory Type</span></td>
                                  <td class="inputalph"><input   name="fromInventoryType" type="text" value="$(V_N2FITC)" size="4" maxlength="4"><a href="$(homeURL)$(cGIPath)invtypesearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromInventoryType&amp;fldDesc=fromITCDescH" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fromITCDescH" type="hidden"></td>
                                  <td class="inputalph"><input   name="toInventoryType" type="text" value="$(V_N2TITC)" size="4" maxlength="4"><a href="$(homeURL)$(cGIPath)invtypesearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toInventoryType&amp;fldDesc=fromITCDescH" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fromITCDescH" type="hidden"></td>

                                  <td class="inputalph"><input name="allInventoryType" value='ALL' $(checkedallInventoryType) type="checkbox" onClick="if (this.checked) this.form.fromInventoryType.value='', this.form.toInventoryType.value='';"></td>
                                  @Build_Sort_Select("sortInventoryType", "$(V_N2SITC)")
                              </tr>
                              @DspErrMsg(Err_N2SITC)

                              %if (V_HDPDRL > "0")
                                  @SetTextOvr(Err_N2FPTP)
                                  %if (textOvr == "") @SetTextOvr(Err_N2SPTP) %endif
                                  <tr><td  class="dsphdr"><span $(textOvr)>Part Type</span></td>
                                      <td class="inputnmbr"><input name="fromPartType" value="$(V_N2FPTP)" type="text" size="1" maxlength="1"></td>
                                      <td class="inputnmbr"><input name="toPartType" value="$(V_N2TPTP)" type="text" size="1" maxlength="1"></td>
                                      <td class="inputalph"><input name="allPartType" value='ALL' $(checkedallPartType) type="checkbox" onClick="if (this.checked) this.form.fromPartType.value='', this.form.toPartType.value='';"></td>
                                      @Build_Sort_Select("sortPartType", "$(V_N2SPTP)")
                                  </tr>
                                  @DspErrMsg(Err_N2SPTP)
                              %endif

                          </table>

                          @dtw_assign(envProgram, "HHDIML")
                          @dtw_assign(envPrinter, "HHDIMLPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HHDITS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(fromProductClass)
  @dtw_mUPPERCASE(toProductClass)
  @dtw_mUPPERCASE(allProductClass)
  @dtw_mUPPERCASE(fromInventoryType)
  @dtw_mUPPERCASE(toInventoryType)
  @dtw_mUPPERCASE(allInventoryType)
  @dtw_mUPPERCASE(fromPartType)
  @dtw_mUPPERCASE(toPartType)
  @dtw_mUPPERCASE(allPartType)

  @dtw_assign(sortItemNumber,@dtw_rstrip(sortItemNumber))
  @dtw_assign(sortProductClass,@dtw_rstrip(sortProductClass))
  @dtw_assign(sortInventoryType,@dtw_rstrip(sortInventoryType))
  @dtw_assign(sortPartType,@dtw_rstrip(sortPartType))

  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allProductClass != "ALL")
      @dtw_assign(allProductClass, "")
  %endif
  %if (allInventoryType != "ALL")
      @dtw_assign(allInventoryType, "")
  %endif
  %if (allPartType != "ALL")
      @dtw_assign(allPartType, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@cont", reportContent)
  @Concat_Field("@@apid", apid)
  %if (reportContent == "01")
      @Concat_Field("@@gndt", generalData)
      @Concat_Field("@@exds", extendedDescription)
      @Concat_Field("@@usdt", userDefinedData)
  %endif
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@sitm", sortItemNumber)
  @Concat_Field("@@fpcl", fromProductClass)
  @Concat_Field("@@tpcl", toProductClass)
  @Concat_Field("@@apcl", allProductClass)
  @Concat_Field("@@spcl", sortProductClass)
  @Concat_Field("@@fitc", fromInventoryType)
  @Concat_Field("@@titc", toInventoryType)
  @Concat_Field("@@aitc", allInventoryType)
  @Concat_Field("@@sitc", sortInventoryType)
  %if (dspPartType != "")
      @Concat_Field("@@fptp", fromPartType)
      @Concat_Field("@@tptp", toPartType)
      @Concat_Field("@@aptp", allPartType)
      @Concat_Field("@@sptp", sortPartType)
  %endif


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}