%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Common User Maintenance"
  d2wName                 = "CommonUserMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;updRecNbr=@dtw_rurlescseq(updRecNbr)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;individualUser=@dtw_rurlescseq(individualUser)&amp;commonUser=@dtw_rurlescseq(commonUser)&amp;maintenanceCode=D"
  programName             = "HSYCUM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  retrieveCode            = "R"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.individualUser.value =="" ||
                      document.Chg.commonUser.value =="" ||
                      document.Chg.fillRange.value =="")
                         {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.fromRate, 3, 0) &&
                      editNum(document.Chg.toRate, 3, 0))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
              %INCLUDE "numedit.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "COMMONUSERAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "SELECT * ", stmtSQL)
                          @dtw_concat(fileSQL, " SYCUSF ", fileSQL)
                          @dtw_concat(selectSQL, " CUUSER='$(individualUser)' and CUCUSR='$(commonUser)'", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN  CHAR(64) profileHandle,
                                       CHAR(2)   dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=160")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          %ROW {
              %if (errFound != "" || maintenanceCode == "A")
                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(edtVar, "")
                      @dtw_assign(focusField, "individualUser")
                      @dtw_assign(V_CUPASS, "N")
                  %else
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @dtw_assign(focusField, "")
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@user", "individualUser")        @dtw_assign(Err_CUUSER, fieldValue)
                      @DecatErr_Field("@@cusr", "commonUser")            @dtw_assign(Err_CUCUSR, fieldValue)
                      @DecatErr_Field("@@pass", "fillRange")             @dtw_assign(Err_CUPASS, fieldValue)
                      @DecatErr_Field("@@frat", "fromRate")              @dtw_assign(Err_CUFRAT, fieldValue)
                      @DecatErr_Field("@@trat", "toRate")                @dtw_assign(Err_CUTRAT, fieldValue)
                  %endif

                  @Decat_Field("@@user")   @dtw_assign(V_CUUSER, fieldValue)
                  @Decat_Field("@@cusr")   @dtw_assign(V_CUCUSR, fieldValue)
                  @Decat_Field("@@pass")   @dtw_assign(V_CUPASS, fieldValue)
                  @Decat_Field("@@frat")   @dtw_assign(V_CUFRAT, fieldValue)
                  @Decat_Field("@@trat")   @dtw_assign(V_CUTRAT, fieldValue)
                  @dtw_assign(errFound, "")

                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(V_CUPASS, "N")
                  %endif

              %elif (maintenanceCode == "Z")
                  @dtw_assign(focusField, "individualUser")
              %else
                  @dtw_assign(focusField, "fillRange")
              %endif

              <table $(contentTable)>
                  @SetTextOvr(Err_CUUSER)
                  @RtvFldDesc("USUSER='$(V_CUUSER)' ", "SYUSER", "USDESC", fieldDesc)
                  <tr><td class="dsphdr"><span $(textOvr)>Individual User</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input type="text" name="individualUser" value="$(V_CUUSER)" size="10" maxlength="10">
                                                <a href="$(homeURL)$(phpPath)UserSearch.php$(altVarBase)&amp;docName=Chg&amp;userFld=individualUser&amp;descFld=individualUserName" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage)</a>
                                                <input type="text" disabled name="individualUserName" value="$(fieldDesc)" size="30"></td>
                      %else
                          <td class="inputalph"><input type="hidden" name="individualUser" value="$(V_CUUSER)">$(V_CUUSER) $(fieldDesc)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_CUUSER)

                  @SetTextOvr(Err_CUCUSR)
                  <tr><td class="dsphdr"><span $(textOvr)>Common User</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input type="text" name="commonUser" value="$(V_CUCUSR)" size="10" maxlength="10"> $(reqFieldChar) </td>
                      %else
                          <td class="inputalph"><input type="hidden" name="commonUser" value="$(V_CUCUSR)" size="10" maxlength="10">$(V_CUCUSR)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_CUCUSR)
               			
                  @SetTextOvr(Err_CUPASS)
                  <tr><td class="dsphdr"><span $(textOvr)>Fill All Ranges</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_CUPASS) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "fillRange", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_CUPASS)
              </table>
    	   		
              <table $(contentTable)>
                  <tr><td class="dsphdr">&nbsp;</td>
                      <td class="dsphdr">From</td>
                      <td class="dsphdr">To</td>
                  </tr>
               			
                  @SetTextOvr(Err_CUFRAT)
                  <tr><td class="dsphdr"><span $(textOvr)>Complexity Rating</span></td>
                      <td class="inputnmbr"><input type="text" name="fromRate" value="$(V_CUFRAT)" size="3" maxlength="3"></td>
                      <td class="inputnmbr"><input type="text" name="toRate" value="$(V_CUTRAT)" size="3" maxlength="3"></td>
                  </tr>
                  @DspErrMsg(Err_CUFRAT)
              </table>
          %}	

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSYCUM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(individualUser)
  @dtw_mUPPERCASE(commonUser)
  @dtw_mUPPERCASE(fillRange)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@user", individualUser)
  @Concat_Field("@@cusr", commonUser)
  @Concat_Field("@@pass", fillRange)
  @Concat_Field("@@frat", fromRate)
  @Concat_Field("@@trat", toRate)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      @RtvFldDesc("USUSER='$(individualUser)' ", "SYUSER", "USDESC", V_USDESC)
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(commonUser), "", $(V_USDESC), $(individualUser), "", "", confMessage)
      %else
          @DecatErr_Field("@@user", "user")
          @Format_ConfMsg_Desc("", $(commonUser), "", $(V_USDESC), $(individualUser), "<br>$(fieldValue)", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=160&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;individualUser=@dtw_rurlescseq(individualUser)&amp;commonUser=@dtw_rurlescseq(commonUser)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
