%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Import Template Maintenance"
  d2wName                 = "MapImportTemplateMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;importKey=@dtw_rurlescseq(importKey)&amp;passedImportTable=@dtw_rurlescseq(passedImportTable)&amp;passedRecordType=@dtw_rurlescseq(passedRecordType)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;updRecNbr=@dtw_rurlescseq(updRecNbr)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  editVariables           = ""
  interfaceLibrary        = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @RtvFldDesc("FEXHND='$(profileHandle)' and FEIMKY=$(importKey) ", "SYMITE", "char(count(*))", recCount)	
  %if (recCount <= "0")
      @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "CHAR(FHMPKY)", V_FHMPKY)
      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Insert Into SYMITE (FEXHND,FEIMKY,FEMFIL,FEMFLD,FEIFIL,FERTYP,FEFLDT,FEFLPL,FELNGT,FEIDEC,FEDECM,FEXIFL,FEXREF,FEMFNC,FEDFMP,FEVALU,FEANAB,FEDTFM,FEPDFM,FETMFM) ", stmtSQL)
      @dtw_concat(stmtSQL, " Select '$(profileHandle)', FDIMKY,FDMFIL,FDMFLD,FDIFIL,FDRTYP,FDFLDT,FDFLPL,FDLNGT,FDIDEC,FDDECM,FDXIFL,FDXREF,FDMFNC,FDDFMP,FDVALU,FDANAB,FDDTFM,FDPDFM,FDTMFM  ", stmtSQL)
      @dtw_concat(stmtSQL, " From SYMITP Where FDIMKY=$(importKey) ", stmtSQL)
      @dtw_concat(stmtSQL, " and exists (Select * from SYMMCL where MDMPKY=$(V_FHMPKY) and MDDPOS<>0 and MDMFIL=FDMFIL and MDMFLD=FDMFLD) ", stmtSQL)
      @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)

      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Insert Into SYMITE (FEXHND,FEIMKY,      FEMFIL,FEMFLD,FEIFIL,FERTYP,FEFLDT,FEFLPL,FELNGT,FEIDEC,FEDECM,FEXIFL,FEXREF,FEMFNC,FEDFMP,FEVALU,FEANAB,FEDTFM,FEPDFM,FETMFM) ", stmtSQL)
      @dtw_concat(stmtSQL, " Select '$(profileHandle)', $(importKey),MDMFIL,MDMFLD,' ',   ' ',   ' ',   0,     0,     ' ',   0,     ' ',   ' ',   ' ',   ' ',   ' ',   ' ',   ' ',   ' ',   ' '     ", stmtSQL)
      @dtw_concat(stmtSQL, " From SYMMCL Where MDMPKY=$(V_FHMPKY) ", stmtSQL)
      @dtw_concat(stmtSQL, " and not exists (Select * from SYMITE where FEXHND='$(profileHandle)' and FEIMKY=$(importKey) and FEMFIL=MDMFIL and FEMFLD=MDMFLD) ", stmtSQL)
      @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)
  %endif

  @RtvFldDesc("FEXHND='$(profileHandle)' and FEIMKY=$(importKey) and MDDPOS<>0 ", "SYMITE inner join SYMIHD on FHIMKY=FEIMKY Inner Join SYMMCL on MDMPKY=FHMPKY and MDMFIL=FEMFIL and MDMFLD=FEMFLD ", "char(count(*))", recCount)	
  @dtw_assign(editVariables, "")
  @dtw_assign(ux, "1")
  %while(ux <= recCount){
      @dtw_assign(recNbr, ux)
      %while(@dtw_rlength(recNbr) != "4") {@dtw_insert("0", recNbr, recNbr)%}
      %if (editVariables != "")
          @dtw_concat(editVariables, "  &&", editVariables)
      %endif
      @dtw_concat(editVariables, " editNum(document.Chg.flpl$(recNbr), 5, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.lngt$(recNbr), 5, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.decm$(recNbr), 1, 0) ", editVariables)
      @dtw_add(ux, "1", ux)
  %}

  %INCLUDE "$(docType)"
  <html>
      <head>
 	   %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function confirmCancel()  { return confirm("Confirm cancel of update")}
              function confirmRefresh() { return confirm("Confirm refresh of columns")}
              function validate(chgForm) {
                  if ($(editVariables))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "MAPIMPORTTEMPLATEMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select SYMITE.*,  ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(MDDESC,' ') as MDDESC, coalesce(MDDLGC,' ') as MDDLGC, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(MDNOTE,' ') as MDNOTE, coalesce(MDFLDT,' ') as MDFLDT, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(MDSTOR,' ') as MDSTOR, coalesce(MDNAB,' ')  as MDNAB ,", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(MDPARM,' ') as MDPARM ", stmtSQL)
                      @dtw_concat(stmtSQL, " From SYMITE ", stmtSQL)
                      @dtw_concat(stmtSQL, " inner join SYMIHD on FHIMKY=FEIMKY ", stmtSQL)
                      @dtw_concat(stmtSQL, " Inner Join SYMMCL on MDMPKY=FHMPKY and MDMFIL=FEMFIL and MDMFLD=FEMFLD ", stmtSQL)
                      @dtw_concat(stmtSQL, " Where FEXHND='$(profileHandle)' and FEIMKY=$(importKey) ", stmtSQL)
                      @dtw_concat(stmtSQL, "   and MDDPOS<>0 ", stmtSQL)
                      @dtw_concat(stmtSQL, " Order By FEMFIL,MDDPOS,FEMFLD ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "CHAR(FHMPKY)", V_FHMPKY)
      @RtvFldDesc("FFIMKY=$(importKey)", "SYMITB", "CHAR(COUNT(*))", importTableCount)
      %if (importTableCount == "1")
          @RtvFldDesc("FFIMKY=$(importKey)", "SYMITB", "max(FFIFIL)", restrictImportTable)
      %endif

      @RtvFldDesc("FFIMKY=$(importKey)", "SYMITB", "char(Count(distinct FFFIXF))", placementCount)
      %if (placementCount > "1")
          @dtw_assign(fixedFormat, "Y")
      %elif (placementCount == "1")
          @RtvFldDesc("FFIMKY=$(importKey)", "SYMITB", "distinct FFFIXF", fixedFormat)
      %else
          @dtw_assign(fixedFormat, "")
      %endif

      @RtvFldDesc("FFIMKY=$(importKey) and FFRTPS>0 ", "SYMITB", "char(Count(*))", recordTypeTables)
      @RtvFldDesc("FRIMKY=$(importKey)", "SYMIRT", "CHAR(COUNT(*))", recordTypeCount)
      %if (recordTypeTables > "0" && recordTypeTables != importTableCount || recordTypeCount > "1")
          @RtvFldDesc("FFIMKY=$(importKey)", "SYMITB", "CHAR(MAX(FFRTLN))", V_FFRTLN)
      %endif
      %if (recordTypeTables == importTableCount && recordTypeCount=="1")
          @dtw_assign(limitRecordType, "Y")
          %if (restrictImportTable == "")
              @RtvFldDesc("FRIMKY=$(importKey)", "SYMIRT", "MAX(FRRTYP)", restrictRecordType)
          %else
              @RtvFldDesc("FRIMKY=$(importKey) and FRIFIL='$(restrictImportTable)'", "SYMIRT", "MAX(FRRTYP)", restrictRecordType)
          %endif
      %endif

      @RtvFldDesc("", "SYMXRF", "CHAR(COUNT(*))", xrefCount)

      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  <a href="javascript:document.Chg.updateOption.value=' '; check(document.Chg)">$(editNoUpdateSml)</a>
                  <a href="javascript:document.Chg.updateOption.value='U'; check(document.Chg)">$(acceptImageMed)</a>
                  <a onClick="return confirmCancel()"  href="javascript:history.back()">$(cancelImageMed)</a>
                  <a onClick="return confirmRefresh()" href="$(homeURL)$(cGIPath)$(d2wName)/REFRESH$(d2wVarBase)">$(selectResetImage)</a>
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>
      <table $(contentTable)>
          @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "FHDESC", V_FHDESC)
          @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "CHAR(FHMPKY)", V_FHMPKY)
          @Format_Header("Import Definition", $(V_FHDESC), $(importKey))

          @RtvFldDesc("MHMPKY=$(V_FHMPKY)", "SYMMHD", "MHDESC", V_MHDESC)
          @RtvFldDesc("MHMPKY=$(V_FHMPKY)", "SYMMHD", "MHWPGM", V_MHWPGM)
          @Format_Header("Map Definition", $(V_MHDESC), $(V_MHWPGM))

          %if (restrictImportTable != "")
              @RtvFldDesc("FFIMKY=$(importKey) and FFIFIL='$(restrictImportTable)'", "SYMITB", "FFDESC", V_FFDESC)
              @Format_Header("Import Table", $(V_FFDESC), $(restrictImportTable))
          %endif

          %if (limitRecordType == "Y")
              @RtvFldDesc("FRIMKY=$(importKey) and FRIFIL='$(restrictImportTable)' and FRRTYP='$(restrictRecordType)'", "SYMIRT", "FRDESC", V_FRDESC)
              @Format_Header("Row Type", $(V_FRDESC), $(restrictRecordType))
          %endif
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
      @dtw_assign(interfaceTable, "")
		
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
              %ROW {
                  @dtw_assign(recNbr, $(ROW_NUM))
                  %while(@dtw_rlength(recNbr) != "4") {@dtw_insert("0", recNbr, recNbr)%}

                  %if (interfaceTable != "" && interfaceTable != V_FEMFIL)
                      </table>
                      </fieldset>
                  %endif
                  %if (interfaceTable != V_FEMFIL)
                      @dtw_assign(interfaceTable, V_FEMFIL)
                      @RtvFldDesc("MFMPKY=$(V_FHMPKY) and MFMFIL='$(V_FEMFIL)'", "SYMMTB", "MFDESC", V_MFDESC)
                      @Format_Code(V_FEMFIL, F_FEMFIL)
                      <fieldset class="legendBody">
                      <legend class="legendTitle">$(V_MFDESC) $(F_FEMFIL)</legend>
                      <table $(contentTable)>
                          <tr>
                              <td class="colhdr">Column</td>
                              <td class="colhdr">Description</td>
                              <td class="colhdr">Note</td>
                              %if (importTableCount > "1")
                                  <td class="colhdr">Import Table</td>
                              %endif
                              %if (recordTypeTables > "0" && recordTypeTables != importTableCount || recordTypeCount > "1")
                                  <td class="colhdr">Row Type</td>
                              %endif
                              <td class="colhdr">Column Type</td>
                              %if (placementCount > "1")
                                  <td class="colhdr">Position/<br>Placement</td>
                              %elif (fixedFormat == "Y")
                                  <td class="colhdr">Position</td>
                              %else
                                  <td class="colhdr">Placement</td>
                              %endif
                              %if (fixedFormat == "Y")
                                  <td class="colhdr">Column Length</td>
                              %endif
                              <td class="colhdr">Implied Decimal Point</td>
                              <td class="colhdr">Decimal Precision</td>
                              %if (xrefCount > "0")
                                  <td class="colhdr" colspan="2">Cross Reference</td>
                              %endif
                              <td class="colhdr">Map Function</td>
                              <td class="colhdr">Default Logic For Mapped</td>
                              <td class="colhdr">Value</td>
                              <td class="colhdr">Reverse Sign</td>
                              <td class="colhdr">Date Format</td>
                              <td class="colhdr">Period Format</td>
                              <td class="colhdr">Time Format</td>
                          </tr>
                  %endif
                  <tr>
                      <td><input type="hidden" name="mfil$(recNbr)" value="$(V_FEMFIL)"></td>
                      %if (importTableCount <= "1")
                          <td><input type="hidden" name="ifil$(recNbr)" value="$(restrictImportTable)"></td>
                      %endif
                      %if (recordTypeTables > "0" && recordTypeTables != importTableCount || recordTypeCount > "1")
                      %else
                          <td><input type="hidden" name="rtyp$(recNbr)" value="$(restrictRecordType)"></td>
                      %endif
                      %if (fixedFormat != "Y")
                          <td><input type="hidden" name="lngt$(recNbr)" value="0"></td>
                      %endif
                      %if (xrefCount <= "0")
                          <td><input type="hidden" name="xref$(recNbr)">
                              <input type="hidden" name="xifl$(recNbr)">
                          </td>
                      %endif
                  </tr>
                  <tr>
                      <td class="inputalph" $(helpCursor)><input type="hidden" name="mfld$(recNbr)" value="$(V_FEMFLD)"><span title="Column Type:$(V_MDFLDT) %if (V_MDSTOR!="") &nbsp; Numeric Stored:$(V_MDSTOR) %endif %if (V_MDNAB!="") &nbsp; Normal Balance:$(V_MDNAB)%endif %if (V_MDPARM!="") &nbsp; Workflow Parameter:$(V_MDPARM) %endif ">$(V_FEMFLD)</span></td>
                      <td class="colalph">$(V_MDDESC)</td>

                      %if (V_MDNOTE != "")
                          <td class="colcode" $(helpCursor)><span title="$(V_MDNOTE)">Y</span></td>                                      	
                      %else
                          <td class="colalph">&nbsp;</td>                                      	
                      %endif

                      %if (importTableCount > "1")
                          <td class="inputalph" nowrap><input type="text"   name="ifil$(recNbr)" value="$(V_FEIFIL)" size="10" maxlength="10">
                                                       <a href="$(homeURL)$(cGIPath)MapImportTableSearch.d2w/REPORT$(d2wVarBase)&amp;specificImportKey=@dtw_rurlescseq(importKey)&amp;docName=Chg&amp;fldName=ifil$(recNbr)&amp;fldDesc=ifil$(recNbr)Desc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                       <input type="hidden" name="ifil$(recNbr)Desc"></td>
                      %endif

                      %if (recordTypeTables > "0" && recordTypeTables != importTableCount || recordTypeCount > "1")
                          <td class="inputalph" nowrap><input type="text"   name="rtyp$(recNbr)" value="$(V_FERTYP)" size="$(V_FFRTLN)" maxlength="$(V_FFRTLN)">
                                                       <a href="$(homeURL)$(cGIPath)MapImportRecordTypeSearch.d2w/REPORT$(d2wVarBase)&amp;docName=Chg&amp;specificImportTable=@dtw_rurlescseq(restrictImportTable)&amp;fldTable=ifil$(recNbr)&amp;fldTableDesc=ifil$(recNbr)Desc&amp;fldName=rtyp$(recNbr)&amp;fldDesc=rtyp$(recNbr)Desc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                       <input type="hidden" name="rtyp$(recNbr)Desc"></td>
                      %endif

                      <td class="inputalph" nowrap><input type="text"   name="fldt$(recNbr)" value="$(V_FEFLDT)" size="1" maxlength="1">
                                                   %if (V_MDFLDT =="D" || V_MDFLDT =="L" || V_MDFLDT =="Z")
                                                       <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=MAPFLDTYPD&amp;flagSrchHdr=@dtw_rurlescseq("Import Column Type")&amp;docName=Chg&amp;fldName=fldt$(recNbr)&amp;fldDesc=fldt$(recNbr)Desc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                   %elif (V_MDFLDT =="P")
                                                       <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=MAPFLDTYPP&amp;flagSrchHdr=@dtw_rurlescseq("Import Column Type")&amp;docName=Chg&amp;fldName=fldt$(recNbr)&amp;fldDesc=fldt$(recNbr)Desc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                   %else
                                                       <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=MAPFLDTYP&amp;flagSrchHdr=@dtw_rurlescseq("Import Column Type")&amp;docName=Chg&amp;fldName=fldt$(recNbr)&amp;fldDesc=fldt$(recNbr)Desc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                   %endif
                                                   <input type="hidden" name="fldt$(recNbr)Desc"></td>

                      <td class="inputnmbr"><input type="text"   name="flpl$(recNbr)" value="$(V_FEFLPL)" size="5" maxlength="5"></td>

                      %if (fixedFormat == "Y")
                          <td class="inputnmbr"><input type="text"   name="lngt$(recNbr)" value="$(V_FELNGT)" size="5" maxlength="5"></td>
                      %endif

                      %if (V_MDFLDT =="N")
                          <td class="inputalph" nowrap><input type="text"   name="idec$(recNbr)" value="$(V_FEIDEC)" size="1" maxlength="1">
                                                       <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=BY&amp;flagSrchHdr=@dtw_rurlescseq("Implied Decimal Point")&amp;docName=Chg&amp;fldName=idec$(recNbr)&amp;fldDesc=idec$(recNbr)Desc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                       <input type="hidden" name="idec$(recNbr)Desc"></td>
                          <td class="inputnmbr" nowrap><input type="text"   name="decm$(recNbr)" value="$(V_FEDECM)" size="1" maxlength="1"></td>
                      %else
                          <td class="inputalph" nowrap><input type="hidden" name="idec$(recNbr)"></td>
                          <td class="inputalph" nowrap><input type="hidden" name="decm$(recNbr)"></td>
                      %endif

                      %if (xrefCount > "0" && (V_MDFLDT =="A" || V_MDFLDT =="N"))
                          <td class="inputalph" nowrap><input type="text"   name="xref$(recNbr)" value="$(V_FEXREF)" size="10" maxlength="10"></td>
                          <td class="inputalph" nowrap><input type="text"   name="xifl$(recNbr)" value="$(V_FEXIFL)" size="10" maxlength="10">
                                                       <a href="$(homeURL)$(cGIPath)MapXRefSearch.d2w/REPORT$(genericVarBase)&amp;docName=Chg&amp;fldTable=xifl$(recNbr)&amp;fldName=xref$(recNbr)&amp;fldDesc=xref$(recNbr)Desc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                       <input type="hidden" name="xref$(recNbr)Desc"></td>
                      %elif (xrefCount > "0")
                          <td class="inputalph" nowrap><input type="hidden" name="xref$(recNbr)"></td>
                          <td class="inputalph" nowrap><input type="hidden" name="xifl$(recNbr)"></td>
                      %endif

                      <td class="inputalph" nowrap><input type="text"   name="mfnc$(recNbr)" value="$(V_FEMFNC)" size="2" maxlength="2">
                                                   <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=MAPFUNCT&amp;flagSrchHdr=@dtw_rurlescseq("Map Function")&amp;docName=Chg&amp;fldName=mfnc$(recNbr)&amp;fldDesc=mfnc$(recNbr)Desc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                   <input type="hidden" name="mfnc$(recNbr)Desc"></td>

                      %if (V_MDDLGC == "Y")
                          <td class="inputalph" nowrap><input type="text"   name="dfmp$(recNbr)" value="$(V_FEDFMP)" size="1" maxlength="1">
                                                       <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=BY&amp;flagSrchHdr=@dtw_rurlescseq("Default Logic For Mapped Column")&amp;docName=Chg&amp;fldName=dfmp$(recNbr)&amp;fldDesc=dfmp$(recNbr)Desc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                       <input type="hidden" name="dfmp$(recNbr)Desc"></td>
                      %else
                          <td class="inputalph" nowrap><input type="hidden" name="dfmp$(recNbr)">
                                                       <input type="hidden" name="dfmp$(recNbr)Desc"></td>
                      %endif

                      <td class="inputalph"><input type="text"   name="valu$(recNbr)" value="$(V_FEVALU)" size="10" maxlength="50"></td>

                      <td class="inputalph" nowrap><input type="text"   name="anab$(recNbr)" value="$(V_FEANAB)" size="1" maxlength="1">
                                                   <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=BY&amp;flagSrchHdr=@dtw_rurlescseq("Reverse Sign")&amp;docName=Chg&amp;fldName=anab$(recNbr)&amp;fldDesc=anab$(recNbr)Desc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                   <input type="hidden" name="anab$(recNbr)Desc"></td>

                      %if (V_MDFLDT == "D" || V_MDFLDT == "L" || V_MDFLDT == "Z")
                          <td class="inputalph" nowrap><input type="text"   name="dtfm$(recNbr)" value="$(V_FEDTFM)" size="10" maxlength="10">
                                                       <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=DATEFMT&amp;flagSrchHdr=@dtw_rurlescseq("Date Format")&amp;docName=Chg&amp;fldName=dtfm$(recNbr)&amp;fldDesc=dtfm$(recNbr)Desc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                       <input type="hidden" name="dtfm$(recNbr)Desc"></td>
                      %else
                          <td class="inputalph" nowrap><input type="hidden" name="dtfm$(recNbr)">
                                                       <input type="hidden" name="dtfm$(recNbr)Desc"></td>
                      %endif

                      %if (V_MDFLDT == "P")
                          <td class="inputalph" nowrap><input type="text"   name="pdfm$(recNbr)" value="$(V_FEPDFM)" size="10" maxlength="10">
                                                       <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=PDFMT&amp;flagSrchHdr=@dtw_rurlescseq("Period Format")&amp;docName=Chg&amp;fldName=pdfm$(recNbr)&amp;fldDesc=pdfm$(recNbr)Desc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                       <input type="hidden" name="pdfm$(recNbr)Desc"></td>
                      %else
                          <td class="inputalph" nowrap><input type="hidden" name="pdfm$(recNbr)">
                                                       <input type="hidden" name="pdfm$(recNbr)Desc"></td>
                      %endif

                      %if (V_MDFLDT == "T")
                          <td class="inputalph" nowrap><input type="text"   name="tmfm$(recNbr)" value="$(V_FETMFM)" size="10" maxlength="10">
                                                       <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=TIMEFMT&amp;flagSrchHdr=@dtw_rurlescseq("Time Format")&amp;docName=Chg&amp;fldName=tmfm$(recNbr)&amp;fldDesc=tmfm$(recNbr)Desc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                       <input type="hidden" name="tmfm$(recNbr)Desc"></td>
                      %else
                          <td class="inputalph" nowrap><input type="hidden" name="tmfm$(recNbr)">
                                                       <input type="hidden" name="tmfm$(recNbr)Desc"></td>
                      %endif
                  </tr>
                  %if (V_FEMSG# != "")
                      @Ret_Error_Msg(profileHandle, dataBaseID, $(V_FEMSG#), errorMessage)
                      <tr>
                          <td class="error" colspan="19">Error: $(errorMessage)</td>		
                      </tr>
                  %endif
              %}
              <tr><td><input type="hidden" name="updateOption"></td></tr>
          </table>
          </fieldset>
      </form>
      <table $(contentTable)>
          <tr>
              <td class="toolbar">
                  <a href="javascript:document.Chg.updateOption.value=' '; check(document.Chg)">$(editNoUpdateSml)</a>
                  <a href="javascript:document.Chg.updateOption.value='U'; check(document.Chg)">$(acceptImageMed)</a>
                  <a onClick="return confirmCancel()"  href="javascript:history.back()">$(cancelImageMed)</a>
                  <a onClick="return confirmRefresh()" href="$(homeURL)$(cGIPath)$(d2wName)/REFRESH$(d2wVarBase)">$(selectResetImage)</a>
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSYIPM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(REFRESH) {
  %INCLUDE "setLibraryList.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Delete From SYMITE Where FEXHND='$(profileHandle)' and FEIMKY=$(importKey) ", stmtSQL)
  @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
  @SQL_Update(stmtSQL, status)

  @Set_SQL(stmtSQL)
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("FEXHND='$(profileHandle)' and FEIMKY=$(importKey) and MDDPOS<>0 ", "SYMITE inner join SYMIHD on FHIMKY=FEIMKY Inner Join SYMMCL on MDMPKY=FHMPKY and MDMFIL=FEMFIL and MDMFLD=FEMFLD ", "char(count(*))", recCount)	
  @dtw_assign(ux, "1")
  %while(ux <= recCount){
      @dtw_assign(recNbr, ux)
      %while(@dtw_rlength(recNbr) != "4") {@dtw_insert("0", recNbr, recNbr)%}
      @dtw_assign(mfil, $(mfil$(recNbr)))  @dtw_mUPPERCASE(mfil)
      @dtw_assign(mfld, $(mfld$(recNbr)))  @dtw_mUPPERCASE(mfld)
      @dtw_assign(ifil, $(ifil$(recNbr)))  @dtw_mUPPERCASE(ifil)
      @dtw_assign(rtyp, $(rtyp$(recNbr)))  @dtw_mUPPERCASE(rtyp)
      @dtw_assign(fldt, $(fldt$(recNbr)))  @dtw_mUPPERCASE(fldt)
      @dtw_assign(flpl, $(flpl$(recNbr)))   %if (flpl=="")  @dtw_assign(flpl, "0") %endif
      @dtw_assign(lngt, $(lngt$(recNbr)))   %if (lngt=="")  @dtw_assign(lngt, "0") %endif
      @dtw_assign(idec, $(idec$(recNbr)))  @dtw_mUPPERCASE(idec)
      @dtw_assign(decm, $(decm$(recNbr)))   %if (decm=="")  @dtw_assign(decm, "0") %endif
      @dtw_assign(xifl, $(xifl$(recNbr)))  @dtw_mUPPERCASE(xifl)
      @dtw_assign(xref, $(xref$(recNbr)))  @dtw_mUPPERCASE(xref)
      @dtw_assign(mfnc, $(mfnc$(recNbr)))  @dtw_mUPPERCASE(mfnc)
      @dtw_assign(dfmp, $(dfmp$(recNbr)))  @dtw_mUPPERCASE(dfmp)
      @dtw_assign(valu, $(valu$(recNbr)))  @dtw_mUPPERCASE(valu)
      @dtw_assign(anab, $(anab$(recNbr)))  @dtw_mUPPERCASE(anab)
      @dtw_assign(dtfm, $(dtfm$(recNbr)))  @dtw_mUPPERCASE(dtfm)
      @dtw_assign(pdfm, $(pdfm$(recNbr)))  @dtw_mUPPERCASE(pdfm)
      @dtw_assign(tmfm, $(tmfm$(recNbr)))  @dtw_mUPPERCASE(tmfm)

      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Update SYMITE Set FEIFIL='$(ifil)', FERTYP='$(rtyp)', FEFLDT='$(fldt)', FEFLPL=$(flpl), FELNGT=$(lngt), FEIDEC='$(idec)', FEDECM=$(decm), FEXIFL='$(xifl)', FEXREF='$(xref)', FEMFNC='$(mfnc)', FEDFMP='$(dfmp)', FEVALU='$(valu)', FEANAB='$(anab)', FEDTFM='$(dtfm)', FEPDFM='$(pdfm)', FETMFM='$(tmfm)', FEMSG#=' ' ", stmtSQL)
      @dtw_concat(stmtSQL, " Where FEXHND='$(profileHandle)' and FEIMKY=$(importKey) and FEMFIL='$(mfil)' and FEMFLD='$(mfld)' ", stmtSQL)
      @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)

      @dtw_add(ux, "1", ux)
  %}

  @dtw_assign(maintenanceCode, updateOption)
  @dtw_assign(edtVar, "")
  @Concat_Field("@@@upd", updateOption)
  @Concat_Field("@@imky", importKey)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" && updateOption=="U")
      @RtvFldDesc("FHMPKY=$(importKey) ", "SYMIHD", "FHDESC", importDescription)
      @Format_ConfMsg_Desc("", $(importDescription), "$(importKey)", "", "", "", "", confMessage)
      @dtw_assign(confMessage, "Confirm Update Of Template $(confMessage)")
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else

      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
