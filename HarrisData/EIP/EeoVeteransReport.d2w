%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Veterans"
  d2wName                 = "EeoVeteransReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;hrCompany=@dtw_rurlescseq(hrCompany)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  programName             = "EEO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@hrCompany", "@dtw_rurlescseq(hrCompany)", "1", "a", workURL)
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  %INCLUDE "SelHrJavaEdit.icl"   %{ Edit from and to company and facility numbers %}
                  if (editFromToAll(document.Chg.fromEeo, document.Chg.toEeo, document.Chg.allEeo))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "EEO2REPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromCompany")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)

                                  @DecatErr_Field("@@svet", "selVets")   @dtw_assign(Err_SLSVET,  fieldValue)
                                  %INCLUDE "SelHrDecatErr.icl"     %{ Decat H/R Report Selection Errors %}
                                  @DecatErr_Field("@@feeo", "fromEeo")  @dtw_assign(Err_SLFEEO,  fieldValue)
                                  @DecatErr_Field("@@teeo", "toEeo")    @dtw_assign(Err_SLFEEO,  fieldValue)
                                  @DecatErr_Field("@@aeeo", "allEeo")   @dtw_assign(Err_SLFEEO,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}

                                  @Decat_Field("@@svet")   @dtw_assign(V_SLSVET,  fieldValue)
                                  %INCLUDE "SelHrDecatSel.icl"       %{ Decat H/R Report Selections %}
                                  @Decat_Field("@@feeo")   @dtw_assign(V_SLFEEO,  fieldValue)
                                  @Decat_Field("@@teeo")   @dtw_assign(V_SLTEEO,  fieldValue)
                                  @Decat_Field("@@aeeo")   @dtw_assign(V_SLAEEO,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}

                                  %if (V_SLSVET == "02")
                                      @dtw_assign(vets100, "")
                                      @dtw_assign(vets100A, "CHECKED")
                                  %else
                                      @dtw_assign(vets100, "CHECKED")
                                      @dtw_assign(vets100A, "")
                                  %endif
                                  %if (V_SLAEEO == "ALL")
                                      @dtw_assign(checkedEeo, "CHECKED")
                                  %else
                                      @dtw_assign(checkedEeo, "")
                                  %endif
                              %else
                                  @dtw_assign(vets100, "CHECKED")
                                  @dtw_assign(checkedEeo, "CHECKED")
                                  @dtw_assign(vets100A, "")
                              %endif
                              %INCLUDE "SelHrCheckBoxes.icl"     %{ Set H/R Report Selection Check Box Values %}
                              @dtw_assign(scheduleJobSwitch, "")

                              @SetTextOvr(Err_SLSVET)
                              <tr><td class="dsphdr"><span $(textOvr)>Select Report Type</span></td>
                                  <td class="inputnmbr"><input name="selVets" type="radio" VALUE='01' $(vets100)>VETS100</td>
                              </tr>
                              @DspErrMsg(Err_SLSVET)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="selVets" type="radio" VALUE='02' $(vets100A)>VETS100A</td>
                              </tr>

                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              %INCLUDE "SelHrSetText.icl"       %{ H/R Report Selection Fields %}
                              @SetTextOvr(Err_SLFEEO)
                              %if (textOvr == "") @SetTextOvr(Err_SLTEEO) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SLAEEO) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>EEO-1 Job Category</span></td>
                                  <td class="inputnmbr"><input name="fromEeo" VALUE="$(V_SLFEEO)" type="text" size="5" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Chg&amp;fldType=Y&amp;fldName=fromEeo&amp;fldDesc=locCodeDesc2" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="locCodeDesc2" value="$(codeDesc)"  type="hidden" size="20" maxlength="20"></td>
                                  <td class="inputnmbr"><input name="toEeo" VALUE="$(V_SLTEEO)" type="text" size="5" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Chg&amp;fldType=Y&amp;fldName=toEeo&amp;fldDesc=locCodeDesc2" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="locCodeDesc2" value="$(codeDesc)"  type="hidden" size="20" maxlength="20"></td>
                                  <td class="inputalph"><input name="allEeo" VALUE='ALL' $(checkedEeo) type="checkbox" onClick="if (this.checked) this.form.fromEeo.value='', this.form.toEeo.value='';"></td>
                                  @DspErrMsg(Err_SLFEEO)
                                  @DspErrMsg(Err_SLTEEO)
                                  @DspErrMsg(Err_SLAEEO)
                              </tr>
                          </table>
                          @dtw_assign(envProgram, "HPEVTR")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HPEVTS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL()
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  %INCLUDE "SelHrEdit.icl"       %{ Prepare H/R Report Selections For Edit %}
  @dtw_mUPPERCASE(fromEeo)
  @dtw_mUPPERCASE(toEeo)
  @dtw_mUPPERCASE(allEeo)
  @dtw_assign(fromEeo,@dtw_rstrip(fromEeo))
  @dtw_assign(toEeo,@dtw_rstrip(toEeo))
  %if (allEeo != "ALL")
      @dtw_assign(allEeo, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@svet", selVets)
  %INCLUDE "SelHrConcat.icl"       %{ Concat H/R Report Selections For Edit %}
  @Concat_Field("@@feeo", fromEeo)
  @Concat_Field("@@teeo", toEeo)
  @Concat_Field("@@aeeo", allEeo)
  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}