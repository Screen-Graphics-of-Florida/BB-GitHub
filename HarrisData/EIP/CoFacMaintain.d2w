%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Company/Facility Maintenance"
  d2wName                 = "CoFacMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromSel=@dtw_rurlescseq(fromSel)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;companyNumber=@dtw_rurlescseq(companyNumber)&amp;facilityNumber=@dtw_rurlescseq(facilityNumber)&amp;coFacName=@dtw_rurlescseq(coFacName)&amp;maintenanceCode=D"
  programName             = "HHDCFU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  V_CTGIBE                = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (maintenanceCode == "A")
      @dtw_assign(userPass, "Y")
  %else
      @CoFacUserView(profileHandle, dataBaseID, userPass, companyNumber, facilityNumber)
  %endif
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      @RtvFldDesc("CTGIBE<>' '", "GLCTRL", "CTGIBE", V_CTGIBE)
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
                  %INCLUDE "Menu.js"
	           %INCLUDE "numedit.icl"
                  %INCLUDE "dateedit.icl"
                  %INCLUDE "calendar.icl"
                  %INCLUDE "CheckEnterChg.icl"
                  function validate(chgForm) {
                      if (document.Chg.companyNumber.value =="" ||
                          document.Chg.facilityNumber.value =="" ||
                          document.Chg.coFacName.value ==""
                          %if (V_CTGIBE == "Y")
                              || (document.Chg.dueToAccountNumber.value =="0" && document.Chg.dueToSubaccountNumber.value =="0")
                              || (document.Chg.dueFromAccountNumber.value =="0" && document.Chg.dueFromSubaccountNumber.value =="0")
                              || (document.Chg.allocationAccountNumber.value =="0" && document.Chg.allocationSubaccountNumber.value =="0")
                              || (document.Chg.currentAccountNumber.value =="0" && document.Chg.currentSubaccountNumber.value =="0")
                              || (document.Chg.recurringAccountNumber.value =="0" && document.Chg.recurringSubaccountNumber.value =="0")
                          %endif
                          )
                         {alert("$(reqFieldError)"); return false;}
                      if (editNum(document.Chg.companyNumber, 2, 0) &&
                          editNum(document.Chg.facilityNumber, 4, 0) &&
                          editNum(document.Chg.dueToAccountNumber, 4, 0) &&
                          editNum(document.Chg.dueToSubaccountNumber, 4, 0) &&
                          editNum(document.Chg.dueFromAccountNumber, 4, 0) &&
                          editNum(document.Chg.dueFromSubaccountNumber, 4, 0) &&
                          editNum(document.Chg.apAccountNumber, 4, 0) &&
                          editNum(document.Chg.apSubaccountNumber, 4, 0) &&
                          editNum(document.Chg.allocationAccountNumber, 4, 0) &&
                          editNum(document.Chg.allocationSubaccountNumber, 4, 0) &&
                          editNum(document.Chg.currentAccountNumber, 4, 0) &&
                          editNum(document.Chg.currentSubaccountNumber, 4, 0) &&
                          editNum(document.Chg.recurringAccountNumber, 4, 0) &&
                          editNum(document.Chg.recurringSubaccountNumber, 4, 0) &&
                          editNum(document.Chg.budgetPlan, 3, 0) &&
                          editdate(document.Chg.dateEstablished) &&
                          editdate(document.Chg.dateDeactivated) &&
                          editNum(document.Chg.translatedCompanyNumber, 2, 0) &&
                          editNum(document.Chg.translatedFacilityNumber, 4, 0))
                          return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "COFACMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "Select * From HDCFAC Where CFCO# = $(companyNumber) and CFFAC# = $(facilityNumber)", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- Ebd Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=112")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "companyNumber")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@co#@", "companyNumber")           @dtw_assign(Err_CFCO#,  fieldValue)
                          @DecatErr_Field("@@fac#", "facilityNumber")          @dtw_assign(Err_CFFAC#, fieldValue)
                          @DecatErr_Field("@@cfnm", "coFacName")               @dtw_assign(Err_CFCFNM, fieldValue)
                          @DecatErr_Field("@@dtac", "dueToAccountNumber")      @dtw_assign(Err_CFDTAC, fieldValue)
                          @DecatErr_Field("@@dfac", "dueFromAccountNumber")    @dtw_assign(Err_CFDFAC, fieldValue)
                          @DecatErr_Field("@@apa@", "apAccountNumber")         @dtw_assign(Err_CFAPA,  fieldValue)
                          @DecatErr_Field("@@iaac", "allocationAccountNumber") @dtw_assign(Err_CFIAAC, fieldValue)
                          @DecatErr_Field("@@icac", "currentAccountNumber")    @dtw_assign(Err_CFICAC, fieldValue)
                          @DecatErr_Field("@@isac", "recurringAccountNumber")  @dtw_assign(Err_CFISAC, fieldValue)
                          @DecatErr_Field("@@tin#", "payerTIN")                @dtw_assign(Err_CFTIN#, fieldValue)
                          @DecatErr_Field("@@dbgt", "budgetPlan")              @dtw_assign(Err_CFDBGT, fieldValue)
                          @DecatErr_Field("@@dtes", "dateEstablished")         @dtw_assign(Err_CFDTES, fieldValue)
                          @DecatErr_Field("@@dtde", "dateDeactivated")         @dtw_assign(Err_CFDTDE, fieldValue)
                          @DecatErr_Field("@@curt", "currencyType")            @dtw_assign(Err_CFCURT, fieldValue)
                          @DecatErr_Field("@@trco", "translatedCompanyNumber") @dtw_assign(Err_CFTRCO, fieldValue)
                      %endif

                      @Decat_Field("@@co#@")   @dtw_assign(V_CFCO#,  fieldValue)
                      @Decat_Field("@@fac#")   @dtw_assign(V_CFFAC#, fieldValue)
                      @Decat_Field("@@cfnm")   @dtw_assign(V_CFCFNM, fieldValue)
                      @Decat_Field("@@dtac")   @dtw_assign(V_CFDTAC, fieldValue)
                      @Decat_Field("@@dtsb")   @dtw_assign(V_CFDTSB, fieldValue)
                      @Decat_Field("@@dfac")   @dtw_assign(V_CFDFAC, fieldValue)
                      @Decat_Field("@@dfsb")   @dtw_assign(V_CFDFSB, fieldValue)
                      @Decat_Field("@@apa@")   @dtw_assign(V_CFAPA,  fieldValue)
                      @Decat_Field("@@aps@")   @dtw_assign(V_CFAPS,  fieldValue)
                      @Decat_Field("@@iaac")   @dtw_assign(V_CFIAAC, fieldValue)
                      @Decat_Field("@@iasb")   @dtw_assign(V_CFIASB, fieldValue)
                      @Decat_Field("@@icac")   @dtw_assign(V_CFICAC, fieldValue)
                      @Decat_Field("@@icsb")   @dtw_assign(V_CFICSB, fieldValue)
                      @Decat_Field("@@isac")   @dtw_assign(V_CFISAC, fieldValue)
                      @Decat_Field("@@issb")   @dtw_assign(V_CFISSB, fieldValue)
                      @Decat_Field("@@tin#")   @dtw_assign(V_CFTIN#, fieldValue)
                      @Decat_Field("@@dbgt")   @dtw_assign(V_CFDBGT, fieldValue)
                      @Decat_Field("@@dtes")   @dtw_assign(V_CFDTES, fieldValue)
                      @Decat_Field("@@dtde")   @dtw_assign(V_CFDTDE, fieldValue)
                      @Decat_Field("@@curt")   @dtw_assign(V_CFCURT, fieldValue)
                      @Decat_Field("@@trco")   @dtw_assign(V_CFTRCO, fieldValue)
                      @Decat_Field("@@trfc")   @dtw_assign(V_CFTRFC, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(V_CFDBGT, "000")
                          @dtw_assign(V_CFTRCO, "00")
                          @dtw_assign(V_CFTRFC, "0000")
                          @dtw_assign(focusField, "companyNumber")
                     %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_CFCO#,  "")
                      @dtw_assign(V_CFFAC#, "")
                      @DateInputFromCYMD(V_CFDTES)
                      @DateInputFromCYMD(V_CFDTDE)
                      @dtw_assign(focusField, "companyNumber")
                  %elif (maintenanceCode != "A")
                      @DateInputFromCYMD(V_CFDTES)
                      @DateInputFromCYMD(V_CFDTDE)
                      @dtw_assign(focusField, "coFacName")
                  %endif

                  @SetTextOvr(Err_CFCO#)
                  <tr><td class="dsphdr"><span $(textOvr)>Company Number</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="companyNumber" type="text" value="$(V_CFCO#)" size="2" maxlength="2"> $(reqFieldChar) </td>
                      %else
                          <td class="inputnmbr"><input name="companyNumber" type="hidden" value="$(V_CFCO#)" size="2" maxlength="2">$(V_CFCO#)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_CFCO#)

                  @SetTextOvr(Err_CFFAC#)
                  <tr><td class="dsphdr"><span $(textOvr)>Facility Number</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="facilityNumber" type="text" value="$(V_CFFAC#)" size="4" maxlength="4"> $(reqFieldChar) </td>
                      %else
                          <td class="inputnmbr"><input name="facilityNumber" type="hidden" value="$(V_CFFAC#)" size="4" maxlength="4">$(V_CFFAC#)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_CFFAC#)

                  @SetTextOvr(Err_CFCFNM)
                  <tr><td class="dsphdr"><span $(textOvr)>Company/Facility Name</span></td>
                      <td class="inputalph"><input name="coFacName" type="text" value="$(V_CFCFNM)" size="30" maxlength="30"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_CFCFNM)
	   		
                  %if (V_CTGIBE == "Y")
                      @dtw_assign(interCoReq,  "$(reqFieldChar)")
                  %else
                      @dtw_assign(interCoReq,  "")
                  %endif
                  @Default_Zero(V_CFDTAC)
                  @Default_Zero(V_CFDTSB)
                  @RtvFldDesc("CHACCT=$(V_CFDTAC) and CHSUB=$(V_CFDTSB) ", "HDCHRT", "CHCHDS", acctDesc)
                  @SetTextOvr(Err_CFDTAC)
                  <tr><td class="dsphdr"><span $(textOvr)>Inter-Company Due To</span></td>
                      <td class="inputnmbr"><input name="dueToAccountNumber" value="$(V_CFDTAC)" type="text" size="4" maxlength="4"> - <input name="dueToSubaccountNumber" value="$(V_CFDTSB)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=dueToAccountNumber&amp;subFld=dueToSubaccountNumber&amp;descFld=dueToAcctDesc" onclick="$(searchWinVar)">$(interCoReq) $(searchImage) </a> <input disabled name="dueToAcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_CFDTAC)
	   		
                  @Default_Zero(V_CFDFAC)
                  @Default_Zero(V_CFDFSB)
                  @RtvFldDesc("CHACCT=$(V_CFDFAC) and CHSUB=$(V_CFDFSB) ", "HDCHRT", "CHCHDS", acctDesc)
                  @SetTextOvr(Err_CFDFAC)
                  <tr><td class="dsphdr"><span $(textOvr)>Inter-Company Due From</span></td>
                      <td class="inputnmbr"><input name="dueFromAccountNumber" value="$(V_CFDFAC)" type="text" size="4" maxlength="4"> - <input name="dueFromSubaccountNumber" value="$(V_CFDFSB)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=dueFromAccountNumber&amp;subFld=dueFromSubaccountNumber&amp;descFld=dueFromAcctDesc" onclick="$(searchWinVar)">$(interCoReq) $(searchImage) </a> <input disabled name="dueFromAcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_CFDFAC)
	   		
                  @Default_Zero(V_CFAPA)
                  @Default_Zero(V_CFAPS)
                  @RtvFldDesc("CHACCT=$(V_CFAPA) and CHSUB=$(V_CFAPS) ", "HDCHRT", "CHCHDS", acctDesc)
                  @SetTextOvr(Err_CFAPA)
                  <tr><td class="dsphdr"><span $(textOvr)>A/P Account</span></td>
                      <td class="inputnmbr"><input name="apAccountNumber" value="$(V_CFAPA)" type="text" size="4" maxlength="4"> - <input name="apSubaccountNumber" value="$(V_CFAPS)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=apAccountNumber&amp;subFld=apSubaccountNumber&amp;descFld=apAcctDesc" onclick="$(searchWinVar)">&nbsp; $(searchImage) </a> <input disabled name="apAcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_CFAPA)
	   		
                  @Default_Zero(V_CFIAAC)
                  @Default_Zero(V_CFIASB)
                  @RtvFldDesc("CHACCT=$(V_CFIAAC) and CHSUB=$(V_CFIASB) ", "HDCHRT", "CHCHDS", acctDesc)
                  @SetTextOvr(Err_CFIAAC)
                  <tr><td class="dsphdr"><span $(textOvr)>Inter-Co Bal Allocations</span></td>
                      <td class="inputnmbr"><input name="allocationAccountNumber" value="$(V_CFIAAC)" type="text" size="4" maxlength="4"> - <input name="allocationSubaccountNumber" value="$(V_CFIASB)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=allocationAccountNumber&amp;subFld=allocationSubaccountNumber&amp;descFld=allocationAcctDesc" onclick="$(searchWinVar)">$(interCoReq) $(searchImage) </a> <input disabled name="allocationAcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_CFIAAC)
	   		
                  @Default_Zero(V_CFICAC)
                  @Default_Zero(V_CFICSB)
                  @RtvFldDesc("CHACCT=$(V_CFICAC) and CHSUB=$(V_CFICSB) ", "HDCHRT", "CHCHDS", acctDesc)
                  @SetTextOvr(Err_CFICAC)
                  <tr><td class="dsphdr"><span $(textOvr)>Inter-Co Bal Current</span></td>
                      <td class="inputnmbr"><input name="currentAccountNumber" value="$(V_CFICAC)" type="text" size="4" maxlength="4"> - <input name="currentSubaccountNumber" value="$(V_CFICSB)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=currentAccountNumber&amp;subFld=currentSubaccountNumber&amp;descFld=currentAcctDesc" onclick="$(searchWinVar)">$(interCoReq) $(searchImage) </a> <input disabled name="currentAcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_CFICAC)

                  @Default_Zero(V_CFISAC)
                  @Default_Zero(V_CFISSB)
                  @RtvFldDesc("CHACCT=$(V_CFISAC) and CHSUB=$(V_CFISSB) ", "HDCHRT", "CHCHDS", acctDesc)
                  @SetTextOvr(Err_CFISAC)
                  <tr><td class="dsphdr"><span $(textOvr)>Inter-Co Bal Recurring</span></td>
                      <td class="inputnmbr"><input name="recurringAccountNumber" value="$(V_CFISAC)" type="text" size="4" maxlength="4"> - <input name="recurringSubaccountNumber" value="$(V_CFISSB)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=recurringAccountNumber&amp;subFld=recurringSubaccountNumber&amp;descFld=recurringAcctDesc" onclick="$(searchWinVar)">$(interCoReq) $(searchImage) </a> <input disabled name="recurringAcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_CFISAC)
	   		
                  @RtvFldDesc("TNTIN#='$(V_CFTIN#)'", "APPTIN", "TNPNAM", fieldDesc)
                  @SetTextOvr(Err_CFTIN#)
                  <tr><td class="dsphdr"><span $(textOvr)>Payer TIN</span></td>
                      <td class="inputnmbr"><input name="payerTIN" value="$(V_CFTIN#)" type="text" size="9" maxlength="9"><a href="$(homeURL)$(cGIPath)PayerTinSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=payerTIN&amp;fldDesc=payerTINName" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="payerTINName" value="$(fieldDesc)" type="text" size="40" maxlength="40"></td>
                  </tr>
                  @DspErrMsg(Err_CFTIN#)
               			
                  @RtvFldDesc("BGNMBR=$(V_CFDBGT)", "GLBGHD", "BGDESC", fieldDesc)
                  @SetTextOvr(Err_CFDBGT)
                  <tr><td class="dsphdr"><span $(textOvr)>Default Budget Plan</span></td>
                      <td class="inputnmbr"><input name="budgetPlan" value="$(V_CFDBGT)" type="text" size="3" maxlength="3">
                                            <a href="$(homeURL)$(phpPath)BudgetPlanSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=budgetPlan&amp;fldDesc=budgetPlanDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                                            <input disabled name="budgetPlanDesc" value="$(fieldDesc)" type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_CFDBGT)
               			
                  @SetTextOvr(Err_CFDTES)
	           <tr><td class="dsphdr"><span $(textOvr)>Date Established</span></td>
                      <td class="inputnmbr"><input type="text" name="dateEstablished" value="$(V_CFDTES)" size="6" maxlength="6"> 		
                            <a href="javascript:calWindow('dateEstablished');">$(calendarImage)</a>
                      </td>
                  </tr>
                  @DspErrMsg(Err_CFDTES)

                  @SetTextOvr(Err_CFDTDE)
	           <tr><td class="dsphdr"><span $(textOvr)>Date Deactivated</span></td>
                      <td class="inputnmbr"><input type="text" name="dateDeactivated" value="$(V_CFDTDE)" size="6" maxlength="6"> 		
                            <a href="javascript:calWindow('dateDeactivated');">$(calendarImage)</a>
                      </td>
                  </tr>
                  @DspErrMsg(Err_CFDTDE)

                  %if (V_HDMCRL > "0")
                      @RtvFldDesc("CYTYPE='$(V_CFCURT)'", "HDCTYP", "CYDESC", fieldDesc)
                      @SetTextOvr(Err_CFCURT)
                      <tr><td class="dsphdr"><span $(textOvr)>Currency Type</span></td>
                          <td class="inputalph"><input name="currencyType" value="$(V_CFCURT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)CurrencyTypeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=currencyType&amp;fldDesc=currencyTypeDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="currencyTypeDesc" value="$(fieldDesc)"  type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_CFCURT)
                  %else			
                      <tr><td class="inputalph"><input name="currencyType" type="hidden" value="$(V_CFCURT)" size="3" maxlength="3"></td></tr>
                  %endif

                  %if (V_HDMCRL > "0")
                      @Default_Zero(V_CFTRCO)
                      @Default_Zero(V_CFTRFC)
                      @RtvFldDesc("CFCO#=$(V_CFTRCO) and CFFAC#=$(V_CFTRFC)", "HDCFAC", "CFCFNM", fieldDesc)
                      @SetTextOvr(Err_CFTRCO)
                      <tr><td class="dsphdr"><span $(textOvr)>Translated Company/Facility</span></td>
                          <td class="inputnmbr"><input name="translatedCompanyNumber" value="$(V_CFTRCO)" type="text" size="2" maxlength="2"> / <input name="translatedFacilityNumber" value="$(V_CFTRFC)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)CoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=translatedCompanyNumber&amp;fldFac=translatedFacilityNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="coFacDesc" value="$(fieldDesc)"  type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_CFTRCO)
                  %else			
                      <tr><td class="inputnmbr"><input name="translatedCompanyNumber" type="hidden" value="0"></td>
                          <td class="inputnmbr"><input name="translatedFacilityNumber" type="hidden" value="0"></td>
                      </tr>
                  %endif
              %}
          </table>
	
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDCFU_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(payerTIN)
  @dtw_mUPPERCASE(currencyType)
  @dtw_assign(companyNumber,@dtw_rstrip(companyNumber))
  @dtw_assign(facilityNumber,@dtw_rstrip(facilityNumber))
  @dtw_assign(dueToAccountNumber,@dtw_rstrip(dueToAccountNumber))
  @dtw_assign(dueToSubaccountNumber,@dtw_rstrip(dueToSubaccountNumber))
  @dtw_assign(dueFromAccountNumber,@dtw_rstrip(dueFromAccountNumber))
  @dtw_assign(dueFromSubaccountNumber,@dtw_rstrip(dueFromSubaccountNumber))
  @dtw_assign(apAccountNumber,@dtw_rstrip(apAccountNumber))
  @dtw_assign(apSubaccountNumber,@dtw_rstrip(apSubaccountNumber))
  @dtw_assign(allocationAccountNumber,@dtw_rstrip(allocationAccountNumber))
  @dtw_assign(allocationSubaccountNumber,@dtw_rstrip(allocationSubaccountNumber))
  @dtw_assign(currentAccountNumber,@dtw_rstrip(currentAccountNumber))
  @dtw_assign(currentSubaccountNumber,@dtw_rstrip(currentSubaccountNumber))
  @dtw_assign(recurringAccountNumber,@dtw_rstrip(recurringAccountNumber))
  @dtw_assign(recurringSubaccountNumber,@dtw_rstrip(recurringSubaccountNumber))
  @dtw_assign(budgetPlan,@dtw_rstrip(budgetPlan))
  @dtw_assign(dateEstablished,@dtw_rstrip(dateEstablished))
  @dtw_assign(dateDeactivated,@dtw_rstrip(dateDeactivated))
  @dtw_assign(translatedCompanyNumber,@dtw_rstrip(translatedCompanyNumber))
  @dtw_assign(translatedFacilityNumber,@dtw_rstrip(translatedFacilityNumber))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@co#@", companyNumber)
  @Concat_Field("@@fac#", facilityNumber)
  @Concat_Field("@@cfnm", coFacName)
  @Concat_Field("@@dtac", dueToAccountNumber)
  @Concat_Field("@@dtsb", dueToSubaccountNumber)
  @Concat_Field("@@dfac", dueFromAccountNumber)
  @Concat_Field("@@dfsb", dueFromSubaccountNumber)
  @Concat_Field("@@apa@", apAccountNumber)
  @Concat_Field("@@aps@", apSubaccountNumber)
  @Concat_Field("@@iaac", allocationAccountNumber)
  @Concat_Field("@@iasb", allocationSubaccountNumber)
  @Concat_Field("@@icac", currentAccountNumber)
  @Concat_Field("@@icsb", currentSubaccountNumber)
  @Concat_Field("@@isac", recurringAccountNumber)
  @Concat_Field("@@issb", recurringSubaccountNumber)
  @Concat_Field("@@tin#", payerTIN)
  @Concat_Field("@@dbgt", budgetPlan)
  @Concat_Field("@@dtes", dateEstablished)
  @Concat_Field("@@dtde", dateDeactivated)
  @Concat_Field("@@curt", currencyType)
  @Concat_Field("@@trco", translatedCompanyNumber)
  @Concat_Field("@@trfc", translatedFacilityNumber)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  @Format_CoFac("$(companyNumber)", "$(facilityNumber)", "", F_CoFac)
  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(coFacName), $(F_CoFac), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@co#@", "companyNumber")
          @Format_ConfMsg_Desc("", $(coFacName), $(F_CoFac), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      %if (fromSel == "Y" && maintenanceCode != "D")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)CoFacSelect.d2w/REPORT$(d2wVarBase)&amp;companyNumber=@dtw_rurlescseq(companyNumber)&amp;facilityNumber=@dtw_rurlescseq(facilityNumber)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
          %if (backURL == "")
              <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=112&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %else
              <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %endif
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;companyNumber=@dtw_rurlescseq(companyNumber)&amp;facilityNumber=@dtw_rurlescseq(facilityNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
