%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EmployeeCalendar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "MonthDesc.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title 		= "Employee Calendar"
  d2wName              = "EmployeeCalendar.d2w"
  d2wVarBase           = "$(genericVarBase)$(employeeVarBase)&amp;dspExcept=@dtw_rurlescseq(dspExcept)&amp;dspReview=@dtw_rurlescseq(dspReview)&amp;dspWorked=@dtw_rurlescseq(dspWorked)&amp;dspNotWrk=@dtw_rurlescseq(dspNotWrk)&amp;searchVar=@dtw_rurlescseq(searchVar)&amp;searchDsp=@dtw_rurlescseq(searchDsp)"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  DTW_REMOVE_WS        = "YES"
  dspMaxRows           = "1000"
  RPT_MAX_ROWS 	= "1000"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  rowIndexNext		= "1"
  totalPages		= "0"	
  curYear              = ""	
  curMonth	        = ""	
  curDay		= ""	
  pastDue 	        = ""	
  reload  	        = ""	
  dayCnt		= "0"	
  dspExcept            = ""	
  dspReview 	        = ""	
  dspNotWrk            = ""	
  dspWorked 	        = ""	
  selMonth	        = ""	
  searchVar	        = ""	
  searchDsp	        = ""	
  startDate	        = ""	
  endDate  	        = ""	
  maxrows  	        = ""	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <link rel=stylesheet type="text/css" href="$(homeURL)$(homePath)$(calStyleSheet)">
          <link rel=stylesheet type="text/css" href="$(homeURL)$(homePath)HDSEmployeeCalendar.css">
          @dtw_assign(formName, "Chg")
          <script type="text/javascript">
              function noLink() {}
              %INCLUDE "calendarAutoSubmit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- Start Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "EMPLOYEECALENDAR")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif

                      %if (selDate > "0")
                          @Date_To_ISO("$(selDate)", dateOut)
                          @dtw_substr(dateOut, "1", "4", calYear)
                          @dtw_substr(dateOut, "6", "2", calMonth)
                      %endif

                      <td class="content">
                          @RetCalEvents(profileHandle, dataBaseID, loadProgram, calYear, calMonth, calWeek, startDate, endDate, reload, pastDue, searchVar, searchDsp)
                          %if (calView == "D")
                              @dtw_assign(startDate, calDate)
                              @dtw_assign(endDate, calDate)
                          %endif
                          @dtw_assign(stmtSQL, "")
                          @dtw_concat(stmtSQL, "SELECT * FROM SYCLDM ", stmtSQL)
                          @dtw_concat(stmtSQL, " Where CDYEAR=$(calYear) ", stmtSQL)
                          %if (calView == "M" || calView == "W" || calView == "D")
                              @dtw_concat(stmtSQL, " and CDMNTH=$(calMonth) ", stmtSQL)
                          %endif
                          %if (calView == "W" || calView == "D")
                              @dtw_concat(stmtSQL, " and CDWEEK=$(calWeek) ", stmtSQL)
                          %endif
                          @dtw_concat(stmtSQL, " ORDER BY CDYEAR,CDMNTH,CDWEEK", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @Employee_Calendar_Query(profileHandle, dataBaseID, stmtSQL)
                          %if (calView != "M")
                              $(hrTagAttr)
                          %endif
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Employee_Calendar_Query (IN CHAR(64)    profileHandle,
				                CHAR(2)     dataBaseID,
                                               CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(prevMonth, calMonth)
      @dtw_assign(nextMonth, calMonth)
      @dtw_assign(prevYear, calYear)
      @dtw_assign(nextYear, calYear)
      @dtw_assign(prevWeek, "0")
      @dtw_assign(nextWeek, "0")

      %if ((calView != "W" && calView != "Y") || (calView == "W" && calWeek == "1"))
          %if (calMonth == "01")
              @dtw_assign(prevMonth, "12")
              @dtw_assign(prevYear, @dtw_rsubtract(calYear, "1"))
          %elif (calMonth == "12")
              @dtw_assign(prevMonth, @dtw_rsubtract(calMonth, "1"))
              @dtw_assign(prevYear, calYear)
          %else
              @dtw_assign(prevMonth, @dtw_rsubtract(calMonth, "1"))
              @dtw_assign(prevYear, calYear)
          %endif
      %endif
      %if (calView == "W")
          %if (calWeek == "1")
              @dtw_assign(prevWeek, "5")
          %else
              @dtw_assign(prevWeek, @dtw_rsubtract(calWeek, "1"))
          %endif
      %endif

      %if ((calView != "W" && calView != "Y") || (calView == "W" && calWeek == "5"))
          %if (calMonth == "01")
              @dtw_assign(nextMonth, @dtw_radd(calMonth, "1"))
              @dtw_assign(nextYear, calYear)
          %elif (calMonth == "12")
              @dtw_assign(nextMonth, "1")
              @dtw_assign(nextYear, @dtw_radd(calYear, "1"))
          %else
              @dtw_assign(nextMonth, @dtw_radd(calMonth, "1"))
              @dtw_assign(nextYear, calYear)
          %endif
      %endif
      %if (calView == "W")
          %if (calWeek == "5")
              @dtw_assign(nextWeek, "1")
          %else
              @dtw_assign(nextWeek, @dtw_radd(calWeek, "1"))
          %endif
      %endif

      %if (calView == "Y")
          @dtw_assign(prevYear, @dtw_rsubtract(calYear, "1"))
          @dtw_assign(nextYear, @dtw_radd(calYear, "1"))
      %else
          %if (@dtw_rlength(prevMonth) == "1")
              @dtw_insert("0", prevMonth, "0", "1", prevMonth)
          %endif
          %if (@dtw_rlength(nextMonth) == "1")
              @dtw_insert("0", nextMonth, "0", "1", nextMonth)
          %endif
      %endif

      %if (calView == "D")
          @dtw_assign(prevWeek, "1")
          @dtw_assign(nextWeek, "1")
          @dtw_assign(prevDate, calDate)
          @Calc_ISO_Date(profileHandle, dataBaseID, prevDate, "S", "D", "1")
          @dtw_assign(prevYear, @dtw_rsubstr(prevDate, "1", "4"))
          @dtw_assign(prevMonth, @dtw_rsubstr(prevDate, "6", "2"))
          @dtw_assign(nextDate, calDate)
          @Calc_ISO_Date(profileHandle, dataBaseID, nextDate, "A", "D", "1")
          @dtw_assign(nextYear, @dtw_rsubstr(nextDate, "1", "4"))
          @dtw_assign(nextMonth, @dtw_rsubstr(nextDate, "6", "2"))
      %endif

      @dtw_tb_rows(monthsTable, maxRows)
      @dtw_assign(mth, "1")
      %while((@dtw_tb_rgetv(monthsTable, mth, "1") != calMonth) && (mth < maxRows))
         {@dtw_add(mth, "1", mth)%}
      @dtw_assign(monthDesc, @dtw_tb_rgetv(monthsTable, mth, "2"))

      <form class="formClass" name="Chg" METHOD="POST" action="$(homeURL)$(cGIPath)$(d2wName)/CALENDAR$(d2wVarBase)&amp;calYear=@dtw_rurlescseq(calYear)&amp;calMonth=@dtw_rurlescseq(calMonth)&amp;calWeek=0&amp;calView=M">
          <table $(calHeaderTable)>
              <tr>
                  %if (calView == "M")
                      @Get_Month_Desc(prevMonth, prevMthDesc)
                      @Get_Month_Desc(nextMonth, nextMthDesc)
                  %else
                      @dtw_assign(prevMthDesc, "$(previousImage)")
                      @dtw_assign(nextMthDesc, "$(nextImage)")
                  %endif
                  @dtw_assign(eventDate, "0")
                  <td class="calselmth">
                      <a href="$(homeURL)$(cGIPath)$(d2wName)/CALENDAR$(d2wVarBase)&amp;calYear=@dtw_rurlescseq(prevYear)&amp;calMonth=@dtw_rurlescseq(prevMonth)&amp;calWeek=@dtw_rurlescseq(prevWeek)&amp;calDate=@dtw_rurlescseq(prevDate)&amp;calView=@dtw_rurlescseq(calView)" title="View Month">$(prevMthDesc)</a>
                      %if (calView == "M")
                          |
                      %endif
                      <a href="$(homeURL)$(cGIPath)$(d2wName)/CALENDAR$(d2wVarBase)&amp;calYear=@dtw_rurlescseq(nextYear)&amp;calMonth=@dtw_rurlescseq(nextMonth)&amp;calWeek=@dtw_rurlescseq(nextWeek)&amp;calDate=@dtw_rurlescseq(nextDate)&amp;calView=@dtw_rurlescseq(calView)" title="View Month">$(nextMthDesc)</a>
                      %if (calView != "Y")
                          <a href="$(homeURL)$(cGIPath)$(d2wName)/CALENDAR$(d2wVarBase)&amp;calYear=@dtw_rurlescseq(calYear)&amp;calMonth=@dtw_rurlescseq(calMonth)&amp;calWeek=0&amp;calView=M" title="View Month">&nbsp; $(monthDesc)</a>
                      %endif
                      <a href="$(homeURL)$(cGIPath)$(d2wName)/CALENDAR$(d2wVarBase)&amp;calYear=@dtw_rurlescseq(calYear)&amp;calMonth=00&amp;calWeek=0&amp;calView=Y" title="View Year">$(calYear)</a>
                      <input type="hidden" name="selDate" size="6" maxlength="6"><a href="javascript:calWindow('selDate');">$(calendarImage)</a>
                  </td>
                  @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
                  <td><h1>$(F_EmpName)</h1></td>
                  %if (searchDsp == "x")
                      <td class="colalph" align="justify">$(searchDsp)</td>
                      <td>&nbsp;</td>
                  %endif
                  <td class="toolbar">
                      <a href="$(homeURL)$(cGIPath)EmployeeProfile.d2w/REPORT$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                  </td>
              </tr>
          </table>
      </form>

          %if (calView == "Y")
             <table $(calYearTable)>
                 <tr class="caldayhdr">
                    <th>Week</th>
                    <th>Sun</th>
                    <th>Mon</th>
                    <th>Tue</th>
                    <th>Wed</th>
                    <th>Thu</th>
                    <th>Fri</th>
                    <th>Sat</th>
                 </tr>
          %elif (calView == "M")
             <table $(calMonthTable)>
                 <tr class="caldayhdr">
                    <th><a href="$(homeURL)$(cGIPath)$(d2wName)/CALENDAR$(d2wVarBase)&amp;calYear=@dtw_rurlescseq(calYear)&amp;calMonth=@dtw_rurlescseq(calMonth)&amp;calWeek=@dtw_rurlescseq(calWeek)&amp;calDate=@dtw_rurlescseq(calDate)&amp;calView=@dtw_rurlescseq(calView)&amp;reload=Y">$(reloadImage)</a></th>
                    <th>Sunday</th>
                    <th>Monday</th>
                    <th>Tuesday</th>
                    <th>Wednesday</th>
                    <th>Thursday</th>
                    <th>Friday</th>
                    <th>Saturday</th>
                 </tr>
          %else
              $(hrTagAttr)
              <table $(calWeekTable)>
          %endif

          @dtw_assign(dayName, "")
          @dtw_assign(saveDate, "")
          @dtw_assign(saveMonth, "")
          @dtw_assign(saveStartDate, "0")
          @dtw_assign(selectWeek, "0")
          @dtw_assign(eventRec, "1")

          %if (dspExcept == "Y")
              @dtw_assign(chgDspExcept, "N")
              @dtw_assign(checkExcept, "CHECKED")
          %else
              @dtw_assign(chgDspExcept, "Y")
              @dtw_assign(checkExcept, "")
          %endif

          %if (dspReview == "Y")
              @dtw_assign(chgDspReview, "N")
              @dtw_assign(checkReview, "CHECKED")
          %else
              @dtw_assign(chgDspReview, "Y")
              @dtw_assign(checkReview, "")
          %endif

          %if (dspWorked == "Y")
              @dtw_assign(chgDspWorked, "N")
              @dtw_assign(checkWorked, "CHECKED")
          %else
              @dtw_assign(chgDspWorked, "Y")
              @dtw_assign(checkWorked, "")
          %endif

          %if (dspNotWrk == "Y")
              @dtw_assign(chgdspNotWrk, "N")
              @dtw_assign(checkNotWrk, "CHECKED")
          %else
              @dtw_assign(chgdspNotWrk, "Y")
              @dtw_assign(checkNotWrk, "")
          %endif

          %if (calView == "Y")
              @dtw_assign(eventsPerDay, "$(eventsPerDayYear)")
          %else
              @dtw_assign(eventsPerDay, "$(eventsPerDayMth)")
          %endif

          %ROW{
              %if (V_CDWEEK == "00")
                  @Event_Query(profileHandle, dataBaseID, V_CDDSUN, V_CDDSAT, eventTable)
                  @dtw_tb_rows(eventTable, maxRows)
                  @dtw_assign(eventRec, "1")

              %else

                  %if (calView == "M" || (calView == "Y" && saveStartDate != V_CDDSUN))
                      @dtw_assign(saveStartDate, "$(V_CDDSUN)")

                      %if (calView == "Y")
                          @dtw_substr(V_CDDSUN, "6", "2", startMonth)
                          @dtw_substr(V_CDDSUN, "9", "2", startDay)
                          @dtw_substr(V_CDDSAT, "6", "2", endMonth)
                          @dtw_substr(V_CDDSAT, "9", "2", endDay)
                          @dtw_assign(week, "&nbsp; $(startMonth)/$(startDay) - $(endMonth)/$(endDay) ")
                          @dtw_assign(selectWeek, "$(V_CDWEEK)")
                      %else
                          @dtw_assign(selectWeek, @dtw_radd(selectWeek, "1"))
                      %endif

                      <tr>
                          %if (calView == "Y")
                              <td class="yrselweek"><a href="$(homeURL)$(cGIPath)$(d2wName)/CALENDAR$(d2wVarBase)&amp;calYear=@dtw_rurlescseq(calYear)&amp;calMonth=@dtw_rurlescseq(startMonth)&amp;calView=W&amp;calWeek=@dtw_rurlescseq(selectWeek)" title="View Week">$(week)</a></td>
                          %else
                              <td class="mthselweek"><a href="$(homeURL)$(cGIPath)$(d2wName)/CALENDAR$(d2wVarBase)&amp;calYear=@dtw_rurlescseq(calYear)&amp;calMonth=@dtw_rurlescseq(calMonth)&amp;calView=W&amp;calWeek=@dtw_rurlescseq(selectWeek)">$(calSelWeekImage)</a></td>
                          %endif

                          @dtw_assign(dayCnt, "1")
                          %while (dayCnt <= "7"){
                              %if (dayCnt == "1")
                                  @dtw_assign(eventDate, "$(V_CDDSUN)")
                              %elif (dayCnt == "2")
                                  @dtw_assign(eventDate, "$(V_CDDMON)")
                              %elif (dayCnt == "3")
                                  @dtw_assign(eventDate, "$(V_CDDTUE)")
                              %elif (dayCnt == "4")
                                  @dtw_assign(eventDate, "$(V_CDDWED)")
                              %elif (dayCnt == "5")
                                  @dtw_assign(eventDate, "$(V_CDDTHU)")
                              %elif (dayCnt == "6")
                                  @dtw_assign(eventDate, "$(V_CDDFRI)")
                              %elif (dayCnt == "7")
                                  @dtw_assign(eventDate, "$(V_CDDSAT)")
                              %endif

                              @dtw_assign(today, "")
                              @dtw_substr(eventDate, "1", "4", eventYear)
                              @dtw_substr(eventDate, "6", "2", eventMonth)
                              @dtw_substr(eventDate, "9", "2", eventDay)
                              %if (calView == "Y")
                                  @dtw_assign(dayClass, "calyearday")
                              %elif (calView == "M")
                                  %if (eventMonth == calMonth)
                                      %if (eventYear == curYear && eventMonth == curMonth && eventDay == curDay)
                                          @dtw_assign(dayClass, "calmthtoday")
                                          @dtw_assign(today, "(Today)")
                                      %else
                                          @dtw_assign(dayClass, "calmthday")
                                      %endif
                                  %else
                                      @dtw_assign(dayClass, "calothday")
                                  %endif
                              %endif

                              <td class="$(dayClass)">
                                  <table $(calDayTable)>
                                      %if (calView == "M")
                                          <tr><td><a href="$(homeURL)$(cGIPath)$(d2wName)/CALENDAR$(d2wVarBase)&amp;calYear=@dtw_rurlescseq(eventYear)&amp;calMonth=@dtw_rurlescseq(eventMonth)&amp;calWeek=1&amp;calView=D&amp;calDate=@dtw_rurlescseq(eventDate)" title="View Day">$(eventDay) $(today)</a></td</tr>
                                      %endif

                                      @dtw_assign(eventCnt, "0")
                                      %while((eventRec <= maxRows) && (eventCnt < eventsPerDay) && (@dtw_tb_rgetv(eventTable, eventRec, @dtw_tb_rQuerycolnonj(eventTable, "CEEVTD")) <= eventDate)) {
                                          @dtw_assign(CEEVTD, @dtw_tb_rgetv(eventTable, eventRec, @dtw_tb_rQuerycolnonj(eventTable, "CEEVTD")))
                                          %if (CEEVTD == eventDate)
                                              @dtw_assign(CESTAT, @dtw_tb_rgetv(eventTable, eventRec, @dtw_tb_rQuerycolnonj(eventTable, "CESTAT")))
                                              %if ((dspExcept == "Y" && CESTAT == "X") || (dspReview == "Y" && CESTAT == "R") || (dspWorked == "Y" && CESTAT == "Y") ||  (dspNotWrk == "Y" && CESTAT == "N") || (dspNotWrk == "Y" && CESTAT == ""))
                                                  @dtw_add(eventCnt, "1", eventCnt)
                                                  @dtw_assign(CEEVTT, @dtw_tb_rgetv(eventTable, eventRec, @dtw_tb_rQuerycolnonj(eventTable, "CEEVTT")))
                                                  @dtw_assign(CEEURL, @dtw_tb_rgetv(eventTable, eventRec, @dtw_tb_rQuerycolnonj(eventTable, "CEEURL")))
                                                  @dtw_assign(CEMTHD, @dtw_tb_rgetv(eventTable, eventRec, @dtw_tb_rQuerycolnonj(eventTable, "CEMTHD")))
                                                  @dtw_assign(CEWKDD, @dtw_tb_rgetv(eventTable, eventRec, @dtw_tb_rQuerycolnonj(eventTable, "CEWKDD")))
                                                  @dtw_assign(CEIMG, @dtw_tb_rgetv(eventTable, eventRec, @dtw_tb_rQuerycolnonj(eventTable, "CEIMG")))
                                                  @dtw_qhtmlencode($(CEWKDD), mouseOver)

                                                  %if (CESTAT == "X")
                                                       @dtw_assign(eventClass, "mthexcept")
                                                  %elif (CESTAT == "R")
                                                       @dtw_assign(eventClass, "mthreview")
                                                  %elif (CESTAT == "Y")
                                                       @dtw_assign(eventClass, "mthworked")
                                                  %else
                                                       @dtw_assign(eventClass, "mthnotwrk")
                                                  %endif

                                                  @dtw_assign(imageExists, "")
                                                  %if (displayImages == "Y" && CEIMG != "")
                                                      @dtw_assign(eventImage, "$(CEIMG)")
                                                      @dtwf_exists(eventImage, imageExists)
                                                  %endif

                                                  @dtw_substr(CEEVTD, "1", "4", eventYear)
                                                  @dtw_substr(CEEVTD, "6", "2", eventMonth)
                                                  @dtw_substr(CEEVTD, "9", "2", eventDay)

                                                  <tr>
                                                      %if (CEEURL == "")
                                                          <td class="$(eventClass)"><a href="javascript:noLink()" onMouseOver="title='$(CEWKDD)'">$(CEMTHD)</a></td>
                                                              %if (imageExists == "Y")
                                                                  <img src="$(homeURL)$(eventImage)" border="0" alt="">
                                                              %endif
                                                          </td>
                                                      %else
                                                          <td class="$(eventClass)">
                                                              <a href="$(homeURL)$(cGIPath)$(CEEURL)&amp;baseVar=@dtw_rurlescseq(baseVar)&amp;eID=@dtw_rurlescseq(eID)&amp;portal=@dtw_rurlescseq(portal)&amp;prCompany=@dtw_rurlescseq(prCompany)&amp;prFacility=@dtw_rurlescseq(prFacility)&amp;prEmployee=@dtw_rurlescseq(prEmployee)&amp;hrCompany=@dtw_rurlescseq(hrCompany)&amp;hrEmployee=@dtw_rurlescseq(hrEmployee)" title="$(CEWKDD)">
                                                                  $(CEMTHD)
                                                                  %if (imageExists == "Y")
                                                                      <img src="$(homeURL)$(eventImage)" border="0" alt="">
                                                                  %endif
                                                              </a>
                                                          </td>
                                                      %endif
                                                  </tr>
                                              %endif
                                          %endif
                                          @dtw_add(eventRec, "1", eventRec)
                                      %}

                                      %if (eventCnt == eventsPerDay)
                                          @dtw_assign(CEEVTD, @dtw_tb_rgetv(eventTable, eventRec, @dtw_tb_rQuerycolnonj(eventTable, "CEEVTD")))
                                          %if (CEEVTD == eventDate)
                                              <tr class="calmoremsg">
                                                  <td>
                                                      %if (calView == "M" && moreMonthImage != "")
                                                          <a href="$(homeURL)$(cGIPath)$(d2wName)/CALENDAR$(d2wVarBase)&amp;calYear=@dtw_rurlescseq(calYear)&amp;calMonth=@dtw_rurlescseq(calMonth)&amp;calWeek=1&amp;calView=D&amp;calDate=@dtw_rurlescseq(eventDate)" title="View Day">$(moreMonthImage)</a>
                                                      %else
                                                          <a href="$(homeURL)$(cGIPath)$(d2wName)/CALENDAR$(d2wVarBase)&amp;calYear=@dtw_rurlescseq(calYear)&amp;calMonth=@dtw_rurlescseq(@dtw_rsubstr(CEEVTD, "6", "2"))&amp;calWeek=1&amp;calView=D&amp;calDate=@dtw_rurlescseq(eventDate)" title="View Day">$(moreYearImage)</a>
                                                      %endif
                                                  </td>
                                              </tr>
                                          %endif
                                      %elif (calView == "M")
                                          %while(eventCnt < eventsPerDay){
                                             @dtw_add(eventCnt, "1", eventCnt)
                                          %}
                                      %endif
                                  </table>
                              </td>
                              @dtw_add(dayCnt, "1", dayCnt)
                          %}
                      </tr>

                  %elif (calView == "D" || calView == "W")

                      %if (calDate != "")
                          @Event_Query(profileHandle, dataBaseID, calDate, calDate, eventTable)
                      %else
                          @Event_Query(profileHandle, dataBaseID, V_CDDSUN, V_CDDSAT, eventTable)
                      %endif
                      @dtw_tb_rows(eventTable, eventMaxRows)

                          @dtw_assign(dayCnt, "1")
                          %while (dayCnt <= "7"){
                              %if (calDate != "")
                                  @dtw_assign(eventDate, "$(calDate)")
                                  @dtw_assign(dayCnt, "7")
                              %else
                                  %if (dayCnt == "1")
                                      @dtw_assign(eventDate, "$(V_CDDSUN)")
                                  %elif (dayCnt == "2")
                                      @dtw_assign(eventDate, "$(V_CDDMON)")
                                  %elif (dayCnt == "3")
                                      @dtw_assign(eventDate, "$(V_CDDTUE)")
                                  %elif (dayCnt == "4")
                                      @dtw_assign(eventDate, "$(V_CDDWED)")
                                  %elif (dayCnt == "5")
                                      @dtw_assign(eventDate, "$(V_CDDTHU)")
                                  %elif (dayCnt == "6")
                                      @dtw_assign(eventDate, "$(V_CDDFRI)")
                                  %elif (dayCnt == "7")
                                      @dtw_assign(eventDate, "$(V_CDDSAT)")
                                  %endif
                              %endif

                              @dtw_substr(eventDate, "1", "4", eventYear)
                              @dtw_substr(eventDate, "6", "2", eventMonth)
                              @dtw_substr(eventDate, "9", "2", eventDay)

                              @RetDayName(profileHandle, dataBaseID, $(eventDate), dayName)
                              @DateFromISO("$(eventDate)", CEEVTD)

                              %if (eventYear == curYear && eventMonth == curMonth && eventDay == curDay)
                                  @dtw_assign(today, "(Today)")
                              %else
                                  @dtw_assign(today, "")
                              %endif

                              @dtw_tb_rows(monthsTable, maxRows)
            	               @dtw_assign(mth, "1")
                              %while((@dtw_tb_rgetv(monthsTable, mth, "1") != eventMonth) && (mth < maxRows))
                                 {@dtw_add(mth, "1", mth)%}
                              @dtw_assign(monthDesc2, @dtw_tb_rgetv(monthsTable, mth, "2"))

                              <tr class="calweekhdr"><td><a href="$(homeURL)$(cGIPath)$(d2wName)/CALENDAR$(d2wVarBase)&amp;calYear=@dtw_rurlescseq(calYear)&amp;calMonth=@dtw_rurlescseq(calMonth)&amp;calWeek=@dtw_rurlescseq(V_CDWEEK)&amp;calDate=@dtw_rurlescseq(eventDate)&amp;calView=D" title="View Day">$(dayName) - $(monthDesc2) $(eventDay) $(today)</a></td></tr>
                                  @dtw_assign(dayTableFlag, "N")
                                      @dtw_assign(eventCnt, "0")
                                      @dtw_assign(x, "1")

                                      %while(x <= eventMaxRows) {
                                          %if (@dtw_tb_rgetv(eventTable, x, @dtw_tb_rQuerycolnonj(eventTable, "CEEVTD")) == eventDate)
                                              @dtw_assign(CESTAT, @dtw_tb_rgetv(eventTable, x, @dtw_tb_rQuerycolnonj(eventTable, "CESTAT")))
                                              %if ((dspExcept == "Y" && CESTAT == "X") || (dspReview == "Y" && CESTAT == "R") || (dspWorked == "Y" && CESTAT == "Y") ||  (dspNotWrk == "Y" && CESTAT == "N") || (dspNotWrk == "Y" && CESTAT == ""))
                                                  @dtw_add(eventCnt, "1", eventCnt)
                                                  @dtw_assign(CEEVTT, @dtw_tb_rgetv(eventTable, x, @dtw_tb_rQuerycolnonj(eventTable, "CEEVTT")))
                                                  @dtw_assign(CEEURL, @dtw_tb_rgetv(eventTable, x, @dtw_tb_rQuerycolnonj(eventTable, "CEEURL")))
                                                  @dtw_assign(CEMTHD, @dtw_tb_rgetv(eventTable, x, @dtw_tb_rQuerycolnonj(eventTable, "CEMTHD")))
                                                  @dtw_assign(CEWKDD, @dtw_tb_rgetv(eventTable, x, @dtw_tb_rQuerycolnonj(eventTable, "CEWKDD")))
                                                  @dtw_assign(CEIMG, @dtw_tb_rgetv(eventTable, x, @dtw_tb_rQuerycolnonj(eventTable, "CEIMG")))
                                                  @dtw_qhtmlencode($(CEWKDD), mouseOver)

                                                  %if (CESTAT == "X")
                                                       @dtw_assign(eventClass, "weekexcept")
                                                  %elif (CESTAT == "R")
                                                       @dtw_assign(eventClass, "weekreview")
                                                  %elif (CESTAT == "Y")
                                                       @dtw_assign(eventClass, "weekworked")
                                                  %else
                                                       @dtw_assign(eventClass, "weeknotwrk")
                                                  %endif

                                                  @dtw_assign(imageExists, "")
                                                  %if (displayImages == "Y" && CEIMG != "")
                                                      @dtw_assign(eventImage, "$(CEIMG)")
                                                      @dtwf_exists(eventImage, imageExists)
                                                  %endif

                                                  @dtw_substr(V_CEEVTD, "1", "4", eventYear)
                                                  @dtw_substr(V_CEEVTD, "6", "2", eventMonth)
                                                  @dtw_substr(V_CEEVTD, "9", "2", eventDay)

                                                  %if (dayTableFlag == "N")
                                                      @dtw_assign(dayTableFlag, "Y")
                                                      <tr><td>
                                                         <table $(calWeekEventTable)>
                                                  %endif
                                                  <tr class="$(eventClass)">
                                                      <td>
                                                          %if (CEEURL == "")
                                                              %if (dspTime == "Y")
                                                                  <span class="caltime">$(eventTime)</span>
                                                              %endif
                                                              <span class="weekevent">$(CEWKDD)</span>
                                                              %if (imageExists == "Y")
                                                                  <img src="$(homeURL)$(eventImage)" border="0" alt="">
                                                              %endif
                                                          %else
                                                              <a href="$(homeURL)$(cGIPath)$(CEEURL)&amp;baseVar=@dtw_rurlescseq(baseVar)&amp;eID=@dtw_rurlescseq(eID)&amp;portal=@dtw_rurlescseq(portal)&amp;prCompany=@dtw_rurlescseq(prCompany)&amp;prFacility=@dtw_rurlescseq(prFacility)&amp;prEmployee=@dtw_rurlescseq(prEmployee)&amp;hrCompany=@dtw_rurlescseq(hrCompany)&amp;hrEmployee=@dtw_rurlescseq(hrEmployee)"  onMouseOver="title='$(mouseOver)'">
                                                                  %if (dspTime == "Y")
                                                                      <span class="caltime">$(eventTime)</span>
                                                                  %endif
                                                                  <span class="weekevent">$(CEWKDD)</span>
                                                                  %if (imageExists == "Y")
                                                                      <img src="$(homeURL)$(eventImage)" border="0" alt="">
                                                                  %endif
                                                              </a>
                                                          %endif
                                                      </td>
                                                  </tr>
                                              %endif
                                          %endif
                                  @dtw_add(x, "1", x)
                              %}

                              %if (dayTableFlag == "Y")
                                  </table>
                                  </td>
                                  </tr>
                              %endif
                              @dtw_add(dayCnt, "1", dayCnt)
                          %}
                  %endif
              %endif
          %}
          </table>

          <table $(calTrailerTable)>
              <tr>
                  <td class="legendtitle">Display:</td>
                  <td class="legendexcept">
                      <form class="formClass" action="">
                          <input type="checkbox" name="except" $(checkExcept) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/CALENDAR$(d2wVarBase)&amp;calYear=@dtw_rurlescseq(calYear)&amp;calMonth=@dtw_rurlescseq(calMonth)&amp;calWeek=@dtw_rurlescseq(calWeek)&amp;calDate=@dtw_rurlescseq(calDate)&amp;calView=@dtw_rurlescseq(calView)&amp;chgDspExcept=Y'">Exceptions
                      </form>
                  </td>
                  <td class="legendreview">
                      <form class="formClass" action="">
                          <input type="checkbox" name="review" $(checkReview) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/CALENDAR$(d2wVarBase)&amp;calYear=@dtw_rurlescseq(calYear)&amp;calMonth=@dtw_rurlescseq(calMonth)&amp;calWeek=@dtw_rurlescseq(calWeek)&amp;calDate=@dtw_rurlescseq(calDate)&amp;calView=@dtw_rurlescseq(calView)&amp;chgDspReview=Y'">Review
                      </form>
                  </td>
                  <td class="legendworked">
                      <form class="formClass" action="">
                          <input type="checkbox" name="worked" $(checkWorked) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/CALENDAR$(d2wVarBase)&amp;calYear=@dtw_rurlescseq(calYear)&amp;calMonth=@dtw_rurlescseq(calMonth)&amp;calWeek=@dtw_rurlescseq(calWeek)&amp;calDate=@dtw_rurlescseq(calDate)&amp;calView=@dtw_rurlescseq(calView)&amp;chgDspWorked=Y'">Worked
                      </form>
                  </td>
                  <td class="legendnotwrk">
                      <form class="formClass" action="">
                          <input type="checkbox" name="nonworked" $(checkNotWrk) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/CALENDAR$(d2wVarBase)&amp;calYear=@dtw_rurlescseq(calYear)&amp;calMonth=@dtw_rurlescseq(calMonth)&amp;calWeek=@dtw_rurlescseq(calWeek)&amp;calDate=@dtw_rurlescseq(calDate)&amp;calView=@dtw_rurlescseq(calView)&amp;chgDspNotWrk=Y'">Not Worked
                      </form>
                  </td>
              </tr>
          </table>
  %}
%}

%HTML(CALENDAR) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %if (dspExcept == "")
          @dtw_assign(dspExcept, "Y")
      %elif (chgDspExcept == "Y" && dspExcept != "Y")
          @dtw_assign(dspExcept, "Y")
      %elif (chgDspExcept == "Y")
          @dtw_assign(dspExcept, "N")
      %endif

      %if (dspReview == "")
          @dtw_assign(dspReview, "Y")
      %elif (chgDspReview == "Y" && dspReview != "Y")
          @dtw_assign(dspReview, "Y")
      %elif (chgDspReview == "Y")
          @dtw_assign(dspReview, "N")
      %endif

      %if (dspWorked == "")
          @dtw_assign(dspWorked, "Y")
      %elif (chgDspWorked == "Y" && dspWorked != "Y")
          @dtw_assign(dspWorked, "Y")
      %elif (chgDspWorked == "Y")
          @dtw_assign(dspWorked, "N")
      %endif

      %if (dspNotWrk == "")
          @dtw_assign(dspNotWrk, "Y")
      %elif (chgDspNotWrk == "Y" && dspNotWrk != "Y")
          @dtw_assign(dspNotWrk, "Y")
      %elif (chgDspNotWrk == "Y")
          @dtw_assign(dspNotWrk, "N")
      %endif

      @dtw_assign(curYear, @dtw_rsubstr(@dtw_rdate("S"), "1", "4"))
      %if (calYear == "")
          @dtw_assign(calYear, curYear)
      %endif

      @dtw_assign(curMonth, @dtw_rsubstr(@dtw_rdate("S"), "5", "2"))
      %if (calMonth == "")
          @dtw_assign(calMonth, curMonth)
      %endif
      @dtw_assign(curDay, @dtw_rsubstr(@dtw_rdate("S"), "7", "2"))

      %if (calWeek == "")
          @dtw_assign(calWeek, "0")
      %endif

      %if (calView == "")
          @dtw_assign(calView, "M")
      %endif

      @dtw_assign(searchVar, "")
      @dtw_concat(searchVar, @dtw_rconcat(@dtw_rconcat("@@comp", prCompany), "}{"), searchVar)
      @dtw_concat(searchVar, @dtw_rconcat(@dtw_rconcat("@@facl", prFacility), "}{"), searchVar)
      @dtw_concat(searchVar, @dtw_rconcat(@dtw_rconcat("@@empl", prEmployee), "}{"), searchVar)
      @Months_Query(profileHandle, dataBaseID, "MONTHS    ", monthsTable)
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script type="text/javascript">
              %INCLUDE "Menu.js"
	       %INCLUDE "numedit.icl"
              %INCLUDE "NewWindowOpen.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.company, 2, 0) &&
                      editNum(document.Search.facility, 4, 0) &&
                      editNum(document.Search.employee, 5, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "EMPLOYEECALSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      <table $(baseTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1> Employee Calendar Search </h1></td>
                              <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                          </tr>
                      </table>
            		
                      $(hrTagAttr)

                      <form class="formClass" METHOD=POST NAME="Search" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)&amp;calYear=@dtw_rurlescseq(calYear)&amp;calMonth=@dtw_rurlescseq(calMonth)&amp;calWeek=@dtw_rurlescseq(calWeek)&amp;calView=@dtw_rurlescseq(calView)&amp;reload=S">
                          <table $(quickSearchTable)>
                              <tr><th class="dsphdr"> Search Element</th>
                                  <th class="dsphdr"> Search Data</th>
                              </tr>

                              <tr><td class="dsphdr">Company Number</td>
                                  <td class="inputalph"><input name="company" type="text" value="" size="2" maxlength="2"></td>
                              </tr>
                              <tr><td class="dsphdr">Facility Number</td>
                                  <td class="inputalph"><input name="facility" type="text" value="" size="4" maxlength="4"></td>
                              </tr>
                              <tr><td class="dsphdr">Employee Number</td>
                                  <td class="inputalph"><input name="employee" type="text" value="" size="5" maxlength="5"></td>
                              </tr>			
                              <tr><td class="dsphdr">Department</td>
                                  <td class="inputnmbr"><input name="department" type="text" size="5" maxlength="5"></td>
                              </tr>
                              <tr><td class="dsphdr">Pay Code</td>
                                  <td class="inputalph"><input name="payCode" type="text" size="3" maxlength="3"></td>
                              </tr>
                              <tr><td class="dsphdr">Mfg Order Number</td>
                                  <td class="inputalph"><input name="mfgOrder" type="text" size="9" maxlength="9"></td>
                              </tr>
                          </table>
                          <a href="javascript:check(document.Search)">$(goSearchImage)</a>
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(company,@dtw_rstrip(company))
  @dtw_assign(facility,@dtw_rstrip(facility))
  @dtw_assign(employee,@dtw_rstrip(employee))
  @dtw_mUPPERCASE(department)
  @dtw_mUPPERCASE(payCode)
  @dtw_mUPPERCASE(mfgOrder)

  @dtw_assign(searchVar, "")
  %if (company > "0")
      @dtw_concat(searchVar, @dtw_rconcat(@dtw_rconcat("@@comp", company), "}{"), searchVar)
  %endif
  %if (facility > "0")
      @dtw_concat(searchVar, @dtw_rconcat(@dtw_rconcat("@@facl", facility), "}{"), searchVar)
  %endif
  %if (employee > "0")
      @dtw_concat(searchVar, @dtw_rconcat(@dtw_rconcat("@@empl", employee), "}{"), searchVar)
  %endif
  %if (department != "")
      @dtw_concat(searchVar, @dtw_rconcat(@dtw_rconcat("@@dept", department), "}{"), searchVar)
  %endif
  %if (payCode != "")
      @dtw_concat(searchVar, @dtw_rconcat(@dtw_rconcat("@@payc", payCode), "}{"), searchVar)
  %endif
  %if (mfgOrder != "")
      @dtw_concat(searchVar, @dtw_rconcat(@dtw_rconcat("@@mord", mfgOrder), "}{"), searchVar)
  %endif

  @dtw_assign(curYear, @dtw_rsubstr(@dtw_rdate("S"), "1", "4"))
  @dtw_assign(curMonth, @dtw_rsubstr(@dtw_rdate("S"), "5", "2"))
  @dtw_assign(curDay, @dtw_rsubstr(@dtw_rdate("S"), "7", "2"))
  @Months_Query(profileHandle, dataBaseID, "MONTHS    ", monthsTable)
  @Set_SQL(stmtSQL)
%}