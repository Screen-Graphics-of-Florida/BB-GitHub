%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Work Item History Notification"
  d2wName                 = "WFHistoryNotification.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfInstance=@dtw_rurlescseq(wfInstance)&amp;wfInstanceDate=@dtw_rurlescseq(wfInstanceDate)&amp;wfWorkItem=@dtw_rurlescseq(wfWorkItem)&amp;wfWorkItemSequence=@dtw_rurlescseq(wfWorkItemSequence)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @dtw_assign(edtVar, "")
  @Concat_Field("@@inst", wfInstance)
  @Concat_Field("@@indt", wfInstanceDate)
  @dtw_concat(edtVar, "}{", edtVar)
  @WFWrkItmUserView(profileHandle, dataBaseID, userPass, edtVar)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterSearch.icl"
                  %INCLUDE "NoFormValidate.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "$(inquiryBanner)"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      <td>
                          @dtw_concat(stmtSQL, " Select WFWIEN.*,   ", stmtSQL)
                          @dtw_concat(stmtSQL, " upper(WEEMAL) as WEEMALU, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(USDESC,' ') as USDESC, coalesce(USDESCU,' ') as USDESCU, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(MSDESC,' ') as MSDESC, coalesce(MSDESCU,' ') as MSDESCU, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(MDDESC,' ') as MDDESC, coalesce(MDDESCU,' ') as MDDESCU, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(a.FLDESC,' ') as typeFLDESC, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(b.FLDESC,' ') as prgmFLDESC ", stmtSQL)
                          @dtw_concat(fileSQL, " WFWIEN ", fileSQL)
                          @dtw_concat(fileSQL, " left join SYUSER on USUSER=WEPART ", fileSQL)
                          @dtw_concat(fileSQL, " left join WFMSGT on MSMSID=WEMSID ", fileSQL)
                          @dtw_concat(fileSQL, " left join WFMEDM on MDMEDM=WEMEDM ", fileSQL)
                          @dtw_concat(fileSQL, " left join SYFLAG a on a.FLTYPE='WFNOTFYTYP' and a.FLVALU=WENFTY ", fileSQL)
                          @dtw_concat(fileSQL, " left join SYFLAG b on b.FLTYPE='WFNTFYUPD' and b.FLVALU=WEPGM ", fileSQL)
                          @dtw_concat(selectSQL, " WEINST=$(wfInstance) and WEINDT=$(wfInstanceDate) and WEWITM=$(wfWorkItem) and WEWISQ=$(wfWorkItemSequence)", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @List_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "$(inquiryTrailer)"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64) profileHandle,
                                   CHAR(2)   dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(displayCloseIcon, "Y")
      %INCLUDE "PageTitle.icl"

      <table $(contentTable)>
          @RtvFldDesc("ININST=$(wfInstance) and ININDT=$(wfInstanceDate)", "WFINST", "INDESC", V_INDESC)
          <tr><td><h2> $(V_INDESC)</h2></td></tr>
          @RtvFldDesc("ININST=$(wfInstance) and ININDT=$(wfInstanceDate)", "WFINST", "INPROC", V_INPROC)
          @RtvFldDesc("WHINST=$(wfInstance) and WHINDT=$(wfInstanceDate) and WHWITM=$(wfWorkItem) and WHWISQ=$(wfWorkItemSequence)", "WFWIHS", "CHAR(WHPONT)", V_WHPONT)
          @RtvFldDesc("WHINST=$(wfInstance) and WHINDT=$(wfInstanceDate) and WHWITM=$(wfWorkItem) and WHWISQ=$(wfWorkItemSequence)", "WFWIHS", "CHAR(WHSEQ)", V_WHSEQ)
          @RtvFldDesc("PDPROC='$(V_INPROC)' and PDPONT=$(V_WHPONT) and PDSEQ=$(V_WHSEQ) ", "WFPRDT", "PDDESC", V_PDDESC)
          @Format_Code("$(V_WHPONT)-$(V_WHSEQ)", F_WHPONT)
          <tr><td><h2> $(V_PDDESC) $(F_WHPONT)</h2></td></tr>
      </table>

      $(inquiryhrTagAttr)

      %if (formatToPrint != "Y")
          <table $(contentTable)>
              <tr><td> %INCLUDE "AssignPageValue.icl" </td>
              </tr>
          </table>
      %endif

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              @OrderBy_Sort("WEEMALU", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Email"           title="Sequence By Email">Email</a></th>
              @OrderBy_Sort("USDESCU", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Participant"      title="Sequence By Participant">Participant</a></th>
              @OrderBy_Sort("MSDESCU", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MsgId"            title="Sequence By Message ID">Message ID</a></th>
              @OrderBy_Sort("WENFTY", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=NotificationType" title="Sequence By Notification Type">Notification Type</a></th>
              @OrderBy_Sort("MDDESCU", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Medium"           title="Sequence By Medium">Medium</a></th>
              @OrderBy_Sort("WEPGM", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Program"          title="Sequence By Program">Sent From</a></th>
              @OrderBy_Sort("WECMPL", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Completed"        title="Sequence By Completed">Completed</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"

              <tr class="$(rowClass)">
                  %if (V_WEMEDM != "*NONE")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)WFHistoryNotificationText.d2w/REPORT$(d2wVarBase)&amp;wfExternalId=@dtw_rurlescseq(V_WEEXID)" title="View Text" onclick="$(commentWinVar)">$(V_WEEMAL)</a></td>
                  %else
                      <td class="colalph">$(V_WEEMAL)</td>
                  %endif
                  <td class="colalph" $(helpCursor)><span title="$(V_WEPART)">$(V_USDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_WEMSID)">$(V_MSDESC)</span></td>
                  <td class="colcode" $(helpCursor)><span title="$(V_typeFLDESC)">$(V_WENFTY)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_WEMEDM)">$(V_MDDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_WEPGM)">$(V_prgmFLDESC)</span></td>
                  <td class="colnmbr">$(V_WECMPL)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      $(inquiryhrTagAttr)
      %INCLUDE "CloseWindow.icl"
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "WECMPL")
      @DTW_ASSIGN(orderByDisplay, "Completed")
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Email")
      %if (orderBy == "WEEMALU,WECMPL")
          @DTW_ASSIGN(orderBy, "WEEMALU DESC,WECMPL")
          @DTW_ASSIGN(orderByDisplay, "Email (descending)")
      %else
          @DTW_ASSIGN(orderBy, "WEEMALU,WECMPL")
          @DTW_ASSIGN(orderByDisplay, "Email")
      %endif
  %elif (sequence == "Participant")
      %if (orderBy == "USDESCU,WECMPL")
          @DTW_ASSIGN(orderBy, "USDESCU DESC,WECMPL")
          @DTW_ASSIGN(orderByDisplay, "Participant (descending)")
      %else
          @DTW_ASSIGN(orderBy, "USDESCU,WECMPL")
          @DTW_ASSIGN(orderByDisplay, "Participant")
      %endif
  %elif (sequence == "MsgId")
      %if (orderBy == "MSDESCU,WECMPL")
          @DTW_ASSIGN(orderBy, "MSDESCU DESC,WECMPL")
          @DTW_ASSIGN(orderByDisplay, "Message ID")
      %else
          @DTW_ASSIGN(orderBy, "MSDESCU,WECMPL")
          @DTW_ASSIGN(orderByDisplay, "Message ID")
      %endif
  %elif (sequence == "NotificationType")
      %if (orderBy == "WENFTY,WECMPL")
          @DTW_ASSIGN(orderBy, "WENFTY DESC,WECMPL")
          @DTW_ASSIGN(orderByDisplay, "Notification Type")
      %else
          @DTW_ASSIGN(orderBy, "WENFTY,WECMPL")
          @DTW_ASSIGN(orderByDisplay, "Notification Type")
      %endif
  %elif (sequence == "Medium")
      %if (orderBy == "MDDESCU,WECMPL")
          @DTW_ASSIGN(orderBy, "MDDESCU DESC,WECMPL")
          @DTW_ASSIGN(orderByDisplay, "Medium (descending)")
      %else
          @DTW_ASSIGN(orderBy, "MDDESCU,WECMPL")
          @DTW_ASSIGN(orderByDisplay, "Medium")
      %endif
  %elif (sequence == "Program")
      %if (orderBy == "WEPGM,WECMPL")
          @DTW_ASSIGN(orderBy, "WEPGM DESC,WECMPL")
          @DTW_ASSIGN(orderByDisplay, "Program (descending)")
      %else
          @DTW_ASSIGN(orderBy, "WEPGM,WECMPL")
          @DTW_ASSIGN(orderByDisplay, "Program")
      %endif
  %elif (sequence == "Completed")
      %if (orderBy == "WECMPL")
          @DTW_ASSIGN(orderBy, "WECMPL DESC")
          @DTW_ASSIGN(orderByDisplay, "Completed (descending)")
      %else
          @DTW_ASSIGN(orderBy, "WECMPL")
          @DTW_ASSIGN(orderByDisplay, "Completed")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}