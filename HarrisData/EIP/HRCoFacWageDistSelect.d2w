                      <td class="colalph">$(acctDesc)</td>
                  </tr>
              %endif
              %if (V_WDDPT9 != "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colalph">$(V_WDDPT9)</td>
                      @RtvFldDesc("EADEPT='$(V_WDDPT9)'", "PREXAC", "EANAME", prDeptName)
                      <td class="colalph">$(prDeptName) </td>
                      @Format_Nbr(@dtw_rmultiply(V_WDPCT9, "100"), F_WDPCT9, "2", $(pctEditCode), "", "", "")
                      <td class="colnmbr">$(F_WDPCT9)</td>
                      @Format_Acct("$(V_WDACT9)", "$(V_WDSUB9)", "", F_AcctSub)
                      <td class="colalph">$(F_AcctSub)</td>
                      @RtvFldDesc("CHACCT=$(V_WDACT9) and CHSUB=$(V_WDSUB9) ", "HDCHRT", "CHCHDS", acctDesc)
                      <td class="colalph">$(acctDesc)</td>
                  </tr>
              %endif
              %if (V_WDDP10 != "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colalph">$(V_WDDP10)</td>
                      @RtvFldDesc("EADEPT='$(V_WDDP10)'", "PREXAC", "EANAME", prDeptName)
                      <td class="colalph">$(prDeptName) </td>
