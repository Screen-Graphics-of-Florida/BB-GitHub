%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title 	        = "Wage Distribution Tables"
  d2wName              = "HRCoFacWageDistselect.d2w"
  d2wVarBase           = "$(genericVarBase)$(employeeVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName          = "HPRWDM"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  RPT_MAX_ROWS         = "99"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext	        = "1"
  totalPages	        = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @dtw_assign(applicationID, "PR")
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "WAGEDISTSELECT")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          @dtw_concat(stmtSQL, "Select * From PRWGDS ", stmtSQL)
                          @dtw_concat(stmtSQL, " Where WDCOMP=$(prCompany) and WDFACL=$(prFacility) and WDEMPL=$(prEmployee)", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @Dist_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Dist_Query (IN CHAR(64)    profileHandle,
				   CHAR(2)     dataBaseID,
                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Return To Employee">$(portalHome)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>

          @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
          <tr><td><h2>$(F_EmpName)</h2></td></tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      %ROW {
          <table $(contentTable)>
              <tr><td class="colhdr">Dept<br>Worked</td>
                  <td class="colhdr">Department<br>Name</td>
                  <td class="colhdr">Distribution<br>Percent</td>
                  <td class="colhdr">Override<br>Account</td>
                  <td class="colhdr">Account Description</td>
              </tr>
              %INCLUDE "SetRowClass.icl"
              %if (V_WDDPT1 != "")
                  <tr class="$(rowClass)">
                      <td class="colalph">$(V_WDDPT1)</td>
                      @RtvFldDesc("EADEPT='$(V_WDDPT1)'", "PREXAC", "EANAME", prDeptName)
                      <td class="colalph">$(prDeptName) </td>
                      @Format_Nbr(@dtw_rmultiply(V_WDPCT1, "100"), F_WDPCT1, "2", $(pctEditCode), "", "", "")
                      <td class="colnmbr">$(F_WDPCT1)</td>
                      @Format_Acct("$(V_WDACT1)", "$(V_WDSUB1)", "", F_AcctSub)
                      <td class="colalph">$(F_AcctSub)</td>
                      @RtvFldDesc("CHACCT=$(V_WDACT1) and CHSUB=$(V_WDSUB1) ", "HDCHRT", "CHCHDS", acctDesc)
                      <td class="colalph">$(acctDesc)</td>
                  </tr>
              %endif
              %if (V_WDDPT2 != "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colalph">$(V_WDDPT2)</td>
                      @RtvFldDesc("EADEPT='$(V_WDDPT2)'", "PREXAC", "EANAME", prDeptName)
