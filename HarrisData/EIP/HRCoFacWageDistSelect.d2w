                      <td class="colalph">$(acctDesc)</td>
                  </tr>
              %endif
              %if (V_WDDPT3 != "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colalph">$(V_WDDPT3)</td>
                      @RtvFldDesc("EADEPT='$(V_WDDPT3)'", "PREXAC", "EANAME", prDeptName)
