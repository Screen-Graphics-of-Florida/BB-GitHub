%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Import Row Type Search"
  d2wName                 = "MapImportRecordTypeSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;importKey=@dtw_rurlescseq(importKey)&amp;specificImportTable=@dtw_rurlescseq(specificImportTable)&amp;passedImportTable=@dtw_rurlescseq(passedImportTable)&amp;docName=@dtw_rurlescseq(docName)&amp;fldTable=@dtw_rurlescseq(fldTable)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)&amp;fldTableDesc=@dtw_rurlescseq(fldTableDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL)  {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %if (specificImportTable == "")
                  function selectRecordType(importTable,importTableDescription,recordType,recordTypeDescription){
                      window.opener.document.$(docName).$(fldTable).value = importTable;
                      window.opener.document.$(docName).$(fldTableDesc).value = importTableDescription;
                      window.opener.document.$(docName).$(fldName).value = recordType;
                      window.opener.document.$(docName).$(fldDesc).value = recordTypeDescription;
                      window.opener.document.$(docName).$(fldName).focus();
                      window.close();
                  }
              %else
                  function selectRecordType(recordType,recordTypeDescription){
                      window.opener.document.$(docName).$(fldName).value = recordType;
                      window.opener.document.$(docName).$(fldDesc).value = recordTypeDescription;
                      window.opener.document.$(docName).$(fldName).focus();
                      window.close();
                  }
              %endif
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      %if (specificImportTable != "")
          @dtw_assign(importTable, specificImportTable)
      %endif

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select SYMIRT.*,  ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(MFDESC,' ') as MFDESC, coalesce(MFDESCU,' ') as MFDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(FFDESC,' ') as FFDESC, coalesce(FFDESCU,' ') as FFDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " SYMIRT ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYMIHD on FHIMKY=FRIMKY ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYMMTB on MFMPKY=FHMPKY and MFMFIL=FRMFIL ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYMITB on FFIMKY=FRIMKY and FFIFIL=FRIFIL ", fileSQL)
                      @dtw_concat(selectSQL, " FRIMKY=$(importKey) ", selectSQL)
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, " and FRIFIL='$(importTable)' and FRRTYP='$(recordType)' ", selectSQL)
                      %elif (specificImportTable != "")
                          @dtw_concat(selectSQL, " and FRIFIL='$(specificImportTable)' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)

                      %if (moreInfo == "Y")
                          @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                          @dtw_assign(SAVE_MAX_ROWS, RPT_MAX_ROWS)
                          @dtw_assign(START_ROW_NUM, "1")
                          @dtw_assign(RPT_MAX_ROWS, "9999")

                          %{Template %}
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select SYMITP.*,  ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(MFDESC,' ') as MFDESC, coalesce(MFDESCU,' ') as MFDESCU, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(MDDPOS,0) as MDDPOS, coalesce(MDDESC,' ') as MDDESC, coalesce(MDDLGC,' ') as MDDLGC, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(MDNOTE,' ') as MDNOTE, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(FFDESC,' ') as FFDESC, coalesce(FFDESCU,' ') as FFDESCU, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(FRDESC,' ') as FRDESC, coalesce(FRDESCU,' ') as FRDESCU ", stmtSQL)
                          @dtw_concat(stmtSQL, " From SYMITP ", stmtSQL)
                          @dtw_concat(stmtSQL, " inner join SYMIHD on FHIMKY=FDIMKY ", stmtSQL)
                          @dtw_concat(stmtSQL, " inner join SYMMTB on MFMPKY=FHMPKY and MFMFIL=FDMFIL ", stmtSQL)
                          @dtw_concat(stmtSQL, " inner join SYMMCL on MDMPKY=FHMPKY and MDMFIL=FDMFIL and MDMFLD=FDMFLD ", stmtSQL)
                          @dtw_concat(stmtSQL, " left  join SYMITB on FFIMKY=FDIMKY and FFIFIL=FDIFIL ", stmtSQL)
                          @dtw_concat(stmtSQL, " left  join SYMIRT on FRIMKY=FDIMKY and FRIFIL=FDIFIL and FRRTYP=FDRTYP ", stmtSQL)
                          @dtw_concat(stmtSQL, " Where FDIMKY=$(importKey) and FDIFIL='$(importTable)' and FDRTYP='$(recordType)' ", stmtSQL)
                          @dtw_concat(stmtSQL, " Order By FDMFIL,MDDPOS,FDMFLD ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @Process_Select_Template(profileHandle, dataBaseID, stmtSQL)

                          %{Key %}
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select SYMIKY.*,  ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(FFDESC,' ') as FFDESC, coalesce(FFDESCU,' ') as FFDESCU, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(FRDESC,' ') as FRDESC, coalesce(FRDESCU,' ') as FRDESCU, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(a.MFDESC,' ') as MFDESC, coalesce(a.MFDESCU,' ') as MFDESCU, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(b.MFDESC,' ') as parentMFDESC, coalesce(b.MFDESCU,' ') as parentMFDESCU ", stmtSQL)
                          @dtw_concat(stmtSQL, " From SYMIKY ", stmtSQL)
                          @dtw_concat(stmtSQL, " left join SYMIHD on FHIMKY=FKIMKY ", stmtSQL)
                          @dtw_concat(stmtSQL, " left join SYMITB on FFIMKY=FKIMKY and FFIFIL=FKIFIL ", stmtSQL)
                          @dtw_concat(stmtSQL, " left join SYMIRT on FRIMKY=FKIMKY and FRIFIL=FKIFIL and FRRTYP=FKRTYP ", stmtSQL)
                          @dtw_concat(stmtSQL, " left join SYMMTB a on a.MFMPKY=FHMPKY and a.MFMFIL=FKMFIL ", stmtSQL)
                          @dtw_concat(stmtSQL, " left join SYMMTB b on b.MFMPKY=FHMPKY and b.MFMFIL=FKPFIL ", stmtSQL)
                          @dtw_concat(stmtSQL, " Where FKIMKY=$(importKey) and FKIFIL='$(importTable)' and FKRTYP='$(recordType)' ", stmtSQL)
                          @dtw_concat(stmtSQL, " Order By FFDESCU,FRDESCU,FFDESCU ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @Process_Select_Key(profileHandle, dataBaseID, stmtSQL)

                          @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                          @dtw_assign(RPT_MAX_ROWS, SAVE_MAX_ROWS)
                      %endif

                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      <table $(contentTable)>
          @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "FHDESC", V_FHDESC)
          @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "CHAR(FHMPKY)", V_FHMPKY)
          @Format_Header("Import Definition", $(V_FHDESC), $(importKey))

          @RtvFldDesc("MHMPKY=$(V_FHMPKY)", "SYMMHD", "MHDESC", V_MHDESC)
          @RtvFldDesc("MHMPKY=$(V_FHMPKY)", "SYMMHD", "MHWPGM", V_MHWPGM)
          @Format_Header("Map Definition", $(V_MHDESC), $(V_MHWPGM))

          %if (specificImportTable != "")
              @RtvFldDesc("FFIMKY=$(importKey) and FFIFIL='$(specificImportTable)'", "SYMITB", "FFDESC", V_FFDESC)
              @Format_Header("Import Table", $(V_FFDESC), $(specificImportTable))
          %endif
      </table>
      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">Row Type</th>
                      %if (passedImportTable == "")
                          <th class="colhdr">Import Table</th>
                      %endif
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="15" maxlength="50">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchRecType" size="5" maxlength="5">
                          <input type="hidden" name="operRecType" value="LIKE">
                      </td>
                      %if (passedImportTable == "")
                          <td><input type="text" class="inputalph" name="srchTable" size="10" maxlength="10">
                              <input type="hidden" name="operTable" value="LIKE">
                          </td>
                      %endif
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>	

          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("FRDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description"     title="Sequence By Description, Row Type">Description</a></th>
                  @OrderBy_Sort("FRRTYP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RowType"         title="Sequence By Row Type">Row Type</a></th>
                  @OrderBy_Sort("MFDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=InterfaceTable"  title="Sequence By Primary Interface Table, Row Type">Primary Interface Table</a></th>
                  %if (passedImportTable == "")
                      @OrderBy_Sort("FFDESCU", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ImportTable" title="Sequence By Import Table, Row Type">Import Table</a></th>
                  %endif
              </tr>

              %INCLUDE "NoRecordsFound.icl"
      %endif		
              %ROW{
                  @Format_Quote(V_FRIFIL, F_FRIFIL)
                  @Format_Quote(V_FFDESC, F_FFDESC)
                  @Format_Quote(V_FRRTYP, F_FRRTYP)
                  @Format_Quote(V_FRDESC, F_FRDESC)

                  %if (moreInfo != "Y")	
                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          %if (specificImportTable == "")
                              <td class="colalph"><a href="javascript:selectRecordType('$(F_FRIFIL)','$(F_FFDESC)','$(F_FRRTYP)','$(F_FRDESC)')" title="Select Row Type">$(V_FRDESC)</a></td>
                          %else
                              <td class="colalph"><a href="javascript:selectRecordType('$(F_FRRTYP)','$(F_FRDESC)')" title="Select Row Type">$(V_FRDESC)</a></td>
                          %endif
                          <td class="colalph">$(V_FRRTYP)</td>
                          <td class="colalph" $(helpCursor)><span title="$(V_FRMFIL)">$(V_MFDESC)</span></td>
                          %if (specificImportTable == "")
                              <td class="colalph" $(helpCursor)><span title="$(V_FRIFIL)">$(V_FFDESC)</span></td>
                          %endif
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)$(orderByVarBase)&amp;importTable=@dtw_rurlescseq(V_FRIFIL)&amp;recordType=@dtw_rurlescseq(V_FRRTYP)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                      </tr>

                  %else
                      <table $(contentTable)>
                          <tr><td>
                              %if (specificImportTable == "")
                                  <a href="javascript:selectRecordType('$(F_FRIFIL)','$(F_FFDESC)','$(F_FRRTYP)','$(F_FRDESC)')" title="Select Row Type">$(selectImageLrg)</a>
                              %else
                                  <a href="javascript:selectRecordType('$(F_FRRTYP)','$(F_FRDESC)')" title="Select Row Type">$(selectImageLrg)</a>
                              %endif
                          </td></tr>
                      </table>

                      <table $(contentTable)>
                          %if (specificImportTable == "")
                              <tr><td class="dsphdr">Import Table</td>
                                  @Format_Code(V_FRIFIL, F_FRIFIL)
                                  <td class="dspalph">$(V_FFDESC) $(F_FRIFIL)</td></tr>
                          %endif

                          <tr><td class="dsphdr">Row Type</td>
                              <td class="dspalph">$(V_FRRTYP)</td></tr>

                          <tr><td class="dsphdr">Description</td>
                              <td class="dspalph">$(V_FRDESC)</td></tr>

                          <tr><td class="dsphdr">Primary Interface Table</td>
                              @Format_Code(V_FRMFIL, F_FRMFIL)
                              <td class="dspalph">$(V_MFDESC) $(F_FRMFIL)</td></tr>
                      </table>
                  %endif
              %}
          </table>
      %if (moreInfo != "Y")	
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
      %endif	   	
  %}
%}

%FUNCTION(dtw_sql) Process_Select_Key (IN  CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("FRIMKY=$(importKey) and FRIFIL='$(passedImportTable)'", "SYMIRT", "CHAR(COUNT(*))", recordTypeCount)

      <fieldset class="legendBody">
          <legend class="legendTitle">Key</legend>
          <table $(contentTable)>
              <tr>
                  %if (recordTypeCount > "1")
                      @Format_Column_Header("FRDESCU",  "Row Type")
                  %endif
                  @Format_Column_Header("MFDESCU", "Interface Table")
                  @Format_Column_Header("parentMFDESCU", "Parent Interface Table")
                  @Format_Column_Header("", "Key Position/<br>Placement")
                  @Format_Column_Header("", "Key Length")
              </tr>

              @dtw_assign(test_FKIFIL, "")
              @dtw_assign(test_FKRTYP, "")
              @dtw_assign(test_FKMFIL, "")
              @dtw_assign(test_FKPFIL, "")

              %ROW{
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      %if (test_FKIFIL!=V_FKIFIL || test_FKRTYP!=V_FKRTYP || test_FRDESC!=V_FRDESC || test_FKMFIL!=V_FKMFIL || test_FKPFIL!=V_FKPFIL)
                          @dtw_assign(test_FKIFIL, V_FKIFIL)
                          @dtw_assign(test_FKRTYP, V_FKRTYP)
                          @dtw_assign(test_FKMFIL, V_FKMFIL)
                          @dtw_assign(test_FKPFIL, V_FKPFIL)
                          %if (recordTypeCount > "1")
                              <td class="colalph" $(helpCursor)><span title="$(V_FKRTYP)">$(V_FRDESC)</span></td>
                          %endif
                          <td class="colalph" $(helpCursor)><span title="$(V_FKMFIL)">$(V_MFDESC)</span></td>
                          <td class="colalph" $(helpCursor)><span title="$(V_FKPFIL)">$(V_parentMFDESC)</span></td>
                      %else
                          %if (recordTypeCount > "1")
                              <td class="colnmbr">&nbsp;</td>                                      	
                          %endif
                          <td class="colnmbr">&nbsp;</td>                                      	
                          <td class="colalph">&nbsp;</td>
                      %endif
                      <td class="colnmbr">$(V_FKKYPS)</td>                                      	
                      <td class="colnmbr">$(V_FKKYLN)</td>                                      	
                  </tr>
              %}
          </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Process_Select_Template (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "CHAR(FHMPKY)", V_FHMPKY)
      @RtvFldDesc("FFIMKY=$(importKey) and FFIFIL='$(passedImportTable)'", "SYMITB", "char(Count(distinct FFFIXF))", placementCount)
      @RtvFldDesc("FRIMKY=$(importKey) and FRIFIL='$(passedImportTable)'", "SYMIRT", "CHAR(COUNT(*))", recordTypeCount)
      @RtvFldDesc("FDIMKY=$(importKey) and FDIFIL='$(passedImportTable)' and (FDXIFL<>' ' or FDXREF<>' ') ", "SYMITP", "CHAR(COUNT(*))", xrefCount)
      %if (placementCount > "1")
          @dtw_assign(fixedFormat, "Y")
      %elif (placementCount == "1")
          @RtvFldDesc("FFIMKY=$(importKey) and FFIFIL='$(passedImportTable)'", "SYMITB", "distinct FFFIXF", fixedFormat)
      %else
          @dtw_assign(fixedFormat, "")
      %endif

      <fieldset class="legendBody">
          <legend class="legendTitle">Template</legend>
          <table $(contentTable)>

              @dtw_assign(interfaceTable, "")

              <tr>
                  @Format_Column_Header("", "Interface Table")
                  @Format_Column_Header("", "Column")
                  @Format_Column_Header("", "Description")
                  @Format_Column_Header("", "Note")
                  %if (recordTypeCount > "1")
                      @Format_Column_Header("", "Row Type")
                  %endif
                  @Format_Column_Header("", "Column Type")
                  %if (placementCount > "1")
                      @Format_Column_Header("", "Position/<br>Placement")
                  %elif (fixedFormat == "Y")
                      @Format_Column_Header("", "Position")
                  %else
                      @Format_Column_Header("", "Placement")
                  %endif
                  %if (fixedFormat == "Y")
                      @Format_Column_Header("", "Column Length")
                  %endif
                  @Format_Column_Header("", "Implied Decimal Point")
                  @Format_Column_Header("", "Decimal Precision")
                  %if (xrefCount > "0")
                      @Format_Column_Header("", "Cross Reference")
                  %endif
                  @Format_Column_Header("", "Map Function")
                  @Format_Column_Header("", "Default Logic For Mapped")
                  @Format_Column_Header("", "Value")
                  @Format_Column_Header("", "Reverse Sign")
                  @Format_Column_Header("", "Date Format")
                  @Format_Column_Header("", "Period Format")
                  @Format_Column_Header("", "Time Format")
              </tr>

              %ROW{
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colalph" $(helpCursor)><span title="$(V_FDMFIL)">$(V_MFDESC)</span></td>
                      <td class="colalph">$(V_FDMFLD)</td>
                      <td class="colalph">$(V_MDDESC)</td>
                      %if (V_MDNOTE != "")
                          <td class="colcode" $(helpCursor)><span title="$(V_MDNOTE)">Y</span></td>                                      	
                      %else
                          <td class="colalph">&nbsp;</td>                                      	
                      %endif
                      %if (recordTypeCount > "1")
                          <td class="colalph" $(helpCursor)><span title="$(V_FDRTYP)">$(V_FRDESC)</span></td>
                      %endif
                      <td class="colalph">$(V_FDFLDT)</td>
                      <td class="colnmbr">$(V_FDFLPL)</td>
                      %if (fixedFormat == "Y")
                          <td class="colnmbr">$(V_FDLNGT)</td>
                      %endif
                      <td class="colcode">$(V_FDIDEC)</td>
                      <td class="colnmbr">$(V_FDDECM)</td>
                      %if (xrefCount > "0")
                          <td class="colalph">$(V_FDXREF) $(V_FDXIFL)</td>
                      %endif
                      <td class="colalph">$(V_FDMFNC)</td>
                      <td class="colalph">$(V_FDDFMP)</td>
                      <td class="colalph">$(V_FDVALU)</td>
                      <td class="colalph">$(V_FDANAB)</td>
                      <td class="colalph">$(V_FDDTFM)</td>
                      <td class="colalph">$(V_FDPDFM)</td>
                      <td class="colalph">$(V_FDTMFM)</td>
                  </tr>
              %}
          </table>
      </fieldset>
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "FRDESCU,FRIFIL")
      @DTW_ASSIGN(orderByDisplay, "Description, Import Table")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"

  %if (sequence == "Description")
      %if (orderBy == "FRDESCU,FRRTYP")
          @DTW_ASSIGN(orderBy, "FRDESCU DESC,FRRTYP")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Row Type")
      %else
          @DTW_ASSIGN(orderBy, "FRDESCU,FRRTYP")
          @DTW_ASSIGN(orderByDisplay, "Description, Row Type")
      %endif
  %elif (sequence == "RowType")
      %if (orderBy == "FRRTYP,FRIFIL")
          @DTW_ASSIGN(orderBy, "FRRTYP DESC,FRIFIL")
          @DTW_ASSIGN(orderByDisplay, "Row Type (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FRRTYP,FRIFIL")
          @DTW_ASSIGN(orderByDisplay, "Row Type")
      %endif
  %elif (sequence == "InterfaceTable")
      %if (orderBy == "MFDESCU,FRIFIL")
          @DTW_ASSIGN(orderBy, "MFDESCU DESC,FRIFIL")
          @DTW_ASSIGN(orderByDisplay, "Interface Table (descending), Row Type")
      %else
          @DTW_ASSIGN(orderBy, "MFDESCU,FRIFIL")
          @DTW_ASSIGN(orderByDisplay, "Interface Table, Row Type")
      %endif
  %elif (sequence == "ImportTable")
      %if (orderBy == "FFDESCU,FRRTYP")
          @DTW_ASSIGN(orderBy, "FFDESCU DESC,FRRTYP")
          @DTW_ASSIGN(orderByDisplay, "Import Table (descending), Row Type")
      %else
          @DTW_ASSIGN(orderBy, "FFDESCU,FRRTYP")
          @DTW_ASSIGN(orderByDisplay, "Import Table, Row Type")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          @dtw_assign(formName, "Search")
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "MAPIMPORTRECTYPESEARCH")
                  <td>
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Row Type</td>
                              @dtw_assign(operNbr, "operRecType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchRecType" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">Primary Interface Table</td>
                              @dtw_assign(operNbr, "operInterfaceTable")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchInterfaceTable" size="15" maxlength="50"></td>
                          </tr>

                          %if (passedImportTable == "")
                              <tr><td class="dsphdr">Import Table</td>
                                  @dtw_assign(operNbr, "operImportTable")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchImportTable" size="15" maxlength="50"></td>
                              </tr>
                          %endif

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDesc.focus();
                          </script>
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("FRDESCU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("FRRTYP", "Row Type", $(srchRecType), "U", operRecType, "A")
  @Build_WildCard ("MFDESCU", "Primary Interface Table", $(srchInterfaceTable), "U", operInterfaceTable, "A")
  @Build_WildCard ("FFDESCU", "Import Table", $(srchImportTable), "U", operImportTable, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}