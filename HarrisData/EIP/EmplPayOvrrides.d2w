%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "Employee.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title 	           = "Employee Pay Transaction Entry"
  d2wName                 = "EmplPayOvrrides.d2w"
  d2wVarBase              = "$(genericVarBase)$(employeeVarBase)&amp;prCKTYPE=@dtw_rurlescseq(prCKTYPE)&amp;prCKSEPC=@dtw_rurlescseq(prCKSEPC)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "99"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  programName             = "HPRSBE"
  caller                  = "ovrrides  "
  rowIndexNext	           = "1"
  totalPages	           = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
  @dtw_replace(workURL, "@@prCKTYPE", "@dtw_rurlescseq(prCKTYPE)", "1", "a", workURL)
  @dtw_replace(workURL, "@@prCKSEPC", "@dtw_rurlescseq(prCKSEPC)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(applicationID, "PR")
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
          <html>
              <head>
	           %INCLUDE "$(headInclude)"
                  @dtw_assign(formName, "Chg")
                  <script type="text/javascript">
                      %INCLUDE "dateedit.icl"
                      %INCLUDE "Menu.js"
                      %INCLUDE "numedit.icl"
                      %INCLUDE "NewWindowOpen.icl"
                      %INCLUDE "CheckEnterChg.icl"
                      function validate(chgForm) {
                      if (editNum(document.Chg.CEFP, 3, 1) &&
                          editNum(document.Chg.CESP, 2, 3) &&
                          editNum(document.Chg.BEFP, 3, 1) &&
                          editNum(document.Chg.BESP, 2, 3))
                      return true;
                  }
                  </script>
                  %INCLUDE "$(genericHead)"
              </head>
              <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
                  <!-- Start Of Banner Code -->
                  %INCLUDE "banner.icl"
                  <!-- End Of Banner Code -->
                  <table $(baseTable)>
                      <tr valign="top">
                          @dtw_assign(pageID, "EMPLPAYOVRRIDES")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                          <td class="content">
      %{Summary Pay query%}
                              @dtw_assign(stmtSQL, "")
                              @dtw_concat(stmtSQL, "SELECT * FROM PRCHCK", stmtSQL)
                              @dtw_concat(stmtSQL, " WHERE CKCOMP=$(prCompany) and CKFACL=$(prFacility) and CKEMPL=$(prEmployee) and CKTYPE='$(prCKTYPE)' and CKSEPC='$(prCKSEPC)'", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              @Check_Query(profileHandle, dataBaseID, stmtSQL)
                          </td>
                      </tr>
                  </table>
                  <!-- Start Of Trailer Code -->
                  %INCLUDE "trailer.icl"
                  <!-- End Of Trailer Code -->
              </body>
          </html>
  %endif
%}

%FUNCTION(dtw_sql) Check_Query (IN  CHAR(64) profileHandle,
				     CHAR(2)   dataBaseID,
                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

   %REPORT{
      %INCLUDE "ProgSecurityTestView.icl"
      %if (pgmOptAuth=="F")
          %INCLUDE "ProgSecurityError.icl"
      %endif
      @In_Process(profileHandle, dataBaseID, INPROCESS)

      %if (INPROCESS != "Y")
          %INCLUDE "ErrorDisplay.icl"
      %endif
      %if (INPROCESS == "Y")
          <table $(contentTable)>
              <tr><td class="colalph"> %include "InProcessMessage.icl" </td></tr>
          </table>
      %endif
      @dtw_assign(sec_03, "N")
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
          <tr><td><h2> $(F_EmpName)</h2></td></tr>
      </table>
      $(hrTagAttr)
      %INCLUDE "ErrorDisplay.icl"
      @DateTodayCYMD(today)
      @dtw_substr(today,"1","3",cyr)
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          %ROW {
              %if (errFound != "")
                  @dtw_assign(focusField, "")
                  @EdtVarErr(profileHandle, typeValue, edtVar)
                  @ErrVarErr(profileHandle, typeError, errVar)
                  @DecatErr_Field("@@type", "checktype")     @dtw_assign(Err_checktype, fieldValue)
                  @DecatErr_Field("@@stid", "STID")          @dtw_assign(Err_CKSTID, fieldValue)
                  @DecatErr_Field("@@suid", "SUID")          @dtw_assign(Err_CKSUID, fieldValue)
                  @DecatErr_Field("@@swid", "SWID")          @dtw_assign(Err_CKSWID, fieldValue)
                  @DecatErr_Field("@@sdid", "SDID")          @dtw_assign(Err_CKSDID, fieldValue)
                  @DecatErr_Field("@@lid1", "LID1")          @dtw_assign(Err_CKLID1, fieldValue)
                  @DecatErr_Field("@@lid2", "LID2")          @dtw_assign(Err_CKLID2, fieldValue)
                  @DecatErr_Field("@@avsc", "AVSC")          @dtw_assign(Err_CKAVSC, fieldValue)
                  @DecatErr_Field("@@assc", "ASSC")          @dtw_assign(Err_CKASSC, fieldValue)
                  @DecatErr_Field("@@acms", "ACMS")          @dtw_assign(Err_CKACMS, fieldValue)
                  @DecatErr_Field("@@cefp", "CEFP")          @dtw_assign(Err_CKCEFP, fieldValue)
                  @DecatErr_Field("@@cesp", "CESP")          @dtw_assign(Err_CKCESP, fieldValue)
                  @DecatErr_Field("@@befp", "BEFP")          @dtw_assign(Err_CKBEFP, fieldValue)
                  @DecatErr_Field("@@besp", "BESP")          @dtw_assign(Err_CKBESP, fieldValue)
                  @DecatErr_Field("@@tstp", "timeStamp")     @dtw_assign(Err_TSTP, fieldValue)

                  @Decat_Field("@@stid")   @dtw_assign(V_CKSTID, fieldValue)
                  @Decat_Field("@@suid")   @dtw_assign(V_CKSUID, fieldValue)
                  @Decat_Field("@@swid")   @dtw_assign(V_CKSWID, fieldValue)
                  @Decat_Field("@@sdid")   @dtw_assign(V_CKSDID, fieldValue)
                  @Decat_Field("@@lid1")   @dtw_assign(V_CKLID1, fieldValue)
                  @Decat_Field("@@lid2")   @dtw_assign(V_CKLID2, fieldValue)
                  @Decat_Field("@@avsc")   @dtw_assign(V_CKAVSC, fieldValue)
                  @Decat_Field("@@assc")   @dtw_assign(V_CKASSC, fieldValue)
                  @Decat_Field("@@acms")   @dtw_assign(V_CKACMS, fieldValue)
                  @Decat_Field("@@cefp")   @dtw_assign(V_CKCEFP, fieldValue)
                  @Decat_Field("@@cesp")   @dtw_assign(V_CKCESP, fieldValue)
                  @Decat_Field("@@befp")   @dtw_assign(V_CKBEFP,  fieldValue)
                  @Decat_Field("@@besp")   @dtw_assign(V_CKBESP, fieldValue)
                  @Decat_Field("@@tstp")   @dtw_assign(V_CKTSTP, fieldValue)

                  @dtw_assign(errFound, "")
                  @dtw_assign(focusField, "STID")
              %else
                  @DateInputFromCYMD(V_CKWKDT)
                  @dtw_assign(focusField, "STID")
                  @dtw_assign(V_CKCEFP, "@dtw_rformat(@dtw_rmultiply(V_CKCEFP, "100"),"","1")")
                  @dtw_assign(V_CKCESP, "@dtw_rformat(@dtw_rmultiply(V_CKCESP, "100"),"","3")")
                  @dtw_assign(V_CKBEFP, "@dtw_rformat(@dtw_rmultiply(V_CKBEFP, "100"),"","1")")
                  @dtw_assign(V_CKBESP, "@dtw_rformat(@dtw_rmultiply(V_CKBESP, "100"),"","3")")
              %endif

              <table $(contentTable)>
                  %if (V_CKRCCD != "H")
                      <tr><td class="dsphdr">Check Number</td>
                          <td class="dspalph">$(V_CKCKNO)</td>
                      </tr>
                      @DateFromCYMD(V_CKCKDT)
                      <tr><td class="dsphdr">Check Date</td>
                          <td class="dspalph">$(V_CKCKDT)</td>
                      </tr>
                  %endif
                  %if (V_CKRCCD == "H")
                      @dtw_assign(checkType, "Regular")
                  %elif (V_CKRCCD == "V")
                      @dtw_assign(checkType, "Void")
                  %elif (V_CKRCCD == "M")
                      @dtw_assign(checkType, "Manual/History Adjustment")
                  %elif (V_CKRCCD == "4")
                      @dtw_assign(checkType, "Non Elective Contribution")
                  %endif

                  @SetTextOvr(Err_checktype)
                  <tr><td class="dsphdr"><span $(textOvr)>Check Type</span></td>
                      <td class="dspalph">$(checkType)</td>
                  </tr>
                  @DspErrMsg(Err_checktype)

                  %if (V_CKSEPC != "")
                      <tr><td class="dsphdr">Separate Check Code</td>
                          <td class="dspalph">$(V_CKSEPC)</td>
                      </tr>
                  %endif
                  
                  @SetTextOvr(Err_TSTP)
                  <tr><td class="dsphdr"><span $(textOvr)>.</span></td>
                      <td><input name="timeStamp" type="hidden" value="$(V_CKTSTP)"></td>
                  </tr>
                  @DspErrMsg(Err_TSTP)
                  
                  
              </table>
              $(hrTagAttr)
              %INCLUDE "RequiredField.icl"
              <a name="overrides"></a>
              <fieldset class="legendBody">
              <legend class="legendTitle"> Tax Overrides/Accruals </legend>

              <table $(contentTable)>
                  @RtvFldDesc("STID='$(V_CKSTID)'", "PRSTID", "STDESC", fieldDesc)
                  @SetTextOvr(Err_CKSTID)
                  <tr><td class="dsphdr"><span $(textOvr)>State Tax ID</span></td>
                      <td class="inputalph"><input name="STID" type="text" value="$(V_CKSTID)" size="3" maxlength="2"><a href="$(homeURL)$(cGIPath)StateSearchHR.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=STID&amp;fldDesc=STIDDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="STIDDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_CKSTID)

                  @RtvFldDesc("STID='$(V_CKSUID)'", "PRSTID", "STDESC", fieldDesc)
                  @SetTextOvr(Err_CKSUID)
                  <tr><td class="dsphdr"><span $(textOvr)>SUI ID</span></td>
                      <td class="inputalph"><input name="SUID" type="text" value="$(V_CKSUID)" size="3" maxlength="2"><a href="$(homeURL)$(cGIPath)StateSearchHR.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=SUID&amp;fldDesc=SUIDDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="SUIDDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_CKSUID)

                  @RtvFldDesc("STID='$(V_CKSWID)'", "PRSTID", "STDESC", fieldDesc)
                  @SetTextOvr(Err_CKSWID)
                  <tr><td class="dsphdr"><span $(textOvr)>SWC ID</span></td>
                      <td class="inputalph"><input name="SWID" type="text" value="$(V_CKSWID)" size="3" maxlength="2"><a href="$(homeURL)$(cGIPath)StateSearchHR.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=SWID&amp;fldDesc=SWIDDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="SWIDDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_CKSWID)

                  @RtvFldDesc("STID='$(V_CKSDID)'", "PRSTID", "STDESC", fieldDesc)
                  @SetTextOvr(Err_CKSDID)
                  <tr><td class="dsphdr"><span $(textOvr)>SDI ID</span></td>
                      <td class="inputalph"><input name="SDID" type="text" value="$(V_CKSDID)" size="3" maxlength="2"><a href="$(homeURL)$(cGIPath)SDISearch.d2w/ENTRY$(genericVarBase)&amp;prCompany=@dtw_rurlescseq(prCompany)&amp;prFacility=@dtw_rurlescseq(prFacility)&amp;docName=Chg&amp;fldName=SDID&amp;fldDesc=SDIDDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="SDIDDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_CKSDID)

                  @DateTodayCYMD(today)
                  @dtw_assign(currentyear, "@dtw_rsubstr(today, "1", "3")")
                  @RtvFldDesc("TLYEAR=$(currentyear) and TLID='$(V_CKLID1)'", "PRLTAX", "TLLCNM", fieldDesc)
                  @SetTextOvr(Err_CKLID1)
                  <tr><td class="dsphdr"><span $(textOvr)>Local Tax ID 1</span></td>
                      <td class="inputalph"><input name="LID1" type="text" value="$(V_CKLID1)" size="3" maxlength="2"><a href="$(homeURL)$(cGIPath)LocalIDSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=LID1&amp;fldDesc=LocDesc1" onclick="$(searchWinVar)"> $(searchImage) </a><input name="LocDesc1" value="$(fieldDesc)" type="text" size="20" disabled></td>
                  </tr>
                  @DspErrMsg(Err_CKLID1)

                  @RtvFldDesc("TLYEAR=$(currentyear) and TLID='$(V_CKLID2)'", "PRLTAX", "TLLCNM", fieldDesc)
                  @SetTextOvr(Err_CKLID2)
                  <tr><td class="dsphdr"><span $(textOvr)>Local Tax ID 2</span></td>
                      <td class="inputalph"><input name="LID2" type="text" value="$(V_CKLID2)" size="3" maxlength="2"><a href="$(homeURL)$(cGIPath)LocalIDSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=LID2&amp;fldDesc=LocDesc2" onclick="$(searchWinVar)"> $(searchImage) </a><input name="LocDesc2" value="$(fieldDesc)" type="text" size="20" disabled></td>
                  </tr>
                  @DspErrMsg(Err_CKLID2)

                  <tr><td class="colhdr"> Accrual Type</td>
                      <td class="colhdr"> Process</td></tr>

                  @SetTextOvr(Err_CKAVSC)
                  <tr><td class="dsphdr"><span $(textOvr)>Vacation</span></td>
     	       	      @dtw_tb_rows(yn01Table, maxRows)
                     @dtw_assign(x, "1")
                     %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_CKAVSC) && (x < maxRows))
                      {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "AVSC", "2", "1", "N", "", x, "1")</td>	
                  </tr>
                  @DspErrMsg(Err_CKAVSC)

                  @SetTextOvr(Err_CKASSC)
                  <tr><td class="dsphdr"><span $(textOvr)>Sick</span></td>
                     @dtw_tb_rows(yn01Table, maxRows)
                     @dtw_assign(x, "1")
                     %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_CKASSC) && (x < maxRows))
                      {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "ASSC", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_CKASSC)

                  @SetTextOvr(Err_CKACMS)
                  <tr><td class="dsphdr"><span $(textOvr)>Miscellaneous</span></td>	
                     @dtw_tb_rows(yn01Table, maxRows)
                     @dtw_assign(x, "1")
                     %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_CKACMS) && (x < maxRows))
                      {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "ACMS", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_CKACMS)

                  <tr><td class="colhdr"> Comm/Bonus Withholding</td></tr>
    	   		
                  @SetTextOvr(Err_CKCEFP)
                  <tr><td class="dsphdr"><span $(textOvr)>FIT Commission W/H Percent</span></td>
                      <td class="inputnmbr"><input name="CEFP" type="text" value="$(V_CKCEFP)" size=4 maxlength=4</td>
                  </tr>
                  @DspErrMsg(Err_CKCEFP)

                  @SetTextOvr(Err_CKBEFP)
                  <tr><td class="dsphdr"><span $(textOvr)>FIT Bonus W/H Percent</span></td>
                      <td class="inputnmbr"><input name="BEFP" type="text" value="$(V_CKBEFP)" size=4 maxlength=4</td>
                  </tr>
                  @DspErrMsg(Err_CKBEFP)

                  @SetTextOvr(Err_CKCESP)
                  <tr><td class="dsphdr"><span $(textOvr)>SIT Commission W/H Percent</span></td>
                      <td class="inputnmbr"><input name="CESP" type="text" value="$(V_CKCESP)" size=6 maxlength=6</td>
                  </tr>
                  @DspErrMsg(Err_CKCESP)

                  @SetTextOvr(Err_CKBESP)
                  <tr><td class="dsphdr"><span $(textOvr)>SIT Bonus W/H Percent</span></td>
                      <td class="inputnmbr"><input name="BESP" type="text" value="$(V_CKBESP)" size=6 maxlength=6</td>
                  </tr>
                  @DspErrMsg(Err_CKBESP)
					<tr><td><input name="timeStamp" type="hidden" value="$(V_CKTSTP)"></td></tr>
              %}
              </table>
              </fieldset>
              <script TYPE="text/javascript">
                  document.Chg.$(focusField).focus();
              </script>
          </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64) profileHandle,
                                               INOUT CHAR(2) dataBaseID,
                                               INOUT CHAR(1) maintenanceCode,
                                               INOUT CHAR(1) errFound,
                                               INOUT CHAR(32000) edtVar,
                                               INOUT CHAR(32000) errVar)


 {%EXEC {HPRPAY_W.PGM %}
%}

%HTML(OVERRIDE) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (sec_02 == "N")
      %INCLUDE "ProgSecurityError.icl"
  %else
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
%HTML(UPDATE) {
  %INCLUDE "setLibraryList.icl"
  @DateTodayCYMD(today)
  @dtw_substr(today,"1","3",cyr)
  @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
  @SUI_Query(profileHandle, dataBaseID, prCompany, prFacility, suiTable)
     @dtw_tb_insertrow(suiTable, "0", "1")
     @dtw_tb_setv(suiTable, "None", "1", "2")
  @LocalTax_Query(profileHandle, dataBaseID, cyr, localtaxtable)
     @dtw_tb_insertrow(localtaxtable, "0", "1")
     @dtw_tb_setv(localtaxtable, "", "1", "1")
  @Set_SQL(stmtSQL)
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(STID)
  @dtw_mUPPERCASE(SUID)
  @dtw_mUPPERCASE(SWID)
  @dtw_mUPPERCASE(SDID)
  @dtw_mUPPERCASE(LID1)
  @dtw_mUPPERCASE(LID2)
  @dtw_assign(CEFP,@dtw_rstrip(CEFP))
  @dtw_assign(CESP,@dtw_rstrip(CESP))
  @dtw_assign(BEFP,@dtw_rstrip(BEFP))
  @dtw_assign(BESP,@dtw_rstrip(BESP))


  @dtw_assign(edtVar, "")
  @Concat_Field("@@call", caller)
  @Concat_Field("@@comp", prCompany)
  @Concat_Field("@@facl", prFacility)
  @Concat_Field("@@empl", prEmployee)
  @Concat_Field("@@type", prCKTYPE)
  @Concat_Field("@@sepc", prCKSEPC)
  @Concat_Field("@@rccd", "H")
  @Concat_Field("@@stid", STID)
  @Concat_Field("@@suid", SUID)
  @Concat_Field("@@swid", SWID)
  @Concat_Field("@@sdid", SDID)
  @Concat_Field("@@lid1", LID1)
  @Concat_Field("@@lid2", LID2)
  @Concat_Field("@@avsc", AVSC)
  @Concat_Field("@@assc", ASSC)
  @Concat_Field("@@acms", ACMS)
  @Concat_Field("@@cefp", CEFP)
  @Concat_Field("@@cesp", CESP)
  @Concat_Field("@@befp", BEFP)
  @Concat_Field("@@besp", BESP)
  @Concat_Field("@@tstp", timeStamp)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
    %if (maintenanceCode == "A")
    @Decat_Field("@@sepc")   @dtw_assign(prCKSEPC, fieldValue)
    %endif
    @Format_ConfMsg_Desc(maintenanceCode, "Sep Ck", $(prCKSEPC), "Check Type", $(checkType), "", "", confMessage)
    %if (fromD2w == "")
        <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)emplpaytran.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
    %else
        <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
    %endif
  %else
    @EdtVarErr(profileHandle, typeValue, edtVar)
    @ErrVarErr(profileHandle, typeError, errVar)
    <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/OVERRIDE$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}