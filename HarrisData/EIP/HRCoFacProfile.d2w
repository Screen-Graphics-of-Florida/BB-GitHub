%FUNCTION(dtw_sql) CoFac_Profile_FicaFui (IN CHAR(64)    profileHandle,
                                             CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="cofacficafui"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %ROW{
              @Format_Nbr("@dtw_rmultiply(V_CFRFCR, "100")", F_CFRFCR, "5", $(pctEditCode), "Y", "", "")
              <tr><td class="dsphdr">Employer FICA OASDI Tax Percent</td>
                  <td class="dspalph">$(F_CFRFCR)</td>
              </tr>

              @Format_Nbr("@dtw_rmultiply(V_CFEFCR, "100")", F_CFEFCR, "5", $(pctEditCode), "Y", "", "")
              <tr><td class="dsphdr">Employee FICA OASDI Tax Percent</td>
                  <td class="dspalph">$(F_CFEFCR)</td>
              </tr>

              @Format_Nbr(V_CFFICB, F_CFFICB, "2", $(amtEditCode), "", "", "")
              <tr><td class="dsphdr">FICA OASDI Maximum Taxable Income</td>
                  <td class="dspalph">$(F_CFFICB)</td>
              </tr>

              @Format_Nbr("@dtw_rmultiply(V_CFRHIR, "100")", F_CFRHIR, "5", $(pctEditCode), "Y", "", "")
              <tr><td class="dsphdr">Employer FICA HI Tax Percent</td>
                  <td class="dspalph">$(F_CFRHIR)</td>
              </tr>

              @Format_Nbr("@dtw_rmultiply(V_CFEHIR, "100")", F_CFEHIR, "5", $(pctEditCode), "Y", "", "")
              <tr><td class="dsphdr">Employee FICA HI Tax Percent</td>
                  <td class="dspalph">$(F_CFEHIR)</td>
              </tr>

              @Format_Nbr(V_CFHIB, F_CFHIB, "2", $(amtEditCode), "", "", "")
              <tr><td class="dsphdr">FICA HI Maximum Taxable Income</td>
                  <td class="dspalph">$(F_CFHIB)</td>
              </tr>

              @Format_Nbr("@dtw_rmultiply(V_CFFUIR, "100")", F_CFFUIR, "3", $(pctEditCode), "Y", "", "")
              <tr><td class="dsphdr">FUI Compensation Percent</td>
                  <td class="dspalph">$(F_CFFUIR)</td>
              </tr>

              @Format_Nbr(V_CFFUIB, F_CFFUIB, "2", $(amtEditCode), "", "", "")
              <tr><td class="dsphdr">FUI Compensation Maximum Wage</td>
                  <td class="dspalph">$(F_CFFUIB)</td>
              </tr>
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) CoFac_Profile_Cobra (IN CHAR(64)    profileHandle,
                                             CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="cofaccobra"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %ROW{
              <tr><td class="dsphdr">Statement Type</td>
                  @RtvFldDesc("FLTYPE='COBRASTMNT' and FLVALU='$(V_CFSTCD)'", "SYFLAG", "FLDESC", syFlagDesc)
                  @Format_Code(V_CFSTCD, F_CFSTCD)
                  <td class="dspalph">$(syFlagDesc)</td>
                  <td class="dspalph">$(F_CFSTCD)</td>
              </tr>
              <tr><td class="dsphdr">Premium Period Start Day</td>
                  <td class="dspalph">$(V_CFDAY)</td>
              </tr>
              <tr><td class="dsphdr">Print Invoice NNN Days<br> Before Premium Period</td>
                  <td class="dspalph">$(V_CFCUT)</td>
              </tr>
              <tr><td class="dsphdr">Days Until Due</td>
                  <td class="dspalph">$(V_CFDUE)</td>
              </tr>
              <tr><td class="dsphdr">Grace Period Days</td>
                  <td class="dspalph">$(V_CFGRAC)</td>
              </tr>
              <tr><td class="dsphdr">Retain Detail Transaction History</td>
                  @RtvYNDesc($(V_CFRDTH), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Manual General Notice</td>
                  @RtvYNDesc($(V_CFMGN), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Manual Continuation Notice</td>
                  @RtvYNDesc($(V_CFMCN), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Manual Conversion Notice</td>
                  @RtvYNDesc($(V_CFMVN), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) CoFac_Profile_Deductions (IN CHAR(64)    profileHandle,
                                             CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="cofacdeductions"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  <th class="colhdr">Deduction<br>Number</th>
                  <th class="colhdr">Deduction <br> Name</th>
                  <th class="colhdr">Cycle</th>
                  <th class="colhdr">G/L Account</th>
                  <th class="colhdr">Priority</th>
                  <th class="colhdr">Accumulate</th>
                  <th class="colhdr">Full Amt<br> Only</th>
                  <th class="colhdr">Take On<br>Sep Check</th>
                  <th class="colhdr">Calc<br>Method</th>
                  <th class="colhdr">Long Description</th>
              </tr>
          %endif

          %ROW{
              @dtw_assign(programName6, "HPRVDM")
              @pgmOptSecurity(profileHandle, dataBaseID, programName6, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
              @dtw_assign(VDM_05, sec_05)

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colcode">$(V_CDDDNO)</td>
                  <td class="colalph">$(V_HVDDNM)</td>
                  
                  <td class="colcode">$(V_CDDCYC)</td>
                  @Format_Acct("$(V_CDGLAC)", "$(V_CDGLSB)", "", F_AcctSub)
                  <td class="colalph">$(F_AcctSub)</td>
                  <td class="colcode">$(V_HVPRTY)</td>
                  @RtvYNDesc($(V_HVACUM), syFlagDesc)
                  <td class="colcode">$(syFlagDesc)</td>
                  @RtvYNDesc($(V_HVFAO), syFlagDesc)
                  <td class="colcode">$(syFlagDesc)</td>
                  @RtvYNDesc($(V_HVTOSC), syFlagDesc)
                  <td class="colcode">$(syFlagDesc)</td>
                  <td class="colcode">$(V_HVMTHD)</td>
                  <td class="colalph">$(V_HVLDSC)</td>
              </tr>
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) CoFac_Profile_LiabAccts (IN CHAR(64)    profileHandle,
                                                    CHAR(2)     dataBaseID,
                                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="cofacliabilityaccts"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %endif

          %ROW{
              <tr><td class="dspalph">Cash And Accruals</td></tr>
              <tr><td class="dsphdr">Cash</td>
                  @Format_Acct("$(V_LACSHA)", "$(V_LACSHS)", "F", F_AcctSub)
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dsphdr">Payroll Payable</td>
                  @Format_Acct("$(V_LAAPPA)", "$(V_LAAPPS)", "F", F_AcctSub)
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dsphdr">Accrued Vacation Payable</td>
                  @Format_Acct("$(V_LAAVPA)", "$(V_LAAVPS)", "F", F_AcctSub)
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dsphdr">Accrued Sick Payable</td>
                  @Format_Acct("$(V_LAASPA)", "$(V_LAASPS)", "F", F_AcctSub)
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dsphdr">Accrued Miscellaneous Payable</td>
                  @Format_Acct("$(V_LAMSPA)", "$(V_LAMSPS)", "F", F_AcctSub)
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dsphdr">EOP Accrued Wages</td>
                  @Format_Acct("$(V_LAEPWA)", "$(V_LAEPWS)", "F", F_AcctSub)
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dsphdr">EOP Accrued Employer Taxes</td>
                  @Format_Acct("$(V_LAEPTA)", "$(V_LAEPTS)", "F", F_AcctSub)
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dsphdr">Charge Tips Payable</td>
                  @Format_Acct("$(V_LACTPA)", "$(V_LACTPS)", "F", F_AcctSub)
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dsphdr">Charge Tips Accrual</td>
                  @Format_Acct("$(V_LACTAA)", "$(V_LACTAS)", "F", F_AcctSub)
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dspalph">Employer Liabilities</td></tr>
              <tr><td class="dsphdr">FICA Taxes Payable</td>
                  @Format_Acct("$(V_LAEFIA)", "$(V_LAEFIS)", "F", F_AcctSub)
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dsphdr">Federal Unemployment Insurance Payable</td>
                  @Format_Acct("$(V_LAEUCA)", "$(V_LAEUCS)", "F", F_AcctSub)
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dsphdr">State Disability Insurance Payable</td>
                  @Format_Acct("$(V_LAESDA)", "$(V_LAESDS)", "F", F_AcctSub)
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dsphdr">State Workers' Compensation Payable</td>
                  @Format_Acct("$(V_LAEWCA)", "$(V_LAEWCS)", "F", F_AcctSub)
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dsphdr">Local Taxes Payable</td>
                  @Format_Acct("$(V_LAELTA)", "$(V_LAELTS)", "F", F_AcctSub)
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>

              <tr><td class="dspalph">Employee Liabilities</td></tr>
              <tr><td class="dsphdr">FICA Taxes Payable</td>
                  @Format_Acct("$(V_LAWFIA)", "$(V_LAWFIS)", "F", F_AcctSub)
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dsphdr">Federal Taxes Payable</td>
                  @Format_Acct("$(V_LAWFTA)", "$(V_LAWFTS)", "F", F_AcctSub)
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dsphdr">Earned Income Credit</td>
                  @Format_Acct("$(V_LAEICA)", "$(V_LAEICS)", "F", F_AcctSub)
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dsphdr">State Taxes Payable</td>
                  @Format_Acct("$(V_LAWSTA)", "$(V_LAWSTS)", "F", F_AcctSub)
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dsphdr">State Disability Insurance Payable</td>
                  @Format_Acct("$(V_LAWSDA)", "$(V_LAWSDS)", "F", F_AcctSub)
                  <td class="dspnmbr">$(returnFldDesc)</td>
