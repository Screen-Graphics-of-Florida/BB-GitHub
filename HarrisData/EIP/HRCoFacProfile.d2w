%FUNCTION(dtw_sql) CoFac_Profile_PayCodeDefaults (IN CHAR(64)    profileHandle,
                                                       CHAR(2)     dataBaseID,
                                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="cofacpaycodedefaults"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %ROW{
              <colgroup>
                  <col width="20%">
                  <col width="5%">
                  <col width="25%">
