                      <td class="dspalph">$(payCodeDesc)</td>
                  </tr>
                  <tr><td class="dsphdr">Other Taxable</td>
                      <td class="dspalph">$(V_CFHOTC)</td>
                      @RtvFldDesc("C2COMP=$(prCompany) and C2FACL=$(prFacility) and C2CODE='$(V_CFHOTC)'", "PRCODE", "C2DESC", payCodeDesc)
                      <td class="dspalph">$(payCodeDesc)</td>
                      <td class="dspalph">$(V_CFSOTC)</td>
                      @RtvFldDesc("C2COMP=$(prCompany) and C2FACL=$(prFacility) and C2CODE='$(V_CFSOTC)'", "PRCODE", "C2DESC", payCodeDesc)
                      <td class="dspalph">$(payCodeDesc)</td>
                  </tr>
                  <tr><td class="dsphdr">Nontaxable</td>
                      <td class="dspalph">$(V_CFHNTC)</td>
                      @RtvFldDesc("C2COMP=$(prCompany) and C2FACL=$(prFacility) and C2CODE='$(V_CFHNTC)'", "PRCODE", "C2DESC", payCodeDesc)
                      <td class="dspalph">$(payCodeDesc)</td>
                      <td class="dspalph">$(V_CFSNTC)</td>
                      @RtvFldDesc("C2COMP=$(prCompany) and C2FACL=$(prFacility) and C2CODE='$(V_CFSNTC)'", "PRCODE", "C2DESC", payCodeDesc)
                      <td class="dspalph">$(payCodeDesc)</td>
                  </tr>
                  <tr><td class="dsphdr">Commission</td>
                      <td class="dspalph">$(V_CFHCMC)</td>
                      @RtvFldDesc("C2COMP=$(prCompany) and C2FACL=$(prFacility) and C2CODE='$(V_CFHCMC)'", "PRCODE", "C2DESC", payCodeDesc)
                      <td class="dspalph">$(payCodeDesc)</td>
                      <td class="dspalph">$(V_CFSCMC)</td>
                      @RtvFldDesc("C2COMP=$(prCompany) and C2FACL=$(prFacility) and C2CODE='$(V_CFSCMC)'", "PRCODE", "C2DESC", payCodeDesc)
                      <td class="dspalph">$(payCodeDesc)</td>
                  </tr>
                  <tr><td class="dsphdr">Bonus</td>
                      <td class="dspalph">$(V_CFHBNC)</td>
                      @RtvFldDesc("C2COMP=$(prCompany) and C2FACL=$(prFacility) and C2CODE='$(V_CFHBNC)'", "PRCODE", "C2DESC", payCodeDesc)
                      <td class="dspalph">$(payCodeDesc)</td>
                      <td class="dspalph">$(V_CFSBNC)</td>
                      @RtvFldDesc("C2COMP=$(prCompany) and C2FACL=$(prFacility) and C2CODE='$(V_CFSBNC)'", "PRCODE", "C2DESC", payCodeDesc)
                      <td class="dspalph">$(payCodeDesc)</td>
                  </tr>
                  <tr><td class="dsphdr">Fringe</td>
                      <td class="dspalph">$(V_CFHFGC)</td>
                      @RtvFldDesc("C2COMP=$(prCompany) and C2FACL=$(prFacility) and C2CODE='$(V_CFHFGC)'", "PRCODE", "C2DESC", payCodeDesc)
                      <td class="dspalph">$(payCodeDesc)</td>
                      <td class="dspalph">$(V_CFSFGC)</td>
                      @RtvFldDesc("C2COMP=$(prCompany) and C2FACL=$(prFacility) and C2CODE='$(V_CFSFGC)'", "PRCODE", "C2DESC", payCodeDesc)
                      <td class="dspalph">$(payCodeDesc)</td>
                  </tr>
                  %if (V_CFHMWM != "")
                      <tr><td class="dsphdr">Minimum Wage Makeup</td>
                          <td class="dspalph">$(V_CFHMWM)</td>
                          @RtvFldDesc("C2COMP=$(prCompany) and C2FACL=$(prFacility) and C2CODE='$(V_CFHMWM)'", "PRCODE", "C2DESC", payCodeDesc)
                          <td class="dspalph">$(payCodeDesc)</td>
                      </tr>
                  %endif
                  %if (V_CFHCTC != "")
                      <tr><td class="dsphdr">Cash Tips</td>
                          <td class="dspalph">$(V_CFHCTC)</td>
                          @RtvFldDesc("C2COMP=$(prCompany) and C2FACL=$(prFacility) and C2CODE='$(V_CFHCTC)'", "PRCODE", "C2DESC", payCodeDesc)
                          <td class="dspalph">$(payCodeDesc)</td>
                      </tr>
                  %endif
                  %if (V_CFHGTC != "")
                      <tr><td class="dsphdr">Charge Tips</td>
                          <td class="dspalph">$(V_CFHGTC)</td>
                          @RtvFldDesc("C2COMP=$(prCompany) and C2FACL=$(prFacility) and C2CODE='$(V_CFHGTC)'", "PRCODE", "C2DESC", payCodeDesc)
                          <td class="dspalph">$(payCodeDesc)</td>
                      </tr>
                  %endif
                  %if (V_CFHGRC != "")
                      <tr><td class="dsphdr">Gross Receipts</td>
                          <td class="dspalph">$(V_CFHGRC)</td>
                          @RtvFldDesc("C2COMP=$(prCompany) and C2FACL=$(prFacility) and C2CODE='$(V_CFHGRC)'", "PRCODE", "C2DESC", payCodeDesc)
                          <td class="dspalph">$(payCodeDesc)</td>
                      </tr>
                  %endif
                  %if (V_CFHMLC != "")
                      <tr><td class="dsphdr">Meal Allowance</td>
                          <td class="dspalph">$(V_CFHMLC)</td>
                          @RtvFldDesc("C2COMP=$(prCompany) and C2FACL=$(prFacility) and C2CODE='$(V_CFHMLC)'", "PRCODE", "C2DESC", payCodeDesc)
                         <td class="dspalph">$(payCodeDesc)</td>
                      </tr>
                  %endif
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) CoFac_Profile_TransactionDefaults (IN CHAR(64)    profileHandle,
