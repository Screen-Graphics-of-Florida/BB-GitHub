%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "QuickLink.icl"

%Define {
  page_title 	        = "Company/Facility Profile"
  d2wName              = "HRCoFacProfile.d2w"
  attachFolder         = "HRCompanyFacility"
  d2wVarBase           = "$(genericVarBase)$(hrCoFacVarBase)"
  programName          = "HHRCOU"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext	        = "1"
  totalPages	        = "0"	
  CDM_05               = ""
  LAM_05               = ""
  FKM_05               = ""
  VDM_05               = ""
  quickLinkByUser      = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "HrCoFacURL.icl"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @HrCoFacUserView(profileHandle, dataBaseID, userPass, prCompany, prFacility)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Trailer Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Trailer Code -->
                  <table $(baseTable)>
                      <tr valign="top">
                          %if (formatToPrint == "")
                               @dtw_assign(pageID, "HRCOFACPROFILE")
                              <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                          %endif

                          @dtw_assign(programName2, "HHRCDM")
                          @pgmOptSecurity(profileHandle, dataBaseID, programName2, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                          @dtw_assign(CDM_05, sec_05)

                          @dtw_assign(programName3, "HPRLAM")
                          @pgmOptSecurity(profileHandle, dataBaseID, programName3, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                          @dtw_assign(LAM_05, sec_05)

                          @dtw_assign(programName4, "HPR4KM")
                          @pgmOptSecurity(profileHandle, dataBaseID, programName4, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                          @dtw_assign(FKM_05, sec_05)

                          <td class="content">
%{ QuickLink Table %}     %INCLUDE "QuickLinkTable.icl"

%{ QuickLink By User %}   %INCLUDE "QuickLinkByUser.icl"

%{ cofacheader %}
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, "SELECT * ", stmtSQL)
                              @dtw_concat(fileSQL, " HRCOFC ", fileSQL)
                              @dtw_concat(selectSQL, " CFCOMP = $(prCompany) and CFFACL = $(prFacility)", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %INCLUDE "stmtSQLEnd.icl"
                              @CoFac_Profile_Header(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Begin %}     %INCLUDE "QuickLinkBegLoop.icl"

    %{ cofacpaycheckoptions %}
                              %if (quicklinkRef == "cofacpaycheckoptions")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT CFCOMP, CFFACL, CFBKNO, CFACCT, CFBEGB, CFCKRC, CFCPGM, CFPCNA, CFP401, CFPRVC, CFPRSC, CFPF11 ", stmtSQL)
                                  @dtw_concat(fileSQL, " HRCOFC ", fileSQL)
                                  @dtw_concat(selectSQL, " CFCOMP = $(prCompany) and CFFACL = $(prFacility)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @CoFac_Profile_PayCheck(profileHandle, dataBaseID, stmtSQL)

    %{ cofacprocessingcontrol %}
                              %elif (quicklinkRef == "cofacprocessingcontrol")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT CFCOMP, CFFACL, CFPRTR, CFPF12, CFPRTS, CFHTCL, CFFGL, CFVGL, CFCPR, PCTIP, CFTCP, CXMWR, CXOPWG, CFEIN, CFVACH, ", stmtSQL)
                                  @dtw_concat(stmtSQL, "CFVACD, CFEXVC, CFSICH, CFSICD, CFEXSC, CFMXHR, CFMXGA, CFOTHD, CFOTHW, CFOTM, CFDTM, CFWGDA, CFWGDS, CFWGCA, CFWGCS, CFTXDA, CFTXDS, CFTXCA, CFTXCS ", stmtSQL)
                                  @dtw_concat(fileSQL, " HRCOFC inner join HRCOFX on CFCOMP=CXCOMP and CFFACL=CXFACL ", fileSQL)
                                  @dtw_concat(selectSQL, " CFCOMP = $(prCompany) and CFFACL = $(prFacility)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @CoFac_Profile_ProcessingControl(profileHandle, dataBaseID, stmtSQL)

    %{ cofacprocessingreports %}
                              %elif (quicklinkRef == "cofacprocessingreports")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT CFCOMP, CFFACL, CFPF13, CFGHPW, CFGHPH, CFPF1, CFPF2, CFPF3, CFPRDD, CFPTCD, ", stmtSQL)
                                  @dtw_concat(stmtSQL, "CFPODD, CFPF5, CFPF6, CFPF7, CFPF8, CFPF9, CFPF4, CFPF10, CFPPRD ", stmtSQL)
                                  @dtw_concat(fileSQL, " HRCOFC ", fileSQL)
                                  @dtw_concat(selectSQL, " CFCOMP = $(prCompany) and CFFACL = $(prFacility)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @CoFac_Profile_ProcessingReports(profileHandle, dataBaseID, stmtSQL)

    %{ cofacpaycodedefaults %}
                              %elif (quicklinkRef == "cofacpaycodedefaults")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT CFCOMP, CFFACL, CFHRGC, CFSRGC, CFHOVC, CFSOVC, CFHDTC, CFSDTC, CFHVCC, CFSVCC, CFHHLC, CFSHLC, CFHSCC, CFSSCC, ", stmtSQL)
                                  @dtw_concat(stmtSQL, "CFHOTC, CFSOTC, CFHNTC, CFSNTC, CFHCMC, CFSCMC, CFHBNC, CFSBNC, CFHFGC, CFSFGC, CFHMWM, CFHCTC, CFHGTC, CFHGRC, CFHMLC ", stmtSQL)
                                  @dtw_concat(fileSQL, " HRCOFC ", fileSQL)
                                  @dtw_concat(selectSQL, " CFCOMP = $(prCompany) and CFFACL = $(prFacility)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @CoFac_Profile_PayCodeDefaults(profileHandle, dataBaseID, stmtSQL)

    %{ cofactransactiondefaults %}
                              %elif (quicklinkRef == "cofactransactiondefaults")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT CFCOMP, CFFACL, CFHD01, CFSD01, CFHD02, CFSD02, CFHD03, CFSD03, CFHD04, CFSD04, CFHD05, CFSD05, ", stmtSQL)
                                  @dtw_concat(stmtSQL, "CFHD06, CFSD06, CFHD07, CFSD07, CFHD08, CFSD08, CFHD09, CFSD09, CFHD10, CFSD10, CFHD11, CFSD11 ", stmtSQL)
                                  @dtw_concat(fileSQL, " HRCOFC ", fileSQL)
                                  @dtw_concat(selectSQL, " CFCOMP = $(prCompany) and CFFACL = $(prFacility)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @CoFac_Profile_TransactionDefaults(profileHandle, dataBaseID, stmtSQL)

    %{ cofacficafui %}
                              %elif (quicklinkRef == "cofacficafui")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT CFCOMP, CFFACL, CFRFCR, CFEFCR, CFFICB, CFRHIR, CFEHIR, CFHIB, CFFUIR, CFFUIB ", stmtSQL)
                                  @dtw_concat(fileSQL, " HRCOFC ", fileSQL)
                                  @dtw_concat(selectSQL, " CFCOMP = $(prCompany) and CFFACL = $(prFacility)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @CoFac_Profile_FicaFui(profileHandle, dataBaseID, stmtSQL)

    %{ cofaccobra %}
                              %elif (quicklinkRef == "cofaccobra")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT CFCOMP, CFFACL, CFSTCD, CFDAY, CFCUT, CFDUE, CFGRAC, CFRDTH, CFMGN, CFMCN, CFMVN ", stmtSQL)
                                  @dtw_concat(fileSQL, " HRCOFC ", fileSQL)
                                  @dtw_concat(selectSQL, " CFCOMP = $(prCompany) and CFFACL = $(prFacility)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @CoFac_Profile_Cobra(profileHandle, dataBaseID, stmtSQL)

    %{ cofacdeductions %}
                              %elif ((quicklinkRef == "cofacdeductions") && (CDM_05 == "Y"))
                                  @dtw_assign(showError, "N")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HRCDED inner join HRDEDM on CDDDNO=HVDDNO ", fileSQL)
                                  @dtw_concat(selectSQL, " CDCOMP = $(prCompany) and CDFACL = $(prFacility)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @CoFac_Profile_Deductions(profileHandle, dataBaseID, stmtSQL)

    %{ cofacliabilityaccts %}
                              %elif ((quicklinkRef == "cofacliabilityaccts") && (LAM_05 == "Y"))
                                  @dtw_assign(showError, "N")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT * ", stmtSQL)
                                  @dtw_concat(fileSQL, " PRLIAC ", fileSQL)
                                  @dtw_concat(selectSQL, " LACOMP = $(prCompany) and LAFACL = $(prFacility)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @CoFac_Profile_LiabAccts(profileHandle, dataBaseID, stmtSQL)

    %{ cofac401k %}
                              %elif ((quicklinkRef == "cofac401k") && (FKM_05 == "Y"))
                                  @dtw_assign(showError, "N")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT * ", stmtSQL)
                                  @dtw_concat(fileSQL, " PR401K ", fileSQL)
                                  @dtw_concat(selectSQL, " K4COMP = $(prCompany) and K4FACL = $(prFacility)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @CoFac_Profile_401k(profileHandle, dataBaseID, stmtSQL)
                              %endif

    %{ Attachments %}         %INCLUDE "AttachmentSQL.icl"

%{ Quicklink End %}       %INCLUDE "QuickLinkEndLoop.icl"

                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) CoFac_Profile_Header (IN CHAR(64)    profileHandle,
				             CHAR(2)     dataBaseID,
                                            CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_tb_setcols(quicklinkSeqTable, "5")
      %ROW {
          %if (CDM_05 == "N")
              @Remove_Quick_Link("COFACDEDUCTIONS")
          %endif
          %if (LAM_05 == "N")
              @Remove_Quick_Link("COFACLIABILITYACCTS")
          %endif
          %if (FKM_05 == "N")
              @Remove_Quick_Link("COFAC401K")
          %endif

              <table $(contentTable)>
                  <colgroup>
                      <col width="80%">
                      <col width="15%">
                  <tr><td><h1>$(page_title)</h1></td>
                      @dtw_assign(prCompanyFilled, "$(prCompany)")
                      %while(@dtw_rlength(prCompanyFilled) != "2") {@dtw_insert("0", prCompanyFilled, prCompanyFilled)%}
                      @dtw_assign(prFacilityFilled, "$(prFacility)")
                      %while(@dtw_rlength(prFacilityFilled) != "4") {@dtw_insert("0", prFacilityFilled, prFacilityFilled)%}
                      @dtw_assign(attachVarKey, "$(prCompanyFilled)_$(prFacilityFilled)")
                      @dtw_assign(attachForDesc, "$(V_CFNAME)")
                      @dtw_assign(attachPrg1, "HRCOFC Where CFCOMP=$(prCompany) and CFFACL=$(prFacility)")
                      %if (formatToPrint != "Y")
                          <td class="toolbar">
                              <a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&tblID=52" title="Back Home">$(portalHome)</a>
                              %INCLUDE "Attachment.icl"
                              %INCLUDE "FormatToPrint.icl"
                              %INCLUDE "HelpPage.icl"
                          </td>
                      %endif
                  </tr>
              </table>
              %INCLUDE "ConfMessageDisplay.icl"
              $(hrTagAttr)

              <table $(contentTable)>
                  <colgroup>
                      <col width="60%">
        	       <col width="20%">
	   		
                      @EditPhoneNumber(V_CFPHON)
                      <tr><td rowspan="5" class="dspalph"> $(V_CFNAME) <br>
                          %if (V_CFADR1 != "")
                              $(V_CFADR1) <br>
                          %endif
                          %if (V_CFADR2 != "")
                              $(V_CFADR2) <br>
                          %endif
                          $(V_CFCITY), $(V_CFSTID) $(V_CFZIP) <br>
                          @Format_HRCoFac("$(V_CFCOMP)", "$(V_CFFACL)", "", F_CoFac)
                          <td class="dsphdr">Company/Facility:</td>
                          <td class="dspnmbr">$(F_CoFac)</td>
                      </tr>

                      %if ($(V_CFCOMP) != $(V_CFHRXR))
                          <tr>
                              <td class="dsphdr">H/R Company: </td>
                              <td class="dspnmbr">$(V_CFHRXR)</td>
                          </tr>
                      %endif
                      <tr>
                          <td class="dsphdr">Phone Number: </td>
                          <td class="dspnmbr">$(V_CFPHON)</td>
                      </tr>
                      <tr>
                          <td class="dsphdr">Payroll Processing Status: </td>
                          @RtvFldDesc("FLTYPE='PROCESSSTS' and FLVALU='$(V_CFSTAT)'", "SYFLAG", "FLDESC", syFlagDesc)
                          <td class="dspnmbr">$(syFlagDesc)</td>
                      </tr>
                      <tr>
                          @Format_Date(V_CFLPPE, "H", F_CFLPPE)
                          <td class="dsphdr">Last Pay Period End Date: </td>
                          <td class="dspdate">$(F_CFLPPE)</td>
                      </tr>
              </table>
          $(hrTagAttr)
          %INCLUDE "QuickLinkDisplay.icl"
      %}
  %}
%}

%FUNCTION(dtw_sql) CoFac_Profile_PayCheck (IN CHAR(64)    profileHandle,
                                              CHAR(2)     dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="cofacpaycheckoptions"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %ROW{
              @dtw_assign(programName5, "HPRBKM")
              @pgmOptSecurity(profileHandle, dataBaseID, programName5, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
              <tr>
                  <td class="dsphdr">Bank</td>
                  @RtvFldDesc("BABKNO=$(V_CFBKNO)", "PRBANK", "BABKNM", bankName)
                  @Format_Code(V_CFBKNO, F_CFBKNO)
                  <td class="dspalph">$(bankName)</td>
                  <td class="dspalph">$(F_CFBKNO)</td>
              </tr>
              <tr><td class="dsphdr">Override Bank Account Number</td>
                  <td class="dspalph">$(V_CFACCT)</td>
              </tr>
              <tr><td class="dsphdr">Override Beginning Batch Number</td>
                  <td class="dspalph">$(V_CFBEGB)</td>
              </tr>
              <tr><td class="dsphdr">Check Reconciliation</td>
                  @RtvYNDesc($(V_CFCKRC), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Check Printing Program Name</td>
                  <td class="dspalph">$(V_CFCPGM)</td>
              </tr>
              <tr><td class="dsphdr">Print Co/Fac Name And Address On Check</td>
                  @RtvYNDesc($(V_CFPCNA), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Print Employer 401(k) On Check</td>
                  @RtvYNDesc($(V_CFP401), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Print Available Vacation Hours On Check</td>
                  @RtvYNDesc($(V_CFPRVC), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Print Available Sick Hours On Check</td>
                  @RtvYNDesc($(V_CFPRSC), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Print Overflow Advice</td>
                  @RtvYNDesc($(V_CFPF11), syFlagDesc)
                  @Format_Code(V_CFPF11, F_CFPF11)
                  <td class="dspalph">$(syFlagDesc)</td>
                  <td class="dspalph">$(F_CFPF11)</td>
              </tr>
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) CoFac_Profile_ProcessingControl (IN CHAR(64)    profileHandle,
                                                       CHAR(2)     dataBaseID,
                                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="cofacprocessingcontrol"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %ROW{
              <tr><td class="dsphdr">Suppress Pay Transaction Entry Rates</td>
                  @RtvYNDesc($(V_CFPRTR), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Run Reset Accruals Each Pay Period</td>
                  @RtvYNDesc($(V_CFPF12), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Time Entry Form Format</td>
                  @RtvFldDesc("FLTYPE='ENTRYFORM' and FLVALU='$(V_CFPRTS)'", "SYFLAG", "FLDESC", syFlagDesc)
                  @Format_Code(V_CFPRTS, F_CFPRTS)
                  <td class="dspalph">$(syFlagDesc)</td>
                  <td class="dspalph">$(F_CFPRTS)</td>
              </tr>
              <tr><td class="dsphdr">Print Time Card Labels</td>
                  @RtvYNDesc($(V_CFHTCL), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Activate G/L Feed</td>
                  @RtvYNDesc($(V_CFFGL), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Validate G/L Accounts</td>
                  @RtvYNDesc($(V_CFVGL), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Certified Payroll History</td>
                  @RtvYNDesc($(V_CFCPR), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Tip Payroll</td>
                  @RtvYNDesc($(V_PCTIP), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              @Format_Nbr($(V_CFTCP), F_CFTCP, "3", $(pctEditCode), "", "", "")
              <tr><td class="dsphdr">Tip Credit Percent</td>
                  <td class="dspnmbr">$(F_CFTCP)</td>
              </tr>
              @Format_Nbr($(V_CXMWR), F_CXMWR, "2", $(rteEditCode), "", "", "")
              <tr><td class="dsphdr">Minimum Wage</td>
                  <td class="dspnmbr">$(F_CXMWR)</td>
              </tr>
              @Format_Nbr($(V_CXOPWG), F_CXOPWG, "2", $(rteEditCode), "", "", "")
              <tr><td class="dsphdr">Opportunity Wage</td>
                  <td class="dspnmbr">$(F_CXOPWG)</td>
              </tr>
              %if ($(V_CFEIN) != "")
                  <tr><td class="dsphdr">Establishment ID Number</td>
                      <td class="dspnmbr">$(V_CFEIN)</td>
                  </tr>
              %endif
              <tr><td class="dsphdr">Validate Vacation Hours</td>
                  @RtvYNDesc($(V_CFVACH), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Validate Vacation Earnings</td>
                  @RtvYNDesc($(V_CFVACD), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Expense Vacation As Earned</td>
                  @RtvYNDesc($(V_CFEXVC), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Validate Sick Hours</td>
                  @RtvYNDesc($(V_CFSICH), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Validate Sick Earnings</td>
                  @RtvYNDesc($(V_CFSICD), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Expense Sick As Earned</td>
                  @RtvYNDesc($(V_CFEXSC), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td>
              </tr>
              @Format_Nbr($(V_CFMXHR), F_CFMXHR, "2", $(rteEditCode), "", "", "")
              <tr><td class="dsphdr">Maximum Hourly Rate</td>
                  <td class="dspnmbr">$(F_CFMXHR)</td>
              </tr>
              @Format_Nbr($(V_CFMXGA), F_CFMXGA, "2", $(amtEditCode), "", "", "")
              <tr><td class="dsphdr">Maximum Gross Amount</td>
                  <td class="dspnmbr">$(F_CFMXGA)</td>
              </tr>
              @Format_Nbr($(V_CFOTHD), F_CFOTHD, "2", $(hrsEditCode), "", "", "")
              <tr><td class="dsphdr">Overtime After # Hours Per Day</td>
                  <td class="dspnmbr">$(F_CFOTHD)</td>
              </tr>
              @Format_Nbr($(V_CFOTHW), F_CFOTHW, "2", $(hrsEditCode), "", "", "")
              <tr><td class="dsphdr">Overtime After # Hours Per Week</td>
                  <td class="dspnmbr">$(F_CFOTHW)</td>
              </tr>
              <tr><td class="dsphdr">Overtime Multiplier</td>
                  <td class="dspnmbr">$(V_CFOTM)</td>
              </tr>
              <tr><td class="dsphdr">Double Time Multiplier</td>
                  <td class="dspnmbr">$(V_CFDTM)</td>
              </tr>
              <tr><td class="dsphdr">Inter-Company Wages Due From Account</td>
                  @Format_Acct("$(V_CFWGDA)", "$(V_CFWGDS)", "Y", F_AcctSub)
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dsphdr">Inter-Company Wages Due To Account</td>
                  @Format_Acct("$(V_CFWGCA)", "$(V_CFWGCS)", "Y", F_AcctSub)
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dsphdr">Inter-Company Tax Due From Account</td>
                  @Format_Acct("$(V_CFTXDA)", "$(V_CFTXDS)", "Y", F_AcctSub)
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dsphdr">Inter-Company Tax Due To Account</td>
                  @Format_Acct("$(V_CFTXCA)", "$(V_CFTXCS)", "Y", F_AcctSub)
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
          %}	
      </table>
      </fieldset>
  %}
%}

