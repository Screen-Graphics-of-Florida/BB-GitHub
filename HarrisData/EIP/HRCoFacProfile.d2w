              </tr>
              <tr><td class="dsphdr">State Workers' Compensation Payable</td>
                  @Format_Acct("$(V_LAWWCA)", "$(V_LAWWCS)", "F", F_AcctSub)
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dsphdr">Local Taxes Payable</td>
                  @Format_Acct("$(V_LAWLTA)", "$(V_LAWLTS)", "F", F_AcctSub)
                  <td class="dspnmbr">$(returnFldDesc)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
              </tr>
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) CoFac_Profile_401k (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="cofac401k"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %endif

          %ROW{
              %if ($(V_K4DED2) == "0")
                  @dtw_assign(V_K4DED2, "")
              %endif
              %if ($(V_K4DED3) == "0")
                  @dtw_assign(V_K4DED3, "")
              %endif
              %if ($(V_K4DED4) == "0")
                  @dtw_assign(V_K4DED4, "")
              %endif
              %if ($(V_K4DED5) == "0")
                  @dtw_assign(V_K4DED5, "")
              %endif

              <tr><td class="dsphdr">401(k) Deduction Numbers</td>
                  <td class="dspalph">$(V_K4DED1) $(V_K4DED2) $(V_K4DED3) $(V_K4DED4) $(V_K4DED5)</td>
              </tr>
              @dtw_assign(employeeMinimum, "")
              @Format_Nbr("@dtw_rmultiply(V_K4EMCN, "100")", F_K4EMCN, "2", $(employeeMinimum), "Y", "", "")
              <tr><td class="dsphdr">Employee Minimum Contribution Percent</td>
                  <td class="dspnmbr">$(F_K4EMCN)</td>
              </tr>
              <tr><td class="dsphdr">Annual Or Pay Period Calculation</td>
                  @Format_Code(V_K4ANPP, F_K4ANPP)
                  %if ($(V_K4ANPP) == "A")
                      <td class="dspnmbr">Annual</td>
                  %else
                      <td class="dspnmbr">Pay Period</td>
                  %endif
                  <td class="dspalph">$(F_K4ANPP)</td>
              </tr>

              <tr>
                  <th class="colhdr">Processing Option</th>
                  <th class="colhdr">Hourly</th>
                  <th class="colhdr">Salary</th>
              </tr>

              <tr class="$(rowClass)">
                  @Format_Nbr("@dtw_rmultiply(V_K4RMXH, "100")", F_K4RMXH, "2", $(pctEditCode), "Y", "", "")
                  @Format_Nbr("@dtw_rmultiply(V_K4RMXS, "100")", F_K4RMXS, "2", $(pctEditCode), "Y", "", "")
                  <td class="dsphdr">Employer Maximum Match Percent</td>
                  <td class="colnmbr">$(F_K4RMXH)</td>
                  <td class="colnmbr">$(F_K4RMXS)</td>
              </tr>
              <tr class="$(rowClass)">
                  @Format_Nbr("@dtw_rmultiply(V_K4RMAH, "100")", F_K4RMAH, "2", $(pctEditCode), "Y", "", "")
                  @Format_Nbr("@dtw_rmultiply(V_K4RMAS, "100")", F_K4RMAS, "2", $(pctEditCode), "Y", "", "")
                  <td class="dsphdr">Employer Match Percent</td>
                  <td class="colnmbr">$(F_K4RMAH)</td>
                  <td class="colnmbr">$(F_K4RMAS)</td>
              </tr>
          %}	
      </table>
      </fieldset>
  %}
%}

