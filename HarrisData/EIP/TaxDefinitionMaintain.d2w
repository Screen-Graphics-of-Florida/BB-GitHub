%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Tax Definition Maintenance"
  d2wName                 = "TaxDefinitionMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;state=@dtw_rurlescseq(state)&amp;county=@dtw_rurlescseq(county)&amp;city=@dtw_rurlescseq(city)&amp;local1=@dtw_rurlescseq(local1)&amp;local2=@dtw_rurlescseq(local2)&amp;local3=@dtw_rurlescseq(local3)&amp;taxDefDesc=@dtw_rurlescseq(taxDefDesc)&amp;maintenanceCode=D"
  programName             = "HOETDU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.state.value =="" ||
                      document.Chg.taxDefDesc.value =="")
                         {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.county, 3, 0) &&
                      editNum(document.Chg.city, 5, 0) &&
                      editNum(document.Chg.local1, 4, 0) &&
                      editNum(document.Chg.local2, 4, 0) &&
                      editNum(document.Chg.local3, 4, 0) &&
                      editNum(document.Chg.rate, 3, 4))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "TAXDEFINTIONMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From HDTAXD ", stmtSQL)
                          @dtw_concat(stmtSQL, "Where TDSTCD='$(state)' and TDCNYC=$(county) and TDCTYC=$(city) ", stmtSQL)
                          @dtw_concat(stmtSQL, "and TDLOC1=$(local1) and TDLOC2=$(local2) and TDLOC3=$(local3) ", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=206")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

	   <form class="formClass" NAME="Chg" METHOD=POST ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "state")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@stcd", "state")       @dtw_assign(Err_TDSTCD, fieldValue)
                          @DecatErr_Field("@@cnyc", "county")      @dtw_assign(Err_TDCNYC, fieldValue)
                          @DecatErr_Field("@@ctyc", "city")        @dtw_assign(Err_TDCTYC, fieldValue)
                          @DecatErr_Field("@@loc1", "local1")      @dtw_assign(Err_TDLOC1, fieldValue)
                          @DecatErr_Field("@@loc2", "local2")      @dtw_assign(Err_TDLOC2, fieldValue)
                          @DecatErr_Field("@@loc3", "local3")      @dtw_assign(Err_TDLOC3, fieldValue)
                          @DecatErr_Field("@@tdsc", "taxDefDesc")  @dtw_assign(Err_TDTDSC, fieldValue)
                          @DecatErr_Field("@@tax1", "rate")        @dtw_assign(Err_TDTAX1, fieldValue)
                          @DecatErr_Field("@@frtx", "frtTax")      @dtw_assign(Err_TDFRTX, fieldValue)
                          @DecatErr_Field("@@txac", "account")     @dtw_assign(Err_TDTXAC, fieldValue)
                          @DecatErr_Field("@@txsb", "subaccount")  @dtw_assign(Err_TDTXSB, fieldValue)
                      %endif

                      @Decat_Field("@@stcd")   @dtw_assign(V_TDSTCD, fieldValue)
                      @Decat_Field("@@cnyc")   @dtw_assign(V_TDCNYC, fieldValue)
                      @Decat_Field("@@ctyc")   @dtw_assign(V_TDCTYC, fieldValue)
                      @Decat_Field("@@loc1")   @dtw_assign(V_TDLOC1, fieldValue)
                      @Decat_Field("@@loc2")   @dtw_assign(V_TDLOC2, fieldValue)
                      @Decat_Field("@@loc3")   @dtw_assign(V_TDLOC3, fieldValue)
                      @Decat_Field("@@tdsc")   @dtw_assign(V_TDTDSC, fieldValue)
                      @Decat_Field("@@tax1")   @dtw_assign(V_TDTAX1, fieldValue)
                      @Decat_Field("@@frtx")   @dtw_assign(V_TDFRTX, fieldValue)
                      @Decat_Field("@@txac")   @dtw_assign(V_TDTXAC, fieldValue)
                      @Decat_Field("@@txsb")   @dtw_assign(V_TDTXSB, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "state")
                      %endif
                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_TDSTCD, "")
                      @dtw_assign(focusField, "state")
                      @dtw_assign(V_TDTAX1, "@dtw_rformat(@dtw_rmultiply(V_TDTAX1, "100"),"","4")")
                  %else
                      @dtw_assign(focusField, "taxDefDesc")
                      @dtw_assign(V_TDTAX1, "@dtw_rformat(@dtw_rmultiply(V_TDTAX1, "100"),"","4")")
                  %endif

                  @RtvFldDesc("STID='$(V_TDSTCD)'", "HDSTID", "STDESC", fieldDesc)
                  @SetTextOvr(Err_TDSTCD)
                  <tr><td class="dsphdr"><span $(textOvr)>State</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="state" type="text" value="$(V_TDSTCD)" size="4" maxlength="2"><a href="$(homeURL)$(phpPath)StateSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=state&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input name="stateDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                      %else
                          <td class="inputalph"><input name="state" type="hidden" value="$(V_TDSTCD)">$(V_TDSTCD)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_TDSTCD)
	   		
                  @SetTextOvr(Err_TDCNYC)
                  <tr><td class="dsphdr"><span $(textOvr)>County</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input type="text" name="county" value="$(V_TDCNYC)" size="4" maxlength="3"></td>
                      %else
                          <td class="inputalph"><input type="hidden" name="county" value="$(V_TDCNYC)">$(V_TDCNYC)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_TDCNYC)
	   		
                  @SetTextOvr(Err_TDCTYC)
                  <tr><td class="dsphdr"><span $(textOvr)>City</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input type="text" name="city" value="$(V_TDCTYC)" size="4" maxlength="5"></td>
                      %else
                          <td class="inputalph"><input type="hidden" name="city" value="$(V_TDCTYC)">$(V_TDCTYC)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_TDCTYC)
	   		
                  @SetTextOvr(Err_TDLOC1)
                  <tr><td class="dsphdr"><span $(textOvr)>Local 1</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input type="text" name="local1" value="$(V_TDLOC1)" size="4" maxlength="4"></td>
                      %else
                          <td class="inputalph"><input type="hidden" name="local1" value="$(V_TDLOC1)">$(V_TDLOC1)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_TDLOC1)
	   		
                  @SetTextOvr(Err_TDLOC2)
                  <tr><td class="dsphdr"><span $(textOvr)>Local 2</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input type="text" name="local2" value="$(V_TDLOC2)" size="4" maxlength="4"></td>
                      %else
                          <td class="inputalph"><input type="hidden" name="local2" value="$(V_TDLOC2)">$(V_TDLOC2)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_TDLOC2)
	   		
                  @SetTextOvr(Err_TDLOC3)
                  <tr><td class="dsphdr"><span $(textOvr)>Local 3</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input type="text" name="local3" value="$(V_TDLOC3)" size="4" maxlength="4"></td>
                      %else
                          <td class="inputalph"><input type="hidden" name="local3" value="$(V_TDLOC3)">$(V_TDLOC3)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_TDLOC3)

                  @SetTextOvr(Err_TDTDSC)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="taxDefDesc" type="text" value="$(V_TDTDSC)" size="20" maxlength="15">$(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_TDTDSC)

                  @SetTextOvr(Err_TDTAX1)
                  <tr><td class="dsphdr"><span $(textOvr)>Tax Rate Percent</span></td>
                      <td class="inputalph"><input name="rate" type="text" value="$(V_TDTAX1)" size="10" maxlength="10"></td>
                  </tr>
                  @DspErrMsg(Err_TDTAX1)
	      	
                  %if (maintenanceCode=="A" || maintenanceCode == "Z" || (V_TDCNYC=="0" && V_TDCTYC=="0" && V_TDLOC1=="0" && V_TDLOC2=="0" && V_TDLOC3=="0"))
    	              <tr>
                         @SetTextOvr(Err_TDFRTX)
                         <td class="dsphdr"><span $(textOvr)>Freight Taxable</span></td>
                         @dtw_tb_rows(yn01Table, maxRows)
                         @dtw_assign(x, "1")
                         %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_TDFRTX) && (x < maxRows))
                                {@dtw_add(x, "1", x)%}
                         <td>@dtw_tb_select(yn01Table, "frtTax", "2", "1", "N", "", x, "1")</td>
                      </tr>
                      @DspErrMsg(Err_TDFRTX)
        	      		
                      @Default_Zero(V_TDTXAC)
                      @Default_Zero(V_TDTXSB)
                      @RtvFldDesc("CHACCT=$(V_TDTXAC) and CHSUB=$(V_TDTXSB) ", "HDCHRT", "CHCHDS", acctDesc)
                      @SetTextOvr(Err_LAEPWA)
                      <tr><td class="dsphdr"><span $(textOvr)>Sales Tax Account</span></td>
                          <td class="inputnmbr"><input name="account" value="$(V_TDTXAC)" type="text" size="4" maxlength="4"> - <input name="subaccount" value="$(V_TDTXSB)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=account&amp;subFld=subaccount&amp;descFld=accountDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="accountDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_TDTXAC)
                      @DspErrMsg(Err_TDTXSB)
                  %else
                      <tr>
                          <td class="inputalph"><input type="hidden" name="frtTax" value=""></td>
                          <td class="inputalph"><input type="hidden" name="account" value="0"></td>
                          <td class="inputalph"><input type="hidden" name="subaccount" value="0"></td>
                      </tr>
                  %endif
              %}
          </table>
	
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HOETDU_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(state)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@stcd", state)
  @Concat_Field("@@cnyc", county)
  @Concat_Field("@@ctyc", city)
  @Concat_Field("@@loc1", local1)
  @Concat_Field("@@loc2", local2)
  @Concat_Field("@@loc3", local3)
  @Concat_Field("@@tdsc", taxDefDesc)
  @Concat_Field("@@tax1", rate)
  @Concat_Field("@@frtx", frtTax)
  @Concat_Field("@@txac", account)
  @Concat_Field("@@txsb", subaccount)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(taxDefDesc), "$(state)/$(county)/$(city)/$(local1)/$(local2)/$(local3)", "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@stcd", "state")
          @Format_ConfMsg_Desc("", $(taxDefDesc), $(state), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=206&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
   %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;state=@dtw_rurlescseq(state)&amp;county=@dtw_rurlescseq(county)&amp;city=@dtw_rurlescseq(city)&amp;local1=@dtw_rurlescseq(local1)&amp;local2=@dtw_rurlescseq(local2)&amp;local3=@dtw_rurlescseq(local3)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
