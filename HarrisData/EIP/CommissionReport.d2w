%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Commission Report"
  d2wName                 = "CommissionReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "03"
  sortSalesmanNumber      = "1"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromSalesmanNumber, 3, 0) &&
                      editNum(document.Chg.toSalesmanNumber, 3, 0) &&
                      editdate(document.Chg.fromInvoiceDate) &&
                      editdate(document.Chg.toInvoiceDate) &&
                      editNum(document.Chg.fromOrderNumber, 8, 0) &&
                      editNum(document.Chg.toOrderNumber, 8, 0) &&
                      editFromToAll(document.Chg.fromSalesmanNumber, document.Chg.toSalesmanNumber, document.Chg.allSalesmanNumber, 3) &&
                      editFromToAll(document.Chg.fromInvoiceDate, document.Chg.toInvoiceDate, document.Chg.allInvoiceDate, "D") &&
                      editFromToAll(document.Chg.fromOrderNumber, document.Chg.toOrderNumber, document.Chg.allOrderNumber, 8))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "COMMISSIONREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromSalesmanNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@fslm", "fromSalesmanNumber")          @dtw_assign(Err_FSLSM,  fieldValue)
                                  @DecatErr_Field("@@tslm", "toSalesmanNumber")            @dtw_assign(Err_TSLSM,  fieldValue)
                                  @DecatErr_Field("@@aslm", "allSalesmanNumber")           @dtw_assign(Err_ASLSM,  fieldValue)
                                  @DecatErr_Field("@@sslm", "sortSalesmanNumber")           @dtw_assign(Err_SSLSM,  fieldValue)
                                  @DecatErr_Field("@@pslm", "totalSalesmanNumber")       @dtw_assign(Err_PSLSM,  fieldValue)
                                  @DecatErr_Field("@@fdat", "fromInvoiceDate")      @dtw_assign(Err_FDATE,  fieldValue)
                                  @DecatErr_Field("@@tdat", "toInvoiceDate")        @dtw_assign(Err_TDATE,  fieldValue)
                                  @DecatErr_Field("@@adat", "allInvoiceDate")       @dtw_assign(Err_ADATE,  fieldValue)
                                  @DecatErr_Field("@@sdat", "sortInvoiceDate")      @dtw_assign(Err_SDATE,  fieldValue)
                                  @DecatErr_Field("@@pdat", "totalInvoiceDate")      @dtw_assign(Err_PDATE,  fieldValue)
                                  @DecatErr_Field("@@ford", "fromOrderNumber")          @dtw_assign(Err_FORD,  fieldValue)
                                  @DecatErr_Field("@@tord", "toOrderNumber")            @dtw_assign(Err_TORD,  fieldValue)
                                  @DecatErr_Field("@@aord", "allOrderNumber")           @dtw_assign(Err_AORD,  fieldValue)
                                  @DecatErr_Field("@@sord", "sortOrderNumber")           @dtw_assign(Err_SORD,  fieldValue)
                                  @DecatErr_Field("@@pord", "totalOrderNumber")       @dtw_assign(Err_PORD,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}

                                  @Decat_Field("@@fslm")   @dtw_assign(V_FSLSM,  fieldValue)
                                  @Decat_Field("@@tslm")   @dtw_assign(V_TSLSM,  fieldValue)
                                  @Decat_Field("@@aslm")   @dtw_assign(V_ASLSM,  fieldValue)
                                  @Decat_Field("@@sslm")   @dtw_assign(V_SSLSM,  fieldValue)
                                  @Decat_Field("@@pslm")   @dtw_assign(V_PSLSM,  fieldValue)
                                  @Decat_Field("@@fdat")   @dtw_assign(V_FDATE,  fieldValue)
                                  @Decat_Field("@@tdat")   @dtw_assign(V_TDATE,  fieldValue)
                                  @Decat_Field("@@adat")   @dtw_assign(V_ADATE,  fieldValue)
                                  @Decat_Field("@@sdat")   @dtw_assign(V_SDATE,  fieldValue)
                                  @Decat_Field("@@pdat")   @dtw_assign(V_PDATE,  fieldValue)
                                  @Decat_Field("@@ford")   @dtw_assign(V_FORD,  fieldValue)
                                  @Decat_Field("@@tord")   @dtw_assign(V_TORD,  fieldValue)
                                  @Decat_Field("@@aord")   @dtw_assign(V_AORD,  fieldValue)
                                  @Decat_Field("@@sord")   @dtw_assign(V_SORD,  fieldValue)
                                  @Decat_Field("@@pord")   @dtw_assign(V_PORD,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}

                                  %if (V_ASLSM == "ALL")
                                      @dtw_assign(checkedallSalesmanNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallSalesmanNumber, "")
                                  %endif
                                  %if (V_ADATE == "ALL")
                                      @dtw_assign(checkedallInvoiceDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallInvoiceDate, "")
                                  %endif
                                  %if (V_AORD == "ALL")
                                      @dtw_assign(checkedallOrderNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallOrderNumber, "")
                                  %endif

                                  %if (V_PSLSM == "Y")
                                      @dtw_assign(checkedSalesmanTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedSalesmanTotals, "")
                                  %endif
                                  %if (V_PDATE == "Y")
                                      @dtw_assign(checkedInvoiceTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedInvoiceTotals, "")
                                  %endif
                                  %if (V_PORD == "Y")
                                      @dtw_assign(checkedOrderTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedOrderTotals, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedallSalesmanNumber, "CHECKED")
                                  @dtw_assign(checkedallInvoiceDate, "CHECKED")
                                  @dtw_assign(checkedallOrderNumber, "CHECKED")
                                  @dtw_assign(V_SSLSM, "1")
                                  @dtw_assign(checkedSalesmanTotals, "N")
                                  @dtw_assign(checkedInvoiceTotals, "N")
                                  @dtw_assign(checkedOrderTotals, "N")
                              %endif

                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                                  <td class="colhdr">Print<br>Totals</td>
                              </tr>

                              @SetTextOvr(Err_FSLSM)
                              %if (textOvr == "") @SetTextOvr(Err_TSLSM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_ASLSM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SSLSM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_PSLSM) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Salesman Number</span></td>
                                  <td class="inputnmbr"><input name="fromSalesmanNumber" value="$(V_FSLSM)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)SalesmanSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromSalesmanNumber&amp;fldDesc=salesmanName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="salesmanName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toSalesmanNumber" value="$(V_TSLSM)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)SalesmanSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toSalesmanNumber&amp;fldDesc=salesmanName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="salesmanName" type="hidden"></td>
                                  <td class="inputalph"><input name="allSalesmanNumber" value='ALL' $(checkedallSalesmanNumber) type="checkbox" onClick="if (this.checked) this.form.fromSalesmanNumber.value='', this.form.toSalesmanNumber.value='';"></td>
                                  <td class="colcode"><input &name="sortSalesmanNumber" type="hidden"  Value="$(sortSalesmanNumber)" size="1" maxlength="1">$(sortSalesmanNumber)</td>
                                  <td class="inputalph"><input name="totalSalesmanNumber" type="checkbox" $(checkedSalesmanTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_FSLSM)
                              @DspErrMsg(Err_TSLSM)
                              @DspErrMsg(Err_ASLSM)
                              @DspErrMsg(Err_SSLSM)
                              @DspErrMsg(Err_PSLSM)

                              @SetTextOvr(Err_FDATE)
                              %if (textOvr == "") @SetTextOvr(Err_TDATE) %endif
                              %if (textOvr == "") @SetTextOvr(Err_ADATE) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SDATE) %endif
                              %if (textOvr == "") @SetTextOvr(Err_PDATE) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Invoice Date</span></td>
                                  <td class="inputnmbr"><input name="fromInvoiceDate" value="$(V_FDATE)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromInvoiceDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toInvoiceDate" value="$(V_TDATE)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toInvoiceDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allInvoiceDate" value='ALL' $(checkedallInvoiceDate) type="checkbox" onClick="if (this.checked) this.form.fromInvoiceDate.value='', this.form.toInvoiceDate.value='';"></td>
                                  @Build_Sort_Select("sortInvoiceDate", "$(V_SDATE)")
                                  <td class="inputcode"><input name="totalInvoiceDate" type="checkbox" $(checkedInvoiceTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_FDATE)
                              @DspErrMsg(Err_TDATE)
                              @DspErrMsg(Err_ADATE)
                              @DspErrMsg(Err_SDATE)
                              @DspErrMsg(Err_PDATE)
                              @SetTextOvr(Err_FORD)

                              %if (textOvr == "") @SetTextOvr(Err_TORD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_AORD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SORD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_PORD) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Order Number</span></td>
                                  <td class="inputnmbr"><input name="fromOrderNumber" value="$(V_FORD)" type="text" size="8" maxlength="8"></td>
                                  <td class="inputnmbr"><input name="toOrderNumber" value="$(V_TORD)" type="text" size="8" maxlength="8"></td>
                                  <td class="inputalph"><input name="allOrderNumber" value='ALL' $(checkedallOrderNumber) type="checkbox" onClick="if (this.checked) this.form.fromOrderNumber.value='', this.form.toOrderNumber.value='';"></td>
                                  @Build_Sort_Select("sortOrderNumber", "$(V_SORD)")
                                  <td class="inputcode"><input name="totalOrderNumber" type="checkbox" $(checkedOrderTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_FORD)
                              @DspErrMsg(Err_TORD)
                              @DspErrMsg(Err_AORD)
                              @DspErrMsg(Err_SORD)
                              @DspErrMsg(Err_PORD)
                          </table>

                          @dtw_assign(envProgram, "HOECMR")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HOESCM_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allSalesmanNumber)
  @dtw_mUPPERCASE(allInvoiceDate)
  @dtw_mUPPERCASE(allOrderNumber)

  @dtw_assign(fromSalesmanNumber,@dtw_rstrip(fromSalesmanNumber))
  @dtw_assign(toSalesmanNumber,@dtw_rstrip(toSalesmanNumber))
  @dtw_assign(sortSalesmanNumber,@dtw_rstrip(sortSalesmanNumber))
  @dtw_assign(fromInvoiceDate,@dtw_rstrip(fromInvoiceDate))
  @dtw_assign(toInvoiceDate,@dtw_rstrip(toInvoiceDate))
  @dtw_assign(sortInvoiceDate,@dtw_rstrip(sortInvoiceDate))
  @dtw_assign(fromOrderNumber,@dtw_rstrip(fromOrderNumber))
  @dtw_assign(toOrderNumber,@dtw_rstrip(toOrderNumber))
  @dtw_assign(sortOrderNumber,@dtw_rstrip(sortOrderNumber))


  %if (allSalesmanNumber != "ALL")
      @dtw_assign(allSalesmanNumber, "")
  %endif
  %if (allInvoiceDate != "ALL")
      @dtw_assign(allInvoiceDate, "")
  %endif
  %if (allOrderNumber != "ALL")
      @dtw_assign(allOrderNumber, "")
  %endif

  %if (totalSalesmanNumber != "Y")
      @dtw_assign(totalSalesmanNumber, "N")
  %endif
  %if (totalInvoiceDate != "Y")
      @dtw_assign(totalInvoiceDate, "N")
  %endif
  %if (totalOrderNumber != "Y")
      @dtw_assign(totalOrderNumber, "N")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@fslm", fromSalesmanNumber)
  @Concat_Field("@@tslm", toSalesmanNumber)
  @Concat_Field("@@aslm", allSalesmanNumber)
  @Concat_Field("@@sslm", sortSalesmanNumber)
  @Concat_Field("@@pslm", totalSalesmanNumber)
  @Concat_Field("@@fdat", fromInvoiceDate)
  @Concat_Field("@@tdat", toInvoiceDate)
  @Concat_Field("@@adat", allInvoiceDate)
  @Concat_Field("@@sdat", sortInvoiceDate)
  @Concat_Field("@@pdat", totalInvoiceDate)
  @Concat_Field("@@ford", fromOrderNumber)
  @Concat_Field("@@tord", toOrderNumber)
  @Concat_Field("@@aord", allOrderNumber)
  @Concat_Field("@@sord", sortOrderNumber)
  @Concat_Field("@@pord", totalOrderNumber)
  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}