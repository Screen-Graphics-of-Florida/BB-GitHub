%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Edit List &nbsp; "
  d2wName                 = "BillingEditListEntry.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editdate(document.Chg.shipDate) &&
                      editdate(document.Chg.recurDate) &&
                      editNum(document.Chg.frLoc, 3, 0) &&
                      editNum(document.Chg.toLoc, 3, 0) &&
                      editFromToAll(document.Chg.frLoc, document.Chg.toLoc, document.Chg.alLoc, 3))
                      return true;
              }
              function confirmNoUpdate() {return confirm("Confirm Cancel Of Edit List Selection")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onkeypress="return event.keyCode!=13">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "BILLINGEDITLISTENTRY")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " OEBIPBW ", fileSQL)
                      @dtw_concat(selectSQL, "WBXHND='$(profileHandle)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Billing_Edit_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) Billing_Edit_Query (IN  CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
  {CALL $(pgmLibrary)HSYSQL_W

      %REPORT{
              <table $(contentTable)>
                  <colgroup>
                      <col width="50%">
                      <col width="45%">
                  <tr><td><h1>$(page_title)</h1></td>
                      <td class="toolbar">
                          <a href="javascript:check(document.Chg)">$(selectAcceptImage)</a>
                          <a onClick="return confirmNoUpdate()" href="$(homeURL)$(cGIPath)$(d2wName)/NOUPDATE$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">$(selectCancelImage)</a>
                          %if (oneOrderType == "")
                              <a href="$(homeURL)$(cGIPath)BillingEditTypeEntry.d2w/INPUT$(genericVarBase)&amp;oneBillCode=@dtw_rurlescseq(oneBillCode)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">$(selectBackImage)</a>
                          %endif
                          @dtw_assign(medIcon, "Y")
                          %INCLUDE "HelpPage.icl"
                      </td>
                  </tr>
              </table>
          $(hrTagAttr)

          <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(d2wVarBase)&amp;oneBillCode=@dtw_rurlescseq(oneBillCode)&amp;oneOrderType=@dtw_rurlescseq(oneOrderType)">

              %ROW{
                  %if (errFound != "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @dtw_assign(focusField, "")
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@stdt", "shipDate")            @dtw_assign(Err_WBSTDT, fieldValue)
                      @DecatErr_Field("@@rodt", "recurDate")           @dtw_assign(Err_WBRODT, fieldValue)
                      @DecatErr_Field("@@floc", "frLoc")               @dtw_assign(Err_WBFLOC, fieldValue)
                      @DecatErr_Field("@@tloc", "companyFacility")     @dtw_assign(Err_WBTLOC, fieldValue)
                      @DecatErr_Field("@@aloc", "accountNumber")       @dtw_assign(Err_WBALOC, fieldValue)

                      @Decat_Field("@@stdt")   @dtw_assign(V_WBSTDT, fieldValue)
                      @Decat_Field("@@rodt")   @dtw_assign(V_WBRODT, fieldValue)
                      @Decat_Field("@@floc")   @dtw_assign(V_WBFLOC, fieldValue)
                      @Decat_Field("@@tloc")   @dtw_assign(V_WBTLOC, fieldValue)
                      @Decat_Field("@@aloc")   @dtw_assign(V_WBALOC, fieldValue)

                      %if (V_WBALOC == "ALL")
                          @dtw_assign(WBALOCChecked, "CHECKED")
                          @dtw_assign(V_WBFLOC, "")
                          @dtw_assign(V_WBTLOC, "")
                      %else
                          @dtw_assign(WBALOCChecked, "")
                      %endif

                      @dtw_assign(errFound, "")
                  %else
                      @DateInputFromCYMD(V_WBSTDT)
                      @DateInputFromCYMD(V_WBRODT)
                      %if (V_WBALOC == "ALL")
                          @dtw_assign(WBALOCChecked, "CHECKED")
                          @dtw_assign(V_WBFLOC, "")
                          @dtw_assign(V_WBTLOC, "")
                      %else
                          @dtw_assign(WBALOCChecked, "")
                      %endif
                      %if (V_WBSHIP == "Y")
                          @dtw_assign(focusField, "shipDate")
                      %elif (V_WBRECU == "Y")
                          @dtw_assign(focusField, "recurDate")
                      %elif (V_WBRECU == "Y")
                          @dtw_assign(focusField, "frLoc")
                      %endif
                  %endif

                  <table $(contentTable)>
                      %if (V_WBSHIP == "Y")
                          @SetTextOvr(Err_WBSTDT)
                          <tr><td class="dsphdr"><span $(textOvr)>Shipments Through</span></td>
                              <td class="inputnmbr"><input type="text" name="shipDate" value="$(V_WBSTDT)" size="6" maxlength="6"> 		
                                  <a href="javascript:calWindow('shipDate');">$(calendarImage)</a></td>
                          </tr>
                          @DspErrMsg(Err_WBSTDT)
                      %else
                          <tr><td class="inputnmbr"><input name="shipDate" type="hidden"></td></tr>
                      %endif

                      %if (V_WBRECU == "Y")
                          @SetTextOvr(Err_WBRODT)
                          <tr><td class="dsphdr"><span $(textOvr)>Recurring Orders Through</span></td>
                              <td class="inputnmbr"><input type="text" name="recurDate" value="$(V_WBRODT)" size="6" maxlength="6"> 		
                                  <a href="javascript:calWindow('recurDate');">$(calendarImage)</a></td>
                          </tr>
                          @DspErrMsg(Err_WBRODT)
                      %else
                          <tr><td class="inputnmbr"><input name="recurDate" type="hidden"></td></tr>
                      %endif
                  </table>

                  <table $(contentTable)>
                      <tr><td>&nbsp;</td>
                          <td class="colhdr">From</td>
                          <td class="colhdr">To</td>
                          <td class="colhdr">All</td>
                      </tr>

                      @SetTextOvr(Err_WBFLOC)
                      %if (textOvr == "") @SetTextOvr(Err_WBTLOC) %endif
                      %if (textOvr == "") @SetTextOvr(Err_WBALOC) %endif
                      <tr><td  class="dsphdr"><span $(textOvr)>Location</span></td>
                          <td class="inputnmbr"><input name="frLoc" value="$(V_WBFLOC)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)LocationSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=frLoc&amp;fldDesc=flocDesc" onclick="$(searchWinVar)">$(searchImage) </a> <input name="flocDesc" type="hidden"></td>
                          <td class="inputnmbr"><input name="toLoc" value="$(V_WBTLOC)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)LocationSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toLoc&amp;fldDesc=tlocDesc" onclick="$(searchWinVar)">$(searchImage) </a> <input name="tlocDesc" type="hidden"></td>
                          <td class="inputalph"><input name="alLoc" value='ALL' $(WBALOCChecked) type="checkbox" onClick="if (this.checked) this.form.frLoc.value='', this.form.toLoc.value='';"></td>
                      </tr>
                      @DspErrMsg(Err_WBFLOC)
                      @DspErrMsg(Err_WBTLOC)
                      @DspErrMsg(Err_WBALOC)
                  </table>
              %}
              %INCLUDE "schedulesubmitquestion.icl"
          </form>
          $(hrTagAttr)
          %INCLUDE "Copyright.icl"
      %}
  %}
%FUNCTION(dtw_directcall) Update_Billing_Edit (IN    CHAR(64)    profileHandle,
                                                     CHAR(2)     dataBaseID,
                                                     CHAR(2)     updCode,
                                               INOUT CHAR(1)     errFound,
                                               INOUT CHAR(32000) edtVar,                             	
                                               INOUT CHAR(32000) errVar)
  {%EXEC {HOEESL_W.PGM %}
%}
%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(UPDATE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @Concat_Field("@@stdt", shipDate)
  @Concat_Field("@@rodt", recurDate)
  @Concat_Field("@@floc", frLoc)
  @Concat_Field("@@tloc", toLoc)
  @Concat_Field("@@aloc", alLoc)
  @Concat_Field("@@scde", submitSchedule)
  @dtw_concat(edtVar, "}{", edtVar)

  @dtw_assign(updCode, "UB")
  @Update_Billing_Edit (profileHandle, dataBaseID, updCode, errFound, edtVar, errVar)

  %if (errFound == "" && submitSchedule == "M")
      %INCLUDE "SubmitScheduleMessage.icl"
      @dtw_assign(updCode, "U ")
      @Update_Billing_Edit (profileHandle, dataBaseID, updCode, errFound, edtVar, errVar)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)billing.d2w/REPORT$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (errFound == "")
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(d2wName)/SCHEDULE$(d2wVarBase)&amp;submitSchedule=@dtw_rurlescseq(submitSchedule)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/ENTRY$(d2wVarBase)&amp;submitSchedule=@dtw_rurlescseq(submitSchedule)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}

%HTML(SCHEDULE) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "$(docType)"
  <html>
      <head>
          @dtw_assign(formName, "Chg")
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              function confirmNoUpdate() {return confirm("Confirm No Update Of Edit")}
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "BILLINGEDITLISTENTRY")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      <table $(contentTable)>
                          <colgroup>
                              <col width="50%">
                              <col width="45%">
                          <tr><td><h1>$(page_title)</h1></td>
                              <td class="toolbar">
                                  <a href="javascript:check(document.Chg)">$(selectAcceptImage)</a>
                                  <a onClick="return confirmNoUpdate()" href="$(homeURL)$(cGIPath)$(d2wName)/NOUPDATE$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">$(selectCancelImage)</a>
                                  <a href="$(homeURL)$(cGIPath)BillingEditListEntry.d2w/ENTRY$(genericVarBase)&amp;oneBillCode=@dtw_rurlescseq(oneBillCode)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">$(selectBackImage)</a>
                              </td>
                          </tr>
                      </table>

                      $(hrTagAttr)
            		
                      <table $(baseTable)>
                          <tr>
                              <td>
                                  <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_SCHEDULE$(d2wVarBase)&amp;submitSchedule=@dtw_rurlescseq(submitSchedule)">
                                      %if (errFound != "")
                                          @EdtVarErr(profileHandle, typeValue, edtVar)
                                          @dtw_assign(focusField, "")
                                          @ErrVarErr(profileHandle, typeError, errVar)
                                          %INCLUDE "scheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                          %INCLUDE "scheduleJobValue.icl"    %{ Schedule Entries Values %}
                                      %endif

                                      @dtw_assign(envProgram, "HOEPEL")
                                      @dtw_assign(envPrinter, "HOEPELPF")
                                      %INCLUDE "schedulejobNS.icl"
                                      $(hrTagAttr)
                                      %INCLUDE "Copyright.icl"
                                      %if (focusField !="")
                                          <script TYPE="text/javascript">
                                              document.Chg.$(focusField).focus();
                                          </script>
                                      %endif
                                  </form>
                              </td>
                          </tr>
                      </table>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(Edit_SCHEDULE) {
  %INCLUDE "setLibraryList.icl"

  @dtw_assign(edtVar, "")
  @Concat_Field("@@scde", submitSchedule)
  %INCLUDE "scheduleJobConcatNS.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @dtw_assign(updCode, "U ")
  @Update_Billing_Edit (profileHandle, dataBaseID, updCode, errFound, edtVar, errVar)

  %if (errFound == "")
      %INCLUDE "SubmitScheduleMessage.icl"
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)billing.d2w/REPORT$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/SCHEDULE$(d2wVarBase)&amp;submitSchedule=@dtw_rurlescseq(submitSchedule)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}

%HTML(NOUPDATE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @dtw_assign(updCode, "D ")
  @Update_Billing_Edit (profileHandle, dataBaseID, updCode, errFound, edtVar, errVar)

  @Format_ConfMsg_Desc("", "Confirm Cancel Of Edit List Selection", "", "", "", "", "", confMessage)
  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)billing.d2w/REPORT$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}