%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Smart Part Segment Definition Maintenance"
  d2wName                 = "SmartPartDefinitionMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;template=@dtw_rurlescseq(template)&amp;templateDesc=@dtw_rurlescseq(templateDesc)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemGroup=@dtw_rurlescseq(itemGroup)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;featuredItem=@dtw_rurlescseq(featuredItem)&amp;feature=@dtw_rurlescseq(feature)&amp;option=@dtw_rurlescseq(option)&amp;segmentNum=@dtw_rurlescseq(segmentNum)&amp;segmentDesc=@dtw_rurlescseq(segmentDesc)&amp;maintenanceCode=D"
  programName             = "HHDSSD_E"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  delBeforeTable          = %table
  delAfterTable           = %table
  delMultipleTable        = %table
%}

%FUNCTION(DTW_SQL) Delimiter_Before (IN  CHAR(64) profileHandle,
			                  CHAR(2)  dataBaseID,
			                  CHAR(10) type,
			  	      OUT   	   delBeforeTable)
			  {call $(pgmLibrary)hsyfvp_w
%}				
%FUNCTION(DTW_SQL) Delimiter_After (IN  CHAR(64) profileHandle,
			                 CHAR(2)  dataBaseID,
			                 CHAR(10) type,
				     OUT    	  delAfterTable)
			  {call $(pgmLibrary)hsyfvp_w
%}				
%FUNCTION(DTW_SQL) Delimiter_Multiple (IN  CHAR(64) profileHandle,
			                    CHAR(2)  dataBaseID,
			                    CHAR(10) type,
				        OUT   	     delMultipleTable)
			  {call $(pgmLibrary)hsyfvp_w
%}
				
%MACRO_FUNCTION SetFieldChecked (IN  field,
                                 OUT checked)
{
  @dtw_assign(checked, "")
  %if (field == "Y")
      @dtw_assign(checked, "CHECKED")
  %endif
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "NoFormValidate.icl"
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "SMARTPARTDEFINITION")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From HDSPSD ", stmtSQL)
                          @dtw_concat(stmtSQL, "Where SGTEMP=$(template)", stmtSQL)
                          @dtw_concat(stmtSQL, " and SGFPRT = '$(featuredItem)'", stmtSQL)
                          @dtw_concat(stmtSQL, " and SGFEAT = '$(feature)'", stmtSQL)
                          @dtw_concat(stmtSQL, " and SGOPTN = '$(option)'", stmtSQL)
                          @dtw_concat(stmtSQL, " and SGSEGN =  $(segmentNum)", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          @Format_Header("Template ID", $(templateDesc), $(template))
          %if (plantNumber > "0")
              @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
              @Format_Header("Plant", $(plantName), $(plantNumber))
          %endif
          %if (itemGroup != "")
              @RtvFldDesc("IGTYPE='F' and IGIGRP='$(itemGroup)'", "HDIGPH", "IGDESC", itemGroupDesc)
              @Format_Header("Feature Family", $(itemGroupDesc), $(itemGroup))
          %endif
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "template")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@fprt", "featureItem")    @dtw_assign(Err_SGFPRT, fieldValue)
                          @DecatErr_Field("@@feat", "feature")        @dtw_assign(Err_SGFEAT, fieldValue)
                          @DecatErr_Field("@@optn", "option")         @dtw_assign(Err_SGOPTN, fieldValue)
                          @DecatErr_Field("@@segn", "segmentNum")     @dtw_assign(Err_SGSEGN, fieldValue)
                          @DecatErr_Field("@@desc", "segmentDesc")    @dtw_assign(Err_SGDESC, fieldValue)
                          @DecatErr_Field("@@ldlm", "leadDel")        @dtw_assign(Err_SGLDLM, fieldValue)
                          @DecatErr_Field("@@tdlm", "trailDel")       @dtw_assign(Err_SGTDLM, fieldValue)
                          @DecatErr_Field("@@mdlm", "multDel")        @dtw_assign(Err_SGMDLM, fieldValue)
                          @DecatErr_Field("@@smpt", "smartPart")      @dtw_assign(Err_SGSMPT, fieldValue)
                          @DecatErr_Field("@@dopt", "dftOption")      @dtw_assign(Err_SGDOPT, fieldValue)
                          @DecatErr_Field("@@alph", "alphDft")        @dtw_assign(Err_SGALPH, fieldValue)
                          @DecatErr_Field("@@tbln", "tableName")      @dtw_assign(Err_SGTBLN, fieldValue)
                          @DecatErr_Field("@@coln", "columnName")     @dtw_assign(Err_SGCOLN, fieldValue)
                          @DecatErr_Field("@@scrp", "screenPrompt")   @dtw_assign(Err_SGSCRP, fieldValue)
                          @DecatErr_Field("@@exit", "exitProg")       @dtw_assign(Err_SGEXIT, fieldValue)
                          @DecatErr_Field("@@valu", "segValue")       @dtw_assign(Err_SGVALU, fieldValue)
                          @DecatErr_Field("@@bdlm", "blankDel")       @dtw_assign(Err_SGBDLM, fieldValue)
                          @DecatErr_Field("@@bdft", "blankDft")       @dtw_assign(Err_SGBDFT, fieldValue)
                      %endif

                      @Decat_Field("@@fprt")   @dtw_assign(V_SGFPRT, fieldValue)
                      @Decat_Field("@@feat")   @dtw_assign(V_SGFEAT, fieldValue)
                      @Decat_Field("@@optn")   @dtw_assign(V_SGOPTN, fieldValue)
                      @Decat_Field("@@segn")   @dtw_assign(V_SGSEGN, fieldValue)
                      @Decat_Field("@@desc")   @dtw_assign(V_SGDESC, fieldValue)
                      @Decat_Field("@@repl")   @dtw_assign(V_SGREPL, fieldValue)
                      @Decat_Field("@@ldlm")   @dtw_assign(V_SGLDLM, fieldValue)
                      @Decat_Field("@@tdlm")   @dtw_assign(V_SGTDLM, fieldValue)
                      @Decat_Field("@@mdlm")   @dtw_assign(V_SGMDLM, fieldValue)
                      @Decat_Field("@@smpt")   @dtw_assign(V_SGSMPT, fieldValue)
                      @Decat_Field("@@dopt")   @dtw_assign(V_SGDOPT, fieldValue)
                      @Decat_Field("@@alph")   @dtw_assign(V_SGALPH, fieldValue)
                      @Decat_Field("@@tbln")   @dtw_assign(V_SGTBLN, fieldValue)
                      @Decat_Field("@@coln")   @dtw_assign(V_SGCOLN, fieldValue)
                      @Decat_Field("@@scrp")   @dtw_assign(V_SGSCRP, fieldValue)
                      @Decat_Field("@@exit")   @dtw_assign(V_SGEXIT, fieldValue)
                      @Decat_Field("@@bdlm")   @dtw_assign(V_SGBDLM, fieldValue)
                      @Decat_Field("@@bdft")   @dtw_assign(V_SGBDFT, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "featuredItem")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "segmentNum")
                  %else
                      @dtw_assign(focusField, "segmentDesc")
                  %endif

                  @dtw_assign(featuredItemDesc, "")
                  @dtw_assign(featureDesc, "")
                  @dtw_assign(optionDesc, "")
                  @RtvFldDesc("IMITEM='$(V_SGFPRT)'", "HDIMST", "IMIMDS", featuredItemDesc)
                  @RtvFldDesc("FOPLT=$(plantNumber) and FOFPRT='$(V_SGFPRT)' and FOFEAT='$(V_SGFEAT)'", "HDMFOP", "FOFDSC", featureDesc)
                  %if (featureDesc == "")
                      @RtvFldDesc("FOPLT=$(plantNumber) and FOFPRT='' and FOFEAT='$(V_SGFEAT)'", "HDMFOP", "FOFDSC", featureDesc)
                  %endif
                  @RtvFldDesc("IMITEM='$(V_SGOPTN)'", "HDIMST", "IMIMDS", optionDesc)
                  @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)

                  @SetTextOvr(Err_SGFPRT)
                  <tr><td class="dsphdr"><span $(textOvr)>Featured Item</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="featuredItem" type="text" value="$(V_SGFPRT)" size="15" maxlength="15"><a href="$(homeURL)$(cGIPath)itemplantsearch.d2w/ENTRY$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;docName=Chg&amp;fldPlant=plantNumber&amp;fldPltName=plantName&amp;fldName=featuredItem&amp;fldDesc=featuredItemDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="featuredItemDesc" value="$(featuredItemDesc)"  type="text" size="30" maxlength="30"></td>
                      %else
                          <td class="inputalph"><input name="featuredItem" type="hidden" value="$(V_SGFPRT)" size="15" maxlength="15">$(V_SGFPRT) &nbsp; $(featuredItemDesc)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_SGFPRT)

                  @SetTextOvr(Err_SGFEAT)
                  <tr><td class="dsphdr"><span $(textOvr)>Feature</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="feature" type="text" value="$(V_SGFEAT)" size="15" maxlength="15"><input name="featureDesc" type="hidden" value="$(featureDesc)">$(featureDesc)</td>
                      %else
                          <td class="inputalph"><input name="feature" type="hidden" value="$(V_SGFEAT)" size="15" maxlength="15">$(V_SGFEAT) &nbsp; $(featureDesc)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_SGFEAT)

                  @SetTextOvr(Err_SGOPTN)
                  <tr><td class="dsphdr"><span $(textOvr)>Option</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="option" type="text" value="$(V_SGOPTN)" size="15" maxlength="15"><a href="$(homeURL)$(cGIPath)itemplantsearch.d2w/ENTRY$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;docName=Chg&amp;fldName=option&amp;fldDesc=optionDesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input disabled name="optionDesc" value="$(optionDesc)"  type="text" size="30" maxlength="30"></td>
                      %else
                          <td class="inputalph"><input name="option" type="hidden" value="$(V_SGOPTN)" size="15" maxlength="15">$(V_SGOPTN) &nbsp; $(optionDesc)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_SGOPTN)

                  @SetTextOvr(Err_SGSEGN)
                  <tr><td class="dsphdr"><span $(textOvr)>Segment</span></td>
                      @dtw_assign(cnt, "0")
                      <td class="inputalph">
                          %if (maintenanceCode == "A" || maintenanceCode == "Z")
                              <select class="page" name="segmentNum">
                                  %while(@dtw_rformat(cnt, "2", "1") <= "99"){
                                      @dtw_add(cnt, "1", cnt)
                                      %if (cnt == V_SGSEGN)
                                          <option value="$(cnt)" SELECTED>$(cnt)
                                      %else
                                          <option value="$(cnt)">$(cnt)
                                      %endif
                                  %}
                              </select> $(reqFieldChar)
                          %else
                              <input name="segmentNum" type="hidden" value="$(V_SGSEGN)" >$(V_SGSEGN)
                          %endif
                      </td>
                  </tr>
                  @DspErrMsg(Err_SGSEGN)

                  @SetTextOvr(Err_SGDESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="segmentDesc" type="text" value="$(V_SGDESC)" size="35" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_SGDESC)

                  @SetTextOvr(Err_SGREPL)
                  <tr><td class="dsphdr"><span $(textOvr)>Replace Data</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_SGREPL) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "allowReplace", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_SGREPL)

                  <tr>
                      <td colspan="2">
                          <fieldset class="legendBody">
                          <legend class="legendTitle">Delimiters</legend>
                          <table $(contentTable)>
                              @SetTextOvr(Err_SGLDLM)
                              <tr><td class="dsphdr"><span $(textOvr)>Before</span></td>
                                  @dtw_tb_rows(delBeforeTable, maxRows)
                                  @dtw_assign(x, "1")
                                  %while((@dtw_tb_rgetv(delBeforeTable, x, "1") != V_SGLDLM) && (x < maxRows)) {@dtw_add(x, "1", x)%}
                                  <td>@dtw_tb_select(delBeforeTable, "leadDel", "2", "1", "N", "", x, "1")</td>
                              </tr>
                              @DspErrMsg(Err_SGLDLM)

                              @SetTextOvr(Err_SGTDLM)
                              <tr><td class="dsphdr"><span $(textOvr)>After</span></td>
                                  @dtw_tb_rows(delAfterTable, maxRows)
                                  @dtw_assign(x, "1")
                                  %while((@dtw_tb_rgetv(delAfterTable, x, "1") != V_SGTDLM) && (x < maxRows)) {@dtw_add(x, "1", x)%}
                                  <td>@dtw_tb_select(delAfterTable, "trailDel", "2", "1", "N", "", x, "1")</td>
                              </tr>
                              @DspErrMsg(Err_SGTDLM)

                              @SetTextOvr(Err_SGMDLM)
                              <tr><td class="dsphdr"><span $(textOvr)>Multiple Options</span></td>
                                  @dtw_tb_rows(delMultipleTable, maxRows)
                                  @dtw_assign(x, "1")
                                  %while((@dtw_tb_rgetv(delMultipleTable, x, "1") != V_SGMDLM) && (x < maxRows)) {@dtw_add(x, "1", x)%}
                                  <td>@dtw_tb_select(delMultipleTable, "multDel", "2", "1", "N", "", x, "1")</td>
                              </tr>
                              @DspErrMsg(Err_SGMDLM)
                          </table>
                          </fieldset>
                      </td>
                  </tr>

                  <tr>
                      <td colspan="6">
                          <fieldset class="legendBody">
                          <legend class="legendTitle">Retrieve Segment Value From (Select Only One)</legend>
                          <table $(contentTable)>
                              @DspErrMsg(Err_SGVALU)

                              @SetFieldChecked(V_SGSMPT, checked)
                              @SetTextOvr(Err_SGSMPT)
                              <tr><td class="dsphdr"><span $(textOvr)>Smart Part Code</span></td>
                                  <td class="dspalph"><input type="checkbox" name="smartPart" value="Y" $(checked)></td>
                              </tr>
                              @DspErrMsg(Err_SGSMPT)

                              @SetFieldChecked(V_SGDOPT, checked)
                              @SetTextOvr(Err_SGDOPT)
                              <tr><td class="dsphdr"><span $(textOvr)>Option</span></td>
                                  <td class="dspalph"><input type="checkbox" name="dftOption" value="Y" $(checked)></td>
                              </tr>
                              @DspErrMsg(Err_SGDOPT)

                              @SetTextOvr(Err_SGALPH)
                              <tr><td class="dsphdr"><span $(textOvr)>Assigned Value</span></td>
                                  <td class="inputnmbr"><input name="alphDft" type="text" value="@dtw_rqhtmlencode($(V_SGALPH))" size="15" maxlength="30"></td>
                              </tr>
                              @DspErrMsg(Err_SGALPH)

                              @SetTextOvr(Err_SGTBLN)
                              @SetTextOvr(Err_SGCOLN)
                              <tr><td class="dsphdr"><span $(textOvr)>Table/Column Name</span></td>
                                  <td class="inputalph"><input name="tableName" type="text" value="$(V_SGTBLN)" size="15" maxlength="130"> / <input name="columnName" type="text" value="$(V_SGCOLN)" size="15" maxlength="130"></td>
                              </tr>
                              @DspErrMsg(Err_SGTBLN)
                              @DspErrMsg(Err_SGCOLN)

                              @SetTextOvr(Err_SGSCRP)
                              <tr><td class="dsphdr"><span $(textOvr)>Screen Prompt</span></td>
                                  <td class="inputalph"><input name="screenPrompt" type="text" value="$(V_SGSCRP)" size="38" maxlength="50"></td>
                              </tr>
                              @DspErrMsg(Err_SGSCRP)

                              @SetTextOvr(Err_SGEXIT)
                              <tr><td class="dsphdr"><span $(textOvr)>Exit Program</span></td>
                                  <td class="inputalph"><input name="exitProg" type="text" value="$(V_SGEXIT)" size="15" maxlength="10"></td>
                              </tr>
                              @DspErrMsg(Err_SGEXIT)
                          </table>
                          </fieldset>
                      </td>
                  </tr>

                  <tr>
                      <td colspan="2">
                          <fieldset class="legendBody">
                          <legend class="legendTitle">Apply If Segment Blank</legend>
                          <table $(contentTable)>
                              @SetTextOvr(Err_SGBDLM)
                              <tr><td class="dsphdr"><span $(textOvr)>Before</span></td>
                                  @dtw_tb_rows(delBeforeTable, maxRows)
                                  @dtw_assign(x, "1")
                                  %while((@dtw_tb_rgetv(delBeforeTable, x, "1") != V_SGBDLM) && (x < maxRows)) {@dtw_add(x, "1", x)%}
                                  <td>@dtw_tb_select(delBeforeTable, "blankDel", "2", "1", "N", "", x, "1")</td>
                              </tr>
                              @DspErrMsg(Err_SGBDLM)

                              @SetTextOvr(Err_SGBDFT)
                              <tr><td class="dsphdr"><span $(textOvr)>Assigned Value</span></td>
                                  <td class="inputnmbr"><input name="blankDft" type="text" value="@dtw_rqhtmlencode($(V_SGBDFT))" size="15" maxlength="30"></td>
                              </tr>
                              @DspErrMsg(Err_SGBDFT)
                          </table>
                          </fieldset>
                      </td>
                  </tr>
              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(10)    userProfile,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDSSD_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @yn01_Table_Query(profileHandle, dataBaseID, "BY        ", yn01Table)
      @Delimiter_Before(profileHandle, dataBaseID, "SEGMENTDEL", delBeforeTable)
      @Delimiter_After(profileHandle, dataBaseID, "SEGMENTDEL", delAfterTable)
      @Delimiter_Multiple(profileHandle, dataBaseID, "SEGMENTDEL", delMultipleTable)
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(featuredItem)
  @dtw_mUPPERCASE(feature)
  @dtw_mUPPERCASE(option)
  @dtw_mUPPERCASE(tableName)
  @dtw_mUPPERCASE(columnName)
  @dtw_mUPPERCASE(exitProg)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@temp", template)
  @Concat_Field("@@fprt", featuredItem)
  @Concat_Field("@@feat", feature)
  @Concat_Field("@@optn", option)
  @Concat_Field("@@segn", segmentNum)
  @Concat_Field("@@desc", segmentDesc)
  @Concat_Field("@@repl", allowReplace)
  @Concat_Field("@@ldlm", leadDel)
  @Concat_Field("@@tdlm", trailDel)
  @Concat_Field("@@mdlm", multDel)
  @Concat_Field("@@aisb", applyIfBlank)
  @Concat_Field("@@smpt", smartPart)
  @Concat_Field("@@dopt", dftOption)
  @Concat_Field("@@alph", alphDft)
  @Concat_Field("@@tbln", tableName)
  @Concat_Field("@@coln", columnName)
  @Concat_Field("@@scrp", screenPrompt)
  @Concat_Field("@@exit", exitProg)
  @Concat_Field("@@bdlm", blankDel)
  @Concat_Field("@@bdft", blankDft)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(userProfile, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(segmentDesc), $(segmentNum), "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)SmartPartDefinition.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@desc", "templateDesc")
      @Format_ConfMsg_Desc("", $(templateDesc), $(template), $(plantName), $(template), "<br>$(fieldValue)", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)SmartPartDefinition.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;featuredItem=@dtw_rurlescseq(featuredItem)&amp;feature=@dtw_rurlescseq(feature)&amp;option=@dtw_rurlescseq(option)&amp;segmentNum=@dtw_rurlescseq(segmentNum)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
