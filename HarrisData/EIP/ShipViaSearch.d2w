%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Ship Via Search"
  d2wName                 = "ShipViaSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
  advanceSearch           = "N"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectShipVia(shipViaCode, desc){
                  window.opener.document.$(docName).$(fldName).value = shipViaCode;
                  window.opener.document.$(docName).$(fldDesc).value = desc;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select SVSVSV, SVSVDS, upper(SVSVDS) as SVSVDSU, SVSCAC, SVBOLR ", stmtSQL)
                      @dtw_concat(fileSQL, " HDSHPV ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, "SVSVSV<>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Ship_Via_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Ship_Via_Search (IN  CHAR(64) profileHandle,
				         CHAR(2)   dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr"> Description</th>
                  <th class="colhdr"> Ship Via <br> Code</th>
              </tr>
              <tr><td class="inputalph">
                      <input type="text" name="srchDesc" size="30" maxlength="30">
                      <input type="hidden" name="operDesc" value="LIKE">
                  </td>
                  <td class="inputalph">
                      <input type="text" name="srchShipVia" size="4" maxlength="4">
                      <input type="hidden" name="operShipVia" value="LIKE">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
          <script TYPE="text/javascript">
              document.Search.srchDesc.focus();
          </script>
      </form>

      %INCLUDE "WildCardPage.icl"

      <table $(contentTable)>
          <tr>	
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("SVSVDSU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=description" title="Sequence By Description, Ship Via Code"> Description</a></th>
              @OrderBy_Sort("SVSVSV", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=shipViaCode" title="Sequence By Ship Via Code, Description"> Ship Via <br> Code</a></th>
              @OrderBy_Sort("SVSCAC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SCAC" title="Sequence By SCAC, Ship Via Code"> SCAC</a></th>
              @OrderBy_Sort("SVBOLR", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BOL" title="Sequence By BOL Required, Ship Via Code"> BOL <br> Required</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
               @Format_Quote(V_SVSVSV, F_SVSVSV)
               @Format_Quote(V_SVSVDS, F_SVSVDS)

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="javascript:selectShipVia('$(F_SVSVSV)', '$(F_SVSVDS)')" title="Select Ship Via Code">$(V_SVSVDS)</a></td>
                  <td class="colalph">$(V_SVSVSV)</td>
                  <td class="colalph">$(V_SVSCAC)</td>
                  <td class="colcode">$(V_SVBOLR)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "SVSVDSU,SVSVSV")
      @DTW_ASSIGN(orderByDisplay, "Description, Ship Via")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "description")
      %if (orderBy == "SVSVDSU,SVSVSV")
          @DTW_ASSIGN(orderBy, "SVSVDSU DESC,SVSVSV")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Ship Via")
      %else
          @DTW_ASSIGN(orderBy, "SVSVDSU,SVSVSV")
          @DTW_ASSIGN(orderByDisplay, "Description, Ship Via")
      %endif
  %elseif (sequence == "shipViaCode")
      %if (orderBy == "SVSVSV")
          @DTW_ASSIGN(orderBy, "SVSVSV DESC")
          @DTW_ASSIGN(orderByDisplay, "Ship Via (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SVSVSV")
          @DTW_ASSIGN(orderByDisplay, "Ship Via")
      %endif
  %elseif (sequence == "SCAC")
      %if (orderBy == "SVSCAC,SVSVSV")
          @DTW_ASSIGN(orderBy, "SVSCAC DESC,SVSVSV")
          @DTW_ASSIGN(orderByDisplay, "Standard Carrier Alpha Code (descending), Ship Via")
      %else
          @DTW_ASSIGN(orderBy, "SVSCAC,SVSVSV")
          @DTW_ASSIGN(orderByDisplay, "Standard Carrier Alpha Code, Ship Via")
      %endif
  %elseif (sequence == "BOL")
      %if (orderBy == "SVBOLR,SVSVSV")
          @DTW_ASSIGN(orderBy, "SVBOLR DESC,SVSVSV")
          @DTW_ASSIGN(orderByDisplay, "Bill Of Lading Required (descending), Ship Via")
      %else
          @DTW_ASSIGN(orderBy, "SVBOLR,SVSVSV")
          @DTW_ASSIGN(orderByDisplay, "Bill Of Lading Required, Ship Via")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("upper(SVSVDS)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("SVSVSV", "Ship Via", $(srchShipVia), "U", operShipVia, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}