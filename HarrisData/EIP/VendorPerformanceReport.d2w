%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Vendor Performance Report"
  d2wName                 = "VendorPerformanceReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if  (editNum(document.Chg.fromVendorNumber, 7, 0) &&
                      editNum(document.Chg.toVendorNumber, 7, 0) &&
                      editFromToAll(document.Chg.fromVendorNumber, document.Chg.toVendorNumber, document.Chg.allVendorNumber, 7) &&
                      editFromToAll(document.Chg.fromVendorType, document.Chg.toVendorType, document.Chg.allVendorType, "A")
                          && editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A")
                          && editNum(document.Chg.fromFiscalYear, 4, 0)
                          && editNum(document.Chg.toFiscalYear, 4, 0)
                          && editFromToAll(document.Chg.fromFiscalYear, document.Chg.toFiscalYear, document.Chg.allFiscalYear, 4)
                          && editdate(document.Chg.fromOrderDate)
                          && editdate(document.Chg.toOrderDate)
                          && editFromToAll(document.Chg.fromOrderDate, document.Chg.toOrderDate, document.Chg.allOrderDate, "D")
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">

                  @dtw_assign(pageID, "PURCHASEVARIANCEREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromVendorNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@frmt", "reportFormat")     @dtw_assign(Err_N1CONT,  fieldValue)
                                  @DecatErr_Field("@@cont", "reportContent")     @dtw_assign(Err_N2CONT,  fieldValue)
                                  @DecatErr_Field("@@fvnd", "fromVendorNumber")          @dtw_assign(Err_N3FVND,  fieldValue)
                                  @DecatErr_Field("@@tvnd", "toVendorNumber")          @dtw_assign(Err_N3TVND,  fieldValue)
                                  @DecatErr_Field("@@avnd", "allVendorNumber")          @dtw_assign(Err_N3AVND,  fieldValue)
                                  @DecatErr_Field("@@fvtp", "fromVendorType")          @dtw_assign(Err_N3FVTP,  fieldValue)
                                  @DecatErr_Field("@@tvtp", "toVendorType")          @dtw_assign(Err_N3TVTP,  fieldValue)
                                  @DecatErr_Field("@@avtp", "allVendorType")          @dtw_assign(Err_N3AVTP,  fieldValue)
                                  @DecatErr_Field("@@fdat", "fromOrderDate")          @dtw_assign(Err_N3FDAT,  fieldValue)
                                  @DecatErr_Field("@@tdat", "toOrderDate")          @dtw_assign(Err_N3TDAT,  fieldValue)
                                  @DecatErr_Field("@@adat", "allOrderDate")          @dtw_assign(Err_N3ADAT,  fieldValue)
                                  @DecatErr_Field("@@ffyr", "fromFiscalYear")          @dtw_assign(Err_N3FFYR,  fieldValue)
                                  @DecatErr_Field("@@tfyr", "toFiscalYear")          @dtw_assign(Err_N3TFYR,  fieldValue)
                                  @DecatErr_Field("@@afyr", "allFiscalYear")          @dtw_assign(Err_N3AFYR,  fieldValue)
                                  @DecatErr_Field("@@fitm", "fromItemNumber")        @dtw_assign(Err_N3FITM,  fieldValue)
                                  @DecatErr_Field("@@titm", "toItemNumber")        @dtw_assign(Err_N3TITM,  fieldValue)
                                  @DecatErr_Field("@@aitm", "allItemNumber")        @dtw_assign(Err_N3AITM,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}

                                  @Decat_Field("@@frmt")  @dtw_assign(V_N1CONT,  fieldValue)
                                  @Decat_Field("@@cont")  @dtw_assign(V_N2CONT,  fieldValue)
                                  @Decat_Field("@@fvnd")  @dtw_assign(V_N3FVND,  fieldValue)
                                  @Decat_Field("@@tvnd")  @dtw_assign(V_N3TVND,  fieldValue)
                                  @Decat_Field("@@avnd")  @dtw_assign(V_N3AVND,  fieldValue)
                                  @Decat_Field("@@fvtp")  @dtw_assign(V_N3FVTP,  fieldValue)
                                  @Decat_Field("@@tvtp")  @dtw_assign(V_N3TVTP,  fieldValue)
                                  @Decat_Field("@@avtp")  @dtw_assign(V_N3AVTP,  fieldValue)
                                  @Decat_Field("@@fdat")  @dtw_assign(V_N3FDAT,  fieldValue)
                                  @Decat_Field("@@tdat")  @dtw_assign(V_N3TDAT,  fieldValue)
                                  @Decat_Field("@@adat")  @dtw_assign(V_N3ADAT,  fieldValue)
                                  @Decat_Field("@@ffyr")  @dtw_assign(V_N3FFYR,  fieldValue)
                                  @Decat_Field("@@tfyr")  @dtw_assign(V_N3TFYR,  fieldValue)
                                  @Decat_Field("@@afyr")  @dtw_assign(V_N3AFYR,  fieldValue)
                                  @Decat_Field("@@fitm")  @dtw_assign(V_N3FITM,  fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N3TITM,  fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N3AITM,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1CONT == "01")
                                      @dtw_assign(byVendor, "CHECKED")
                                      @dtw_assign(byVendorItem, "")
                                      @dtw_assign(byItemVendor, "")
                                      @dtw_assign(reportFormat, "01")
                                  %elif (V_N1CONT == "02")
                                      @dtw_assign(byVendor, "")
                                      @dtw_assign(byVendorItem, "CHECKED")
                                      @dtw_assign(byItemVendor, "")
                                      @dtw_assign(reportFormat, "02")
                                  %else
                                      @dtw_assign(byVendor, "")
                                      @dtw_assign(byVendorItem, "")
                                      @dtw_assign(byItemVendor, "CHECKED")
                                      @dtw_assign(reportFormat, "03")
                                  %endif

                                  %if (V_N2CONT == "01")
                                      @dtw_assign(detail, "CHECKED")
                                      @dtw_assign(summary, "")
                                      @dtw_assign(reportContent, "01")
                                  %else
                                      @dtw_assign(detail, "")
                                      @dtw_assign(summary, "CHECKED")
                                      @dtw_assign(reportContent, "02")
                                  %endif

                                  %if (V_N3AVND == "ALL")
                                      @dtw_assign(checkedallVendorNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallVendorNumber, "")
                                  %endif
                                  %if (V_N3AVTP == "ALL")
                                      @dtw_assign(checkedallVendorType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallVendorType, "")
                                  %endif
                                  %if (V_N3ADAT == "ALL")
                                      @dtw_assign(checkedallOrderDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallOrderDate, "")
                                  %endif
                                  %if (V_N3AITM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_N3AFYR == "ALL")
                                      @dtw_assign(checkedallFiscalYear, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallFiscalYear, "")
                                  %endif
                              %else
                                  @dtw_assign(byVendor, "CHECKED")
                                  @dtw_assign(byVendorItem, "")
                                  @dtw_assign(byItemVendor, "")
                                  @dtw_assign(reportFormat, "01")
                                  @dtw_assign(detail, "CHECKED")
                                  @dtw_assign(summary, "")
                                  @dtw_assign(reportContent, "01")
                                  @dtw_assign(checkedallVendorNumber, "CHECKED")
                                  @dtw_assign(checkedallVendorType, "CHECKED")
                                  @dtw_assign(checkedallOrderDate, "CHECKED")
                                  @dtw_assign(checkedallFiscalYear, "CHECKED")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                              %endif

                              @SetTextOvr(Err_N1CONT)
                              <tr><td  class="dsphdr"><span $(textOvr)>Report Format Selection</span></td>
                                  <td class="inputnmbr"><input name="reportFormat" type="radio" VALUE='01' $(byVendor)>By Vendor</td>
                              </tr>
                              @DspErrMsg(Err_N1CONT)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="reportFormat" type="radio" VALUE='02' $(byVendorItem)>By Vendor/Item</td>
                              </tr>

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="reportFormat" type="radio" VALUE='03' $(byItemVendor)>By Item/Vendor</td>
                              </tr>

                              @SetTextOvr(Err_N2CONT)
                              <tr><td  class="dsphdr"><span $(textOvr)>Report Content Selection</span></td>
                                  <td class="inputnmbr"><input name="reportContent" type="radio" VALUE='01' $(detail)>Detail</td>
                                  @DspErrMsg(Err_N2CONT)
                                  <td><input type="hidden" name="chgContent" value=""></td>
                              </tr>

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="reportContent" type="radio" VALUE='02' $(summary)>Summary</td>
                              </tr>

                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_N3FVND)
                              %if (textOvr == "") @SetTextOvr(Err_N3TVND) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N3AVND) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Vendor Number</span></td>
                                  <td class="inputnmbr"><input name="fromVendorNumber" value="$(V_N3FVND)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="vendorName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toVendorNumber" value="$(V_N3TVND)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="vendorName" type="hidden"></td>
                                  <td class="inputalph"><input name="allVendorNumber" value='ALL' $(checkedallVendorNumber) type="checkbox" onClick="if (this.checked) this.form.fromVendorNumber.value='', this.form.toVendorNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N3FVND)
                              @DspErrMsg(Err_N3TVND)
                              @DspErrMsg(Err_N3AVND)

                              @SetTextOvr(Err_N3FVTP)
                              %if (textOvr == "") @SetTextOvr(Err_N3TVTP) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N3AVTP) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Vendor Type</span></td>
                                  <td class="inputnmbr"><input name="fromVendorType" value="$(V_N3FVTP)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)VendorTypeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromVendorType&amp;fldDesc=vendorTypeDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="vendorTypeDesc" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toVendorType" value="$(V_N3TVTP)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)VendorTypeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toVendorType&amp;fldDesc=vendorTypeDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="vendorTypeDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allVendorType" value='ALL' $(checkedallVendorType) type="checkbox" onClick="if (this.checked) this.form.fromVendorType.value='', this.form.toVendorType.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N3FVTP)
                              @DspErrMsg(Err_N3TVTP)
                              @DspErrMsg(Err_N3AVTP)

                              @SetTextOvr(Err_N3FDAT)
                              %if (textOvr == "") @SetTextOvr(Err_N3TDAT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N3ADAT) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Order Date</span></td>
                                  <td class="inputnmbr"><input name="fromOrderDate" value="$(V_N3FDAT)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromOrderDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toOrderDate" value="$(V_N3TDAT)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toOrderDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allOrderDate" value='ALL' $(checkedallOrderDate) type="checkbox" onClick="if (this.checked) this.form.fromOrderDate.value='', this.form.toOrderDate.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N3FDAT)
                              @DspErrMsg(Err_N3TDAT)
                              @DspErrMsg(Err_N3ADAT)

                              @SetTextOvr(Err_N3FFYR)
                              %if (textOvr == "") @SetTextOvr(Err_N3TFYR) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N3AFYR) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Fiscal Year</span></td>
                                  <td class="inputalph"><input name="fromFiscalYear" value="$(V_N3FFYR)" type="text" size="4" maxlength="4"></td>
                                  <td class="inputalph"><input name="toFiscalYear" value="$(V_N3TFYR)" type="text" size="4" maxlength="4"></td>
                                  <td class="inputalph"><input name="allFiscalYear" value='ALL' $(checkedallFiscalYear) type="checkbox" onClick="if (this.checked) this.form.fromFiscalYear.value='', this.form.toFiscalYear.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N3FFYR)
                              @DspErrMsg(Err_N3TFYR)
                              @DspErrMsg(Err_N3AFYR)

                              @SetTextOvr(Err_N3FITM)
                              %if (textOvr == "") @SetTextOvr(Err_N3TITM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N3AITM) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N3FITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N3TITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N3FITM)
                              @DspErrMsg(Err_N3TITM)
                              @DspErrMsg(Err_N3AITM)
                          </table>

                          %if (V_N1CONT == "01")
                              %if (V_N2CONT == "01")
                                 @dtw_assign(envProgram, "HPOVP1")
                                 @dtw_assign(envPrinter, "HPOVP1PF")
                              %else
                                 @dtw_assign(envProgram, "HPOVP4")
                                 @dtw_assign(envPrinter, "HPOVP4PF")
                              %endif
                          %elif (V_N1CONT == "02")
                                  %if (V_N2CONT == "01")
                                     @dtw_assign(envProgram, "HPOVP2")
                                     @dtw_assign(envPrinter, "HPOVP2PF")
                                  %else
                                     @dtw_assign(envProgram, "HPOVP5")
                                     @dtw_assign(envPrinter, "HPOVP5PF")
                                  %endif
                          %elif (V_N1CONT == "03")
                                  %if (V_N2CONT == "01")
                                     @dtw_assign(envProgram, "HPOVP3")
                                     @dtw_assign(envPrinter, "HPOVP3PF")
                                  %else
                                     @dtw_assign(envProgram, "HPOVP6")
                                     @dtw_assign(envPrinter, "HPOVP6PF")
                                  %endif
                          %endif

                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HPOVPS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allVendorNumber)
  @dtw_mUPPERCASE(fromVendorType)
  @dtw_mUPPERCASE(toVendorType)
  @dtw_mUPPERCASE(allVendorType)
  @dtw_mUPPERCASE(allOrderDate)
  @dtw_mUPPERCASE(allFiscalYear)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)

  @dtw_assign(fromVendorNumber,@dtw_rstrip(fromVendorNumber))
  @dtw_assign(toVendorNumber,@dtw_rstrip(toVendorNumber))
  @dtw_assign(fromOrderDate,@dtw_rstrip(fromOrderDate))
  @dtw_assign(toOrderDate,@dtw_rstrip(toOrderDate))
  @dtw_assign(fromFiscalYear,@dtw_rstrip(fromFiscalYear))
  @dtw_assign(toFiscalYear,@dtw_rstrip(toFiscalYear))

  %if (allVendorNumber != "ALL")
      @dtw_assign(allVendorNumber, "")
  %endif
  %if (allVendorType != "ALL")
      @dtw_assign(allVendorType, "")
  %endif
  %if (allOrderDate != "ALL")
      @dtw_assign(allOrderDate, "")
  %endif
  %if (allFiscalYear != "ALL")
      @dtw_assign(allFiscalYear, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif


  @dtw_assign(edtVar, "")
  @Concat_Field("@@frmt", reportFormat)
  @Concat_Field("@@cont", reportContent)
  @Concat_Field("@@fvnd", fromVendorNumber)
  @Concat_Field("@@tvnd", toVendorNumber)
  @Concat_Field("@@avnd", allVendorNumber)
  @Concat_Field("@@fvtp", fromVendorType)
  @Concat_Field("@@tvtp", toVendorType)
  @Concat_Field("@@avtp", allVendorType)
  @Concat_Field("@@fdat", fromOrderDate)
  @Concat_Field("@@tdat", toOrderDate)
  @Concat_Field("@@adat", allOrderDate)
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@ffyr", fromFiscalYear)
  @Concat_Field("@@tfyr", toFiscalYear)
  @Concat_Field("@@afyr", allFiscalYear)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}