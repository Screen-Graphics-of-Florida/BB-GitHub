%INCLUDE "$(baseVar)"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"

%Define {	
  page_title              = "Color Chart"
  d2wName                 = "ColorChart.d2w"
  DATABASE                = "*LOCAL"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "$(inquiryBanner)"
              <!-- End Of Banner Code -->
                  <table $(baseTable)>
                      <tr valign="top">
                          <td class="content">
                              <table $(contentTable)>
                          	   <colgroup>
                          	       <col width="85%">
                          	       <col width="10%">
                                  <tr><td><h1>$(page_title)</h1></td>
                                      <td class="toolbar">
                                          %INCLUDE "CloseWindow.icl"
                                          @dtw_assign(medIcon, "Y")
                                          %INCLUDE "HelpPage.icl"
                                      </td>
                                  </tr>
                              </table>
                              $(inquiryhrTagAttr)
                              <table $(contentTable)>
                                  <tr>
                                      <td>
                                          <center>
                                              <script TYPE="text/javascript">
                                                  clr=new Array('00','20','40','60','80','A0','C0','FF');
                                                  for (i=0;i<8;i++) {
                                                  document.write("<table border=1 cellpadding=8>");
                                                  for (j=0;j<8;j++) {
                                                  document.write("<tr>");
                                                  for (k=0;k<8;k++) {
                                                  document.write('<td bgcolor="#'+clr[i]+clr[j]+clr[k]+'">');
                                                  document.write('<tt><span STYLE="color: "#'+clr[7-i]+clr[7-j]+clr[7-k]+'"> ');
                                                  document.write(clr[i]+clr[j]+clr[k]+'</span></tt></td>'); }
                                                  document.write("</tr>"); }
                                                  document.write("</table><br>"); }
                                              </script>
                                          </center>
                                      </td>
                                  </tr>
                              </table>
                              $(inquiryhrTagAttr)
                              %INCLUDE "CloseWindow.icl"
                              %INCLUDE "Copyright.icl"
                          </td>
                      </tr>
                  </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "$(inquiryTrailer)"
             <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL()
%}