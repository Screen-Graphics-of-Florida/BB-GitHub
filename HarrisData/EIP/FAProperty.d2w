%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "WildCardAcct.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Property Type"
  d2wName                 = "FAProperty.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HFALCU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script type="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              %INCLUDE "Menu.js"
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchProperty, 3, 0))
                      return true;
              }
           </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "FAPROPERTY")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      @dtw_assign(uv_PropertyTypeName, "PTTYPE")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select FAPROP.*,upper(PTDESC) as PTDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(a.CHCHDS,' ') as AsstCHCHDS, coalesce(a.CHCHDSU,' ') as AsstCHCHDSU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(b.CHCHDS,' ') as AcumCHCHDS, coalesce(b.CHCHDSU,' ') as AcumCHCHDSU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(c.CHCHDS,' ') as ExpsCHCHDS, coalesce(c.CHCHDSU,' ') as ExpsCHCHDSU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(d.CHCHDS,' ') as GainCHCHDS, coalesce(d.CHCHDSU,' ') as GainCHCHDSU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(e.CHCHDS,' ') as CashCHCHDS, coalesce(e.CHCHDSU,' ') as CashCHCHDSU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(f.CHCHDS,' ') as TrnfCHCHDS, coalesce(f.CHCHDSU,' ') as TrnfCHCHDSU  ", stmtSQL)
                      @dtw_concat(fileSQL, " FAPROP ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDCHRT a on a.CHACCT=PTAAAC and a.CHSUB=PTAASU ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDCHRT b on b.CHACCT=PTADAC and b.CHSUB=PTADSU ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDCHRT c on c.CHACCT=PTDEAC and c.CHSUB=PTDESU ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDCHRT d on d.CHACCT=PTGLAC and d.CHSUB=PTGLSU ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDCHRT e on e.CHACCT=PTCAAC and e.CHSUB=PTCASU ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDCHRT f on f.CHACCT=PTTRAC and f.CHSUB=PTTRSU ", fileSQL)
                      %if (wildCardSearch!="" || uv_Sql!="")
                          @dtw_concat(selectSQL, "PTTYPE<>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y" && backHome != "FixedAssetSelect.d2w/REPORT")
                          <a href="$(homeURL)$(cGIPath)FAPropertyMaintain.d2w/MAINTAIN$(genericVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (backHome != "$(d2wName)/REPORT" && backHome != "")
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Description</th>
                      <th class="colhdr">Property Type</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="20" maxlength="26">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchProperty" size="4" maxlength="4">
                          <input type="hidden" name="operProperty" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (backHome != "FixedAssetSelect.d2w/REPORT" && (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y")))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("PTTYPE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Property" title="Sequence By Property Type">Property Type</a></th>
              @OrderBy_Sort("PTDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Description, Property Type">Description</a></th>
              @OrderBy_Sort("PTAAAC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=AssetAccount" title="Sequence By Asset Account, Property Type">Asset Account</a></th>
              @OrderBy_Sort("PTADAC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=AccumAccount" title="Sequence By Accumulated Depreciation Account, Property Type">Accumulated Depreciation Account</a></th>
              @OrderBy_Sort("PTDEAC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DeprAccount" title="Sequence By Depreciation Expense Account, Property Type">Depreciation Expense Account</a></th>
              @OrderBy_Sort("PTGLAC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=GainAccount" title="Sequence By Gain/Loss Account, Property Type">Gain/Loss Account</a></th>
              @OrderBy_Sort("PTCAAC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CashAccount" title="Sequence By Cash or A/R Account, Property Type">Cash or A/R Account</a></th>
              @OrderBy_Sort("PTTRAC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TransferAccount" title="Sequence By Transfer Account, Property Type">Transfer Account</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(genericVarBase)&amp;faProperty=@dtw_rurlescseq(V_PTTYPE)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              @Format_Acct("$(V_PTAAAC)", "$(V_PTAASU)", "", F_PTAAAC)
              @Format_Acct("$(V_PTADAC)", "$(V_PTADSU)", "", F_PTADAC)
              @Format_Acct("$(V_PTDEAC)", "$(V_PTDESU)", "", F_PTDEAC)
              @Format_Acct("$(V_PTGLAC)", "$(V_PTGLSU)", "", F_PTGLAC)
              @Format_Acct("$(V_PTCAAC)", "$(V_PTCASU)", "", F_PTCAAC)
              @Format_Acct("$(V_PTTRAC)", "$(V_PTTRSU)", "", F_PTTRAC)

              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_PTDESC), $(V_PTTYPE), "", "", "", "", confirmDesc)
              <tr class="$(rowClass)">
                  %if (backHome != "FixedAssetSelect.d2w/REPORT" && (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y")))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)FAPropertyMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)FAPropertyMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)FAPropertyMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_PTTYPE)</td>
                  %if (backHome == "FixedAssetSelect.d2w/REPORT")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)FAAsset.d2w/REPORT$(genericVarBase)&amp;passedProperty=@dtw_rurlescseq(V_PTTYPE)" title="View Assets">$(V_PTDESC)</a></td>
                  %else
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)FAPropertySelect.d2w/REPORT$(genericVarBase)&amp;faProperty=@dtw_rurlescseq(V_PTTYPE)" title="View Property Type">$(V_PTDESC)</a></td>
                  %endif
                  <td class="colalph" $(helpCursor)><span title="$(F_PTAAAC)">$(V_AsstCHCHDS)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(F_PTADAC)">$(V_AcumCHCHDS)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(F_PTDEAC)">$(V_ExpsCHCHDS)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(F_PTGLAC)">$(V_GainCHCHDS)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(F_PTCAAC)">$(V_CashCHCHDS)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(F_PTTRAC)">$(V_TrnfCHCHDS)</span></td>
              </tr>
          %}
      </table>
   		
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  @dtw_assign(uv_PropertyTypeName, "PTTYPE")
  %INCLUDE "userview.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select FAPROP.*,upper(PTDESC) as PTDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(a.CHCHDS,' ') as AsstCHCHDS, coalesce(a.CHCHDSU,' ') as AsstCHCHDSU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(b.CHCHDS,' ') as AcumCHCHDS, coalesce(b.CHCHDSU,' ') as AcumCHCHDSU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(c.CHCHDS,' ') as ExpsCHCHDS, coalesce(c.CHCHDSU,' ') as ExpsCHCHDSU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(d.CHCHDS,' ') as GainCHCHDS, coalesce(d.CHCHDSU,' ') as GainCHCHDSU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(e.CHCHDS,' ') as CashCHCHDS, coalesce(e.CHCHDSU,' ') as CashCHCHDSU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(f.CHCHDS,' ') as TrnfCHCHDS, coalesce(f.CHCHDSU,' ') as TrnfCHCHDSU  ", stmtSQL)
  @dtw_concat(fileSQL, " FAPROP ", fileSQL)
  @dtw_concat(fileSQL, " left join HDCHRT a on a.CHACCT=PTAAAC and a.CHSUB=PTAASU ", fileSQL)
  @dtw_concat(fileSQL, " left join HDCHRT b on b.CHACCT=PTADAC and b.CHSUB=PTADSU ", fileSQL)
  @dtw_concat(fileSQL, " left join HDCHRT c on c.CHACCT=PTDEAC and c.CHSUB=PTDESU ", fileSQL)
  @dtw_concat(fileSQL, " left join HDCHRT d on d.CHACCT=PTGLAC and d.CHSUB=PTGLSU ", fileSQL)
  @dtw_concat(fileSQL, " left join HDCHRT e on e.CHACCT=PTCAAC and e.CHSUB=PTCASU ", fileSQL)
  @dtw_concat(fileSQL, " left join HDCHRT f on f.CHACCT=PTTRAC and f.CHSUB=PTTRSU ", fileSQL)
  %if (wildCardSearch!="" || uv_Sql!="")
      @dtw_concat(selectSQL, "PTTYPE<>' ' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_XMLQuery(profileHandle, dataBaseID, stmtSQL)

%}

%FUNCTION(dtw_sql) List_XMLQuery (IN  CHAR(64)    profileHandle,
			               CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("FAPropertyList")
		
          %ROW{
              @XMLIDTag(V_PTTYPE, "FAProperty ID")
                  @XMLTag(V_PTTYPE, "PropertyType")
                  @XMLTag(V_PTDESC, "Description")
                  @XMLTag(V_PTAAAC, "AssetAccount")
                  @XMLTag(V_PTAASU, "AssetSubaccount")
                  @XMLTag(V_PTADAC, "AccumDepreciation Account")
                  @XMLTag(V_PTADSU, "AccumDepreciation Subaccount")
                  @XMLTag(V_PTDEAC, "DeprExpense Account")
                  @XMLTag(V_PTDESU, "DeprExpense Subaccount")
                  @XMLTag(V_PTGLAC, "GainLossAccount")
                  @XMLTag(V_PTGLSU, "GainLossSubaccount")
                  @XMLTag(V_PTCAAC, "CashARAccount")
                  @XMLTag(V_PTCASU, "CashARSubaccount")
                  @XMLTag(V_PTTRAC, "TransfersAccount")
                  @XMLTag(V_PTTRSU, "TransfersSubaccount")
              @XMLEndTag("FAProperty")
	   %}

      @XMLEndTag("FAPropertyList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "PTDESCU,PTTYPE")
          @DTW_ASSIGN(orderByDisplay, "Description, Property Type")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Property")
      %if (orderBy == "PTTYPE")
          @DTW_ASSIGN(orderBy, "PTTYPE DESC")
          @DTW_ASSIGN(orderByDisplay, "Property Type (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PTTYPE")
          @DTW_ASSIGN(orderByDisplay, "Property Type")
      %endif
  %elif (sequence == "Description")
      %if (orderBy == "PTDESCU,PTTYPE")
          @DTW_ASSIGN(orderBy, "PTDESCU DESC,PTTYPE")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Property Type")
      %else
          @DTW_ASSIGN(orderBy, "PTDESCU,PTTYPE")
          @DTW_ASSIGN(orderByDisplay, "Description, Property Type")
      %endif
  %elif (sequence == "AssetAccount")
      %if (orderBy == "PTAAAC,PTAASU,PTTYPE")
          @DTW_ASSIGN(orderBy, "PTAAAC DESC,PTAASU DESC,PTTYPE")
          @DTW_ASSIGN(orderByDisplay, "Asset Account (descending), Property Type")
      %else
          @DTW_ASSIGN(orderBy, "PTAAAC,PTAASU,PTTYPE")
          @DTW_ASSIGN(orderByDisplay, "Asset Account, Property Type")
      %endif
  %elif (sequence == "AccumAccount")
      %if (orderBy == "PTADAC,PTADSU,PTTYPE")
          @DTW_ASSIGN(orderBy, "PTADAC DESC,PTADSU DESC,PTTYPE")
          @DTW_ASSIGN(orderByDisplay, "Accumulated Depreciation Account (descending), Property Type")
      %else
          @DTW_ASSIGN(orderBy, "PTADAC,PTADSU,PTTYPE")
          @DTW_ASSIGN(orderByDisplay, "Accumulated Depreciation Account, Property Type")
      %endif
  %elif (sequence == "DeprAccount")
      %if (orderBy == "PTDEAC,PTDESU,PTTYPE")
          @DTW_ASSIGN(orderBy, "PTDEAC DESC,PTDESU DESC,PTTYPE")
          @DTW_ASSIGN(orderByDisplay, "Depreciation Expense Account (descending), Property Type")
      %else
          @DTW_ASSIGN(orderBy, "PTDEAC,PTDESU,PTTYPE")
          @DTW_ASSIGN(orderByDisplay, "Depreciation Expense Account, Property Type")
      %endif
  %elif (sequence == "GainAccount")
      %if (orderBy == "PTGLAC,PTGLSU,PTTYPE")
          @DTW_ASSIGN(orderBy, "PTGLAC DESC,PTGLSU DESC,PTTYPE")
          @DTW_ASSIGN(orderByDisplay, "Gain/Loss Account (descending), Property Type")
      %else
          @DTW_ASSIGN(orderBy, "PTGLAC,PTGLSU,PTTYPE")
          @DTW_ASSIGN(orderByDisplay, "Gain/Loss Account, Property Type")
      %endif
  %elif (sequence == "CashAccount")
      %if (orderBy == "PTCAAC,PTCASU,PTTYPE")
          @DTW_ASSIGN(orderBy, "PTCAAC DESC,PTCASU DESC,PTTYPE")
          @DTW_ASSIGN(orderByDisplay, "Cash or A/R Account (descending), Property Type")
      %else
          @DTW_ASSIGN(orderBy, "PTCAAC,PTCASU,PTTYPE")
          @DTW_ASSIGN(orderByDisplay, "Cash or A/R Account, Property Type")
      %endif
  %elif (sequence == "TransferAccount")
      %if (orderBy == "PTTRAC,PTTRSU,PTTYPE")
          @DTW_ASSIGN(orderBy, "PTTRAC DESC,PTTRSU DESC,PTTYPE")
          @DTW_ASSIGN(orderByDisplay, "Transfer Account (descending), Property Type")
      %else
          @DTW_ASSIGN(orderBy, "PTTRAC,PTTRSU,PTTYPE")
          @DTW_ASSIGN(orderByDisplay, "Transfer Account, Property Type")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchAcctAA, 4, 0) &&
                      editNum(document.Search.srchSubAA, 4, 0)  &&
                      editNum(document.Search.srchAcctAD, 4, 0) &&
                      editNum(document.Search.srchSubAD, 4, 0)  &&
                      editNum(document.Search.srchAcctDE, 4, 0) &&
                      editNum(document.Search.srchSubDE, 4, 0)  &&
                      editNum(document.Search.srchAcctGL, 4, 0) &&
                      editNum(document.Search.srchSubGL, 4, 0)  &&
                      editNum(document.Search.srchAcctCA, 4, 0) &&
                      editNum(document.Search.srchSubCA, 4, 0)  &&
                      editNum(document.Search.srchAcctTR, 4, 0) &&
                      editNum(document.Search.srchSubTR, 4, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "FAPROPERTYSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Property Type</td>
                              @dtw_assign(operNbr, "operProperty")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchProperty" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="26" maxlength="26"></td>
                          </tr>

                          <tr><td class="dsphdr">Asset Account</td>
                              @dtw_assign(operNbr, "operAcctAA")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchAcctAA" size="4" maxlength="4">
                                                    <input type="text" name="srchSubAA" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Accumulated Depreciation Account</td>
                              @dtw_assign(operNbr, "operAcctAD")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchAcctAD" size="4" maxlength="4">
                                                    <input type="text" name="srchSubAD" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Depreciation Expense Account</td>
                              @dtw_assign(operNbr, "operAcctDE")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchAcctDE" size="4" maxlength="4">
                                                    <input type="text" name="srchSubDE" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Gain/Loss Account</td>
                              @dtw_assign(operNbr, "operAcctGL")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchAcctGL" size="4" maxlength="4">
                                                    <input type="text" name="srchSubGL" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Cash or A/R Account</td>
                              @dtw_assign(operNbr, "operAcctCA")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchAcctCA" size="4" maxlength="4">
                                                    <input type="text" name="srchSubCA" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Transfers Account</td>
                              @dtw_assign(operNbr, "operAcctTR")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchAcctTR" size="4" maxlength="4">
                                                    <input type="text" name="srchSubTR" size="4" maxlength="4"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchProperty.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("PTTYPE", "Property Type", $(srchProperty), "U", operProperty, "A")
  @Build_WildCard ("upper(PTDESC)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard_Acct ("PTAAAC", "PTAASU", "Asset Account", $(srchAcctAA), $(srchSubAA), $(operAcctAA))
  @Build_WildCard_Acct ("PTADAC", "PTADSU", "Accumulated Depreciation Account", $(srchAcctAD), $(srchSubAD), $(operAcctAD))
  @Build_WildCard_Acct ("PTDEAC", "PTDESU", "Depreciation Expense Account", $(srchAcctDE), $(srchSubDE), $(operAcctDE))
  @Build_WildCard_Acct ("PTGLAC", "PTGLSU", "Gain/Loss Account", $(srchAcctGL), $(srchSubGL), $(operAcctGL))
  @Build_WildCard_Acct ("PTCAAC", "PTCASU", "Cash or A/R Account", $(srchAcctCA), $(srchSubCA), $(operAcctCA))
  @Build_WildCard_Acct ("PTTRAC", "PTTRSU", "Transfers Account", $(srchAcctTR), $(srchSubTR), $(operAcctTR))

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
