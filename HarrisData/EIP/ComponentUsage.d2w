%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Component Usage"
  d2wName                 = "ComponentUsage.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;plantName=@dtw_rurlescseq(plantName)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;itemDescription=@dtw_rurlescseq(itemDescription)&amp;openClosed=@dtw_rurlescseq(openClosed)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@plantNumber", "@dtw_rurlescseq(plantNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@itemNumber", "@dtw_rurlescseq(itemNumber)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (plantNumber != "")
      @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
      @dtw_assign(userPass, "Y")
  %else
      @dtw_assign(userPass, "Y")
  %endif

  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Search")
              <script TYPE="text/javascript">
                  %INCLUDE "dateedit.icl"
                  %INCLUDE "Menu.js"
	           %INCLUDE "numedit.icl"
                  %INCLUDE "calendar.icl"
                  %INCLUDE "CheckEnterSearch.icl"
                  function validate(searchForm) {
                      if (editdate(document.Search.srchReqDate))
                          return true;
                  }
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                          @dtw_assign(pageID, "COMPUSAGE")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select CRPPN,CRORD,CRSTC,CRSEQN,CRRQDT,CRRQTY,CRQTYI,CRREAS,CRFSTK,CRSTC, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(IMIMDS,' ') as IMIMDS ", stmtSQL)
                          @dtw_concat(fileSQL, " HDMCRM ", fileSQL)
                          @dtw_concat(fileSQL, " left join HDIMST on CRPPN=IMITEM ", fileSQL)
                          @dtw_concat(selectSQL, " CRCPN='$(itemNumber)' and CRPPLT=$(plantNumber) ", selectSQL)
                          %if (openClosed == "C")
                              @dtw_concat(selectSQL, " and CRSTC='C' ", selectSQL)
                          %else
                              @dtw_concat(selectSQL, " and CRSTC<>'C' ", selectSQL)
                          %endif
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Component_Usage_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Component_Usage_Query (IN CHAR(64)    profileHandle,
                                             CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
	   <colgroup>
	       <col width="80%">
	       <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
                      %if (backURL != "")
                          <a href="$(backURL)" title="BackHome">$(portalHome)</a>
                      %else
                          <a href="$(homeURL)$(cGIPath)ItemPlantSelect.d2w/REPORT$(d2wVarBase)" title="BackHome">$(portalHome)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      <table $(contentTable)>
          @Format_Header_URL("Plant", $(plantName), $(plantNumber), "$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(d2wVarBase)")
          @Format_Header_URL("Component", $(itemDescription), $(itemNumber), "$(homeURL)$(cGIPath)ItemSelect.d2w/REPORT$(d2wVarBase)")
      </table>

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr"> Parent <br> Item</th>
                      <th class="colhdr"> Required <br> Date</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchParent" size="10" maxlength="15">
                          <input type="hidden" name="operParent" value="LIKE">
                      </td>
                      <td><input type="text" class="inputnmbr" name="srchReqDate" size="10" maxlength="6">
                          <a href="javascript:calWindow('srchReqDate');">$(calendarImage)</a>
                          <input type="hidden" name="operReqDate" value="=">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchParent.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              @OrderBy_Sort("CRPPN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=parentItem" title="Sequence By Parent Item">Parent<br>Item</a></th>
              @OrderBy_Sort("IMIMDS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=parentDesc" title="Sequence By Parent Description">Parent<br>Description</a></th>
              @OrderBy_Sort("CRORD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=mfgOrder" title="Sequence By Order Number">Order<br>Number</a></th>
              @OrderBy_Sort("CRSEQN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=rtgSeqn" title="Sequence By Routing Sequence">Rtg<br>Seqn</a></th>
              @OrderBy_Sort("CRRQDT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=requireDate" title="Sequence By Required Date">Required<br>Date</a></th>
              @OrderBy_Sort("CRRQTY", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=qtyRequired" title="Sequence By Quantity Required">Quantity<br>Required</a></th>
              @OrderBy_Sort("CRQTYI", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=qtyIssued" title="Sequence By Quantity Issued">Quantity<br>Issued</a></th>
              @OrderBy_Sort("CRREAS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=reasonCode" title="Sequence By Reason Code">R<br>C</a></th>
              @OrderBy_Sort("CRFSTK", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=backflushCode" title="Sequence By Backflush Code">Bkf<br>Code</a></th>
              @OrderBy_Sort("CRSTC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=status" title="Sequence By Status">Status</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{

              %INCLUDE "SetRowClass.icl"
              @Format_Date(V_CRRQDT, "D", F_CRRQDT)
              @Format_Nbr(V_CRRQTY, F_CRRQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr(V_CRQTYI, F_CRQTYI, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @RtvFldDesc("(FLTYPE='BACKFLUSH' and FLVALU='$(V_CRFSTK)')", "SYFLAG", "FLDESC", backFlushDesc)
              @RtvFldDesc("OHPLT=$(plantNumber) and OHORD='$(V_CRORD)' ", "HDMOHM", "count(*)", mfgCnt)
              @RtvFldDesc("IPPLT=$(plantNumber) and IPITEM='$(V_CRPPN)' ", "HDIPLT", "count(*)", itemPltCnt)

              <tr class="$(rowClass)">
                  %if (itemPltCnt > "0")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemInquiry.d2w/DISPLAY$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_CRPPN)" onclick="$(inquiryWinVar)" title="Item Quickview">$(V_CRPPN)</a></td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemPlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(V_CRPPN)" title="View Item/Plant">$(V_IMIMDS)</a></td>
                  %else
                      <td class="colalph">$(V_CRPPN)</td>
                      <td class="colalph">$(V_IMIMDS)</td>
                  %endif
                  %if (mfgCnt > "0")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)SelectMfgOrder.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;plantName=@dtw_rurlescseq(plantName)&amp;mfgOrder=@dtw_rurlescseq(V_CRORD)" onclick="$(inquiryWinVar)" title="View Manufacturing Order">$(V_CRORD)</a></td>
                  %else
                      <td class="colalph">$(V_CRORD)</td>
                  %endif
                  <td class="colnmbr">$(V_CRSEQN)</td>
                  <td class="coldate">$(F_CRRQDT)</td>
                  <td class="colnmbr">$(F_CRRQTY)</td>
                  <td class="colnmbr">$(F_CRQTYI)</td>
                  <td class="colalph">$(V_CRREAS)</td>
                  <td class="colcode" $(helpCursor)><span title="$(backFlushDesc)">$(V_CRFSTK)</span></td>
                  <td class="colcode">$(V_CRSTC)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
  @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)

  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "CRPPN,CRRQDT,CRORD")
          @DTW_ASSIGN(orderByDisplay, "Parent Item")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "parentItem")
      %if (orderBy == "CRPPN,CRRQDT,CRORD")
          @DTW_ASSIGN(orderBy, "CRPPN DESC,CRRQDT,CRORD")
          @DTW_ASSIGN(orderByDisplay, "Parent Item (descending), Required Date, Order Number")
      %else
          @DTW_ASSIGN(orderBy, "CRPPN,CRRQDT,CRORD")
          @DTW_ASSIGN(orderByDisplay, "Parent Item, Required Date, Order Number")
      %endif
  %elif (sequence == "parentDesc")
      %if (orderBy == "IMIMDS,CRRQDT,CRORD")
          @DTW_ASSIGN(orderBy, "IMIMDS DESC,CRRQDT,CRORD")
          @DTW_ASSIGN(orderByDisplay, "Parent Description (descending), Required Date, Order Number")
      %else
          @DTW_ASSIGN(orderBy, "IMIMDS,CRRQDT,CRORD")
          @DTW_ASSIGN(orderByDisplay, "Parent Description, Required Date, Order Number")
      %endif
  %elif (sequence == "mfgOrder")
      %if (orderBy == "CRORD")
          @DTW_ASSIGN(orderBy, "CRORD DESC")
          @DTW_ASSIGN(orderByDisplay, "Order Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CRORD")
          @DTW_ASSIGN(orderByDisplay, "Order Number")
      %endif
  %elif (sequence == "rtgSeqn")
      %if (orderBy == "CRSEQN,CRRQDT,CRORD")
          @DTW_ASSIGN(orderBy, "CRSEQN DESC,CRRQDT,CRORD")
          @DTW_ASSIGN(orderByDisplay, "Routing Sequence (descending), Required Date, Order Number")
      %else
          @DTW_ASSIGN(orderBy, "CRSEQN,CRRQDT,CRORD")
          @DTW_ASSIGN(orderByDisplay, "Routing Sequence, Required Date, Order Number")
      %endif
  %elif (sequence == "requireDate")
      %if (orderBy == "CRRQDT,CRORD")
          @DTW_ASSIGN(orderBy, "CRRQDT DESC,CRORD")
          @DTW_ASSIGN(orderByDisplay, "Required Date (descending), Order Number")
      %else
          @DTW_ASSIGN(orderBy, "CRRQDT,CRORD")
          @DTW_ASSIGN(orderByDisplay, "Required Date, Order Number")
      %endif
  %elif (sequence == "qtyRequired")
      %if (orderBy == "CRRQTY,CRRQDT,CRORD")
          @DTW_ASSIGN(orderBy, "CRRQTY DESC,CRRQDT,CRORD")
          @DTW_ASSIGN(orderByDisplay, "Quantity Required (descending), Required Date, Order Number")
      %else
          @DTW_ASSIGN(orderBy, "CRRQTY,CRRQDT,CRORD")
          @DTW_ASSIGN(orderByDisplay, "Quantity Required, Required Date, Order Number")
      %endif
  %elif (sequence == "qtyIssued")
      %if (orderBy == "CRQTYI,CRRQDT,CRORD")
          @DTW_ASSIGN(orderBy, "CRQTYI DESC,CRRQDT,CRORD")
          @DTW_ASSIGN(orderByDisplay, "Quantity Issued (descending), Required Date, Order Number")
      %else
          @DTW_ASSIGN(orderBy, "CRQTYI,CRRQDT,CRORD")
          @DTW_ASSIGN(orderByDisplay, "Quantity Issued, Required Date, Order Number")
      %endif
  %elif (sequence == "reasonCode")
      %if (orderBy == "CRREAS,CRRQDT,CRORD")
          @DTW_ASSIGN(orderBy, "CRREAS DESC,CRRQDT,CRORD")
          @DTW_ASSIGN(orderByDisplay, "Reason Code (descending), Required Date, Order Number")
      %else
          @DTW_ASSIGN(orderBy, "CRREAS,CRRQDT,CRORD")
          @DTW_ASSIGN(orderByDisplay, "Reason Code, Required Date, Order Number")
      %endif
  %elif (sequence == "backflushCode")
      %if (orderBy == "CRFSTK,CRRQDT,CRORD")
          @DTW_ASSIGN(orderBy, "CRFSTK DESC,CRRQDT,CRORD")
          @DTW_ASSIGN(orderByDisplay, "Backflush Code (descending), Required Date, Order Number")
      %else
          @DTW_ASSIGN(orderBy, "CRFSTK,CRRQDT,CRORD")
          @DTW_ASSIGN(orderByDisplay, "Backflush Code, Required Date, Order Number")
      %endif
  %elif (sequence == "status")
      %if (orderBy == "CRSTC,CRRQDT,CRORD")
          @DTW_ASSIGN(orderBy, "CRSTCDESC,CRRQDT,CRORD")
          @DTW_ASSIGN(orderByDisplay, "Status (descending), Required Date, Order Number")
      %else
          @DTW_ASSIGN(orderBy, "CRSTC,CRRQDT,CRORD")
          @DTW_ASSIGN(orderByDisplay, "Status, Required Date, Order Number")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("CRPPN", "Parent Item", $(srchParent), "U", operParent, "A")
  @Build_WildCard ("CRRQDT", "Required Date", $(srchReqDate), "", operReqDate, "D")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}