%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Employee Pay Code Defaults"
  d2wName                 = "EmplPayCodeDefaultsList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;coNumber=@dtw_rurlescseq(coNumber)&amp;facNumber=@dtw_rurlescseq(facNumber)&amp;emplNumber=@dtw_rurlescseq(emplNumber)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPRPDM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}


%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
    %INCLUDE "$(docType)"
    <html>
        <head>
            %INCLUDE "$(headInclude)"
            <script TYPE="text/javascript">
                function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
                %INCLUDE "NumEdit.icl"
                %INCLUDE "CheckEnterSearch.icl"
                %INCLUDE "NoFormValidate.icl"
            </script>
            %INCLUDE "$(genericHead)"
        </head>
        <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
            <!-- Start Of Banner Code -->
            %INCLUDE "banner.icl"
            <!-- End Of Banner Code -->
            <table $(baseTable)>
                <tr valign="top">
                    %if (formatToPrint == "")
                         @dtw_assign(pageID, "EMPLPAYCODEDEFAULTSLIST")
                        <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                    %endif
                    <td class="content">
                        %INCLUDE "stmtSQLClear.icl"
                        @dtw_concat(stmtSQL, " Select C3CODE, C3SEQ, C3HRS, C3OVRT, C3STRT, C3END ", stmtSQL)
                        @dtw_concat(fileSQL, " PREMDF ", fileSQL)
                        @dtw_concat(selectSQL, "C3COMP=$(coNumber) and C3FACL=$(facNumber) and C3EMPL=$(emplNumber) ", selectSQL)
                        %INCLUDE "stmtSQLSelect.icl"
                        @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                        %INCLUDE "stmtSQLEnd.icl"
                        %INCLUDE "stmtSQLTotalRows.icl"
                        @EmplPayCodeDefaultsList_Query(profileHandle, dataBaseID, stmtSQL)
                    </td>
                </tr>
            </table>
            <!-- Start Of Trailer Code -->
            %INCLUDE "trailer.icl"
            <!-- End Of Trailer Code -->
        </body>
    </html>
%}

%FUNCTION(dtw_sql) EmplPayCodeDefaultsList_Query (IN CHAR(64)    profileHandle,
				                      CHAR(2)     dataBaseID,
                                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      <a href="$(homeURL)$(cGIPath)EmplPayCodeDefaults.d2w/REPORT$(genericVarBase)" title="Back Home">$(portalHome)</a>
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)EmplPayCodeDefaultsMaintain.d2w/REPORT$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (sec_04 == "Y")
                          <a href="$(homeURL)$(cGIPath)EmplPayCodeDefaultsMaintain.d2w/COPYALL$(d2wVarBase)&amp;maintenanceCode=Z">$(copyAllImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      <table $(contentTable)>
          @RtvFldDesc("CFCOMP=$(coNumber) and CFFACL=$(facNumber)", "HRCOFC", "CFNAME", coFacDesc)
          @Format_HRCoFac("$(coNumber)", "$(facNumber)", "", F_CoFac)
          @Ret_Format_EmplName(coNumber, facNumber, emplNumber, "", "", "H", F_EmpName)
          @Format_Header("Company/Facility", $(coFacDesc), $(F_CoFac))
          @Format_Header("Employee", $(F_EmpName), $(emplNumber))
      </table>
	
      $(hrTagAttr)	

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Pay Code</th>
                  </tr>

                  <tr>
                      <td><input type="text" class="inputalph" name="srchCode" size="5" maxlength="3">
                          <input type="hidden" name="operCode" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchCode.focus();
              </script>
          </form>
	
          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("C3CODE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Pay Code" title="Sequence By Pay Code"> Pay Code</a></th>
              @OrderBy_Sort("C3SEQ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Seq" title="Sequence By Seq)"> Seq</a></th>	
              <th class="colhdr">Description</th>
              <th class="colhdr">Hr/Unit/Earn.</th>
              <th class="colhdr">O/R Rate</th>
              <th class="colhdr">Start</th>
              <th class="colhdr">End</th>
          </tr>		
          %INCLUDE "NoRecordsFound.icl"

      %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;payCode=@dtw_rurlescseq(V_C3CODE)&amp;sequence=@dtw_rurlescseq(V_C3SEQ)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
                  %INCLUDE "SetRowClass.icl"
                  @RtvFldDesc("C2COMP=$(coNumber) and C2FACL=$(facNumber) and C2CODE='$(V_C3CODE)'", "PRCODE", "C2DESC", payCodeDesc)
                  @Format_Date(V_C3STRT, "D", F_C3STRT)
                  @Format_Date(V_C3END,  "D", F_C3END)
                  @Format_Confirm_Desc("Pay Code", $(V_C3CODE), "", "", "", "", confirmDesc)
                  <tr class="$(rowClass)">
                      %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                          <td class="opticon">
                              %if (sec_02 == "Y" || sec_03 == "Y")
                                  <a href="$(homeURL)$(cGIPath)EmplPayCodeDefaultsMaintain.d2w/REPORT$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                              %endif
                              %if (sec_04 == "Y")
                                  <a href="$(homeURL)$(cGIPath)EmplPayCodeDefaultsMaintain.d2w/REPORT$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                              %endif
                              %if (sec_03 == "Y")
                                  <a onClick="return confirmDelete('$(confirmDesc)')" href=$(homeURL)$(cGIPath)EmplPayCodeDefaultsMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D>$(deleteImageSml)</a>
                              %endif
                          </td>
                      %endif
                      @Format_Nbr($(V_C3OVRT), F_C3OVRT, "5", $(rteEditCode), "", "", "")
                      <td class="colalph"> $(V_C3CODE)</td>
                      <td class="colnmbr"> $(V_C3SEQ)</td>
                      <td class="colalph"> $(payCodeDesc)</td>
                      <td class="colnmbr"> $(V_C3HRS)</td>
                      <td class="colnmbr"> $(F_C3OVRT)</td>
                      <td class="colnmbr"> $(F_C3STRT)</td>
                      <td class="colnmbr"> $(F_C3END)</td>
                  </tr>

	   %}
      </table>

          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
          $(hrTagAttr)
          %INCLUDE "Copyright.icl"

  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "C3COMP, C3FACL, C3EMPL, C3CODE, C3SEQ")
              @DTW_ASSIGN(orderByDisplay, "Co/Fac, Employee, Pay Code, Sequence Number")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Pay Code")
      %if (orderBy == "C3CODE")
          @DTW_ASSIGN(orderBy, "C3CODE DESC")
          @DTW_ASSIGN(orderByDisplay, "Pay Code (descending)")
      %else
          @DTW_ASSIGN(orderBy, "C3CODE")
          @DTW_ASSIGN(orderByDisplay, "Pay Code")
      %endif
  %elseif (sequence == "Seq")
      %if (orderBy == "C3SEQ")
          @DTW_ASSIGN(orderBy, "C3SEQ DESC")
          @DTW_ASSIGN(orderByDisplay, "Sequence (descending)")
      %else
          @DTW_ASSIGN(orderBy, "C3SEQ")
          @DTW_ASSIGN(orderByDisplay, "Sequence")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchSeq, 2, 0) &&
                      editNum(document.Search.srchHUE,  5, 2) &&
                      editNum(document.Search.srchOverrideRate, 6, 5) &&
                      editNum(document.Search.srchStartDate, 6, 0) &&
                      editNum(document.Search.srchEndDate, 6, 0))

                  return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "EMPLPAYCODEDEFAULTSSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"
                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Pay Code</td>
                              @dtw_assign(operNbr, "operCode")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCode" size="5" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Sequence</td>
                              @dtw_assign(operNbr, "operSeq")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchSeq" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Hours/Units/Earnings</td>
                              @dtw_assign(operNbr, "operHUE")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchHUE" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">Override Rate</td>
                              @dtw_assign(operNbr, "operOverrideRate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchOverrideRate" size="13" maxlength="13"></td>
                          </tr>

                          <tr><td class="dsphdr">Start Date</td>
                              @dtw_assign(operNbr, "operStartDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchStartDate" size="6 maxlength="6">
                              <a href="javascript:calWindow('srchStartDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">End Date</td>
                              @dtw_assign(operNbr, "operEndDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchEndDate" size="6 maxlength="6">
                              <a href="javascript:calWindow('srchEndDate');">$(calendarImage)</a></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchCode.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("C3CODE", "Pay Code", $(srchCode), "U", operCode, "A")
  @Build_WildCard ("C3SEQ", "Sequence", $(srchSeq), "", operSeq, "N")
  @Build_WildCard ("C3HRS", "Hours/Units/Earnings", $(srchHUE), "", operHUE, "N")
  @Build_WildCard ("C3OVRT", "Override Rate", $(srchOverrideRate), "", operOverrideRate, "N")
  @Build_WildCard ("C3STRT", "Start Date", $(srchStartDate), "", operStartDate, "D")
  @Build_WildCard ("C3END", "End Date", $(srchEndDate), "", operEndDate, "D")
		
  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}