%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "E-mail/Fax Recipient"
  d2wName                 = "EmailFaxRecipient.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HOEEFM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"	
  advanceSearch           = "N"
  tabID                   = "EMAILFAX"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "OrderEntryConfirm.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "EMAILFAXRECIPIENT")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select EWSEQ, EWDOCT, EWRNAM, EWEMAL, EWFAX, EWBCC, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(EWRNAM) as EWRNAMU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(DODESC,' ') as DODESC, upper(DODESC) as DODESCU  ", stmtSQL)
                      @dtw_concat(fileSQL, " OEEFWK left join HDDOCT on DODOCT=EWDOCT and DOAPID='OE' ", fileSQL)
                      @dtw_concat(selectSQL, "EWOCTL=$(orderControlNumber) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Email_Fax_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Email_Fax_Query (IN CHAR(64)    profileHandle,
				        CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "OrderEntryProgOpt.icl"
      %INCLUDE "OrderEntryTabs.icl"
      %INCLUDE "ConfMessageDisplay.icl"
	
      <div class="quickLinksTop">
          %if (formatToPrint != "Y")
              @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
              %if (sec_01 == "Y")
                  <a href="$(homeURL)$(cGIPath)EmailFaxRecipientMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
              %endif
          %endif
      </div>
      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Recipient Name</th></tr>
                  <tr><td><input type="text" class="inputalph" name="srchName" size="26" maxlength="26">
                          <input type="hidden" name="operName" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchName.focus();
              </script>
          </form>
          %INCLUDE "WildCardPage.icl"
      %endif
			
      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("DODESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Document" title="Sequence By Document, Recipient Name">Document</a></th>
              @OrderBy_Sort("EWRNAMU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Recipient" title="Sequence By Recipient Name, Document">Recipient Name</a></th>
              @OrderBy_Sort("EWEMAL", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Email" title="Sequence By E-mail Address, Document">E-mail Address</a></th>
              @OrderBy_Sort("EWBCC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BCC" title="Sequence By BCC, Document">BCC</a></th>
              @OrderBy_Sort("EWFAX", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Fax" title="Sequence By Fax Number, Document">Fax Number</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"
			
          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;sequenceNumber=@dtw_rurlescseq(V_EWSEQ)&amp;recipientName=@dtw_rurlescseq(V_EWRNAM)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_EWRNAM), $(EWSEQ), "", "", "", "", confirmDesc)
              @EditPhoneNumber(V_EWFAX)
              %if (V_EWBCC == "Y")
                  @dtw_assign(bccImage, checkImage)
              %else
                  @dtw_assign(bccImage, "&nbsp")
              %endif
              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)EmailFaxRecipientMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)EmailFaxRecipientMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)EmailFaxRecipientMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_DODESC)</td>
                  <td class="colalph">$(V_EWRNAM)</td>
                  <td class="colalph">$(V_EWEMAL)</td>
                  <td class="colcode">$(bccImage)</td>
                  <td class="colcode">$(V_EWFAX)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      %INCLUDE "EndTabs.icl"
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "DODESCU, EWRNAMU")
          @DTW_ASSIGN(orderByDisplay, "Document, Recipient Name")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Document")
      %if (orderBy == "DODESCU,EWRNAMU")
          @DTW_ASSIGN(orderBy, "DODESCU DESC,EWRNAMU")
          @DTW_ASSIGN(orderByDisplay, "Document (descending), Recipient Name")
      %else
          @DTW_ASSIGN(orderBy, "DODESCU,EWRNAMU")
          @DTW_ASSIGN(orderByDisplay, "Document")
      %endif
  %elif (sequence == "Recipient")
      %if (orderBy == "EWRNAMU,DODESCU")
          @DTW_ASSIGN(orderBy, "EWRNAMU DESC,DODESCU")
          @DTW_ASSIGN(orderByDisplay, "Recipient Name (descending), Document")
      %else
          @DTW_ASSIGN(orderBy, "EWRNAMU,DODESCU")
          @DTW_ASSIGN(orderByDisplay, "Recipient Name, Document")
      %endif
  %elif (sequence == "Email")
      %if (orderBy == "EWEMAL,DODESCU")
          @DTW_ASSIGN(orderBy, "EWEMAL DESC,DODESCU")
          @DTW_ASSIGN(orderByDisplay, "E-mail Address (descending), Document")
      %else
          @DTW_ASSIGN(orderBy, "EWEMAL,DODESCU")
          @DTW_ASSIGN(orderByDisplay, "E-mail Address, Document")
      %endif
  %elif (sequence == "BCC")
      %if (orderBy == "EWBCC,DODESCU")
          @DTW_ASSIGN(orderBy, "EWBCC DESC,DODESCU")
          @DTW_ASSIGN(orderByDisplay, "BCC (descending), Document")
      %else
          @DTW_ASSIGN(orderBy, "EWBCC,DODESCU")
          @DTW_ASSIGN(orderByDisplay, "BCC, Document")
      %endif
  %elif (sequence == "Fax")
      %if (orderBy == "EWFAX,DODESCU")
          @DTW_ASSIGN(orderBy, "EWFAX DESC,DODESCU")
          @DTW_ASSIGN(orderByDisplay, "Fax Number (descending), Document")
      %else
          @DTW_ASSIGN(orderBy, "EWFAX,DODESCU")
          @DTW_ASSIGN(orderByDisplay, "Fax Number, Document")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("upper(EWRNAM)", "Recipient Name", $(srchName), "U", operName, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
