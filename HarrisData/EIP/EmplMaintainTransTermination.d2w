%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "Employee.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Employee Termination Maintenance"
  d2wName                 = "EmplMaintainTransTermination.d2w"
  d2wVarBase              = "$(genericVarBase)$(employeeVarBase)&amp;sequenceNbr=@dtw_rurlescseq(sequenceNbr)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;forceUpdEmpl=@dtw_rurlescseq(forceUpdEmpl)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=D"
  programName             = "HPEPTE"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  updateEmployee          = ""
  payCheck                = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
  @dtw_replace(workURL, "@@fromD2w", "@dtw_rurlescseq(fromD2w)", "1", "a", workURL)
  @dtw_replace(workURL, "@@sequenceNbr", "@dtw_rurlescseq(sequenceNbr)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
              function confirmDelete() {return confirm("$(delRecordConf)")}              %INCLUDE "NewWindowOpen.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
              	if (document.Chg.reasonCode.value =="" ||
              	document.Chg.eligibleRehire.value =="" ||
              	document.Chg.removeOrgSt.value =="" ||
              	document.Chg.updateEmployee.value =="" ||
              	document.Chg.payCheck.value =="")
              	{alert("$(reqFieldError)"); return false;}
              	if (editdate(document.Chg.transactionDate))
              	return true;
              }
              %INCLUDE "numedit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "EMPLMAINTAINACR")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "SELECT * ", stmtSQL)
                              @dtw_concat(stmtSQL, " FROM PEHIST ", stmtSQL)
                              @dtw_concat(stmtSQL, " WHERE HICOMP=$(hrCompany) and HIEMPL=$(hrEmployee) and HISEQ=$(sequenceNbr)", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Termination_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Termination_Query (IN CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
	   <colgroup>
	       <col width="80%">
	       <col width="15%">
          @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
          <tr><td><h2>$(F_EmpName)</h2></td></tr>
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"		

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "transactionDate")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@trdt", "transactionDate") @dtw_assign(Err_HITRDT, fieldValue)
                          @DecatErr_Field("@@rscd", "reasonCode")      @dtw_assign(Err_HIRSCD, fieldValue)
                          @DecatErr_Field("@@efrh", "eligibleRehire")  @dtw_assign(Err_HIEFRH, fieldValue)
                          @DecatErr_Field("@@rfos", "removeOrgSt")     @dtw_assign(Err_HIRFOS, fieldValue)
                          @DecatErr_Field("@@upem", "updateEmployee")  @dtw_assign(Err_updateEmployee, fieldValue)
                          @DecatErr_Field("@@pyck", "payCheck")        @dtw_assign(Err_payCheck, fieldValue)
                          @DecatErr_Field("@@cmnt", "comment")         @dtw_assign(Err_HICMNT, fieldValue)

                      %endif
                      @Decat_Field("@@trdt")    @dtw_assign(V_HITRDT, fieldValue)
                      @Decat_Field("@@rscd")    @dtw_assign(V_HIRSCD, fieldValue)
                      @Decat_Field("@@efrh")    @dtw_assign(V_HIEFRH, fieldValue)
                      @Decat_Field("@@rfos")    @dtw_assign(V_HIRFOS, fieldValue)
                      @Decat_Field("@@upem")    @dtw_assign(updateEmployee, fieldValue)
                      @Decat_Field("@@pyck")    @dtw_assign(payCheck, fieldValue)
                      @Decat_Field("@@cmnt")    @dtw_assign(V_HICMNT, fieldValue)
                      @Decat_Field("@@tstp")    @dtw_assign(V_HITSTP, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "transactionDate")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "transactionDate")
                  %else
                      @dtw_assign(focusField, "transactionDate")
                      @DateInputFromCYMD(V_HITRDT)
                  %endif
                  
                  
                   %if (maintenanceCode == "A" && forceUpdEmpl == "Y")
                       @DateTodayCYMD(V_HITRDT)
                       @DateInputFromCYMD(V_HITRDT)
                  %endif
                  @SetTextOvr(Err_HITRDT)
	           <tr><td class="dsphdr"><span $(textOvr)>Termination Date</span></td>
                      <td class="inputnmbr"><input type="text" name="transactionDate" value="$(V_HITRDT)" size="6" maxlength="6"> 		
                          <a href="javascript:calWindow('transactionDate');">  $(reqFieldChar) $(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_HITRDT)

                  %if(V_HIRSCD != "")
                      @RtvFldDesc("ODCOMP=$(V_HICOMP) and ODTYPE='T' and ODCODE='$(V_HIRSCD)' ", "PECODE", "CHAR(ODDESC)", codeDesc)
                  %else
                      @dtw_assign(codeDesc, "")
                  %endif
                  @SetTextOvr(Err_HIRSCD)
                  <tr><td class="dsphdr"><span $(textOvr)>Termination Reason</span></td>
                      <td class="inputalph"><input name="reasonCode" type="text" value="$(V_HIRSCD)" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Chg&amp;fldComp=@dtw_rurlescseq(hrCompany)&amp;fldType=T&amp;fldName=reasonCode&amp;fldDesc=reasonDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="reasonDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                  </tr>
                  @DspErrMsg(Err_HIRSCD)

                  
                  @SetTextOvr(Err_HIEFRH)
                  <tr><td class="dsphdr"><span $(textOvr)>Eligible For Rehire</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      %if(forceUpdEmpl == "Y")
                        @dtw_assign(V_HIEFRH, "2")
                        @dtw_assign(x, "2")
                	 %else
                	  @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_HIEFRH) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                    %endif
                      <td>@dtw_tb_select(yn01Table, "eligibleRehire", "2", "1", "N", "", x, "1") $(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_HIEFRH)

                   
                  @SetTextOvr(Err_HIRFOS)
                  <tr><td class="dsphdr"><span $(textOvr)>Remove From Organization Structure</span></td>
                      @dtw_tb_rows(yn02Table, maxRows)
                      %if(forceUpdEmpl == "Y")
                        @dtw_assign(V_HIRFOS, "3")
                        @dtw_assign(x, "3")
                       %else
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn02Table, x, "1") != V_HIRFOS) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      %endif
                      <td>@dtw_tb_select(yn02Table, "removeOrgSt", "2", "1", "N", "", x, "1") $(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_HIRFOS)

                   
                 
                  @SetTextOvr(Err_updateEmployee)
                  <tr><td class="dsphdr"><span $(textOvr)>Update Employee</span></td>
                      @dtw_tb_rows(yn03Table, maxRows)
                      %if(forceUpdEmpl == "Y")
                        @dtw_assign(updateEmployee, "3")
                        @dtw_assign(x, "3")
                        %else
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn03Table, x, "1") != updateEmployee) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                           %endif
                      <td>@dtw_tb_select(yn03Table, "updateEmployee", "2", "1", "N", "", x, "1") $(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_updateEmployee)

                  @SetTextOvr(Err_payCheck)
                  <tr><td class="dsphdr"><span $(textOvr)>Will Employee Get Another Pay Check</span></td>
                      @dtw_tb_rows(yn04Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn04Table, x, "1") != payCheck) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn04Table, "payCheck", "2", "1", "N", "", x, "1") $(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_payCheck)

                  @SetTextOvr(Err_HICMNT)
                  <tr><td class="dsphdr"><span $(textOvr)>Comment</span></td>
                      <td class="inputalph"><input name="comment" type="text" value="$(V_HICMNT)" size="31" maxlength="31"></td>
                  </tr>
                  @DspErrMsg(Err_HICMNT)
                  
                  <tr><td><input name="timeStamp" type="hidden" value="$(V_HITSTP)"></td></tr>
                  
              %}	
          </table>

          <script TYPE="text/javascript">
          document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HPETTR_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F" || sec_14 == "N")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
          @dtw_tb_insertrow(yn01Table, "0", "1")
	   @dtw_tb_setv(yn01Table, "", "1", "2")
      @yn02_Table_Query(profileHandle, dataBaseID, "YORN      ", yn02Table)
          @dtw_tb_insertrow(yn02Table, "0", "1")
	   @dtw_tb_setv(yn02Table, "", "1", "2")
      @yn03_Table_Query(profileHandle, dataBaseID, "YORN      ", yn03Table)
          @dtw_tb_insertrow(yn03Table, "0", "1")
	   @dtw_tb_setv(yn03Table, "", "1", "2")
      @yn04_Table_Query(profileHandle, dataBaseID, "YORN      ", yn04Table)
          @dtw_tb_insertrow(yn04Table, "0", "1")
	   @dtw_tb_setv(yn04Table, "", "1", "2")
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data){
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(reasonCode)
  @dtw_mUPPERCASE(eligibleRehire)
  @dtw_mUPPERCASE(removeOrgSt)
  @dtw_mUPPERCASE(updateEmployee)
  @dtw_mUPPERCASE(payCheck)

  @dtw_assign(transactionDate,@dtw_rstrip(transactionDate))

  @dtw_assign(updateError, " ")

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  %if (maintenanceCode == "A")
      @dtw_assign(sequenceNbr, "0")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@comp", hrCompany)
  @Concat_Field("@@empl", hrEmployee)
  @Concat_Field("@@seq@", sequenceNbr)
  @Concat_Field("@@trdt", transactionDate)
  @Concat_Field("@@rscd", reasonCode)
  @Concat_Field("@@efrh", eligibleRehire)
  @Concat_Field("@@rfos", removeOrgSt)
  @Concat_Field("@@upem", updateEmployee)
  @Concat_Field("@@pyck", payCheck)
  @Concat_Field("@@cmnt", comment)
  @Concat_Field("@@tstp", timeStamp)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
      @Format_ConfMsg_Desc(maintenanceCode, $(F_EmpName), "", "Termination", $(terminationDate), "", "", confMessage)
      %if (maintenanceCode == "D")
          %if ((fromD2w != "") && (fromD2w != "EmplTransSelect.d2w"))
              <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %else
              <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)employeeTransactions.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %endif
      %elif (fromD2w != "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)employeeTransactions.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@trdt", "transactionDate")
      @Format_ConfMsg_Desc("", $(F_EmpName), "", "Termination", "", "<br>$(fieldValue)", "", confMessage)
      %if (fromD2w != "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)employeeTransactions.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif

%}