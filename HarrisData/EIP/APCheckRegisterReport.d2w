%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%INCLUDE "APControl$(dataBaseID).icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%if (V_HDMCRL == "0")
    @dtw_assign(V_CPPRMC, "N")
%endif

%Define {
  page_title              = "A/P Check Register Report"
  d2wName                 = "APCheckRegisterReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"

              function validate(chgForm) {

                  if (document.Chg.detail.checked == false &&
                      document.Chg.condensed.checked == false)
                      {alert("Select Detail, Condensed or both"); return false;}

                  if (document.Chg.fromCheckDate.value =="" ||
                      document.Chg.toCheckDate.value =="")
                      {alert("Select both 'from' and 'to' check Dates");
                      document.Chg.fromCheckDate.focus();
                      document.Chg.fromCheckDate.select();
                      return false;}

                  if  (editdate(document.Chg.fromCheckDate) &&
                      editdate(document.Chg.toCheckDate) &&
                      editFromToAll(document.Chg.fromBankNumber, document.Chg.toBankNumber, document.Chg.allBankNumber, "2") &&
                      editFromTo(document.Chg.fromCheckDate, document.Chg.toCheckDate, "D"))

                      return true;
              }

              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CHECKREGISTERREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromBankNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@det@", "detail") @dtw_assign(Err_N1DET,  fieldValue)
                                  @DecatErr_Field("@@con@", "condensed") @dtw_assign(Err_N1CON,  fieldValue)
                                  @DecatErr_Field("@@fbnk", "fromBankName") @dtw_assign(Err_N1FBNK,  fieldValue)
                                  @DecatErr_Field("@@tbnk", "toBankName") @dtw_assign(Err_N1TBNK,  fieldValue)
                                  @DecatErr_Field("@@abnk", "allBankName") @dtw_assign(Err_N1ABNK,  fieldValue)
                                  @DecatErr_Field("@@fckd", "fromCheckDate") @dtw_assign(Err_N1FCKD,  fieldValue)
                                  @DecatErr_Field("@@tckd", "toCheckDate") @dtw_assign(Err_N1TCKD,  fieldValue)
                                  @DecatErr_Field("@@curt", "currencyType") @dtw_assign(Err_N1CURT,  fieldValue)

                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@det@")  @dtw_assign(V_N1DET,  fieldValue)
                                  @Decat_Field("@@con@")  @dtw_assign(V_N1CON,  fieldValue)
                                  @Decat_Field("@@fbnk")  @dtw_assign(V_N1FBNK,  fieldValue)
                                  @Decat_Field("@@tbnk")  @dtw_assign(V_N1TBNK,  fieldValue)
                                  @Decat_Field("@@abnk")  @dtw_assign(V_N1ABNK,  fieldValue)
                                  @Decat_Field("@@fckd")  @dtw_assign(V_N1FCKD,  fieldValue)
                                  @Decat_Field("@@tckd")  @dtw_assign(V_N1TCKD,  fieldValue)
                                  @Decat_Field("@@curt")  @dtw_assign(V_N1CURT,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1DET == "1")
                                      @dtw_assign(checkedDetail, "CHECKED")
                                  %else
                                      @dtw_assign(checkedDetail, "")
                                  %endif
                                  %if (V_N1CON == "1")
                                      @dtw_assign(checkedCondensed, "CHECKED")
                                  %else
                                      @dtw_assign(checkedCondensed, "")
                                  %endif
                                  %if (V_N1ABNK == "ALL")
                                      @dtw_assign(checkedAllBankNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllBankNumber, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedDetail, "CHECKED")
                                  @dtw_assign(checkedCondensed, "")
                                  @dtw_assign(checkedAllBankNumber, "CHECKED")
                              %endif

                              <tr><td><input type="hidden" name="multiCurrency" value="$(V_CPPRMC)"></td></tr>
                              @SetTextOvr(Err_N1DET)
                              %if (textOvr == "") @SetTextOvr(Err_N1DET) %endif
                                  <tr><td class="dsphdr"><span $(textOvr)>Select Options</span></td>
                                      <td class="inputnmbr"><input type="checkbox" name="detail" VALUE='1' $(checkedDetail)>Detail</td>
                                  </tr>
                                  @DspErrMsg(Err_N1DET)

                                  <tr><td>&nbsp;</td>
                                      <td class="inputnmbr"><input type="checkbox" name="condensed" VALUE='1' $(checkedCondensed)>Condensed</td>
                                  </tr>
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_N1FBNK)
                              %if (textOvr == "") @SetTextOvr(Err_N1TBNK) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ABNK) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Bank</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromBankNumber" value="$(V_N1FBNK)" size="6" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)BankSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromBankNumber&amp;fldDesc=bankName" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="bankName"></td>
                                  <td class="inputnmbr"><input type="text" name="toBankNumber" value="$(V_N1TBNK)" size="6" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)BankSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toBankNumber&amp;fldDesc=bankName" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="bankName"></td>
                                  <td class="inputalph"><input type="checkbox" name="allBankNumber" value='ALL' $(checkedAllBankNumber) onClick="if (this.checked) this.form.fromBankNumber.value='', this.form.toBankNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FBNK)
                              @DspErrMsg(Err_N1TBNK)
                              @DspErrMsg(Err_N1ABNK)

                              @SetTextOvr(Err_N1FCKD)
                              %if (textOvr == "") @SetTextOvr(Err_N1TCKD) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Check Date</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromCheckDate" value="$(V_N1FCKD)" size="6" maxlength="6">
                                                        <a href="javascript:calWindow('fromCheckDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input type="text" name="toCheckDate" value="$(V_N1TCKD)" size="6" maxlength="6">
                                                        <a href="javascript:calWindow('toCheckDate');">$(calendarImage)</a>&nbsp;$(reqFieldChar)</td>
                                  <td><input type="hidden" name="allCheckDate" value=""></td>
                              </tr>
                              @DspErrMsg(Err_N1FCKD)
                              @DspErrMsg(Err_N2TCKD)
                          </table>

                          %if (V_CPPRMC == "Y")
                              <table $(contentTable)>
                                  @SetTextOvr(Err_N1CURT)
                                  <tr><td class="dsphdr"><span $(textOvr)>Convert To Currency Type</span></td>
                                      <td class="inputalph"><input type="text" name="currencyType" value="$(V_N1CURT)" size="3" maxlength="3">
                                                            <a href="$(homeURL)$(phpPath)CurrencyTypeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=currencyType&amp;fldDesc=currencyTypeDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                            <input type="hidden" name="currencyTypeDesc"></td>
                                  </tr>
                                  @DspErrMsg(Err_N1CURT)
                              </table>
                          %endif

                          @dtw_assign(envProgram, "HAPCRG")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                          %if (focusField != "")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HAPCRS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allBankNumber)
  @dtw_mUPPERCASE(currencyTYpe)

  %if (allBankNumber != "ALL")
      @dtw_assign(allBankNumber, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@mult", multiCurrency)
  @Concat_Field("@@det@", detail)
  @Concat_Field("@@con@", condensed)
  @Concat_Field("@@fbnk", fromBankNumber)
  @Concat_Field("@@tbnk", toBankNumber)
  @Concat_Field("@@abnk", allBankNumber)
  @Concat_Field("@@fckd", fromCheckDate)
  @Concat_Field("@@tckd", toCheckDate)
  %if (multiCurrency == "Y")
      @Concat_Field("@@curt", currencyType)
  %endif


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}