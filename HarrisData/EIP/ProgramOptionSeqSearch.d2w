%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Program Option Security Sequence Search"
  d2wName                 = "ProgramOptionSeqSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)&amp;fldSeq=@dtw_rurlescseq(fldSeq)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldSeq                  = ""
  fldDesc                 = ""
  advanceSearch           = "N"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectILEModule(progName, desc, optSeq){
                  window.opener.document.$(docName).$(fldName).value = progName;
                  window.opener.document.$(docName).$(fldDesc).value = desc;
                  window.opener.document.$(docName).$(fldSeq).value = optSeq;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select SYPGMO.*, coalesce(PTDESC,' ') as PTDESC, coalesce(upper(PTDESC),' ') as PTDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " SYPGMO left join SYILET on SOPGID=PTPGID ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, "SOPGID>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"

                      @Prog_Option_Seq_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) Prog_Option_Seq_Search (IN CHAR(64) profileHandle,
				               CHAR(2)   dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"

      $(searchhrTagAttr)
      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr">Program Name</th>
                  <th class="colhdr">Program Description</th>
              </tr>
              <tr><td class="inputalph">
                      <input type="text" name="srchProg" size="10" maxlength="10">
                      <input type="hidden" name="operProg" value="LIKE">
                  </td>
                  <td class="inputalph">
                      <input type="text" name="srchDesc" size="20" maxlength="50">
                      <input type="hidden" name="operDesc" value="LIKE">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
          <script TYPE="text/javascript">
              document.Search.srchProg.focus();
          </script>
      </form>
	
      %INCLUDE "WildCardPage.icl"

      <table $(contentTable)>
          <tr>	
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("SOPGID", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Prog" title="Sequence By Program Name">Program<br>Name</a></th>
              @OrderBy_Sort("PTDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description, Program Name">Program<br>Description</a></th>
              @OrderBy_Sort("SOMOPT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=OptSeq" title="Sequence By Option, Program Name">Option</a></th>
              @OrderBy_Sort("SOMDES", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=OptDesc" title="Sequence By Option Description, Program Name">Option<br>Description</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Quote(V_SOPGID, F_SOPGID)
              @Format_Quote(V_PTDESC, F_PTDESC)
              @Format_Quote(V_SOMOPT, F_SOMOPT)

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="javascript:selectILEModule('$(F_SOPGID)', '$(F_PTDESC)', '$(F_SOMOPT)')" title="Select Program Name">$(V_SOPGID)</a></td>
                  <td class="colalph"> $(V_PTDESC)</td>
                  <td class="colcode">$(V_SOMOPT)</td>
                  <td class="colalph">$(V_SOMDES)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "SOPGID,PTDESCU")
      @DTW_ASSIGN(orderByDisplay, "Program Name, Description")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY)  {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "ILEModule")
      %if (orderBy == "SOPGID")
          @DTW_ASSIGN(orderBy, "SOPGID DESC")
          @DTW_ASSIGN(orderByDisplay, "Program Name (optSeqending)")
      %else
          @DTW_ASSIGN(orderBy, "SOPGID")
          @DTW_ASSIGN(orderByDisplay, "Program Name")
      %endif
  %elif (sequence == "ILEDesc")
      %if (orderBy == "PTDESCU,SOPGID")
          @DTW_ASSIGN(orderBy, "PTDESCU DESC,SOPGID")
          @DTW_ASSIGN(orderByDisplay, "Description (optSeqending), Program Name")
      %else
          @DTW_ASSIGN(orderBy, "PTDESCU,SOPGID")
          @DTW_ASSIGN(orderByDisplay, "Description, Program Name")
      %endif
  %elif (sequence == "ILEType")
      %if (orderBy == "SOMOPT,SOPGID")
          @DTW_ASSIGN(orderBy, "SOMOPT DESC,SOPGID")
          @DTW_ASSIGN(orderByDisplay, "ILE Type (optSeqending), Program Name")
      %else
          @DTW_ASSIGN(orderBy, "SOMOPT,SOPGID")
          @DTW_ASSIGN(orderByDisplay, "ILE Type, Program Name")
      %endif
  %elif (sequence == "ActGrp")
      %if (orderBy == "SOMDES,SOPGID")
          @DTW_ASSIGN(orderBy, "SOMDES DESC,SOPGID")
          @DTW_ASSIGN(orderByDisplay, "Activation Group (optSeqending), Program Name")
      %else
          @DTW_ASSIGN(orderBy, "SOMDES,SOPGID")
          @DTW_ASSIGN(orderByDisplay, "Activation Group, Program Name")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("SOPGID", "Program Name", $(srchProg), "U", operProg, "A")
  @Build_WildCard ("upper(PTDESC)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("SOMOPT", "ILE Type", $(srchILEType), "U", operILEType, "A")
  @Build_WildCard ("SOMDES", "Activation Group", $(srchActGrp), "U", operActGrp, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}