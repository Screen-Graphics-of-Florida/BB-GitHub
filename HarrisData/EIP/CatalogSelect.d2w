                                  <td class="inputalph"><input name="fromCTG4" type="text" value="$(fromField)" size="10" maxlength="15"><a href="$(homeURL)$(cGIPath)categorysearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromCTG4&amp;fldDesc=fromCTG4Desc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fromCTG4Desc" type="hidden"></td>
                                  <td class="inputalph"><input name="toCTG4" type="text" value="$(toField)" size="10" maxlength="15"><a href="$(homeURL)$(cGIPath)categorysearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toCTG4&amp;fldDesc=toCTG4Desc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toCTG4Desc" type="hidden"></td>
                                  <td class="inputnmbr"><input name="groupCTG4" type="text" value="$(seqField)" size="2" maxlength="2"></td>
