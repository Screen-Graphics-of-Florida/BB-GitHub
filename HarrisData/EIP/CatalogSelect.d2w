%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Catalog Maintenance &nbsp;"
  d2wName                 = "CatalogSelect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;catalog=@dtw_rurlescseq(catalog)&amp;catalogDesc=@dtw_rurlescseq(catalogDesc)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  fromField               = ""
  toField                 = ""
  seqField                = ""
  S0                      = ""
  S1                      = ""
  S2                      = ""
  S3                      = ""
  S4                      = ""
  S5                      = ""
  S6                      = ""
  S7                      = ""
  S8                      = ""
  S9                      = ""
%}

%INCLUDE "opersel_rtvfield.icl"
%INCLUDE "opersel_bldfield.icl"

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@catalog", "@dtw_rurlescseq(catalog)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL () {	
  %INCLUDE "$(docType)"

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Sel")
          <script TYPE="text/javascript">
              function confirmReset() {return confirm("Confirm Reset Of Form")}
              function confirmClear() {return confirm("Confirm Clear Of Form")}
              function resetForm() {document.Chg.reset();}
              %INCLUDE "Menu.js"
	       %INCLUDE "numedit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.selectDesc.value =="")
                         {alert("$(reqFieldError)");
                          return false;}
                  if (editNum(document.Chg.orderSequence, 7, 2) &&
                      editNum(document.Chg.fromWHS, 3, 0) &&
                      editNum(document.Chg.toWHS, 3, 0) &&
                      editNum(document.Chg.groupITEM, 2, 0) &&
                      editNum(document.Chg.groupIMDS, 2, 0) &&
                      editNum(document.Chg.groupPCLS, 2, 0) &&
                      editNum(document.Chg.groupWHS, 2, 0)
                      %if (itemExtAlph1 != "")	
                          && editNum(document.Chg.groupUXA1, 2, 0)
                      %endif
                      %if (itemExtAlph2 != "")	
                          && editNum(document.Chg.groupUXA2, 2, 0)
                      %endif
                      %if (itemExtAlph3 != "")	
                          && editNum(document.Chg.groupUXA3, 2, 0)
                      %endif
                      %if (itemExtAlph4 != "")	
                          && editNum(document.Chg.groupUXA4, 2, 0)
                      %endif
                      %if (itemExtAlph5 != "")	
                          && editNum(document.Chg.groupUXA5, 2, 0)
                      %endif
                      %if (itemExtNum1 != "")
                          && editNum(document.Chg.groupUXN1, 2, 0)
                      %endif
                      %if (itemExtNum2 != "")
                          && editNum(document.Chg.groupUXN2, 2, 0)
                      %endif
                      %if (itemExtNum3 != "")
                          && editNum(document.Chg.groupUXN3, 2, 0)
                      %endif
                      %if (itemExtNum4 != "")
                          && editNum(document.Chg.groupUXN4, 2, 0)
                      %endif
                      %if (itemExtNum5 != "")
                          && editNum(document.Chg.groupUXN5, 2, 0)
                      %endif
                      %if (V_CIIAS1 != "")
                          && editNum(document.Chg.groupUDA1, 2, 0)
                      %endif
                      %if (V_CIIAS2 != "")
                          && editNum(document.Chg.groupUDA2, 2, 0)
                      %endif
                      %if (V_CIIAS3 != "")
                          && editNum(document.Chg.groupUDA3, 2, 0)
                      %endif
                      %if (V_CIIAS4 != "")
                          && editNum(document.Chg.groupUDA4, 2, 0)
                      %endif
                      %if (V_CIIAS5 != "")
                          && editNum(document.Chg.groupUDA5, 2, 0)
                      %endif
                      %if (V_CIINS1 != "")
                          && editNum(document.Chg.groupUDN1, 2, 0)
                      %endif
                      %if (V_CIINS2 != "")
                          && editNum(document.Chg.groupUDN2, 2, 0)
                      %endif
                      %if (V_CIINS3 != "")
                          && editNum(document.Chg.groupUDN3, 2, 0)
                      %endif
                      %if (V_CIINS4 != "")
                          && editNum(document.Chg.groupUDN4, 2, 0)
                      %endif
                      %if (V_CIINS5 != "")
                          && editNum(document.Chg.groupUDN5, 2, 0)
                      %endif
                      )
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CATALOGSELECT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      <table $(contentTable)>
            	       <colgroup>
            	           <col width="80%">
            	           <col width="15%">
                          <tr><td><h1>$(page_title)</h1></td>
                              <td>&nbsp;</td>
                              <td class="toolbar">
                                  <a href="javascript:check(document.Chg)">$(selectAcceptImage)</a>
                                  <a onClick="return confirmReset() && resetForm()">$(selectResetImage)</a>
                                  <a onClick="return confirmClear()" href="$(homeURL)$(cGIPath)$(d2wName)/SELECT$(d2wVarBase)&amp;selectUser=@dtw_rurlescseq(selectUser)">$(selectClearImage)</a>
                                  @dtw_assign(medIcon, "Y")
                                  %INCLUDE "HelpPage.icl"
                              </td>
                          </tr>
                      </table>
                      <table $(contentTable)>
                          @Format_Header_URL("Catalog", $(catalogDesc), $(catalog), "$(homeURL)$(cGIPath)CatalogSequence.d2w/SELECT$(d2wVarBase)")
                      </table>

                      $(hrTagAttr)
                      %INCLUDE "RequiredField.icl"
            	
                      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/PROCESS$(d2wVarBase)&amp;recordSequence=@dtw_rurlescseq(recordSequence)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
                          <table $(contentTable)>
                              <tr><td class="dsphdr">Description</td>
                                  <td class="inputalph" colspan="2"><input name="selectDesc" type="text" value="$(selectDesc)" size="50" maxlength="50"> $(reqFieldChar) </td>
                              </tr>
                              <tr><td class="dsphdr">Sequence Number</td>
                                  <td class="inputnmbr"><input name="orderSequence" type="text" value="$(orderSequence)" size="9" maxlength="9"></td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">Operand</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">Group<br>By</td>
                                  <td class="colhdr">New<br>Page</td>
                              </tr>

                              @Retrieve_Field("IXCTG1")
                              %if (@dtw_rpos("@@IXCTG1", newPage) > "0")
                                  @dtw_assign(checked, "CHECKED")
                              %else
                                  @dtw_assign(checked, "")
                              %endif
                              @dtw_assign(operNbr, "operCTG1")
                              <tr><td class="dsphdr">Category 1</td>
                                  <td>%INCLUDE "opersel_alph.icl"</td>
                                  <td class="inputalph"><input name="fromCTG1" type="text" value="$(fromField)" size="10" maxlength="15"><a href="$(homeURL)$(cGIPath)categorysearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromCTG1&amp;fldDesc=fromCTG1Desc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fromCTG1Desc" type="hidden"></td>
                                  <td class="inputalph"><input name="toCTG1" type="text" value="$(toField)" size="10" maxlength="15"><a href="$(homeURL)$(cGIPath)categorysearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toCTG1&amp;fldDesc=toCTG1Desc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toCTG1Desc" type="hidden"></td>
                                  <td class="inputnmbr"><input name="groupCTG1" type="text" value="$(seqField)" size="2" maxlength="2"></td>
                                  <td class="inputcode"><input name="pageCTG1" type="checkbox" $(checked) VALUE='Y'></td>
                              </tr>

                              @Retrieve_Field("IXCTG2")
                              %if (@dtw_rpos("@@IXCTG2", newPage) > "0")
                                  @dtw_assign(checked, "CHECKED")
                              %else
                                  @dtw_assign(checked, "")
                              %endif
                              @dtw_assign(operNbr, "operCTG2")
                              <tr><td class="dsphdr">Category 2</td>
                                  <td>%INCLUDE "opersel_alph.icl"</td>
                                  <td class="inputalph"><input name="fromCTG2" type="text" value="$(fromField)" size="10" maxlength="15"><a href="$(homeURL)$(cGIPath)categorysearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromCTG2&amp;fldDesc=fromCTG2Desc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fromCTG2Desc" type="hidden"></td>
                                  <td class="inputalph"><input name="toCTG2" type="text" value="$(toField)" size="10" maxlength="15"><a href="$(homeURL)$(cGIPath)categorysearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toCTG2&amp;fldDesc=toCTG2Desc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toCTG2Desc" type="hidden"></td>
                                  <td class="inputnmbr"><input name="groupCTG2" type="text" value="$(seqField)" size="2" maxlength="2"></td>
                                  <td class="inputcode"><input name="pageCTG2" type="checkbox" $(checked) VALUE='Y'></td>
                              </tr>

                              @Retrieve_Field("IXCTG3")
                              %if (@dtw_rpos("@@IXCTG3", newPage) > "0")
                                  @dtw_assign(checked, "CHECKED")
                              %else
                                  @dtw_assign(checked, "")
                              %endif
                              @dtw_assign(operNbr, "operCTG3")
                              <tr><td class="dsphdr">Category 3</td>
                                  <td>%INCLUDE "opersel_alph.icl"</td>
                                  <td class="inputalph"><input name="fromCTG3" type="text" value="$(fromField)" size="10" maxlength="15"><a href="$(homeURL)$(cGIPath)categorysearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromCTG3&amp;fldDesc=fromCTG3Desc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fromCTG3Desc" type="hidden"></td>
                                  <td class="inputalph"><input name="toCTG3" type="text" value="$(toField)" size="10" maxlength="15"><a href="$(homeURL)$(cGIPath)categorysearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toCTG3&amp;fldDesc=toCTG3Desc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toCTG3Desc" type="hidden"></td>
                                  <td class="inputnmbr"><input name="groupCTG3" type="text" value="$(seqField)" size="2" maxlength="2"></td>
                                  <td class="inputcode"><input name="pageCTG3" type="checkbox" $(checked) VALUE='Y'></td>
                              </tr>

