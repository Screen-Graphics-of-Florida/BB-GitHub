%FUNCTION(dtw_directcall) Update_Catalog_Sequence(INOUT CHAR(64) profileHandle,
                                                  INOUT CHAR(2)  dataBaseID,
                                                  INOUT CHAR(1)  maintCode,
                                                  INOUT CHAR(15) catalog,
                                                  INOUT DEC(7,0) recordSequence,
                                                  INOUT DEC(7,2) orderSequence,
                                                  INOUT CHAR(50) selectDesc,
                                                  INOUT CHAR(500) newPage,
                                                  INOUT CHAR(500) selectGroupBy,
                                                  INOUT CHAR(3000) selectCriteria)
{%EXEC {HOECTS_W.PGM %}
%}

%HTML(SELECT) {
  %INCLUDE "setLibraryList.icl"

  @dtw_assign(selectGroupBy, "")
  @dtw_assign(selectCriteria, "")
  %if (recordSequence == "0")
      @dtw_assign(selectDesc, "")
      @dtw_assign(category, "")
      @dtw_assign(newPage, "")
  %else
      @dtw_assign(maintCode, "S")
      @Update_Catalog_Sequence(profileHandle, dataBaseID, maintCode, catalog, recordSequence, orderSequence, selectDesc, newPage, selectGroupBy, selectCriteria)
  %endif

  %if (maintenanceCode == "Z")
      @dtw_assign(recordSequence, "0")
      @dtw_assign(selectDesc, "")
      @dtw_assign(category, "")
      @dtw_assign(newPage, "")
  %endif

  @Set_SQL()
%}

%HTML(PROCESS) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(fromITEM)
  @dtw_mUPPERCASE(toITEM)
  @dtw_mUPPERCASE(fromUDA1)
  @dtw_mUPPERCASE(toUDA1)
  @dtw_mUPPERCASE(fromUDA2)
  @dtw_mUPPERCASE(toUDA2)
  @dtw_mUPPERCASE(fromUDA3)
  @dtw_mUPPERCASE(toUDA3)
  @dtw_mUPPERCASE(fromUDA4)
  @dtw_mUPPERCASE(toUDA4)
  @dtw_mUPPERCASE(fromUDA5)
  @dtw_mUPPERCASE(toUDA5)
  @dtw_mUPPERCASE(fromPCLS)
  @dtw_mUPPERCASE(toPCLS)
  @dtw_mUPPERCASE(fromPGRP)
  @dtw_mUPPERCASE(toPGRP)
  @dtw_mUPPERCASE(fromITC)
  @dtw_mUPPERCASE(toITC)
  @dtw_mUPPERCASE(fromIMDS)
  @dtw_mUPPERCASE(toIMDS)
  @dtw_assign(maintCode, "A")
  @dtw_assign(selectGroupBy, "")
  @dtw_assign(x, "1")
  %while(x  <= "500"){@dtw_concat(selectGroupBy, " ", selectGroupBy) @dtw_add(x, "1", x)%}
  @dtw_assign(selectCriteria, "")
  @Build_Select("IXCTG1 ", operCTG1, fromCTG1, toCTG1, groupCTG1)
  @Build_Select("IXCTG2 ", operCTG2, fromCTG2, toCTG2, groupCTG2)
  @Build_Select("IXCTG3 ", operCTG3, fromCTG3, toCTG3, groupCTG3)
