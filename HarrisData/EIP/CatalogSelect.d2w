                                  <td class="inputalph"><input name="fromCTG5" type="text" value="$(fromField)" size="10" maxlength="15"><a href="$(homeURL)$(cGIPath)categorysearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromCTG5&amp;fldDesc=fromCTG5Desc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fromCTG5Desc" type="hidden"></td>
                                  <td class="inputalph"><input name="toCTG5" type="text" value="$(toField)" size="10" maxlength="15"><a href="$(homeURL)$(cGIPath)categorysearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toCTG5&amp;fldDesc=toCTG5Desc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toCTG5Desc" type="hidden"></td>
                                  <td class="inputnmbr"><input name="groupCTG5" type="text" value="$(seqField)" size="2" maxlength="2"></td>
                                  <td class="inputcode"><input name="pageCTG5" type="checkbox" $(checked) VALUE='Y'></td>
                              </tr>

                              %if (itemExtAlph1 != "")		
                                  @Retrieve_Field("IXUXA1")
                                  %if (@dtw_rpos("@@IXUXA1", newPage) > "0")
                                      @dtw_assign(checked, "CHECKED")
                                  %else
                                      @dtw_assign(checked, "")
                                  %endif
                                  @dtw_assign(operNbr, "operUXA1")
                                  <tr><td class="dsphdr">$(itemExtAlph1)</td>
                                      <td>%INCLUDE "opersel_alph.icl"</td>
                                      <td class="inputalph"><input name="fromUXA1" type="text" value="$(fromField)" size="10" maxlength="15"></td>
                                      <td class="inputalph"><input name="toUXA1" type="text" value="$(toField)" size="10" maxlength="15"></td>
                                      <td class="inputnmbr"><input name="groupUXA1" type="text" value="$(seqField)" size="2" maxlength="2"></td>
                                      <td class="inputcode"><input name="pageUXA1" type="checkbox" $(checked) VALUE='Y'></td>
                                  </tr>
                              %endif

                              %if (itemExtAlph2 != "")		
