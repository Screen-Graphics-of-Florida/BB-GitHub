%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Reprint Picking Tickets"
  d2wName                 = "OrderDocPickReprint.d2w"
  d2wVarBase              = "$(genericVarBase)"
  nextPrevVar             = "$(d2wVarBase)&amp;orderBy=@dtw_rurlescseq(orderBy)&amp;wildCardSearch=@dtw_rurlescseq(wildCardSearch)&amp;haveRec=@dtw_rurlescseq(haveRec)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "25"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "25"
  rowIndexNext            = "1"
  totalPages              = "0"
  haveRec                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
   @dtw_replace(workURL, "@@orderBy", "@dtw_rurlescseq(orderBy)", "1", "a", workURL)
   @dtw_replace(workURL, "@@wildCardSearch", "@dtw_rurlescseq(wildCardSearch)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ORDERDOCPICKREPRINT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " OEPICW ", fileSQL)
                      @dtw_concat(selectSQL, "PWXHND='$(profileHandle)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Pick_Reprint_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Pick_Reprint_Query (IN  CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="50%">
              <col width="45%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  %if (haveRec == "Y")
                      <a href="$(homeURL)$(cGIPath)OrderDocPickReprtRvw.d2w/DISPLAY$(genericVarBase)&amp;orderBy=@dtw_rurlescseq(orderBy)">$(selectAcceptImage)</a>
                  %endif
                  <a href="$(homeURL)$(cGIPath)$(d2wName)/CLEAR$(d2wVarBase)&amp;orderBy=@dtw_rurlescseq(orderBy)">$(selectClearImage)</a>
                  <a href="$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)&amp;orderBy=@dtw_rurlescseq(orderBy)">$(wildChgImage)</a>
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>

      $(hrTagAttr)

      %INCLUDE "AssignPageValue.icl"

      <form class="formClass" METHOD=POST name="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(genericVarBase)&amp;orderBy=@dtw_rurlescseq(orderBy)&amp;wildCardSearch=@dtw_rurlescseq(wildCardSearch)&amp;updateRowNum=@dtw_rurlescseq($(START_ROW_NUM))">
          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)&amp;haveRec=@dtw_rurlescseq(haveRec)")
              <tr>
                  @OrderBy_Sort("PWSEL", sortVar)
                  <td class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=selection" title="Sequence By Selection">Sel</a></td>
                  @OrderBy_Sort("PWTURN", sortVar)
                  <td class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=turnaround" title="Sequence By Turnaround">Turnaround</a></td>
                  @OrderBy_Sort("PWORD#", sortVar)
                  <td class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=orderNumber" title="Sequence By Order Number">Order<br>Number</a></td>
                  @OrderBy_Sort("PWSHTO", sortVar)
                  <td class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=shipTo" title="Sequence By Ship-To Customer">Ship-To</a></td>
                  @OrderBy_Sort("PWCNA1", sortVar)
                  <td class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=custName" title="Sequence By Customer Name">Name</a></td>
                  @OrderBy_Sort("PWRQDT", sortVar)
                  <td class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=reqDate" title="Sequence By Required Date">Required<br>Date</a></td>
                  @OrderBy_Sort("PWSVSV", sortVar)
                  <td class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=shipVia" title="Sequence By Ship Via">Ship<br>Via</a></td>
                  @OrderBy_Sort("PWORTY", sortVar)
                  <td class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=orderType" title="Sequence By Order Type">Order<br>Type</a></td>
                  @OrderBy_Sort("PWUSER", sortVar)
                  <td class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=user" title="Sequence By User">User</a></td>
                  @OrderBy_Sort("PWGEND", sortVar)
                  <td class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=genDate" title="Sequence By Generation Date">Generation<br>Date</a></td>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
    		
              %ROW{
                  %INCLUDE "SetRowClass.icl"
                  %if (V_PWSEL == "S")
                      @dtw_assign(selected, "CHECKED")
                  %else
                      @dtw_assign(selected, "")
                  %endif

                  @Format_Date(V_PWRQDT, "D", F_PWRQDT)
                  @Format_Date(V_PWGEND, "D", F_PWGEND)
          	   @RtvFldDesc("OTOTCD='$(V_PWORTY)' and OTAPID='OE'", "HDOTYP", "OTDESC", orderTypeDesc)
          	   @RtvFldDesc("SVSVSV='$(V_PWSVSV)' ", "HDSHPV", "SVSVDS", shipViaDesc)
          	   @RtvFldDesc("USUSER='$(V_PWUSER)' ", "SYUSER", "USDESC", userName)

                  <tr class="$(rowClass)">
                      <td class="colcode"><input type="checkbox" name="selc$(ROW_NUM)" $(selected) VALUE='S' onClick="javascript:check(document.Chg)"></td>
                      <td class="colnmbr">$(V_PWTURN)</td>
                      <td class="colnmbr">$(V_PWORD#)</td>
                      <td class="colnmbr">$(V_PWSHTO)</td>
                      <td class="colalph">$(V_PWCNA1)</td>
                      <td class="coldate">$(F_PWRQDT)</td>
                      <td class="colalph" $(helpCursor)><span title="$(V_PWSVSV)">$(shipViaDesc)</span></td>
                      <td class="colcode" $(helpCursor)><span title="$(orderTypeDesc)">$(V_PWORTY)</span></td>
                      <td class="colalph" $(helpCursor)><span title="$(V_PWUSER)">$(userName)</span></td>
                      <td class="coldate">$(F_PWGEND)<input type="hidden" name="turn$(ROW_NUM)" value="@dtw_rqhtmlencode($(V_PWTURN))"></td>
                  </tr>
              %}
          </table>
      </form>
      %INCLUDE "PageBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Update_Pick_Reprint (IN    CHAR(64)    profileHandle,
                                                     CHAR(2)     dataBaseID,
                                                     CHAR(1)     updCode,
                                               INOUT CHAR(1)     haveRec,
                                               INOUT CHAR(1)     errFound,
                                               INOUT CHAR(32000) edtVar,                             	
                                               INOUT CHAR(32000) errVar)
{%EXEC {HOERPS_W.PGM %}
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(updCode, "L")
  @Update_Pick_Reprint (profileHandle, dataBaseID, updCode, haveRec, errFound, edtVar, errVar)

  @DTW_ASSIGN(orderBy, "PWTURN")
  @Set_SQL(stmtSQL)
%}

%HTML(CLEAR) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(updCode, "L")
  @Update_Pick_Reprint (profileHandle, dataBaseID, updCode, haveRec, errFound, edtVar, errVar)

  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "selection")
      %if (orderBy == "PWSEL")
          @DTW_ASSIGN(orderBy, "PWSEL DESC,PWTURN")
      %else
          @DTW_ASSIGN(orderBy, "PWSEL")
      %endif
  %elif (sequence == "turnaround")
      %if (orderBy == "PWTURN")
          @DTW_ASSIGN(orderBy, "PWTURN DESC")
      %else
          @DTW_ASSIGN(orderBy, "PWTURN")
      %endif
  %elif (sequence == "orderNumber")
      %if (orderBy == "PWORD#,PWTURN")
          @DTW_ASSIGN(orderBy, "PWORD# DESC,PWTURN")
      %else
          @DTW_ASSIGN(orderBy, "PWORD#,PWTURN")
      %endif
  %elif (sequence == "shipTo")
      %if (orderBy == "PWSHTO,PWORD#")
          @DTW_ASSIGN(orderBy, "PWSHTO DESC,PWORD#")
      %else
          @DTW_ASSIGN(orderBy, "PWSHTO,PWORD#")
      %endif
  %elif (sequence == "custName")
      %if (orderBy == "PWCNA1,PWTURN")
          @DTW_ASSIGN(orderBy, "PWCNA1 DESC,PWTURN")
      %else
          @DTW_ASSIGN(orderBy, "PWCNA1,PWTURN")
      %endif
  %elif (sequence == "reqDate")
      %if (orderBy == "PWRQDT,PWTURN")
          @DTW_ASSIGN(orderBy, "PWRQDT DESC,PWTURN")
      %else
          @DTW_ASSIGN(orderBy, "PWRQDT,PWTURN")
      %endif
  %elif (sequence == "shipVia")
      %if (orderBy == "PWSVSV,PWTURN")
          @DTW_ASSIGN(orderBy, "PWSVSV DESC,PWTURN")
      %else
          @DTW_ASSIGN(orderBy, "PWSVSV,PWTURN")
      %endif
  %elif (sequence == "orderType")
      %if (orderBy == "PWORTY,PWTURN")
          @DTW_ASSIGN(orderBy, "PWORTY DESC,PWTURN")
      %else
          @DTW_ASSIGN(orderBy, "PWORTY,PWTURN")
      %endif
  %elif (sequence == "user")
      %if (orderBy == "PWUSER,PWTURN")
          @DTW_ASSIGN(orderBy, "PWUSER DESC,PWTURN")
      %else
          @DTW_ASSIGN(orderBy, "PWUSER,PWTURN")
      %endif
  %elif (sequence == "genDate")
      %if (orderBy == "PWGEND,PWTURN")
          @DTW_ASSIGN(orderBy, "PWGEND DESC,PWTURN")
      %else
          @DTW_ASSIGN(orderBy, "PWGEND,PWTURN")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(UPDATE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(updCode, "")
  %if (selc1 != "S")
      @dtw_assign(selc1, "")
  %endif
  %if (selc2 != "S")
      @dtw_assign(selc2, "")
  %endif
  %if (selc3 != "S")
      @dtw_assign(selc3, "")
  %endif
  %if (selc4 != "S")
      @dtw_assign(selc4, "")
  %endif
  %if (selc5 != "S")
      @dtw_assign(selc5, "")
  %endif
  %if (selc6 != "S")
      @dtw_assign(selc6, "")
  %endif
  %if (selc7 != "S")
      @dtw_assign(selc7, "")
  %endif
  %if (selc8 != "S")
      @dtw_assign(selc8, "")
  %endif
  %if (selc9 != "S")
      @dtw_assign(selc9, "")
  %endif
  %if (selc10 != "S")
      @dtw_assign(selc10, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@sl01", selc1)
  @Concat_Field("@@sl02", selc2)
  @Concat_Field("@@sl03", selc3)
  @Concat_Field("@@sl04", selc4)
  @Concat_Field("@@sl05", selc5)
  @Concat_Field("@@sl06", selc6)
  @Concat_Field("@@sl07", selc7)
  @Concat_Field("@@sl08", selc8)
  @Concat_Field("@@sl09", selc9)
  @Concat_Field("@@sl10", selc10)
  @Concat_Field("@@tn01", turn1)
  @Concat_Field("@@tn02", turn2)
  @Concat_Field("@@tn03", turn3)
  @Concat_Field("@@tn04", turn4)
  @Concat_Field("@@tn05", turn5)
  @Concat_Field("@@tn06", turn6)
  @Concat_Field("@@tn07", turn7)
  @Concat_Field("@@tn08", turn8)
  @Concat_Field("@@tn09", turn9)
  @Concat_Field("@@tn10", turn10)
  @dtw_concat(edtVar, "}{", edtVar)

  @Update_Pick_Reprint (profileHandle, dataBaseID, updCode, haveRec, errFound, edtVar, errVar)
  @dtw_assign(START_ROW_NUM,  "$(updateRowNum)")
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.frTurn, 9, 0) &&
                      editNum(document.Search.toTurn, 9, 0) &&
                      editNum(document.Search.frOrder, 8, 0) &&
                      editNum(document.Search.toOrder, 8, 0) &&
                      editNum(document.Search.frShipTo, 7, 0) &&
                      editNum(document.Search.toShipTo, 7, 0) &&
                      editdate(document.Search.frReqDate) &&
                      editdate(document.Search.toReqDate) &&
                      editdate(document.Search.frGenDate) &&
                      editdate(document.Search.toGenDate) &&
                      editFromTo(document.Search.frTurn, document.Search.toTurn, 3) &&
                      editFromTo(document.Search.frOrder, document.Search.toOrder, 8) &&
                      editFromTo(document.Search.frShipTo, document.Search.toShipTo, 7) &&
                      editFromTo(document.Search.frUser, document.Search.toUser, "A") &&
                      editFromTo(document.Search.frReqDate, document.Search.toReqDate, "D") &&
                      editFromTo(document.Search.frGenDate, document.Search.toGenDate, "D") &&
                      editFromTo(document.Search.frShip, document.Search.toShip, "A"))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ORDERDOCPICKRANGE")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      <table $(contentTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1>Reprint Picking Ticket Range Selection</h1></td>
                              <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                          </tr>
                      </table>

                      $(hrTagAttr)

                      <form class="formClass" METHOD=POST NAME="Search" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)&amp;orderBy=@dtw_rurlescseq(orderBy)">
                          <table $(contentTable)>
                              %if (errFound != "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @DecatErr_Field("@@ftrn", "frTurn")   @dtw_assign(Err_N1FTRN,  fieldValue)
                                  @DecatErr_Field("@@ttrn", "toTurn")   @dtw_assign(Err_N1TTRN,  fieldValue)
                                  @DecatErr_Field("@@ford", "frOrder")   @dtw_assign(Err_N1FORD,  fieldValue)
                                  @DecatErr_Field("@@tord", "toOrder")   @dtw_assign(Err_N1TORD,  fieldValue)
                                  @DecatErr_Field("@@fsht", "frShipTo")   @dtw_assign(Err_N1FSHT,  fieldValue)
                                  @DecatErr_Field("@@tsht", "toShipTo")   @dtw_assign(Err_N1TSHT,  fieldValue)
                                  @DecatErr_Field("@@fusr", "frUser")   @dtw_assign(Err_N1FUSR,  fieldValue)
                                  @DecatErr_Field("@@tusr", "toUser")   @dtw_assign(Err_N1TUSR,  fieldValue)
                                  @DecatErr_Field("@@frqd", "frReqDate")   @dtw_assign(Err_N1FRQD,  fieldValue)
                                  @DecatErr_Field("@@trqd", "toReqDate")   @dtw_assign(Err_N1TRQD,  fieldValue)
                                  @DecatErr_Field("@@fgen", "frGenDate")   @dtw_assign(Err_N1FGEN,  fieldValue)
                                  @DecatErr_Field("@@tgen", "toGenDate")   @dtw_assign(Err_N1TGEN,  fieldValue)
                                  @DecatErr_Field("@@fsv@", "frShip")   @dtw_assign(Err_N1FSV,  fieldValue)
                                  @DecatErr_Field("@@tsv@", "toShip")   @dtw_assign(Err_N1TSV,  fieldValue)
                                  %INCLUDE "scheduleJobErr.icl"    %{ Schedule Entries Errors %}

                                  @Decat_Field("@@ftrn")   @dtw_assign(V_N1FTRN,  fieldValue)
                                  @Decat_Field("@@ttrn")   @dtw_assign(V_N1TTRN,  fieldValue)
                                  @Decat_Field("@@ford")   @dtw_assign(V_N1FORD,  fieldValue)
                                  @Decat_Field("@@tord")   @dtw_assign(V_N1TORD,  fieldValue)
                                  @Decat_Field("@@fsht")   @dtw_assign(V_N1FSHT,  fieldValue)
                                  @Decat_Field("@@tsht")   @dtw_assign(V_N1TSHT,  fieldValue)
                                  @Decat_Field("@@fusr")   @dtw_assign(V_N1FUSR,  fieldValue)
                                  @Decat_Field("@@tusr")   @dtw_assign(V_N1TUSR,  fieldValue)
                                  @Decat_Field("@@frqd")   @dtw_assign(V_N1FRQD,  fieldValue)
                                  @Decat_Field("@@trqd")   @dtw_assign(V_N1TRQD,  fieldValue)
                                  @Decat_Field("@@fgen")   @dtw_assign(V_N1FGEN,  fieldValue)
                                  @Decat_Field("@@tgen")   @dtw_assign(V_N1TGEN,  fieldValue)
                                  @Decat_Field("@@fsv@")   @dtw_assign(V_N1FSV,  fieldValue)
                                  @Decat_Field("@@tsv@")   @dtw_assign(V_N1TSV,  fieldValue)
                                  %INCLUDE "scheduleJobValue.icl"    %{ Schedule Entries Values %}
                              %else
                                  @dtw_assign(focusField, "frTurn")
                              %endif

                              <tr>
                                  <th>&nbsp;</th>
                                  <th class="colhdr"> From</th>
                                  <th class="colhdr"> To</th>
                              </tr>

                              @SetTextOvr(Err_N1FTRN)
                              %if (textOvr == "") @SetTextOvr(Err_N1TTRN) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Turnaround Number</span></td>
                                  <td class="inputnmbr"><input type="text" name="frTurn" VALUE="$(V_N1FTRN)" size="9" maxlength="9"></td>
                                  <td class="inputnmbr"><input type="text" name="toTurn" VALUE="$(V_N1TTRN)" size="9" maxlength="9"></td>
                              </tr>
                              @DspErrMsg(Err_N1FTRN)
                              @DspErrMsg(Err_N1TTRN)

                              @SetTextOvr(Err_N1FORD)
                              %if (textOvr == "") @SetTextOvr(Err_N1TORD) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Order Number</span></td>
                                  <td class="inputnmbr"> <input type="text" name="frOrder" VALUE="$(V_N1FORD)" size="8" maxlength="8"></td>
                                  <td class="inputnmbr"> <input type="text" name="toOrder" VALUE="$(V_N1TORD)" size="8" maxlength="8"></td>
                              </tr>
                              @DspErrMsg(Err_N1FORD)
                              @DspErrMsg(Err_N1TORD)

                              @SetTextOvr(Err_N1FSHT)
                              %if (textOvr == "") @SetTextOvr(Err_N1TSHT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Ship-To Number</span></td>
                                  <td class="inputnmbr"> <input type="text" name="frShipTo" VALUE="$(V_N1FSHT)" size="7" maxlength="7"></td>
                                  <td class="inputnmbr"> <input type="text" name="toShipTo" VALUE="$(V_N1TSHT)" size="7" maxlength="7"></td>
                              </tr>
                              @DspErrMsg(Err_N1FSHT)
                              @DspErrMsg(Err_N1TSHT)

                              @SetTextOvr(Err_N1FUSR)
                              %if (textOvr == "") @SetTextOvr(Err_N1TUSR) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>User ID</span></td>
                                  <td class="inputalph"> <input type="text" name="frUser" VALUE="$(V_N1FUSR)" size="10" maxlength="10"></td>
                                  <td class="inputalph"> <input type="text" name="toUser" VALUE="$(V_N1TUSR)" size="10" maxlength="10"></td>
                              </tr>
                              @DspErrMsg(Err_N1FUSR)
                              @DspErrMsg(Err_N1TUSR)

                              @SetTextOvr(Err_N1FRQD)
                              %if (textOvr == "") @SetTextOvr(Err_N1TRQD) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Required Date</span></td>
                                  <td class="inputnmbr"> <input type="text" name="frReqDate" VALUE="$(V_N1FRQD)" size="6" maxlength="6">
                                      <a href="javascript:calWindow('frReqDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"> <input type="text" name="toReqDate" VALUE="$(V_N1TRQD)" size="6" maxlength="6">
                                      <a href="javascript:calWindow('toReqDate');">$(calendarImage)</a></td>
                              </tr>
                              @DspErrMsg(Err_N1FRQD)
                              @DspErrMsg(Err_N1TRQD)

                              @SetTextOvr(Err_N1FGEN)
                              %if (textOvr == "") @SetTextOvr(Err_N1TGEN) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Generation Date</span></td>
                                  <td class="inputnmbr"> <input type="text" name="frGenDate" VALUE="$(V_N1FGEN)" size="6" maxlength="6">
                                      <a href="javascript:calWindow('frGenDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"> <input type="text" name="toGenDate" VALUE="$(V_N1TGEN)" size="6" maxlength="6">
                                      <a href="javascript:calWindow('toGenDate');">$(calendarImage)</a></td>
                              </tr>
                              @DspErrMsg(Err_N1FGEN)
                              @DspErrMsg(Err_N1TGEN)

                              @SetTextOvr(Err_N1FSV)
                              %if (textOvr == "") @SetTextOvr(Err_N1TSV) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Ship Via</span></td>
                                  <td class="inputalph"> <input type="text" name="frShip" VALUE="$(V_N1FSV)" size="2" maxlength="2"></td>
                                  <td class="inputalph"> <input type="text" name="toShip" VALUE="$(V_N1TSV)" size="2" maxlength="2"></td>
                              </tr>
                              @DspErrMsg(Err_N1FSV)
                              @DspErrMsg(Err_N1TSV)
                          </table>
                          <a href="javascript:check(document.Search)">$(goSearchImage)</a>
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                          <script TYPE="text/javascript">
                              document.Search.$(focusField).focus();
                          </script>
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(updCode, "R")
  @dtw_mUPPERCASE(frUser)
  @dtw_mUPPERCASE(toUser)
  @dtw_mUPPERCASE(frShip)
  @dtw_mUPPERCASE(toShip)

  @dtw_assign(frTurn,@dtw_rstrip(frTurn))
  @dtw_assign(toTurn,@dtw_rstrip(toTurn))
  @dtw_assign(frOrder,@dtw_rstrip(frOrder))
  @dtw_assign(toOrder,@dtw_rstrip(toOrder))
  @dtw_assign(frShipTo,@dtw_rstrip(frShipTo))
  @dtw_assign(toShipTo,@dtw_rstrip(toShipTo))
  @dtw_assign(frReqDate,@dtw_rstrip(frReqDate))
  @dtw_assign(toReqDate,@dtw_rstrip(toReqDate))
  @dtw_assign(frGenDate,@dtw_rstrip(frGenDate))
  @dtw_assign(toGenDate,@dtw_rstrip(toGenDate))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@ftrn", frTurn)
  @Concat_Field("@@ttrn", toTurn)
  @Concat_Field("@@ford", frOrder)
  @Concat_Field("@@tord", toOrder)
  @Concat_Field("@@fsht", frShipTo)
  @Concat_Field("@@tsht", toShipTo)
  @Concat_Field("@@fusr", frUser)
  @Concat_Field("@@tusr", toUser)
  @Concat_Field("@@frqd", frReqDate)
  @Concat_Field("@@trqd", toReqDate)
  @Concat_Field("@@fgen", frGenDate)
  @Concat_Field("@@tgen", toGenDate)
  @Concat_Field("@@fsv@", frShip)
  @Concat_Field("@@tsv@", toShip)
  @dtw_concat(edtVar, "}{", edtVar)

  @Update_Pick_Reprint (profileHandle, dataBaseID, updCode, haveRec, errFound, edtVar, errVar)

  %if (errFound == "")
      @DTW_ASSIGN(wildCardSearch, "")

      @dtw_assign(frTurn,@dtw_rstrip(frTurn))
      @dtw_assign(toTurn,@dtw_rstrip(toTurn))
      %if (frTurn != "" || toTurn != "")
          @Default_Zero(frTurn)
          @dtw_concat(wildCardSearch, " and PWTURN between $(frTurn) and $(toTurn)", wildCardSearch)
      %endif

      @dtw_assign(frOrder,@dtw_rstrip(frOrder))
      @dtw_assign(toOrder,@dtw_rstrip(toOrder))
      %if (frOrder != "" || toOrder != "")
          @Default_Zero(frOrder)
          @dtw_concat(wildCardSearch, " and PWORD# between $(frOrder) and $(toOrder)", wildCardSearch)
      %endif

      @dtw_assign(frShipTo,@dtw_rstrip(frShipTo))
      @dtw_assign(toShipTo,@dtw_rstrip(toShipTo))
      %if (frShipTo != "" || toShipTo != "")
          @Default_Zero(frShipTo)
          @dtw_concat(wildCardSearch, " and PWSHTO between $(frShipTo) and $(toShipTo)", wildCardSearch)
      %endif

      @dtw_assign(frUser,@dtw_rstrip(frUser))
      @dtw_assign(toUser,@dtw_rstrip(toUser))
      %if (frUser != "" || toUser != "")
          @dtw_concat(wildCardSearch, " and PWUSER between '$(frUser)' and '$(toUser)'", wildCardSearch)
      %endif

      @dtw_assign(frReqDate,@dtw_rstrip(frReqDate))
      @dtw_assign(toReqDate,@dtw_rstrip(toReqDate))
      %if (frReqDate != "" || toReqDate != "")
          @Default_Zero(frReqDate)
          @DateToCYMD(frReqDate)
          @Default_Zero(toReqDate)
          @DateToCYMD(toReqDate)
          @dtw_concat(wildCardSearch, " and PWRQDT between $(frReqDate) and $(toReqDate)", wildCardSearch)
      %endif

      @dtw_assign(frGenDate,@dtw_rstrip(frGenDate))
      @dtw_assign(toGenDate,@dtw_rstrip(toGenDate))
      %if (frGenDate != "" || toGenDate != "")
          @Default_Zero(frGenDate)
          @DateToCYMD(frGenDate)
          @Default_Zero(toGenDate)
          @DateToCYMD(toGenDate)
          @dtw_concat(wildCardSearch, " and PWGEND between $(frGenDate) and $(toGenDate)", wildCardSearch)
      %endif

      @dtw_assign(frShip,@dtw_rstrip(frShip))
      @dtw_assign(toShip,@dtw_rstrip(toShip))
      %if (frShip != "" || toShip != "")
          @dtw_concat(wildCardSearch, " and PWSVSV between '$(frShip)' and '$(toShip)'", wildCardSearch)
      %endif

      @Set_SQL(stmtSQL)
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)&amp;orderBy=@dtw_rurlescseq(orderBy)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}