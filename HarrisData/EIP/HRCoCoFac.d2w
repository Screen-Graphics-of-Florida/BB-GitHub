%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title 	        = "Companies And Facilities"
  d2wName              = "HRCoCoFac.d2w"
  d2wVarBase           = "$(genericVarBase)"
  nextPrevVar          = "$(d2wVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  wildDftVar           = "REPORT$(d2wVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  advSrchVar           = "&amp;backHome=@dtw_rurlescseq(backHome)"
  programName          = "HHRCOU"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  DTW_PRINT_HEADER     = "NO"
  RPT_MAX_ROWS 	= "10"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext		= "1"
  totalPages		= "0"	
  country              = "US"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchCo, 2, 0) &&
                      editNum(document.Search.srchFac, 4, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "HRCOCOFAC")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      @dtw_assign(uv_CompanyName, "CFCOMP")
                      @dtw_assign(uv_FacilityName, "CFFACL")
	               %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select CFCOMP, CFFACL, CFNAME, CFADR1, CFADR2, CFCITY, CFSTID, CFZIP, CFPHON, CFNAMEU, CFHRXR", stmtSQL)
                      @dtw_concat(stmtSQL, ", upper(CFADR1) as CFADR1U", stmtSQL)
                      @dtw_concat(stmtSQL, ", upper(CFCITY) as CFCITYU", stmtSQL)
                      @dtw_concat(fileSQL, " HRCOFC ", fileSQL)
                      %if (wildCardSearch!="" || uv_Sql!="")
                          @dtw_concat(selectSQL, "CFPRAC != 'X' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @CoFac_Inquiry(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) CoFac_Inquiry (IN CHAR(64)    profileHandle,
                                     CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count != "1")
          <table $(contentTable)>
	       <colgroup>
	           <col width="80%">
	           <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if ((backHome != "")  && (backHome != "$(d2wName)/REPORT"))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)&amp;backHome=@dtw_rurlescseq(backHome)" title="Back Home">$(portalHome)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                       </td>
                  %endif
              </tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"	
          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;backHome=@dtw_rurlescseq(backHome)">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Name</th>
                          <th class="colhdr">Co / Fac</th>
                      </tr>
                      <tr><td class="inputalph"><input type="text" name="srchName" size="20" maxlength="30">
                              <input type="hidden" name="operName" value="LIKE">
                          </td>
                          <td class="inputnmbr"><input name="srchCo" type="text" size="2" maxlength="2"> / <input name="srchFac" type="text" size="4" maxlength="4">
                              <input type="hidden" name="operCo" value="=">
                              <input type="hidden" name="operFac" value="=">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchName.focus();
                  </script>
              </form>

              %INCLUDE "WildCardPage.icl"
          %endif
	   		
          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)&amp;backHome=@dtw_rurlescseq(backHome)")
              <tr>
                  @OrderBy_Sort("CFCOMP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Number" title="Sequence By Co/Fac"> Co/Fac</a></th>
                  @OrderBy_Sort("CFNAMEU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Name" title="Sequence By Name, Co/Fac"> Name</a></th>
                  @OrderBy_Sort("CFADR1U", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Address" title="Sequence By Address, Name"> Address</a></th>
                  @OrderBy_Sort("CFCITYU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=City" title="Sequence By City, State, Name"> City</a></th>
                  @OrderBy_Sort("CFSTID", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=State" title="Sequence By State, City, Name"> State</a></th>
                  @OrderBy_Sort("CFZIP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Zip" title="Sequence By Zip, City, Name"> Zip</a></th>
                  @OrderBy_Sort("CFPHON", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Phone" title="Sequence By Phone Number, Name"> Phone<br>Number</a></th>
              </tr>
          %INCLUDE "NoRecordsFound.icl"
      %endif

              %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;prCompany=@dtw_rurlescseq(V_CFCOMP)&amp;prFacility=@dtw_rurlescseq(V_CFFACL)")
                  %if (sql_Record_Count == "1")
                      @Save_WebReg(webRegCurFile, profileHandle, d2wName, "", orderBy, orderByDisplay, "")
                      %if (V_CFFACL == "0")
                          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)HRCompSelect.d2w/REPORT$(maintainVar)&amp;hrCompany=@dtw_rurlescseq(V_CFCOMP)&amp;backHome=$(d2wName)/REPORT">
                      %else
                          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)HRCoFacProfile.d2w/REPORT$(maintainVar)&amp;hrCompany=@dtw_rurlescseq(V_CFHRXR)&amp;backHome=$(d2wName)/REPORT">
                      %endif
                  %else
                      %INCLUDE "SetRowClass.icl"
                      @Format_HRCoFac("$(V_CFCOMP)", "$(V_CFFACL)", "", F_CoFac)
                      <tr class="$(rowClass)">
                          <td class="colnmbr">$(F_CoFac)</td>
                          %if (V_CFFACL == "0")
                              <td class="colalph"><a href="$(homeURL)$(cGIPath)HRCompSelect.d2w/REPORT$(maintainVar)&amp;hrCompany=@dtw_rurlescseq(V_CFCOMP)&amp;backHome=$(d2wName)/REPORT" title="View Company">$(V_CFNAME)</a></td>
                          %else
                              <td class="colalph"><a href="$(homeURL)$(cGIPath)HRCoFacProfile.d2w/REPORT$(maintainVar)&amp;hrCompany=@dtw_rurlescseq(V_CFHRXR)&amp;backHome=$(d2wName)/REPORT" title="View Company/Facility">$(V_CFNAME)</a></td>
                          %endif
                          @EditPhoneNumber(V_CFPHON)
                          <td class="colalph">$(V_CFADR1)</td>
                          <td class="colalph">$(V_CFCITY)</td>
                          <td class="colcode">$(V_CFSTID)</td>
                          <td class="colalph">$(V_CFZIP)</td>
                          <td class="colalph">$(V_CFPHON)</td>
                      </tr>
                  %endif
              %}
          </table>
          %if (sql_Record_Count != "1")
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  @dtw_assign(uv_CompanyName, "CFCOMP")
  @dtw_assign(uv_FacilityName, "CFFACL")
  @dtw_assign(uv_HRCompanyName, "CFCOMP")
  %INCLUDE "userview.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "Select CFCOMP, CFFACL, CFNAME, CFADR1, CFADR2, CFCITY, CFSTID, CFZIP, CFPHON, CFNAMEU, CFHRXR", stmtSQL)
  @dtw_concat(stmtSQL, ", upper(CFADR1) as CFADR1U", stmtSQL)
  @dtw_concat(stmtSQL, ", upper(CFCITY) as CFCITYU", stmtSQL)
  @dtw_concat(fileSQL, " HRCOFC ", fileSQL)
  %if (wildCardSearch!="" || uv_Sql!="")
      @dtw_concat(selectSQL, "CFPRAC != 'X' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @CoFac_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) CoFac_XMLQuery (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("CompanyFacilityList")
          %ROW{
              @EditPhoneNumber(V_CFPHON)

              @XMLIDTag(@DTW_rCONCAT(V_CFCOMP, @DTW_rCONCAT("/", V_CFFACL)), "CompanyFacility ID")
                  @XMLTag(V_CFCOMP, "CompanyNumber")
                  @XMLTag(V_CFFACL, "FacilityNumber")
                  @XMLTag(V_CFPHON, "PhoneNumber")

		       @XMLBeginTag("PostalAddress")
                          @XMLTag(country, "CountryCode")
                          @XMLTag(V_CFZIP, "PostalCode")
                          @XMLTag(V_CFSTID, "Region")
                          @XMLTag(V_CFCITY, "Municipality")

    	                   @XMLBeginTag("DeliveryAddress")
                              @XMLTag(V_CFADR1, "AddressLine")
                              @XMLTag(V_CFADR2, "AddressLine")
    		           @XMLEndTag("DeliveryAddress")

                          @XMLBeginTag("Recipient")
                              @XMLTag(V_CFNAME, "OrganizationName")
    		           @XMLEndTag("Recipient")

		       @XMLEndTag("PostalAddress")
              @XMLEndTag("CompanyFacility")
	   %}
      @XMLEndTag("CompanyFacilityList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (sec_06 == "N")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)progOptSecError.d2w/DISPLAY$(genericVarBase)&amp;page_title=@dtw_rurlescseq(page_title)">
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "CFCOMP,CFFACL")
              @DTW_ASSIGN(orderByDisplay, "Company/Facility")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      %INCLUDE "SearchReturn.icl"
  %endif
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Number")
      %if (orderBy == "CFCOMP,CFFACL")
          @DTW_ASSIGN(orderBy, "CFCOMP DESC,CFFACL")
          @DTW_ASSIGN(orderByDisplay, "Co/Fac (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CFCOMP,CFFACL")
          @DTW_ASSIGN(orderByDisplay, "Co/Fac")
      %endif
  %elseif (sequence == "Name")
      %if (orderBy == "CFNAMEU,CFCOMP,CFFACL")
          @DTW_ASSIGN(orderBy, "CFNAMEU DESC,CFCOMP,CFFACL")
          @DTW_ASSIGN(orderByDisplay, "Name (descending), Co/Fac")
      %else
          @DTW_ASSIGN(orderBy, "CFNAMEU,CFCOMP,CFFACL")
          @DTW_ASSIGN(orderByDisplay, "Name, Co/Fac")
      %endif
  %elseif (sequence == "Address")
      %if (orderBy == "CFADR1U,CFNAMEU")
          @DTW_ASSIGN(orderBy, "CFADR1U DESC,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "Address (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "CFADR1U,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "Address, Name")
      %endif
  %elseif (sequence == "City")
      %if (orderBy == "CFCITYU,CFSTID,CFNAMEU")
          @DTW_ASSIGN(orderBy, "CFCITYU DESC,CFSTID,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "City (descending), State, Name")
      %else
          @DTW_ASSIGN(orderBy, "CFCITYU,CFSTID,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "City, State, Name")
      %endif
  %elseif (sequence == "State")
      %if (orderBy == "CFSTID,CFCITYU,CFNAMEU")
          @DTW_ASSIGN(orderBy, "CFSTID DESC,CFCITYU,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "State (descending), City, Name")
      %else
          @DTW_ASSIGN(orderBy, "CFSTID,CFCITYU,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "State, City, Name")
      %endif
  %elseif (sequence == "Zip")
      %if (orderBy == "CFZIP,CFCITYU,CFNAMEU")
          @DTW_ASSIGN(orderBy, "CFZIP DESC,CFCITYU,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "Zip (descending), City, Name")
      %else
          @DTW_ASSIGN(orderBy, "CFZIP,CFCITYU,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "Zip, City, Name")
      %endif
  %elseif (sequence == "Phone")
      %if (orderBy == "CFPHON,CFNAMEU")
          @DTW_ASSIGN(orderBy, "CFPHON DESC,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "Phone Number (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "CFPHON,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "Phone Number, Name")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchPhone, 10, 0) &&
                      editNum(document.Search.srchCo, 2, 0) &&
                      editNum(document.Search.srchFac, 4, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "HRCOFACSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y&amp;backHome=@dtw_rurlescseq(backHome)")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)&amp;backHome=@dtw_rurlescseq(backHome)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Company</td>
                              @dtw_assign(operNbr, "operCo")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchCo" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Facility</td>
                              @dtw_assign(operNbr, "operFac")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchFac" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Name</td>
                              @dtw_assign(operNbr, "operName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchName" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Address</td>
                              @dtw_assign(operNbr, "operAddr")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchAddr" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">City</td>
                              @dtw_assign(operNbr, "operCity")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCity" size="16" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">State</td>
                              @dtw_assign(operNbr, "operState")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchState" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)StateSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Search&amp;fldName=srchState&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stateDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Zip</td>
                              @dtw_assign(operNbr, "operZip")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchZip" size="10" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Phone Number</td>
                              <td>&nbsp;</td>
                              <td class="inputnmbr"><input type="text" name="srchPhone" size="10" maxlength="10"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchCo.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("CFCOMP", "Company", $(srchCo), "", operCo, "N")
  @Build_WildCard ("CFFACL", "Facility", $(srchFac), "", operFac, "N")
  @Build_WildCard ("CFNAMEU", "Name", $(srchName), "U", operName, "A")
  @Build_WildCard ("upper(CFADR1)", "Address", $(srchAddr), "U", operAddr, "A")
  @Build_WildCard ("upper(CFCITY)", "City", $(srchCity), "U", operCity, "A")
  @Build_WildCard ("CFSTID", "State", $(srchState), "U", operState, "A")
  @Build_WildCard ("CFZIP", "Zip", $(srchZip), "", operZip, "A")
  @Build_WildCard ("CFPHON", "Phone Number", $(srchPhone), "", "", "PA")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)&amp;backHome=@dtw_rurlescseq(backHome)")
  %INCLUDE "WildCardUpdate.icl"
%}