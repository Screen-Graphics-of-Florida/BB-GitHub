%FUNCTION(dtw_sql) Process_Select_Exception (IN CHAR(64)    profileHandle,
                                                CHAR(2)     dataBaseID,
                                                CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="exception"></a>
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)WFException.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("VPDESCU,VIDESCU,RMDESCU", "Program")
                  @Format_Column_Header("VIDESCU,RMDESCU", "Validation")
                  @Format_Column_Header("RMDESCU,VIDESCU", "Role")
                  @Format_Column_Header("FLDESCU,RMDESCU,VIDESCU", "Bypass Validation")
                  @Format_Column_Header("VEVLID,RMDESCU", "Validation ID")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;documentType=@dtw_rurlescseq(V_FMDOCT)&amp;docDescr=@dtw_rurlescseq(V_DODESC)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              <tr class="$(rowClass)">
                  <td class="colalph" $(helpCursor)><span title="$(V_VEVPGM)">$(V_VPDESC)</span></td>                                      	
                  <td class="colalph">$(V_VIDESC)</td>                                      	
                  <td class="colcode" $(helpCursor)><span title="$(V_VEROLE)">$(V_RMDESC)</span></td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_VEBYPS)">$(V_FLDESC)</span></td>                                      	
                  <td class="colnmbr">$(V_VEVLID)</td>                                      	
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Process_Select_Transition (IN CHAR(64)    profileHandle,
                                                 CHAR(2)     dataBaseID,
                                                 CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="transition"></a>
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)WFTransition.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("PDDESCU_FR", "From Detail Point Description")
                  @Format_Column_Header("TRFAIL", "Pass/<br>Fail")
                  @Format_Column_Header("TRLEVL", "And Split")
                  @Format_Column_Header("TROPT", "Opt")
                  @Format_Column_Header("PDDESCU_TO", "To Detail Point Description")
                  @Format_Column_Header("CMDESCU", "Condition")
                  @Format_Column_Header("VIDESCU", "Validation")
                  @Format_Column_Header("TRFPNT", "From Detail Point")
                  @Format_Column_Header("TRTPNT", "To Detail Point")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @RtvFldDesc("FLTYPE='WFPASSFAIL' and FLVALU='$(V_TRFAIL)'", "SYFLAG", "FLDESC", failDesc)
              @RtvFldDesc("FLTYPE='WFOPTTRANS' and FLVALU='$(V_TROPT)'", "SYFLAG", "FLDESC", optDesc)
              <tr class="$(rowClass)">
                  <td class="colalph">$(V_PDDESC_FR)</td>
                  <td class="colcode" $(helpCursor)><span title="$(failDesc)">$(V_TRFAIL)</span></td>
                  <td class="colalph">$(V_TRLEVL)</td>
                  <td class="colcode" $(helpCursor)><span title="$(optDesc)">$(V_TROPT)</span></td>
                  <td class="colalph">$(V_PDDESC_TO)</td>
                  <td class="colalph" $(helpCursor)><span title="$(V_TRCOND)">$(V_CMDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_TRVPGM)-$(V_TRVLID)">$(V_VIDESC)</span></td>
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)WFDetailSelect.d2w/REPORT$(d2wVarBase)&amp;passedWfPoint=@dtw_rurlescseq(V_TRFPNT)&amp;passedWfSequence=@dtw_rurlescseq(V_TRFSEQ)" title="View Detail Point">$(V_TRFPNT)-$(V_TRFSEQ)</a></td>
                  %if (V_TRTPNT>"0")
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)WFDetailSelect.d2w/REPORT$(d2wVarBase)&amp;passedWfPoint=@dtw_rurlescseq(V_TRTPNT)&amp;passedWfSequence=@dtw_rurlescseq(V_TRTSEQ)" title="View Detail Point">$(V_TRTPNT)-$(V_TRTSEQ)</a></td>
                  %else
                      <td class="colnmbr">&nbsp;</td>
                  %endif
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}