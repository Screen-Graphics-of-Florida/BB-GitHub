%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Table Link Maintenance"
  d2wName                 = "TableLinkMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;tblID=@dtw_rurlescseq(tblID)&amp;linkID=@dtw_rurlescseq(linkID)&amp;tableName=@dtw_rurlescseq(tableName)&amp;tableDesc=@dtw_rurlescseq(tableDesc)&amp;dftD2WName=@dtw_rurlescseq(dftD2WName)&amp;progOptName=@dtw_rurlescseq(progOptName)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;urlID=@dtw_rurlescseq(urlID)&amp;maintenanceCode=D"
  programName             = "HSYTBL_E"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              function validate(chgForm) {
                  if (document.Chg.linkType.value =="")
                         {alert("$(reqFieldError)"); return false;}
                      if (editNum(document.Chg.dspSeq, 3, 0) &&
                          editNum(document.Chg.progSeq, 2, 0))
                          return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "TABLELINKMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From SYTBLL ", stmtSQL)
                          @dtw_concat(stmtSQL, "Where TLTBID=$(tblID) and TLLKID=$(linkID)", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "linkType")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)

                          @DecatErr_Field("@@type", "linkType")    @dtw_assign(Err_TLTYPE,  fieldValue)
                          @DecatErr_Field("@@dseq", "dspSeq")      @dtw_assign(Err_TLDSEQ,  fieldValue)
                          @DecatErr_Field("@@urli", "urlID")       @dtw_assign(Err_TLURLID, fieldValue)
                          @DecatErr_Field("@@imgn", "image")       @dtw_assign(Err_TLIMG,   fieldValue)
                          @DecatErr_Field("@@d2wn", "ovrD2WName")  @dtw_assign(Err_TLD2WN,  fieldValue)
                          @DecatErr_Field("@@cnid", "condID")      @dtw_assign(Err_TLCNID,  fieldValue)
                          @DecatErr_Field("@@cseq", "condSeq")     @dtw_assign(Err_TLCSEQ,  fieldValue)
                          @DecatErr_Field("@@coln", "column")      @dtw_assign(Err_TLCOLN,  fieldValue)
                          @DecatErr_Field("@@filn", "fileName")    @dtw_assign(Err_TLFILN,  fieldValue)
                          @DecatErr_Field("@@selc", "selCriteria") @dtw_assign(Err_TLSELC,  fieldValue)
                          @DecatErr_Field("@@pgov", "progName")    @dtw_assign(Err_TLPGOV,  fieldValue)
                          @DecatErr_Field("@@popt", "progSeq")     @dtw_assign(Err_TLPOPT,  fieldValue)
                          @DecatErr_Field("@@ipth", "imgPath")     @dtw_assign(Err_TLIPTH,  fieldValue)
                      %endif

                      @Decat_Field("@@type")  @dtw_assign(V_TLTYPE,  fieldValue)
                      @Decat_Field("@@dseq")  @dtw_assign(V_TLDSEQ,  fieldValue)
                      @Decat_Field("@@urli")  @dtw_assign(V_TLURLID, fieldValue)
                      @Decat_Field("@@imgn")  @dtw_assign(V_TLIMG, fieldValue)
                      @Decat_Field("@@d2wn")  @dtw_assign(V_TLD2WN,  fieldValue)
                      @Decat_Field("@@cnid")  @dtw_assign(V_TLCNID,  fieldValue)
                      @Decat_Field("@@cseq")  @dtw_assign(V_TLCSEQ,  fieldValue)
                      @Decat_Field("@@coln")  @dtw_assign(V_TLCOLN,  fieldValue)
                      @Decat_Field("@@filn")  @dtw_assign(V_TLFILN,  fieldValue)
                      @Decat_Field("@@selc")  @dtw_assign(V_TLSELC,  fieldValue)
                      @Decat_Field("@@pgov")  @dtw_assign(V_TLPGOV,  fieldValue)
                      @Decat_Field("@@popt")  @dtw_assign(V_TLPOPT,  fieldValue)
                      @Decat_Field("@@ipth")  @dtw_assign(V_TLIPTH,  fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "linkType")
                      %endif
                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "linkType")
                  %else
                      @dtw_assign(focusField, "linkType")
                  %endif

                  @RtvFldDesc("FLTYPE='LINKTYPE' and FLVALU='$(V_TLTYPE)'", "SYFLAG", "FLDESC", linkTypeDesc)
                  @SetTextOvr(Err_TLTYPE)
                  <tr><td class="dsphdr"><span $(textOvr)>Type</span></td>
                      <td class="inputalph"><input name="linkType" type="text" value="$(V_TLTYPE)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=LINKTYPE&amp;flagSrchHdr=@dtw_rurlescseq("Link Type")&amp;docName=Chg&amp;fldName=linkType&amp;fldDesc=linkTypeDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input name="linkTypeDesc" value="$(linkTypeDesc)" type="text" size="50" disabled></td>
                  </tr>
                  @DspErrMsg(Err_TLTYPE)

                  @SetTextOvr(Err_TLDSEQ)
                  <tr><td class="dsphdr"><span $(textOvr)>Display Sequence</span></td>
                      <td class="inputnmbr"><input name="dspSeq" type="text" value="$(V_TLDSEQ)" size="1" maxlength="3"></td>
                  </tr>
                  @DspErrMsg(Err_TLDSEQ)

                  @RtvFldDesc("FUID='$(V_TLURLID)'", "SYURLM", "FUDESC", fieldDesc)
                  @SetTextOvr(Err_TLURLID)
                  <tr><td class="dsphdr"><span $(textOvr)>URL ID</span></td>
                      <td class="inputalph"><input name="urlID" type="text" value="$(V_TLURLID)" size="50" maxlength="55"><a href="$(homeURL)$(cGIPath)URLSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=urlID&amp;fldDesc=urlIDDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="urlIDDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_TLURLID)

                  @SetTextOvr(Err_TLIMG)
                  <tr><td class="dsphdr"><span $(textOvr)>Image</span></td>
                      <td class="inputalph"><input name="image" type="text" value="$(V_TLIMG)" size="50" maxlength="256"></td>
                  </tr>
                  @DspErrMsg(Err_TLIMG)

                  @SetTextOvr(Err_TLD2WN)
                  <tr><td class="dsphdr"><span $(textOvr)>Script Name</span></td>
                      <td class="inputalph"><input name="ovrD2WName" type="text" value="$(V_TLD2WN)" size="50" maxlength="100"></td>
                  </tr>
                  @DspErrMsg(Err_TLD2WN)

                  @RtvFldDesc("CCCNID='$(V_TLCNID)'", "SYTBCC", "CCDESC", fieldDesc)
                  @SetTextOvr(Err_TLCNID)
                  <tr><td class="dsphdr"><span $(textOvr)>Condition ID</span></td>
                      <td class="inputalph"><input name="condID" type="text"  value="$(V_TLCNID)" size="10" maxlength="10"><a href="$(homeURL)$(cGIPath)ColumnConditionSearch.d2w/REPORT$(genericVarBase)&amp;docName=Chg&amp;fldName=condID&amp;fldDesc=condIDDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="condIDDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_TLCNID)

                  @SetTextOvr(Err_TLCSEQ)
                  <tr><td class="dsphdr"><span $(textOvr)>Condition Sequence</span></td>
                      <td class="inputnmbr"><input name="condSeq" type="text" value="$(V_TLCSEQ)" size="1" maxlength="3"></td>
                  </tr>
                  @DspErrMsg(Err_TLCSEQ)

                  @RtvFldDesc("TCTBLN='$(tableName)' and TCCOLN='$(V_TLCOLN)'", "SYTBLC", "TCCTXT", fieldDesc)
                  @SetTextOvr(Err_TLCOLN)
                  <tr><td class="dsphdr"><span $(textOvr)>Column Name</span></td>
                      <td class="inputalph"><input type="text" name="column" value="$(V_TLCOLN)" size="10" maxlength="130"><a href="$(homeURL)$(cGIPath)TableColumnSearch.d2w/REPORT$(d2wVarBase)&amp;docName=Chg&amp;fldName=column&amp;fldDesc=columnDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="columnDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_TLCOLN)

                  @SetTextOvr(Err_TLFILN)
                  <tr><td class="dsphdr"><span $(textOvr)>Table</span></td>
                      <td class="inputalph"><input name="fileName" type="text" value="$(V_TLFILN)" size="300" maxlength="1000"></td>
                  </tr>
                  @DspErrMsg(Err_TLFILN)

                  @SetTextOvr(Err_TLSELC)
                  <tr><td class="dsphdr"><span $(textOvr)>Selection Criteria</span></td>
                      <td class="inputalph"><input name="selCriteria" type="text" value="$(V_TLSELC)" size="300" maxlength="3000"></td>
                  </tr>
                  @DspErrMsg(Err_TLSELC)

                  @RtvFldDesc("PTPGID='$(V_TLPGOV)'", "SYILET", "PTDESC", fieldDesc)
                  @SetTextOvr(Err_TLPGOV)
                  <tr><td class="dsphdr"><span $(textOvr)>Override Program Option Program</span></td>
                      <td class="inputalph"><input name="progName" type="text" value="$(V_TLPGOV)" size="10" maxlength="10"><a href="$(homeURL)$(cGIPath)ProgramOptionSeqSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=progName&amp;fldDesc=progDesc&amp;fldSeq=progSeq" onclick="$(searchWinVar)"> $(searchImage) </a><input name="progDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_TLPGOV)

                  @SetTextOvr(Err_TLPOPT)
                  <tr><td class="dsphdr"><span $(textOvr)>Program Option Sequence</span></td>
                      <td class="inputnmbr"><input name="progSeq" type="text" value="$(V_TLPOPT)" size="1" maxlength="2"></td>
                  </tr>
                  @DspErrMsg(Err_TLPOPT)

                  @SetTextOvr(Err_TLIPTH)
                  <tr><td class="dsphdr"><span $(textOvr)>Image Path</span></td>
                      <td class="inputalph"><input name="imgPath" type="text" value="$(V_TLIPTH)" size="50" maxlength="256"></td>
                  </tr>
                  @DspErrMsg(Err_TLIPTH)
              </table>
    			
              %}

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                              CHAR(2)     dataBaseID,
                                              CHAR(1)     maintenanceCode,
                                              CHAR(1)     errFound,
                                              CHAR(32000) edtVar,                             	
                                              CHAR(32000) errVar)
{%EXEC {HSYTBL_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @dtw_mUPPERCASE(linkType)
  @dtw_mUPPERCASE(progName)
  @dtw_mUPPERCASE(column)

  %if (progOptName == progName)
      @dtw_assign(progName, "")
  %endif
  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@tbln", tableName)
  @Concat_Field("@@tbid", tblID)
  @Concat_Field("@@lkid", linkID)
  @Concat_Field("@@type", linkType)
  @Concat_Field("@@dseq", dspSeq)
  @Concat_Field("@@urli", urlID)
  @Concat_Field("@@imgn", image)
  @Concat_Field("@@d2wn", ovrD2WName)
  @Concat_Field("@@cnid", condID)
  @Concat_Field("@@cseq", condSeq)
  @Concat_Field("@@coln", column)
  @Concat_Field("@@filn", fileName)
  @Concat_Field("@@selc", selCriteria)
  @Concat_Field("@@pgov", progName)
  @Concat_Field("@@popt", progSeq)
  @Concat_Field("@@ipth", imgPath)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, "$(urlID)", "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)TableLink.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@urli", "urlID")
      @Format_ConfMsg_Desc("", "$(fieldValue)", "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)TableLink.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
