%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HPRLAM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else

      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @dtw_assign(coNumber,@dtw_rstrip(coNumber))
  @dtw_assign(facNumber,@dtw_rstrip(facNumber))
  @dtw_assign(cashAcctNumber,@dtw_rstrip(cashAcctNumber))
  @dtw_assign(cashSubAcctNumber,@dtw_rstrip(cashSubAcctNumber))
  @dtw_assign(accrWagesAcctNumber,@dtw_rstrip(accrWagesAcctNumber))
  @dtw_assign(accrWagesSubAcctNumber,@dtw_rstrip(accrWagesSubAcctNumber))
  @dtw_assign(prPayableAcctNumber,@dtw_rstrip(prPayableAcctNumber))
  @dtw_assign(prPayableSubAcctNumber,@dtw_rstrip(prPayableSubAcctNumber))
  @dtw_assign(accrEmplTaxAcctNumber,@dtw_rstrip(accrEmplTaxAcctNumber))
  @dtw_assign(accrEmplTaxSubAcctNumber,@dtw_rstrip(accrEmplTaxSubAcctNumber))
  @dtw_assign(accrVacAcctNumber,@dtw_rstrip(accrVacAcctNumber))
  @dtw_assign(accrVacSubAcctNumber,@dtw_rstrip(accrVacSubAcctNumber))
  @dtw_assign(accrSickAcctNumber,@dtw_rstrip(accrSickAcctNumber))
  @dtw_assign(accrSickSubAcctNumber,@dtw_rstrip(accrSickSubAcctNumber))
  @dtw_assign(accrMiscAcctNumber,@dtw_rstrip(accrMiscAcctNumber))
  @dtw_assign(accrMiscSubAcctNumber,@dtw_rstrip(accrMiscSubAcctNumber))
  @dtw_assign(employerFicaTaxesAcctNumber,@dtw_rstrip(employerFicaTaxesAcctNumber))
  @dtw_assign(employerFicaTaxesSubAcctNumber,@dtw_rstrip(employerFicaTaxesSubAcctNumber))
  @dtw_assign(employerFedUCAcctNumber,@dtw_rstrip(employerFedUCAcctNumber))
  @dtw_assign(employerFedUCSubAcctNumber,@dtw_rstrip(employerFedUCSubAcctNumber))
  @dtw_assign(employerLocalAcctNumber,@dtw_rstrip(employerLocalAcctNumber))
  @dtw_assign(employerLocalSubAcctNumber,@dtw_rstrip(employerLocalSubAcctNumber))
  @dtw_assign(employerStateDisAcctNumber,@dtw_rstrip(employerStateDisAcctNumber))
  @dtw_assign(employerStateDisSubAcctNumber,@dtw_rstrip(employerStateDisSubAcctNumber))
  @dtw_assign(employerStateWCAcctNumber,@dtw_rstrip(employerStateWCAcctNumber))
  @dtw_assign(employerStateWCSubAcctNumber,@dtw_rstrip(employerStateWCSubAcctNumber))
  @dtw_assign(employeeFicaTaxesAcctNumber,@dtw_rstrip(employeeFicaTaxesAcctNumber))
  @dtw_assign(employeeFicaTaxesSubAcctNumber,@dtw_rstrip(employeeFicaTaxesSubAcctNumber))
  @dtw_assign(employeeFedTaxesAcctNumber,@dtw_rstrip(employeeFedTaxesAcctNumber))
  @dtw_assign(employeeFedTaxesSubAcctNumber,@dtw_rstrip(employeeFedTaxesSubAcctNumber))
  @dtw_assign(employeeEarnedIncomeAcctNumber,@dtw_rstrip(employeeEarnedIncomeAcctNumber))
  @dtw_assign(employeeEarnedIncomeSubAcctNumber,@dtw_rstrip(employeeEarnedIncomeSubAcctNumber))
  @dtw_assign(employeeStateTaxesAcctNumber,@dtw_rstrip(employeeStateTaxesAcctNumber))
  @dtw_assign(employeeStateTaxesSubAcctNumber,@dtw_rstrip(employeeStateTaxesSubAcctNumber))
  @dtw_assign(employeeLocalAcctNumber,@dtw_rstrip(employeeLocalAcctNumber))
  @dtw_assign(employeeLocalSubAcctNumber,@dtw_rstrip(employeeLocalSubAcctNumber))
  @dtw_assign(employeeStateDisAcctNumber,@dtw_rstrip(employeeStateDisAcctNumber))
  @dtw_assign(employeeStateDisSubAcctNumber,@dtw_rstrip(employeeStateDisSubAcctNumber))
  @dtw_assign(employeeStateWCAcctNumber,@dtw_rstrip(employeeStateWCAcctNumber))
  @dtw_assign(employeeStateWCSubAcctNumber,@dtw_rstrip(employeeStateWCSubAcctNumber))
  @dtw_assign(chargeTipsPayableAcctNumber,@dtw_rstrip(chargeTipsPayableAcctNumber))
  @dtw_assign(chargeTipsPayableSubAcctNumber,@dtw_rstrip(chargeTipsPayableSubAcctNumber))
  @dtw_assign(chargeTipsAccrualAcctNumber,@dtw_rstrip(chargeTipsAccrualAcctNumber))
  @dtw_assign(chargeTipsAccrualSubAcctNumber,@dtw_rstrip(chargeTipsAccrualSubAcctNumber))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@comp", coNumber)
  @Concat_Field("@@facl", facNumber)
  @Concat_Field("@@csha", cashAcctNumber)
  @Concat_Field("@@cshs", cashSubAcctNumber)
  @Concat_Field("@@epwa", accrWagesAcctNumber)
  @Concat_Field("@@epws", accrWagesSubAcctNumber)
  @Concat_Field("@@appa", prPayableAcctNumber)
  @Concat_Field("@@apps", prPayableSubAcctNumber)
  @Concat_Field("@@epta", accrEmplTaxAcctNumber)
  @Concat_Field("@@epts", accrEmplTaxSubAcctNumber)
  @Concat_Field("@@avpa", accrVacAcctNumber)
  @Concat_Field("@@avps", accrVacSubAcctNumber)
  @Concat_Field("@@aspa", accrSickAcctNumber)
  @Concat_Field("@@asps", accrSickSubAcctNumber)
  @Concat_Field("@@mspa", accrMiscAcctNumber)
  @Concat_Field("@@msps", accrMiscSubAcctNumber)
  @Concat_Field("@@efia", employerFicaTaxesAcctNumber)
  @Concat_Field("@@efis", employerFicaTaxesSubAcctNumber)
  @Concat_Field("@@euca", employerFedUCAcctNumber)
  @Concat_Field("@@eucs", employerFedUCSubAcctNumber)
  @Concat_Field("@@elta", employerLocalAcctNumber)
  @Concat_Field("@@elts", employerLocalSubAcctNumber)
  @Concat_Field("@@esda", employerStateDisAcctNumber)
  @Concat_Field("@@esds", employerStateDisSubAcctNumber)
  @Concat_Field("@@ewca", employerStateWCAcctNumber)
  @Concat_Field("@@ewcs", employerStateWCSubAcctNumber)
  @Concat_Field("@@wfia", employeeFicaTaxesAcctNumber)
  @Concat_Field("@@wfis", employeeFicaTaxesSubAcctNumber)
  @Concat_Field("@@wfta", employeeFedTaxesAcctNumber)
  @Concat_Field("@@wfts", employeeFedTaxesSubAcctNumber)
  @Concat_Field("@@eica", employeeEarnedIncomeAcctNumber)
  @Concat_Field("@@eics", employeeEarnedIncomeSubAcctNumber)
  @Concat_Field("@@wsta", employeeStateTaxesAcctNumber)
  @Concat_Field("@@wsts", employeeStateTaxesSubAcctNumber)
  @Concat_Field("@@wlta", employeeLocalAcctNumber)
  @Concat_Field("@@wlts", employeeLocalSubAcctNumber)
  @Concat_Field("@@wsda", employeeStateDisAcctNumber)
  @Concat_Field("@@wsds", employeeStateDisSubAcctNumber)
  @Concat_Field("@@wwca", employeeStateWCAcctNumber)
  @Concat_Field("@@wwcs", employeeStateWCSubAcctNumber)
  @Concat_Field("@@ctpa", chargeTipsPayableAcctNumber)
  @Concat_Field("@@ctps", chargeTipsPayableSubAcctNumber)
  @Concat_Field("@@ctaa", chargeTipsAccrualAcctNumber)
  @Concat_Field("@@ctas", chargeTipsAccrualSubAcctNumber)
  @Concat_Field("@@tstp", timeStamp)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)
  @DecatErr_Field("@@comp", "coNumber")    @dtw_assign(Err_LACOMP, fieldValue)

  
  %if (errFound == "")
      @Format_HRCoFac(coNumber, facNumber, "", F_CoFac)
      @RtvFldDesc("CFCOMP=$(coNumber) and CFFACL=$(facNumber)", "HRCOFC", "CFNAME", fieldDesc)
      @Format_ConfMsg_Desc(maintenanceCode, $(fieldDesc), $(F_CoFac), "", "", "", "", confMessage)
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=191&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %elif ((maintenanceCode == "C" || maintenanceCode == "D") && errFound != "" && fieldValue != "")  
      @Format_HRCoFac(coNumber, facNumber, "", F_CoFac)
      @RtvFldDesc("CFCOMP=$(coNumber) and CFFACL=$(facNumber)", "HRCOFC", "CFNAME", fieldDesc)
      @Format_ConfMsg_Desc("E", $(fieldDesc), "$(F_CoFac)", "<br>$(fieldValue)", "", "", "", confMessage)   
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=191&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif             
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;coNumber=@dtw_rurlescseq(coNumber)&amp;facNumber=@dtw_rurlescseq(facNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
