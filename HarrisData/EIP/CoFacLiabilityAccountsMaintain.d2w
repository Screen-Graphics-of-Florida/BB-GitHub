%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Co/Fac Liability Accounts Maintenance"
  d2wName                 = "CoFacLiabilityAccountsMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;coNumber=@dtw_rurlescseq(coNumber)&amp;facNumber=@dtw_rurlescseq(facNumber)&amp;maintenanceCode=D"
  programName             = "HPRLAM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
      %if (coNumber>"0" && facNumber>"0")
          @RtvFldDesc("CFCOMP=$(coNumber) and CFFACL=$(facNumber)", "HRCOFC", "PCTIP", tipCompany)
      %else
          @dtw_assign(tipCompany, "Y")
      %endif
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  function validate(chgForm) {
                      if (document.Chg.coNumber.value =="" ||
                          document.Chg.facNumber.value =="" )
                         {alert("$(reqFieldError)"); return false;}
                      if (editNum(document.Chg.coNumber,                           2, 0) &&
                          editNum(document.Chg.facNumber,                          4, 0) &&
                          editNum(document.Chg.cashAcctNumber,                     4, 0) &&
                          editNum(document.Chg.cashSubAcctNumber,                  4, 0) &&
                          editNum(document.Chg.accrWagesAcctNumber,                4, 0) &&
                          editNum(document.Chg.accrWagesSubAcctNumber,             4, 0) &&
                          editNum(document.Chg.prPayableAcctNumber,                4, 0) &&
                          editNum(document.Chg.prPayableSubAcctNumber,             4, 0) &&
                          editNum(document.Chg.accrEmplTaxAcctNumber,              4, 0) &&
                          editNum(document.Chg.accrEmplTaxSubAcctNumber,           4, 0) &&
                          editNum(document.Chg.accrVacAcctNumber,                  4, 0) &&
                          editNum(document.Chg.accrVacSubAcctNumber,               4, 0) &&
                          editNum(document.Chg.accrSickAcctNumber,                 4, 0) &&
                          editNum(document.Chg.accrSickSubAcctNumber,              4, 0) &&
                          editNum(document.Chg.accrMiscAcctNumber,                 4, 0) &&
                          editNum(document.Chg.accrMiscSubAcctNumber,              4, 0) &&
                          editNum(document.Chg.employerFicaTaxesAcctNumber,        4, 0) &&
                          editNum(document.Chg.employerFicaTaxesSubAcctNumber,     4, 0) &&
                          editNum(document.Chg.employerFedUCAcctNumber,            4, 0) &&
                          editNum(document.Chg.employerFedUCSubAcctNumber,         4, 0) &&
                          editNum(document.Chg.employerLocalAcctNumber,            4, 0) &&
                          editNum(document.Chg.employerLocalSubAcctNumber,         4, 0) &&
                          editNum(document.Chg.employerStateDisAcctNumber,         4, 0) &&
                          editNum(document.Chg.employerStateDisSubAcctNumber,      4, 0) &&
                          editNum(document.Chg.employerStateWCAcctNumber,          4, 0) &&
                          editNum(document.Chg.employerStateWCSubAcctNumber,       4, 0) &&
                          editNum(document.Chg.employeeFicaTaxesAcctNumber,        4, 0) &&
                          editNum(document.Chg.employeeFicaTaxesSubAcctNumber,     4, 0) &&
                          editNum(document.Chg.employeeFedTaxesAcctNumber,         4, 0) &&
                          editNum(document.Chg.employeeFedTaxesSubAcctNumber,      4, 0) &&
                          editNum(document.Chg.employeeEarnedIncomeAcctNumber,     4, 0) &&
                          editNum(document.Chg.employeeEarnedIncomeSubAcctNumber,  4, 0) &&
                          editNum(document.Chg.employeeStateTaxesAcctNumber,       4, 0) &&
                          editNum(document.Chg.employeeStateTaxesSubAcctNumber,    4, 0) &&
                          editNum(document.Chg.employeeLocalAcctNumber,            4, 0) &&
                          editNum(document.Chg.employeeLocalSubAcctNumber,         4, 0) &&
                          editNum(document.Chg.employeeStateDisAcctNumber,         4, 0) &&
                          editNum(document.Chg.employeeStateDisSubAcctNumber,      4, 0) &&
                          editNum(document.Chg.employeeStateWCAcctNumber,          4, 0) &&
                          editNum(document.Chg.employeeStateWCSubAcctNumber,       4, 0)
                          %if (tipCompany=="Y") &&
                              editNum(document.Chg.chargeTipsPayableAcctNumber,        4, 0) &&
                              editNum(document.Chg.chargeTipsPayableSubAcctNumber,     4, 0) &&
                              editNum(document.Chg.chargeTipsAccrualAcctNumber,        4, 0) &&
                              editNum(document.Chg.chargeTipsAccrualSubAcctNumber,     4, 0)
                          %endif
                         )
                          return true;

                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
	           %INCLUDE "NumEdit.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "COFACLIABILITYACCOUNTSMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "SELECT * FROM PRLIAC WHERE LACOMP=$(coNumber) AND LAFACL=$(facNumber)  ", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=191")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(tipCompany, "Y")
                          @dtw_assign(focusField, "coNumber")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@comp", "coNumber")                           @dtw_assign(Err_LACOMP, fieldValue)
                          @DecatErr_Field("@@facl", "facNumber")                          @dtw_assign(Err_LAFACL, fieldValue)
                          @DecatErr_Field("@@csha", "cashAcctNumber")                     @dtw_assign(Err_LACSHA, fieldValue)
                          @DecatErr_Field("@@cshs", "cashSubAcctNumber")                  @dtw_assign(Err_LACSHS, fieldValue)
                          @DecatErr_Field("@@epwa", "accrWagesAcctNumber")                @dtw_assign(Err_LAEPWA, fieldValue)
                          @DecatErr_Field("@@epws", "accrWagesSubAcctNumber")             @dtw_assign(Err_LAEPWS, fieldValue)
                          @DecatErr_Field("@@appa", "prPayableAcctNumber")                @dtw_assign(Err_LAAPPA, fieldValue)
                          @DecatErr_Field("@@apps", "prPayableSubAcctNumber")             @dtw_assign(Err_LAAPPS, fieldValue)
                          @DecatErr_Field("@@epta", "accrEmplTaxAcctNumber")              @dtw_assign(Err_LAEPTA, fieldValue)
                          @DecatErr_Field("@@epts", "accrEmplTaxSubAcctNumber")           @dtw_assign(Err_LAEPTS, fieldValue)
                          @DecatErr_Field("@@avpa", "accrVacAcctNumber")                  @dtw_assign(Err_LAAVPA, fieldValue)
                          @DecatErr_Field("@@avps", "accrVacSubAcctNumber")               @dtw_assign(Err_LAAVPS, fieldValue)
                          @DecatErr_Field("@@aspa", "accrSickAcctNumber")                 @dtw_assign(Err_LAASPA, fieldValue)
                          @DecatErr_Field("@@asps", "accrSickSubAcctNumber")              @dtw_assign(Err_LAASPS, fieldValue)
                          @DecatErr_Field("@@mspa", "accrMiscAcctNumber")                 @dtw_assign(Err_LAMSPA, fieldValue)
                          @DecatErr_Field("@@msps", "accrMiscSubAcctNumber")              @dtw_assign(Err_LAMSPS, fieldValue)
                          @DecatErr_Field("@@efia", "employerFicaTaxesAcctNumber")        @dtw_assign(Err_LAEFIA, fieldValue)
                          @DecatErr_Field("@@efis", "employerFicaTaxesSubAcctNumber")     @dtw_assign(Err_LAEFIS, fieldValue)
                          @DecatErr_Field("@@euca", "employerFedUCAcctNumber")            @dtw_assign(Err_LAEUCA, fieldValue)
                          @DecatErr_Field("@@eucs", "employerFedUCSubAcctNumber")         @dtw_assign(Err_LAEUCS, fieldValue)
                          @DecatErr_Field("@@elta", "employerLocalAcctNumber")            @dtw_assign(Err_LAELTA, fieldValue)
                          @DecatErr_Field("@@elts", "employerLocalSubAcctNumber")         @dtw_assign(Err_LAELTS, fieldValue)
                          @DecatErr_Field("@@esda", "employerStateDisAcctNumber")         @dtw_assign(Err_LAESDA, fieldValue)
                          @DecatErr_Field("@@esds", "employerStateDisSubAcctNumber")      @dtw_assign(Err_LAESDS, fieldValue)
                          @DecatErr_Field("@@ewca", "employerStateWCAcctNumber")          @dtw_assign(Err_LAEWCA, fieldValue)
                          @DecatErr_Field("@@ewcs", "employerStateWCSubAcctNumber")       @dtw_assign(Err_LAEWCS, fieldValue)
                          @DecatErr_Field("@@wfia", "employeeFicaTaxesAcctNumber")        @dtw_assign(Err_LAWFIA, fieldValue)
                          @DecatErr_Field("@@wfis", "employeeFicaTaxesSubAcctNumber")     @dtw_assign(Err_LAWFIS, fieldValue)
                          @DecatErr_Field("@@wfta", "employeeFedTaxesAcctNumber")         @dtw_assign(Err_LAWFTA, fieldValue)
                          @DecatErr_Field("@@wfts", "employeeFedTaxesSubAcctNumber")      @dtw_assign(Err_LAWFTS, fieldValue)
                          @DecatErr_Field("@@eica", "employeeEarnedIncomeAcctNumber")     @dtw_assign(Err_LAEICA, fieldValue)
                          @DecatErr_Field("@@eics", "employeeEarnedIncomeSubAcctNumber")  @dtw_assign(Err_LAEICS, fieldValue)
                          @DecatErr_Field("@@wsta", "employeeStateTaxesAcctNumber")       @dtw_assign(Err_LAWSTA, fieldValue)
                          @DecatErr_Field("@@wsts", "employeeStateTaxesSubAcctNumber")    @dtw_assign(Err_LAWSTS, fieldValue)
                          @DecatErr_Field("@@wlta", "employeeLocalAcctNumber")            @dtw_assign(Err_LAWLTA, fieldValue)
                          @DecatErr_Field("@@wlts", "employeeLocalSubAcctNumber")         @dtw_assign(Err_LAWLTS, fieldValue)
                          @DecatErr_Field("@@wsda", "employeeStateDisAcctNumber")         @dtw_assign(Err_LAWSDA, fieldValue)
                          @DecatErr_Field("@@wsds", "employeeStateDisSubAcctNumber")      @dtw_assign(Err_LAWSDS, fieldValue)
                          @DecatErr_Field("@@wwca", "employeeStateWCAcctNumber")          @dtw_assign(Err_LAWWCA, fieldValue)
                          @DecatErr_Field("@@wwcs", "employeeStateWCSubAcctNumber")       @dtw_assign(Err_LAWWCS, fieldValue)
                          @DecatErr_Field("@@ctpa", "chargeTipsPayableAcctNumber")        @dtw_assign(Err_LACTPA, fieldValue)
                          @DecatErr_Field("@@ctps", "chargeTipsPayableSubAcctNumber")     @dtw_assign(Err_LACTPS, fieldValue)
                          @DecatErr_Field("@@ctaa", "chargeTipsAccrualAcctNumber")        @dtw_assign(Err_LACTAA, fieldValue)
                          @DecatErr_Field("@@ctas", "chargeTipsAccrualSubAcctNumber")     @dtw_assign(Err_LACTAS, fieldValue)
                          @DecatErr_Field("@@tstp", "timeStamp")                          @dtw_assign(Err_LATSTP, fieldValue)
                      %endif

                      @Decat_Field("@@comp")   @dtw_assign(V_LACOMP, fieldValue)
                      @Decat_Field("@@facl")   @dtw_assign(V_LAFACL, fieldValue)
                      @Decat_Field("@@csha")   @dtw_assign(V_LACSHA, fieldValue)
                      @Decat_Field("@@cshs")   @dtw_assign(V_LACSHS, fieldValue)
                      @Decat_Field("@@epwa")   @dtw_assign(V_LAEPWA, fieldValue)
                      @Decat_Field("@@epws")   @dtw_assign(V_LAEPWS, fieldValue)
                      @Decat_Field("@@appa")   @dtw_assign(V_LAAPPA, fieldValue)
                      @Decat_Field("@@apps")   @dtw_assign(V_LAAPPS, fieldValue)
                      @Decat_Field("@@epta")   @dtw_assign(V_LAEPTA, fieldValue)
                      @Decat_Field("@@epts")   @dtw_assign(V_LAEPTS, fieldValue)
                      @Decat_Field("@@avpa")   @dtw_assign(V_LAAVPA, fieldValue)
                      @Decat_Field("@@avps")   @dtw_assign(V_LAAVPS, fieldValue)
                      @Decat_Field("@@aspa")   @dtw_assign(V_LAASPA, fieldValue)
                      @Decat_Field("@@asps")   @dtw_assign(V_LAASPS, fieldValue)
                      @Decat_Field("@@mspa")   @dtw_assign(V_LAMSPA, fieldValue)
                      @Decat_Field("@@msps")   @dtw_assign(V_LAMSPS, fieldValue)
                      @Decat_Field("@@efia")   @dtw_assign(V_LAEFIA, fieldValue)
                      @Decat_Field("@@efis")   @dtw_assign(V_LAEFIS, fieldValue)
                      @Decat_Field("@@euca")   @dtw_assign(V_LAEUCA, fieldValue)
                      @Decat_Field("@@eucs")   @dtw_assign(V_LAEUCS, fieldValue)
                      @Decat_Field("@@elta")   @dtw_assign(V_LAELTA, fieldValue)
                      @Decat_Field("@@elts")   @dtw_assign(V_LAELTS, fieldValue)
                      @Decat_Field("@@esda")   @dtw_assign(V_LAESDA, fieldValue)
                      @Decat_Field("@@esds")   @dtw_assign(V_LAESDS, fieldValue)
                      @Decat_Field("@@ewca")   @dtw_assign(V_LAEWCA, fieldValue)
                      @Decat_Field("@@ewcs")   @dtw_assign(V_LAEWCS, fieldValue)
                      @Decat_Field("@@wfia")   @dtw_assign(V_LAWFIA, fieldValue)
                      @Decat_Field("@@wfis")   @dtw_assign(V_LAWFIS, fieldValue)
                      @Decat_Field("@@wfta")   @dtw_assign(V_LAWFTA, fieldValue)
                      @Decat_Field("@@wfts")   @dtw_assign(V_LAWFTS, fieldValue)
                      @Decat_Field("@@eica")   @dtw_assign(V_LAEICA, fieldValue)
                      @Decat_Field("@@eics")   @dtw_assign(V_LAEICS, fieldValue)
                      @Decat_Field("@@wsta")   @dtw_assign(V_LAWSTA, fieldValue)
                      @Decat_Field("@@wsts")   @dtw_assign(V_LAWSTS, fieldValue)
                      @Decat_Field("@@wlta")   @dtw_assign(V_LAWLTA, fieldValue)
                      @Decat_Field("@@wlts")   @dtw_assign(V_LAWLTS, fieldValue)
                      @Decat_Field("@@wsda")   @dtw_assign(V_LAWSDA, fieldValue)
                      @Decat_Field("@@wsds")   @dtw_assign(V_LAWSDS, fieldValue)
                      @Decat_Field("@@wwca")   @dtw_assign(V_LAWWCA, fieldValue)
                      @Decat_Field("@@wwcs")   @dtw_assign(V_LAWWCS, fieldValue)
                      @Decat_Field("@@ctpa")   @dtw_assign(V_LACTPA, fieldValue)
                      @Decat_Field("@@ctps")   @dtw_assign(V_LACTPS, fieldValue)
                      @Decat_Field("@@ctaa")   @dtw_assign(V_LACTAA, fieldValue)
                      @Decat_Field("@@ctas")   @dtw_assign(V_LACTAS, fieldValue)
                      @Decat_Field("@@tstp")   @dtw_assign(V_LATSTP, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "coNumber")
                          @dtw_assign(V_LACOMP, "0")
                          @dtw_assign(V_LAFACL, "0")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_LACOMP, "0")
                      @dtw_assign(V_LAFACL, "0")
                      @dtw_assign(focusField, "coNumber")
                  %else
                      @dtw_assign(focusField, "cashAcctNumber")
                  %endif
              	  @SetTextOvr(Err_LATSTP)
                  <tr><td class="dsphdr"><span $(textOvr)>.</span></td>
                  	  <td><input name="timeStamp" type="hidden" value="$(V_LATSTP)"></td> 
                  </tr>
                  @DspErrMsg(Err_LATSTP)

                  @Format_HRCoFac("$(V_LACOMP)", "$(V_LAFACL)", "", F_CoFac)
                  @RtvFldDesc("CFCOMP=$(V_LACOMP) and CFFACL=$(V_LAFACL)", "HRCOFC", "CFNAME", fieldDesc)
                  @RtvFldDesc("CFCOMP=$(V_LACOMP) and CFFACL=$(V_LAFACL)", "HRCOFC", "PCTIP", tipCompany)
                  @SetTextOvr(Err_LACOMP)
                  @SetTextOvr(Err_LAFACL)
                  <tr><td class="dsphdr"><span $(textOvr)>Company/Facility</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="coNumber" value="$(V_LACOMP)" type="text" size="4" maxlength="2"> / <input name="facNumber" value="$(V_LAFACL)" type="text" size="4" maxlength="4"> $(reqFieldChar) <a href="$(homeURL)$(phpPath)HRCoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=coNumber&amp;fldFac=facNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="coFacDesc" value="$(fieldDesc)"  type="text" size="30" maxlength="30"></td>
                      %else
                          @Format_Code(F_CoFac, F2_CoFac)
                          <td class="dspalph"><input name="coNumber" value="$(V_LACOMP)" type="hidden" size="4" maxlength="2"> <input name="facNumber" value="$(V_LAFACL)" type="hidden" size="4" maxlength="4">$(fieldDesc) &nbsp; $(F2_CoFac)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_LACOMP)
                  @DspErrMsg(Err_LAFACL)

                  @Default_Zero(V_LACSHA)
                  @Default_Zero(V_LACSHS)
                  @RtvFldDesc("CHACCT=$(V_LACSHA) and CHSUB=$(V_LACSHS) ", "HDCHRT", "CHCHDS", acctDesc)
                  @SetTextOvr(Err_LACSHA)
                  <tr><td class="dsphdr"><span $(textOvr)>Cash</span></td>
                      <td class="inputnmbr"><input name="cashAcctNumber" value="$(V_LACSHA)" type="text" size="4" maxlength="4"> - <input name="cashSubAcctNumber" value="$(V_LACSHS)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=cashAcctNumber&amp;subFld=cashSubAcctNumber&amp;descFld=cashAcctDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="cashAcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_LACSHA)
                  @DspErrMsg(Err_LACSHS)
    	      		
                  @Default_Zero(V_LAEPWA)
                  @Default_Zero(V_LAEPWS)
                  @RtvFldDesc("CHACCT=$(V_LAEPWA) and CHSUB=$(V_LAEPWS) ", "HDCHRT", "CHCHDS", acctDesc)
                  @SetTextOvr(Err_LAEPWA)
                  <tr><td class="dsphdr"><span $(textOvr)>Accrued Wages</span></td>
                      <td class="inputnmbr"><input name="accrWagesAcctNumber" value="$(V_LAEPWA)" type="text" size="4" maxlength="4"> - <input name="accrWagesSubAcctNumber" value="$(V_LAEPWS)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=accrWagesAcctNumber&amp;subFld=accrWagesSubAcctNumber&amp;descFld=accrWagesAcctDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="accrWagesAcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_LAEPWA)
                  @DspErrMsg(Err_LAEPWS)

                  @Default_Zero(V_LAAPPA)
                  @Default_Zero(V_LAAPPS)
                  @RtvFldDesc("CHACCT=$(V_LAAPPA) and CHSUB=$(V_LAAPPS) ", "HDCHRT", "CHCHDS", acctDesc)
                  @SetTextOvr(Err_LAAPPA)
                  <tr><td class="dsphdr"><span $(textOvr)>Payroll Payable</span></td>
                      <td class="inputnmbr"><input name="prPayableAcctNumber" value="$(V_LAAPPA)" type="text" size="4" maxlength="4"> - <input name="prPayableSubAcctNumber" value="$(V_LAAPPS)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=prPayableAcctNumber&amp;subFld=prPayableSubAcctNumber&amp;descFld=prPayableAcctDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="prPayableAcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_LAAPPA)
                  @DspErrMsg(Err_LAAPPS)
    	      		
                  @Default_Zero(V_LAEPTA)
                  @Default_Zero(V_LAEPTS)
                  @RtvFldDesc("CHACCT=$(V_LAEPTA) and CHSUB=$(V_LAEPTS) ", "HDCHRT", "CHCHDS", acctDesc)
                  @SetTextOvr(Err_LAEPTA)
                  <tr><td class="dsphdr"><span $(textOvr)>Accrued Employer Taxes</span></td>
                      <td class="inputnmbr"><input name="accrEmplTaxAcctNumber" value="$(V_LAEPTA)" type="text" size="4" maxlength="4"> - <input name="accrEmplTaxSubAcctNumber" value="$(V_LAEPTS)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=accrEmplTaxAcctNumber&amp;subFld=accrEmplTaxSubAcctNumber&amp;descFld=accrEmplTaxAcctDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="accrEmplTaxAcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_LAEPTA)
                  @DspErrMsg(Err_LAEPTS)

                  @Default_Zero(V_LAAVPA)
                  @Default_Zero(V_LAAVPS)
                  @RtvFldDesc("CHACCT=$(V_LAAVPA) and CHSUB=$(V_LAAVPS) ", "HDCHRT", "CHCHDS", acctDesc)
