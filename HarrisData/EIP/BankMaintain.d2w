%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Bank Maintenance"
  d2wName                 = "BankMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;bankNumber=@dtw_rurlescseq(bankNumber)&amp;bankName=@dtw_rurlescseq(bankName)&amp;maintenanceCode=D"
  programName             = "HHDBKU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (maintenanceCode == "A")
      @dtw_assign(userPass, "Y")
  %else
      @BankUserView(profileHandle, dataBaseID, userPass, bankNumber)
  %endif
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  function validate(chgForm) {
                      if (document.Chg.bankNumber.value =="" ||
                          document.Chg.bankName.value =="" ||
                          document.Chg.checkingAccount.value =="")
                         {alert("$(reqFieldError)"); return false;}
                      if (editNum(document.Chg.bankNumber, 2, 0) &&
                          editNum(document.Chg.companyNumber, 2, 0) &&
                          editNum(document.Chg.facilityNumber, 4, 0) &&
                          editNum(document.Chg.accountNumber, 4, 0) &&
                          editNum(document.Chg.subaccountNumber, 4, 0) &&
                          editNum(document.Chg.checkVoid, 2, 0))
                          return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
	           %INCLUDE "NumEdit.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "BANKMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "SELECT * FROM HDBANK ", stmtSQL)
                              @dtw_concat(stmtSQL, "LEFT JOIN HDBANKE ON BKBANK=BEBANK ", stmtSQL)
                              @dtw_concat(stmtSQL, "WHERE BKBANK = $(bankNumber)", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=111")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "bankNumber")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@bank", "bankNumber")          @dtw_assign(Err_BKBANK, fieldValue)
                          @DecatErr_Field("@@bknm", "bankName")            @dtw_assign(Err_BKBKNM, fieldValue)
                          @DecatErr_Field("@@bacc", "checkingAccount")     @dtw_assign(Err_BKBACC, fieldValue)
                          @DecatErr_Field("@@co#@", "companyNumber")       @dtw_assign(Err_BKCO,   fieldValue)
                          @DecatErr_Field("@@acct", "accountNumber")       @dtw_assign(Err_BKACCT, fieldValue)
                          @DecatErr_Field("@@sub@", "subaccountNumber")    @dtw_assign(Err_BKSUB,  fieldValue)
                          @DecatErr_Field("@@alph", "alphaSequence")       @dtw_assign(Err_BKALPH, fieldValue)
                          @DecatErr_Field("@@vck#", "checkVoid")           @dtw_assign(Err_BKVCK#, fieldValue)
                          @DecatErr_Field("@@pseg", "pageSegment")         @dtw_assign(Err_BEPSEG, fieldValue)
                          @DecatErr_Field("@@pnoc", "printCheckOnCheck")   @dtw_assign(Err_BKPNOC, fieldValue)
                          @DecatErr_Field("@@pnos", "printCheckOnStub")    @dtw_assign(Err_BKPNOS, fieldValue)
                          @DecatErr_Field("@@curt", "currencyType")        @dtw_assign(Err_BKCURT, fieldValue)
                      %endif

                      @Decat_Field("@@bank")   @dtw_assign(V_BKBANK, fieldValue)
                      @Decat_Field("@@bknm")   @dtw_assign(V_BKBKNM, fieldValue)
                      @Decat_Field("@@bacc")   @dtw_assign(V_BKBACC, fieldValue)
                      @Decat_Field("@@co#@")   @dtw_assign(V_BKCO,   fieldValue)
                      @Decat_Field("@@fac#")   @dtw_assign(V_BKFAC,  fieldValue)
                      @Decat_Field("@@acct")   @dtw_assign(V_BKACCT, fieldValue)
                      @Decat_Field("@@sub@")   @dtw_assign(V_BKSUB,  fieldValue)
                      @Decat_Field("@@alph")   @dtw_assign(V_BKALPH, fieldValue)
                      @Decat_Field("@@vck#")   @dtw_assign(V_BKVCK#, fieldValue)
                      @Decat_Field("@@pseg")   @dtw_assign(V_BEPSEG, fieldValue)
                      @Decat_Field("@@pnoc")   @dtw_assign(V_BKPNOC, fieldValue)
                      @Decat_Field("@@pnos")   @dtw_assign(V_BKPNOS, fieldValue)
                      @Decat_Field("@@curt")   @dtw_assign(V_BKCURT, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(V_BKCO,   "00")
                          @dtw_assign(V_BKFAC,  "0000")
                          @dtw_assign(V_BKVCK#, "2")
                          @dtw_assign(V_BKPNOC, "N")
                          @dtw_assign(V_BKPNOS, "N")
                          @dtw_assign(focusField, "bankNumber")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_BKBANK, "")
                      @dtw_assign(focusField, "bankNumber")
                  %else
                      @dtw_assign(focusField, "bankName")
                  %endif

                  @SetTextOvr(Err_BKBANK)
                  <tr><td class="dsphdr"><span $(textOvr)>Bank Number</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="bankNumber" type="text" value="$(V_BKBANK)" size="2" maxlength="2"> $(reqFieldChar) </td>
                      %else
                          <td class="inputnmbr"><input name="bankNumber" type="hidden" value="$(V_BKBANK)" size="2" maxlength="2">$(V_BKBANK)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_BKBANK)

                  @SetTextOvr(Err_BKBKNM)
                  <tr><td class="dsphdr"><span $(textOvr)>Bank Name</span></td>
                      <td class="inputalph"><input name="bankName" type="text" value="$(V_BKBKNM)" size="30" maxlength="30"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_BKBKNM)
    	
                  @SetTextOvr(Err_BKBACC)
                  <tr><td class="dsphdr"><span $(textOvr)>Checking Account</span></td>
                      <td class="inputalph"><input name="checkingAccount" type="text" value="$(V_BKBACC)" size="12" maxlength="12"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_BKBACC)
    	   		
                  @Default_Zero(V_BKCO)
                  @Default_Zero(V_BKFAC)
                  @RtvFldDesc("CFCO#=$(V_BKCO) and CFFAC#=$(V_BKFAC)", "HDCFAC", "CFCFNM", fieldDesc)
                  @SetTextOvr(Err_BKCO)
                  <tr><td class="dsphdr"><span $(textOvr)>Balance Sheet Company/Facility</span></td>
                      <td class="inputnmbr"><input name="companyNumber" value="$(V_BKCO)" type="text" size="4" maxlength="2"> / <input name="facilityNumber" value="$(V_BKFAC)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)CoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=companyNumber&amp;fldFac=facilityNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="coFacDesc" value="$(fieldDesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_BKCO)

                  @Default_Zero(V_BKACCT)
                  @Default_Zero(V_BKSUB)
                  @RtvFldDesc("CHACCT=$(V_BKACCT) and CHSUB=$(V_BKSUB) ", "HDCHRT", "CHCHDS", acctDesc)
                  @SetTextOvr(Err_BKACCT)
                  <tr><td class="dsphdr"><span $(textOvr)>Cash Account</span></td>
                      <td class="inputnmbr"><input name="accountNumber" value="$(V_BKACCT)" type="text" size="4" maxlength="4"> - <input name="subaccountNumber" value="$(V_BKSUB)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=accountNumber&amp;subFld=subaccountNumber&amp;descFld=cashAcctDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="cashAcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_BKACCT)
    	      		
                  @SetTextOvr(Err_BKALPH)
                  <tr><td class="dsphdr"><span $(textOvr)>Alpha Sequence</span></td>
                      <td class="inputalph"><input type="text" name="alphaSequence" value="$(V_BKALPH)" size="4" maxlength="4"></td>
                  </tr>
                  @DspErrMsg(Err_BKALPH)
    	   		
                  @SetTextOvr(Err_BKVCK#)
                  <tr><td class="dsphdr"><span $(textOvr)>Number Of Checks To Void</span></td>
                      <td class="inputnmbr"><input type="text" name="checkVoid" value="$(V_BKVCK#)" size="2" maxlength="2"></td>
                  </tr>
                  @DspErrMsg(Err_BKVCK#)

    	   		  @SetTextOvr(Err_BEPSEG)
                  <tr><td class="dsphdr"><a href="javascript:noLink(0)" onMouseOver="title='(Optional) Override Remittance Advice Page Segment'" onMouseOut=""><span style="color:#0066CC;font-weight:bold" $(textOvr)>Page Segment Name</span></td>
                      <td class="inputalph"><input type="text" name="pageSegment" value="$(V_BEPSEG)" size="8" maxlength="8"></td>
                  </tr>
                  @DspErrMsg(Err_BEPSEG)

                  @SetTextOvr(Err_BKPNOC)
                  <tr><td class="dsphdr"><span $(textOvr)>Print Check# On The Check</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_BKPNOC) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "printCheckOnCheck", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_BKPNOC)
               			
                  @SetTextOvr(Err_BKPNOS)
                  <tr><td class="dsphdr"><span $(textOvr)>Print Check# On The Stub</span></td>
                      @dtw_tb_rows(yn02Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn02Table, x, "1") != V_BKPNOS) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn02Table, "printCheckOnStub", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_BKPNOS)
                   			
                  %if (V_HDMCRL > "0")
                      @RtvFldDesc("CYTYPE='$(V_BKCURT)'", "HDCTYP", "CYDESC", fieldDesc)
                      @SetTextOvr(Err_BKCURT)
                      <tr><td class="dsphdr"><span $(textOvr)>Currency Type</span></td>
                          <td class="inputalph"><input name="currencyType" value="$(V_BKCURT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)CurrencyTypeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=currencyType&amp;fldDesc=currencyTypeDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="currencyTypeDesc" value="$(fieldDesc)"  type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_BKCURT)
                  %else			
                      <tr><td class="inputalph"><input name="currencyType" type="hidden" value="$(V_BKCURT)" size="3" maxlength="3"></td></tr>
                  %endif
              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
	  @DTWF_CLOSE(HDBANK)
	  @DTWF_CLOSE(HDBANKE)
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDBKU_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @yn02_Table_Query(profileHandle, dataBaseID, "YORN      ", yn02Table)

      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(alphaSequence)
  @dtw_mUPPERCASE(checkingAccount)
  @dtw_mUPPERCASE(currencyType)
  @dtw_mUPPERCASE(pageSegment)

  @dtw_assign(bankNumber,@dtw_rstrip(bankNumber))
  @dtw_assign(companyNumber,@dtw_rstrip(companyNumber))
  @dtw_assign(facilityNumber,@dtw_rstrip(facilityNumber))
  @dtw_assign(accountNumber,@dtw_rstrip(accountNumber))
  @dtw_assign(subaccountNumber,@dtw_rstrip(subaccountNumber))
  @dtw_assign(checkVoid,@dtw_rstrip(checkVoid))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@bank", bankNumber)
  @Concat_Field("@@bknm", bankName)
  @Concat_Field("@@bacc", checkingAccount)
  @Concat_Field("@@co#@", companyNumber)
  @Concat_Field("@@fac#", facilityNumber)
  @Concat_Field("@@acct", accountNumber)
  @Concat_Field("@@sub@", subaccountNumber)
  @Concat_Field("@@alph", alphaSequence)
  @Concat_Field("@@vck#", checkVoid)
  @Concat_Field("@@pseg", pageSegment)
  @Concat_Field("@@pnoc", printCheckOnCheck)
  @Concat_Field("@@pnos", printCheckOnStub)
  @Concat_Field("@@curt", currencyType)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(bankName), $(bankNumber), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@bank", "bankNumber")
          @Format_ConfMsg_Desc("", $(bankName), $(bankNumber), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=111&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;bankNumber=@dtw_rurlescseq(bankNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
