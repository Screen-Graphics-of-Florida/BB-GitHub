%INCLUDE "$(baseVar)"
%INCLUDE "EdtVar.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Item/Warehouse Min/Max Maintain"
  d2wName                 = "ItemWarehouseMinMaxMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;itemDescription=@dtw_rurlescseq(itemDescription)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;rowNum=@dtw_rurlescseq(rowNum)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  <html>
      <head>
          %INCLUDE "headcmt.icl"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.minQty.value =="" ||
                      document.Chg.maxQty.value =="")
                    {alert("$(reqFieldError)"); return false;}
                  testfield = document.Chg.minQty.value;
                  var negPos=testfield.indexOf('-');
                  if (negPos>=0) {alert ("Negative quantity is not allowed.  Please try again."); return false;}
                  testfield = document.Chg.maxQty.value;
                  var negPos=testfield.indexOf('-');
                  if (negPos>=0) {alert ("Negative quantity is not allowed.  Please try again."); return false;}
                  var min = parseInt(document.Chg.minQty.value, 13);
                  var max = parseInt(document.Chg.maxQty.value, 13);
                  if (min > max)
                     {alert("Minimum Quantity cannot be greater than Maximum Quantity");
                             return false;}
                  if (editNum(document.Chg.minQty, 9, 4) &&
                      editNum(document.Chg.maxQty, 9, 4))
                      return true;
              }
          </script>
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  <td class="toolbar">
                      <a href="javascript:check(document.Chg)">$(selectAcceptImage)</a>
                      %INCLUDE "CloseWindow.icl"
                  </td>
              </tr>
          </table>
          <table $(contentTable)>
              @RtvFldDesc("WHWHS=$(warehouseNumber)", "HDWHSM", "WHWHNM", warehouseName)
              @Format_Header("Item", $(itemDescription), $(itemNumber))
              @Format_Header("Warehouse", $(warehouseName), $(warehouseNumber))
          </table>
          $(hrTagAttr)
          %if (fromMinQty == "")
              @RtvFldDesc("IWITEM='$(itemNumber)' and IWWHS=$(warehouseNumber)", "HDIWHS", "IWMINQ", fromMinQty)
              @RtvFldDesc("IWITEM='$(itemNumber)' and IWWHS=$(warehouseNumber)", "HDIWHS", "IWMAXQ", fromMaxQty)
          %endif
          %INCLUDE "RequiredField.icl"
              <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)">
                  <table $(contentTable)>
                      <tr><td class="dsphdr">Minimum Quantity</td>
                          <td class="inputnmbr"><input type="text" name="minQty" value="$(fromMinQty)" size="15" maxlength="15"> $(reqFieldChar)</td>
                      </tr>
                      <tr><td class="dsphdr">Maximum Quantity</td>
                          <td class="inputnmbr"><input type="text" name="maxQty" value="$(fromMaxQty)" size="15" maxlength="15"> $(reqFieldChar)</td>
                      </tr>
                  </table>
              </form>
          $(hrTagAttr)
          <a href="javascript:check(document.Chg)">$(selectAcceptImage)</a>
          %INCLUDE "CloseWindow.icl"
      </body>
  </html>
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Update HDIWHS Set IWMINQ=$(minQty), IWMAXQ=$(maxQty) ", stmtSQL)
  @dtw_concat(stmtSQL, " Where IWITEM='$(itemNumber)' and IWWHS=$(warehouseNumber)  @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)

  @Format_Nbr(minQty, F_minQty, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
  @Format_Nbr(maxQty, F_maxQty, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")

  <script TYPE="text/javascript">
      opener.document.getElementById("minQty$(rowNum)").innerHTML = "$(F_minQty)";
      opener.document.getElementById("maxQty$(rowNum)").innerHTML = "$(F_maxQty)";
      window.close();
  </script>
%}