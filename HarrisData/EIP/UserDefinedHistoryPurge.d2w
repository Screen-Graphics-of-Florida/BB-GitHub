%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Purge User Defined Detail History"
  d2wName                 = "UserDefinedHistoryPurge.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editdate(document.Chg.frmTransDate) &&
                      editdate(document.Chg.toTransDate) &&
                      %if (V_HDPDRL>"0")
                          editNum(document.Chg.frmPlant, 3, 0) &&
                          editNum(document.Chg.toPlant, 3, 0) &&
                      %endif
                      editFromToAll(document.Chg.frmTransDate,  document.Chg.toTransDate, document.Chg.allTransDate, "D") &&
                      editFromToAll(document.Chg.frmFunction, document.Chg.toFunction, document.Chg.allFunction, "A")
                      %if (V_HDPDRL>"0")
                          && editFromToAll(document.Chg.frmPlant, document.Chg.toPlant, document.Chg.allPlant, 3)
                      %endif
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "USERDEFINEDHISTORYPURGE")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          @dtw_assign(focusField, "frmTransDate")

                          %if (errFound != "" || scheduleJobSwitch == "Y")
                              @dtw_assign(scheduleJobSwitch, "")
                              @EdtVarErr(profileHandle, typeValue, edtVar)
                              @dtw_assign(focusField, "")
                              @ErrVarErr(profileHandle, typeError, errVar)
                              @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)

                              @DecatErr_Field("@@fdat", "frmTransDate")   @dtw_assign(Err_N1FDAT, fieldValue)
                              @DecatErr_Field("@@tdat", "toTransDate")    @dtw_assign(Err_N1TDAT, fieldValue)
                              @DecatErr_Field("@@adat", "allTransDate")   @dtw_assign(Err_N1ADAT, fieldValue)
                              @DecatErr_Field("@@ffcn", "frmFunction")    @dtw_assign(Err_N1FFCN,  fieldValue)
                              @DecatErr_Field("@@tfcn", "toFunction")     @dtw_assign(Err_N1TFCN,  fieldValue)
                              @DecatErr_Field("@@afcn", "allFunction")    @dtw_assign(Err_N1AFCN,  fieldValue)
                              @DecatErr_Field("@@fplt", "frmPlant")       @dtw_assign(Err_N1FPLT, fieldValue)
                              @DecatErr_Field("@@tplt", "toPlant")        @dtw_assign(Err_N1TPLT, fieldValue)
                              @DecatErr_Field("@@aplt", "allPlant")       @dtw_assign(Err_N1APLT, fieldValue)
                              %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}

                              @Decat_Field("@@fdat")   @dtw_assign(V_N1FDAT, fieldValue)
                              @Decat_Field("@@tdat")   @dtw_assign(V_N1TDAT, fieldValue)
                              @Decat_Field("@@adat")   @dtw_assign(V_N1ADAT, fieldValue)
                              @Decat_Field("@@ffcn")   @dtw_assign(V_N1FFCN, fieldValue)
                              @Decat_Field("@@tfcn")   @dtw_assign(V_N1TFCN, fieldValue)
                              @Decat_Field("@@afcn")   @dtw_assign(V_N1AFCN, fieldValue)
                              @Decat_Field("@@fplt")   @dtw_assign(V_N1FPLT, fieldValue)
                              @Decat_Field("@@tplt")   @dtw_assign(V_N1TPLT, fieldValue)
                              @Decat_Field("@@aplt")   @dtw_assign(V_N1APLT, fieldValue)
                              %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                          %else
                              @dtw_assign(V_N1ADAT, "")
                              @dtw_assign(V_N1AFCN, "ALL")
                              @dtw_assign(V_N1APLT, "ALL")
                          %endif

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @Field_Checked(V_N1AFDAT, "ALL", allChecked)
                              @SetTextOvr(Err_N1FDAT)
                              %if (textOvr == "") @SetTextOvr(Err_N1TDAT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ADAT) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Transaction Date</span></td>
                                  <td class="inputnmbr"><input type="text" name="frmTransDate" value="$(V_N1FDAT)" size="6" maxlength="6">
                                                        <a href="javascript:calWindow('frmTransDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input type="text" name="toTransDate" value="$(V_N1TDAT)" size="6" maxlength="6">
                                                        <a href="javascript:calWindow('toTransDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input type="hidden" name="allTransDate" value="$(V_N1ADAT)"></td>
                              </tr>  			
                              @DspErrMsg(Err_N1FDAT)
                              @DspErrMsg(Err_N1TDAT)
                              @DspErrMsg(Err_N1ADAT)

                              @Field_Checked(V_N1AFCN, "ALL", allChecked)
                              @SetTextOvr(Err_N1FFCN)
                              %if (textOvr == "") @SetTextOvr(Err_N1TFCN) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AFCN) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Function Group</span></td>
                                  <td class="inputnmbr"><input type="text" name="frmFunction" value="$(V_N1FFCN)" size="15" maxlength="15">
                                                        <a href="$(homeURL)$(cGIPath)FunctionGroupSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=frmFunction&amp;fldDesc=frmFunctionDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                                                        <input type="hidden" name="frmFunctionDesc"></td>
                                  <td class="inputnmbr"><input type="text" name="toFunction" value="$(V_N1TFCN)" size="15" maxlength="15">
                                                        <a href="$(homeURL)$(cGIPath)FunctionGroupSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toFunction&amp;fldDesc=toFunctionDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                                                        <input type="hidden" name="toFunctionDesc"></td>
                                  <td class="inputalph"><input type="checkbox" name="allFunction" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmFunction.value='', this.form.toFunction.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FFCN)
                              @DspErrMsg(Err_N1TFCN)
                              @DspErrMsg(Err_N1AFCN)

                              %if (V_HDPDRL>"0")
                                  @Field_Checked(V_N1APLT, "ALL", allChecked)
                                  @SetTextOvr(Err_N1FPLT)
                                  %if (textOvr == "") @SetTextOvr(Err_N1TPLT) %endif
                                  %if (textOvr == "") @SetTextOvr(Err_N1APLT) %endif
                                  <tr><td  class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                      <td class="inputnmbr"><input type="text" name="frmPlant" value="$(V_N1FPLT)" size="3" maxlength="3">
                                                            <a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=frmPlant&amp;fldDesc=frmPlantName" onclick="$(searchWinVar)"> $(searchImage) </a>
                                                            <input type="hidden" name="frmPlantName"></td>
                                      <td class="inputnmbr"><input type="text" name="toPlant" value="$(V_N1TPLT)" size="3" maxlength="3">
                                                            <a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toPlant&amp;fldDesc=toPlantName" onclick="$(searchWinVar)"> $(searchImage) </a>
                                                            <input type="hidden" name="toPlantName"></td>
                                      <td class="inputalph"><input type="checkbox" name="allPlant" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmPlant.value='', this.form.toPlant.value='';"></td>
                                  </tr>
                                  @DspErrMsg(Err_N1FPLT)
                                  @DspErrMsg(Err_N1TPLT)
                                  @DspErrMsg(Err_N1APLT)
                              %endif
                          </table>

                          @dtw_assign(envProgram, "HSYDPM")
                          @dtw_assign(envPrinter, "HSYDPMPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSYDPS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"

  @dtw_assign(edtVar, "")
                                                                                                 @Concat_Field("@@fdat", @dtw_rstrip(frmTransDate))
                                                                                                 @Concat_Field("@@tdat", @dtw_rstrip(toTransDate))
  @dtw_mUPPERCASE(allTransDate) %if (allTransDate != "ALL") @dtw_assign(allTransDate, "") %endif @Concat_Field("@@adat", allTransDate)

  @dtw_mUPPERCASE(frmFunction)                                                                    @Concat_Field("@@ffcn", frmFunction)
  @dtw_mUPPERCASE(toFunction)                                                                     @Concat_Field("@@tfcn", toFunction)
  @dtw_mUPPERCASE(allFunction) %if (allFunction != "ALL") @dtw_assign(allFunction, "") %endif @Concat_Field("@@afcn", allFunction)

                                                                                                 @Concat_Field("@@fplt", @dtw_rstrip(frmPlant))
                                                                                                 @Concat_Field("@@tplt", @dtw_rstrip(toPlant))
  @dtw_mUPPERCASE(allPlant) %if (allPlant != "ALL") @dtw_assign(allPlant, "") %endif @Concat_Field("@@aplt", allPlant)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}