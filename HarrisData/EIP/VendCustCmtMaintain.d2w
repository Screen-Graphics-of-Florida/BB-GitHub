%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "$(hdrTrlDesc) Comments Maintenance"
  d2wName                 = "VendCustCmtMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;vendCustNumber=@dtw_rurlescseq(vendCustNumber)&amp;vendCustName=@dtw_rurlescseq(vendCustName)&amp;vendCustFlag=@dtw_rurlescseq(vendCustFlag)&amp;headerTrailer=@dtw_rurlescseq(headerTrailer)&amp;documentType=@dtw_rurlescseq(documentType)&amp;docDescription=@dtw_rurlescseq(docDescription)&amp;inquiryOnly=@dtw_rurlescseq(inquiryOnly)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
  helpExt                 = ""
%}

%MACRO_FUNCTION Display_Comments () {	
  %if (vendCustFlag == "C")
      @dtw_assign(helpExt, " (Customer)")
      @dtw_assign(vendCustHdg, "Customer")
  %else
      @dtw_assign(helpExt, " (Vendor)")
      @dtw_assign(vendCustHdg, "Vendor")
  %endif
  %if (headerTrailer == "H")
      @dtw_assign(hdrTrlDesc, "Header")
  %else
      @dtw_assign(hdrTrlDesc, "Trailer")
  %endif
  <html>
      <head>
          %INCLUDE "headcmt.icl"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "NoFormValidate.icl"
              function checkLimit(opt_countedTextBox, opt_charCnt) {
                  var countedTextBox = opt_countedTextBox ? opt_countedTextBox : "cmtFld";
                  var charCnt = opt_charCnt ? opt_charCnt : "charCnt";
                  var maxSize = 64000;

                  var field = document.getElementById(countedTextBox);

                  if (field && field.value.length >= maxSize) {
                      field.value = field.value.substring(0, maxSize);
                  }
                  var txtField = document.getElementById(charCnt);
                  if (txtField) {
                      txtField.innerHTML = maxSize - field.value.length;
                  }
              }
          </script>
      </head>
      <body $(bodyTagAttr) onload="checkLimit('cmtFld', 'charCnt')">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(cmtBanner)"
          <!-- End Of Banner Code -->
          <table $(contentTable)>
              <tr valign="top">
                  <td width=30>&nbsp;</td>
                  <td>
                      @dtw_assign(comments, "")
                      @dtw_assign(comment, "")
                      %if (cmtSelection != "C")
                          @Get_VendCust_Comments(profileHandle, dataBaseID, vendCustFlag, vendCustNumber, documentType, headerTrailer, comment)
                      %endif

                      %if (inquiryOnly == "Y")
                          @dtw_assign(page_title, "$(vendCustHdg) Comments")
                      %endif

                      <table $(contentTable)>
                  	   <colgroup>
                  	       <col width="70%">
                  	       <col width="30%">
                          <tr><td><h1>$(page_title)</h1></td>
                              <td class="toolbar">
                                  %if (inquiryOnly == "Y")
                                      %INCLUDE "CloseWindow.icl"
                                  %else
                                      <a href="javascript:check(document.Chg)">$(commentAcceptImage)</a>
                                      <a href="javascript:document.Chg.cmtSelection.value='R'; check(document.Chg)">$(commentResetImage)</a>
                                      <a href="$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;cmtSelection=C">$(commentClearImage)</a>
                                      <a href="$(homeURL)$(cGIPath)DocumentCommentSearch.d2w/REPORT$(genericVarBase)" onclick="$(searchWinVar)">$(goSearchImage)</a>
                                      @dtw_assign(medIcon, "Y")
                                      %INCLUDE "HelpPage.icl"
                                      <a href="javascript:window.close()">$(closeImageMed)</a>
                                  %endif
                              </td>
                          </tr>
                      </table>

                      <table $(contentTable)>
                          %if (vendCustFlag == "C")
                              @Format_Header("Customer", $(vendCustName), $(vendCustNumber))
                          %else
                              @Format_Header("Vendor", $(vendCustName), $(vendCustNumber))
                          %endif
                          @Format_Header("Document", $(docDescription), $(documentType))
                      </table>

                      <form class="formClass" METHOD=POST NAME=Chg ACTION="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)">
                          <table $(contentTable)>
                              <tr><td><input type="hidden" name="cmtSelection"></td>
                                  <td>
                                      %if ("$(comment)" != "")
                                          <textarea id="cmtFld" name="comments" rows="20" COLS=60 WRAP="hard" onKeyUp="checkLimit('cmtFld', 'charCnt');" onKeyPress="checkLimit('cmtFld', 'charCnt');">$(comment)</textarea>
                                      %else
                                          <textarea id="cmtFld" name="comments" rows="20" COLS=60 WRAP="hard" onKeyUp="checkLimit('cmtFld', 'charCnt');" onKeyPress="checkLimit('cmtFld', 'charCnt');"></textarea>
                                      %endif
                                  </td>
                              </tr>
                          </table>
                	   <table $(contentTable)>
                              <colgroup>
                                  <col width="70%">
                                  <col width="30%">
                              <tr>
                                  <td valign="top">
                                      %if (inquiryOnly == "Y")
                                          %INCLUDE "CloseWindow.icl"
                                      %else
                                          <a href="javascript:check(document.Chg)">$(commentAcceptImage)</a>
                                          <a href="javascript:document.Chg.cmtSelection.value='R'; check(document.Chg)">$(commentResetImage)</a>
                                          <a href="$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;cmtSelection=C">$(commentClearImage)</a>
                                          <a href="$(homeURL)$(cGIPath)DocumentCommentSearch.d2w/REPORT$(genericVarBase)" onclick="$(searchWinVar)">$(goSearchImage)</a>
                                          @dtw_assign(medIcon, "Y")
                                          %INCLUDE "HelpPage.icl"
                                          <a href="javascript:window.close()">$(closeImageMed)</a>
                                      %endif
                                  </td>
                                  <td nowrap><b><span id="charCnt">0</span></b> Characters Left</td>
                              </tr>
                          </table>
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(cmtTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(DTW_directcall) Update_VendCust_Comments (INOUT char(32000)  edtVar,
				      		           char(65000)  comments)

{%EXEC {HHDCMT_W.PGM %}
%}

%FUNCTION(DTW_directcall) Get_VendCust_Comments (INOUT CHAR(64)     profileHandle,
				                        CHAR(2)      dataBaseID,
				      	                CHAR(1)      vendCustFlag,
				                        DECIMAL(7,0) vendCustNumber,
				      	                CHAR(3)      documentType,
				      	                CHAR(1)      headerTrailer,
				                        char(65000)  comment)
{%EXEC {HHDCMT_P.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @Display_Comments ()
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  %if (cmtSelection == "R")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)">
  %else
      @dtw_assign(edtVar, "")
      @Concat_Field("@@vcf@", vendCustFlag)
      @Concat_Field("@@nmbr", vendCustNumber)
      @Concat_Field("@@doct", documentType)
      @Concat_Field("@@ht@@", headerTrailer)
      @dtw_concat(edtVar, "}{", edtVar)
      @Update_VendCust_Comments(edtVar, comments)
      @dtw_assign(confMessage, "Confirm Update Of Document $(documentType) - $(docDescription)")
      <script TYPE="text/javascript">
          opener.location.href=opener.location.href;
          opener.focus();
          window.close();
      </script>
  %endif
%}