%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "ILE Module Search"
  d2wName                 = "ILEModuleSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
  advanceSearch           = "N"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectILEModule(ileModule, desc){
                  window.opener.document.$(docName).$(fldName).value = ileModule;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select PTPGID, PTDESC, upper(PTDESC) as PTDESCU, PTTYPE, PTACTG", stmtSQL)
                      @dtw_concat(fileSQL, " SYILET ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, "PTPGID>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"

                      @ILE_Module_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) ILE_Module_Search (IN  CHAR(64) profileHandle,
				                       CHAR(2)   dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"

      $(searchhrTagAttr)
      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr">ILE Module</th>
                  <th class="colhdr">Description</th>
              </tr>
              <tr><td class="inputalph">
                      <input type="text" name="srchILEModule" size="10" maxlength="10">
                      <input type="hidden" name="operILEModule" value="LIKE">
                  </td>
                  <td class="inputalph">
                      <input type="text" name="srchDesc" size="50" maxlength="50">
                      <input type="hidden" name="operDesc" value="LIKE">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
          <script TYPE="text/javascript">
              document.Search.srchILEModule.focus();
          </script>
      </form>
	
      %INCLUDE "WildCardPage.icl"

      <table $(contentTable)>
          <tr>	
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("PTPGID", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ILEModule" title="Sequence By ILE Module"> ILE Module</a></th>
              @OrderBy_Sort("PTDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ILEDesc" title="Sequence By Description, ILE Module"> Description</a></th>
              @OrderBy_Sort("PTTYPE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ILEType" title="Sequence By ILE Type, ILE Module"> Type</a></th>
              @OrderBy_Sort("PTACTG", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ActGrp" title="Sequence By Activation Group, ILE Module"> Act Grp</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Quote(V_PTPGID, F_PTPGID)
              @Format_Quote(V_PTDESC, F_PTDESC)

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="javascript:selectILEModule('$(F_PTPGID)', '$(F_PTDESC)')" title="Select ILE Module">$(V_PTPGID)</a></td>
                  <td class="colalph"> $(V_PTDESC)</td>
                  <td class="colcode">$(V_PTTYPE)</td>
                  <td class="colcode">$(V_PTACTG)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "PTPGID,PTDESCU")
      @DTW_ASSIGN(orderByDisplay, "ILE Module, Description")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY)  {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "ILEModule")
      %if (orderBy == "PTPGID")
          @DTW_ASSIGN(orderBy, "PTPGID DESC")
          @DTW_ASSIGN(orderByDisplay, "ILE Module (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PTPGID")
          @DTW_ASSIGN(orderByDisplay, "ILE Module")
      %endif
  %elseif (sequence == "ILEDesc")
      %if (orderBy == "PTDESCU,PTPGID")
          @DTW_ASSIGN(orderBy, "PTDESCU DESC,PTPGID")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), ILE Module")
      %else
          @DTW_ASSIGN(orderBy, "PTDESCU,PTPGID")
          @DTW_ASSIGN(orderByDisplay, "Description, ILE Module")
      %endif
  %elseif (sequence == "ILEType")
      %if (orderBy == "PTTYPE,PTPGID")
          @DTW_ASSIGN(orderBy, "PTTYPE DESC,PTPGID")
          @DTW_ASSIGN(orderByDisplay, "ILE Type (descending), ILE Module")
      %else
          @DTW_ASSIGN(orderBy, "PTTYPE,PTPGID")
          @DTW_ASSIGN(orderByDisplay, "ILE Type, ILE Module")
      %endif
  %elseif (sequence == "ActGrp")
      %if (orderBy == "PTACTG,PTPGID")
          @DTW_ASSIGN(orderBy, "PTACTG DESC,PTPGID")
          @DTW_ASSIGN(orderByDisplay, "Activation Group (descending), ILE Module")
      %else
          @DTW_ASSIGN(orderBy, "PTACTG,PTPGID")
          @DTW_ASSIGN(orderByDisplay, "Activation Group, ILE Module")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("PTPGID", "ILE Module", $(srchILEModule), "U", operILEModule, "A")
  @Build_WildCard ("upper(PTDESC)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("PTTYPE", "ILE Type", $(srchILEType), "U", operILEType, "A")
  @Build_WildCard ("PTACTG", "Activation Group", $(srchActGrp), "U", operActGrp, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}