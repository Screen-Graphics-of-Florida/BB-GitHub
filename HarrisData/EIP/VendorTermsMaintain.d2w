%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Vendor Terms Maintenance"
  d2wName                 = "VendorTermsMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;vendorTerms=@dtw_rurlescseq(vendorTerms)&amp;termsDesc=@dtw_rurlescseq(termsDesc)&amp;maintenanceCode=D"
  programName             = "HHDTRM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.vendorTerms.value =="" ||
                      document.Chg.termsDesc.value =="")
                         {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.daysTillDue, 3, 0) &&
                      editNum(document.Chg.daysForDiscount, 3, 0) &&
                      editNum(document.Chg.discountPercent, 2, 1))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
              %INCLUDE "numedit.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "VENDORTERMSMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From APVTRM Where VTRMS = '$(vendorTerms)'", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=124")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "vendorTerms")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@rms@", "vendorTerms")      @dtw_assign(Err_VTRMS,  fieldValue)
                          @DecatErr_Field("@@vtds", "termsDesc")        @dtw_assign(Err_VTVTDS, fieldValue)
                          @DecatErr_Field("@@days", "daysTillDue")      @dtw_assign(Err_VTDAYS, fieldValue)
                          @DecatErr_Field("@@disd", "daysForDiscount")  @dtw_assign(Err_VTDISD, fieldValue)
                          @DecatErr_Field("@@disp", "discountPercent")  @dtw_assign(Err_VTDISP, fieldValue)
                      %endif

                      @Decat_Field("@@rms@")   @dtw_assign(V_VTRMS,  fieldValue)
                      @Decat_Field("@@vtds")   @dtw_assign(V_VTVTDS, fieldValue)
                      @Decat_Field("@@days")   @dtw_assign(V_VTDAYS, fieldValue)
                      @Decat_Field("@@disd")   @dtw_assign(V_VTDISD, fieldValue)
                      @Decat_Field("@@disp")   @dtw_assign(V_VTDISP, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "vendorTerms")
                      %endif
                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_VTRMS,  "")
                      @dtw_assign(V_VTDISP,  "@dtw_rformat(@dtw_rmultiply(V_VTDISP, "100"),"","1")")
                      @dtw_assign(focusField, "vendorTerms")
                  %else
                      @dtw_assign(V_VTDISP,  "@dtw_rformat(@dtw_rmultiply(V_VTDISP, "100"),"","1")")
                      @dtw_assign(focusField, "termsDesc")
                  %endif

                  @SetTextOvr(Err_VTRMS)
                  <tr><td class="dsphdr"><span $(textOvr)>Terms Code</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputcode"><input name="vendorTerms" type="text" value="$(V_VTRMS)" size="2" maxlength="2"> $(reqFieldChar) </td>
                      %else
                          <td class="inputcode"><input name="vendorTerms" type="hidden" value="$(V_VTRMS)" size="2" maxlength="2">$(V_VTRMS)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_VTRMS)

                  @SetTextOvr(Err_VTVTDS)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="termsDesc" type="text" value="$(V_VTVTDS)" size="10" maxlength="10"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_VTVTDS)
	   		
                  @SetTextOvr(Err_VTDAYS)
                  <tr><td class="dsphdr"><span $(textOvr)>Days Till Due</span></td>
                      <td class="inputnmbr"><input name="daysTillDue" type="text" value="$(V_VTDAYS)" size="3" maxlength="3"></td>
                  </tr>
                  @DspErrMsg(Err_VTDAYS)
	   		
                  @SetTextOvr(Err_VTDISD)
                  <tr><td class="dsphdr"><span $(textOvr)>Days For Discount</span></td>
                      <td class="inputnmbr"><input name="daysForDiscount" type="text" value="$(V_VTDISD)" size="3" maxlength="3"></td>
                  </tr>
                  @DspErrMsg(Err_VTDISD)
	   		
                  @SetTextOvr(Err_VTDISP)
                  <tr><td class="dsphdr"><span $(textOvr)>Discount Percent</span></td>
                      <td class="inputnmbr"><input name="discountPercent" type="text" value="$(V_VTDISP)" size="4" maxlength="4"></td>
                  </tr>
                  @DspErrMsg(Err_VTDISP)
              %}
          </table>
	
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDTRM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(vendorTerms)
  @dtw_assign(daysTillDue,@dtw_rstrip(daysTillDue))
  @dtw_assign(daysForDiscount,@dtw_rstrip(daysForDiscount))
  @dtw_assign(discountPercent,@dtw_rstrip(discountPercent))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@rms@", vendorTerms)
  @Concat_Field("@@vtds", termsDesc)
  @Concat_Field("@@days", daysTillDue)
  @Concat_Field("@@disd", daysForDiscount)
  @Concat_Field("@@disp", discountPercent)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(termsDesc), $(vendorTerms), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@rms@", "vendorTerms")
          @Format_ConfMsg_Desc("", $(termsDesc), $(vendorTerms), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=124&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;vendorTerms=@dtw_rurlescseq(vendorTerms)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}