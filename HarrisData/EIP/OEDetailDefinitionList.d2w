%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "O/E Detail Definition List"
  d2wName                 = "OEDetailDefinitionList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;reportSelType=@dtw_rurlescseq(reportSelType)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editFromToAll(document.Chg.fromUserProfile, document.Chg.toUserProfile, document.Chg.allUserProfile, "A") &&
                      editFromToAll(document.Chg.fromOrderType, document.Chg.toOrderType, document.Chg.allOrderType, "A"))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "OEDETAILDEFINITIONLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromUserProfile")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@fusr")  @dtw_assign(V_N1FUSR,  fieldValue)
                                  @Decat_Field("@@tusr")  @dtw_assign(V_N1TUSR,  fieldValue)
                                  @Decat_Field("@@ausr")  @dtw_assign(V_N1AUSR,  fieldValue)
                                  @Decat_Field("@@ftyp")  @dtw_assign(V_N1FTYP,  fieldValue)
                                  @Decat_Field("@@ttyp")  @dtw_assign(V_N1TTYP,  fieldValue)
                                  @Decat_Field("@@atyp")  @dtw_assign(V_N1ATYP,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1AUSR == "ALL")
                                      @dtw_assign(checkedallUserProfile, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallUserProfile, "")
                                  %endif
                                  %if (V_N1ATYP == "ALL")
                                      @dtw_assign(checkedallOrderType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallOrderType, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedallUserProfile, "CHECKED")
                                  @dtw_assign(checkedallOrderType, "CHECKED")
                              %endif
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                                  <tr><td  class="dsphdr">User Profile</td>
                                      <td class="inputalph"><input name="fromUserProfile" value="$(V_N1FUSR)" type="text" size="15" maxlength="10"></td>
                                      <td class="inputalph"><input name="toUserProfile" value="$(V_N1TUSR)" type="text" size="15" maxlength="10"></td>
                                      <td class="inputalph"><input name="allUserProfile" value='ALL' $(checkedallUserProfile) type="checkbox" onClick="if (this.checked) this.form.fromUserProfile.value='', this.form.toUserProfile.value='';"></td>
                                  </tr>

                                  <tr><td  class="dsphdr">Order Type</td>
                                      <td class="inputalph"><input name="fromOrderType" value="$(V_N1FTYP)" type="text" size="1" maxlength="1"><a href="$(homeURL)$(cGIPath)ordertypesearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromOrderType&amp;fldDesc=fromOrderTypeDescH&amp;appID=OE" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fromOrderTypeDescH" type="hidden"></td>
                                      <td class="inputalph"><input name="toOrderType" value="$(V_N1TTYP)" type="text" size="1" maxlength="1"><a href="$(homeURL)$(cGIPath)ordertypesearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toOrderType&amp;fldDesc=toOrderTypeDescH&amp;appID=OE" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toOrderTypeDescH" type="hidden"></td>
                                      <td class="inputalph"><input name="allOrderType" value='ALL' $(checkedallOrderType) type="checkbox" onClick="if (this.checked) this.form.fromOrderType.value='', this.form.toOrderType.value='';"></td>
                                  </tr>
                          </table>

                          @dtw_assign(envProgram, "HOEDDL")
                          @dtw_assign(envPrinter, "HOEDDLPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HOEDDS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(fromUserProfile)
  @dtw_mUPPERCASE(toUserProfile)
  @dtw_mUPPERCASE(allUserProfile)
  @dtw_mUPPERCASE(fromOrderType)
  @dtw_mUPPERCASE(toOrderType)
  @dtw_mUPPERCASE(allOrderType)

  %if (allUserProfile != "ALL")
      @dtw_assign(allUserProfile, "")
  %endif

  %if (allOrderType != "ALL")
      @dtw_assign(allOrderType, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@fusr", fromUserProfile)
  @Concat_Field("@@tusr", toUserProfile)
  @Concat_Field("@@ausr", allUserProfile)
  @Concat_Field("@@ftyp", fromOrderType)
  @Concat_Field("@@ttyp", toOrderType)
  @Concat_Field("@@atyp", allOrderType)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}