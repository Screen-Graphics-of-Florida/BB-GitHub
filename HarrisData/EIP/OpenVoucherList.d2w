%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%INCLUDE "APControl$(dataBaseID).icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%if (V_HDMCRL == "0")
    @dtw_assign(V_CPPRMC, "N")
%endif

%Define {
  page_title              = "Open Voucher List"
  d2wName                 = "OpenVoucherList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "6"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"

              function validate(chgForm) {

                  if (document.Chg.selectedForPayment.checked == false &&
                      document.Chg.held.checked == false &&
                      document.Chg.open.checked == false &&
                      document.Chg.manualPayments.checked == false &&
                      document.Chg.voids.checked == false)
                      {alert("Must make at least one voucher selection");
                      return false;}

                  if  (editNum(document.Chg.fromBankNumber, 2, 0) &&
                      editNum(document.Chg.toBankNumber, 2, 0) &&
                      editNum(document.Chg.fromVendorNumber, 7, 0) &&
                      editNum(document.Chg.toVendorNumber, 7, 0) &&
                      editdate(document.Chg.fromVoucherDueDate) &&
                      editdate(document.Chg.toVoucherDueDate) &&
                      editdate(document.Chg.fromVoucherDiscountDate) &&
                      editdate(document.Chg.toVoucherDiscountDate) &&
                      editFromToAll(document.Chg.fromBankNumber, document.Chg.toBankNumber, document.Chg.allBankNumber, 2) &&
                      editFromToAll(document.Chg.fromAlphaSequence, document.Chg.toAlphaSequence, document.Chg.allAlphaSequence, "A") &&
                      editFromToAll(document.Chg.fromVendorNumber, document.Chg.toVendorNumber, document.Chg.allVendorNumber, 7) &&
                      editFromToAll(document.Chg.fromVendorType, document.Chg.toVendorType, document.Chg.allVendorType, "A") &&
                      editFromToAll(document.Chg.fromVoucherDueDate, document.Chg.toVoucherDueDate, document.Chg.allVoucherDueDate, "D") &&
                      editFromToAll(document.Chg.fromVoucherDiscountDate, document.Chg.toVoucherDiscountDate, document.Chg.allVoucherDiscountDate, "D"))
                      return true;
              }

              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "OPENVOUCHERLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromBankNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@selc", "selectedForPayment")       @dtw_assign(Err_N2SELC,  fieldValue)
                                  @DecatErr_Field("@@held", "held")                     @dtw_assign(Err_N2HELD,  fieldValue)
                                  @DecatErr_Field("@@open", "open")                     @dtw_assign(Err_N2OPEN,  fieldValue)
                                  @DecatErr_Field("@@mpmt", "manualPayments")           @dtw_assign(Err_N2MPMT,  fieldValue)
                                  @DecatErr_Field("@@void", "voids")                    @dtw_assign(Err_N2VOID,  fieldValue)
                                  @DecatErr_Field("@@fbnk", "fromBankNumber")           @dtw_assign(Err_N2FBNK,  fieldValue)
                                  @DecatErr_Field("@@tbnk", "toBankNumber")             @dtw_assign(Err_N2TBNK,  fieldValue)
                                  @DecatErr_Field("@@abnk", "allBankNumber")            @dtw_assign(Err_N2ABNK,  fieldValue)
                                  @DecatErr_Field("@@sbnk", "sortBankNumber")           @dtw_assign(Err_N2SBNK,  fieldValue)
                                  @DecatErr_Field("@@pbnk", "totalBankNumber")          @dtw_assign(Err_N2PBNK,  fieldValue)
                                  @DecatErr_Field("@@falp", "fromAlphaSequence")        @dtw_assign(Err_N2FALP,  fieldValue)
                                  @DecatErr_Field("@@talp", "toAlphaSequence")          @dtw_assign(Err_N2TALP,  fieldValue)
                                  @DecatErr_Field("@@aalp", "allAlphaSequence")         @dtw_assign(Err_N2AALP,  fieldValue)
                                  @DecatErr_Field("@@salp", "sortAlphaSequence")        @dtw_assign(Err_N2SALP,  fieldValue)
                                  @DecatErr_Field("@@palp", "totalAlphaSequence")       @dtw_assign(Err_N2PALP,  fieldValue)
                                  @DecatErr_Field("@@fvnd", "fromVendorNumber")         @dtw_assign(Err_N2FVND,  fieldValue)
                                  @DecatErr_Field("@@tvnd", "toVendorNumber")           @dtw_assign(Err_N2TVND,  fieldValue)
                                  @DecatErr_Field("@@avnd", "allVendorNumber")          @dtw_assign(Err_N2AVND,  fieldValue)
                                  @DecatErr_Field("@@svnd", "sortVendorNumber")         @dtw_assign(Err_N2SVND,  fieldValue)
                                  @DecatErr_Field("@@pvnd", "totalVendorNumber")        @dtw_assign(Err_N2PVND,  fieldValue)
                                  @DecatErr_Field("@@frvt", "fromVendorType")           @dtw_assign(Err_N2FRVT,  fieldValue)
                                  @DecatErr_Field("@@tovt", "toVendorType")             @dtw_assign(Err_N2TOVT,  fieldValue)
                                  @DecatErr_Field("@@avtp", "allVendorType")            @dtw_assign(Err_N2AVTP,  fieldValue)
                                  @DecatErr_Field("@@svtp", "sortVendorType")           @dtw_assign(Err_N2SVTP,  fieldValue)
                                  @DecatErr_Field("@@pvtp", "totalVendorType")          @dtw_assign(Err_N2PVTP,  fieldValue)
                                  @DecatErr_Field("@@fdue", "fromVoucherDueDate")       @dtw_assign(Err_N2FDUE,  fieldValue)
                                  @DecatErr_Field("@@tdue", "toVoucherDueDate")         @dtw_assign(Err_N2TDUE,  fieldValue)
                                  @DecatErr_Field("@@adue", "allVoucherDueDate")        @dtw_assign(Err_N2ADUE,  fieldValue)
                                  @DecatErr_Field("@@sdue", "sortVoucherDueDate")       @dtw_assign(Err_N2SDUE,  fieldValue)
                                  @DecatErr_Field("@@pdue", "totalVoucherDueDate")      @dtw_assign(Err_N2PDUE,  fieldValue)
                                  @DecatErr_Field("@@fdsc", "fromVoucherDiscountDate")  @dtw_assign(Err_N2FDSC,  fieldValue)
                                  @DecatErr_Field("@@tdsc", "toVoucherDiscountDate")    @dtw_assign(Err_N2TDSC,  fieldValue)
                                  @DecatErr_Field("@@adsc", "allVoucherDiscountDate")   @dtw_assign(Err_N2ADSC,  fieldValue)
                                  @DecatErr_Field("@@sdsc", "sortVoucherDiscountDate")  @dtw_assign(Err_N2SDSC,  fieldValue)
                                  @DecatErr_Field("@@pdsc", "totalVoucherDiscountDate") @dtw_assign(Err_N2PDSC,  fieldValue)
                                  %if (V_CPPRMC == "Y")
                                      @DecatErr_Field("@@curt", "currencyType") @dtw_assign(Err_N2CURT,  fieldValue)
                                  %endif

                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@selc")  @dtw_assign(V_N2SELC,  fieldValue)
                                  @Decat_Field("@@held")  @dtw_assign(V_N2HELD,  fieldValue)
                                  @Decat_Field("@@open")  @dtw_assign(V_N2OPEN,  fieldValue)
                                  @Decat_Field("@@mpmt")  @dtw_assign(V_N2MPMT,  fieldValue)
                                  @Decat_Field("@@void")  @dtw_assign(V_N2VOID,  fieldValue)
                                  @Decat_Field("@@fbnk")  @dtw_assign(V_N2FBNK,  fieldValue)
                                  @Decat_Field("@@tbnk")  @dtw_assign(V_N2TBNK,  fieldValue)
                                  @Decat_Field("@@abnk")  @dtw_assign(V_N2ABNK,  fieldValue)
                                  @Decat_Field("@@sbnk")  @dtw_assign(V_N2SBNK,  fieldValue)
                                  @Decat_Field("@@pbnk")  @dtw_assign(V_N2PBNK,  fieldValue)
                                  @Decat_Field("@@falp")  @dtw_assign(V_N2FALP,  fieldValue)
                                  @Decat_Field("@@talp")  @dtw_assign(V_N2TALP,  fieldValue)
                                  @Decat_Field("@@aalp")  @dtw_assign(V_N2AALP,  fieldValue)
                                  @Decat_Field("@@salp")  @dtw_assign(V_N2SALP,  fieldValue)
                                  @Decat_Field("@@palp")  @dtw_assign(V_N2PALP,  fieldValue)
                                  @Decat_Field("@@fvnd")  @dtw_assign(V_N2FVND,  fieldValue)
                                  @Decat_Field("@@tvnd")  @dtw_assign(V_N2TVND,  fieldValue)
                                  @Decat_Field("@@avnd")  @dtw_assign(V_N2AVND,  fieldValue)
                                  @Decat_Field("@@svnd")  @dtw_assign(V_N2SVND,  fieldValue)
                                  @Decat_Field("@@pvnd")  @dtw_assign(V_N2PVND,  fieldValue)
                                  @Decat_Field("@@frvt")  @dtw_assign(V_N2FRVT,  fieldValue)
                                  @Decat_Field("@@tovt")  @dtw_assign(V_N2TOVT,  fieldValue)
                                  @Decat_Field("@@avtp")  @dtw_assign(V_N2AVTP,  fieldValue)
                                  @Decat_Field("@@svtp")  @dtw_assign(V_N2SVTP,  fieldValue)
                                  @Decat_Field("@@pvtp")  @dtw_assign(V_N2PVTP,  fieldValue)
                                  @Decat_Field("@@fdue")  @dtw_assign(V_N2FDUE,  fieldValue)
                                  @Decat_Field("@@tdue")  @dtw_assign(V_N2TDUE,  fieldValue)
                                  @Decat_Field("@@adue")  @dtw_assign(V_N2ADUE,  fieldValue)
                                  @Decat_Field("@@sdue")  @dtw_assign(V_N2SDUE,  fieldValue)
                                  @Decat_Field("@@pdue")  @dtw_assign(V_N2PDUE,  fieldValue)
                                  @Decat_Field("@@fdsc")  @dtw_assign(V_N2FDSC,  fieldValue)
                                  @Decat_Field("@@tdsc")  @dtw_assign(V_N2TDSC,  fieldValue)
                                  @Decat_Field("@@adsc")  @dtw_assign(V_N2ADSC,  fieldValue)
                                  @Decat_Field("@@sdsc")  @dtw_assign(V_N2SDSC,  fieldValue)
                                  @Decat_Field("@@pdsc")  @dtw_assign(V_N2PDSC,  fieldValue)

                                  %if (V_CPPRMC == "Y")
                                      @Decat_Field("@@curt")  @dtw_assign(V_N2CURT,  fieldValue)
                                  %endif
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N2SELC == "1")
                                      @dtw_assign(checkedSelectedForPayment, "CHECKED")
                                  %else
                                      @dtw_assign(checkedSelectedForPayment, "")
                                  %endif
                                  %if (V_N2HELD == "1")
                                      @dtw_assign(checkedHeld, "CHECKED")
                                  %else
                                      @dtw_assign(checkedHeld, "")
                                  %endif
                                  %if (V_N2OPEN == "1")
                                      @dtw_assign(checkedOpen, "CHECKED")
                                  %else
                                      @dtw_assign(checkedOpen, "")
                                  %endif
                                  %if (V_N2MPMT == "1")
                                      @dtw_assign(checkedManualPayments, "CHECKED")
                                  %else
                                      @dtw_assign(checkedManualPayments, "")
                                  %endif
                                  %if (V_N2VOID == "1")
                                      @dtw_assign(checkedVoids, "CHECKED")
                                  %else
                                      @dtw_assign(checkedVoids, "")
                                  %endif
                                  %if (V_N2ABNK == "ALL")
                                      @dtw_assign(checkedAllBankNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllBankNumber, "")
                                  %endif
                                  %if (V_N2AALP == "ALL")
                                      @dtw_assign(checkedAllAlphaSequence, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllAlphaSequence, "")
                                  %endif
                                  %if (V_N2AVND == "ALL")
                                      @dtw_assign(checkedAllVendorNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllVendorNumber, "")
                                  %endif
                                  %if (V_N2AVTP == "ALL")
                                      @dtw_assign(checkedAllVendorType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllVendorType, "")
                                  %endif
                                  %if (V_N2ADUE == "ALL")
                                      @dtw_assign(checkedAllVoucherDueDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllVoucherDueDate, "")
                                  %endif
                                  %if (V_N2ADSC == "ALL")
                                      @dtw_assign(checkedAllVoucherDiscountDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllVoucherDiscountDate, "")
                                  %endif

                                  %if (V_N2PBNK == "Y")
                                      @dtw_assign(checkedBankNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedBankNumberTotals, "")
                                  %endif
                                  %if (V_N2PALP == "Y")
                                      @dtw_assign(checkedAlphaSequenceTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAlphaSequenceTotals, "")
                                  %endif
                                  %if (V_N2PVND == "Y")
                                      @dtw_assign(checkedVendorNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedVendorNumberTotals, "")
                                  %endif
                                  %if (V_N2PVTP == "Y")
                                      @dtw_assign(checkedVendorTypeTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedVendorTypeTotals, "")
                                  %endif
                                  %if (V_N2PDUE == "Y")
                                      @dtw_assign(checkedVoucherDueDateTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedVoucherDueDateTotals, "")
                                  %endif
                                  %if (V_N2PDSC == "Y")
                                      @dtw_assign(checkedVoucherDiscountDateTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedVoucherDiscountDateTotals, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedSelectedForPayment, "CHECKED")
                                  @dtw_assign(checkedHeld, "CHECKED")
                                  @dtw_assign(checkedOpen, "CHECKED")
                                  @dtw_assign(checkedManualPayments, "CHECKED")
                                  @dtw_assign(checkedVoids, "CHECKED")
                                  @dtw_assign(checkedAllBankNumber, "CHECKED")
                                  @dtw_assign(checkedAllAlphaSequence, "CHECKED")
                                  @dtw_assign(checkedAllVendorNumber, "CHECKED")
                                  @dtw_assign(checkedAllVendorType, "CHECKED")
                                  @dtw_assign(checkedAllVoucherDueDate, "CHECKED")
                                  @dtw_assign(checkedAllVoucherDiscountDate, "CHECKED")
                                  @dtw_assign(checkedBankNumberTotals, "")
                                  @dtw_assign(checkedAlphaSequenceTotals, "")
                                  @dtw_assign(checkedVendorNumberTotals, "")
                                  @dtw_assign(checkedVendorTypeTotals, "")
                                  @dtw_assign(checkedVoucherDueDateTotals, "")
                                  @dtw_assign(checkedVoucherDiscountDateTotals, "")
                              %endif

                              <tr><td><input type="hidden" name="multiCurrency" value="$(V_CPPRMC)"></td></tr>

                              @SetTextOvr(Err_N2SELC)
                              <tr><td class="dsphdr"><span $(textOvr)>Include Vouchers </span></td>
                                  <td class="inputnmbr"><input type="checkbox" name="selectedForPayment" VALUE='1' $(checkedSelectedForPayment)>Selected For Payment</td>
                              </tr>
                              @DspErrMsg(Err_N2SELC)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input type="checkbox" name="held" VALUE='1' $(checkedHeld)>Held</td>
                              </tr>

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input type="checkbox" name="open" VALUE='1' $(checkedOpen)>Open</td>
                              </tr>

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input type="checkbox" name="manualPayments" VALUE='1' $(checkedManualPayments)>Manual Payments</td>
                              </tr>

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input type="checkbox" name="voids" VALUE='1' $(checkedVoids)>Voids</td>
                              </tr>
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                                  <td class="colhdr">Print<br>Totals</td>
                              </tr>

                              @SetTextOvr(Err_N2FBNK)
                              %if (textOvr == "") @SetTextOvr(Err_N2TBNK) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2ABNK) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SBNK) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2PBNK) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Bank</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromBankNumber" value="$(V_N2FBNK)" size="7" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)BankSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromBankNumber&amp;fldDesc=bankName" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="bankName"></td>
                                  <td class="inputnmbr"><input type="text" name="toBankNumber" value="$(V_N2TBNK)" size="7" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)BankSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toBankNumber&amp;fldDesc=bankName" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="bankName"></td>
                                  <td class="inputalph"><input type="checkbox" name="allBankNumber" value='ALL' $(checkedAllBankNumber) onClick="if (this.checked) this.form.fromBankNumber.value='', this.form.toBankNumber.value='';"></td>
                                  @Build_Sort_Select("sortBankNumber", "$(V_N2SBNK)")
                                  <td align=center ><input type="checkbox" name="totalBankNumber" $(checkedBankNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2FBNK)
                              @DspErrMsg(Err_N2TBNK)
                              @DspErrMsg(Err_N2ABNK)
                              @DspErrMsg(Err_N2SBNK)
                              @DspErrMsg(Err_N2PBNK)

                              @SetTextOvr(Err_N2FALP)
                              %if (textOvr == "") @SetTextOvr(Err_N2TALP) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2AALP) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SALP) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2PALP) %endif
                                  <tr><td  class="dsphdr"><span $(textOvr)>Alpha Sequence</span></td>
                                      <td class="inputalph"><input type="text" name="fromAlphaSequence" value="$(V_N2FALP)" size="7" maxlength="4"></td>
                                      <td class="inputalph"><input type="text" name="toAlphaSequence" value="$(V_N2TALP)" size="7" maxlength="4"></td>
                                      <td class="inputalph"><input type="checkbox" name="allAlphaSequence" value='ALL' $(checkedAllAlphaSequence) onClick="if (this.checked) this.form.fromAlphaSequence.value='', this.form.toAlphaSequence.value='';"></td>
                                      @Build_Sort_Select("sortAlphaSequence", "$(V_N2SALP)")
                                      <td align=center ><input type="checkbox" name="totalAlphaSequence" $(checkedAlphaSequenceTotals) VALUE='Y'>
                                  </tr>
                                  @DspErrMsg(Err_N2FALP)
                                  @DspErrMsg(Err_N2TALP)
                                  @DspErrMsg(Err_N2AALP)
                                  @DspErrMsg(Err_N2SALP)
                                  @DspErrMsg(Err_N2PALP)

                              @SetTextOvr(Err_N2FVND)
                              %if (textOvr == "") @SetTextOvr(Err_N2TVND) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2AVND) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SVND) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2PVND) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Vendor</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromVendorNumber" value="$(V_N2FVND)" size="7" maxlength="7">
                                                        <a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="vendorName"></td>
                                  <td class="inputnmbr"><input type="text" name="toVendorNumber" value="$(V_N2TVND)" size="7" maxlength="7">
                                                        <a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="vendorName"></td>
                                  <td class="inputalph"><input type="checkbox" name="allVendorNumber" value='ALL' $(checkedAllVendorNumber) onClick="if (this.checked) this.form.fromVendorNumber.value='', this.form.toVendorNumber.value='';"></td>
                                  @Build_Sort_Select("sortVendorNumber", "$(V_N2SVND)")
                                  <td align=center ><input type="checkbox" name="totalVendorNumber" $(checkedVendorNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2FVND)
                              @DspErrMsg(Err_N2TVND)
                              @DspErrMsg(Err_N2AVND)
                              @DspErrMsg(Err_N2SVND)
                              @DspErrMsg(Err_N2PVND)

                              @SetTextOvr(Err_N2FRVT)
                              %if (textOvr == "") @SetTextOvr(Err_N2TOVT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2AVTP) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SVTP) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2PVTP) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Vendor Type</span></td>
                                  <td class="inputalph"><input type="text" name="fromVendorType" value="$(V_N2FRVT)" size="7" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)VendorTypeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromVendorType&amp;fldDesc=vendorTypeDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="vendorTypeDesc"></td>
                                  <td class="inputalph"><input type="text" name="toVendorType" value="$(V_N2TOVT)" size="7" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)VendorTypeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toVendorType&amp;fldDesc=vendorTypeDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="vendorTypeDesc"></td>
                                  <td class="inputalph"><input type="checkbox" name="allVendorType" value='ALL' $(checkedAllVendorType) onClick="if (this.checked) this.form.fromVendorType.value='', this.form.toVendorType.value='';"></td>
                                  @Build_Sort_Select("sortVendorType", "$(V_N2SVTP)")
                                  <td align=center ><input type="checkbox" name="totalVendorType" $(checkedVendorTypeTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2FRVT)
                              @DspErrMsg(Err_N2TOVT)
                              @DspErrMsg(Err_N2AVTP)
                              @DspErrMsg(Err_N2SVTP)
                              @DspErrMsg(Err_N2PVTP)

                              @SetTextOvr(Err_N2FDUE)
                              %if (textOvr == "") @SetTextOvr(Err_N2TDUE) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2ADUE) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SDUE) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2PDUE) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Voucher Due Date</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromVoucherDueDate" value="$(V_N2FDUE)" size="7" maxlength="6">
                                                        <a href="javascript:calWindow('fromVoucherDueDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input type="text" name="toVoucherDueDate" value="$(V_N2TDUE)" size="7" maxlength="6">
                                                        <a href="javascript:calWindow('toVoucherDueDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input type="checkbox" name="allVoucherDueDate" value='ALL' $(checkedAllVoucherDueDate) onClick="if (this.checked) this.form.fromVoucherDueDate.value='', this.form.toVoucherDueDate.value='';"></td>
                                  @Build_Sort_Select("sortVoucherDueDate", "$(V_N2SDUE)")
                                  <td align=center ><input type="checkbox" name="totalVoucherDueDate" $(checkedVoucherDueDateTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2FDUE)
                              @DspErrMsg(Err_N2TDUE)
                              @DspErrMsg(Err_N2ADUE)
                              @DspErrMsg(Err_N2SDUE)
                              @DspErrMsg(Err_N2PDUE)

                              @SetTextOvr(Err_N2FDSC)
                              %if (textOvr == "") @SetTextOvr(Err_N2TDSC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2ADSC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SDSC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2PDSC) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Voucher Discount Date</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromVoucherDiscountDate" value="$(V_N2FDSC)" size="7" maxlength="6">
                                                        <a href="javascript:calWindow('fromVoucherDiscountDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input type="text" name="toVoucherDiscountDate" value="$(V_N2TDSC)" size="7" maxlength="6">
                                                        <a href="javascript:calWindow('toVoucherDiscountDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input type="checkbox" name="allVoucherDiscountDate" value='ALL' $(checkedAllVoucherDiscountDate) onClick="if (this.checked) this.form.fromVoucherDiscountDate.value='', this.form.toVoucherDiscountDate.value='';"></td>
                                  @Build_Sort_Select("sortVoucherDiscountDate", "$(V_N2SDSC)")
                                  <td align=center ><input type="checkbox" name="totalVoucherDiscountDate" $(checkedVoucherDiscountDateTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2FDSC)
                              @DspErrMsg(Err_N2TDSC)
                              @DspErrMsg(Err_N2ADSC)
                              @DspErrMsg(Err_N2SDSC)
                              @DspErrMsg(Err_N2PDSc)

                              %if (V_CPPRMC == "Y")
                                  @SetTextOvr(Err_N2CURT)
                                  <tr><td  class="dsphdr"><span $(textOvr)>Convert To Currency Type</span></td>
                                      <td class="inputalph"><input type="text" name="currencyType" value="$(V_N2CURT)" size="3" maxlength="3">
                                                            <a href="$(homeURL)$(phpPath)CurrencyTypeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=currencyType&amp;fldDesc=currencyTypeDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                            <input type="hidden" name="currencyTypeDesc"></td>
                                  </tr>
                                  @DspErrMsg(Err_N2CURT)
                              %endif
                          </table>

                          @dtw_assign(envProgram, "HAPOLA")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                          %if (focusField != "")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HAPVSS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allBankNumber)
  @dtw_mUPPERCASE(fromAlphaSequence)
  @dtw_mUPPERCASE(toAlphaSequence)
  @dtw_mUPPERCASE(allAlphaSequence)
  @dtw_mUPPERCASE(allVendorNumber)
  @dtw_mUPPERCASE(fromVendorType)
  @dtw_mUPPERCASE(toVendorType)
  @dtw_mUPPERCASE(allVendorType)
  @dtw_mUPPERCASE(allVoucherDueDate)
  @dtw_mUPPERCASE(allVoucherDiscountDate)
  %if (multiCurrency == "Y")
      @dtw_mUPPERCASE(currencyType)
  %endif

  @dtw_assign(fromBankNumber,@dtw_rstrip(fromBankNumber))
  @dtw_assign(toBankNumber,@dtw_rstrip(toBankNumber))
  @dtw_assign(sortBankNumber,@dtw_rstrip(sortBankNumber))
  @dtw_assign(sortAlphaSequence,@dtw_rstrip(sortAlphaSequence))
  @dtw_assign(fromVendorNumber,@dtw_rstrip(fromVendorNumber))
  @dtw_assign(toVendorNumber,@dtw_rstrip(toVendorNumber))
  @dtw_assign(sortVendorNumber,@dtw_rstrip(sortVendorNumber))
  @dtw_assign(sortVendorType,@dtw_rstrip(sortVendorType))
  @dtw_assign(fromVoucherDueDate,@dtw_rstrip(fromVoucherDueDate))
  @dtw_assign(toVoucherDueDate,@dtw_rstrip(toVoucherDueDate))
  @dtw_assign(sortVoucherDueDate,@dtw_rstrip(sortVoucherDueDate))
  @dtw_assign(fromVoucherDiscountDate,@dtw_rstrip(fromVoucherDiscountDate))
  @dtw_assign(toVoucherDiscountDate,@dtw_rstrip(toVoucherDiscountDate))
  @dtw_assign(sortVoucherDiscountDate,@dtw_rstrip(sortVoucherDiscountDate))

  %if (allBankNumber != "ALL")
      @dtw_assign(allBankNumber, "")
  %endif
  %if (allAlphaSequence != "ALL")
      @dtw_assign(allAlphaSequence, "")
  %endif
  %if (allVendorNumber != "ALL")
      @dtw_assign(allVendorNumber, "")
  %endif
  %if (allVendorType != "ALL")
      @dtw_assign(allVendorType, "")
  %endif
  %if (allVoucherDueDate != "ALL")
      @dtw_assign(allVoucherDueDate, "")
  %endif
  %if (allVoucherDiscountDate != "ALL")
      @dtw_assign(allVoucherDiscountDate, "")
  %endif

  %if (totalBankNumber != "Y")
      @dtw_assign(totalBankNumber, "N")
  %endif
  %if (totalAlphaSequence != "Y")
      @dtw_assign(totalAlphaSequence, "N")
  %endif
  %if (totalVendorNumber != "Y")
      @dtw_assign(totalVendorNumber, "N")
  %endif
  %if (totalVendorType != "Y")
      @dtw_assign(totalVendorType, "N")
  %endif
  %if (totalVoucherDueDate != "Y")
      @dtw_assign(totalVoucherDueDate, "N")
  %endif
  %if (totalVoucherDiscountDate != "Y")
      @dtw_assign(totalVoucherDiscountDate, "N")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@mult", multiCurrency)
  @Concat_Field("@@selc", selectedForPayment)
  @Concat_Field("@@held", held)
  @Concat_Field("@@open", open)
  @Concat_Field("@@mpmt", manualPayments)
  @Concat_Field("@@void", voids)
  @Concat_Field("@@fbnk", fromBankNumber)
  @Concat_Field("@@tbnk", toBankNumber)
  @Concat_Field("@@abnk", allBankNumber)
  @Concat_Field("@@sbnk", sortBankNumber)
  @Concat_Field("@@pbnk", totalBankNumber)
  @Concat_Field("@@falp", fromAlphaSequence)
  @Concat_Field("@@talp", toAlphaSequence)
  @Concat_Field("@@aalp", allAlphaSequence)
  @Concat_Field("@@salp", sortAlphaSequence)
  @Concat_Field("@@palp", totalAlphaSequence)
  @Concat_Field("@@fvnd", fromVendorNumber)
  @Concat_Field("@@tvnd", toVendorNumber)
  @Concat_Field("@@avnd", allVendorNumber)
  @Concat_Field("@@svnd", sortVendorNumber)
  @Concat_Field("@@pvnd", totalVendorNumber)
  @Concat_Field("@@frvt", fromVendorType)
  @Concat_Field("@@tovt", toVendorType)
  @Concat_Field("@@avtp", allVendorType)
  @Concat_Field("@@svtp", sortVendorType)
  @Concat_Field("@@pvtp", totalVendorType)
  @Concat_Field("@@fdue", fromVoucherDueDate)
  @Concat_Field("@@tdue", toVoucherDueDate)
  @Concat_Field("@@adue", allVoucherDueDate)
  @Concat_Field("@@sdue", sortVoucherDueDate)
  @Concat_Field("@@pdue", totalVoucherDueDate)
  @Concat_Field("@@fdsc", fromVoucherDiscountDate)
  @Concat_Field("@@tdsc", toVoucherDiscountDate)
  @Concat_Field("@@adsc", allVoucherDiscountDate)
  @Concat_Field("@@sdsc", sortVoucherDiscountDate)
  @Concat_Field("@@pdsc", totalVoucherDiscountDate)
  %if (multiCurrency == "Y")
      @Concat_Field("@@curt", currencyType)
  %endif

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}