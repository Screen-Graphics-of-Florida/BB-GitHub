%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Cost Summary Maintenance"
  d2wName                 = "CostSummaryMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;costSet=@dtw_rurlescseq(costSet)&amp;costSetDescription=@dtw_rurlescseq(costSetDescription)&amp;maintenanceCode=D"
  programName             = "HPD030"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  Cat1Desc                = ""
  Cat2Desc                = ""
  Cat3Desc                = ""
  Cat4Desc                = ""
  Cat5Desc                = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLCC1D", Cat1Desc)
          @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLCC2D", Cat2Desc)
          @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLCC3D", Cat3Desc)
          @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLCC4D", Cat4Desc)
          @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLCC5D", Cat5Desc)

          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.costSet.value =="")
                     {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.costSet, 2, 0) &&
                      editNum(document.Chg.unitCostCategory1, 12, 5) &&
                      editNum(document.Chg.unitCostCategory2, 12, 5) &&
                      editNum(document.Chg.unitCostCategory3, 12, 5) &&
                      editNum(document.Chg.unitCostCategory4, 12, 5) &&
                      editNum(document.Chg.unitCostCategory5, 12, 5) &&
                      editNum(document.Chg.thisLevelCostCategory1, 12, 5) &&
                      editNum(document.Chg.thisLevelCostCategory2, 12, 5) &&
                      editNum(document.Chg.thisLevelCostCategory3, 12, 5) &&
                      editNum(document.Chg.thisLevelCostCategory4, 12, 5) &&
                      editNum(document.Chg.thisLevelCostCategory5, 12, 5))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
	       %INCLUDE "NumEdit.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "COSTSUMMARYMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, " Select * From HDMCMM inner join HDIPLT on CMPLT=IPPLT and CMPN=IPITEM", stmtSQL)
                          @dtw_concat(stmtSQL, " Where (CMPLT=$(plantNumber) and CMPN='$(itemNumber)' and CMCSET = $(costSet))", stmtSQL)
                          @dtw_concat(stmtSQL, " Order By CMPLT, CMPN, CMCSET ", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
      <table $(contentTable)>
          @Format_Header("Plant", $(plantName), $(plantNumber))
          @Format_Header("Item", $(itemDescription), $(itemNumber))
      </table>

      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "costSet")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@plt@", "plantNumber")             @dtw_assign(Err_CMPLT, fieldValue)
                          @DecatErr_Field("@@cset", "costSet")                 @dtw_assign(Err_CMCSET, fieldValue)
                          @DecatErr_Field("@@pn@@", "itemNumber")              @dtw_assign(Err_CMPN, fieldValue)
                          @DecatErr_Field("@@ucc1", "unitCostCategory1")       @dtw_assign(Err_CMUCC1, fieldValue)
                          @DecatErr_Field("@@ucc2", "unitCostCategory2")       @dtw_assign(Err_CMUCC2, fieldValue)
                          @DecatErr_Field("@@ucc3", "unitCostCategory3")       @dtw_assign(Err_CMUCC3, fieldValue)
                          @DecatErr_Field("@@ucc4", "unitCostCategory4")       @dtw_assign(Err_CMUCC4, fieldValue)
                          @DecatErr_Field("@@ucc5", "unitCostCategory5")       @dtw_assign(Err_CMUCC5, fieldValue)
                          @DecatErr_Field("@@lcc1", "thisLevelCostCategory1")  @dtw_assign(Err_CMLCC1, fieldValue)
                          @DecatErr_Field("@@lcc2", "thisLevelCostCategory2")  @dtw_assign(Err_CMLCC2, fieldValue)
                          @DecatErr_Field("@@lcc3", "thisLevelCostCategory3")  @dtw_assign(Err_CMLCC3, fieldValue)
                          @DecatErr_Field("@@lcc4", "thisLevelCostCategory4")  @dtw_assign(Err_CMLCC4, fieldValue)
                          @DecatErr_Field("@@lcc5", "thisLevelCostCategory5")  @dtw_assign(Err_CMLCC5, fieldValue)
                          @DecatErr_Field("@@csrl", "noCostRoll")              @dtw_assign(Err_IPCSRL, fieldValue)


                      %endif

                      @Decat_Field("@@plt@")   @dtw_assign(V_CMPLT, fieldValue)
                      @Decat_Field("@@cset")   @dtw_assign(V_CMCSET, fieldValue)
                      @Decat_Field("@@pn@@")   @dtw_assign(V_CMPN, fieldValue)
                      @Decat_Field("@@ucc1")   @dtw_assign(V_CMUCC1, fieldValue)
                      @Decat_Field("@@ucc2")   @dtw_assign(V_CMUCC2, fieldValue)
                      @Decat_Field("@@ucc3")   @dtw_assign(V_CMUCC3, fieldValue)
                      @Decat_Field("@@ucc4")   @dtw_assign(V_CMUCC4, fieldValue)
                      @Decat_Field("@@ucc5")   @dtw_assign(V_CMUCC5, fieldValue)
                      @Decat_Field("@@lcc1")   @dtw_assign(V_CMLCC1, fieldValue)
                      @Decat_Field("@@lcc2")   @dtw_assign(V_CMLCC2, fieldValue)
                      @Decat_Field("@@lcc3")   @dtw_assign(V_CMLCC3, fieldValue)
                      @Decat_Field("@@lcc4")   @dtw_assign(V_CMLCC4, fieldValue)
                      @Decat_Field("@@lcc5")   @dtw_assign(V_CMLCC5, fieldValue)
                      @Decat_Field("@@csrl")   @dtw_assign(F_IPCSRL, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(F_IPCSRL, "")
                          @dtw_assign(focusField, "costSet")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_CMCSET, "")
                      @dtw_assign(F_IPCSRL, "")
                      @dtw_assign(focusField, "costSet")
                  %else
                      @dtw_assign(F_IPCSRL, "")
                      %if (V_CMCSET == "1")
                          @dtw_assign(F_IPCSRL, V_IPCSRL)
                      %elif (V_CMCSET == "2")
                          @dtw_assign(F_IPCSRL, V_IPCSRC)
                      %elif (V_CMCSET == "3")
                          @dtw_assign(F_IPCSRL, V_IPCSRF)
                      %endif
                      @dtw_assign(focusField, "unitCostCategory1")
                  %endif

                  @Default_Zero(V_CMCSET)
                  @RtvFldDesc("STCSET=$(V_CMCSET)", "SCMSTM", "STCSLD", costSetDescription)
                  @SetTextOvr(Err_CMCSET)
                  <tr><td class="dsphdr"><span $(textOvr)>Cost Set</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr" colspan="3"><input name="costSet" type="text" value="$(V_CMCSET)" size="2" maxlength="2"> $(reqFieldChar) <a href="$(homeURL)$(cGIPath)CostSetDefinitionSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=costSet&amp;fldDesc=costSetDescription" onclick="$(searchWinVar)">  $(searchImage) </a> <input disabled name="costSetDescription" value="$(costSetDescription)"  type="text" size="25"></td>
                      %else
                          <td class="inputnmbr" colspan="3"><input name="costSet" type="hidden" value="$(V_CMCSET)" size="2">$(V_CMCSET) - $(costSetDescription)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_CMCSET)

                  <tr><td>&nbsp;</td>
                      <td class="colhdr">Unit Cost</td>
                      <td class="colhdr">This Level Cost</td>
                  </tr>

                  @Default_Zero(V_CMUCC1)    	   		
                  @Default_Zero(V_CMLCC1)    	   		
                  <tr><td class="dsphdr">$(Cat1Desc)</td>
                      <td class="inputnmbr"><input type="text" name="unitCostCategory1" value="$(V_CMUCC1)" size="13" maxlength="13"></td>
                      <td class="inputnmbr"><input type="text" name="thisLevelCostCategory1" value="$(V_CMLCC1)" size="13" maxlength="13"></td>
                  </tr>
    	   		
                  @Default_Zero(V_CMUCC2)    	   		
                  @Default_Zero(V_CMLCC2)    	   		
                  <tr><td class="dsphdr">$(Cat2Desc)</td>
                      <td class="inputnmbr"><input type="text" name="unitCostCategory2" value="$(V_CMUCC2)" size="13" maxlength="13"></td>
                      <td class="inputnmbr"><input type="text" name="thisLevelCostCategory2" value="$(V_CMLCC2)" size="13" maxlength="13"></td>
                  </tr>
    	   		
                  @Default_Zero(V_CMUCC3)    	   		
                  @Default_Zero(V_CMLCC3)    	   		
                  <tr><td class="dsphdr">$(Cat3Desc)</td>
                      <td class="inputnmbr"><input type="text" name="unitCostCategory3" value="$(V_CMUCC3)" size="13" maxlength="13"></td>
                      <td class="inputnmbr"><input type="text" name="thisLevelCostCategory3" value="$(V_CMLCC3)" size="13" maxlength="13"></td>
                  </tr>
    	   		
                  @Default_Zero(V_CMUCC4)    	   		
                  @Default_Zero(V_CMLCC4)    	   		
                  <tr><td class="dsphdr">$(Cat4Desc)</td>
                      <td class="inputnmbr"><input type="text" name="unitCostCategory4" value="$(V_CMUCC4)" size="13" maxlength="13"></td>
                      <td class="inputnmbr"><input type="text" name="thisLevelCostCategory4" value="$(V_CMLCC4)" size="13" maxlength="13"></td>
                  </tr>
    	   		
                  @Default_Zero(V_CMUCC5)    	   		
                  @Default_Zero(V_CMLCC5)    	   		
                  <tr><td class="dsphdr">$(Cat5Desc)</td>
                      <td class="inputnmbr"><input type="text" name="unitCostCategory5" value="$(V_CMUCC5)" size="13" maxlength="13"></td>
                      <td class="inputnmbr"><input type="text" name="thisLevelCostCategory5" value="$(V_CMLCC5)" size="13" maxlength="13"></td>
                  </tr>
    	   		
                  @SetTextOvr(Err_IPCSRL)
                  <tr><td class="dsphdr"><span $(textOvr)>No Cost Roll-Up</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != F_IPCSRL) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "noCostRoll", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_IPCSRL)

                  %if (maintenanceCode == "C")
                      <tr><td class="dsphdr">Cost Error On Last Roll-Up</td>
               	          <td class="dspalph">$(V_CMCEFL)</td>		
                      </tr>

                      @Format_Date(V_CMRUDT, "H", F_CMRUDT)
                      <tr><td class="dsphdr">Date Of Last Cost Roll-Up</td>
                          <td class="dspdate">$(F_CMRUDT)</td>
                      </tr>

                      @Format_Date(V_CMEFDT, "H", F_CMEFDT)
                      <tr><td class="dsphdr">Cost Roll-Up Effectivity Date</td>
                          <td class="dspdate">$(F_CMEFDT)</td>
                      </tr>

                      @Format_Date(V_CMDTMT, "H", F_CMDTMT)
                      <tr><td class="dsphdr">Date Of Last Maintenance</td>
                          <td class="dspdate">$(F_CMDTMT)</td>
                      </tr>
                  %endif
              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HPD030_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @yn01_Table_Query(profileHandle, dataBaseID, "BY        ", yn01Table)

      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @dtw_assign(costSet,@dtw_rstrip(costSet))
  @dtw_assign(unitCostCategory1,@dtw_rstrip(unitCostCategory1))
  @dtw_assign(unitCostCategory2,@dtw_rstrip(unitCostCategory2))
  @dtw_assign(unitCostCategory3,@dtw_rstrip(unitCostCategory3))
  @dtw_assign(unitCostCategory4,@dtw_rstrip(unitCostCategory4))
  @dtw_assign(unitCostCategory5,@dtw_rstrip(unitCostCategory5))
  @dtw_assign(thisLevelCostCategory1,@dtw_rstrip(thisLevelCostCategory1))
  @dtw_assign(thisLevelCostCategory2,@dtw_rstrip(thisLevelCostCategory2))
  @dtw_assign(thisLevelCostCategory3,@dtw_rstrip(thisLevelCostCategory3))
  @dtw_assign(thisLevelCostCategory4,@dtw_rstrip(thisLevelCostCategory4))
  @dtw_assign(thisLevelCostCategory5,@dtw_rstrip(thisLevelCostCategory5))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@cset", costSet)
  @Concat_Field("@@pn@@", itemNumber)
  @Concat_Field("@@ucc1", unitCostCategory1)
  @Concat_Field("@@ucc2", unitCostCategory2)
  @Concat_Field("@@ucc3", unitCostCategory3)
  @Concat_Field("@@ucc4", unitCostCategory4)
  @Concat_Field("@@ucc5", unitCostCategory5)
  @Concat_Field("@@lcc1", thisLevelCostCategory1)
  @Concat_Field("@@lcc2", thisLevelCostCategory2)
  @Concat_Field("@@lcc3", thisLevelCostCategory3)
  @Concat_Field("@@lcc4", thisLevelCostCategory4)
  @Concat_Field("@@lcc5", thisLevelCostCategory5)
  @Concat_Field("@@csrl", noCostRoll)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)
  @RtvFldDesc("STCSET=$(costSet)", "SCMSTM", "STCSLD", costSetDescription)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(costSetDescription), $(costSet), "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)CostSummary.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@cset", "costSet")
      @Format_ConfMsg_Desc("", $(costSetDescription), $(costSet), "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)CostSummary.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;costSet=@dtw_rurlescseq(costSet)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
