%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"

%Define {
  page_title 	      = "Catalog Selection Criteria"
  DATABASE           = "*LOCAL"
  DTW_DEFAULT_REPORT = "NO"
%}

%INCLUDE "opersel_dspfield.icl"

%FUNCTION(dtw_directcall) Retrieve_Catalog_Selection(INOUT CHAR(64) profileHandle,
                                                     INOUT CHAR(2)  dataBaseID,
                                                     INOUT CHAR(1)  maintCode,
                                                     INOUT CHAR(15) catalog,
                                                     INOUT DEC(7,0) recordSequence,
                                                     INOUT DEC(7,2) orderSequence,
                                                     INOUT CHAR(50) selectDesc,
                                                     INOUT CHAR(500) newPage,
                                                     INOUT CHAR(500) selectGroupBy,
                                                     INOUT CHAR(3000) selectCriteria)
  {%EXEC {HOECTS_W.PGM %}
%}

%HTML(DISPLAY){
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onLoad="window.focus()" onBlur="window.close()">

	   <table $(contentTable)>
              <tr><td><h1>$(page_title)</h1></td></tr>
	   </table>
          <table $(contentTable)>
              @Format_Header("Catalog", $(catalogDesc), $(catalog))
          </table>

          $(hrTagAttr)

          @dtw_assign(maintCode, "R")
          @Retrieve_Catalog_Selection(profileHandle, dataBaseID, maintCode, catalog, recordSequence, orderSequence, selectDesc, newPage, selectGroupBy, selectCriteria)

          <table $(contentTable)>
              <tr><td class="dsphdr">Description</td>
                  <td class="dspalph" colspan="2">$(selectDesc)</td>
              </tr>
              <tr><td class="dsphdr">Sequence Number</td>
                  <td class="dspnmbr">$(orderSequence)</td>
              </tr>
              <tr><td>&nbsp;</td>
                  <td class="colhdr">Operand</td>
                  <td class="colhdr">From</td>
                  <td class="colhdr">&nbsp; To &nbsp;</td>
                  <td class="colhdr">Group<br>By</td>
                  <td class="colhdr">New<br>Page</td>
              </tr>
              @Build_Selection("IXCTG1", "Category 1", "A")
              @Build_Selection("IXCTG2", "Category 2", "A")
              @Build_Selection("IXCTG3", "Category 3", "A")
              @Build_Selection("IXCTG4", "Category 4", "A")
              @Build_Selection("IXCTG5", "Category 5", "A")
              @Build_Selection("IXUXA1", "$(itemExtAlph1)", "A")
              @Build_Selection("IXUXA2", "$(itemExtAlph2)", "A")
              @Build_Selection("IXUXA3", "$(itemExtAlph3)", "A")
              @Build_Selection("IXUXA4", "$(itemExtAlph4)", "A")
              @Build_Selection("IXUXA5", "$(itemExtAlph5)", "A")
              @Build_Selection("IXUXN1", "$(itemExtNum1)", "N")
              @Build_Selection("IXUXN2", "$(itemExtNum2)", "N")
              @Build_Selection("IXUXN3", "$(itemExtNum3)", "N")
              @Build_Selection("IXUXN4", "$(itemExtNum4)", "N")
              @Build_Selection("IXUXN5", "$(itemExtNum5)", "N")
              @Build_Selection("IXUXD1", "$(itemExtDate1)", "D")
              @Build_Selection("IXUXD2", "$(itemExtDate2)", "D")
              @Build_Selection("IXUXD3", "$(itemExtDate3)", "D")
              @Build_Selection("IXUXD4", "$(itemExtDate4)", "D")
              @Build_Selection("IXUXD5", "$(itemExtDate5)", "D")
              @Build_Selection("IMUDA1", "$(V_CIIAS1)", "A")
              @Build_Selection("IMUDA2", "$(V_CIIAS2)", "A")
              @Build_Selection("IMUDA3", "$(V_CIIAS3)", "A")
              @Build_Selection("IMUDA4", "$(V_CIIAS4)", "A")
              @Build_Selection("IMUDA5", "$(V_CIIAS5)", "A")
              @Build_Selection("IMUDN1", "$(V_CIINS1)", "N")
              @Build_Selection("IMUDN2", "$(V_CIINS2)", "N")
              @Build_Selection("IMUDN3", "$(V_CIINS3)", "N")
              @Build_Selection("IMUDN4", "$(V_CIINS4)", "N")
              @Build_Selection("IMUDN5", "$(V_CIINS5)", "N")
              @Build_Selection("IMPCLS", "Product Class", "A")
              @Build_Selection("IWPGRP", "Product Group", "A")
              @Build_Selection("IMITC", "Inventory Type", "A")
              @Build_Selection("IWWHS", "Warehouse Number", "N")
              @Build_Selection("IMITEM", "Item Number", "A")
              @Build_Selection("IMIMDS", "Item Description", "A")
	   </table>
          $(hrTagAttr)
          %INCLUDE "CloseWindow.icl"
      </body>
  </html>
%}