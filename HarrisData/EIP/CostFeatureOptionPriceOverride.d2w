%}

%INCLUDE "$(baseVar)"
%INCLUDE "BrowserType.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title         = "Feature/Option Price Override"
  d2wName            = "CostFeatureOptionPriceOverride.d2w"
  d2wVarBase         = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;feature=@dtw_rurlescseq(feature)&amp;featureDesc=@dtw_rurlescseq(featureDesc)&amp;option=@dtw_rurlescseq(option)&amp;optionDesc=@dtw_rurlescseq(optionDesc)&amp;biLevel=@dtw_rurlescseq(biLevel)"
  DATABASE           = "*LOCAL"
  DTW_DEFAULT_REPORT = "NO"
  DTW_HTML_TABLE     = "YES"
  DTW_PAD_PGM_PARMS  = "YES"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "headcmt.icl"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                 if (editNum(document.Chg.sellingPrice, 9, 5) &&
                      editNum(document.Chg.extraCharge, 9, 5))
                      return true;
              }
	       %INCLUDE "NumEdit.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      @dtw_concat(stmtSQL, "Select * From HDFOPW Where SAXHND='$(profileHandle)' and SAFEAT='$(feature)' and SABLVL='$(biLevel)' and SAOPTN='$(option)'", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Option_Maintain(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Option_Maintain (IN CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  <a href="javascript:check(document.Chg)">$(selectAcceptImage)</a>
                  %INCLUDE "CloseWindow.icl"
              </td>
          </tr>
      </table>
      <table $(contentTable)>
          @Format_Header("Feature", $(featureDesc), $(feature))
          @Format_Header("Option", $(optionDesc), $(option))
      </table>
      $(hrTagAttr)

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)">
          %ROW {
              <table $(contentTable)>
                  <tr><td class="dsphdr">Price</td>
                      <td class="inputnmbr"><input type="text" name="sellingPrice" value="$(V_SASLPR)" size="15" maxlength="15"></td>
                  </tr>
                  <tr><td class="dsphdr">Extra Charge</td>
                      <td class="inputnmbr"><input type="text" name="extraCharge" value="$(V_SAXCHG)" size="15" maxlength="15"></td>
                  </tr>
                  <tr>
                      <td><input type="hidden" name="savePrice" value="$(V_SASLPR)"></td>
                      <td><input type="hidden" name="saveOverride" value="$(V_SALPOV)"></td>
                  </tr>
              </table>
          %}
      </form>
      $(hrTagAttr)
      <a href="javascript:check(document.Chg)">$(selectAcceptImage)</a>
      %INCLUDE "CloseWindow.icl"
  %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  %if (sellingPrice == savePrice)
      @dtw_assign(priceOverride, saveOverride)
  %elif (sellingPrice > ".00000")
      @dtw_assign(priceOverride, "Y")
  %else
      @dtw_assign(sellingPrice, "0")
      @dtw_assign(priceOverride, "")
  %endif
  %if (extraCharge == "")
      @dtw_assign(extraCharge, "0")
  %endif
  @dtw_concat(stmtSQL, " Update HDFOPW Set SASLPR=$(sellingPrice), SALPOV='$(priceOverride)', SAXCHG=$(extraCharge) ", stmtSQL)
  @dtw_concat(stmtSQL, " Where SAXHND='$(profileHandle)' and SAFEAT='$(feature)' and SABLVL='$(biLevel)' and SAOPTN='$(option)'  @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)

  <script TYPE="text/javascript">
      opener.location.href="$(homeURL)$(cGIPath)CostSimulatorFeatureOption2.d2w/PRICE?baseVar=@dtw_rurlescseq(baseVar)&portal=@dtw_rurlescseq(portal)&eID=@dtw_rurlescseq(eID)&plantNumber=@dtw_rurlescseq(plantNumber)&itemNumber=@dtw_rurlescseq(itemNumber)&feature=@dtw_rurlescseq(feature)&option=@dtw_rurlescseq(option)&biLevel=@dtw_rurlescseq(biLevel)&maintenanceCode=P&timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))";
      opener.focus();
      self.close();
  </script>

%}