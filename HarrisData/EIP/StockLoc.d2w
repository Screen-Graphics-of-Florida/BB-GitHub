%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Stock Location"
  d2wName                 = "StockLoc.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;warehouseName=@dtw_rurlescseq(warehouseName)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HHDSRU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@warehouseNumber", "@dtw_rurlescseq(warehouseNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@warehouseName", "@dtw_rurlescseq(warehouseName)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  %if (warehouseName =="")
                      if (editNum(document.Search.wareHouse, 3, 0))
                  %endif
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "STOCKLOC")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " HDSTLC ", fileSQL)
                      @dtw_concat(selectSQL, "SLWHS=$(warehouseNumber) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @StockLoc_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) StockLoc_Query (IN CHAR(64) profileHandle,
                                      CHAR(2)   dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)StockLocMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      <table $(contentTable)>
          @Format_Header_URL("Warehouse", $(warehouseName), $(warehouseNumber), "$(homeURL)$(cGIPath)WarehouseSelect.d2w/REPORT$(d2wVarBase)")
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      %if (warehouseName =="")
                           @dtw_assign(focusField, "wareHouse")
                          <th class="colhdr"> Whs</th>
                          <th class="colhdr" colspan="3"> Stock Location</th>
                      %else
                           @dtw_assign(focusField, "stockRoom")
                          <th class="colhdr" colspan="4"> Stock Location</th>
                      %endif
                  </tr>
                  <tr>%if (warehouseName =="")
                           <td><input type="text" class="inputnmbr" name="wareHouse" size="3" maxlength="3">
                               <input type="hidden" name="operWhs" value="=">
                           </td>
                      %else
                           <td><input type="hidden" class="inputnmbr" name="wareHouse"></td>
                      %endif
                      <td><input type="text" class="inputalph" name="stockRoom" size="3" maxlength="3">
                          <input type="hidden" name="operRoom" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="aisle" size="4" maxlength="4">
                          <input type="hidden" name="operAisle" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="location" size="8" maxlength="8">
                          <input type="hidden" name="operLoc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.$(focusField).focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              %if (warehouseName =="")
                  @OrderBy_Sort("SLWHS", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Whs" title="Sequence By Warehouse, Stock Location"> Whs</a></th>
              %endif
              @OrderBy_Sort("SLSTKR", sortVar)
              <th class="colhdr$(sortVar)" colspan="3"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=StockLocation" title="Sequence By Stock Location"> Stock Location</a></th>
              @OrderBy_Sort("SLPALT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Pallet" title="Sequence By Pallet, Warehouse, Stock Location"> Pallet</a></th>
              @OrderBy_Sort("SLRATE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Priority" title="Sequence By Priority, Warehouse, Stock Location"> Priority</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{

               @dtw_assign(maintainVar, "$(genericVarBase)&amp;warehouseNumber=@dtw_rurlescseq(V_SLWHS)&amp;stockRoom=@dtw_rurlescseq(V_SLSTKR)&amp;aisle=@dtw_rurlescseq(V_SLAILE)&amp;location=@dtw_rurlescseq(V_SLSLOC)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
               %INCLUDE "SetRowClass.icl"
               @Format_Confirm_Desc("$(V_SLSTKR)-$(V_SLAILE)-$(V_SLSLOC)", "", "", "", "", "", confirmDesc)

               <tr class="$(rowClass)">
                   %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                       <td class="opticon">
                           %if (sec_02 == "Y" || sec_03 == "Y")
                               <a href="$(homeURL)$(cGIPath)StockLocMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                           %endif
                           %if (sec_04 == "Y")
                               <a href="$(homeURL)$(cGIPath)StockLocMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                           %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)StockLocMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                       </td>
                   %endif
                   %if (warehouseName =="")
                       <td class="colnmbr">$(V_SLWHS)</td>
                   %endif
                   <td class="colalph">$(V_SLSTKR)</td>
                   <td class="colalph">$(V_SLAILE)</td>
                   <td class="colalph">$(V_SLSLOC)</td>
                   <td class="colcode">$(V_SLPALT)</td>
                   <td class="colcode">$(V_SLRATE)</td>
               </tr>
           %}
       </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
  @dtw_concat(fileSQL, " HDSTLC ", fileSQL)
  @dtw_concat(selectSQL, "SLWHS=$(warehouseNumber) ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @StockLoc_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) StockLoc_XMLQuery (IN CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("StockLocList")
          %ROW{
	       @XMLIDTag("$(V_SLSTKR)-$(V_SLAILE)-$(V_SLSLOC)", "StockLoc ID")
                  @XMLTag("$(V_SLSTKR)-$(V_SLAILE)-$(V_SLSLOC)", "StockLoc")
                  @XMLTag(V_SLWHS, "Warehouse")
                  @XMLTag(V_SLSTKR, "Stockroom")
                  @XMLTag(V_SLAILE, "Aisle")
                  @XMLTag(V_SLSLOC, "Location")
                  @XMLTag(V_SLPALT, "PalletSize")
                  @XMLTag(V_SLRATE, "Priority")
              @XMLEndTag("StockLoc")
          %}
      @XMLEndTag("StockLocList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "SLSTKR,SLAILE,SLSLOC,SLWHS")
          @DTW_ASSIGN(orderByDisplay, "Stock Location, Warehouse")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Whs")
      %if (orderBy == "SLWHS,SLSTKR,SLAILE,SLSLOC")
          @DTW_ASSIGN(orderBy, "SLWHS DESC,SLSTKR,SLAILE,SLSLOC")
          @DTW_ASSIGN(orderByDisplay, "Warehouse (descending), Stock Location")
      %else
          @DTW_ASSIGN(orderBy, "SLWHS,SLSTKR,SLAILE,SLSLOC")
          @DTW_ASSIGN(orderByDisplay, "Warehouse, Stock Location")
      %endif
  %elseif (sequence == "StockLocation")
      %if (orderBy == "SLSTKR,SLAILE,SLSLOC,SLWHS")
          @DTW_ASSIGN(orderBy, "SLSTKR DESC,SLAILE,SLSLOC,SLWHS")
          @DTW_ASSIGN(orderByDisplay, "Stock Location (descending), Warehouse")
      %else
          @DTW_ASSIGN(orderBy, "SLSTKR,SLAILE,SLSLOC,SLWHS")
          @DTW_ASSIGN(orderByDisplay, "Stock Location, Warehouse")
      %endif
  %elseif (sequence == "Pallet")
      %if (orderBy == "SLPALT,SLWHS,SLSTKR,SLAILE,SLSLOC")
          @DTW_ASSIGN(orderBy, "SLPALT DESC,SLWHS,SLSTKR,SLAILE,SLSLOC")
          @DTW_ASSIGN(orderByDisplay, "Pallet (descending), Warehouse, Stock Location")
      %else
          @DTW_ASSIGN(orderBy, "SLPALT,SLWHS,SLSTKR,SLAILE,SLSLOC")
          @DTW_ASSIGN(orderByDisplay, "Pallet, Warehouse, Stock Location")
      %endif
  %elseif (sequence == "Priority")
      %if (orderBy == "SLRATE,SLWHS,SLSTKR,SLAILE,SLSLOC")
          @DTW_ASSIGN(orderBy, "SLRATE DESC,SLWHS,SLSTKR,SLAILE,SLSLOC")
          @DTW_ASSIGN(orderByDisplay, "Priority (descending), Warehouse, Stock Location")
      %else
          @DTW_ASSIGN(orderBy, "SLRATE,SLWHS,SLSTKR,SLAILE,SLSLOC")
          @DTW_ASSIGN(orderByDisplay, "Priority, Warehouse, Stock Location")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("SLWHS", "Warehouse", $(wareHouse), "", operWhs, "N")
  @Build_WildCard ("SLSTKR", "Stockroom", $(stockRoom), "U", operRoom, "A")
  @Build_WildCard ("SLAILE", "Aisle", $(aisle), "U", operAisle, "A")
  @Build_WildCard ("SLSLOC", "Location", $(location), "U", operLoc, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}