%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "Employee.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"
%INCLUDE "QuickLink.icl"

%Define {
  page_title              = "Employee Payroll Taxes Maintenance"
  d2wName                 = "EmplMaintainTax.d2w"
  d2wVarBase              = "$(genericVarBase)$(employeeVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  programName             = "HHREMU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  PAYTYPECODE             = ""
  SCRS                    = ""
  DLIN                    = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
  @dtw_replace(workURL, "@@fromD2w", "@dtw_rurlescseq(fromD2w)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  function validate(chgForm) {
                      %if (prEmployee != "99999")
                          if (document.Chg.fitExempt.value =="" ||
                              document.Chg.ficaExempt.value =="" ||
                              document.Chg.fitWhStatus.value =="" ||
                              document.Chg.earnedIncomeCr.value =="" ||
                              document.Chg.sitExempt.value =="" ||
                              document.Chg.sitId.value =="" ||
                              document.Chg.suiId.value =="" ||
                              document.Chg.swcExempt.value =="" ||
                              document.Chg.qualPension.value =="" ||
                              document.Chg.legalRep.value =="")
                              {alert("$(reqFieldError)"); return false;}
                      %endif
                      if (editNum(document.Chg.wageExpAcct, 4, 0) &&
                          editNum(document.Chg.wageExpSub, 4, 0) &&
                          editNum(document.Chg.fitDependents, 2, 2) &&
                          editNum(document.Chg.fitAddPercent, 2, 3) &&
                          editNum(document.Chg.fitAddAmount, 5, 2) &&
                          editNum(document.Chg.fitCommRate, 2, 1) &&
                          editNum(document.Chg.fitBonusRate, 2, 1) &&
                          editNum(document.Chg.guaranteedAmount, 7, 2) &&
                          editNum(document.Chg.guaranteedPercent, 2, 3) &&
                          editNum(document.Chg.sitDependents, 2, 2) &&
                          editNum(document.Chg.persExCat, 1, 0) &&
                          editNum(document.Chg.addlExCat, 1, 0) &&
                          editNum(document.Chg.exemptAmount, 5, 2) &&
                          editNum(document.Chg.taxCreditCat, 1, 0) &&
                          editNum(document.Chg.addlCredits, 2, 0) &&
                          editNum(document.Chg.sitAddPercent, 2, 3) &&
                          editNum(document.Chg.sitAddAmount, 5, 2) &&
                          editNum(document.Chg.sitCommRate, 2, 3) &&
                          editNum(document.Chg.sitBonusRate, 2, 3) &&
                          editNum(document.Chg.jobClass, 4, 0) &&
                          editNum(document.Chg.loc1Dep, 2, 0) &&
                          editNum(document.Chg.loc2Dep, 2, 0) &&
                          editNum(document.Chg.loc1PersExempt, 2, 0) &&
                          editNum(document.Chg.loc2PersExempt, 2, 0) &&
                          editNum(document.Chg.occIndCode, 6, 0) &&
                          editNum(document.Chg.emplHealthCode, 1, 0) &&
                          editNum(document.Chg.employerHealthCode, 1, 0) &&
                          editdate(document.Chg.probationDate) &&
                          editdate(document.Chg.dateDeceased))
                      return true;
                  }
	           %INCLUDE "numedit.icl"
                  %INCLUDE "dateedit.icl"
                  %INCLUDE "calendar.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "EMPLMAINTAINTAX")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          @dtw_concat(stmtSQL, "SELECT PREMPL.*, coalesce(RXLPE1,0) as RXLPE1, coalesce(RXLPE2,0) as RXLPE2, coalesce(RXERES,'  ') as RXERES, coalesce(RXW420,'  ') as RXW420, coalesce(RXSTP2,'  ') as RXSTP2, coalesce(RXCDAM,0) as RXCDAM, coalesce(RXOTHI,0) as RXOTHI, coalesce(RXDED,0) as RXDED  ", stmtSQL)                                                    
                          @dtw_concat(stmtSQL, " FROM PREMPL left outer join HREMPL on ERCOMP=EMCOMP and ERFACL=EMFACL and EREMPL=EMEMPL ", stmtSQL)
                          @dtw_concat(stmtSQL, "             left outer join PREMPLE on EMEMID=RXEMID ", stmtSQL)                          
                          @dtw_concat(stmtSQL, " WHERE ERCOMP=$(prCompany) and ERFACL=$(prFacility) and EREMPL=$(prEmployee)", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @MaintainTax_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) MaintainTax_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @dtw_assign(sec_03, "N")
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
	   <colgroup>
	       <col width="80%">
	       <col width="15%">
          @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
          <tr><td><h2>$(F_EmpName)</h2></td></tr>
      </table>
      $(hrTagAttr)

      <table $(quickLinkTable)>
           %if (genEmplImage != "" && quicklinkDspImage == "Y")
              <tr>
                  <td><a href="#federal">$(federalImage)</a></td>
                  <td><a href="#stateIncomeTax">$(sitImage)</a></td>
                  <td><a href="#stateUnemploymentInsurance">$(suiImage)</a></td>
                  <td><a href="#stateWorkersComp">$(swcImage)</a></td>
              </tr>
              <tr><td><a href="#stateDisabilityInsurance">$(sdiImage)</a></td>
                  <td><a href="#localTax">$(litImage)</a></td>
                  <td><a href="#taxReporting">$(taxReportingImage)</a></td>
              </tr>
           %else
              <tr>
                  <td class="quickLinkTabs"><a href="#federal">Federal</a></td>
                  <td class="quickLinkTabs"><a href="#stateIncomeTax">State Income Tax</a></td>
                  <td class="quickLinkTabs"><a href="#stateUnemploymentInsurance">State Unemployment Insurance</a></td>
                  <td class="quickLinkTabs"><a href="#stateWorkersComp">State Worker's Compensation</a></td>
              </tr>
              <tr>
                  <td class="quickLinkTabs"><a href="#stateDisabilityInsurance">State Disability Insurance</a></td>
                  <td class="quickLinkTabs"><a href="#localTax">Local Tax</a></td>
                  <td class="quickLinkTabs"><a href="#taxReporting">Tax Reporting</a></td>
              </tr>
           %endif
              <tr><td>&nbsp;</td></tr>
      </table>



      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"		

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          %if (prEmployee == "99999")
              @dtw_assign(reqFieldChar, "")
          %endif
          %ROW {

              %if (errFound != "")
                  @dtw_assign(focusField, "")
                  @EdtVarErr(profileHandle, typeValue, edtVar)
                  @ErrVarErr(profileHandle, typeError, errVar)

                  @DecatErr_Field("@@acct", "wageExpAcct")        @dtw_assign(Err_ERACCT, fieldValue)
                  @DecatErr_Field("@@sact", "wageExpSub")         @dtw_assign(Err_ERSACT, fieldValue)
                  @DecatErr_Field("@@xfit", "fitExempt")          @dtw_assign(Err_ERXFIT, fieldValue)
                  @DecatErr_Field("@@xfic", "ficaExempt")         @dtw_assign(Err_ERXFIC, fieldValue)
                  @DecatErr_Field("@@exsu", "fuiExempt")          @dtw_assign(Err_EREXSU, fieldValue)
                  @DecatErr_Field("@@fwhs", "fitWhStatus")        @dtw_assign(Err_ERFWHS, fieldValue)
                  @DecatErr_Field("@@dfdp", "fitDependents")      @dtw_assign(Err_ERDFDP, fieldValue)
                  @DecatErr_Field("@@fdap", "fitAddPercent")      @dtw_assign(Err_ERFDAP, fieldValue)
                  @DecatErr_Field("@@fdaa", "fitAddAmount")       @dtw_assign(Err_ERFDAA, fieldValue)
                  @DecatErr_Field("@@cftp", "fitCommRate")        @dtw_assign(Err_ERCFTP, fieldValue)
                  @DecatErr_Field("@@bftp", "fitBonusRate")       @dtw_assign(Err_ERBFTP, fieldValue)
                  @DecatErr_Field("@@eic@", "earnedIncomeCr")     @dtw_assign(Err_EREIC, fieldValue)
                  @DecatErr_Field("@@gwgs", "guaranteedAmount")   @dtw_assign(Err_ERGWGS, fieldValue)
                  @DecatErr_Field("@@gpct", "guaranteedPercent")  @dtw_assign(Err_ERGPCT, fieldValue)
                  @DecatErr_Field("@@w420", "w42020")             @dtw_assign(Err_RXW420, fieldValue)
                  @DecatErr_Field("@@stp2", "w42020Step2")        @dtw_assign(Err_RXSTP2, fieldValue)
                  @DecatErr_Field("@@cdam", "w4ClaimDependentsAmount")  @dtw_assign(Err_RXCDAM, fieldValue)
                  @DecatErr_Field("@@othi", "w4OtherIncomeAmount")      @dtw_assign(Err_RXOTHI, fieldValue)
                  @DecatErr_Field("@@ded@",  "w4DeductionsAmount")      @dtw_assign(Err_RXDED, fieldValue)
                  

                  @DecatErr_Field("@@exst", "sitExempt")          @dtw_assign(Err_EREXST, fieldValue)
                  @DecatErr_Field("@@stid", "sitId")              @dtw_assign(Err_ERSTID, fieldValue)
                  @DecatErr_Field("@@sdc@", "stdDedCat")          @dtw_assign(Err_ERSDC, fieldValue)
                  @DecatErr_Field("@@stdp", "sitDependents")      @dtw_assign(Err_ERSTDP, fieldValue)
                  @DecatErr_Field("@@pec@", "persExCat")          @dtw_assign(Err_ERPEC, fieldValue)
                  @DecatErr_Field("@@aec@", "addlExCat")          @dtw_assign(Err_ERAEC, fieldValue)
                  @DecatErr_Field("@@exam", "exemptAmount")       @dtw_assign(Err_EREXAM, fieldValue)
                  @DecatErr_Field("@@taxc", "sitWhCat")           @dtw_assign(Err_ERTAXC, fieldValue)
                  @DecatErr_Field("@@crc@", "taxCreditCat")       @dtw_assign(Err_ERCRC, fieldValue)
                  @DecatErr_Field("@@adc@", "addlCredits")        @dtw_assign(Err_ERADC, fieldValue)
                  @DecatErr_Field("@@stap", "sitAddPercent")      @dtw_assign(Err_ERSTAP, fieldValue)
                  @DecatErr_Field("@@staa", "sitAddAmount")       @dtw_assign(Err_ERSTAA, fieldValue)
                  @DecatErr_Field("@@cstp", "sitCommRate")        @dtw_assign(Err_ERCSTP, fieldValue)
                  @DecatErr_Field("@@bstp", "sitBonusRate")       @dtw_assign(Err_ERBSTP, fieldValue)

                  @DecatErr_Field("@@suid", "suiId")              @dtw_assign(Err_ERSUID, fieldValue)

                  @DecatErr_Field("@@exwc", "swcExempt")          @dtw_assign(Err_EREXWC, fieldValue)
                  @DecatErr_Field("@@swid", "swcId")              @dtw_assign(Err_ERSWID, fieldValue)
                  @DecatErr_Field("@@jbcl", "jobClass")           @dtw_assign(Err_ERJBCL, fieldValue)

                  @DecatErr_Field("@@sdid", "sdiId")              @dtw_assign(Err_ERSDID, fieldValue)

                  @DecatErr_Field("@@loc1", "loc1Id")             @dtw_assign(Err_ERLOC1, fieldValue)
                  @DecatErr_Field("@@ldp1", "loc1Dep ")           @dtw_assign(Err_ERLDP1, fieldValue)
                  @DecatErr_Field("@@lpe1", "loc1PersExempt ")    @dtw_assign(Err_RXLPE1, fieldValue)
                  @DecatErr_Field("@@loc2", "loc2Id")             @dtw_assign(Err_ERLOC2, fieldValue)
                  @DecatErr_Field("@@ldp2", "loc2Dep ")           @dtw_assign(Err_ERLDP2, fieldValue)
                  @DecatErr_Field("@@lpe2", "loc2PersExempt ")    @dtw_assign(Err_RXLPE2, fieldValue)
                  @DecatErr_Field("@@eres", "empResId ")          @dtw_assign(Err_RXERES, fieldValue)
                  
                  @DecatErr_Field("@@pen@", "qualPension")        @dtw_assign(Err_ERPEN, fieldValue)
                  @DecatErr_Field("@@type", "employmentType")     @dtw_assign(Err_ERTYPE, fieldValue)
                  @DecatErr_Field("@@inds", "occIndCode")         @dtw_assign(Err_ERINDS, fieldValue)
                  @DecatErr_Field("@@opcd", "areaClass")          @dtw_assign(Err_EROPCD, fieldValue)
                  @DecatErr_Field("@@nqpc", "nonQualPlan")        @dtw_assign(Err_ERNQPC, fieldValue)
                  @DecatErr_Field("@@stem", "statutoryEmpl")      @dtw_assign(Err_ERSTEM, fieldValue)
                  @DecatErr_Field("@@lgrp", "legalRep")           @dtw_assign(Err_ERLGRP, fieldValue)
                  @DecatErr_Field("@@pbcd", "probationCode")      @dtw_assign(Err_ERPBCD, fieldValue)
                  @DecatErr_Field("@@pbdt", "probationDate")      @dtw_assign(Err_ERPBDT, fieldValue)
                  @DecatErr_Field("@@cnty", "countyCode")         @dtw_assign(Err_ERCNTY, fieldValue)
                  @DecatErr_Field("@@ehlt", "emplHealthCode")     @dtw_assign(Err_EREHLT, fieldValue)
                  @DecatErr_Field("@@rhlt", "employerHealthCode") @dtw_assign(Err_ERRHLT, fieldValue)
                  @DecatErr_Field("@@wgpc", "wagePlanCode")       @dtw_assign(Err_ERWGPC, fieldValue)
                  @DecatErr_Field("@@seas", "seasonalInd")        @dtw_assign(Err_ERSEAS, fieldValue)
                  @DecatErr_Field("@@unit", "unitDivLocPlant")    @dtw_assign(Err_ERUNIT, fieldValue)
                  @DecatErr_Field("@@dcdt", "dateDeceased")       @dtw_assign(Err_ERDCDT, fieldValue)
                  @DecatErr_Field("@@tstp", "timeStamp")          @dtw_assign(Err_TSTP, fieldValue)

                  @Decat_Field("@@acct")    @dtw_assign(V_ERACCT, fieldValue)
                  @Decat_Field("@@sact")    @dtw_assign(V_ERSACT, fieldValue)
                  @Decat_Field("@@xfit")    @dtw_assign(V_ERXFIT, fieldValue)
                  @Decat_Field("@@xfic")    @dtw_assign(V_ERXFIC, fieldValue)
                  @Decat_Field("@@exsu")    @dtw_assign(V_EREXSU, fieldValue)
                  @Decat_Field("@@fwhs")    @dtw_assign(V_ERFWHS, fieldValue)
                  @Decat_Field("@@dfdp")    @dtw_assign(V_ERDFDP, fieldValue)
                  @Decat_Field("@@fdap")    @dtw_assign(V_ERFDAP, fieldValue)
                  @Decat_Field("@@fdaa")    @dtw_assign(V_ERFDAA, fieldValue)
                  @Decat_Field("@@cftp")    @dtw_assign(V_ERCFTP, fieldValue)
                  @Decat_Field("@@bftp")    @dtw_assign(V_ERBFTP, fieldValue)
                  @Decat_Field("@@eic@")    @dtw_assign(V_EREIC, fieldValue)
                  @Decat_Field("@@gwgs")    @dtw_assign(V_ERGWGS, fieldValue)
                  @Decat_Field("@@gpct")    @dtw_assign(V_ERGPCT, fieldValue)
                  @Decat_Field("@@w420")    @dtw_assign(V_RXW420, fieldValue)
                  @Decat_Field("@@stp2")    @dtw_assign(V_RXSTP2, fieldValue)
                  @Decat_Field("@@cdam")    @dtw_assign(V_RXCDAM, fieldValue)
                  @Decat_Field("@@othi")    @dtw_assign(V_RXOTHI, fieldValue)
                  @Decat_Field("@@ded@")    @dtw_assign(V_RXDED, fieldValue)
                  

                  @Decat_Field("@@exst")    @dtw_assign(V_EREXST, fieldValue)
                  @Decat_Field("@@stid")    @dtw_assign(V_ERSTID, fieldValue)
                  @Decat_Field("@@sdc@")    @dtw_assign(V_ERSDC, fieldValue)
                  @Decat_Field("@@stdp")    @dtw_assign(V_ERSTDP, fieldValue)
                  @Decat_Field("@@pec@")    @dtw_assign(V_ERPEC, fieldValue)
                  @Decat_Field("@@aec@")    @dtw_assign(V_ERAEC, fieldValue)
                  @Decat_Field("@@exam")    @dtw_assign(V_EREXAM, fieldValue)
                  @Decat_Field("@@taxc")    @dtw_assign(V_ERTAXC, fieldValue)
                  @Decat_Field("@@crc@")    @dtw_assign(V_ERCRC, fieldValue)
                  @Decat_Field("@@adc@")    @dtw_assign(V_ERADC, fieldValue)
                  @Decat_Field("@@stap")    @dtw_assign(V_ERSTAP, fieldValue)
                  @Decat_Field("@@staa")    @dtw_assign(V_ERSTAA, fieldValue)
                  @Decat_Field("@@cstp")    @dtw_assign(V_ERCSTP, fieldValue)
                  @Decat_Field("@@bstp")    @dtw_assign(V_ERBSTP, fieldValue)

                  @Decat_Field("@@suid")    @dtw_assign(V_ERSUID, fieldValue)

                  @Decat_Field("@@exwc")    @dtw_assign(V_EREXWC, fieldValue)
                  @Decat_Field("@@swid")    @dtw_assign(V_ERSWID, fieldValue)
                  @Decat_Field("@@jbcl")    @dtw_assign(V_ERJBCL, fieldValue)

                  @Decat_Field("@@sdid")    @dtw_assign(V_ERSDID, fieldValue)

                  @Decat_Field("@@loc1")    @dtw_assign(V_ERLOC1, fieldValue)
                  @Decat_Field("@@ldp1")    @dtw_assign(V_ERLDP1, fieldValue)
                  @Decat_Field("@@lpe1")    @dtw_assign(V_RXLPE1, fieldValue)
                  @Decat_Field("@@loc2")    @dtw_assign(V_ERLOC2, fieldValue)
                  @Decat_Field("@@ldp2")    @dtw_assign(V_ERLDP2, fieldValue)
                  @Decat_Field("@@lpe2")    @dtw_assign(V_RXLPE2, fieldValue)
                  @Decat_Field("@@eres")    @dtw_assign(V_RXERES, fieldValue)

                  @Decat_Field("@@pen@")    @dtw_assign(V_ERPEN, fieldValue)
                  @Decat_Field("@@type")    @dtw_assign(V_ERTYPE, fieldValue)
                  @Decat_Field("@@inds")    @dtw_assign(V_ERINDS, fieldValue)
                  @Decat_Field("@@opcd")    @dtw_assign(V_EROPCD, fieldValue)
                  @Decat_Field("@@nqpc")    @dtw_assign(V_ERNQPC, fieldValue)
                  @Decat_Field("@@stem")    @dtw_assign(V_ERSTEM, fieldValue)
                  @Decat_Field("@@lgrp")    @dtw_assign(V_ERLGRP, fieldValue)
                  @Decat_Field("@@pbcd")    @dtw_assign(V_ERPBCD, fieldValue)
                  @Decat_Field("@@pbdt")    @dtw_assign(V_ERPBDT, fieldValue)
                  @Decat_Field("@@cnty")    @dtw_assign(V_ERCNTY, fieldValue)
                  @Decat_Field("@@ehlt")    @dtw_assign(V_EREHLT, fieldValue)
                  @Decat_Field("@@rhlt")    @dtw_assign(V_ERRHLT, fieldValue)
                  @Decat_Field("@@wgpc")    @dtw_assign(V_ERWGPC, fieldValue)
                  @Decat_Field("@@seas")    @dtw_assign(V_ERSEAS, fieldValue)
                  @Decat_Field("@@unit")    @dtw_assign(V_ERUNIT, fieldValue)
                  @Decat_Field("@@dcdt")    @dtw_assign(V_ERDCDT, fieldValue)
                  @Decat_Field("@@tstp")    @dtw_assign(V_ERTSTP, fieldValue)

                  @dtw_assign(errFound, "")

              %else
                  @dtw_assign(focusField, "wageExpAcct")
                  @DateInputFromCYMD(V_ERPBDT)
                  @DateInputFromCYMD(V_ERDCDT)
              %endif

              <a name="federal"></a>
              <fieldset class="legendBody">
                  <legend class="legendTitle">Federal</legend>
                  <div class="quickLinksTop">
                      <a href="#top">$(topOfFormImage)</a>
                  </div>
                  <table $(contentTable)>
                  
                      @SetTextOvr(Err_TSTP)
                      <tr><td class="dsphdr"><span $(textOvr)>.</span></td>
                          <td><input name="timeStamp" type="hidden" value="$(V_ERTSTP)"></td>
                      </tr>
                      @DspErrMsg(Err_TSTP)
                  
                      @Default_Zero(V_ERACCT)
                      @Default_Zero(V_ERSACT)
                      @RtvFldDesc("CHACCT=$(V_ERACCT) and CHSUB=$(V_ERSACT) ", "HDCHRT", "CHCHDS", acctDesc)
                      @SetTextOvr(Err_ERACCT)
                      <tr><td class="dsphdr"><span $(textOvr)>G/L Wages Expense Account</span></td>
                          <td class="inputnmbr"><input name="wageExpAcct" value="$(V_ERACCT)" type="text" size="4" maxlength="4"> - <input name="wageExpSub" value="$(V_ERSACT)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=wageExpAcct&amp;subFld=wageExpSub&amp;descFld=wageAcctDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="wageAcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_ERACCT)

                      @SetTextOvr(Err_ERXFIT)
                      <tr><td class="dsphdr"><span $(textOvr)>Exempt From Federal Income Tax</span></td>
                          @dtw_tb_rows(fitExemptTable, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(fitExemptTable, x, "1") != V_ERXFIT) && (x < maxRows))
                              {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(fitExemptTable, "fitExempt", "2", "1", "N", "", x, "1")  $(reqFieldChar)</td>
                      </tr>
                      @DspErrMsg(Err_ERXFIT)

                      @SetTextOvr(Err_ERXFIC)
                      <tr><td class="dsphdr"><span $(textOvr)>Exempt From FICA</span></td>
                          @dtw_tb_rows(yn01Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_ERXFIC) && (x < maxRows))
                              {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(yn01Table, "ficaExempt", "2", "1", "N", "", x, "1")  $(reqFieldChar)</td>
                      </tr>
                      @DspErrMsg(Err_ERXFIC)

                      @SetTextOvr(Err_EREXSU)
                      <tr><td class="dsphdr"><span $(textOvr)>Exempt From FUI/SUI</span></td>
                          @dtw_tb_rows(yn02Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn02Table, x, "1") != V_EREXSU) && (x < maxRows))
                              {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(yn02Table, "fuiExempt", "2", "1", "N", "", x, "1")</td>
