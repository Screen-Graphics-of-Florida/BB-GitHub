                      @SetTextOvr(Err_ERPBDT)
    	               <tr><td class="dsphdr"><span $(textOvr)>Probationary Date</span></td>
                          <td class="inputnmbr"><input type="text" name="probationDate" value="$(V_ERPBDT)" size="6" maxlength="6"> 		
                              <a href="javascript:calWindow('probationDate');"> $(calendarImage)</a></td>
                      </tr>
                      @DspErrMsg(Err_ERPBDT)

                      @SetTextOvr(Err_ERCNTY)
                      <tr><td class="dsphdr"><span $(textOvr)>County Code</span></td>
                          <td class="inputnmbr"><input name="countyCode" type="text" value="$(V_ERCNTY)" size="3" maxlength="3"> </td>
                      </tr>
                      @DspErrMsg(Err_ERCNTY)

                      @SetTextOvr(Err_EREHLT)
                      <tr><td class="dsphdr"><span $(textOvr)>Employee Health Insurance Code</span></td>
                          <td class="inputnmbr"><input name="emplHealthCode" type="text" value="$(V_EREHLT)" size="1" maxlength="1"> </td>
                      </tr>
                      @DspErrMsg(Err_EREHLT)

                      @SetTextOvr(Err_ERRHLT)
                      <tr><td class="dsphdr"><span $(textOvr)>Employer Health Insurance Code</span></td>
                          <td class="inputnmbr"><input name="employerHealthCode" type="text" value="$(V_ERRHLT)" size="1" maxlength="1"> </td>
                      </tr>
                      @DspErrMsg(Err_ERRHLT)

                      @SetTextOvr(Err_ERWGPC)
                      <tr><td class="dsphdr"><span $(textOvr)>Wage Plan Code</span></td>
                          <td class="inputalph"><input name="wagePlanCode" type="text" value="$(V_ERWGPC)" size="1" maxlength="1"> </td>
                      </tr>
                      @DspErrMsg(Err_ERWGPC)

                      @SetTextOvr(Err_ERSEAS)
                      <tr><td class="dsphdr"><span $(textOvr)>Seasonal Indicator</span></td>
                          <td class="inputalph"><input name="seasonalInd" type="text" value="$(V_ERSEAS)" size="2" maxlength="2"> </td>
                      </tr>
                      @DspErrMsg(Err_ERSEAS)

                      @SetTextOvr(Err_ERUNIT)
                      <tr><td class="dsphdr"><span $(textOvr)>Unit/Div/Loc/Plant</span></td>
                          <td class="inputalph"><input name="unitDivLocPlant" type="text" value="$(V_ERUNIT)" size="15" maxlength="15"> </td>
                      </tr>
                      @DspErrMsg(Err_ERUNIT)

                      @SetTextOvr(Err_ERDCDT)
    	               <tr><td class="dsphdr"><span $(textOvr)>Date Deceased</span></td>
                          <td class="inputnmbr"><input type="text" name="dateDeceased" value="$(V_ERDCDT)" size="6" maxlength="6"> 		
                              <a href="javascript:calWindow('dateDeceased');"> $(calendarImage)</a></td>
                      </tr>
                      @DspErrMsg(Err_ERDCDT)
                  </table>
              </fieldset>
              
          %}
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>

      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHREMT_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMTYPE", PAYTYPECODE)
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if ((sec_02 == "N") || (sec_11 == "N"))
      %INCLUDE "ProgSecurityError.icl"
  %else
      @eic_Query(profileHandle, dataBaseID, "EIC       ", eicTable)
          @dtw_tb_insertrow(eicTable, "0", "1")
	   @dtw_tb_setv(eicTable, "", "1", "2")
      @employmentType_Query(profileHandle, dataBaseID, "EMPLOYMENT", employmentTypeTable)
          @dtw_tb_insertrow(employementTypeTable, "0", "1")
	   @dtw_tb_setv(employementTypeTable, "", "1", "2")
      @fitExempt_Query(profileHandle, dataBaseID, "TAXEXEMPT ", fitExemptTable)
          @dtw_tb_insertrow(fitExemptTable, "0", "1")
	   @dtw_tb_setv(fitExemptTable, "", "1", "2")
      @federal_Wh_Query(profileHandle, dataBaseID, "FEDERALWH ", federalWhTable)
          @dtw_tb_insertrow(federalWhTable, "0", "1")
	   @dtw_tb_setv(federalWhTable, "", "1", "2")
      @sitExempt_Query(profileHandle, dataBaseID, "TAXEXEMPT ", sitExemptTable)
          @dtw_tb_insertrow(sitExemptTable, "0", "1")
	   @dtw_tb_setv(sitExemptTable, "", "1", "2")
      @sitWhCat_Query(profileHandle, dataBaseID, "STATEWHCAT", sitWhCatTable)
          @dtw_tb_insertrow(sitWhCatTable, "0", "1")
	   @dtw_tb_setv(sitWhCatTable, "0", "1", "1")
	   @dtw_tb_setv(sitWhCatTable, "", "1", "2")
      @statutory_Empl_Query(profileHandle, dataBaseID, "STATUTORY ", statutoryEmplTable)
      @stdDed_Query(profileHandle, dataBaseID, "STDDEDCAT ", stdDedTable)
          @dtw_tb_insertrow(stdDedTable, "0", "1")
	   @dtw_tb_setv(stdDedTable, "0", "1", "1")
	   @dtw_tb_setv(stdDedTable, "", "1", "2")
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
          @dtw_tb_insertrow(yn01Table, "0", "1")
	   @dtw_tb_setv(yn01Table, "", "1", "2")
      @yn02_Table_Query(profileHandle, dataBaseID, "YORN      ", yn02Table)
          @dtw_tb_insertrow(yn02Table, "0", "1")
	   @dtw_tb_setv(yn02Table, "", "1", "2")
      @yn03_Table_Query(profileHandle, dataBaseID, "YORN      ", yn03Table)
          @dtw_tb_insertrow(yn03Table, "0", "1")
	   @dtw_tb_setv(yn03Table, "", "1", "2")
      @yn04_Table_Query(profileHandle, dataBaseID, "YORN      ", yn04Table)
          @dtw_tb_insertrow(yn04Table, "0", "1")
	   @dtw_tb_setv(yn04Table, "", "1", "2")
      @yn05_Table_Query(profileHandle, dataBaseID, "YORN      ", yn05Table)
          @dtw_tb_insertrow(yn05Table, "0", "1")
	   @dtw_tb_setv(yn05Table, "", "1", "2")

      @dtw_assign(sec_03, "")
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(sitId)
  @dtw_mUPPERCASE(suiId)
  @dtw_mUPPERCASE(swcId)
  @dtw_mUPPERCASE(sdiId)
  @dtw_mUPPERCASE(loc1Id)
  @dtw_mUPPERCASE(loc2Id)
  @dtw_mUPPERCASE(empResId)
  @dtw_mUPPERCASE(areaClass)
  @dtw_mUPPERCASE(nonQualPlan)
  @dtw_mUPPERCASE(probationCode)
  @dtw_mUPPERCASE(wagePlanCode)
  @dtw_mUPPERCASE(seasonalInd)
  @dtw_mUPPERCASE(unitDivLocPlant)

  @dtw_assign(wageExpAcct,@dtw_rstrip(wageExpAcct))
  @dtw_assign(wageExpSub,@dtw_rstrip(wageExpSub))
  @dtw_assign(fitDependents,@dtw_rstrip(fitDependents))
  @dtw_assign(fitAddPercent,@dtw_rstrip(fitAddPercent))
  @dtw_assign(fitAddAmount,@dtw_rstrip(fitAddAmount))
  @dtw_assign(fitCommRate,@dtw_rstrip(fitCommRate))
  @dtw_assign(fitBonusRate,@dtw_rstrip(fitBonusRate))
  @dtw_assign(guaranteedAmount,@dtw_rstrip(guaranteedAmount))
  @dtw_assign(guaranteedPercent,@dtw_rstrip(guaranteedPercent))
  @dtw_assign(stdDedCat,@dtw_rstrip(stdDedCat))
  @dtw_assign(sitDependents,@dtw_rstrip(sitDependents))
  @dtw_assign(persExCat,@dtw_rstrip(persExCat))
  @dtw_assign(addlExCat,@dtw_rstrip(addlExCat))
  @dtw_assign(exemptAmount,@dtw_rstrip(exemptAmount))
  @dtw_assign(sitWhCat,@dtw_rstrip(sitWhCat))
  @dtw_assign(taxCreditCat,@dtw_rstrip(taxCreditCat))
  @dtw_assign(addlCredits,@dtw_rstrip(addlCredits))
  @dtw_assign(sitAddPercent,@dtw_rstrip(sitAddPercent))
  @dtw_assign(sitAddAmount,@dtw_rstrip(sitAddAmount))
  @dtw_assign(sitCommRate,@dtw_rstrip(sitCommRate))
  @dtw_assign(sitBonusRate,@dtw_rstrip(sitBonusRate))
  @dtw_assign(jobClass,@dtw_rstrip(jobClass))
  @dtw_assign(loc1Dep,@dtw_rstrip(loc1Dep))
  @dtw_assign(loc2Dep,@dtw_rstrip(loc2Dep))
  @dtw_assign(loc1PersExempt,@dtw_rstrip(loc1PersExempt))
  @dtw_assign(loc2PersExempt,@dtw_rstrip(loc2PersExempt))  
  @dtw_assign(occIndCode,@dtw_rstrip(occIndCode))
  @dtw_assign(probationDate,@dtw_rstrip(probationDate))
  @dtw_assign(countyCode,@dtw_rstrip(countyCode))
  @dtw_assign(emplHealthCode,@dtw_rstrip(emplHealthCode))
  @dtw_assign(employerHealthCode,@dtw_rstrip(employerHealthCode))
  @dtw_assign(dateDeceased,@dtw_rstrip(dateDeceased))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@comp", prCompany)
  @Concat_Field("@@facl", prFacility)
  @Concat_Field("@@empl", prEmployee)
  @Concat_Field("@@pecp", hrCompany)
  @Concat_Field("@@pemp", hrEmployee)

  @Concat_Field("@@acct", wageExpAcct)
  @Concat_Field("@@sact", wageExpSub)
  @Concat_Field("@@xfit", fitExempt)
  @Concat_Field("@@xfic", ficaExempt)
  @Concat_Field("@@exsu", fuiExempt)
  @Concat_Field("@@fwhs", fitWhStatus)
  @Concat_Field("@@dfdp", fitDependents)
  @Concat_Field("@@fdap", fitAddPercent)
  @Concat_Field("@@fdaa", fitAddAmount)
  @Concat_Field("@@cftp", fitCommRate)
  @Concat_Field("@@bftp", fitBonusRate)
  @Concat_Field("@@eic@", earnedIncomeCr)
  @Concat_Field("@@gwgs", guaranteedAmount)
  @Concat_Field("@@gpct", guaranteedPercent)
  @Concat_Field("@@w420", w42020)
  @Concat_Field("@@stp2", w42020Step2)
  @Concat_Field("@@othi", w4OtherIncomeAmount)
  @Concat_Field("@@cdam", w4ClaimDependentsAmount)
  @Concat_Field("@@ded@", w4DeductionsAmount)

  @Concat_Field("@@exst", sitExempt)
  @Concat_Field("@@stid", sitId)
  @Concat_Field("@@sdc@", stdDedCat)
  @Concat_Field("@@stdp", sitDependents)
  @Concat_Field("@@pec@", persExCat)
  @Concat_Field("@@aec@", addlExCat)
  @Concat_Field("@@exam", exemptAmount)
  @Concat_Field("@@taxc", sitWhCat)
  @Concat_Field("@@crc@", taxCreditCat)
  @Concat_Field("@@adc@", addlCredits)
  @Concat_Field("@@stap", sitAddPercent)
  @Concat_Field("@@staa", sitAddAmount)
  @Concat_Field("@@cstp", sitCommRate)
  @Concat_Field("@@bstp", sitBonusRate)

  @Concat_Field("@@suid", suiId)

  @Concat_Field("@@exwc", swcExempt)
  @Concat_Field("@@swid", swcId)
  @Concat_Field("@@jbcl", jobClass)

  @Concat_Field("@@sdid", sdiId)

  @Concat_Field("@@loc1", loc1Id)
  @Concat_Field("@@ldp1", loc1Dep)
  @Concat_Field("@@lpe1", loc1PersExempt)
  @Concat_Field("@@loc2", loc2Id)
  @Concat_Field("@@ldp2", loc2Dep)
  @Concat_Field("@@lpe2", loc2PersExempt)
  @Concat_Field("@@eres", empResId)

  @Concat_Field("@@pen@", qualPension)
  @Concat_Field("@@type", employmentType)
  @Concat_Field("@@inds", occIndCode)
  @Concat_Field("@@opcd", areaClass)
  @Concat_Field("@@nqpc", nonQualPlan)
  @Concat_Field("@@stem", statutoryEmpl)
  @Concat_Field("@@lgrp", legalRep)
  @Concat_Field("@@pbcd", probationCode)
  @Concat_Field("@@pbdt", probationDate)
  @Concat_Field("@@cnty", countyCode)
  @Concat_Field("@@ehlt", emplHealthCode)
  @Concat_Field("@@rhlt", employerHealthCode)
  @Concat_Field("@@wgpc", wagePlanCode)
  @Concat_Field("@@seas", seasonalInd)
  @Concat_Field("@@unit", unitDivLocPlant)
  @Concat_Field("@@dcdt", dateDeceased)
  @Concat_Field("@@tstp", timeStamp)

  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
      @Format_ConfMsg_Desc(maintenanceCode, $(F_EmpName), $(prEmployee), "Payroll Taxes", "", "", "", confMessage)
      %if (fromD2w != "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)EmployeeMaintainSelect.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}