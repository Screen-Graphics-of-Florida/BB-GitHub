%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Order Flags"
  d2wName                 = "OrderFLags.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;orderApplication=@dtw_rurlescseq(orderApplication)&amp;orderType=@dtw_rurlescseq(orderType)&amp;description=@dtw_rurlescseq(description)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HHDOFU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchFlag, 2, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "ORDERFLAGS")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select FGFGFG, FGFGDS, SUBSTR(FGFGOP,1,1) as FGFGOP01, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(FGFGDS) as FGFGDSU " , stmtSQL)
                      @dtw_concat(fileSQL, " HDORFG ", fileSQL)
                      @dtw_concat(selectSQL, "FGAPID='$(orderApplication)' and FGORTY='$(orderType)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @OrderFlags_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) OrderFlags_Query (IN CHAR(64) profileHandle,
                                       CHAR(2)   dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      <a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&tblID=156" title="Back Home">$(portalHome)</a>
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)OrderFlagsMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      <table $(contentTable)>
          @RtvFldDesc("AIAPID='$(orderApplication)'", "SYAPID", "AIAPDS", apidDesc)
          @Format_Header_URL("Application ID", $(apidDesc), "", "")
          @Format_Header_URL("Order Type", $(description), $(orderType), "")
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Description</th>
                      <th class="colhdr">Flag</th>
                  </tr>
                  <tr align=center>
                      <td><input type="text" class="inputalph" name="srchDesc" size="25" maxlength="23">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputnmbr" name="srchFlag" size="5" maxlength="2">
                          <input type="hidden" name="operFlag" value="=">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("FGFGFG", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Flag" title="Sequence By Flag">Flag</a></th>
              @OrderBy_Sort("FGFGDS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Description, Flag">Description</a></th>
              <th class="colhdr" colspan="2">Default</th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;flagNumber=@dtw_rurlescseq(V_FGFGFG)&amp;flagDesc=@dtw_rurlescseq(V_FGFGDS)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_FGFGDS), $(V_FGFGFG), "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)OrderFlagsMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)OrderFlagsMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colnmbr">$(V_FGFGFG)</td>
                  <td class="colalph">$(V_FGFGDS)</td>
                  @dtw_assign(flagNumber, V_FGFGFG)
                  %while(@dtw_rlength(flagNumber) != "2") {@dtw_insert("0", flagNumber, flagNumber)%}
                  @RtvFldDesc("FLTYPE='$(orderApplication)FLAG$(flagNumber)' AND FLVALU='$(V_FGFGOP01)'", "SYFLAG", "FLDESC", flag01Desc)
                  <td class="colalph">$(flag01Desc)</td>
                  @Format_Code(V_FGFGOP01, F_FGFGOP01)
                  <td class="colalph">$(F_FGFGOP01)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select FGFGFG, FGFGDS, SUBSTR(FGFGOP,1,1) as FGFGOP01, ", stmtSQL)
  @dtw_concat(stmtSQL, " upper(FGFGDS) as FGFGDSU " , stmtSQL)
  @dtw_concat(fileSQL, " HDORFG ", fileSQL)
  @dtw_concat(selectSQL, "FGAPID='$(orderApplication)' and FGORTY='$(orderType)' ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @OrderFlags_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) OrderFlags_XMLQuery (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @RtvFldDesc("AIAPID='$(orderApplication)'", "SYAPID", "AIAPDS", apidDesc)
      @XMLBeginTag("OrderFlagsList")
          @XMLIDTag(orderApplication, "ApplicationID ID")
              @XMLTag(orderApplication, "ApplicationID")
              @XMLTag(apidDesc, "ApplicationIDDesc")
          @XMLIDTag(orderType, "OrderType ID")
              @XMLTag(orderType, "OrderType")
              @XMLTag(description, "OrderTypeDesc")

          %ROW{
	       @XMLIDTag(V_FGFGFG, "Flag ID")
                  @XMLTag(V_FGFGFG, "Flag")
                  @XMLTag(V_FGFGDS, "Description")
                  @dtw_assign(flagNumber, V_FGFGFG)
                  %while(@dtw_rlength(flagNumber) != "2") {@dtw_insert("0", flagNumber, flagNumber)%}
                  @RtvFldDesc("FLTYPE='$(orderApplication)FLAG$(flagNumber)' AND FLVALU='$(V_FGFGOP01)'", "SYFLAG", "FLDESC", flag01Desc)
                  @XMLTag(flag01Desc, "Default")
              @XMLEndTag("Flag")
          %}
      @XMLEndTag("OrderType")
      @XMLEndTag("ApplicationID")
      @XMLEndTag("OrderFlagsList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "FGFGFG")
          @DTW_ASSIGN(orderByDisplay, "Flag")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Flag")
      %if (orderBy == "FGFGFG")
          @DTW_ASSIGN(orderBy, "FGFGFG DESC")
          @DTW_ASSIGN(orderByDisplay, "Flag (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FGFGFG")
          @DTW_ASSIGN(orderByDisplay, "Flag")
      %endif
  %elif (sequence == "Description")
      %if (orderBy == "FGFGDSU,FGFGFG")
          @DTW_ASSIGN(orderBy, "FGFGDSU DESC,FGFGFG")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Flag")
      %else
          @DTW_ASSIGN(orderBy, "FGFGDSU,FGFGFG")
          @DTW_ASSIGN(orderByDisplay, "Description, Flag")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("upper(FGFGDS)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("FGFGFG", "Flag", $(srchFlag), "", operFlag, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
