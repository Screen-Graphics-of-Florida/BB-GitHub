%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "ProgSecurity.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Table Link"
  d2wName                 = "TableLink.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;tblID=@dtw_rurlescseq(tblID)&amp;tableName=@dtw_rurlescseq(tableName)&amp;tableDesc=@dtw_rurlescseq(tableDesc)&amp;dftD2WName=@dtw_rurlescseq(dftD2WName)&amp;progOptName=@dtw_rurlescseq(progOptName)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HSYTBL_E"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "TABLEOPTION")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select SYTBLL.*, coalesce(FUDESC,' ') as FUDESC, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(FUDESCU,' ') as FUDESCU, coalesce(FUIMG,' ') as FUIMG ", stmtSQL)
                      @dtw_concat(fileSQL, " SYTBLL left join SYURLM on TLURLID=FUID", fileSQL)
                      @dtw_concat(selectSQL, "TLTBID=$(tblID) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Table_Link_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Table_Link_Query (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td ><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)TableLinkMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      <table $(contentTable)>
 	      @dtw_assign(customTable, "")
		  %if (tblID >= "5000")
			@dtw_assign(customTable, "Custom")
		  %endif
          @Format_Header_URL("Table", $(tableDesc), $(tableName), "$(homeURL)$(cGIPath)$(customTable)Table.d2w/REPORT$(genericVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))")
          @Format_Header("Maintenance Script Name", $(dftD2WName), "")
          @Format_Header("Security Program", $(progOptName), "")
      </table>

      %INCLUDE "ConfMessageDisplay.icl"
      $(hrTagAttr)

      %if (formatToPrint != "Y")
          %INCLUDE "AssignPageValue.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("TLTYPE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Type" title="Sequence By Type, Display Sequence">Type</a></th>
              @OrderBy_Sort("TLDSEQ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DSeq" title="Sequence By Display Sequence">Display<br>Sequence</a></th>
              @OrderBy_Sort("TLURLID", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=UrlID" title="Sequence By URL ID">URL ID</a></th>
              @OrderBy_Sort("FUDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description">Description</a></th>
              @OrderBy_Sort("TLD2WNU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Script" title="Sequence By Script Name, Type, Display Sequence">Script Name</a></th>
              @OrderBy_Sort("TLCNID", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Cond" title="Sequence By Condition ID">Cond<br>ID</a></th>
              @OrderBy_Sort("TLCOLN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Column" title="Sequence By Column Name, Condition Sequence">Column<br>Name</a></th>
              @OrderBy_Sort("TLCSEQ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CondSeq" title="Sequence By Condition Sequence">Cond<br>Seq</a></th>
              @OrderBy_Sort("TLPGOV", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Prog" title="Sequence By Override Program Option Program">Override Program<br>Option Program</a></th>
              @OrderBy_Sort("TLPOPT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PSeq" title="Sequence By Program Option Sequence, Type, Display Sequence">Program<br>Option<br>Sequence</a></th>
              <th class="colhdr">Image</th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;linkID=@dtw_rurlescseq(V_TLLKID)&amp;urlID=@dtw_rurlescseq(V_TLURLID)&amp;urlDesc=@dtw_rurlescseq(V_FUDESC)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_TLURLID), "", "", "", "", "", confirmDesc)
              @RtvFldDesc("FLTYPE='LINKTYPE' and FLVALU='$(V_TLTYPE)'", "SYFLAG", "FLDESC", typeDesc)
              @dtw_assign(condDesc, "")
              %if (V_TLCNID != "")
                  @RtvFldDesc("CCCNID='$(V_TLCNID)'", "SYTBCC", "CCDESC", condDesc)
              %endif

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)TableLinkMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)TableLinkMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)TableLinkMaintain.d2w/Edit_Data$(maintainVar)&amp;urlID=@dtw_rurlescseq(V_TLURLID)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                          %if (V_TLTYPE == "D" || V_TLTYPE == "C")
                              <a href="$(homeURL)$(cGIPath)TableLinkParmMaintain.d2w/REFRESH$(maintainVar)&amp;detailLink=Y">$(tableLinkParm)</a>
                          %else
                              <a href="$(homeURL)$(cGIPath)TableLinkParmMaintain.d2w/REFRESH$(maintainVar)">$(tableLinkParm)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">
                      %if (V_TLTYPE == "D" || V_TLTYPE == "C")
                          <a href="$(homeURL)$(cGIPath)TableLinkParmMaintain.d2w/REFRESH$(d2wVarBase)&amp;linkID=0&amp;detailLink=Y" title="Click here to maintain parameters for all detail options">$(typeDesc)</a>
                      %else
                          $(typeDesc)
                      %endif
                  </td>
                  <td class="colnmbr">$(V_TLDSEQ)</td>
                  <td class="colalph">$(V_TLURLID)</td>
                  <td class="colalph">$(V_FUDESC)</td>
                  <td class="colalph">$(V_TLD2WN)</td>
                  <td class="colalph" $(helpCursor)><span title="$(condDesc)">$(V_TLCNID)</span></td>
                  <td class="colalph">$(V_TLCOLN)</td>
                  <td class="colnmbr">$(V_TLCSEQ)</td>
                  <td class="colcode">$(V_TLPGOV)</td>
                  <td class="colcode">$(V_TLPOPT)</td>
                  <td class="colcode">
                      %if (V_TLIMG != "")
                          $($(V_TLIMG))
                      %else
                          $($(V_FUIMG))
                      %endif
                  </td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "TLTYPE,TLDSEQ")
          @DTW_ASSIGN(orderByDisplay, "Type, Display Sequence")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Type")
      %if (orderBy == "TLTYPE,TLDSEQ")
          @DTW_ASSIGN(orderBy, "TLTYPE DESC,TLDSEQ")
          @DTW_ASSIGN(orderByDisplay, "Type (descending), Display Sequence")
      %else
          @DTW_ASSIGN(orderBy, "TLTYPE,TLDSEQ")
          @DTW_ASSIGN(orderByDisplay, "Type, Display Sequence")
      %endif
  %elif (sequence == "DSeq")
      %if (orderBy == "TLDSEQ")
          @DTW_ASSIGN(orderBy, "TLDSEQ DESC")
          @DTW_ASSIGN(orderByDisplay, "Display Sequence (descending)")
      %else
          @DTW_ASSIGN(orderBy, "TLDSEQ")
          @DTW_ASSIGN(orderByDisplay, "Display Sequence")
      %endif
  %elif (sequence == "UrlID")
      %if (orderBy == "TLURLID")
          @DTW_ASSIGN(orderBy, "TLURLID DESC")
          @DTW_ASSIGN(orderByDisplay, "URL ID (descending)")
      %else
          @DTW_ASSIGN(orderBy, "TLURLID")
          @DTW_ASSIGN(orderByDisplay, "URL ID")
      %endif
  %elif (sequence == "Desc")
      %if (orderBy == "FUDESCU")
          @DTW_ASSIGN(orderBy, "FUDESCU DESC")
          @DTW_ASSIGN(orderByDisplay, "Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FUDESCU")
          @DTW_ASSIGN(orderByDisplay, "Description")
      %endif
  %elif (sequence == "Script")
      %if (orderBy == "TLD2WN,TLTYPE,TLDSEQ")
          @DTW_ASSIGN(orderBy, "TLD2WN DESC,TLTYPE,TLDSEQ")
          @DTW_ASSIGN(orderByDisplay, "Script Name (descending), Type, Display Sequence")
      %else
          @DTW_ASSIGN(orderBy, "TLD2WN,TLTYPE,TLDSEQ")
          @DTW_ASSIGN(orderByDisplay, "Script Name, Type, Display Sequence")
      %endif
  %elif (sequence == "Prog")
      %if (orderBy == "TLPGOV")
          @DTW_ASSIGN(orderBy, "TLPGOV DESC")
          @DTW_ASSIGN(orderByDisplay, "Override Program Option Program (descending)")
      %else
          @DTW_ASSIGN(orderBy, "TLPGOV")
          @DTW_ASSIGN(orderByDisplay, "Override Program Option Program")
      %endif
  %elif (sequence == "PSeq")
      %if (orderBy == "TLPOPT,TLTYPE,TLDSEQ")
          @DTW_ASSIGN(orderBy, "TLPOPT DESC,TLTYPE,TLDSEQ")
          @DTW_ASSIGN(orderByDisplay, "Program Option Sequence (descending), Type, Display Sequence")
      %else
          @DTW_ASSIGN(orderBy, "TLPOPT,TLTYPE,TLDSEQ")
          @DTW_ASSIGN(orderByDisplay, "Program Option Sequence, Type, Display Sequence")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
