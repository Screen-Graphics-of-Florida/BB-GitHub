%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"

%Define {	
  page_title              = "$(buyerAnalyst) Inquiry"
  d2wName                 = "BuyerInquiry.d2w"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName      	    = ""
%}
	
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onLoad="window.focus()" onBlur="window.close()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->

          %INCLUDE "PageTitle.icl"
          $(inquiryhrTagAttr)

          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " HDBUYR ", fileSQL)
                      @dtw_concat(selectSQL, "BMBUYR=$(buyerNumber)", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By BMBUYR ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Buyer_Inquiry(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>

          $(inquiryhrTagAttr)
          %INCLUDE "Copyright.icl"

          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) Buyer_Inquiry (IN CHAR(64)    profileHandle,
                                     CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          %ROW{
              <tr><td class="dspalph">$(V_BMBNA1)</td>
                  <td class="dsphdr">Buyer Number</td>
                  <td class="dspnmbr">$(V_BMBUYR)</td>
              </tr>
          %}
      </table>
  %}
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}
