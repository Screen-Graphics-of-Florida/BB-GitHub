%INCLUDE "$(baseVar)"
%INCLUDE "EdtVar.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Pricing Inquiry Overrides"
  d2wName                 = "PricingInquiryEntry.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;itemDescription=@dtw_rurlescseq(itemDescription)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;productClass=@dtw_rurlescseq(productClass)&amp;origQuantity=@dtw_rurlescseq(origQuantity)&amp;overridePrice=@dtw_rurlescseq(overridePrice)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
%}

%MACRO_FUNCTION Pricing_Inquiry_Entry () {	
  <html>
      <head>
          %INCLUDE "headcmt.icl"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "numedit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              function checkEnterChg() {
                document.onkeyup = function(e){
                   var k = (e) ? e.which:event.keyCode;
                   if (k == 13)
                       check(document.Chg);
                }
              }

              function check(chgForm) {
                  if (validate(chgForm))
                      chgForm.submit();
                      self.close();
              }
              function validate(chgForm) {
                  if (editNum(document.Chg.quantity, 9, 4) &&
                      editdate(document.Chg.orderDate))
                      return true;
              }
          </script>
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  <td class="toolbar">
                      <a href="javascript:check(document.Chg)">$(selectAcceptImage )</a>
                      %INCLUDE "CloseWindow.icl"
                     @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
                  </td>
              </tr>
          </table>
          $(hrTagAttr)
              <form class="formClass" METHOD=POST NAME="Chg" TARGET="PricingInquiry" ACTION="$(homeURL)$(cGIPath)PricingInquiry.d2w/REPORT$(d2wVarBase)">
                  <table $(contentTable)>
                      <tr><td class="dsphdr">Quantity</td>
                          <td class="inputnmbr"><input type="text" name="quantity" value="$(fromQuantity)" size="15" maxlength="15"></td>
                      </tr>
                      <tr><td class="dsphdr">Date</td>
                          <td class="inputnmbr"><input type="text" name="orderDate" value="$(fromOrderDate)" size="6" maxlength="6"><a href="javascript:calWindow('orderDate');">$(calendarImage)</a></td>
                      </tr>
                  </table>
              </form>
            
          
          <a href="javascript:check(document.Chg)">$(selectAcceptImage )</a>
          %INCLUDE "CloseWindow.icl"
           @dtw_assign(medIcon, "Y")
           %INCLUDE "HelpPage.icl"
           $(hrTagAttr)
          %INCLUDE "Copyright.icl"
      </body>
  </html>
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Pricing_Inquiry_Entry ()
%}

%HTML(ACCEPT) {
  <script TYPE="text/javascript">
      opener.location.href='$(homeURL)$(cGIPath)PricingInquiry.d2w/REPORT$(d2wVarBase)&amp;quantity=@dtw_rurlescseq(quantity)&amp;orderDate=@dtw_rurlescseq(orderDate)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))';
      window.close();
  </script>
%}