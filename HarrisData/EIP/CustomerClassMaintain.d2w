%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Customer Class Maintenance"
  d2wName                 = "CustomerClassMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;classCode=@dtw_rurlescseq(classCode)&amp;classCodeDesc=@dtw_rurlescseq(classCodeDesc)&amp;maintenanceCode=D"
  programName             = "HHDCLU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.classCode.value =="" ||
                      document.Chg.classCodeDesc.value =="")
                     {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.managementpriority, 2, 1))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
	       %INCLUDE "NumEdit.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CUSTOMERCLASSMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From HDCCLS Where CCCCLS = '$(classCode)'", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=105")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "classCode")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@ccls", "classCode")          @dtw_assign(Err_CCCCLS, fieldValue)
                          @DecatErr_Field("@@ccds", "classCodeDesc")      @dtw_assign(Err_CCCCDS, fieldValue)
                          @DecatErr_Field("@@alph", "alphaSequence")      @dtw_assign(Err_CCALPH, fieldValue)
                          @DecatErr_Field("@@mpty", "managementpriority") @dtw_assign(Err_CCMPTY, fieldValue)
                          @DecatErr_Field("@@orty", "dftOrderType")       @dtw_assign(Err_CCORTY, fieldValue)
                      %endif

                      @Decat_Field("@@ccls")   @dtw_assign(V_CCCCLS, fieldValue)
                      @Decat_Field("@@ccds")   @dtw_assign(V_CCCCDS, fieldValue)
                      @Decat_Field("@@alph")   @dtw_assign(V_CCALPH, fieldValue)
                      @Decat_Field("@@mpty")   @dtw_assign(V_CCMPTY, fieldValue)
                      @Decat_Field("@@orty")   @dtw_assign(V_CCORTY, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "classCode")
                      %endif
                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_CCCCLS, "")
                      @dtw_assign(focusField, "classCode")
                  %else
                      @dtw_assign(focusField, "classCodeDesc")
                  %endif

                  @SetTextOvr(Err_CCCCLS)
                  <tr><td class="dsphdr"><span $(textOvr)>Customer Class</span></td>
                         %if (maintenanceCode == "A" || maintenanceCode == "Z")
                             <td class="inputalph"><input name="classCode" type="text" value="$(V_CCCCLS)" size="2" maxlength="2"> $(reqFieldChar) </td>
                         %else
                             <td class="inputalph"><input name="classCode" type="hidden" value="$(V_CCCCLS)" size="2" maxlength="2">$(V_CCCCLS)</td>
                         %endif
                  </tr>
                  @DspErrMsg(Err_CCCCLS)

                  @SetTextOvr(Err_CCCCDS)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="classCodeDesc" type="text" value="$(V_CCCCDS)" size="20" maxlength="20"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_CCCCDS)
    			
                  @SetTextOvr(Err_CCALPH)
                  <tr><td class="dsphdr"><span $(textOvr)>Alpha Sequence</span></td>
                      <td class="inputalph"><input type="text" name="alphaSequence" value="$(V_CCALPH)" size="4" maxlength="4"></td>
                  </tr>
                  @DspErrMsg(Err_CCALPH)
	
                  @SetTextOvr(Err_CCMPTY)
                  <tr><td class="dsphdr"><span $(textOvr)>Management Priority</span></td>
                      <td class="inputnmbr"><input type="text" name="managementpriority" value="$(V_CCMPTY)" size="5" maxlength="5"></td>
                  </tr>
                  @DspErrMsg(Err_CCMPTY)

                  %if (V_HDOERL > "0")
                      @RtvFldDesc("OTAPID='OE' and OTOTCD='$(V_CCORTY)'", "HDOTYP", "OTDESC", fieldDesc)
                      @SetTextOvr(Err_CCORTY)
            	       <tr><td class="dsphdr"><span $(textOvr)>Default Order Type</span></td>
                          <td class="inputalph"><input name="dftOrderType" type="text" value="$(V_CCORTY)" size="5" maxlength="1"><a href="$(homeURL)$(cGIPath)OrderTypeSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=dftOrderType&amp;fldDesc=dftOrderTypeDesc&amp;appID=OE" onclick="$(searchWinVar)"> $(searchImage) </a><input name="dftOrderTypeDesc" type="text" value="$(fieldDesc)" size="35" disabled></td>
                      </tr>
                      @DspErrMsg(Err_CCORTY)
                  %endif
              %}
          </table>
	
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDCLU_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(classCode)
  @dtw_mUPPERCASE(alphaSequence)
  @dtw_mUPPERCASE(dftOrderType)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@ccls", classCode)
  @Concat_Field("@@ccds", classCodeDesc)
  @Concat_Field("@@alph", alphaSequence)
  @Concat_Field("@@mpty", managementpriority)
  @Concat_Field("@@orty", dftOrderType)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(classCodeDesc), $(classCode), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@ccls", "classCode")
          @Format_ConfMsg_Desc("", $(classCodeDesc), $(classCode), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=105&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;classCode=@dtw_rurlescseq(classCode)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
