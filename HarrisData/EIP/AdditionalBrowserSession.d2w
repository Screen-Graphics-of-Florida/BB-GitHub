%INCLUDE "$(baseVar)"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "ErrorMessage.icl"

%Define {
  page_title              = "Sign On"
  d2wName                 = "AdditionalBrowserSession.d2w"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "999"
  menuTable               = %table
  browser                 = ""
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr)>
          @dtw_assign(userProfile, "NewSession")
          @setLibl(profileHandle, dataBaseID, tokenError, userProfile)
          @retrieveUserRole(profileHandle, dataBaseID, userProfile, userCustomer, userVendor, userSalesman, userBadge, userCatalog, newsLink, profileName)
          @dtw_SetCookie("handle_cookie", "$(profileHandle)", "path=/")
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)welcome.d2w/WELCOME?newsLink=@dtw_rurlescseq(newsLink)&amp;profileName=@dtw_rurlescseq(profileName)&amp;demo=@dtw_rurlescseq(demo)&amp;baseVar=@dtw_rurlescseq(baseVar)">
      </body>
  </html>
%}