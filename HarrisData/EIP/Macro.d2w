%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "ProgSecurity.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Macros"
  d2wName                 = "Macro.d2w"
  d2wVarBase              = "$(genericVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HSYMCM_E"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  formatComment           = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "MACRO")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " SYMCRO ", fileSQL)
                      %if (selectMacroName!="")
                          @dtw_concat(selectSQL, "MMMCRO ='$(selectMacroName)'", selectSQL)
                      %elif (wildCardSearch!="")
                          @dtw_concat(selectSQL, "MMMCRO>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Macro_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Macro_Query (IN CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)MacroMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Macro Name</th>
                      <th class="colhdr">Description</th></tr>
                  <tr><td><input type="text" class="inputalph" name="srchName" size="20" maxlength="50">
                          <input type="hidden" name="operName" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchDesc" size="20" maxlength="50">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchName.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          %if (formatToPrint != "Y")
              <tr>
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("MMMCRO", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MacroName" title="Sequence By Macro Name">Macro Name</a></th>
                  @OrderBy_Sort("MMDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description, Macro Name">Description</a></th>
                  @OrderBy_Sort("MMINCLU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=InclName" title="Sequence By Include Name, Macro Name">Include Name</a></th>
                  @OrderBy_Sort("MMD2WUU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ScriptUsing" title="Sequence By Script Using Macro, Macro Name">Script Using Macro</a></th>
                  @OrderBy_Sort("MMRESV", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ResvRec" title="Sequence By Reserved Row, Macro Name">Reserved Row</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
          %endif

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;macroName=@dtw_rurlescseq(V_MMMCRO)&amp;macroNameDesc=@dtw_rurlescseq(V_MMDESC)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_MMDESC), $(V_MMMCRO), "", "", "", "", confirmDesc)
              %if (formatToPrint != "Y")
                  <tr class="$(rowClass)">
                      %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                          <td class="opticon">
                              %if (sec_02 == "Y" || sec_03 == "Y")
                                  <a href="$(homeURL)$(cGIPath)MacroMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                              %endif
                              %if (sec_01=="Y" && sec_04=="Y")
                                  <a href="$(homeURL)$(cGIPath)MacroMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                              %endif
                              %if (sec_03 == "Y")
                                  <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)MacroMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                              %endif
                          </td>
                      %endif
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;formatToPrint=Y&amp;selectMacroName=@dtw_rurlescseq(V_MMMCRO)" onclick="$(inquiryWinVar)" title="View Macro">$(V_MMMCRO)</a></td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;formatToPrint=Y&amp;selectMacroName=@dtw_rurlescseq(V_MMMCRO)" onclick="$(inquiryWinVar)" title="View Macro">$(V_MMDESC)</a></td>
                      <td class="colalph">$(V_MMINCL)</td>
                      <td class="colalph">$(V_MMD2WU)</td>
                      <td class="colcode">$(V_MMRESV)</td>
                  </tr>
              %else
                  <tr>
                      <td colspan="3" align="center"><h1>$(V_MMMCRO)</h1></td>
                  </tr>
                  <tr>
                      <td class="dsphdr">Descrition</td>
                      <td class="colalph">$(V_MMDESC)</td>
                  </tr>
                  %if (V_MMINCL != "")
                      <tr>
                          <td class="dsphdr">Include Name</td>
                          <td class="colalph">$(V_MMINCL)</td>
                      </tr>
                  %endif
                  %if (V_MMD2WU != "")
                      <tr>
                          <td class="dsphdr">Script Using Macro</td>
                          <td class="colalph">$(V_MMD2WU)</td>
                      </tr>
                  %endif
                  %if (V_MMRESV == "Y")
                      <tr>
                          <td class="dsphdr">Reserved Row</td>
                          <td class="colalph">$(V_MMRESV)</td>
                      </tr>
                  %endif
                  <tr>
                      <td class="dsphdr">Comments:</td>
                      @dtw_chartohex(V_MMCMNT, hexValue)
                      @dtw_length(hexValue, fldLength)
                      @dtw_assign(printRows, "1")
                      @dtw_assign(x, "1")
                      %while(x <= fldLength){
                          @dtw_pos("0D25", hexValue, x, y)
                          %if (y > "0")
                              @dtw_add(printRows, "1", printRows)
                              @dtw_add(y, "4", x)
                          %else
                              @dtw_add(fldLength, "1", x)
                          %endif
                      %}
                      <td colspan="3"><textarea readonly ROWS=$(printRows) COLS=80>$(V_MMCMNT)</textarea>
                  </tr>
                  %if (sql_Record_Count > "1")
                      <tr>
                          <td colspan="3">$(hrTagAttr)</td>
                      </tr>
                  %endif
              %endif
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %if (selectMacroName != "")
          %INCLUDE "CloseWindow.icl"
      %endif
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "MMDESCU,MMMCRO")
          @DTW_ASSIGN(orderByDisplay, "Description, Macro Name")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "MacroName")
      %if (orderBy == "MMMCRO")
          @DTW_ASSIGN(orderBy, "MMMCRO DESC")
          @DTW_ASSIGN(orderByDisplay, "Macro Name (descending)")
      %else
          @DTW_ASSIGN(orderBy, "MMMCRO")
          @DTW_ASSIGN(orderByDisplay, "Macro Name")
      %endif
  %elif (sequence == "Desc")
      %if (orderBy == "MMDESCU,MMMCRO")
          @DTW_ASSIGN(orderBy, "MMDESCU DESC,MMMCRO")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Macro Name")
      %else
          @DTW_ASSIGN(orderBy, "MMDESCU,MMMCRO")
          @DTW_ASSIGN(orderByDisplay, "Description, Macro Name")
      %endif
  %elif (sequence == "InclName")
      %if (orderBy == "MMINCLU,MMMCRO")
          @DTW_ASSIGN(orderBy, "MMINCLU DESC,MMMCRO")
          @DTW_ASSIGN(orderByDisplay, "Include Name (descending), Macro Name")
      %else
          @DTW_ASSIGN(orderBy, "MMINCLU,MMMCRO")
          @DTW_ASSIGN(orderByDisplay, "Include Name, Macro Name")
      %endif
  %elif (sequence == "ScriptUsing")
      %if (orderBy == "MMD2WUU,MMMCRO")
          @DTW_ASSIGN(orderBy, "MMD2WUU DESC,MMMCRO")
          @DTW_ASSIGN(orderByDisplay, "Script Using Macro (descending), Macro Name")
      %else
          @DTW_ASSIGN(orderBy, "MMD2WUU,MMMCRO")
          @DTW_ASSIGN(orderByDisplay, "Script Using Macro, Macro Name")
      %endif
  %elif (sequence == "ResvRec")
      %if (orderBy == "MMRESV,MMMCRO")
          @DTW_ASSIGN(orderBy, "MMRESV DESC,MMMCRO")
          @DTW_ASSIGN(orderByDisplay, "Reserved Row (descending), Macro Name")
      %else
          @DTW_ASSIGN(orderBy, "MMRESV,MMMCRO")
          @DTW_ASSIGN(orderByDisplay, "Reserved Row, Macro Name")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "MACROSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Macro Name</td>
                              @dtw_assign(operNbr, "operName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchName" size="50" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="50" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Include Name</td>
                              @dtw_assign(operNbr, "operINCL")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchINCL" size="50" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Script Using Macro</td>
                              @dtw_assign(operNbr, "operUsing")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchUsing" size="50" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Reserved Rows Only</td>
                              <td class="dspalph"><input type="checkbox" name="srchResv"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchName.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("MMMCROU", "Macro Name", $(srchName), "U", $(operName), "A")
  @Build_WildCard ("MMDESCU", "Description", $(srchDesc), "U", $(operDesc), "A")
  @Build_WildCard ("MMINCLU", "Include Name", $(srchINCL), "U", $(operINCL), "A")
  @Build_WildCard ("MMD2WUU", "Script Using Macro", $(srchUsing), "U", $(operUsing), "A")
  %if (srchResv == "on")
      @Build_WildCard ("MMRESV", "Reserved Rows Only", "Y", "", "=", "A")
  %endif
  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}