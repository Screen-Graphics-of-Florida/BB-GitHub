%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Factor Action Code Maintenance"
  d2wName                 = "FactorActionCodeMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;actionCode=@dtw_rurlescseq(actionCode)&amp;actionDesc=@dtw_rurlescseq(actionDesc)&amp;maintenanceCode=D"
  programName             = "HARFAC_E"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.actionDesc.value =="" ||
                      document.Chg.actionGroup.value =="")
                     {alert("$(reqFieldError)"); return false;}
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "FACTORACTIONCODEMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From HDFACT Where ACACTN = '$(actionCode)'", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=129")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "actionCode")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@actn", "actionCode")   @dtw_assign(Err_ACACTN, fieldValue)
                          @DecatErr_Field("@@desc", "actionDesc")   @dtw_assign(Err_ACDESC, fieldValue)
                          @DecatErr_Field("@@agrp", "actionGroup")  @dtw_assign(Err_ACAGRP, fieldValue)
                          @DecatErr_Field("@@fsts", "factorStatus") @dtw_assign(Err_ACFSTS, fieldValue)
                      %endif

                      @Decat_Field("@@actn")   @dtw_assign(V_ACACTN, fieldValue)
                      @Decat_Field("@@desc")   @dtw_assign(V_ACDESC, fieldValue)
                      @Decat_Field("@@agrp")   @dtw_assign(V_ACAGRP, fieldValue)
                      @Decat_Field("@@fsts")   @dtw_assign(V_ACFSTS, fieldValue)
                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "actionCode")
                      @dtw_assign(V_ACACTN, "")
                  %else
                      @dtw_assign(focusField, "actionDesc")
                  %endif

                  @SetTextOvr(Err_ACACTN)
	           <tr><td class="dsphdr"><span $(textOvr)>Action Code</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input type="text" name="actionCode" value="$(V_ACACTN)" size="2" maxlength="2"></td>
                      %else
                          <td class="inputalph"><input type="hidden" name="actionCode" value="$(V_ACACTN)">$(V_ACACTN)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_ACACTN)

                  @SetTextOvr(Err_ACDESC)
	   	   <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input type="text" name="actionDesc" value="$(V_ACDESC)" size="25" maxlength="50">$(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_ACDESC)

                  @RtvFldDesc("FLTYPE='FACTACTGRP' and FLVALU='$(V_ACAGRP)'", "SYFLAG", "FLDESC", agrpDesc)
                  @SetTextOvr(Err_ACAGRP)
	   	   <tr><td class="dsphdr"><span $(textOvr)>Action Group</span></td>
                      <td class="inputalph"><input type="text" name="actionGroup" value="$(V_ACAGRP)" size="2" maxlength="1">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=FACTACTGRP&amp;flagSrchHdr=@dtw_rurlescseq("Action Group")&amp;docName=Chg&amp;fldName=actionGroup&amp;fldDesc=actionGroupDesc" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage)</a>
                                            <input type="text" disabled name="actionGroupDesc" value="$(agrpDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_ACAGRP)

                  @RtvFldDesc("FLTYPE='FACTCRSTAT' and FLVALU='$(V_ACFSTS)'", "SYFLAG", "FLDESC", fstsDesc)
                  @SetTextOvr(Err_ACFSTS)
	   	   <tr><td class="dsphdr"><span $(textOvr)>Factor Status</span></td>
                      <td class="inputalph"><input type="text" name="factorStatus" value="$(V_ACFSTS)" size="2" maxlength="1">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=FACTCRSTAT&amp;flagSrchHdr=@dtw_rurlescseq("Factor Status")&amp;docName=Chg&amp;fldName=factorStatus&amp;fldDesc=factorStatusDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                            <input type="text" disabled name="factorStatusDesc" value="$(fstsDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_ACFSTS)
              %}
          </table>

          %if (focusField != "")
              <script TYPE="text/javascript">
                  document.Chg.$(focusField).focus();
              </script>
          %endif

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HARFAC_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(actionCode)
  @dtw_mUPPERCASE(actionGroup)
  @dtw_mUPPERCASE(factorStatus)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@actn", actionCode)
  @Concat_Field("@@desc", actionDesc)
  @Concat_Field("@@agrp", actionGroup)
  @Concat_Field("@@fsts", factorStatus)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(actionDesc), $(actionCode), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@actn", "actionCode")
          @Format_ConfMsg_Desc("", $(actionDesc), $(actionCode), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=129&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;actionCode=@dtw_rurlescseq(actionCode)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}