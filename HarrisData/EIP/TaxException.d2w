%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define{
  page_title              = "Tax Exception"
  d2wName                 = "TaxException.d2w"
  d2wVarBase              = "$(genericVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HOETEU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "TAXEXCEPTION")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select HDTAXE.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(TCDESC,' ') as TCDESC, ifnull(PCPCDS,' ') as PCPCDS, ifnull(TCTXBL,' ') as TCTXBL ", stmtSQL)
                      @dtw_concat(fileSQL, " HDTAXE ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDTAXC on TCCODE=TETAXC ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDPCLS on PCPCLS=TEPCLS ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, "TETAXC>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @TaxException_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) TaxException_Query (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td ><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)TaxExceptionMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Tax<br>Code</th>
                      <th class="colhdr">State</th>
                      <th class="colhdr">Product<br>Class</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchCode" size="2" maxlength="1">
                          <input type="hidden" name="operCode" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchState" size="2" maxlength="2">
                          <input type="hidden" name="operState" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchClass" size="4" maxlength="4">
                          <input type="hidden" name="operClass" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchCode.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("TETAXC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Code" title="Sequence By Tax Code, State, Product Class">Tax<br>Code</a></th>
              @OrderBy_Sort("TCDESC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CodeDesc" title="Sequence By Tax Code Description, State, Product Class">Tax Code<br>Description</a></th>
              @OrderBy_Sort("TESTAT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=State" title="Sequence By State, Tax Code, Product Class">State</a></th>
              @OrderBy_Sort("TEPCLS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Class" title="Sequence By Product Class, Tax Code, State">Product<br>Class</a></th>
              @OrderBy_Sort("PCPCDS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ClassDesc" title="Sequence By Product Class Description, Tax Code, State">Product Class<br>Description</a></th>
              <th class="colhdr">Exception</th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(genericVarBase)&amp;taxCode=@dtw_rurlescseq(V_TETAXC)&amp;state=@dtw_rurlescseq(V_TESTAT)&amp;productClass=@dtw_rurlescseq(V_TEPCLS)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc("Tax Code", $(V_TETAXC), "State", $(V_TESTAT), "Product Class", $(V_TEPCLS), confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y"))
                      <td class="opticon">
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)TaxExceptionMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colcode">$(V_TETAXC)</td>
                  <td class="colalph">$(V_TCDESC)</td>
                  <td class="colcode">$(V_TESTAT)</td>
                  <td class="colalph">$(V_TEPCLS)</td>
                  <td class="colalph">$(V_PCPCDS)</td>
                  %if (V_TCTXBL=="Y")
                      <td class="colalph">Non-Taxable</td>
                  %else
                      <td class="colalph">Taxable</td>
                  %endif
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select HDTAXE.*, ", stmtSQL)
  @dtw_concat(stmtSQL, " ifnull(TCDESC,' ') as TCDESC, ifnull(PCPCDS,' ') as PCPCDS ", stmtSQL)
  @dtw_concat(fileSQL, " HDTAXE ", fileSQL)
  @dtw_concat(fileSQL, " left join HDTAXC on TCCODE=TETAXC ", fileSQL)
  @dtw_concat(fileSQL, " left join HDPCLS on PCPCLS=TEPCLS ", fileSQL)
  %if (wildCardSearch!="")
      @dtw_concat(selectSQL, "TETAXC>' ' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @TaxException_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) TaxException_XMLQuery (IN CHAR(64)    profileHandle,
                                             CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("TaxExceptionList")

          %ROW{
	       @XMLIDTag(V_TETAXC, "TaxException ID")
                  @XMLTag(V_TETAXC, "TaxCode")
                  @XMLTag(V_TCDESC, "TaxCodeDescription")
                  @XMLTag(V_TESTAT, "State")
                  @XMLTag(V_TEPCLS, "ProductClass")
                  @XMLTag(V_PCPCDS, "ProductClassDescription")
              @XMLEndTag("TaxException")
	       %}

      @XMLEndTag("TaxExceptionList")
  %}
%}

%HTML(REPORT){
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "TESTAT,TETAXC")
          @DTW_ASSIGN(orderByDisplay, "Description, Tax Exception")
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT){
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit ()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT){
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY){
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Code")
      %if (orderBy == "TETAXC,TESTAT,TEPCLS")
          @DTW_ASSIGN(orderBy, "TETAXC DESC,TESTAT,TEPCLS")
          @DTW_ASSIGN(orderByDisplay, "Tax Code (descending), State, Product Class")
      %else
          @DTW_ASSIGN(orderBy, "TETAXC,TESTAT,TEPCLS")
          @DTW_ASSIGN(orderByDisplay, "Tax Code, State, Product Class")
      %endif
  %elseif (sequence == "CodeDesc")
      %if (orderBy == "TCDESC,TESTAT,TEPCLS")
          @DTW_ASSIGN(orderBy, "TCDESC DESC,TESTAT,TEPCLS")
          @DTW_ASSIGN(orderByDisplay, "Tax Code Description (descending), State, Product Class")
      %else
          @DTW_ASSIGN(orderBy, "TCDESC,TESTAT,TEPCLS")
          @DTW_ASSIGN(orderByDisplay, "Tax Code Description, State, Product Class")
      %endif
  %elseif (sequence == "State")
      %if (orderBy == "TESTAT,TETAXC,TEPCLS")
          @DTW_ASSIGN(orderBy, "TESTAT DESC,TETAXC,TEPCLS")
          @DTW_ASSIGN(orderByDisplay, "State (descending), Tax Code, Product Class")
      %else
          @DTW_ASSIGN(orderBy, "TESTAT,TETAXC,TEPCLS")
          @DTW_ASSIGN(orderByDisplay, "State, Tax Code, Product Class")
      %endif
  %elseif (sequence == "Class")
      %if (orderBy == "TEPCLS,TETAXC,TESTAT")
          @DTW_ASSIGN(orderBy, "TEPCLS DESC,TETAXC,TESTAT")
          @DTW_ASSIGN(orderByDisplay, "Product Class (descending), Tax Code, State")
      %else
          @DTW_ASSIGN(orderBy, "TEPCLS,TETAXC,TESTAT")
          @DTW_ASSIGN(orderByDisplay, "Product Class, Tax Code, State")
      %endif
  %elseif (sequence == "ClassDesc")
      %if (orderBy == "PCPCDS,TETAXC,TESTAT")
          @DTW_ASSIGN(orderBy, "PCPCDS DESC,TETAXC,TESTAT")
          @DTW_ASSIGN(orderByDisplay, "Product Class Description (descending), Tax Code, State")
      %else
          @DTW_ASSIGN(orderBy, "PCPCDS,TETAXC,TESTAT")
          @DTW_ASSIGN(orderByDisplay, "Product Class Description, Tax Code, State")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "TAXEXCEPTIONSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Tax Code</td>
                              @dtw_assign(operNbr, "operCode")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchCode" size="4" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">State</td>
                              @dtw_assign(operNbr, "operState")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchState" size="4" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Product Class</td>
                              @dtw_assign(operNbr, "operClass")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchClass" size="4" maxlength="4"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchCode.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("TETAXC", "Tax Code", $(srchCode), "U", operCode, "A")
  @Build_WildCard ("TESTAT", "State", $(srchState), "U", operState, "A")
  @Build_WildCard ("TEPCLS", "Product Class", $(srchClass), "U", operClass, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}