%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Vendor Order History"
  d2wName                 = "VendorOrderHistory.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;vendorNumber=@dtw_rurlescseq(vendorNumber)&amp;vendorName=@dtw_rurlescseq(vendorName)&amp;purchaseOrderNumber=@dtw_rurlescseq(purchaseOrderNumber)&amp;noMenu=@dtw_rurlescseq(noMenu)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  DTW_PAD_PGM_PARMS       = "YES"
  rowIndexNext            = "1"
  totalPages              = "0"	
  multRemitToVendor       = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL)
{
  @dtw_replace(workURL, "@@vendorName", "@dtw_rurlescseq(vendorName)", "1", "a", workURL)
  @dtw_replace(workURL, "@@vendorNumber", "@dtw_rurlescseq(vendorNumber)", "1", "a", workURL)
%}
	
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @VendorUserView(profileHandle, dataBaseID, userPass, vendorNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
	           %INCLUDE "NumEdit.icl"
                  %INCLUDE "CheckEnterSearch.icl"
                  function validate(searchForm) {
                      if (editNum(document.Search.srchOrder, 8, 0))
                          return true;
                  }
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %if (noMenu =="Y")
                  %INCLUDE "$(inquiryBanner)"
              %else
                  %INCLUDE "banner.icl"
              %endif
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "" && noMenu !="Y")
                           @dtw_assign(pageID, "VENDORORDERS")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          @dtw_assign(uv_WarehouseName, "PHWHS")
                          @dtw_assign(uv_VendorName, "PHVEND")
                          @dtw_assign(uv_BuyerName, "PHBUYR")
                          %INCLUDE "userview.icl"

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, "SELECT PHPO, PHSEQ#, PHSTAT, PHPORF, PHDSHP, PHRQDT, PHTYPE,", stmtSQL)
                          @dtw_concat(stmtSQL, " PHLRDT, PHSVSV, PHSVDS, PHVEND ", stmtSQL)
                          @dtw_concat(fileSQL, " POPOHH ", fileSQL)
                          @dtw_concat(selectSQL, "(PHVEND=$(vendorNumber) or PHRTOV=$(vendorNumber)) ", selectSQL)
                          %if (purchaseOrderNumber != "")
                              @dtw_concat(selectSQL, " and PHPO=$(purchaseOrderNumber) ", selectSQL)
                          %endif
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Order_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %if (noMenu =="Y")
                  %INCLUDE "$(inquiryTrailer)"
              %else
                  %INCLUDE "trailer.icl"
              %endif
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Order_Query (IN   CHAR(64)    profileHandle,
				      CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitleWithPrint.icl"
      <table $(contentTable)>
          @Format_Header_URL("Vendor", $(vendorName), $(vendorNumber), "$(homeURL)$(cGIPath)VendorSelect.d2w/REPORT$(d2wVarBase)")
      </table>

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr"> Reference<br>Number</th>
                      <th class="colhdr"> Purchase<br>Order</th></tr>
                  <tr><td><input type="text" class="inputalph" name="srchRef" size="15" maxlength="15">
                          <input type="hidden" name="operRef" value="LIKE">
                      </td>
                      <td><input type="text" class="inputnmbr" name="srchOrder" size="8" maxlength="8">
                          <input type="hidden" name="operOrder" value="=">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchRef.focus();
              </script>
          </form>

          %INCLUDE "wildCardPage.icl"
      %endif

      <table $(contentTable)>
          @RtvFldDesc("VMRTVD=$(vendorNumber) or VMVEND=$(vendorNumber)", "HDVEND", " char(count(VMVEND))", multRemitToVendor)
          <tr>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              %if (multRemitToVendor > "1")
                  @OrderBy_Sort("PHVEND", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=vendorSearch" title="Sequence By Vendor Number">Vendor</a></th>	
              %endif
              @OrderBy_Sort("PHPO ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=purchaseOrder" title="Sequence By Purchase Order">Purchase<br>Order</a></th>
              @OrderBy_Sort("PHSEQ#", sortVar)
	       <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SequenceNumber" title="Sequence By Sequence, Purchase Order">Seq</a></th>
              @OrderBy_Sort("PHPORF", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Reference" title="Sequence By Reference Number, Purchase Order">Reference<br>Number</a></th>
              @OrderBy_Sort("PHRQDT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RequireDate" title="Sequence By Required Date, Purchase Order">Required<br>Date</a></th>
              @OrderBy_Sort("PHLRDT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ReceivedDate" title="Sequence By Last Receipt Date, Purchase Order">Last<br>Receipt</a></th>
              @OrderBy_Sort("PHSVDS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ShipVia" title="Sequence By Ship Via, Purchase Order">Ship<br>Via</a></th>
              @OrderBy_Sort("PHTYPE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=POType" title="Sequence By Order Type, Purchase Order">Order<br>Type</a></th>
              @OrderBy_Sort("PHDSHP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DropShip" title="Sequence By Drop Shipment, Purchase Order">Drop<br>Ship</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"
   			
          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Date(V_PHRQDT, "D", F_PHRQDT)
              @Format_Date(V_PHLRDT, "D", F_PHLRDT)
              @RtvFldDesc("(OTOTCD='$(V_PHTYPE)' and OTAPID='PO')", "HDOTYP", "OTDESC", orderTypeDesc)

              <tr class="$(rowClass)">
                  %if (multRemitToVendor > "1")
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)VendorInquiry.d2w/DISPLAY$(genericVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_PHVEND)" onclick="$(inquiryWinVar)" title="Vendor Quickview">$(V_PHVEND)</a></td>
                  %endif
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)SelectPurchaseOrderHistory.d2w/REPORT$(genericVarBase)&amp;vendorNumber=@dtw_rurlescseq(vendorNumber)&amp;vendorName=@dtw_rurlescseq(vendorName)&amp;purchaseOrderNumber=@dtw_rurlescseq(V_PHPO)&amp;orderSequence=@dtw_rurlescseq(V_PHSEQ#)&amp;noMenu=@dtw_rurlescseq(noMenu)" title="View Purchase Order History">$(V_PHPO)</a></td>
		   <td class="colnmbr">$(V_PHSEQ#)</td>
                  <td class="colalph">$(V_PHPORF)</td>
                  <td class="coldate">$(F_PHRQDT)</td>
                  <td class="coldate">$(F_PHLRDT)</td>
                  <td class="colalph" $(helpCursor)><span title="$(V_PHSVSV)">$(V_PHSVDS)</span></td>
                  <td class="colcode" $(helpCursor)><span title="$(orderTypeDesc)">$(V_PHTYPE)</span></td>
                  %if (V_PHDSHP>"0")
                      @RtvFldDesc("DSVCF='V' and DSVNCS=$(vendorNumber) and DSNMBR=$(V_PHDSHP)", "HDDSHP", "DSNAME", dropShipName)
                      %if (dropShipName>" ")
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)DropShipInquiry.d2w/DISPLAY$(genericVarBase)&amp;dropShipVCF=V&amp;dropShipVendCust=@dtw_rurlescseq(vendorNumber)&amp;dropShipNumber=@dtw_rurlescseq(V_PHDSHP)" onclick="$(inquiryWinVar)" title="Drop Ship Quickview">$(V_PHDSHP)</a></td>
                      %else
                          <td class="colnmbr">$(V_PHDSHP)</td>
                      %endif
                  %else
                      <td class="colalph">&nbsp;</td>
                  %endif
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (vendorName=="")
      @RtvFldDesc("VMVEND=$(vendorNumber)", "HDVEND", " VMVNA1", vendorName)
  %endif
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "PHPO,PHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Purchase Order, Sequence")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "vendorSearch")
      %if (orderBy == "PHVEND,PHPO")
          @DTW_ASSIGN(orderBy, "PHVEND DESC,PHPO")
          @DTW_ASSIGN(orderByDisplay, "Vendor Number (descending), Purchase Order")
      %else
          @DTW_ASSIGN(orderBy, "PHVEND,PHPO")
          @DTW_ASSIGN(orderByDisplay, "Vendor Number, Purchase Order")
      %endif
  %elseif (sequence == "purchaseOrder")
      %if (orderBy == "PHPO ")
          @DTW_ASSIGN(orderBy, "PHPO DESC")
          @DTW_ASSIGN(orderByDisplay, "Purchase Order (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PHPO ")
          @DTW_ASSIGN(orderByDisplay, "Purchase Order")
      %endif
  %elseif (sequence == "SequenceNumber")
      %if (orderBy == "PHSEQ#,PHPO")
          @DTW_ASSIGN(orderBy, "PHSEQ# DESC,PHPO")
          @DTW_ASSIGN(orderByDisplay, "Sequence (descending), Purchase Order")
      %else
          @DTW_ASSIGN(orderBy, "PHSEQ#,PHPO")
          @DTW_ASSIGN(orderByDisplay, "Sequence, Purchase Order")
      %endif
  %elseif (sequence == "Reference")
      %if (orderBy == "PHPORF,PHPO")
          @DTW_ASSIGN(orderBy, "PHPORF DESC,PHPO")
          @DTW_ASSIGN(orderByDisplay, "Reference (descending), Purchase Order")
      %else
          @DTW_ASSIGN(orderBy, "PHPORF,PHPO")
          @DTW_ASSIGN(orderByDisplay, "Reference, Purchase Order")
      %endif
  %elseif (sequence == "DropShip")
      %if (orderBy == "PHDSHP,PHPO")
          @DTW_ASSIGN(orderBy, "PHDSHP DESC,PHPO")
          @DTW_ASSIGN(orderByDisplay, "Drop Ship (descending), Purchase Order")
      %else
          @DTW_ASSIGN(orderBy, "PHDSHP,PHPO")
          @DTW_ASSIGN(orderByDisplay, "Drop Ship, Purchase Order")
      %endif
  %elseif (sequence == "RequireDate")
      %if (orderBy == "PHRQDT,PHPO")
          @DTW_ASSIGN(orderBy, "PHRQDT DESC,PHPO")
          @DTW_ASSIGN(orderByDisplay, "Required Date (descending), Purchase Order")
      %else
          @DTW_ASSIGN(orderBy, "PHRQDT,PHPO")
          @DTW_ASSIGN(orderByDisplay, "Required Date, Purchase Order")
      %endif
  %elseif (sequence == "POType")
      %if (orderBy == "PHTYPE,PHPO")
          @DTW_ASSIGN(orderBy, "PHTYPE DESC,PHPO")
          @DTW_ASSIGN(orderByDisplay, "Type (descending), Purchase Order")
      %else
          @DTW_ASSIGN(orderBy, "PHTYPE,PHPO")
          @DTW_ASSIGN(orderByDisplay, "Type, Purchase Order")
      %endif
  %elseif (sequence == "ReceivedDate")
      %if (orderBy == "PHLRDT,PHPO")
          @DTW_ASSIGN(orderBy, "PHLRDT DESC,PHPO")
          @DTW_ASSIGN(orderByDisplay, "Last Receipt Date (descending), Purchase Order")
      %else
          @DTW_ASSIGN(orderBy, "PHLRDT,PHPO")
          @DTW_ASSIGN(orderByDisplay, "Last Receipt Date, Purchase Order")
      %endif
  %elseif (sequence == "ShipVia")
      %if (orderBy == "PHSVDS,PHPO")
          @DTW_ASSIGN(orderBy, "PHSVDS DESC,PHPO")
          @DTW_ASSIGN(orderByDisplay, "Ship Via (descending), Purchase Order")
      %else
          @DTW_ASSIGN(orderBy, "PHSVDS,PHPO")
          @DTW_ASSIGN(orderByDisplay, "Ship Via, Purchase Order")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          @dtw_assign(formName, "Search")
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchOrder, 7, 0) &&
                      editdate(document.Search.srchReqDate) &&
                      editdate(document.Search.srchLastRec))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "VENDORORDERS")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Purchase Order</td>
                              @dtw_assign(operNbr, "operOrder")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchOrder" size="8" maxlength="8"></td>
                          </tr>

                          <tr><td class="dsphdr">Reference Number</td>
                              @dtw_assign(operNbr, "operRef")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchRef" size="22" maxlength="22"></td>
                          </tr>

                          <tr><td class="dsphdr">Required Date</td>
                              @dtw_assign(operNbr, "operReqDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input name="srchReqDate" type="text" size="6" maxlength="6">
                                  <a href="javascript:calWindow('srchReqDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Last Receipt</td>
                              @dtw_assign(operNbr, "operLastRec")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input name="srchLastRec" type="text" size="6" maxlength="6">
                                  <a href="javascript:calWindow('srchLastRec');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Ship Via</td>
                              @dtw_assign(operNbr, "operShipVia")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchShipVia" type="text" size="4" maxlength="2"><a href="$(homeURL)$(cGIPath)ShipViaSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Search&amp;fldName=srchShipVia&amp;fldDesc=shipViaDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="shipViaDesc" type="text" size="35" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Order Type</td>
                              @dtw_assign(operNbr, "operOrderType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchOrderType" type="text" value="$(fromField)" size="4" maxlength="1"><a href="$(homeURL)$(cGIPath)OrderTypeSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Search&amp;fldName=srchOrderType&amp;fldDesc=srchOrderTypeDesc&amp;appID=PO" onclick="$(searchWinVar)"> $(searchImage) </a><input name="srchOrderTypeDesc" type="text" size="35" disabled></td>
                          </tr>
                		
                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchOrder.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("PHPORF", "Reference Number", $(srchRef), "U", operRef, "A")
  @Build_WildCard ("PHPO", "Order Number", $(srchOrder), "", operOrder, "N")
  @Build_WildCard ("PHRQDT", "Required Date", $(srchReqDate), "", operReqDate, "D")
  @Build_WildCard ("PHLRDT", "Last Receipt", $(srchLastRec), "", operLastRec, "D")
  @Build_WildCard ("PHSVSV", "Ship Via", $(srchShipVia), "U", operShipVia, "A")
  @Build_WildCard ("PHTYPE", "Order Type", $(srchOrderType), "U", operOrderType, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}