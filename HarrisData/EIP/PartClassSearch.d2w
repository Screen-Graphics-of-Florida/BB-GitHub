%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Part Class Search"
  d2wName                 = "PartClassSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectPartClass(partClass, desc){
                  window.opener.document.$(docName).$(fldName).value = partClass;
                  window.opener.document.$(docName).$(fldDesc).value = desc;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(uv_PartClassName, "ICCLAS")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select ICCLAS, ICDESC, ICFDTF, ICFSPR, ICTFND, ICPFCT, ICCFCT, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(ICDESC) as ICDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " HDMICM ", fileSQL)
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, " ICCLAS='$(moreInfoClass)'", selectSQL)
                      %elif (wildCardSearch!="" || uv_Sql != "")
                          @dtw_concat(selectSQL, "ICDESC<>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Process_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Process_Search (IN  CHAR(64) profileHandle,
                                       CHAR(2)   dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      %if (moreInfo != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Description</th>
                      <th class="colhdr">Part<br>Class</th>
                  </tr>
                  <tr><td class="inputalph">
                          <input type="text" name="srchDesc" size="30" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td class="inputalph">
                          <input type="text" name="srchClas" size="2" maxlength="2">
                          <input type="hidden" name="operClas" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              <tr>	
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("ICDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=description" title="Sequence By Description, Part Class">Description</a></th>
                  @OrderBy_Sort("ICCLAS", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=partClass" title="Sequence By Part Class">Part<br>Class</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %else
          <table $(contentTable)>
      %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Quote(V_ICCLAS, F_ICCLAS)
              @Format_Quote(V_ICDESC, F_ICDESC)

              %if (moreInfo != "Y")
                  <tr class="$(rowClass)">
                      <td class="colalph"><a href="javascript:selectPartClass('$(F_ICCLAS)','$(F_ICDESC)')" title="Select Part Class">$(V_ICDESC)</a></td>
                      <td class="colcode">$(V_ICCLAS)</td>
                      <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;moreInfoClass=@dtw_rurlescseq(V_ICCLAS)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                  </tr>

              %else
                  <tr><td><a href="javascript:selectPartClass('$(F_ICCLAS)','$(F_ICDESC)')" title="Select  Part Class">$(selectImageLrg)</a></td></tr>

                  <tr><td class="dsphdr">Part Class</td>
                      <td class="dspalph">$(V_ICCLAS)</td>
                  </tr>
	      		
                  <tr><td class="dsphdr">Class Description</td>
                      <td class="dspalph">$(V_ICDESC)</td>
                  </tr>

                  @RtvFldDesc("FLTYPE='FORECASTDF' AND FLVALU='$(V_ICFDTF)'", "SYFLAG", "FLDESC", fieldDesc)
                  <tr><td class="dsphdr">Forecast Date Format</td>
                      <td class="dspalph">$(fieldDesc)</td> 		
                  </tr>

                  @RtvFldDesc("FLTYPE='FORECASTSP' AND FLVALU='$(V_ICFSPR)'", "SYFLAG", "FLDESC", fieldDesc)
                  <tr><td class="dsphdr">Forecast Spreaders</td>
                      <td class="dspalph">$(fieldDesc)</td> 		
                  </tr>

                  @RtvFldDesc("TFDEF='$(V_ICTFND)'", "HDMTFM", "TFDESC", fieldDesc)
                  <tr><td class="dsphdr">Time Fence Definition</td>
                      <td class="dspalph">$(fieldDesc)</td> 		
                  </tr>

                  <tr><td class="dsphdr">Periods To Retain Forecast</td>
                      <td class="dspnmbr">$(V_ICPFCT)</td> 		
                  </tr>

                  <tr><td class="dsphdr">Periods To Consume Forecast</td>
                      <td class="dspnmbr">$(V_ICCFCT)</td> 		
                  </tr>
              %endif
          %}
      </table>
      %if (moreInfo != "Y")
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
      %endif
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "ICDESCU,ICCLAS")
      @DTW_ASSIGN(orderByDisplay, "Description, Part Class")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "description")
      %if (orderBy == "ICDESCU,ICCLAS")
          @DTW_ASSIGN(orderBy, "ICDESCU DESC,ICCLAS")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Part Class")
      %else
          @DTW_ASSIGN(orderBy, "ICDESCU,ICCLAS")
          @DTW_ASSIGN(orderByDisplay, "Description, Part Class")
      %endif
  %elif (sequence == "partClass")
      %if (orderBy == "ICCLAS")
          @DTW_ASSIGN(orderBy, "ICCLAS DESC")
          @DTW_ASSIGN(orderByDisplay, "Part Class (descending)")
      %else
          @DTW_ASSIGN(orderBy, "ICCLAS")
          @DTW_ASSIGN(orderByDisplay, "Part Class")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchPfct, 1, 0) &&
                      editNum(document.Search.srchCfct, 1, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Part Class</td>
                              @dtw_assign(operNbr, "operClas")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchClas" size="5" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchDesc" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Forecast Date Format</td>
                              @dtw_assign(operNbr, "operFdtf")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchFdtf" size="5" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Forecast Spreaders</td>
                              @dtw_assign(operNbr, "operFspr")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchFspr" size="5" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Time Fence Definition</td>
                              @dtw_assign(operNbr, "operTfnd")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchTfnd" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">Periods To Retain Forecast</td>
                              @dtw_assign(operNbr, "operPfct")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchPfct" size="5" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Periods To Consume Forecast</td>
                              @dtw_assign(operNbr, "operCfct")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchCfct" size="5" maxlength="1"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchClas.focus();
                          </script>
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}		

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("upper(ICDESC)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("ICCLAS", "Part Class", $(srchClas), "U", operClas, "A")
  @Build_WildCard ("ICFDTF", "Forecast Date Format", $(srchFdtf), "U", operFdtf, "A")
  @Build_WildCard ("ICFSPR", "Forecast Spreaders", $(srchFspr), "U", operFspr, "A")
  @Build_WildCard ("ICTFND", "Time Fence Definition", $(srchTfnd), "U", operTfnd, "A")
  @Build_WildCard ("ICPFCT", "Periods To Retain Forecast", $(srchPfct), "", operPfct, "N")
  @Build_WildCard ("ICCFCT", "Periods To Consume Forecast", $(srchCfct), "", operCfct, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}