%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Order Entry"
  d2wName                 = "OrderEntryByCustomerItem.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  dspMaxRows              = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"
  buyerNumber             = "0"
  buyerSearch             = ""
  buyerSearchAppend       = ""
  imageExists             = ""
  defaultQty              = ""
  tabID                   = "CUSTOMERITEM"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @CustomerUserView(profileHandle, dataBaseID, userPass, customerNumber, " ")
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              %INCLUDE "OrderEntryProgOpt.icl"
              <script TYPE="text/javascript">
                  %INCLUDE "OrderEntryConfirm.icl"
                  %INCLUDE "Menu.js"
                  %INCLUDE "numedit.icl"
                  %INCLUDE "CheckEnterSearch.icl"
                  %INCLUDE "NoFormValidate.icl"
                  function checkAdd(addForm) {
                      if (editAdd(addForm))
                          addForm.submit();
                  }
                  function editAdd(addForm) {
                  var rows = (addForm.displayedRows.value ? addForm.displayedRows.value : 0);
                  var ok = true;
                  for (var rx = 1; rx <= rows; rx++) {
                      var suffix = rx.toString();
                      var elemName = "orderQty" + rx;
                      ok = (editNum(addForm[elemName], 9, 4));
                      if (!ok) {break;}
                  }
                  return ok;
              }
             </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "CUSTITEMORDERENTRY")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(uv_CustomerName, "VCVNCS")
                          @dtw_assign(uv_WarehouseName, "WIWHS")
                          @dtw_assign(uv_ProductClassName, "IMPCLS")
                          @dtw_assign(uv_ProdInventoryTypeName, "IMITC")
                          @dtw_assign(uv_ProdPartTypeName, "IMPTYP")
	                   %INCLUDE "userview.icl"

                          @RtvFldDesc("XPEXPT='OE.ITEM.ADD'", "SYUXPM", "XPUXPG", exitPointItem)
                          @RtvFldDesc("H1OCTL=$(orderControlNumber)", "OEHDWK", "H1ORTY", H1ORTY)
                          @RtvFldDesc("H1OCTL=$(orderControlNumber)", "OEHDWK", "H1OEF", H1OEF)
                          @DTW_SUBSTR(H1OEF, "7", "1", H1FL07)

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select VCVCF, VCVNCS, VCITEM, VCVCIT, VCVCITU, ", stmtSQL)
                          @dtw_concat(stmtSQL, " WIWHS, WILRSQ,", stmtSQL)
                          @dtw_concat(stmtSQL, " IMIMDS, IMIMDSU, IMKIT, IMLOT, IMPCLS, IWSTKL, ", stmtSQL)
                          @dtw_concat(stmtSQL, " WHWHNM ", stmtSQL)
                          @dtw_concat(fileSQL, " HDVCIT ", fileSQL)
                          @dtw_concat(fileSQL, " inner join HDVCIW on WIID=VCID ", fileSQL)
                          @dtw_concat(fileSQL, " inner join HDIMST on IMITEM=VCITEM ", fileSQL)
                          @dtw_concat(fileSQL, " inner join HDIWHS on IWITEM=VCITEM and IWWHS=WIWHS ", fileSQL)
                          @dtw_concat(fileSQL, " left join HDWHSM on WHWHS=WIWHS ", fileSQL)
                          @dtw_concat(selectSQL, "VCVNCS = $(customerNumber)  and VCVCF = 'C' and IMIMAC = ' ' ", selectSQL)
                          %if (H1FL07 == "0" && H1ORTY !="Q" && H1ORTY !="X")
                              @dtw_concat(selectSQL, " and IWSTKL='N' and IMLOT='N' ", selectSQL)
                          %endif
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Select_Item_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- End Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- Start Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Select_Item_Query (IN CHAR(64)    profileHandle,
				          CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "OrderEntryTabs.icl"
	
      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr">Customer Item</th>
                  <th class="colhdr">Description</th></tr>
              <tr><td class="inputalph">
                      <input type="text" name="custItemNumber" size="17" maxlength="15">
                      <input type="hidden" name="operCustItem" value="LIKE">
                  </td>
                  <td class="inputalph">
                      <input type="text" name="itemDescription" size="15" maxlength="30">
                      <input type="hidden" name="operDesc" value="LIKE">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
          <script TYPE="text/javascript">
              document.Search.custItemNumber.focus();
          </script>
      </form>

      %INCLUDE "WildCardPage.icl"

      <form class="formClass" METHOD=POST name="Add" ACTION="$(homeURL)$(cGIPath)$(d2wName)/ADDTOORDER$(d2wVarBase)&amp;updateRowNum=@dtw_rurlescseq($(START_ROW_NUM))">

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("VCVCITU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=VendCustItem" title="Sequence By Customer Itemr"> Customer Item</a></th>
                  %if (oe_sec_10 == "Y")
                      @OrderBy_Sort("WIWHS", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Whs" title="Sequence By Warehouse, Customer Item">Whs</a></th>
                  %endif
                  @OrderBy_Sort("IMIMDSU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description, Customer Item Number"> Description</a></th>
                  <th class="colhdr">Price</th>
                  <th class="colhdr">Last Order<br>Quantity
                      %if (sql_Record_Count>"0")
                          <br><a href="$(homeURL)$(cGIPath)$(d2wName)/DEFAULT$(d2wVarBase)">$(orderDftQtyImage)</a>
                      %endif
                  </th>
                  <th class="colhdr">Order <br> Quantity</th>
                  %if (sql_Record_Count>"0")
                      <th colspan="3"><a onClick="return checkAdd(document.Add);">$(orderAddToImage)</a></th>
                  %endif
              </tr>
              %INCLUDE "NoRecordsFound.icl"

              %ROW{
                  @Check_Item_Comments(profileHandle, dataBaseID, V_VCITEM, V_VCVCF, V_VCVNCS, documentType, headerTrailer, itemComments)
                  @Cust_Unit_Price(profileHandle, dataBaseID, customerNumber, V_VCITEM, unitPrice, V_WIWHS, piecesPerPricing)
                  @Format_Nbr(unitPrice, F_unitPrice, $(prcNbrDec), $(amtEditCode), "Y", "", "")
                  @Format_Nbr(V_WILRSQ, F_WILRSQ, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                  %INCLUDE "SetRowClass.icl"
                  @dtw_assign(itemImage, "$(V_VCITEM)$(itemImageExt)")
                  @dtwf_exists(itemImage, imageExists)

                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(V_VCITEM)&amp;vendCustItemNumber=@dtw_rurlescseq(V_VCVCIT)&amp;itemDesc=@dtw_rurlescseq(V_IMIMDS)&amp;vendCustNumber=@dtw_rurlescseq(V_VCVNCS)&amp;vendCustFlag=@dtw_rurlescseq(V_VCVCF)")
                  <tr class="$(rowClass)">
                      <td class="colalph">$(V_VCVCIT)</td>
                      %if (oe_sec_10 == "Y")                	
                          <td class="colnmbr" $(helpCursor)><span title="$(V_WHWHNM)">$(V_WIWHS)</span></td>
                      %endif
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemInquiry.d2w/DISPLAY$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq($(V_VCITEM))" onclick="$(inquiryWinVar)" title="Item Quickview">$(V_IMIMDS)</a>
                          %if (V_IMKIT == "F")
                              $(cfgItemImage)
                          %endif
                      </td>
                      %if (IMKIT == "K")
                          @RtvFldDesc("KTKTIT='$(V_VCITEM)'", "HDKIT", "KTKTPR", KTKTPR)
                      %endif
                      %if ((V_IMKIT == "" || (V_IMKIT == "K" && V_KTKTPR == "K")))
                          %if (pricingAvailabilityInquiry == "Y")
                              <td class="colnmbr"><a href="$(homeURL)$(cGIPath)PricingAvailability.d2w/REPORT$(genericVarBase)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;itemNumber=@dtw_rurlescseq(V_VCITEM)&amp;itemDescription=@dtw_rurlescseq(V_IMIMDS)&amp;warehouseNumber=@dtw_rurlescseq(V_WIWHS)&amp;quantity=1&amp;noClose=Y" onclick="$(inquiryWinVar)" title="View Pricing">$(F_unitPrice)</a></td>
                          %else
                              <td class="colnmbr"><a href="$(homeURL)$(cGIPath)PricingInquiry.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;itemNumber=@dtw_rurlescseq(V_VCITEM)&amp;itemDescription=@dtw_rurlescseq(V_IMIMDS)&amp;warehouseNumber=@dtw_rurlescseq(V_WIWHS)&amp;productClass=@dtw_rurlescseq(V_IMPCLS)&amp;quantity=1" onclick="$(inquiryWinVar)" title="View Pricing">$(F_unitPrice)</a></td>
                          %endif
                      %else
                          <td class="colnmbr">$(F_unitPrice)</td>
                      %endif
                      <td class="colnmbr">$(F_WILRSQ)</td>
                      @dtw_assign(itemError, "")
                      %if (exitPointItem != "")
                          @Exit_Point_OEITEMADD(orderControlNumber, V_VCITEM, itemError)
                      %endif
                      %if (itemError != "")
                          <td class="error">$(itemError)</td>		
                      %elseif (defaultQty == "Y")
                          <td class="inputnmbr"><input type="text" name="orderQty$(ROW_NUM)" value="$(V_WILRSQ)" size="6" maxlength="15"></td>		
                      %else
                          <td class="inputnmbr"><input type="text" name="orderQty$(ROW_NUM)" size="6" maxlength="15"></td>		
                      %endif
                      <td class="colicon">
                          %if (itemComments == "Y")
                              <a href="$(homeURL)$(cGIPath)itemComments.d2w/REPORT$(maintainVar)" onclick="$(commentWinVar)">$(commentExistImage)</a>
                          %elif (itemComments != "")
                              <a href="$(homeURL)$(cGIPath)vendCustItemComments.d2w/REPORT$(maintainVar)" onclick="$(commentWinVar)">$(commentExistImage)</a>
                          %endif
                          %if (imageExists == "Y")
                              <a href="$(homeURL)$(cGIPath)imageDisplay.d2w/DISPLAY$(genericVarBase)&amp;imageDisplayPath=$(homeURL)$(itemImage)&amp;imageDesc=@dtw_rurlescseq(V_IMIMDS)" onclick="$(itemImageWinVar)">$(foundImage)</a>
                          %endif
                          <input type="hidden" name="item$(ROW_NUM)" value="$(V_VCITEM)">
                          <input type="hidden" name="whs$(ROW_NUM)" value="$(V_WIWHS)">
                      </td>		
                  </tr>
              %}
              <tr><td><input type="hidden" name="displayedRows" value="$(ROW_NUM)"></td></tr>	
          </table>
      </form>
      @DTW_ASSIGN(defaultQty, "")
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      %INCLUDE "EndTabs.icl"
      %INCLUDE "Copyright.icl"

      @dtw_assign(haveKit, "")
      @dtw_GetCookie("work_cookie", haveKit)
      @dtw_SetCookie("work_cookie", "", "path=/")
      %if (haveKit == "K")
          <meta http-equiv="refresh" content="0; URL=javascript:NewWindow('$(homeURL)$(cGIPath)OrderEntryKitOptionError.d2w/DISPLAY$(d2wVarBase)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;reliefCode=D&amp;addToOrder=C&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))','orderEntry_win','$(orderEntryWinPctH)','$(orderEntryWinPctW)','$(orderEntryWinSB)','$(orderEntryWinRZ)','$(orderEntryWinTB)','$(orderEntryWinMB)','$(orderEntryWinST)');">
      %elif (haveKit == "F")
          <meta http-equiv="refresh" content="0; URL=javascript:NewWindow('$(homeURL)$(cGIPath)OrderEntryFeatureOptionError.d2w/DISPLAY$(d2wVarBase)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;reliefCode=D&amp;addToOrder=C&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))','orderEntry_win','$(orderEntryWinPctH)','$(orderEntryWinPctW)','$(orderEntryWinSB)','$(orderEntryWinRZ)','$(orderEntryWinTB)','$(orderEntryWinMB)','$(orderEntryWinST)');">
      %endif
  %}
%}

%HTML(ADDTOORDER) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(orderQty1,@dtw_rstrip(orderQty1))
  @dtw_assign(orderQty2,@dtw_rstrip(orderQty2))
  @dtw_assign(orderQty3,@dtw_rstrip(orderQty3))
  @dtw_assign(orderQty4,@dtw_rstrip(orderQty4))
  @dtw_assign(orderQty5,@dtw_rstrip(orderQty5))
  @dtw_assign(orderQty6,@dtw_rstrip(orderQty6))
  @dtw_assign(orderQty7,@dtw_rstrip(orderQty7))
  @dtw_assign(orderQty8,@dtw_rstrip(orderQty8))
  @dtw_assign(orderQty9,@dtw_rstrip(orderQty9))
  @dtw_assign(orderQty10,@dtw_rstrip(orderQty10))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@octl", orderControlNumber)
  @Concat_Field("@@shto", customerNumber)
  %if (item1 != "" && orderQty1 != "")
      @Concat_Field("@@itm1", item1)
      @Concat_Field("@@whs1", whs1)
      @Concat_Field("@@qty1", orderQty1)
  %endif
  %if (item2 != "" && orderQty2 != "")
      @Concat_Field("@@itm2", item2)
      @Concat_Field("@@whs2", whs2)
      @Concat_Field("@@qty2", orderQty2)
  %endif
  %if (item3 != "" && orderQty3 != "")
      @Concat_Field("@@itm3", item3)
      @Concat_Field("@@whs3", whs3)
      @Concat_Field("@@qty3", orderQty3)
  %endif
  %if (item4 != "" && orderQty4 != "")
      @Concat_Field("@@itm4", item4)
      @Concat_Field("@@whs4", whs4)
      @Concat_Field("@@qty4", orderQty4)
  %endif
  %if (item5 != "" && orderQty5 != "")
      @Concat_Field("@@itm5", item5)
      @Concat_Field("@@whs5", whs5)
      @Concat_Field("@@qty5", orderQty5)
  %endif
  %if (item6 != "" && orderQty6 != "")
      @Concat_Field("@@itm6", item6)
      @Concat_Field("@@whs6", whs6)
      @Concat_Field("@@qty6", orderQty6)
  %endif
  %if (item7 != "" && orderQty7 != "")
      @Concat_Field("@@itm7", item7)
      @Concat_Field("@@whs7", whs7)
      @Concat_Field("@@qty7", orderQty7)
  %endif
  %if (item8 != "" && orderQty8 != "")
      @Concat_Field("@@itm8", item8)
      @Concat_Field("@@whs8", whs8)
      @Concat_Field("@@qty8", orderQty8)
  %endif
  %if (item9 != "" && orderQty9 != "")
      @Concat_Field("@@itm9", item9)
      @Concat_Field("@@whs9", whs9)
      @Concat_Field("@@qty9", orderQty9)
  %endif
  %if (item10 != "" && orderQty10 != "")
      @Concat_Field("@@itm0", item10)
      @Concat_Field("@@whs0", whs10)
      @Concat_Field("@@qty0", orderQty10)
  %endif
  @Concat_Field("@@pcfc", productCfgFormat)
  @Concat_Field("@@pcrr", productCfgReqReview)
  @Concat_Field("@@adpc", autoDisplayProdCfg)
  @Concat_Field("@@adko", autoDisplayKitCfg)
  @dtw_concat(edtVar, "}{", edtVar)

  @Add_To_Order(profileHandle, dataBaseID, haveKit, edtVar)

  @DTW_ASSIGN(updateTotal, "Y")
  @Update_Misc_Charges (profileHandle, dataBaseID, orderControlNumber, freightCharge, specialCharge, updateTotal)
  @dtw_SetCookie("work_cookie", "$(haveKit)", "path=/")
  <meta http-equiv="refresh" content="0; URL= $(homeURL)$(cGIPath)$(d2wName)/ENTRY$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(DEFAULT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(defaultQty, "Y")
  @Set_SQL(stmtSQL)
%}

%HTML(REVIEWORDER) {
  %INCLUDE "setLibraryList.icl"
  <meta http-equiv="refresh" content="0; URL= $(homeURL)$(cGIPath)OrderEntryOrderReview.d2w/REVIEW$(d2wVarBase)">
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "VCVCITU")
      @DTW_ASSIGN(orderByDisplay, "Customer Item Number")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %if (updateRowNum > "0")
      @dtw_assign(START_ROW_NUM,  "$(updateRowNum)")
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "VendCustItem")
      %if (orderBy == "VCVCITU")
          @DTW_ASSIGN(orderBy, "VCVCITU DESC")
          @DTW_ASSIGN(orderByDisplay, "Customer Item Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "VCVCITU")
          @DTW_ASSIGN(orderByDisplay, "Customer Item Number")
      %endif
  %elif (sequence == "Whs")
      %if (orderBy == "WIWHS,VCVCITU")
          @DTW_ASSIGN(orderBy, "WIWHS DESC,VCVCITU")
          @DTW_ASSIGN(orderByDisplay, "Warehouse (descending), Customer Item Number")
      %else
          @DTW_ASSIGN(orderBy, "WIWHS,VCVCITU")
          @DTW_ASSIGN(orderByDisplay, "Warehouse, Customer Item Number")
      %endif
  %elif (sequence == "Desc")
      %if (orderBy == "IMIMDSU,VCVCITU")
          @DTW_ASSIGN(orderBy, "IMIMDSU DESC,VCVCITU")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Customer Item Number")
      %else
          @DTW_ASSIGN(orderBy, "IMIMDSU,VCVCITU")
          @DTW_ASSIGN(orderByDisplay, "Description, Customer Item Number")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.upc, 13, 0)
                      %if (V_CIINS1 != "")
                          && editNum(document.Search.numeric01, 8, 5)
                      %endif
                      %if (V_CIINS2 != "")
                          && editNum(document.Search.numeric02, 8, 5)
                      %endif
                      %if (V_CIINS3 != "")
                          && editNum(document.Search.numeric03, 8, 5)
                      %endif
                      %if (V_CIINS4 != "")
                          && editNum(document.Search.numeric04, 8, 5)
                      %endif
                      %if (V_CIINS5 != "")
                          && editNum(document.Search.numeric05, 8, 5)
                      %endif
                  )
                  return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ITEMSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Customer Item Number</td>
                              @dtw_assign(operNbr, "operCustItem")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="custItemNumber" type="text" size="30" maxlength="30"></td>
                          </tr>
        			
                          <tr><td class="dsphdr">Item Number</td>
                              @dtw_assign(operNbr, "operItem")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="itemNumber" type="text" size="15" maxlength="15"></td>
                          </tr>
        			
                          <tr><td class="dsphdr">Item Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="itemDescription" type="text" size="30" maxlength="30"></td>
                          </tr>
        			
                          <tr><td class="dsphdr">Product Class</td>
                              @dtw_assign(operNbr, "operProdClass")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="productClass" type="text" size="4" maxlength="4"><a href="$(homeURL)$(cGIPath)prodclasssearch.d2w/ENTRY$(genericVarBase)&amp;docName=Search&amp;fldName=productClass&amp;fldDesc=productClassDescH" onclick="$(searchWinVar)"> $(searchImage) </a><input name="productClassDescH" type="text" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Catalog Number</td>
                              @dtw_assign(operNbr, "operCatalog")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="catalog" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">U.P.C. Number</td>
                              @dtw_assign(operNbr, "operUPC")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="upc" size="13" maxlength="13"></td>
                          </tr>

                          %if (V_CIIAS1 != "")		
                              <tr><td class="dsphdr">$(V_CIIAS1)</td>
                                  @dtw_assign(operNbr, "operAlpha1")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="alpha01" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIIAS2 != "")		
                              <tr><td class="dsphdr">$(V_CIIAS2)</td>
                                  @dtw_assign(operNbr, "operAlpha2")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="alpha02" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIIAS3 != "")		
                              <tr><td class="dsphdr">$(V_CIIAS3)</td>
                                  @dtw_assign(operNbr, "operAlpha3")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="alpha03" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIIAS4 != "")		
                              <tr><td class="dsphdr">$(V_CIIAS4)</td>
                                  @dtw_assign(operNbr, "operAlpha4")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="alpha04" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIIAS5 != "")		
                              <tr><td class="dsphdr">$(V_CIIAS5)</td>
                                  @dtw_assign(operNbr, "operAlpha5")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="alpha05" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIINS1 != "")		
                              <tr><td class="dsphdr">$(V_CIINS1)</td>
                                  @dtw_assign(operNbr, "operNumeric1")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="numeric01" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIINS2 != "")		
                              <tr><td class="dsphdr">$(V_CIINS2)</td>
                                  @dtw_assign(operNbr, "operNumeric2")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="numeric02" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIINS3 != "")		
                              <tr><td class="dsphdr">$(V_CIINS3)</td>
                                  @dtw_assign(operNbr, "operNumeric3")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="numeric03" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIINS4 != "")		
                              <tr><td class="dsphdr">$(V_CIINS4)</td>
                                  @dtw_assign(operNbr, "operNumeric4")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="numeric04" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIINS5 != "")		
                              <tr><td class="dsphdr">$(V_CIINS5)</td>
                                  @dtw_assign(operNbr, "operNumeric5")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="numeric05" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.custItemNumber.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("VCVCITU", "Customer Item Number", $(custItemNumber), "U", operCustItem, "A")
  @Build_WildCard ("IMITEM", "Item Number", $(itemNumber), "U", operItem, "A")
  @Build_WildCard ("IMIMDSU", "Item Description", $(itemDescription), "U", operDesc, "A")
  @Build_WildCard ("IMPCLS", "Product Class", $(productClass), "U", operProdClass, "A")
  @Build_WildCard ("IMCATN", "Catalog Number", $(catalog), "U", operCatalog, "A")
  @Build_WildCard ("IMUPC", "U.P.C. Number", $(upc), "", operUPC, "N")
  @Build_WildCard ("IMUDA1", "$(V_CIIAS1)", $(alpha01), "U", operAlpha1, "A")
  @Build_WildCard ("IMUDA2", "$(V_CIIAS2)", $(alpha02), "U", operAlpha2, "A")
  @Build_WildCard ("IMUDA3", "$(V_CIIAS3)", $(alpha03), "U", operAlpha3, "A")
  @Build_WildCard ("IMUDA4", "$(V_CIIAS4)", $(alpha04), "U", operAlpha4, "A")
  @Build_WildCard ("IMUDA5", "$(V_CIIAS5)", $(alpha05), "U", operAlpha5, "A")
  @Build_WildCard ("IMUDN1", "$(V_CIINS1)", $(numeric01), "", operNumeric1, "N")
  @Build_WildCard ("IMUDN2", "$(V_CIINS2)", $(numeric02), "", operNumeric2, "N")
  @Build_WildCard ("IMUDN3", "$(V_CIINS3)", $(numeric03), "", operNumeric3, "N")
  @Build_WildCard ("IMUDN4", "$(V_CIINS4)", $(numeric04), "", operNumeric4, "N")
  @Build_WildCard ("IMUDN5", "$(V_CIINS5)", $(numeric05), "", operNumeric5, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}