%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title 	           = "Group Number Search"
  d2wName                 = "GroupNumberSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script type="text/javascript">
              function selectCode(groupNumber, groupName){
                  window.opener.document.$(docName).$(fldName).value = groupNumber;
                  window.opener.document.$(docName).$(fldDesc).value = groupName;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(uv_PlantName, "BBPLNT")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select BBGRP#, BBDESC, BBPLNT, BBDEPT, BBWC, BBSCHD, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(BBDESC) as BBDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " HDGRPM ", fileSQL)
                      @dtw_concat(selectSQL, " BBPLNT=$(plantNumber) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @groupNumber_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) groupNumber_Search (IN CHAR(64)    profileHandle,
				           CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      <table $(contentTable)>
          @Format_Header("Plant", $(plantName), $(plantNumber))
      </table>

      $(searchhrTagAttr)
      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr">Group Description</th>
                  <th class="colhdr">Dept</th>
              </tr>
              <tr><td class="inputalph"><input type="text" name="srchDesc" size="30" maxlength="30">
                      <input type="hidden" name="operDesc" value="LIKE">
                  </td>
                  <td class="inputalph"><input type="text" name="srchDept" size="5" maxlength="5">
                      <input type="hidden" name="operDept" value="LIKE">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
          <script TYPE="text/javascript">
              document.Search.srchDesc.focus();
          </script>
      </form>
	
          %INCLUDE "WildCardPage.icl"
      </table>

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              @OrderBy_Sort("BBGRP#", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=group" title="Sequence By Group Number"> Group Number</a></th>
              @OrderBy_Sort("BBDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=desc" title="Sequence By Group Description"> Group Description</a></th>
              @OrderBy_Sort("BBDEPT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=dept" title="Sequence By Department, Work Center"> Dept</a></th>
              @OrderBy_Sort("BBWC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=wc" title="Sequence By Work Center"> Work Center</a></th>
              @OrderBy_Sort("BBSCHD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=schd" title="Sequence By Schedule, Department, Work Center"> Schedule</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Quote(V_BBDESC, F_BBDESC)

              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_BBGRP#)</td>
                  <td class="colalph"><a href="javascript:selectCode($(V_BBGRP#),'$(F_BBDESC)')" title="Select Group">$(V_BBDESC)</a></td>
                  <td class="colalph">$(V_BBDEPT)</td>
                  <td class="colalph">$(V_BBWC)</td>
                  <td class="colnmbr">$(V_BBSCHD)</td>
              </tr>
      %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "BBDESCU")
      @DTW_ASSIGN(orderByDisplay, "Group Description")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "group")
      %if (orderBy == "BBGRP#")
          @DTW_ASSIGN(orderBy, "BBGRP# DESC")
          @DTW_ASSIGN(orderByDisplay, "Group Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "BBGRP#")
          @DTW_ASSIGN(orderByDisplay, "Group Number")
      %endif
  %elseif (sequence == "desc")
      %if (orderBy == "BBDESCU")
          @DTW_ASSIGN(orderBy, "BBDESCU DESC")
          @DTW_ASSIGN(orderByDisplay, "Group Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "BBDESCU")
          @DTW_ASSIGN(orderByDisplay, "Group Description")
      %endif
  %elseif (sequence == "dept")
      %if (orderBy == "BBDEPT,BBWC")
          @DTW_ASSIGN(orderBy, "BBDEPT DESC,BBWC")
          @DTW_ASSIGN(orderByDisplay, "Department (descending) Work Center")
      %else
          @DTW_ASSIGN(orderBy, "BBDEPT,BBWC")
          @DTW_ASSIGN(orderByDisplay, "Department, Work Center")
      %endif
  %elseif (sequence == "wc")
      %if (orderBy == "BBWC")
          @DTW_ASSIGN(orderBy, "BBWC DESC")
          @DTW_ASSIGN(orderByDisplay, "Work Center (descending)")
      %else
          @DTW_ASSIGN(orderBy, "BBWC")
          @DTW_ASSIGN(orderByDisplay, "Work Center")
      %endif
  %elseif (sequence == "schd")
      %if (orderBy == "BBSCHD,BBDEPT,BBWC")
          @DTW_ASSIGN(orderBy, "BBSCHD DESC,BBDEPT,BBWC")
          @DTW_ASSIGN(orderByDisplay, "Schedule (descending), Department Work Center")
      %else
          @DTW_ASSIGN(orderBy, "BBSCHD,BBDEPT,BBWC")
          @DTW_ASSIGN(orderByDisplay, "Schedule, Department, Work Center")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchGroup, 5, 0) &&
                      editNum(document.Search.srchSchd, 3, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Group Number</td>
                              @dtw_assign(operNbr, "operGroup")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchGroup" size="5" maxlength="5"></td>
                          </tr>	

                          <tr><td class="dsphdr">Group Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="30" maxlength="30"></td>
                          </tr>	

                          <tr><td class="dsphdr">Department</td>
                              @dtw_assign(operNbr, "operDept")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDept" size="5" maxlength="5"></td>
                          </tr>	

                          <tr><td class="dsphdr">Work Center</td>
                              @dtw_assign(operNbr, "operWc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchWc" size="5" maxlength="5"></td>
                          </tr>	

                          <tr><td class="dsphdr">Schedule</td>
                              @dtw_assign(operNbr, "operSchd")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchSchd" size="3" maxlength="3"></td>
                          </tr>	


                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchGroup.focus();
                          </script>
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("BBGRP#", "Group Number", $(srchGroup), "", operGroup, "N")
  @Build_WildCard ("upper(BBDESC)", "Group Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("BBDEPT", "Department", $(srchDept), "U", operDept, "A")
  @Build_WildCard ("BBWC", "Work Center", $(srchWc), "U", operDept, "A")
  @Build_WildCard ("BBSCHD", "Schedule", $(srchSchd), "", operSchd, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}