%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Event Calendar Select"
  d2wName                 = "EventCalendarSelect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;calYear=@dtw_rurlescseq(calYear)&amp;calMonth=@dtw_rurlescseq(calMonth)&amp;calWeek=@dtw_rurlescseq(calWeek)&amp;calView=@dtw_rurlescseq(calView)&amp;calDate=@dtw_rurlescseq(calDate)&amp;reportSelType=C"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  allowScheduleJob        = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.customerNumber, 7, 0) &&
                      editNum(document.Chg.customerContact, 7, 0) &&
                      editNum(document.Chg.vendorNumber, 7, 0) &&
                      editNum(document.Chg.supplierContact, 7, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "EVENTCALSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                              @dtw_assign(focusField, "user")

                              %if (errFound != "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")

                                  @Decat_Field("@@user")   @dtw_assign(user, fieldValue)
                                  @Decat_Field("@@cust")   @dtw_assign(customerNumber, fieldValue)
                                  @Decat_Field("@@ccon")   @dtw_assign(customerContact, fieldValue)
                                  @Decat_Field("@@vend")   @dtw_assign(vendorNumber, fieldValue)
                                  @Decat_Field("@@scon")   @dtw_assign(supplierContact, fieldValue)
                                  @Decat_Field("@@evnt")   @dtw_assign(eventCode, fieldValue)
                                  @Decat_Field("@@copn")   @dtw_assign(chkOpen, fieldValue)
                                  @Decat_Field("@@casn")   @dtw_assign(chkAssigned, fieldValue)
                                  @Decat_Field("@@ccmp")   @dtw_assign(chkCompleted, fieldValue)
                                  @Decat_Field("@@ctim")   @dtw_assign(chkTime, fieldValue)
                              %else
                                  @dtw_assign(chkOpen, "CHECKED")
                                  @dtw_assign(chkAssigned, "CHECKED")
                                  @dtw_assign(chkCompleted, "CHECKED")
                                  @dtw_assign(chkTime, "CHECKED")
                                  %endif

                          <table $(contentTable)>
                              <tr><th class="dsphdr"> Search Element</th>
                                  <th class="dsphdr"> Search Data</th>
                              </tr>

                              @dtw_assign(userName, "")
                              %if (user != "")
                                  @RtvFldDesc("USUSER='$(user)' ", "SYUSER", "USDESC", userName)
                              %endif
                              <tr><td class="dsphdr">User Profile</td>
                                  <td class="inputalph"><input name="user" type="text" value="$(user)" size="10" maxlength="10"><a href="$(homeURL)$(phpPath)UserSearch.php$(altVarBase)&amp;docName=@dtw_rurlescseq(formName)&amp;userFld=user&amp;descFld=userName" onclick="$(searchWinVar)"> $(searchImage) </a></td>
                                  <td class="inputalph"><input name="userName" value="$(userName)" type="text" size="30" disabled></td>
                              </tr>

                              @dtw_assign(customerName, "")
                              %if (customerNumber > "0")
                                  @RtvFldDesc("CMCUST=$(customerNumber) ", "HDCUST", "CMCNA1", customerName)
                              %endif
                              <tr><td class="dsphdr">Customer Number</td>
                                  <td class="inputalph"><input name="customerNumber" value="$(customerNumber)" type="text" value="$(custNumber)" size="10" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=@dtw_rurlescseq(formName)&amp;fldName=customerNumber&amp;fldDesc=customerName" onclick="$(searchWinVar)"> $(searchImage) </a></td>
                                  <td class="inputalph"><input name="customerName" value="$(customerName)" type="text" size="30" disabled></td>
                              </tr>

                              @dtw_assign(customerContactName, "")
                              %if (customerContact > "0")
                                  @RtvFldDesc("CRCONT=$(customerContact) ", "CRCNTM", "CRFNAM", V_CRFNAM)
                                  @RtvFldDesc("CRCONT=$(customerContact) ", "CRCNTM", "CRLNAM", V_CRLNAM)
                                  @Format_EmplName(V_CRFNAM, V_CRLNAM, "", "", "", "D", customerContactName)
                              %endif
                              <tr><td class="dsphdr">Customer Contact Number</td>
                                  <td class="inputnmbr"><input name="customerContact" value="$(customerContact)" type="text" size="10" maxlength="7"><a href="$(homeURL)$(cGIPath)customercontactsearch.d2w/ENTRY$(genericVarBase)&amp;docName=@dtw_rurlescseq(formName)&amp;fldName=customerContact&amp;fldDesc=customerContactName" onclick="$(searchWinVar)"> $(searchImage) </a></td>
                                  <td class="inputalph"><input name="customerContactName" value="$(customerContactName)" type="text" size="30" disabled></td>
                              </tr>

                              @dtw_assign(vendorName, "")
                              %if (vendorNumber > "0")
                                  @RtvFldDesc("VMVEND=$(vendorNumber) ", "HDVEND", "VMVNA1", vendorName)
                              %endif
                              <tr><td class="dsphdr">Vendor Number</td>
                                  <td class="inputalph"><input name="vendorNumber" value="$(vendorNumber)" type="text" size="10" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=@dtw_rurlescseq(formName)&amp;fldName=vendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)"> $(searchImage) </a></td>
                                  <td class="inputalph"><input name="vendorName" value="$(vendorName)" type="text" size="30" disabled></td>
                              </tr>
                           			
                              @dtw_assign(supplierContactName, "")
                              %if (supplierContact > "0")
                                  @RtvFldDesc("SRCONT=$(supplierContact) ", "SRCNTM", "SRFNAM", V_SRFNAM)
                                  @RtvFldDesc("SRCONT=$(supplierContact) ", "SRCNTM", "SRLNAM", V_SRLNAM)
                                  @Format_EmplName(V_SRFNAM, V_SRLNAM, "", "", "", "D", supplierContactName)
                              %endif
                              <tr><td class="dsphdr">Supplier Contact Number</td>
                                  <td class="inputnmbr"><input name="supplierContact" value="$(supplierContact)" type="text" size="10" maxlength="7"><a href="$(homeURL)$(cGIPath)suppliercontactsearch.d2w/ENTRY$(genericVarBase)&amp;docName=@dtw_rurlescseq(formName)&amp;fldName=supplierContact&amp;fldDesc=supplierContactName" onclick="$(searchWinVar)"> $(searchImage) </a></td>
                                  <td class="inputalph"><input name="supplierContactName" value="$(supplierContactName)" type="text" size="30" disabled></td>
                              </tr>

                              @dtw_assign(eventDesc, "")
                              %if (eventCode != "")
                                  @RtvFldDesc("ECEVNT='$(eventCode)' ", "SYEVNT", "ECDESC", eventDesc)
                              %endif
                              <tr><td class="dsphdr">Event Code</td>
                                  <td class="inputalph"><input name="eventCode" value="$(eventCode)" type="text" size="10" maxlength="10"><a href="$(homeURL)$(cGIPath)eventcodesearch.d2w/ENTRY$(genericVarBase)&amp;docName=@dtw_rurlescseq(formName)&amp;fldName=eventCode&amp;fldDesc=eventDesc" onclick="$(searchWinVar)"> $(searchImage) </a></td>
                                  <td class="inputalph"><input name="eventDesc" value="$(eventDesc)" type="text" size="30" disabled></td>
                              </tr>

                              <tr><td class="dsphdr">Event Display</td>
                                  <td class="inputalph"><input type="checkbox" name="dspOpen" value="CHECKED" $(chkOpen)>Open</td>
                              </tr>  			
                              <tr><td>&nbsp;</td>
                                  <td class="inputalph"><input type="checkbox" name="dspAssigned" value="CHECKED" $(chkAssigned)>Assigned</td>
                              </tr>  			
                              <tr><td>&nbsp;</td>
                                  <td class="inputalph"><input type="checkbox" name="dspCompleted" value="CHECKED" $(chkCompleted)>Completed</td>
                              </tr>  			
                              <tr><td>&nbsp;</td>
                                  <td class="inputalph"><input type="checkbox" name="dspTime" value="CHECKED" $(chkTime)>Time</td>
                              </tr>  			
                          </table>

                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(32000) edtVar)
  {%EXEC {HSYCLS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  %if (getCurrent == "Y")
      @RtvFldDesc("CSXHND='$(profileHandle)' ", "SYCLSW", "CSCSEL", edtVar)
      %if (edtVar != "")
          @EdtVarErr(profileHandle, typeValue, edtVar)
          @dtw_assign(errFound, "Y")
      %endif
  %endif
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(user)
  @dtw_mUPPERCASE(eventCode)

  @dtw_assign(customerNumber,@dtw_rstrip(customerNumber))
  @dtw_assign(customerContact,@dtw_rstrip(customerContact))
  @dtw_assign(vendorNumber,@dtw_rstrip(vendorNumber))
  @dtw_assign(supplierContact,@dtw_rstrip(supplierContact))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@user", user)
  @Concat_Field("@@cust", customerNumber)
  @Concat_Field("@@ccon", customerContact)
  @Concat_Field("@@vend", vendorNumber)
  @Concat_Field("@@scon", supplierContact)
  @Concat_Field("@@evnt", eventCode)
  @Concat_Field("@@copn", dspOpen)
  @Concat_Field("@@casn", dspAssigned)
  @Concat_Field("@@ccmp", dspCompleted)
  @Concat_Field("@@ctim", dspTime)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, edtVar)

  %if ((errFound == "" && saveSelection == "Y") || rtvSelection == "Y")
      @dtw_assign(errFound, "Y")
      @EdtVarErr(profileHandle, typeValue, edtVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
      <script TYPE="text/javascript">
          %INCLUDE "NewWindowOpen.icl"
          NewWindow('$(homeURL)$(cGIPath)ReportSelection.d2w/REPORT$(d2wVarBase)&amp;reportSelD2W=@dtw_rurlescseq(d2wName)&amp;reportDesc=@dtw_rurlescseq(page_title)&amp;reportSelUser=@dtw_rurlescseq(userProfile)&amp;rtvSelection=@dtw_rurlescseq(rtvSelection)&amp;maintenanceCode=C','search_win','$(searchWinPctH)','$(searchWinPctW)','$(searchWinSB)','$(searchWinRZ)','$(searchWinTB)','$(searchWinMB)','$(searchWinST)');
      </script>
  %elif (errFound == "" && saveSelection != "S")
      @dtw_assign(dspTimeSel, "N")
      @dtw_assign(dspAsgnSel, "N")
      @dtw_assign(dspOpenSel, "N")
      @dtw_assign(dspCompSel, "N")

      %if (dspTime == "CHECKED")
          @dtw_assign(dspTimeSel, "Y")
      %endif

      %if (dspAssigned == "CHECKED")
          @dtw_assign(dspAsgnSel, "Y")
      %endif

      %if (dspOpen == "CHECKED")
          @dtw_assign(dspOpenSel, "Y")
      %endif

      %if (dspCompleted == "CHECKED")
          @dtw_assign(dspCompSel, "Y")
      %endif

      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)EventCalendar.d2w/CALENDAR$(d2wVarBase)&amp;dspTime=@dtw_rurlescseq(dspTimeSel)&amp;dspComp=@dtw_rurlescseq(dspCompSel)&amp;dspOpen=@dtw_rurlescseq(dspOpenSel)&amp;dspAsgn=@dtw_rurlescseq(dspAsgnSel)&amp;reload=S">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}