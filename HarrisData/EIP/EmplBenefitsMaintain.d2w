                      <td class="inputalph"><input name="certificateIssuer" type="text" value="$(V_ECCISU)" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_ECCISU)

                  @SetTextOvr(Err_ECPHON)
                  <tr><td class="dsphdr"><span $(textOvr)>Phone Number Of Issuer</span></td>
                      <td class="inputnmbr"><input name="phoneNumber" type="text" value="$(V_ECPHON)" size="10" maxlength="10"></td>
                  </tr>
                  @DspErrMsg(Err_ECPHON)

                  @SetTextOvr(Err_ECMNTH)
                  <tr><td class="dsphdr"><span $(textOvr)>Previous Months Of Coverage</span></td>
                      <td class="inputnmbr"><input name="monthsOfCoverage" type="text" value="$(V_ECMNTH)" size="3" maxlength="3"></td>
                  </tr>
                  @DspErrMsg(Err_ECMNTH)

                  @SetTextOvr(Err_dsphdr)
                  <tr><td class="dsphdr"><span $(textOvr)>Preexisting Condition Expiration Date</span></td>
                      <td class="inputnmbr"><input name="preexistingCondDate" type="text" value="$(V_ECPREC)" size="6" maxlength="6">
                          <a href="javascript:calWindow('preexistingCondDate');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_ECPREC)
              </table>
              </fieldset>

              %if (CVEBEN == "Y")
                  <a name="bene1"></a>
                  <fieldset class="legendBody">
                  <legend class="legendTitle"> Beneficiary 1 </legend>
                  <div class="quickLinksTop">
                      <a href="#top">$(topOfFormImage)</a>
                  </div>
                  <table $(contentTable)>
                      <tr><td class="dsphdr"><span $(textOvr)>Name</span></td>
                          <td class="inputalph"><input name="BEN1" type="text" value="$(V_ECBEN1)" size="20" maxlength="20"></td>
                      </tr>
                      @DspErrMsg(Err_ECBEN1)

                      @SetTextOvr(Err_ECBSS1)
                      %while(@dtw_rlength(V_ECBSS1) != "9") {@dtw_insert("0", V_ECBSS1, V_ECBSS1)%}
                      <tr><td class="dsphdr"><span $(textOvr)>Social Security Number</span></td>
                          <td class="inputnmbr"><input name="BSS1" type="text" value="$(V_ECBSS1)" size="9" maxlength="9"></td>
                      </tr>
                      @DspErrMsg(Err_ECBSS1)

                      @SetTextOvr(Err_ECBPC1)
                      <tr><td class="dsphdr"><span $(textOvr)>Percent</span></td>
                          <td class="inputnmbr"><input name="BPC1" type="text" value="$(V_ECBPC1)" size="3" maxlength="3"></td>
                      </tr>
                      @DspErrMsg(Err_ECBPC1)
                  </table>
                  </fieldset>

                  <a name="bene2"></a>
                  <fieldset class="legendBody">
                  <legend class="legendTitle"> Beneficiary 2 </legend>
                  <div class="quickLinksTop">
                      <a href="#top">$(topOfFormImage)</a>
                  </div>
                  <table $(contentTable)>
                      <tr><td class="dsphdr"><span $(textOvr)>Name</span></td>
                          <td class="inputalph"><input name="BEN2" type="text" value="$(V_ECBEN2)" size="20" maxlength="20"></td>
                      </tr>
                      @DspErrMsg(Err_ECBEN2)

                      @SetTextOvr(Err_ECBSS2)
                      %while(@dtw_rlength(V_ECBSS2) != "9") {@dtw_insert("0", V_ECBSS2, V_ECBSS2)%}
                      <tr><td class="dsphdr"><span $(textOvr)>Social Security Number</span></td>
                          <td class="inputnmbr"><input name="BSS2" type="text" value="$(V_ECBSS2)" size="9" maxlength="9"></td>
                      </tr>
                      @DspErrMsg(Err_ECBSS2)

                      @SetTextOvr(Err_ECBPC2)
                      <tr><td class="dsphdr"><span $(textOvr)>Percent</span></td>
                          <td class="inputnmbr"><input name="BPC2" type="text" value="$(V_ECBPC2)" size="3" maxlength="3"></td>
                      </tr>
                      @DspErrMsg(Err_ECBPC2)
                  </table>
                  </fieldset>

                  <a name="bene3"></a>
                  <fieldset class="legendBody">
                  <legend class="legendTitle"> Beneficiary 3 </legend>
                  <div class="quickLinksTop">
                      <a href="#top">$(topOfFormImage)</a>
                  </div>
                  <table $(contentTable)>
                      <tr><td class="dsphdr"><span $(textOvr)>Name</span></td>
                          <td class="inputalph"><input name="BEN3" type="text" value="$(V_ECBEN3)" size="20" maxlength="20"></td>
                      </tr>
                      @DspErrMsg(Err_ECBEN3)

                      @SetTextOvr(Err_ECBSS3)
                      %while(@dtw_rlength(V_ECBSS3) != "9") {@dtw_insert("0", V_ECBSS3, V_ECBSS3)%}
                      <tr><td class="dsphdr"><span $(textOvr)>Social Security Number</span></td>
                          <td class="inputnmbr"><input name="BSS3" type="text" value="$(V_ECBSS3)" size="9" maxlength="9"></td>
                      </tr>
                      @DspErrMsg(Err_ECBSS3)

                      @SetTextOvr(Err_ECBPC3)
                      <tr><td class="dsphdr"><span $(textOvr)>Percent</span></td>
                          <td class="inputnmbr"><input name="BPC3" type="text" value="$(V_ECBPC3)" size="3" maxlength="3"></td>
                      </tr>
                      @DspErrMsg(Err_ECBPC3)
                  </table>
                  </fieldset>

                  <a name="bene4"></a>
                  <fieldset class="legendBody">
                  <legend class="legendTitle"> Beneficiary 4 </legend>
                  <div class="quickLinksTop">
                      <a href="#top">$(topOfFormImage)</a>
                  </div>
                  <table $(contentTable)>
                      <tr><td class="dsphdr"><span $(textOvr)>Name</span></td>
                          <td class="inputnmbr"><input name="BEN4" type="text" value="$(V_ECBEN4)" size="20" maxlength="20"></td>
                      </tr>
                      @DspErrMsg(Err_ECBEN4)

                      @SetTextOvr(Err_ECBSS4)
                      %while(@dtw_rlength(V_ECBSS4) != "9") {@dtw_insert("0", V_ECBSS4, V_ECBSS4)%}
                      <tr><td class="dsphdr"><span $(textOvr)>Social Security Number</span></td>
                          <td class="inputnmbr"><input name="BSS4" type="text" value="$(V_ECBSS4)" size="9" maxlength="9"></td>
                      </tr>
                      @DspErrMsg(Err_ECBSS4)

                      @SetTextOvr(Err_ECBPC4)
                      <tr><td class="dsphdr"><span $(textOvr)>Percent</span></td>
                          <td class="inputnmbr"><input name="BPC4" type="text" value="$(V_ECBPC4)" size="3" maxlength="3"></td>
                      </tr>
                      @DspErrMsg(Err_ECBPC4)
                  </table>
                  </fieldset>

                  <a name="bene5"></a>
                  <fieldset class="legendBody">
                  <legend class="legendTitle"> Beneficiary 5 </legend>
                  <div class="quickLinksTop">
                      <a href="#top">$(topOfFormImage)</a>
                  </div>
                  <table $(contentTable)>
                      <tr><td class="dsphdr"><span $(textOvr)>Name</span></td>
                          <td class="inputalph"><input name="BEN5" type="text" value="$(V_ECBEN5)" size="20" maxlength="20"></td>
                      </tr>
                      @DspErrMsg(Err_ECBEN5)

                      @SetTextOvr(Err_ECBSS5)
                      %while(@dtw_rlength(V_ECBSS5) != "9") {@dtw_insert("0", V_ECBSS5, V_ECBSS5)%}
                      <tr><td class="dsphdr"><span $(textOvr)>Social Security Number</span></td>
                          <td class="inputnmbr"><input name="BSS5" type="text" value="$(V_ECBSS5)" size="9" maxlength="9"></td>
                      </tr>
                      @DspErrMsg(Err_ECBSS5)

                      @SetTextOvr(Err_ECBPC5)
                      <tr><td class="dsphdr"><span $(textOvr)>Percent</span></td>
                          <td class="inputnmbr"><input name="BPC5" type="text" value="$(V_ECBPC5)" size="3" maxlength="3"></td>
                      </tr>
                      @DspErrMsg(Err_ECBPC5)
                  </table>
                  </fieldset>

                  <a name="bene6"></a>
                  <fieldset class="legendBody">
                  <legend class="legendTitle"> Beneficiary 6 </legend>
                  <div class="quickLinksTop">
                      <a href="#top">$(topOfFormImage)</a>
                  </div>
                  <table $(contentTable)>
                      <tr><td class="dsphdr"><span $(textOvr)>Name</span></td>
                          <td class="inputnmbr"><input name="BEN6" type="text" value="$(V_ECBEN6)" size="20" maxlength="20"></td>
                      </tr>
                      @DspErrMsg(Err_ECBEN6)

                      @SetTextOvr(Err_ECBSS6)
                      %while(@dtw_rlength(V_ECBSS6) != "9") {@dtw_insert("0", V_ECBSS6, V_ECBSS6)%}
                      <tr><td class="dsphdr"><span $(textOvr)>Social Security Number</span></td>
                          <td class="inputnmbr"><input name="BSS6" type="text" value="$(V_ECBSS6)" size="9" maxlength="9"></td>
                      </tr>
                      @DspErrMsg(Err_ECBSS6)

                      @SetTextOvr(Err_ECBPC6)
                      <tr><td class="dsphdr"><span $(textOvr)>Percent</span></td>
                          <td class="inputnmbr"><input name="BPC6" type="text" value="$(V_ECBPC6)" size="3" maxlength="3"></td>
                      </tr>
                      @DspErrMsg(Err_ECBPC6)
                  </table>
                  </fieldset>
              %else
                  <input type="hidden" name="BSS1" value="000000000">
                  <input type="hidden" name="BPC1" value="000">
                  <input type="hidden" name="BSS2" value="000000000">
                  <input type="hidden" name="BPC2" value="000">
                  <input type="hidden" name="BSS3" value="000000000">
                  <input type="hidden" name="BPC3" value="000">
                  <input type="hidden" name="BSS4" value="000000000">
                  <input type="hidden" name="BPC4" value="000">
                  <input type="hidden" name="BSS5" value="000000000">
                  <input type="hidden" name="BPC5" value="000">
                  <input type="hidden" name="BSS6" value="000000000">
                  <input type="hidden" name="BPC6" value="000">
              %endif

              <a name="terminate"></a>
              <fieldset class="legendBody">
              <legend class="legendTitle"> Terminate Benefit</legend>
              <div class="quickLinksTop">
                  <a href="#top">$(topOfFormImage)</a>
              </div>
              <table $(contentTable)>

                  %if(V_ECDCT == "0")
                      @dtw_assign(V_ECDCT, "")
                  %endif
                  @SetTextOvr(Err_ECDCT)
                  <tr><td class="dsphdr"><span $(textOvr)>Coverage Termination Date</span></td>
                      <td class="inputnmbr"><input name="coverageTermDate" type="text" value="$(V_ECDCT)" size="6" maxlength="6">
                          <a href="javascript:calWindow('coverageTermDate');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_ECDCT)

                  @SetTextOvr(Err_ECTRCR)
                  <tr><td class="dsphdr"><span $(textOvr)>Date Certificate Requested</span></td>
                      <td class="inputnmbr"><input name="certificateRequested" type="text" value="$(V_ECTRCR)" size="6" maxlength="6">
                          <a href="javascript:calWindow('certificateRequested');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_ECTRCR)

                  @SetTextOvr(Err_ECTRCI)
                  <tr><td class="dsphdr"><span $(textOvr)>Date Certificate Issued</span></td>
                      <td class="inputnmbr"><input name="certificateIssued" type="text" value="$(V_ECTRCI)" size="6" maxlength="6">
                          <a href="javascript:calWindow('certificateIssued');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_ECTRCI)
    	   	
                  @SetTextOvr(Err_ECACKN)
                  <tr><td class="dsphdr"><span $(textOvr)>Employee Receipt</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_ECACKN) && (x < maxRows))
                           {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "employeeReceipt", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_ECACKN)
    	   	
                  @SetTextOvr(Err_ECCARR)
                  <tr><td class="dsphdr"><span $(textOvr)>Provider Notified</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_ECCARR) && (x < maxRows))
                           {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "carrierNotified", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_ECCARR)

                  @SetTextOvr(Err_ECPREM)
                  <tr><td class="dsphdr"><span $(textOvr)>COBRA Premium Override</span></td>
                      <td class="inputnmbr"><input name="premium" type="text" value="$(V_ECPREM)" size="9" maxlength="9"></td>
                  </tr>
                  @DspErrMsg(Err_ECPREM)

                  @dtw_assign(classcode, V_ECCLAS)

              </table>
              </fieldset>
          %}

          %if ((focusField == "benefitCode") || (focusField == "planCode"))
              @dtw_assign(focusField, "eligibilityDate")
          %endif

          <script type="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64) profileHandle,
                                        INOUT CHAR(2) dataBaseID,
                                        INOUT CHAR(1) maintenanceCode,
                                        INOUT CHAR(1) errFound,
                                        INOUT CHAR(32000) edtVar,
                                        INOUT CHAR(32000) errVar,
                                        INOUT CHAR(1) editcovrplan)
  {%EXEC {HPEECU_W.PGM %}
%}

%HTML(UPDATE) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if ((sec_01 == "N" && maintenanceCode == "A") || (sec_04 == "N" && maintenanceCode == "Z"))
     <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)progOptSecError.d2w/DISPLAY$(genericVarBase)&amp;page_title=@dtw_rurlescseq(page_title)">
  %else
     %if (errFound == "" )
         @dtw_assign(updateDependents, "N")
         @dtw_assign(updateDeduction, "N")
     %endif

     @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
         @dtw_tb_insertrow(yn01Table, "0", "1")
         @dtw_tb_setv(yn01Table, "", "1", "2")
     @PlanHolder_Query(profileHandle, dataBaseID, "PLANHOLDER", planHolderTable)
     @RtvFldDesc("CVCOMP=$(prCompany) AND CVFACL=$(prFacility) AND CVCOVR='$(benefitCode)' AND CVPLAN='$(planCode)'", "CBCOVR", "CVEBEN", CVEBEN)
     @RtvFldDesc("CVCOMP=$(prCompany) AND CVFACL=$(prFacility) AND CVCOVR='$(benefitCode)' AND CVPLAN='$(planCode)'", "CBCOVR", "char(CVUNIT)", CVUNIT)
     @RtvFldDesc("CVCOMP=$(prCompany) AND CVFACL=$(prFacility) AND CVCOVR='$(benefitCode)' AND CVPLAN='$(planCode)'", "CBCOVR", "CVAUTD", CVAUTD)
     @RtvFldDesc("CVCOMP=$(prCompany) AND CVFACL=$(prFacility) AND CVCOVR='$(benefitCode)' AND CVPLAN='$(planCode)'", "CBCOVR", "CVCREQ", cobraBenefit)
     @RtvFldDesc("SDCOMP=$(prCompany) AND SDFACL=$(prFacility) AND SDEMPL=$(hrEmployee)", "HRSPDP", "SDLNAM", SDLNAM)
     @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  %if (dependentNbr == "0000000")
      @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "char(EMSSNO)", socSecNo)
  %else
      @RtvFldDesc("SDCOMP=$(prCompany) and SDFACL=$(prFacility) and SDEMPL=$(hrEmployee) and SDSD#=$(dependentNbr)", "HRSPDP", "char(SDSS#)", socSecNo)
  %endif

  @dtw_assign(socSecNo,@dtw_rstrip(socSecNo))
  @dtw_assign(dependentNbr,@dtw_rstrip(dependentNbr))
  @dtw_assign(eligibilityDate,@dtw_rstrip(eligibilityDate))
  @dtw_assign(enrollmentDate,@dtw_rstrip(enrollmentDate))
  @dtw_assign(dateEffective,@dtw_rstrip(dateEffective))
  @dtw_assign(vestingDate,@dtw_rstrip(vestingDate))
  @dtw_assign(amount,@dtw_rstrip(amount))
  @dtw_assign(BSS1,@dtw_rstrip(BSS1))
  @dtw_assign(BPC1,@dtw_rstrip(BPC1))
  @dtw_assign(BSS2,@dtw_rstrip(BSS2))
  @dtw_assign(BPC2,@dtw_rstrip(BPC2))
  @dtw_assign(BSS3,@dtw_rstrip(BSS3))
  @dtw_assign(BPC3,@dtw_rstrip(BPC3))
  @dtw_assign(BSS4,@dtw_rstrip(BSS4))
  @dtw_assign(BPC4,@dtw_rstrip(BPC4))
  @dtw_assign(BSS5,@dtw_rstrip(BSS5))
  @dtw_assign(BPC5,@dtw_rstrip(BPC5))
  @dtw_assign(BSS6,@dtw_rstrip(BSS6))
  @dtw_assign(BPC6,@dtw_rstrip(BPC6))
  @dtw_assign(numberOfUnits,@dtw_rstrip(numberOfUnits))
  @dtw_assign(deductionAmount,@dtw_rstrip(deductionAmount))
  @dtw_assign(deductionPercent,@dtw_rstrip(deductionPercent))
  @dtw_assign(planHolderSSN,@dtw_rstrip(planHolderSSN))
  @dtw_assign(certificateReceived,@dtw_rstrip(certificateReceived))
  @dtw_assign(phoneNumber,@dtw_rstrip(phoneNumber))
  @dtw_assign(monthsOfCoverage,@dtw_rstrip(monthsOfCoverage))
  @dtw_assign(preexistingCondDate,@dtw_rstrip(preexistingCondDate))
  @dtw_assign(coverageTermDate,@dtw_rstrip(coverageTermDate))
  @dtw_assign(certificateRequested,@dtw_rstrip(certificateRequested))
  @dtw_assign(certificateIssued,@dtw_rstrip(certificateIssued))
  @dtw_assign(premium,@dtw_rstrip(premium))
  @dtw_assign(electronicDoc,@dtw_rstrip(electronicDoc))
  @dtw_assign(coverageTermDate,@dtw_rstrip(coverageTermDate))
  @dtw_assign(planHolderSSN,@dtw_rstrip(planHolderSSN))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@comp", prCompany)
  @Concat_Field("@@facl", prFacility)
  @Concat_Field("@@pecp", hrCompany)
  @Concat_Field("@@empl", hrEmployee)
  @Concat_Field("@@sd@@", dependentNbr)
  @Concat_Field("@@ss@@", socSecNo)
  @Concat_Field("@@covr", benefitCode)
  @Concat_Field("@@plan", planCode)
  @Concat_Field("@@clas", classcode)
  @Concat_Field("@@elig", eligibilityDate)
  @Concat_Field("@@elec", enrollmentDate)
  @Concat_Field("@@dce@", dateEffective)
  @Concat_Field("@@vest", vestingDate)
  @Concat_Field("@@amt@", amount)
  @Concat_Field("@@ben1", BEN1)
  @Concat_Field("@@bss1", BSS1)
  @Concat_Field("@@bpc1", BPC1)
  @Concat_Field("@@ben2", BEN2)
  @Concat_Field("@@bss2", BSS2)
  @Concat_Field("@@bpc2", BPC2)
  @Concat_Field("@@ben3", BEN3)
  @Concat_Field("@@bss3", BSS3)
  @Concat_Field("@@bpc3", BPC3)
  @Concat_Field("@@ben4", BEN4)
  @Concat_Field("@@bss4", BSS4)
  @Concat_Field("@@bpc4", BPC4)
  @Concat_Field("@@ben5", BEN5)
  @Concat_Field("@@bss5", BSS5)
  @Concat_Field("@@bpc5", BPC5)
  @Concat_Field("@@ben6", BEN6)
  @Concat_Field("@@bss6", BSS6)
  @Concat_Field("@@bpc6", BPC6)
  @Concat_Field("@@unit", numberOfUnits)
  @Concat_Field("@@deda", deductionAmount)
  @Concat_Field("@@dedp", deductionPercent)
  @Concat_Field("@@phc@", planHolder)
  @Concat_Field("@@phss", planHolderSSN)
  @Concat_Field("@@id@@", identificationNbr)
  @Concat_Field("@@cert", certificateReceived)
  @Concat_Field("@@cisu", certificateIssuer)
  @Concat_Field("@@phon", phoneNumber)
  @Concat_Field("@@mnth", monthsOfCoverage)
  @Concat_Field("@@prec", preexistingCondDate)
  @Concat_Field("@@dct@", coverageTermDate)
  @Concat_Field("@@trcr", certificateRequested)
  @Concat_Field("@@trci", certificateIssued)
  @Concat_Field("@@ackn", employeeReceipt)
  @Concat_Field("@@carr", carrierNotified)
  @Concat_Field("@@prem", premium)
  @Concat_Field("@@edoc", electronicDoc)
  @Concat_Field("@@autd", updateDependents)
  @Concat_Field("@@eded", updateDeduction)
  @dtw_concat(edtVar, "}{", edtVar)
  @dtw_assign(editcovrplan, "N")
  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar, editcovrplan)

  @RtvFldDesc("CVCOMP=$(prCompany) AND CVFACL=$(prFacility) AND CVCOVR='$(benefitCode)' AND CVPLAN='$(planCode)'", "CBCOVR", "CVDESC", CVDESC)
  @RtvFldDesc("CCCODE='$(planCode)'", "CBCODE", "CCDESC", CCDESC)
  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(CVDESC), $(benefitCode), $(CCDESC), $(planCode), "", "", confMessage)
      %if (maintenanceCode == "D")
          %if ((fromD2w != "") && (fromD2w != "EmplBenefitSelect.d2w"))
              <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %else
              <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)emplBenefits.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %endif
      %elseif (fromD2w != "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;benefitCode=@dtw_rurlescseq(benefitCode)&amp;planCode=@dtw_rurlescseq(planCode)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)emplBenefits.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %elseif (maintenanceCode == "D")
      @DecatErr_Field("@@covr", "benefitCode")
      @Format_ConfMsg_Desc("", $(CVDESC), $(benefitCode), $(CCDESC), $(planCode), "<br>$(fieldValue)", "", confMessage)
      %if (fromD2w != "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)emplBenefits.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(d2wVarBase)&amp;benefitCode=@dtw_rurlescseq(benefitCode)&amp;planCode=@dtw_rurlescseq(planCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif

%}