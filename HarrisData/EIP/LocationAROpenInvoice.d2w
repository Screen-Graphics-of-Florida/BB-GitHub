%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "A/R Open Invoices"
  d2wName                 = "LocationAROpenInvoice.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  noMsg                   = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "DateEdit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "LOCAROPENINVOICE")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (V_HDMCRL>"0")
                          @dtw_concat(distinctSQL, "IVLOC||IVARAC||IVARSB||IVCURT", distinctSQL)
                          @dtw_concat(stmtSQL, " Select IVLOC, IVARAC, IVARSB, IVCURT, ", stmtSQL)
                      %else
                          @dtw_concat(distinctSQL, "IVLOC||IVARAC||IVARSB", distinctSQL)
                          @dtw_concat(stmtSQL, " Select IVLOC, IVARAC, IVARSB,  ", stmtSQL)
                      %endif
                      @dtw_concat(stmtSQL, " SUM(IVIVAM-IVNPOS) as IVIVAM, ", stmtSQL)
                      @dtw_concat(stmtSQL, " SUM(IVDAMT-IVONPO) as IVDBAL, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(max(LOCO#),' ') as LOCO#, coalesce(max(LOFAC#),' ') as LOFAC#, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(max(LOLNA1),CHAR(IVLOC)) as LOLNA1, coalesce(upper(max(LOLNA1)),CHAR(IVLOC)) as LOLNA1U, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(max(CFCFNM),' ') as CFCFNM, coalesce(max(CFCFNMU),' ') as CFCFNMU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(max(CHCHDS),' ') as CHCHDS, coalesce(max(CHCHDSU),' ') as CHCHDSU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(max(CYDESC),' ') as CYDESC, coalesce(upper(max(CYDESC)),' ') as CYDESCU, ", stmtSQL)
                      %if (V_HDMCRL>"0")
                          @dtw_concat(stmtSQL, " coalesce((Select Count(*) from HDINVC b Where b.IVLOC=a.IVLOC and b.IVARAC=a.IVARAC and b.IVARSB=b.IVARSB and b.IVCURT=a.IVCURT and b.IVIVAM-b.IVNPOS<>0 and b.IVIVCD<>'U') ,0) as INV_COUNT ", stmtSQL)
                      %else
                          @dtw_concat(stmtSQL, " coalesce((Select Count(*) from HDINVC b Where b.IVLOC=a.IVLOC and b.IVARAC=a.IVARAC and b.IVARSB=b.IVARSB and b.IVIVAM-b.IVNPOS<>0 and b.IVIVCD<>'U') ,0) as INV_COUNT ", stmtSQL)
                      %endif
                      @dtw_concat(fileSQL, " HDINVC a ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDLCTN on LOLOC#=IVLOC ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDCFAC on CFCO#=LOCO# and CFFAC#=LOFAC# ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDCHRT on CHACCT=IVARAC and CHSUB=IVARSB ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDCTYP on CYTYPE=IVCURT ", fileSQL)
                      @dtw_concat(selectSQL, " IVIVAM-IVNPOS<>0 ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %if (V_HDMCRL>"0")
                          @dtw_concat(stmtSQL, " Group By IVLOC, IVARAC, IVARSB, IVCURT ", stmtSQL)
                      %else
                          @dtw_concat(stmtSQL, " Group By IVLOC, IVARAC, IVARSB ", stmtSQL)
                      %endif
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64) profileHandle,
                                   CHAR(2)   dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      $(hrTagAttr)

      %if (formatToPrint == "")
          <form class="formClass" METHOD=POST name="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Location</th>
                      <th class="colhdr">Company/Facility</th>
                      <th class="colhdr">A/R Account</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchLocation" size="10" maxlength="30">
                          <input type="hidden" name="operLocation" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchCoFac" size="10" maxlength="30">
                          <input type="hidden" name="operCoFac" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchAcct" size="10" maxlength="30">
                          <input type="hidden" name="operAcct" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchLocation.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
     %endif

      <table $(contentTable)>
          <tr>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("LOLNA1U", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Location" title="Sequence By Location, Company/Facility">Location</a></th>
              @OrderBy_Sort("CFCFNMU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CoFac" title="Sequence By Company/Facility, Location">Company/Facility</a></th>
              @OrderBy_Sort("IVIVAM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=OpenPayable" title="Sequence By Open Payables, Location">Open Amount</a></th>
              @OrderBy_Sort("CHCHDSU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Account" title="Sequence By A/R Account, Location">A/R Account</a></th>
              %if (V_HDMCRL > "0")
                  @OrderBy_Sort("CYDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Currency" title="Sequence By Currency, Location">Currency</a></th>
                  @OrderBy_Sort("IVDBAL", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DomAmount" title="Sequence By Domestic Amount, Location">Domestic Amount</a></th>
                  %endif
              @OrderBy_Sort("INV_COUNT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=NumberInvoices" title="Sequence By Number Of Invoices, Location">Number Of Invoices</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"

              @Format_CoFac("$(V_LOCO#)", "$(V_LOFAC#)", "", F_CoFac)
              @Format_Acct("$(V_IVARAC)", "$(V_IVARSB)", "", F_AcctSub)
              @Format_Nbr($(V_IVIVAM), F_IVIVAM, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr($(V_IVDBAL), F_IVDBAL, "2", $(amtEditCode), "Y", "", "")

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)LocationSelect.d2w/REPORT$(genericVarBase)&amp;locationNumber=@dtw_rurlescseq(V_IVLOC)&amp;locationName=@dtw_rurlescseq(V_LOLNA1)" title="View Location [$(V_IVLOC)]">$(V_LOLNA1)</a></td>
                  <td class="colalph" $(helpCursor)><span title="$(F_CoFac)">$(V_CFCFNM)</span></td>
                  %if (V_HDMCRL > "0")
                      <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=177&amp;fKey1=IVLOC&amp;fVal1=@dtw_rurlescseq(V_IVLOC)&amp;fKey2=IVARAC&amp;fVal2=@dtw_rurlescseq(V_IVARAC)&amp;fKey3=IVARSB&amp;fVal3=@dtw_rurlescseq(V_IVARSB)&amp;fKey4=IVCURT&amp;fVal4=@dtw_rurlescseq(V_IVCURT)&amp;fKey5=IVOPEN&amp;fVal5=Y&amp;fDsc5=null&amp;fRel=Y" title="View Customer Invoices">$(F_IVIVAM)</a></td>
                  %else
                      <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=177&amp;fKey1=IVLOC&amp;fVal1=@dtw_rurlescseq(V_IVLOC)&amp;fKey2=IVARAC&amp;fVal2=@dtw_rurlescseq(V_IVARAC)&amp;fKey3=IVARSB&amp;fVal3=@dtw_rurlescseq(V_IVARSB)&amp;fKey4=IVOPEN&amp;fVal4=Y&amp;fDsc4=null&amp;fRel=Y" title="View Customer Invoices">$(F_IVIVAM)</a></td>
                  %endif
                  <td class="colalph" $(helpCursor)><span title="$(F_AcctSub)">$(V_CHCHDS)</span></td>
                  %if (V_HDMCRL > "0")
                      <td class="colalph" $(helpCursor)><span title="$(V_IVCURT)">$(V_CYDESC)</span></td>
                      <td class="colnmbr">$(F_IVDBAL)</td>
                  %endif
                  <td class="colnmbr">$(V_INV_COUNT)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  %if (V_HDMCRL>"0")
      @dtw_concat(distinctSQL, "IVLOC||IVARAC||IVARSB||IVCURT", distinctSQL)
      @dtw_concat(stmtSQL, " Select IVLOC, IVARAC, IVARSB, IVCURT, ", stmtSQL)
  %else
      @dtw_concat(distinctSQL, "IVLOC||IVARAC||IVARSB", distinctSQL)
      @dtw_concat(stmtSQL, " Select IVLOC, IVARAC, IVARSB,  ", stmtSQL)
  %endif
  @dtw_concat(stmtSQL, " SUM(IVIVAM-IVNPOS) as IVIVAM, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(max(LOCO#),' ') as LOCO#, coalesce(max(LOFAC#),' ') as LOFAC#, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(max(LOLNA1),CHAR(IVLOC)) as LOLNA1, coalesce(upper(max(LOLNA1)),CHAR(IVLOC)) as LOLNA1U, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(max(CFCFNM),' ') as CFCFNM, coalesce(max(CFCFNMU),' ') as CFCFNMU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(max(CHCHDS),' ') as CHCHDS, coalesce(max(CHCHDSU),' ') as CHCHDSU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(max(CYDESC),' ') as CYDESC, coalesce(upper(max(CYDESC)),' ') as CYDESCU, ", stmtSQL)
  %if (V_HDMCRL>"0")
      @dtw_concat(stmtSQL, " coalesce((Select Count(*) from HDINVC b Where b.IVLOC=a.IVLOC and b.IVARAC=a.IVARAC and b.IVARSB=b.IVARSB and b.IVCURT=a.IVCURT and b.IVIVAM-b.IVNPOS<>0 and b.IVIVCD<>'U') ,0) as INV_COUNT ", stmtSQL)
  %else
      @dtw_concat(stmtSQL, " coalesce((Select Count(*) from HDINVC b Where b.IVLOC=a.IVLOC and b.IVARAC=a.IVARAC and b.IVARSB=b.IVARSB and b.IVIVAM-b.IVNPOS<>0 and b.IVIVCD<>'U') ,0) as INV_COUNT ", stmtSQL)
  %endif
  @dtw_concat(fileSQL, " HDINVC ", fileSQL)
  @dtw_concat(fileSQL, " left join HDLCTN on LOLOC#=IVLOC ", fileSQL)
  @dtw_concat(fileSQL, " left join HDCFAC on CFCO#=LOCO# and CFFAC#=LOFAC# ", fileSQL)
  @dtw_concat(fileSQL, " left join HDCHRT on CHACCT=IVARAC and CHSUB=IVARSB ", fileSQL)
  @dtw_concat(fileSQL, " left join HDCTYP on CYTYPE=IVCURT ", fileSQL)
  @dtw_concat(selectSQL, " IVIVAM-IVNPOS<>0 ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  %if (V_HDMCRL>"0")
      @dtw_concat(stmtSQL, " Group By IVLOC, IVARAC, IVARSB, IVCURT ", stmtSQL)
  %else
      @dtw_concat(stmtSQL, " Group By IVLOC, IVARAC, IVARSB ", stmtSQL)
  %endif
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_XMLQuery (IN  CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("LocationAROpenList")
          %ROW{
              @XMLIDTag(V_IVLOC, "LocationAROpen ID")
                  @XMLTag(V_IVLOC, "Location")
                  @XMLTag(V_IVIVAM, "OpenPayable")
                  @XMLTag(V_INV_COUNT, "InvoiceCount")
                  @XMLTag(V_LOLNA1, "LocationName")
                  @XMLTag(V_LOCO#, "BalanceSheetCompany")
                  @XMLTag(V_LOFAC#, "BalanceSheetFacility")
                  @XMLTag(V_IVARAC, "ARAccountNumber")
                  @XMLTag(V_IVARSB, "ARSubaccountNumber")
                  @XMLTag(V_IVCURT,  "CurrencyType")
              @XMLEndTag("LocationAROpen")
          %}
      @XMLEndTag("LocationAROpenList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "LOLNA1U")
          @DTW_ASSIGN(orderByDisplay, "Location")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Location")
      %if (orderBy == "LOLNA1U")
          @DTW_ASSIGN(orderBy, "LOLNA1U DESC")
          @DTW_ASSIGN(orderByDisplay, "Location (descending)")
      %else
          @DTW_ASSIGN(orderBy, "LOLNA1U")
          @DTW_ASSIGN(orderByDisplay, "Location")
      %endif
  %elif (sequence == "CoFac")
      %if (orderBy == "CFCFNMU,LOLNA1U")
          @DTW_ASSIGN(orderBy, "CFCFNMU DESC,LOLNA1U")
          @DTW_ASSIGN(orderByDisplay, "Company/Facility (descending), Location")
      %else
          @DTW_ASSIGN(orderBy, "CFCFNMU,LOLNA1U")
          @DTW_ASSIGN(orderByDisplay, "Company/Facility, Location")
      %endif
  %elif (sequence == "OpenPayable")
      %if (orderBy == "IVIVAM,LOLNA1U")
          @DTW_ASSIGN(orderBy, "IVIVAM DESC,LOLNA1U")
          @DTW_ASSIGN(orderByDisplay, "Open Payables (descending), Location")
      %else
          @DTW_ASSIGN(orderBy, "IVIVAM,LOLNA1U")
          @DTW_ASSIGN(orderByDisplay, "Open Payables, Location")
      %endif
  %elif (sequence == "Account")
      %if (orderBy == "CHCHDSU,LOLNA1U")
          @DTW_ASSIGN(orderBy, "CHCHDSU DESC,LOLNA1U")
          @DTW_ASSIGN(orderByDisplay, "A/R Account (descending), Location")
      %else
          @DTW_ASSIGN(orderBy, "CHCHDSU,LOLNA1U")
          @DTW_ASSIGN(orderByDisplay, "A/R Account, Location")
      %endif
  %elif (sequence == "Currency")
      %if (orderBy == "CYDESCU,LOLNA1U")
          @DTW_ASSIGN(orderBy, "CYDESCU DESC,LOLNA1U")
          @DTW_ASSIGN(orderByDisplay, "Currency (descending), Location")
      %else
          @DTW_ASSIGN(orderBy, "CYDESCU,LOLNA1U")
          @DTW_ASSIGN(orderByDisplay, "Currency, Location")
      %endif
  %elif (sequence == "DomAmount")
      %if (orderBy == "IVDBAL,LOLNA1U")
          @DTW_ASSIGN(orderBy, "CYDESCU DESC,LOLNA1U")
          @DTW_ASSIGN(orderByDisplay, "Domestic Amount (descending), Location")
      %else
          @DTW_ASSIGN(orderBy, "IVDBAL,LOLNA1U")
          @DTW_ASSIGN(orderByDisplay, "Domestic Amount, Location")
      %endif
  %elif (sequence == "NumberInvoices")
      %if (orderBy == "INV_COUNT,LOLNA1U")
          @DTW_ASSIGN(orderBy, "INV_COUNT DESC,LOLNA1U")
          @DTW_ASSIGN(orderByDisplay, "Number Of Invoices (descending), Location")
      %else
          @DTW_ASSIGN(orderBy, "INV_COUNT,LOLNA1U")
          @DTW_ASSIGN(orderByDisplay, "Number Of Invoices, Location")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          @dtw_assign(formName, "Search")
          %INCLUDE "$(headInclude)"
          <link rel=stylesheet type="text/css" href="$(homeURL)$(homePath)$(GLDDStyleSheet)">
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "GLUNPOSTJRNLSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Location</td>
                              @dtw_assign(operNbr, "operLocation")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchLocation" size="10" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Company/Facility</td>
                              @dtw_assign(operNbr, "operCoFac")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCoFac" size="10" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">A/R Account</td>
                              @dtw_assign(operNbr, "operAcct")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchAcct" size="10" maxlength="30"></td>
                          </tr>

                          %if (V_HDMCRL>"0")
                              <tr><td class="dsphdr">Currency Type</td>
                                  @dtw_assign(operNbr, "operCurrency")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchCurrency" size="3" maxlength="3"></td>
                              </tr>
                          %endif

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchPeriod.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("Upper(LOLNA1)", "Location", $(srchLocation), "U", operLocation, "A")
  @Build_WildCard ("CFCFNMU", "Company/Facility", $(srchCoFac), "U", operCoFac, "A")
  @Build_WildCard ("CHCHDSU", "A/R Account", $(srchAcct), "U", operAcct, "A")
  @Build_WildCard ("IVCURT", "Currency Type", $(srchCurrency), "U", operCurrency, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}