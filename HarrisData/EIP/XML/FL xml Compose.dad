						<element_node name="ContributionDue">	
							<text_node>
								<column name="CONTRIBUTIONDUE"/>
							</text_node>								
						</element_node>
						<element_node name="UIAmountPaid">	
							<text_node>
								<column name="UIAMOUNTPAID"/>
							</text_node>								
						</element_node>
						<element_node name="UIInterest">	
							<text_node>
								<column name="UIINTEREST"/>
							</text_node>								
						</element_node>
						<element_node name="UIPenalty">	
							<text_node>
								<column name="UIPenalty"/>
							</text_node>								
						</element_node>
						<element_node name="UITotalDue">	
							<text_node>
								<column name="UITOTALDUE"/>
							</text_node>								
						</element_node>
						<element_node name="CreditWeeks">	
							<text_node>
								<column name="CREDITWEEKS"/>
							</text_node>								
						</element_node>
						<element_node name="PayRoll">	
							<element_node name="Employee" multi_occurrence="YES">
								<element_node name="SSN">	
									<text_node>
										<column name="SSN"/>
									</text_node>								
								</element_node>
								<element_node name="Employee">
									<element_node name="FirstName">	
										<text_node>
											<column name="FIRSTNAME"/>
										</text_node>								
									</element_node>
									<element_node name="MiddleName">	
										<text_node>
											<column name="MIDDLENAME"/>
										</text_node>								
									</element_node>
									<element_node name="LastName">	
										<text_node>
											<column name="LASTNAME"/>
										</text_node>								
									</element_node>
								</element_node>
								<element_node name="TotalWages">	
									<text_node>
