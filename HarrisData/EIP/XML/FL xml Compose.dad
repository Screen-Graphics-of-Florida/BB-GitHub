								</element_node>
								<element_node name="Reason">
									<text_node>
										<column name="REASON"/>
									</text_node>
								</element_node>
							</element_node>
							<element_node name="TIN">
								<element_node name="TypeTIN">
									<text_node>
										<column name="TYPETIN"/>
									</text_node>
								</element_node>
								<element_node name="TINTypeValue">
									<text_node>
										<column name="TINTYPEVALUE"/>
									</text_node>
								</element_node>
							</element_node>
							<element_node name="StateEIN">
								<element_node name="TypeStateEIN">
									<text_node>
										<column name="TYPESTATEEIN"/>
									</text_node>
								</element_node>
								<element_node name="StateEINValue">
									<text_node>
										<column name="STATEEINVALUE"/>
