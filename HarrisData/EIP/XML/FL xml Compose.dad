<?xml version="1.0"?>
<!DOCTYPE DAD SYSTEM "dad.dtd">
<DAD>
	<validation>NO</validation>
	<Xcollection>
		<SQL_stmt>
		  select 1 as X, xmlns, xsi, schemalocation, jurisdiction, transmissionid, timestampa, processtype, etin, originid, timestampc, itemcount, contentlocation, agentidentifier, documentcount, documenttype, documentid, documentname, uitotalwages, excesswages, uitaxablewages, contributionrate, contributiondue, uiamountpaid, uiinterest, uipenalty, uitotaldue, creditweeks, numberofemployees, month1employees, month2employees, month3employees, quarter, taxyear, softwareid, returntype, statecode, action, reason, typetin, tintypevalue, typestateein, stateeinvalue, businessname, addressline, city, stateorprovince, zipcode, fullname, phone, emailaddress, ssn, firstname, middlename, lastname, totalwages1, taxablewages1, totalwages2, taxablewages2, taxstate2 from w6hdsdata.flxmlview, w6hdsdata.employee b join w6hdsdata.outstwages c  on b.primarykey=c.foreignkey  ORDER BY X, ssn
               </SQL_stmt>
		<prolog>?xml version="1.0" encoding="UTF-8" ?</prolog>
		<root_node>
		<element_node name="Transmission">
			<attribute_node name="xmlns">
				<column name="XMLNS"/>
			</attribute_node>
			<attribute_node name="xmlns:xsi">
				<column name="XSI"/>
			</attribute_node>
			<attribute_node name="xsi:schemaLocation">
				<column name="SCHEMALOCATION"/>
			</attribute_node>
			<element_node name="TransmissionHeader">
				<element_node name="Jurisdiction">
					<text_node>
						<column name="JURISDICTION"/>
					</text_node>
				</element_node>
				<element_node name="TransmissionId">
					<text_node>
						<column name="TRANSMISSIONID"/>
					</text_node>
				</element_node>
				<element_node name="Timestamp">
					<text_node>
						<column name="TIMESTAMPA"/>
					</text_node>
				</element_node>				
				<element_node name="Transmitter">
					<element_node name="ETIN">
						<text_node>
							<column name="ETIN"/>
						</text_node>
					</element_node>
				</element_node>
				<element_node name="ProcessType">
					<text_node>
						<column name="PROCESSTYPE"/>
					</text_node>
				</element_node>
			</element_node>
			<element_node name="OriginHeaders">
				<element_node name="ReturnOriginHeader">
					<element_node name="OriginId">
						<text_node>
							<column name="ORIGINID"/>
						</text_node>
					</element_node>
					<element_node name="Timestamp">
						<text_node>
							<column name="TIMESTAMPC"/>
						</text_node>
					</element_node>
					<element_node name="OriginManifest">
						<attribute_node name="itemCount">
						    <column name="ITEMCOUNT"/>
						</attribute_node>
						<element_node name="ItemReference">
							<attribute_node name="contentLocation">
								<column name="CONTENTLOCATION"/>
							</attribute_node>
						</element_node>
					</element_node>
					<element_node name="Originator">
						<element_node name="AgentIdentifier">
							<text_node>
								<column name="AGENTIDENTIFIER"/>
							</text_node>
						</element_node>
					</element_node>
				</element_node>
			</element_node>
			<element_node name="ReturnData">
				<attribute_node name="documentCount">
					<column name="DOCUMENTCOUNT"/>
				</attribute_node>
				<element_node name="StateReturn">
					<element_node name="StateUI">
						<attribute_node name="documentType">
							<column name="DOCUMENTTYPE"/>
						</attribute_node>
						<attribute_node name="documentId">
							<column name="DOCUMENTID"/>
						</attribute_node>
						<attribute_node name="documentName">
							<column name="DOCUMENTNAME"/>
						</attribute_node>
						<element_node name="ReturnHeader">
							<element_node name="Quarter">
								<text_node>
									<column name="QUARTER"/>
								</text_node>
							</element_node>
							<element_node name="Taxyear">
								<text_node>
									<column name="TAXYEAR"/>
