%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Customer Labels"
  d2wName                 = "CustomerLabels.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)&amp;apid=@dtw_rurlescseq(apid)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "06"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromLocationNumber, 3, 0) &&
                      editNum(document.Chg.toLocationNumber, 3, 0) &&
                      editNum(document.Chg.fromCustomerNumber, 7, 0) &&
                      editNum(document.Chg.toCustomerNumber, 7, 0) &&
                      editNum(document.Chg.fromSalesmanNumber, 3, 0) &&
                      editNum(document.Chg.toSalesmanNumber, 3, 0) &&
                      editFromToAll(document.Chg.fromLocationNumber, document.Chg.toLocationNumber, document.Chg.allLocationNumber, 3) &&
                      editFromToAll(document.Chg.fromCustomerNumber, document.Chg.toCustomerNumber, document.Chg.allCustomerNumber, 7) &&
                      editFromToAll(document.Chg.fromAlphaSequence, document.Chg.toAlphaSequence, document.Chg.allAlphaSequence, "A") &&
                      editFromToAll(document.Chg.fromSalesmanNumber, document.Chg.toSalesmanNumber, document.Chg.allSalesmanNumber, 3) &&
                      editFromToAll(document.Chg.fromCustomerClassCode, document.Chg.toCustomerClassCode, document.Chg.allCustomerClassCode, "A") &&
                      editFromToAll(document.Chg.fromZipCode, document.Chg.toZipCode, document.Chg.allZipCode, "A"))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CUSTOMERMASTERLABELSLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromLocationNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@sloc", "sortLocationNumber")        @dtw_assign(Err_N3SLOC,  fieldValue)
                                  @DecatErr_Field("@@lnbr", "fiveUp")        @dtw_assign(Err_N2CONT,  fieldValue)
                                  @DecatErr_Field("@@scus", "sortCustomerNumber")        @dtw_assign(Err_N3SCUS,  fieldValue)
                                  @DecatErr_Field("@@salp", "sortAlphaSequence")        @dtw_assign(Err_N3SALP,  fieldValue)
                                  @DecatErr_Field("@@ssls", "sortSalesmanNumber")        @dtw_assign(Err_N3SSLS,  fieldValue)
                                  @DecatErr_Field("@@scls", "sortCustomerClassCode")        @dtw_assign(Err_N3SCLS,  fieldValue)
                                  @DecatErr_Field("@@szip", "sortZipCode")        @dtw_assign(Err_N3SZIP,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@type")  @dtw_assign(V_N1LABL,  fieldValue)
                                  @Decat_Field("@@lnbr")  @dtw_assign(V_N2CONT,  fieldValue)
                                  @Decat_Field("@@floc")  @dtw_assign(V_N3FLOC,  fieldValue)
                                  @Decat_Field("@@tloc")  @dtw_assign(V_N3TLOC,  fieldValue)
                                  @Decat_Field("@@aloc")  @dtw_assign(V_N3ALOC,  fieldValue)
                                  @Decat_Field("@@sloc")  @dtw_assign(V_N3SLOC,  fieldValue)
                                  @Decat_Field("@@fcus")  @dtw_assign(V_N3FCUS,  fieldValue)
                                  @Decat_Field("@@tcus")  @dtw_assign(V_N3TCUS,  fieldValue)
                                  @Decat_Field("@@acus")  @dtw_assign(V_N3ACUS,  fieldValue)
                                  @Decat_Field("@@scus")  @dtw_assign(V_N3SCUS,  fieldValue)
                                  @Decat_Field("@@falp")  @dtw_assign(V_N3FALP,  fieldValue)
                                  @Decat_Field("@@talp")  @dtw_assign(V_N3TALP,  fieldValue)
                                  @Decat_Field("@@aalp")  @dtw_assign(V_N3AALP,  fieldValue)
                                  @Decat_Field("@@salp")  @dtw_assign(V_N3SALP,  fieldValue)
                                  @Decat_Field("@@fsls")  @dtw_assign(V_N3FSLS,  fieldValue)
                                  @Decat_Field("@@tsls")  @dtw_assign(V_N3TSLS,  fieldValue)
                                  @Decat_Field("@@asls")  @dtw_assign(V_N3ASLS,  fieldValue)
                                  @Decat_Field("@@ssls")  @dtw_assign(V_N3SSLS,  fieldValue)
                                  @Decat_Field("@@fcls")  @dtw_assign(V_N3FCLS,  fieldValue)
                                  @Decat_Field("@@tcls")  @dtw_assign(V_N3TCLS,  fieldValue)
                                  @Decat_Field("@@acls")  @dtw_assign(V_N3ACLS,  fieldValue)
                                  @Decat_Field("@@scls")  @dtw_assign(V_N3SCLS,  fieldValue)
                                  @Decat_Field("@@fzip")  @dtw_assign(V_N3FZIP,  fieldValue)
                                  @Decat_Field("@@tzip")  @dtw_assign(V_N3TZIP,  fieldValue)
                                  @Decat_Field("@@azip")  @dtw_assign(V_N3AZIP,  fieldValue)
                                  @Decat_Field("@@szip")  @dtw_assign(V_N3SZIP,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1LABL == "02")
                                      @dtw_assign(standard, "")
                                      @dtw_assign(international, "CHECKED")
                                  %else
                                      @dtw_assign(standard, "CHECKED")
                                      @dtw_assign(international, "")
                                  %endif
                                  %if (V_N2CONT == "01")
                                      @dtw_assign(oneUp, "CHECKED")
                                      @dtw_assign(twoUp, "")
                                      @dtw_assign(threeUp, "")
                                      @dtw_assign(fourUp, "")
                                      @dtw_assign(fiveUp, "")
                                  %elif (V_N2CONT == "02")
                                      @dtw_assign(oneUp, "")
                                      @dtw_assign(twoUp, "CHECKED")
                                      @dtw_assign(threeUp, "")
                                      @dtw_assign(fourUp, "")
                                      @dtw_assign(fiveUp, "")
                                  %elif (V_N2CONT == "03")
                                      @dtw_assign(oneUp, "")
                                      @dtw_assign(twoUp, "")
                                      @dtw_assign(threeUp, "CHECKED")
                                      @dtw_assign(fourUp, "")
                                      @dtw_assign(fiveUp, "")
                                  %elif (V_N2CONT == "04")
                                      @dtw_assign(oneUp, "")
                                      @dtw_assign(twoUp, "")
                                      @dtw_assign(threeUp, "")
                                      @dtw_assign(fourUp, "CHECKED")
                                      @dtw_assign(fiveUp, "")
                                  %elif (V_N2CONT == "05")
                                      @dtw_assign(oneUp, "")
                                      @dtw_assign(twoUp, "")
                                      @dtw_assign(threeUp, "")
                                      @dtw_assign(fourUp, "")
                                      @dtw_assign(fiveUp, "CHECKED")
                                  %endif
                                  %if (V_N3ALOC == "ALL")
                                      @dtw_assign(checkedallLocationNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallLocationNumber, "")
                                  %endif
                                  %if (V_N3ACUS == "ALL")
                                      @dtw_assign(checkedallCustomerNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallCustomerNumber, "")
                                  %endif
                                  %if (V_N3AALP == "ALL")
                                      @dtw_assign(checkedallAlphaSequence, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallAlphaSequence, "")
                                  %endif
                                  %if (V_N3ASLS == "ALL")
                                      @dtw_assign(checkedallSalesmanNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallSalesmanNumber, "")
                                  %endif
                                  %if (V_N3ACLS == "ALL")
                                      @dtw_assign(checkedallCustomerClassCode, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallCustomerClassCode, "")
                                  %endif
                                  %if (V_N3AZIP == "ALL")
                                      @dtw_assign(checkedallZipCode, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallZipCode, "")
                                  %endif
                              %else
                                  @dtw_assign(standard, "CHECKED")
                                  @dtw_assign(international, "")
                                  @dtw_assign(oneUp, "CHECKED")
                                  @dtw_assign(twoUp, "")
                                  @dtw_assign(threeUp, "")
                                  @dtw_assign(fourUp, "")
                                  @dtw_assign(fiveUp, "")
                                  @dtw_assign(checkedallLocationNumber, "CHECKED")
                                  @dtw_assign(checkedallCustomerNumber, "CHECKED")
                                  @dtw_assign(checkedallAlphaSequence, "CHECKED")
                                  @dtw_assign(checkedallSalesmanNumber, "CHECKED")
                                  @dtw_assign(checkedallCustomerClassCode, "CHECKED")
                                  @dtw_assign(checkedallZipCode, "CHECKED")
                              %endif

                              <tr><td class="dsphdr">Label Type Selection</td>
                                  <td class="inputnmbr"><input type="radio" name="labelType" VALUE='01' $(standard)>Standard</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input type="radio" name="labelType" VALUE='02' $(international)>International</td>
                              </tr>

                              @SetTextOvr(Err_N2CONT)
                              %if (textOvr == "") @SetTextOvr(Err_N2CONT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Label Number Selection</span></td>
                                  <td class="inputnmbr"><input type="radio" name="labelNumber" VALUE='01' $(oneUp)>1-Up</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input type="radio" name="labelNumber" VALUE='02' $(twoUp)>2-Up</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input type="radio" name="labelNumber" VALUE='03' $(threeUp)>3-Up</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input type="radio" name="labelNumber" VALUE='04' $(fourUp)>4-Up</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input type="radio" name="labelNumber" VALUE='05' $(fiveUp)>5-Up</td>
                              </tr>
                              @DspErrMsg(Err_N2CONT)
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                              </tr>

                              @SetTextOvr(Err_N3FLOC)
                              %if (textOvr == "") @SetTextOvr(Err_N3SLOC) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Location</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromLocationNumber" value="$(V_N3FLOC)" size="7" maxlength="3">
                                                        <a href="$(homeURL)$(phpPath)LocationSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromLocationNumber&amp;fldDesc=fromLocationNumberDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="fromLocationNumberDesc"></td>
                                  <td class="inputnmbr"><input type="text" name="toLocationNumber" value="$(V_N3TLOC)" size="7" maxlength="3">
                                                        <a href="$(homeURL)$(phpPath)LocationSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toLocationNumber&amp;fldDesc=toLocationNumberDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="toLocationNumberDesc"></td>
                                  <td class="inputalph"><input type="checkbox" name="allLocationNumber" value='ALL' $(checkedallLocationNumber) onClick="if (this.checked) this.form.fromLocationNumber.value='', this.form.toLocationNumber.value='';"></td>
                                  @Build_Sort_Select("sortLocationNumber", "$(V_N3SLOC)")
                              </tr>
                              @DspErrMsg(Err_N3SLOC)

                              @SetTextOvr(Err_N3FCUS)
                              %if (textOvr == "") @SetTextOvr(Err_N3SCUS) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Customer</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromCustomerNumber" value="$(V_N3FCUS)" size="7" maxlength="7">
                                                        <a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromCustomerNumber&amp;fldDesc=fcusName" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="fcusName"></td>
                                  <td class="inputnmbr"><input type="text" name="toCustomerNumber" value="$(V_N3TCUS)" size="7" maxlength="7">
                                                        <a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toCustomerNumber&amp;fldDesc=tcusName" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="tcusName"></td>
                                  <td class="inputalph"><input type="checkbox" name="allCustomerNumber" value='ALL' $(checkedallCustomerNumber) onClick="if (this.checked) this.form.fromCustomerNumber.value='', this.form.toCustomerNumber.value='';"></td>
                                  @Build_Sort_Select("sortCustomerNumber", "$(V_N3SCUS)")
                              </tr>
                              @DspErrMsg(Err_N3SCUS)

                              @SetTextOvr(Err_N3FALP)
                              %if (textOvr == "") @SetTextOvr(Err_N3SALP) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Alpha Sequence</span></td>
                                  <td class="inputalph"><input type="text" name="fromAlphaSequence" value="$(V_N3FALP)" size="7" maxlength="4"></td>
                                  <td class="inputalph"><input type="text" name="toAlphaSequence" value="$(V_N3TALP)" size="7" maxlength="4"></td>
                                  <td class="inputalph"><input type="checkbox" name="allAlphaSequence" value='ALL' $(checkedallAlphaSequence) onClick="if (this.checked) this.form.fromAlphaSequence.value='', this.form.toAlphaSequence.value='';"></td>
                                  @Build_Sort_Select("sortAlphaSequence", "$(V_N3SALP)")
                              </tr>
                              @DspErrMsg(Err_N3SALP)

                              @SetTextOvr(Err_N3FSLS)
                              %if (textOvr == "") @SetTextOvr(Err_N3SSLS) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Salesman</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromSalesmanNumber" value="$(V_N3FSLS)" size="7" maxlength="3">
                                                        <a href="$(homeURL)$(phpPath)SalesmanSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromSalesmanNumber&amp;fldDesc=salesmanName" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="salesmanName"></td>
                                  <td class="inputnmbr"><input type="text" name="toSalesmanNumber" value="$(V_N3TSLS)" size="7" maxlength="3">
                                                        <a href="$(homeURL)$(phpPath)SalesmanSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toSalesmanNumber&amp;fldDesc=salesmanName" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="salesmanName"></td>
                                  <td class="inputalph"><input type="checkbox" name="allSalesmanNumber" value='ALL' $(checkedallSalesmanNumber) onClick="if (this.checked) this.form.fromSalesmanNumber.value='', this.form.toSalesmanNumber.value='';"></td>
                                  @Build_Sort_Select("sortSalesmanNumber", "$(V_N3SSLS)")
                              </tr>
                              @DspErrMsg(Err_N3SSLS)

                              @SetTextOvr(Err_N3FCLS)
                              %if (textOvr == "") @SetTextOvr(Err_N3SCLS) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Customer Class Code</span></td>
                                  <td class="inputalph"><input type="text" name="fromCustomerClassCode" value="$(V_N3FCLS)" size="7" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)CustomerClassSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromCustomerClassCode&amp;fldDesc=fromCustomerClassCodeDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="fromCustomerClassCodeDesc"></td>
                                  <td class="inputalph"><input type="text" name="toCustomerClassCode" value="$(V_N3TCLS)" size="7" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)CustomerClassSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toCustomerClassCode&amp;fldDesc=toCustomerClassCodeDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="toCustomerClassCodeDesc"></td>
                                  <td class="inputalph"><input type="checkbox" name="allCustomerClassCode" value='ALL' $(checkedallCustomerClassCode) onClick="if (this.checked) this.form.fromCustomerClassCode.value='', this.form.toCustomerClassCode.value='';"></td>
                                  @Build_Sort_Select("sortCustomerClassCode", "$(V_N3SCLS)")
                              </tr>
                              @DspErrMsg(Err_N3SCLS)

                              @SetTextOvr(Err_N3FZIP)
                              %if (textOvr == "") @SetTextOvr(Err_N3SZIP) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Zip Code</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromZipCode" value="$(V_N3FZIP)" size="18" maxlength="18"></td>
                                  <td class="inputnmbr"><input type="text" name="toZipCode" value="$(V_N3TZIP)" size="18" maxlength="18"></td>
                                  <td class="inputalph"><input type="checkbox" name="allZipCode" value='ALL' $(checkedallZipCode) onClick="if (this.checked) this.form.fromZipCode.value='', this.form.toZipCode.value='';"></td>
                                  @Build_Sort_Select("sortZipCode", "$(V_N3SZIP)")
                              </tr>
                              @DspErrMsg(Err_N3SZIP)
                          </table>

                          @dtw_assign(envProgram, "HHDLBL")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HHDLBS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allLocationNumber)
  @dtw_mUPPERCASE(allCustomerNumber)
  @dtw_mUPPERCASE(fromAlphaSequence)
  @dtw_mUPPERCASE(toAlphaSequence)
  @dtw_mUPPERCASE(allAlphaSequence)
  @dtw_mUPPERCASE(allSalesmanNumber)
  @dtw_mUPPERCASE(fromCustomerClassCode)
  @dtw_mUPPERCASE(toCustomerClassCode)
  @dtw_mUPPERCASE(allCustomerClassCode)
  @dtw_mUPPERCASE(fromZipCode)
  @dtw_mUPPERCASE(toZipCode)
  @dtw_mUPPERCASE(allZipCode)

  @dtw_assign(fromLocationNumber,@dtw_rstrip(fromLocationNumber))
  @dtw_assign(toLocationNumber,@dtw_rstrip(toLocationNumber))
  @dtw_assign(sortLocationNumber,@dtw_rstrip(sortLocationNumber))
  @dtw_assign(fromCustomerNumber,@dtw_rstrip(fromCustomerNumber))
  @dtw_assign(toCustomerNumber,@dtw_rstrip(toCustomerNumber))
  @dtw_assign(sortCustomerNumber,@dtw_rstrip(sortCustomerNumber))
  @dtw_assign(sortAlphaSequence,@dtw_rstrip(sortAlphaSequence))
  @dtw_assign(fromSalesmanNumber,@dtw_rstrip(fromSalesmanNumber))
  @dtw_assign(toSalesmanNumber,@dtw_rstrip(toSalesmanNumber))
  @dtw_assign(sortSalesmanNumber,@dtw_rstrip(sortSalesmanNumber))
  @dtw_assign(sortCustomerClassCode,@dtw_rstrip(sortCustomerClassCode))
  @dtw_assign(sortZipCode,@dtw_rstrip(sortZipCode))


  %if (allLocationNumber != "ALL")
      @dtw_assign(allLocationNumber, "")
  %endif
  %if (allCustomerNumber != "ALL")
      @dtw_assign(allCustomerNumber, "")
  %endif
  %if (allAlphaSequence != "ALL")
      @dtw_assign(allAlphaSequence, "")
  %endif
  %if (allSalesmanNumber != "ALL")
      @dtw_assign(allSalesmanNumber, "")
  %endif
  %if (allCustomerClassCode != "ALL")
      @dtw_assign(allCustomerClassCode, "")
  %endif
  %if (allZipCode != "ALL")
      @dtw_assign(allZipCode, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@type", labelType)
  @Concat_Field("@@lnbr", labelNumber)
  @Concat_Field("@@apid", apid)
  @Concat_Field("@@floc", fromLocationNumber)
  @Concat_Field("@@tloc", toLocationNumber)
  @Concat_Field("@@aloc", allLocationNumber)
  @Concat_Field("@@sloc", sortLocationNumber)
  @Concat_Field("@@fcus", fromCustomerNumber)
  @Concat_Field("@@tcus", toCustomerNumber)
  @Concat_Field("@@acus", allCustomerNumber)
  @Concat_Field("@@scus", sortCustomerNumber)
  @Concat_Field("@@falp", fromAlphaSequence)
  @Concat_Field("@@talp", toAlphaSequence)
  @Concat_Field("@@aalp", allAlphaSequence)
  @Concat_Field("@@salp", sortAlphaSequence)
  @Concat_Field("@@fsls", fromSalesmanNumber)
  @Concat_Field("@@tsls", toSalesmanNumber)
  @Concat_Field("@@asls", allSalesmanNumber)
  @Concat_Field("@@ssls", sortSalesmanNumber)
  @Concat_Field("@@fcls", fromCustomerClassCode)
  @Concat_Field("@@tcls", toCustomerClassCode)
  @Concat_Field("@@acls", allCustomerClassCode)
  @Concat_Field("@@scls", sortCustomerClassCode)
  @Concat_Field("@@fzip", fromZipCode)
  @Concat_Field("@@tzip", toZipCode)
  @Concat_Field("@@azip", allZipCode)
  @Concat_Field("@@szip", sortZipCode)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
