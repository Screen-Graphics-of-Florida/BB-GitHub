%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "O/E Control Maintenance"
  d2wName                 = "OEControlMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName             = "HOECTU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "7"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "dateedit.icl"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.oeDistributionPeriod.value =="" ||
                      document.Chg.reclaimResourceLevel.value =="" ||
                      document.Chg.numberOfDaysPastDue.value =="" ||
                      document.Chg.lastInvoiceNumberUsed.value =="" ||
                      document.Chg.dueDateUsed.value =="" ||
                      document.Chg.oeToARAudit.value =="" ||
                      document.Chg.numberOfDataQueueProcessingJobs.value =="" ||
                      document.Chg.defaultBankNumber.value =="" ||
                      (document.Chg.accountsReceivableAccountNumber.value =="" &&
                       document.Chg.accountsReceivableSubaccountNumber.value =="") ||
                      (document.Chg.freightAccountNumber.value =="" &&
                       document.Chg.freightSubaccountNumber.value =="") ||
                      (document.Chg.salesTaxAccountNumber.value =="" &&
                       document.Chg.salesTaxSubaccountNumber.value =="") ||
                      (document.Chg.specialChargesAccountNumber.value =="" &&
                       document.Chg.specialChargesSubaccountNumber.value =="") ||
                       document.Chg.onlineCreditCardAuthorization.value =="" ||
                       document.Chg.defaultBankNumber.value =="")
                         {alert("$(reqFieldError)"); return false;}

                  if (editNum(document.Chg.oeDistributionPeriod, 4, 0) &&
                      editNum(document.Chg.lastOrderNumberUsed, 8, 0) &&
                      editNum(document.Chg.pastDueDollarAmount, 7, 0) &&
                      editNum(document.Chg.numberOfDaysPastDue, 3, 0) &&
                      editNum(document.Chg.lastInvoiceNumberUsed, 7, 0) &&
                      editNum(document.Chg.dueDateUsed, 1, 0) &&
                      editNum(document.Chg.numberOfDataQueueProcessingJobs, 2, 0) &&
                      editNum(document.Chg.defaultBankNumber, 2, 0) &&
                      editNum(document.Chg.accountsReceivableAccountNumber, 4, 0) &&
                      editNum(document.Chg.accountsReceivableSubaccountNumber, 4, 0) &&
                      editNum(document.Chg.freightAccountNumber, 4, 0) &&
                      editNum(document.Chg.freightSubaccountNumber, 4, 0) &&
                      editNum(document.Chg.salesTaxAccountNumber, 4, 0) &&
                      editNum(document.Chg.salesTaxSubaccountNumber, 4, 0) &&
                      editNum(document.Chg.specialChargesAccountNumber, 4, 0) &&
                      editNum(document.Chg.specialChargesSubaccountNumber, 4, 0) &&
                      editNum(document.Chg.lastPackingListNumber, 8, 0) &&
                      editNum(document.Chg.lastBillOfLadingNumber, 8, 0))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
	       %INCLUDE "numedit.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "OECONTROLMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select OECTRL.*, CEPD$ as CEPD, OEIVCT.* ", stmtSQL)
                          @dtw_concat(fileSQL, " OECTRL, OEIVCT ", fileSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
   </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN  CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @dtw_assign(sec_03, "N")
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "oeDistributionPeriod")
                      %else
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@per@", "oeDistributionPeriod")               @dtw_assign(Err_CEPER#, fieldValue)
                          @DecatErr_Field("@@rclr", "reclaimResourceLevel")               @dtw_assign(Err_CERCLR, fieldValue)
                          @DecatErr_Field("@@lord", "lastOrderNumberUsed")                @dtw_assign(Err_CELORD, fieldValue)
                          @DecatErr_Field("@@assn", "automaticOrderNumberAssignment")     @dtw_assign(Err_CEASSN, fieldValue)
                          @DecatErr_Field("@@oawc", "orderAvailabilityWarning")           @dtw_assign(Err_CEOAWC, fieldValue)
                          @DecatErr_Field("@@pd@@", "pastDueDollarAmount")                @dtw_assign(Err_CEPD, fieldValue)
                          @DecatErr_Field("@@pddc", "numberOfDaysPastDue")                @dtw_assign(Err_CEPDDC, fieldValue)
                          @DecatErr_Field("@@linv", "lastInvoiceNumberUsed")              @dtw_assign(Err_CELINV, fieldValue)
                          @DecatErr_Field("@@abor", "autoReleaseBackorders")              @dtw_assign(Err_CEABOR, fieldValue)
                          @DecatErr_Field("@@dudt", "dueDateUsed")                        @dtw_assign(Err_CEDUDT, fieldValue)
                          @DecatErr_Field("@@apgo", "automaticallyPurgeOrderWhenClosed")  @dtw_assign(Err_CEAPGO, fieldValue)
                          @DecatErr_Field("@@shpo", "defaultShipQuantity")                @dtw_assign(Err_CESHPO, fieldValue)
                          @DecatErr_Field("@@aovs", "allowOverShipments")                 @dtw_assign(Err_CEAOVS, fieldValue)
                          @DecatErr_Field("@@oear", "oeToARAudit")                        @dtw_assign(Err_CEOEAR, fieldValue)
                          @DecatErr_Field("@@nmdq", "numberOfDataQueueProcessingJobs")    @dtw_assign(Err_CENMDQ, fieldValue)
                          @DecatErr_Field("@@mhld", "mfgHoldCode")                        @dtw_assign(Err_CEMHLD, fieldValue)
                          @DecatErr_Field("@@dbnk", "defaultBankNumber")                  @dtw_assign(Err_CEDBNK, fieldValue)
                          @DecatErr_Field("@@aiwd", "automaticItemWarehouseCreation")     @dtw_assign(Err_CEAIWD, fieldValue)
                          @DecatErr_Field("@@bpbl", "backupPriorToBillingUpdate")         @dtw_assign(Err_CEBPBL, fieldValue)
                          @DecatErr_Field("@@arac", "accountsReceivableAccountNumber")    @dtw_assign(Err_CEARAC, fieldValue)
                          @DecatErr_Field("@@arsb", "accountsReceivableSubaccountNumber") @dtw_assign(Err_CEARSB, fieldValue)
                          @DecatErr_Field("@@frac", "freightAccountNumber")               @dtw_assign(Err_CEFRAC, fieldValue)
                          @DecatErr_Field("@@frsb", "freightSubaccountNumber")            @dtw_assign(Err_CEFRSB, fieldValue)
                          @DecatErr_Field("@@txac", "salesTaxAccountNumber")              @dtw_assign(Err_CETXAC, fieldValue)
                          @DecatErr_Field("@@txsb", "salesTaxSubaccountNumber")           @dtw_assign(Err_CETXSB, fieldValue)
                          @DecatErr_Field("@@scac", "specialChargesAccountNumber")        @dtw_assign(Err_CESCAC, fieldValue)
                          @DecatErr_Field("@@scsb", "specialChargesSubaccountNumber")     @dtw_assign(Err_CESCSB, fieldValue)
                          @DecatErr_Field("@@ccp@", "onlineCreditCardAuthorization")      @dtw_assign(Err_CECCP, fieldValue)
                          @DecatErr_Field("@@uccm", "updateCustomerCreditCardMaster")     @dtw_assign(Err_CEUCCM, fieldValue)
                          @DecatErr_Field("@@upgp", "useProductGroupPricing")             @dtw_assign(Err_CEUPGP, fieldValue)
                          @DecatErr_Field("@@oepo", "allowPOGeneration")                  @dtw_assign(Err_CEOEPO, fieldValue)
                          @DecatErr_Field("@@ucd1", "userDefined1")                       @dtw_assign(Err_CEUCD1, fieldValue)
                          @DecatErr_Field("@@ucd2", "userDefined2")                       @dtw_assign(Err_CEUCD2, fieldValue)
                          @DecatErr_Field("@@ucd3", "userDefined3")                       @dtw_assign(Err_CEUCD3, fieldValue)
                          @DecatErr_Field("@@ucd4", "userDefined4")                       @dtw_assign(Err_CEUCD4, fieldValue)
                          @DecatErr_Field("@@ucd5", "userDefined5")                       @dtw_assign(Err_CEUCD5, fieldValue)
                          @DecatErr_Field("@@sud1", "storeDefined1")                      @dtw_assign(Err_CESUD1, fieldValue)
                          @DecatErr_Field("@@sud2", "storeDefined2")                      @dtw_assign(Err_CESUD2, fieldValue)
                          @DecatErr_Field("@@sud3", "storeDefined3")                      @dtw_assign(Err_CESUD3, fieldValue)
                          @DecatErr_Field("@@sud4", "storeDefined4")                      @dtw_assign(Err_CESUD4, fieldValue)
                          @DecatErr_Field("@@sud5", "storeDefined5")                      @dtw_assign(Err_CESUD5, fieldValue)
                          @DecatErr_Field("@@lpl@", "lastPackingListNumber")              @dtw_assign(Err_CELPL#, fieldValue)
                          @DecatErr_Field("@@lbl@", "lastBillOfLadingNumber")             @dtw_assign(Err_CELBL#, fieldValue)
                          @DecatErr_Field("@@bolc", "printCommentsOnlyNoDetail")          @dtw_assign(Err_CEBOLC, fieldValue)
                          @DecatErr_Field("@@hf01", "bolHdrFoot01")                       @dtw_assign(Err_CEHF01, fieldValue)
                          @DecatErr_Field("@@cm01", "bolComment01")                       @dtw_assign(Err_CECM01, fieldValue)
                          @DecatErr_Field("@@hf02", "bolHdrFoot02")                       @dtw_assign(Err_CEHF02, fieldValue)
                          @DecatErr_Field("@@cm02", "bolComment02")                       @dtw_assign(Err_CECM02, fieldValue)
                          @DecatErr_Field("@@hf03", "bolHdrFoot03")                       @dtw_assign(Err_CEHF03, fieldValue)
                          @DecatErr_Field("@@cm03", "bolComment03")                       @dtw_assign(Err_CECM03, fieldValue)
                          @DecatErr_Field("@@hf04", "bolHdrFoot04")                       @dtw_assign(Err_CEHF04, fieldValue)
                          @DecatErr_Field("@@cm04", "bolComment04")                       @dtw_assign(Err_CECM04, fieldValue)
                          @DecatErr_Field("@@hf05", "bolHdrFoot05")                       @dtw_assign(Err_CEHF05, fieldValue)
                          @DecatErr_Field("@@cm05", "bolComment05")                       @dtw_assign(Err_CECM05, fieldValue)
                          @DecatErr_Field("@@hf06", "bolHdrFoot06")                       @dtw_assign(Err_CEHF06, fieldValue)
                          @DecatErr_Field("@@cm06", "bolComment06")                       @dtw_assign(Err_CECM06, fieldValue)
                          @DecatErr_Field("@@hf07", "bolHdrFoot07")                       @dtw_assign(Err_CEHF07, fieldValue)
                          @DecatErr_Field("@@cm07", "bolComment07")                       @dtw_assign(Err_CECM07, fieldValue)
                          @DecatErr_Field("@@hf08", "bolHdrFoot08")                       @dtw_assign(Err_CEHF08, fieldValue)
                          @DecatErr_Field("@@cm08", "bolComment08")                       @dtw_assign(Err_CECM08, fieldValue)
                          @DecatErr_Field("@@sloc", "sortLocationNumber")                 @dtw_assign(Err_OISLOC, fieldValue)
                          @DecatErr_Field("@@sord", "sortOrderNumber")                    @dtw_assign(Err_OISORD, fieldValue)
                          @DecatErr_Field("@@sblt", "sortBillToNumber")                   @dtw_assign(Err_OISBLT, fieldValue)
                          @DecatErr_Field("@@sbnm", "sortBillToName")                     @dtw_assign(Err_OISBNM, fieldValue)
                          @DecatErr_Field("@@szip", "sortBillToZipCode")                  @dtw_assign(Err_OISZIP, fieldValue)
                          @DecatErr_Field("@@ssls", "sortSalesmanNumber")                 @dtw_assign(Err_OISSLS, fieldValue)
                          @DecatErr_Field("@@sinv", "sortInvoiceNumber")                  @dtw_assign(Err_OISINV, fieldValue)
                      %endif

                      @Decat_Field("@@per@")   @dtw_assign(V_CEPER#, fieldValue)
                      @Decat_Field("@@lord")   @dtw_assign(V_CELORD, fieldValue)
                      @Decat_Field("@@assn")   @dtw_assign(V_CEASSN, fieldValue)
                      @Decat_Field("@@oawc")   @dtw_assign(V_CEOAWC, fieldValue)
                      @Decat_Field("@@pd@@")   @dtw_assign(V_CEPD,   fieldValue)
                      @Decat_Field("@@pddc")   @dtw_assign(V_CEPDDC, fieldValue)
                      @Decat_Field("@@linv")   @dtw_assign(V_CELINV, fieldValue)
                      @Decat_Field("@@abor")   @dtw_assign(V_CEABOR, fieldValue)
                      @Decat_Field("@@dudt")   @dtw_assign(V_CEDUDT, fieldValue)
                      @Decat_Field("@@shpo")   @dtw_assign(V_CESHPO, fieldValue)
                      @Decat_Field("@@dbnk")   @dtw_assign(V_CEDBNK, fieldValue)
                      @Decat_Field("@@aiwd")   @dtw_assign(V_CEAIWD, fieldValue)
                      @Decat_Field("@@bpbl")   @dtw_assign(V_CEBPBL, fieldValue)
                      @Decat_Field("@@arac")   @dtw_assign(V_CEARAC, fieldValue)
                      @Decat_Field("@@arsb")   @dtw_assign(V_CEARSB, fieldValue)
                      @Decat_Field("@@txac")   @dtw_assign(V_CETXAC, fieldValue)
                      @Decat_Field("@@txsb")   @dtw_assign(V_CETXSB, fieldValue)
                      @Decat_Field("@@frac")   @dtw_assign(V_CEFRAC, fieldValue)
                      @Decat_Field("@@frsb")   @dtw_assign(V_CEFRSB, fieldValue)
                      @Decat_Field("@@scac")   @dtw_assign(V_CESCAC, fieldValue)
                      @Decat_Field("@@scsb")   @dtw_assign(V_CESCSB, fieldValue)
                      @Decat_Field("@@oepo")   @dtw_assign(V_CEOEPO, fieldValue)
                      @Decat_Field("@@ucd1")   @dtw_assign(V_CEUCD1, fieldValue)
                      @Decat_Field("@@ucd2")   @dtw_assign(V_CEUCD2, fieldValue)
                      @Decat_Field("@@ucd3")   @dtw_assign(V_CEUCD3, fieldValue)
                      @Decat_Field("@@ucd4")   @dtw_assign(V_CEUCD4, fieldValue)
                      @Decat_Field("@@ucd5")   @dtw_assign(V_CEUCD5, fieldValue)
                      @Decat_Field("@@sud1")   @dtw_assign(V_CESUD1, fieldValue)
                      @Decat_Field("@@sud2")   @dtw_assign(V_CESUD2, fieldValue)
                      @Decat_Field("@@sud3")   @dtw_assign(V_CESUD3, fieldValue)
                      @Decat_Field("@@sud4")   @dtw_assign(V_CESUD4, fieldValue)
                      @Decat_Field("@@sud5")   @dtw_assign(V_CESUD5, fieldValue)
                      @Decat_Field("@@lpl@")   @dtw_assign(V_CELPL#, fieldValue)
                      @Decat_Field("@@lbl@")   @dtw_assign(V_CELBL#, fieldValue)
                      @Decat_Field("@@bolc")   @dtw_assign(V_CEBOLC, fieldValue)
                      @Decat_Field("@@hf01")   @dtw_assign(V_CEHF01, fieldValue)
                      @Decat_Field("@@hf02")   @dtw_assign(V_CEHF02, fieldValue)
                      @Decat_Field("@@hf03")   @dtw_assign(V_CEHF03, fieldValue)
                      @Decat_Field("@@hf04")   @dtw_assign(V_CEHF04, fieldValue)
                      @Decat_Field("@@hf05")   @dtw_assign(V_CEHF05, fieldValue)
                      @Decat_Field("@@hf06")   @dtw_assign(V_CEHF06, fieldValue)
                      @Decat_Field("@@hf07")   @dtw_assign(V_CEHF07, fieldValue)
                      @Decat_Field("@@hf08")   @dtw_assign(V_CEHF08, fieldValue)
                      @Decat_Field("@@cm01")   @dtw_assign(V_CECM01, fieldValue)
                      @Decat_Field("@@cm02")   @dtw_assign(V_CECM02, fieldValue)
                      @Decat_Field("@@cm03")   @dtw_assign(V_CECM03, fieldValue)
                      @Decat_Field("@@cm04")   @dtw_assign(V_CECM04, fieldValue)
                      @Decat_Field("@@cm05")   @dtw_assign(V_CECM05, fieldValue)
                      @Decat_Field("@@cm06")   @dtw_assign(V_CECM06, fieldValue)
                      @Decat_Field("@@cm07")   @dtw_assign(V_CECM07, fieldValue)
                      @Decat_Field("@@cm08")   @dtw_assign(V_CECM08, fieldValue)
                      @Decat_Field("@@rclr")   @dtw_assign(V_CERCLR, fieldValue)
                      @Decat_Field("@@mhld")   @dtw_assign(V_CEMHLD, fieldValue)
                      @Decat_Field("@@ccp@")   @dtw_assign(V_CECCP,  fieldValue)
                      @Decat_Field("@@uccm")   @dtw_assign(V_CEUCCM, fieldValue)
                      @Decat_Field("@@upgp")   @dtw_assign(V_CEUPGP, fieldValue)
                      @Decat_Field("@@apgo")   @dtw_assign(V_CEAPGO, fieldValue)
                      @Decat_Field("@@aovs")   @dtw_assign(V_CEAOVS, fieldValue)
                      @Decat_Field("@@oear")   @dtw_assign(V_CEOEAR, fieldValue)
                      @Decat_Field("@@nmdq")   @dtw_assign(V_CENMDQ, fieldValue)
                      @Decat_Field("@@sloc")   @dtw_assign(V_OISLOC, fieldValue)
                      @Decat_Field("@@sord")   @dtw_assign(V_OISORD, fieldValue)
                      @Decat_Field("@@sblt")   @dtw_assign(V_OISBLT, fieldValue)
                      @Decat_Field("@@sbnm")   @dtw_assign(V_OISBNM, fieldValue)
                      @Decat_Field("@@szip")   @dtw_assign(V_OISZIP, fieldValue)
                      @Decat_Field("@@ssls")   @dtw_assign(V_OISSLS, fieldValue)
                      @Decat_Field("@@sinv")   @dtw_assign(V_OISINV, fieldValue)
                      @Decat_Field("@@bloc")   @dtw_assign(V_OIBLOC, fieldValue)
                      @Decat_Field("@@bord")   @dtw_assign(V_OIBORD, fieldValue)
                      @Decat_Field("@@bblt")   @dtw_assign(V_OIBBLT, fieldValue)
                      @Decat_Field("@@bbnm")   @dtw_assign(V_OIBBNM, fieldValue)
                      @Decat_Field("@@bzip")   @dtw_assign(V_OIBZIP, fieldValue)
                      @Decat_Field("@@bsls")   @dtw_assign(V_OIBSLS, fieldValue)
                      @Decat_Field("@@tloc")   @dtw_assign(V_OITLOC, fieldValue)
                      @Decat_Field("@@tord")   @dtw_assign(V_OITORD, fieldValue)
                      @Decat_Field("@@tblt")   @dtw_assign(V_OITBLT, fieldValue)
                      @Decat_Field("@@tbnm")   @dtw_assign(V_OITBNM, fieldValue)
                      @Decat_Field("@@tzip")   @dtw_assign(V_OITZIP, fieldValue)
                      @Decat_Field("@@tsls")   @dtw_assign(V_OITSLS, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "oeDistributionPeriod")
                          @dtw_assign(V_CERCLR, "O")
                          @dtw_assign(V_CEASSN, "Y")
                          @dtw_assign(V_CEOAWC, "Y")
                          @dtw_assign(V_CEABOR, "N")
                          @dtw_assign(V_CEAPGO, "N")
                          @dtw_assign(V_CEAOVS, "N")
                          @dtw_assign(V_CESHPO, "N")
                          @dtw_assign(V_CEOEAR, "D")
                          @dtw_assign(V_CENMDQ, "1")
                          @dtw_assign(V_CEMHLD, "N")
                          @dtw_assign(V_CEAIWD, "N")
                          @dtw_assign(V_CEBPBL, "N")
                          @dtw_assign(V_CEOEPO, "N")
                          @dtw_assign(V_CEBOLC, "N")
                          @dtw_assign(V_CECCP,  "N")
                          @dtw_assign(V_CEUCCM, "N")
                          @dtw_assign(V_CEUPGP, "N")
                          @dtw_assign(V_OISLOC, "1")
                          @dtw_assign(V_OISORD, "2")
                          @dtw_assign(V_OISBLT, "3")
                          @dtw_assign(V_OISBNM, "4")
                          @dtw_assign(V_OISZIP, "5")
                          @dtw_assign(V_OISSLS, "6")
                          @dtw_assign(V_OISINV, "7")
                          @dtw_assign(V_OIBLOC, "N")
                          @dtw_assign(V_OIBORD, "N")
                          @dtw_assign(V_OIBBLT, "N")
                          @dtw_assign(V_OIBBNM, "N")
                          @dtw_assign(V_OIBZIP, "N")
                          @dtw_assign(V_OIBSLS, "N")
                          @dtw_assign(V_OITLOC, "N")
                          @dtw_assign(V_OITORD, "N")
                          @dtw_assign(V_OITBLT, "N")
                          @dtw_assign(V_OITBNM, "N")
                          @dtw_assign(V_OITZIP, "N")
                          @dtw_assign(V_OITSLS, "N")
                          %if (V_HDARRL > "0")
                             @RtvFldDesc("CRARAC>0", "ARCTRL", "CHAR(CRARAC)", V_CEARAC)
                             @RtvFldDesc("CRARSB>0", "ARCTRL", "CHAR(CRARSB)", V_CEARSB)
                             @RtvFldDesc("CRTXAC>0", "ARCTRL", "CHAR(CRTXAC)", V_CETXAC)
                             @RtvFldDesc("CRTXSB>0", "ARCTRL", "CHAR(CRTXSB)", V_CETXSB)
                             @RtvFldDesc("CRFRAC>0", "ARCTRL", "CHAR(CRFRAC)", V_CEFRAC)
                             @RtvFldDesc("CRFRSB>0", "ARCTRL", "CHAR(CRFRSB)", V_CEFRSB)
                             @RtvFldDesc("CRSCAC>0", "ARCTRL", "CHAR(CRSCAC)", V_CESCAC)
                             @RtvFldDesc("CRSCSB>0", "ARCTRL", "CHAR(CRSCSB)", V_CESCSB)
                          %endif
                      %endif

                      @dtw_assign(errFound, "")

                  %else
                      @dtw_assign(focusField, "oeDistributionPeriod")
                      @PeriodInputFromCYP(V_CEPER#)
                  %endif

                  <table $(contentTable)>
                      @SetTextOvr(Err_HDOERL)
                      <tr><td class="dsphdr"><span $(textOvr)>O/E Release Version</span></td>
                          <td class="inputnmbr"><input name="oeReleaseVersion" type="hidden" value="$(V_HDOERL)" size="5" maxlength="5">$(V_HDOERL)</td>
                      </tr>
