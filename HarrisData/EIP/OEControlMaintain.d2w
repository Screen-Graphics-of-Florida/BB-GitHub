                  %if (V_CEHF03=="H") @dtw_assign(head03, "CHECKED") %endif
                  %if (V_CEHF04=="H") @dtw_assign(head04, "CHECKED") %endif
                  %if (V_CEHF05=="H") @dtw_assign(head05, "CHECKED") %endif
                  %if (V_CEHF06=="H") @dtw_assign(head06, "CHECKED") %endif
                  %if (V_CEHF07=="H") @dtw_assign(head07, "CHECKED") %endif
                  %if (V_CEHF08=="H") @dtw_assign(head08, "CHECKED") %endif
                  %if (V_CEHF01=="F") @dtw_assign(foot01, "CHECKED") %endif
                  %if (V_CEHF02=="F") @dtw_assign(foot02, "CHECKED") %endif
                  %if (V_CEHF03=="F") @dtw_assign(foot03, "CHECKED") %endif
                  %if (V_CEHF04=="F") @dtw_assign(foot04, "CHECKED") %endif
                  %if (V_CEHF05=="F") @dtw_assign(foot05, "CHECKED") %endif
                  %if (V_CEHF06=="F") @dtw_assign(foot06, "CHECKED") %endif
                  %if (V_CEHF07=="F") @dtw_assign(foot07, "CHECKED") %endif
                  %if (V_CEHF08=="F") @dtw_assign(foot08, "CHECKED") %endif

                  <table $(contentTable)>
                      <tr><td class="colhdr">Header</td><td class="colhdr">Footer</td><td class="colhdr">Bill Of Lading Comments</td></tr>
                      <tr><td class="colCode"><input name="bolHdrFoot01" type="radio" VALUE='H' $(head01)></td>
                          <td class="colCode"><input name="bolHdrFoot01" type="radio" VALUE='F' $(foot01)></td>
                          <td class="inputalph"><input name="bolComment01" value="$(V_CECM01)" type="text" size="40" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_CEHF01)
                      @DspErrMsg(Err_CECM01)

                      <tr><td class="colCode"><input name="bolHdrFoot02" type="radio" VALUE='H' $(head02)></td>
                          <td class="colCode"><input name="bolHdrFoot02" type="radio" VALUE='F' $(foot02)></td>
                          <td class="inputalph"><input name="bolComment02" value="$(V_CECM02)" type="text" size="40" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_CEHF02)
                      @DspErrMsg(Err_CECM02)

                      <tr><td class="colCode"><input name="bolHdrFoot03" type="radio" VALUE='H' $(head03)></td>
                          <td class="colCode"><input name="bolHdrFoot03" type="radio" VALUE='F' $(foot03)></td>
                          <td class="inputalph"><input name="bolComment03" value="$(V_CECM03)" type="text" size="40" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_CEHF03)
                      @DspErrMsg(Err_CECM03)

                      <tr><td class="colCode"><input name="bolHdrFoot04" type="radio" VALUE='H' $(head04)></td>
                          <td class="colCode"><input name="bolHdrFoot04" type="radio" VALUE='F' $(foot04)></td>
                          <td class="inputalph"><input name="bolComment04" value="$(V_CECM04)" type="text" size="40" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_CEHF04)
                      @DspErrMsg(Err_CECM04)

                      <tr><td class="colCode"><input name="bolHdrFoot05" type="radio" VALUE='H' $(head05)></td>
                          <td class="colCode"><input name="bolHdrFoot05" type="radio" VALUE='F' $(foot05)></td>
                          <td class="inputalph"><input name="bolComment05" value="$(V_CECM05)" type="text" size="40" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_CEHF05)
                      @DspErrMsg(Err_CECM05)

                      <tr><td class="colCode"><input name="bolHdrFoot06" type="radio" VALUE='H' $(head06)></td>
                          <td class="colCode"><input name="bolHdrFoot06" type="radio" VALUE='F' $(foot06)></td>
                          <td class="inputalph"><input name="bolComment06" value="$(V_CECM06)" type="text" size="40" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_CEHF06)
                      @DspErrMsg(Err_CECM06)

                      <tr><td class="colCode"><input name="bolHdrFoot07" type="radio" VALUE='H' $(head07)></td>
                          <td class="colCode"><input name="bolHdrFoot07" type="radio" VALUE='F' $(foot07)></td>
                          <td class="inputalph"><input name="bolComment07" value="$(V_CECM07)" type="text" size="40" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_CEHF07)
                      @DspErrMsg(Err_CECM07)

                      <tr><td class="colCode"><input name="bolHdrFoot08" type="radio" VALUE='H' $(head08)></td>
                          <td class="colCode"><input name="bolHdrFoot08" type="radio" VALUE='F' $(foot08)></td>
                          <td class="inputalph"><input name="bolComment08" value="$(V_CECM08)" type="text" size="40" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_CEHF08)
                      @DspErrMsg(Err_CECM08)
                  </table>

                  @dtw_assign(chkBrkLoc, "")
                  @dtw_assign(chkBrkOrd, "")
                  @dtw_assign(chkBrkBlt, "")
                  @dtw_assign(chkBrkBnm, "")
                  @dtw_assign(chkBrkZip, "")
                  @dtw_assign(chkBrkSls, "")
                  @dtw_assign(chkTotLoc, "")
                  @dtw_assign(chkTotOrd, "")
                  @dtw_assign(chkTotBlt, "")
                  @dtw_assign(chkTotBnm, "")
                  @dtw_assign(chkTotZip, "")
                  @dtw_assign(chkTotSls, "")

                  %if (V_OIBLOC=="Y") @dtw_assign(chkBrkLoc, "CHECKED") %endif
                  %if (V_OIBORD=="Y") @dtw_assign(chkBrkOrd, "CHECKED") %endif
                  %if (V_OIBBLT=="Y") @dtw_assign(chkBrkBlt, "CHECKED") %endif
                  %if (V_OIBBNM=="Y") @dtw_assign(chkBrkBnm, "CHECKED") %endif
                  %if (V_OIBZIP=="Y") @dtw_assign(chkBrkZip, "CHECKED") %endif
                  %if (V_OIBSLS=="Y") @dtw_assign(chkBrkSls, "CHECKED") %endif

                  %if (V_OITLOC=="Y") @dtw_assign(chkTotLoc, "CHECKED") %endif
                  %if (V_OITORD=="Y") @dtw_assign(chkTotOrd, "CHECKED") %endif
                  %if (V_OITBLT=="Y") @dtw_assign(chkTotBlt, "CHECKED") %endif
                  %if (V_OITBNM=="Y") @dtw_assign(chkTotBnm, "CHECKED") %endif
                  %if (V_OITZIP=="Y") @dtw_assign(chkTotZip, "CHECKED") %endif
                  %if (V_OITSLS=="Y") @dtw_assign(chkTotSls, "CHECKED") %endif

                  <table $(contentTable)>
                      <tr><td class="dsphdr">Invoice:</td>
                          <td class="colhdr">Sequence</td>
                          <td class="colhdr">Print<br>Total</td>
                          <td class="colhdr">Page<br>Break</td>
                      </tr>

                      @SetTextOvr(Err_OISLOC)
                      <tr><td class="dsphdr"><span $(textOvr)>Location Number</span></td>
                          @Build_Sort_Select("sortLocationNumber", "$(V_OISLOC)")
                          <td class="colcode"><input name="totLoc" type="checkbox" VALUE='Y' $(chkTotLoc)></td>
                          <td class="colcode"><input name="brkLoc" type="checkbox" VALUE='Y' $(chkBrkLoc)></td>
                      </tr>
                      @DspErrMsg(Err_OISLOC)

                      @SetTextOvr(Err_OISORD)
                      <tr><td class="dsphdr"><span $(textOvr)>Order Number</span></td>
                          @Build_Sort_Select("sortOrderNumber", "$(V_OISORD)")
                          <td class="colcode"><input name="totOrd" type="checkbox" VALUE='Y' $(chkTotOrd)></td>
                          <td class="colcode"><input name="brkOrd" type="checkbox" VALUE='Y' $(chkBrkOrd)></td>
                      </tr>
                      @DspErrMsg(Err_OISORD)

                      @SetTextOvr(Err_OISBLT)
                      <tr><td class="dsphdr"><span $(textOvr)>Bill-To Number</span></td>
                          @Build_Sort_Select("sortBillToNumber", "$(V_OISBLT)")
                          <td class="colcode"><input name="totBlt" type="checkbox" VALUE='Y' $(chkTotBlt)></td>
                          <td class="colcode"><input name="brkBlt" type="checkbox" VALUE='Y' $(chkBrkBlT)></td>
                      </tr>
                      @DspErrMsg(Err_OISBLT)

                      @SetTextOvr(Err_OISBNM)
                      <tr><td class="dsphdr"><span $(textOvr)>Bill-To Name</span></td>
                          @Build_Sort_Select("sortBillToName", "$(V_OISBNM)")
                          <td class="colcode"><input name="totBnm" type="checkbox" VALUE='Y' $(chkTotBnm)></td>
                          <td class="colcode"><input name="brkBnm" type="checkbox" VALUE='Y' $(chkBrkBnm)></td>
                      </tr>
                      @DspErrMsg(Err_OISBNM)

                      @SetTextOvr(Err_OISZIP)
                      <tr><td class="dsphdr"><span $(textOvr)>Bill-To Zip Code</span></td>
                          @Build_Sort_Select("sortBillToZipCode", "$(V_OISZIP)")
                          <td class="colcode"><input name="totZip" type="checkbox" VALUE='Y' $(chkTotZip)></td>
                          <td class="colcode"><input name="brkZip" type="checkbox" VALUE='Y' $(chkBrkZip)></td>
                      </tr>
                      @DspErrMsg(Err_OISZIP)

                      @SetTextOvr(Err_OISSLS)
                      <tr><td class="dsphdr"><span $(textOvr)>Salesman Number</span></td>
                          @Build_Sort_Select("sortSalesmanNumber", "$(V_OISSLS)")
                          <td class="colcode"><input name="totSls" type="checkbox" VALUE='Y' $(chkTotSls)></td>
                          <td class="colcode"><input name="brkSls" type="checkbox" VALUE='Y' $(chkBrkSls)></td>
                      </tr>
                      @DspErrMsg(Err_OISSLS)

                      @SetTextOvr(Err_OISINV)
                      <tr><td class="dsphdr"><span $(textOvr)>Invoice Number</span></td>
                          @Build_Sort_Select("sortInvoiceNumber", "$(V_OISINV)")
                      </tr>
                      @DspErrMsg(Err_OISINV)
                  </table>

              %}	

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HOECTU_W.PGM %}
  %}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"

  @RtvFldDesc("", "OECTRL", "Char(Count(*))", RecCount)
  %if (RecCount>"0")
      @dtw_assign(maintenanceCode,"C")
  %else
      @dtw_assign(maintenanceCode,"A")
  %endif
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if ((sec_02 == "N" && sec_03 == "N" && maintenanceCode != "A") || (sec_01 == "N" && maintenanceCode == "A") || (sec_04 == "N" && maintenanceCode == "Z"))
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)progOptSecError.d2w/DISPLAY$(genericVarBase)&amp;page_title=@dtw_rurlescseq(page_title)">
  %else

      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @yn02_Table_Query(profileHandle, dataBaseID, "YORN      ", yn02Table)
      @yn03_Table_Query(profileHandle, dataBaseID, "YORN      ", yn03Table)
      @yn04_Table_Query(profileHandle, dataBaseID, "YORN      ", yn04Table)
      @yn05_Table_Query(profileHandle, dataBaseID, "YORN      ", yn05Table)
      @yn06_Table_Query(profileHandle, dataBaseID, "YORN      ", yn06Table)
      @yn06_Table_Query(profileHandle, dataBaseID, "YORN      ", yn07Table)
      @yn08_Table_Query(profileHandle, dataBaseID, "YORN      ", yn08Table)
      @yn09_Table_Query(profileHandle, dataBaseID, "YORN      ", yn09Table)
      @yn10_Table_Query(profileHandle, dataBaseID, "YORN      ", yn10Table)
      @yn11_Table_Query(profileHandle, dataBaseID, "YORN      ", yn11Table)

      @Set_SQL(stmtSQL)
  %endif
%}


%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(reclaimResourceLevel)
  @dtw_mUPPERCASE(oeToARAudit)
  @dtw_mUPPERCASE(allowPOGeneration)
  @dtw_mUPPERCASE(mfgHoldCode)
  @dtw_mUPPERCASE(onlineCreditCardAuthorization)
  @dtw_mUPPERCASE(bolHdrFoot01)
  @dtw_mUPPERCASE(bolHdrFoot02)
  @dtw_mUPPERCASE(bolHdrFoot03)
  @dtw_mUPPERCASE(bolHdrFoot04)
  @dtw_mUPPERCASE(bolHdrFoot05)
  @dtw_mUPPERCASE(bolHdrFoot06)
  @dtw_mUPPERCASE(bolHdrFoot07)
  @dtw_mUPPERCASE(bolHdrFoot08)

  @dtw_assign(oeDistributionPeriod,@dtw_rstrip(oeDistributionPeriod))
  @dtw_assign(lastOrderNumberUsed,@dtw_rstrip(lastOrderNumberUsed))
  @dtw_assign(pastDueDollarAmount,@dtw_rstrip(pastDueDollarAmount))
  @dtw_assign(numberOfDaysPastDue,@dtw_rstrip(numberOfDaysPastDue))
  @dtw_assign(lastInvoiceNumberUsed,@dtw_rstrip(lastInvoiceNumberUsed))
  @dtw_assign(dueDateUsed,@dtw_rstrip(dueDateUsed))
  @dtw_assign(numberOfDataQueueProcessingJobs,@dtw_rstrip(numberOfDataQueueProcessingJobs))
  @dtw_assign(defaultBankNumber,@dtw_rstrip(defaultBankNumber))
  @dtw_assign(accountsReceivableAccountNumber,@dtw_rstrip(accountsReceivableAccountNumber))
  @dtw_assign(accountsReceivableSubaccountNumber,@dtw_rstrip(accountsReceivableSubaccountNumber))
  @dtw_assign(freightAccountNumber,@dtw_rstrip(freightAccountNumber))
  @dtw_assign(freightSubaccountNumber,@dtw_rstrip(freightSubaccountNumber))
  @dtw_assign(salesTaxAccountNumber,@dtw_rstrip(salesTaxAccountNumber))
  @dtw_assign(salesTaxSubaccountNumber,@dtw_rstrip(salesTaxSubaccountNumber))
  @dtw_assign(specialChargesAccountNumber,@dtw_rstrip(specialChargesAccountNumber))
  @dtw_assign(specialChargesSubaccountNumber,@dtw_rstrip(specialChargesSubaccountNumber))
  @dtw_assign(sortLocationNumber,@dtw_rstrip(sortLocationNumber))
  @dtw_assign(sortOrderNumber,@dtw_rstrip(sortOrderNumber))
  @dtw_assign(sortBillToNumber,@dtw_rstrip(sortBillToNumber))
  @dtw_assign(sortBillToName,@dtw_rstrip(sortBillToName))
  @dtw_assign(sortBillToZipCode,@dtw_rstrip(sortBillToZipCode))
  @dtw_assign(sortSalesmanNumber,@dtw_rstrip(sortSalesmanNumber))
  @dtw_assign(sortInvoiceNumber,@dtw_rstrip(sortInvoiceNumber))

  %if (bolComment01=="") @dtw_assign(bolHdrFoot01, "") %endif
  %if (bolComment02=="") @dtw_assign(bolHdrFoot02, "") %endif
  %if (bolComment03=="") @dtw_assign(bolHdrFoot03, "") %endif
  %if (bolComment04=="") @dtw_assign(bolHdrFoot04, "") %endif
  %if (bolComment05=="") @dtw_assign(bolHdrFoot05, "") %endif
  %if (bolComment06=="") @dtw_assign(bolHdrFoot06, "") %endif
  %if (bolComment07=="") @dtw_assign(bolHdrFoot07, "") %endif
  %if (bolComment08=="") @dtw_assign(bolHdrFoot08, "") %endif

  %if (brkLoc!="Y") @dtw_assign(brkLoc, "N") %endif
  %if (brkOrd!="Y") @dtw_assign(brkOrd, "N") %endif
  %if (brkBlt!="Y") @dtw_assign(brkBlt, "N") %endif
  %if (brkBnm!="Y") @dtw_assign(brkBnm, "N") %endif
  %if (brkZip!="Y") @dtw_assign(brkZip, "N") %endif
  %if (brkSls!="Y") @dtw_assign(brkSls, "N") %endif

  %if (totLoc!="Y") @dtw_assign(totLoc, "N") %endif
  %if (totOrd!="Y") @dtw_assign(totOrd, "N") %endif
  %if (totBlt!="Y") @dtw_assign(totBlt, "N") %endif
  %if (totBnm!="Y") @dtw_assign(totBnm, "N") %endif
  %if (totZip!="Y") @dtw_assign(totZip, "N") %endif
  %if (totSls!="Y") @dtw_assign(totSls, "N") %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@per@", oeDistributionPeriod)
  @Concat_Field("@@lord", lastOrderNumberUsed)
  @Concat_Field("@@assn", automaticOrderNumberAssignment)
  @Concat_Field("@@oawc", orderAvailabilityWarning)
  @Concat_Field("@@pd@@", pastDueDollarAmount)
  @Concat_Field("@@pddc", numberOfDaysPastDue)
  @Concat_Field("@@linv", lastInvoiceNumberUsed)
  @Concat_Field("@@abor", autoReleaseBackorders)
  @Concat_Field("@@dudt", dueDateUsed)
  @Concat_Field("@@apgo", automaticallyPurgeOrderWhenClosed)
  @Concat_Field("@@shpo", defaultShipQuantity)
  @Concat_Field("@@aovs", allowOverShipments)
  @Concat_Field("@@oear", oeToARAudit)
  @Concat_Field("@@nmdq", numberOfDataQueueProcessingJobs)
  @Concat_Field("@@rclr", reclaimResourceLevel)
  @Concat_Field("@@mhld", mfgHoldCode)
  @Concat_Field("@@dbnk", defaultBankNumber)
  @Concat_Field("@@aiwd", automaticItemWarehouseCreation)
  @Concat_Field("@@bpbl", backupPriorToBillingUpdate)
  @Concat_Field("@@arac", accountsReceivableAccountNumber)
  @Concat_Field("@@arsb", accountsReceivableSubaccountNumber)
  @Concat_Field("@@frac", freightAccountNumber)
  @Concat_Field("@@frsb", freightSubaccountNumber)
  @Concat_Field("@@txac", salesTaxAccountNumber)
  @Concat_Field("@@txsb", salesTaxSubaccountNumber)
  @Concat_Field("@@scac", specialChargesAccountNumber)
  @Concat_Field("@@scsb", specialChargesSubaccountNumber)
  @Concat_Field("@@ccp@", onlineCreditCardAuthorization)
  @Concat_Field("@@uccm", updateCustomerCreditCardMaster)
  @Concat_Field("@@upgp", useProductGroupPricing)
  @Concat_Field("@@oepo", allowPOGeneration)
  @Concat_Field("@@ucd1", userDefined1)
  @Concat_Field("@@ucd2", userDefined2)
  @Concat_Field("@@ucd3", userDefined3)
  @Concat_Field("@@ucd4", userDefined4)
  @Concat_Field("@@ucd5", userDefined5)
  @Concat_Field("@@sud1", storeDefined1)
  @Concat_Field("@@sud2", storeDefined2)
  @Concat_Field("@@sud3", storeDefined3)
  @Concat_Field("@@sud4", storeDefined4)
  @Concat_Field("@@sud5", storeDefined5)
  @Concat_Field("@@lpl@", lastPackingListNumber)
  @Concat_Field("@@lbl@", lastBillOfLadingNumber)
  @Concat_Field("@@bolc", printCommentsOnlyNoDetail)
  @Concat_Field("@@hf01", bolHdrFoot01)
  @Concat_Field("@@cm01", bolComment01)
  @Concat_Field("@@hf02", bolHdrFoot02)
  @Concat_Field("@@cm02", bolComment02)
  @Concat_Field("@@hf03", bolHdrFoot03)
  @Concat_Field("@@cm03", bolComment03)
  @Concat_Field("@@hf04", bolHdrFoot04)
  @Concat_Field("@@cm04", bolComment04)
  @Concat_Field("@@hf05", bolHdrFoot05)
  @Concat_Field("@@cm05", bolComment05)
  @Concat_Field("@@hf06", bolHdrFoot06)
  @Concat_Field("@@cm06", bolComment06)
  @Concat_Field("@@hf07", bolHdrFoot07)
  @Concat_Field("@@cm07", bolComment07)
  @Concat_Field("@@hf08", bolHdrFoot08)
  @Concat_Field("@@cm08", bolComment08)
  @Concat_Field("@@sloc", sortLocationNumber)
  @Concat_Field("@@sord", sortOrderNumber)
  @Concat_Field("@@sblt", sortBillToNumber)
  @Concat_Field("@@sbnm", sortBillToName)
  @Concat_Field("@@szip", sortBillToZipCode)
  @Concat_Field("@@ssls", sortSalesmanNumber)
  @Concat_Field("@@sinv", sortInvoiceNumber)
  @Concat_Field("@@bloc", brkLoc)
  @Concat_Field("@@bord", brkOrd)
  @Concat_Field("@@bblt", brkBlt)
  @Concat_Field("@@bbnm", brkBnm)
  @Concat_Field("@@bzip", brkZip)
  @Concat_Field("@@bsls", brkSls)
  @Concat_Field("@@tloc", totLoc)
  @Concat_Field("@@tord", totOrd)
  @Concat_Field("@@tblt", totBlt)
  @Concat_Field("@@tbnm", totBnm)
  @Concat_Field("@@tzip", totZip)
  @Concat_Field("@@tsls", totSls)

  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, "O/E Control", "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(backHome)$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}