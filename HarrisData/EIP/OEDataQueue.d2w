%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "$(procDesc)"
  d2wVarBase              = "$(genericVarBase)&amp;procOption=@dtw_rurlescseq(procOption)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(alertMessage, "")
  %if (procOption == "S" || procOption == "R")
      @RtvFldDesc("SPPREF='OEDQ' and SPAPID='OE'", "SYAPFF", "SPJOBA", jobInProcess)
      %if (jobInProcess == "Y")
          %if (procOption == "S")
              @Rtv_Error_Desc("HHD0435", alertMessage)
          %else
              @Rtv_Error_Desc("HHD0436", alertMessage)
          %endif
      %endif
  %elif (procOption == "E")
      @RtvFldDesc("SPPREF='OEDQ' and SPAPID='OE'", "SYAPFF", "SPJOBA", jobInProcess)
      %if (jobInProcess != "Y")
          @Rtv_Error_Desc("HHD0433", alertMessage)
      %endif
  %endif
  %if (alertMessage != "")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)&amp;alertMessage=@dtw_rurlescseq(alertMessage)">
  %endif
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)SubmitJob.d2w/REPORT$(d2wVarBase)&amp;submitPageTitle=@dtw_rurlescseq(submitPageTitle)&amp;submitCallProgram=@dtw_rurlescseq(submitCallProgram)&amp;submitEnvProgram=@dtw_rurlescseq(submitEnvProgram)&amp;submitEnvPrinter=@dtw_rurlescseq(submitEnvPrinter)&amp;submitApplPref=@dtw_rurlescseq(submitApplPref)&amp;submitScheduleD2W=DMSUtilities.d2w&amp;apid=@dtw_rurlescseq(apid)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}