%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Production Plan Report"
  d2wName                 = "ProductionPlanReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;apid=@dtw_rurlescseq(apid)&amp;backHome=@dtw_rurlescseq(backHome)&amp"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  FDTF                    = ""
  periodFormat            = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"


          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                      if  (editNum(document.Chg.PlantNumber, 3, 0) &&
                           editNum(document.Chg.fromBuyerAnalyst, 7, 0) &&
                           editNum(document.Chg.toBuyerAnalyst, 7, 0) &&
                           editdate(document.Chg.fromPeriodEndRange) &&
                           editdate(document.Chg.toPeriodEndRange) &&
                           editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                           editFromToAll(document.Chg.fromInventoryType, document.Chg.toInventoryType, document.Chg.allInventoryType, "A") &&
                           editFromToAll(document.Chg.fromProductClass, document.Chg.toProductClass, document.Chg.allProductClass, "A") &&
                           editFromToAll(document.Chg.fromBuyerAnalyst, document.Chg.toBuyerAnalyst, document.Chg.allBuyerAnalyst, 7) &&
                           editFromToAll(document.Chg.fromABCCode, document.Chg.toABCCode, document.Chg.allABCCode, "A") &&
                           editFromToAll(document.Chg.fromPartType, document.Chg.toPartType, document.Chg.allPartType, "A") &&
                           editFromToAll(document.Chg.fromPeriodEndRange, document.Chg.toPeriodEndRange, document.Chg.allPeriodEndRange, "D")
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PRODUCTIONPLANREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			   %INCLUDE "RequiredField.icl"

                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "PlantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@plt@", "PlantNumber")        @dtw_assign(Err_N1PLT,  fieldValue)
                                  @DecatErr_Field("@@fitm", "fromItemNumber")        @dtw_assign(Err_N1FITM,  fieldValue)
                                  @DecatErr_Field("@@titm", "toItemNumber")        @dtw_assign(Err_N1TITM,  fieldValue)
                                  @DecatErr_Field("@@aitm", "allItemNumber")        @dtw_assign(Err_N1AITM,  fieldValue)
                                  @DecatErr_Field("@@fitc", "fromInventoryType")        @dtw_assign(Err_N1FITC,  fieldValue)
                                  @DecatErr_Field("@@titc", "toInventoryType")        @dtw_assign(Err_N1TITC,  fieldValue)
                                  @DecatErr_Field("@@aitc", "allInventoryType")        @dtw_assign(Err_N1AITC,  fieldValue)
                                  @DecatErr_Field("@@fpcl", "fromProductClass")        @dtw_assign(Err_N1FPCL,  fieldValue)
                                  @DecatErr_Field("@@tpcl", "toProductClass")        @dtw_assign(Err_N1TPCL,  fieldValue)
                                  @DecatErr_Field("@@apcl", "allProductClass")        @dtw_assign(Err_N1APCL,  fieldValue)
                                  @DecatErr_Field("@@fbac", "fromBuyerAnalyst")        @dtw_assign(Err_N1FBAC,  fieldValue)
                                  @DecatErr_Field("@@tbac", "toBuyerAnalyst")        @dtw_assign(Err_N1TBAC,  fieldValue)
                                  @DecatErr_Field("@@abac", "allBuyerAnalyst")        @dtw_assign(Err_N1ABAC,  fieldValue)
                                  @DecatErr_Field("@@fabc", "fromABCCode")        @dtw_assign(Err_N1FABC,  fieldValue)
                                  @DecatErr_Field("@@tabc", "toABCCode")        @dtw_assign(Err_N1TABC,  fieldValue)
                                  @DecatErr_Field("@@aabc", "allABCCode")        @dtw_assign(Err_N1AABC,  fieldValue)
                                  @DecatErr_Field("@@ftyp", "fromPartType")        @dtw_assign(Err_N1FPTYP,  fieldValue)
                                  @DecatErr_Field("@@ttyp", "toPartType")        @dtw_assign(Err_N1TPTYP,  fieldValue)
                                  @DecatErr_Field("@@atyp", "allPartType")        @dtw_assign(Err_N1APTYP,  fieldValue)
                                  @DecatErr_Field("@@fmt@", "periodFormat")        @dtw_assign(Err_N1FMT,  fieldValue)
                                  @DecatErr_Field("@@frdt", "fromPeriodEndRange")        @dtw_assign(Err_N1FRDT,  fieldValue)
                                  @DecatErr_Field("@@todt", "toPeriodEndRange")        @dtw_assign(Err_N1TODT,  fieldValue)
                                  @DecatErr_Field("@@adt@", "allPeriodEndRange")        @dtw_assign(Err_N1ADT,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@plt@")  @dtw_assign(V_N1PLT, fieldValue)
								  @Decat_Field("@@selv")   @dtw_assign(V_OUTFMT,  fieldValue)
                                  @Decat_Field("@@fitm")  @dtw_assign(V_N1FITM, fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N1TITM, fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N1AITM, fieldValue)
                                  @Decat_Field("@@fitc")  @dtw_assign(V_N1FITC, fieldValue)
                                  @Decat_Field("@@titc")  @dtw_assign(V_N1TITC, fieldValue)
                                  @Decat_Field("@@aitc")  @dtw_assign(V_N1AITC, fieldValue)
                                  @Decat_Field("@@fpcl")  @dtw_assign(V_N1FPCL, fieldValue)
                                  @Decat_Field("@@tpcl")  @dtw_assign(V_N1TPCL, fieldValue)
                                  @Decat_Field("@@apcl")  @dtw_assign(V_N1APCL, fieldValue)
                                  @Decat_Field("@@fbac")  @dtw_assign(V_N1FBAC, fieldValue)
                                  @Decat_Field("@@tbac")  @dtw_assign(V_N1TBAC, fieldValue)
                                  @Decat_Field("@@abac")  @dtw_assign(V_N1ABAC, fieldValue)
                                  @Decat_Field("@@fabc")  @dtw_assign(V_N1FABC, fieldValue)
                                  @Decat_Field("@@tabc")  @dtw_assign(V_N1TABC, fieldValue)
                                  @Decat_Field("@@aabc")  @dtw_assign(V_N1AABC, fieldValue)
                                  @Decat_Field("@@ftyp")  @dtw_assign(V_N1FPTYP, fieldValue)
                                  @Decat_Field("@@ttyp")  @dtw_assign(V_N1TPTYP, fieldValue)
                                  @Decat_Field("@@atyp")  @dtw_assign(V_N1APTYP, fieldValue)
                                  @Decat_Field("@@fmt@")  @dtw_assign(V_N1FMT, fieldValue)
                                  @Decat_Field("@@frdt")  @dtw_assign(V_N1FRDT, fieldValue)
                                  @Decat_Field("@@todt")  @dtw_assign(V_N1TODT, fieldValue)
                                  @Decat_Field("@@adt@")  @dtw_assign(V_N1ADT, fieldValue)

                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}

                                  %if (V_OUTFMT == "02")
                                     @dtw_assign(seqReport, "")
                                     @dtw_assign(seqCSV, "CHECKED")
                                  %else
                                     @dtw_assign(seqReport, "CHECKED")
                                     @dtw_assign(seqCSV, "")
                                  %endif  
                                  %if (V_N1AITM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_N1AITC == "ALL")
                                      @dtw_assign(checkedallInventoryType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallInventoryType, "")
                                  %endif
                                  %if (V_N1APCL == "ALL")
                                      @dtw_assign(checkedallProductClass, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallProductClass, "")
                                  %endif
                                  %if (V_N1ABAC == "ALL")
                                      @dtw_assign(checkedallBuyerAnalyst, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallBuyerAnalyst, "")
                                  %endif
                                  %if (V_N1AABC == "ALL")
                                      @dtw_assign(checkedallABCCode, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallABCCode, "")
                                  %endif
                                  %if (V_N1APTYP == "ALL")
                                      @dtw_assign(checkedallPartType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPartType, "")
                                  %endif
                                  %if (V_N1ADT == "ALL")
                                      @dtw_assign(checkedallPeriodEndRange, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPeriodEndRange, "")
                                  %endif

                              %else
                                  @RtvDftPlant(plantNumber, plantName)
                                  %if (plantNumber != "0")
                                      @dtw_assign(V_N1PLT, plantNumber)
                                  %endif
                                  %if (plantNumber != "0" && resetSelectionFlag == "Y")
                                      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLFDTF", FDTF)
                                      @dtw_assign(periodFormat, FDTF)
                                      @dtw_assign(V_N1FMT,periodFormat)
                                  %endif
								  @dtw_assign(seqReport, "CHECKED")
                                  @dtw_assign(seqCSV, "")
                                  @dtw_assign(V_N1FMT,periodFormat)
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallInventoryType, "CHECKED")
                                  @dtw_assign(checkedallProductClass, "CHECKED")
                                  @dtw_assign(checkedallBuyerAnalyst, "CHECKED")
                                  @dtw_assign(checkedallABCCode, "CHECKED")
                                  @dtw_assign(checkedallPartType, "CHECKED")
                                  @dtw_assign(checkedallPeriodEndRange, "CHECKED")
                              %endif

                          </table>

                          <table $(contentTable)>
                              @SetTextOvr(Err_N1PLT)
                              <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                  <td class="inputnmbr"><input name="PlantNumber" value="$(V_N1PLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=PlantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input name="plantName" type="hidden"></td>
                              </tr>
                              @DspErrMsg(Err_N1PLT)
                              <tr><td> &nbsp; </td></tr>
							
                              <tr><td class="dsphdr"><span $(textOvr)>Output Format</span></td>
                                  <td class="inputnmbr"><input name="outFormat" type="radio" VALUE='01' $(seqReport)>Report</td>
                              </tr>
                              
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="outFormat" type="radio" VALUE='02' $(seqCSV)>CSV File</td>
                              </tr>
                              
							  <tr><td> &nbsp; </td></tr>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_N1FITM)
                              %if (textOvr == "") @SetTextOvr(Err_N1TITM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AITM) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N1FITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N1TITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=titemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="titemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FITM)
                              @DspErrMsg(Err_N1TITM)
                              @DspErrMsg(Err_N1AITM)

                              @SetTextOvr(Err_N1FITC)
                              %if (textOvr == "") @SetTextOvr(Err_N1TITC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AITC) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Inventory Type</span></td>
                                  <td class="inputalph"><input name="fromInventoryType" value="$(V_N1FITC)" type="text" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)invtypesearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromInventoryType&amp;fldDesc=finventoryTypeDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="finventoryTypeDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="toInventoryType" value="$(V_N1TITC)" type="text" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)invtypesearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toInventoryType&amp;fldDesc=tinventoryTypeDesc" onclick="$(searchWinVar)">$(searchImage) </a><input name="tinventoryTypeDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="allInventoryType" value='ALL' $(checkedallInventoryType) type="checkbox" onClick="if (this.checked) this.form.fromInventoryType.value='', this.form.toInventoryType.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FITC)
                              @DspErrMsg(Err_N1TITC)
                              @DspErrMsg(Err_N1AITC)

                              @SetTextOvr(Err_N1FPCL)
                              %if (textOvr == "") @SetTextOvr(Err_N1TPCL) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1APCL) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Product Class</span></td>
                                  <td class="inputalph"><input name="fromProductClass" value="$(V_N1FPCL)" type="text" size="8" maxlength="4"><a href="$(homeURL)$(cGIPath)ProdClassSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromProductClass&amp;fldDesc=fproductClassDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fproductClassDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="toProductClass" value="$(V_N1TPCL)" type="text" size="8" maxlength="4"><a href="$(homeURL)$(cGIPath)ProdClassSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toProductClass&amp;fldDesc=tproductClassDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="tproductClassDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allProductClass" value='ALL' $(checkedallProductClass) type="checkbox" onClick="if (this.checked) this.form.fromProductClass.value='', this.form.toProductClass.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FPCL)
                              @DspErrMsg(Err_N1TPCL)
                              @DspErrMsg(Err_N1APCL)

                              @SetTextOvr(Err_N1FBAC)
                              %if (textOvr == "") @SetTextOvr(Err_N1TBAC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ABAC) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Buyer/Analyst</span></td>
                                  <td class="inputnmbr"><input name="fromBuyerAnalyst" value="$(V_N1FBAC)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)BuyerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromBuyerAnalyst&amp;fldDesc=analystName&amp;buyerAnalyst=Analyst" onclick="$(searchWinVar)"> $(searchImage) </a><input name="analystName" type="hidden"><input name="Analyst" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toBuyerAnalyst" value="$(V_N1TBAC)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)BuyerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toBuyerAnalyst&amp;fldDesc=analystName&amp;buyerAnalyst=Analyst" onclick="$(searchWinVar)"> $(searchImage) </a><input name="analystName" type="hidden"><input name="Analyst" type="hidden"></td>
                                  <td class="inputalph"><input name="allBuyerAnalyst" value='ALL' $(checkedallBuyerAnalyst) type="checkbox" onClick="if (this.checked) this.form.fromBuyerAnalyst.value='', this.form.toBuyerAnalyst.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FBAC)
                              @DspErrMsg(Err_N1TBAC)
                              @DspErrMsg(Err_N1ABAC)

                              @SetTextOvr(Err_N1FABC)
                              %if (textOvr == "") @SetTextOvr(Err_N1TABC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AABC) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>ABC Code (A,B,C,D)</span></td>
                                  <td class="inputalph"><input name="fromABCCode" value="$(V_N1FABC)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="toABCCode" value="$(V_N1TABC)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="allABCCode" value='ALL' $(checkedallABCCode) type="checkbox" onClick="if (this.checked) this.form.fromABCCode.value='', this.form.toABCCode.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FABC)
                              @DspErrMsg(Err_N1TABC)
                              @DspErrMsg(Err_N1AABC)

                              @SetTextOvr(Err_N1FPTYP)
                              %if (textOvr == "") @SetTextOvr(Err_N1TPTYP) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1APTYP) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Part Type (M,P,S)</span></td>
                                  <td class="inputnmbr"><input name="fromPartType" value="$(V_N1FPTYP)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputnmbr"><input name="toPartType" value="$(V_N1TPTYP)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="allPartType" value='ALL' $(checkedallPartType) type="checkbox" onClick="if (this.checked) this.form.fromPartType.value='', this.form.toPartType.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FPTYP)
                              @DspErrMsg(Err_N1TPTYP)
                              @DspErrMsg(Err_N1APTYP)

                              @SetTextOvr(Err_N1FMT)
                              <tr><td  class="dsphdr"><span $(textOvr)>Period Format</span></td>
                                  <td class="inputalph"><input name="periodFormat" type="text" value="$(V_N1FMT)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=FORECASTDF&amp;flagSrchHdr=@dtw_rurlescseq("Period Format")&amp;docName=Chg&amp;fldName=periodFormat&amp;fldDesc=periodFormatDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="periodFormatDesc" value="$(fieldDesc)" type="hidden"></td>
                              @DspErrMsg(Err_N1FMT)
                              @SetTextOvr(Err_N1FRDT)
                              %if (textOvr == "") @SetTextOvr(Err_N1TODT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ADT) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Period-End Range</span></td>
                                  <td class="inputnmbr"><input name="fromPeriodEndRange" type="text" value="$(V_N1FRDT)" size="6" maxlength="6"><a href="$(homeURL)$(cGIPath)PlanningPeriodSearch.d2w/LOAD$(genericVarBase)&amp;plant=$(V_N1PLT)&amp;format=$(periodFormat)&amp;docName=Chg&amp;fldEndDate=fromPeriodEndRange" onclick="$(searchWinVar)"> $(searchImage) </a></td>
                                  <td class="inputnmbr"><input name="toPeriodEndRange" type="text" value="$(V_N1TODT)" size="6" maxlength="6"><a href="$(homeURL)$(cGIPath)PlanningPeriodSearch.d2w/LOAD$(genericVarBase)&amp;plant=$(V_N1PLT)&amp;format=$(periodFormat)&amp;docName=Chg&amp;fldEndDate=toPeriodEndRange" onclick="$(searchWinVar)"> $(searchImage) </a></td>

                                  <td class="inputalph"><input name="allPeriodEndRange" value='ALL' $(checkedallPeriodEndRange) type="checkbox" onClick="if (this.checked) this.form.fromPeriodEndRange.value='', this.form.toPeriodEndRange.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FRDT)
                              @DspErrMsg(Err_N1TODT)
                              @DspErrMsg(Err_N1ADT)

                          </table>

                          %if (outFormat == "01")
                              @dtw_assign(envProgram, "HMS221")
                          %elseif (outFormat == "02")
                              @dtw_assign(envProgram, "HMS221CSV")
                          %endif
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HMSPPS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}
%HTML(LOAD) {
  %INCLUDE "SetLibraryList.icl"
  @RtvDftPlant(plantNumber, plantName)
  %if (plantNumber != "0")
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLFDTF", FDTF)
      @dtw_assign(periodFormat, $(FDTF))
      @dtw_assign(V_N1FMT,periodFormat)
  %endif
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(fromInventoryType)
  @dtw_mUPPERCASE(toInventoryType)
  @dtw_mUPPERCASE(allInventoryType)
  @dtw_mUPPERCASE(fromProductClass)
  @dtw_mUPPERCASE(toProductClass)
  @dtw_mUPPERCASE(allProductClass)
  @dtw_mUPPERCASE(allBuyerAnalyst)
  @dtw_mUPPERCASE(fromABCCode)
  @dtw_mUPPERCASE(toABCCode)
  @dtw_mUPPERCASE(allABCCode)
  @dtw_mUPPERCASE(fromPartType)
  @dtw_mUPPERCASE(toPartType)
  @dtw_mUPPERCASE(allPartType)
  @dtw_mUPPERCASE(allPeriodEndRange)

  @dtw_assign(PlantNumber,@dtw_rstrip(PlantNumber))
  @dtw_assign(fromBuyerAnalyst,@dtw_rstrip(fromBuyerAnalyst))
  @dtw_assign(toBuyerAnalyst,@dtw_rstrip(toBuyerAnalyst))
  @dtw_assign(fromPeriodEndRange,@dtw_rstrip(fromPeriodEndRange))
  @dtw_assign(toPeriodEndRange,@dtw_rstrip(toPeriodEndRange))

  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif

  %if (allInventoryType != "ALL")
      @dtw_assign(allInventoryType, "")
  %endif

  %if (allProductClass != "ALL")
      @dtw_assign(allProductClass, "")
  %endif

  %if (allBuyerAnalyst != "ALL")
      @dtw_assign(allBuyerAnalyst, "")
  %endif

  %if (allABCCode != "ALL")
      @dtw_assign(allABCCode, "")
  %endif

  %if (allPartType != "ALL")
      @dtw_assign(allPartType, "")
  %endif

  %if (allPeriodEndRange != "ALL")
      @dtw_assign(allPeriodEndRange, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", PlantNumber)
  @Concat_Field("@@selv", outFormat)
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@fitc", fromInventoryType)
  @Concat_Field("@@titc", toInventoryType)
  @Concat_Field("@@aitc", allInventoryType)
  @Concat_Field("@@fpcl", fromProductClass)
  @Concat_Field("@@tpcl", toProductClass)
  @Concat_Field("@@apcl", allProductClass)
  @Concat_Field("@@fbac", fromBuyerAnalyst)
  @Concat_Field("@@tbac", toBuyerAnalyst)
  @Concat_Field("@@abac", allBuyerAnalyst)
  @Concat_Field("@@fabc", fromABCCode)
  @Concat_Field("@@tabc", toABCCode)
  @Concat_Field("@@aabc", allABCCode)
  @Concat_Field("@@ftyp", fromPartType)
  @Concat_Field("@@ttyp", toPartType)
  @Concat_Field("@@atyp", allPartType)
  @Concat_Field("@@fmt@", periodFormat)
  @Concat_Field("@@frdt", fromPeriodEndRange)
  @Concat_Field("@@todt", toPeriodEndRange)
  @Concat_Field("@@adt@", allPeriodEndRange)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}