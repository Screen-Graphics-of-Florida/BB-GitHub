%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Event Code Maintenance"
  d2wName                 = "EventCodeMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fileName=@dtw_rurlescseq(fileName)&amp;fileDesc=@dtw_rurlescseq(fileDesc)&amp;eventResv=@dtw_rurlescseq(eventResv)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;eventCode=@dtw_rurlescseq(eventCode)&amp;eventCodeDesc=@dtw_rurlescseq(eventCodeDesc)&amp;maintenanceCode=D"
  programName             = "HSYEVN_E"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.eventCode.value =="" ||
                      document.Chg.eventCodeDesc.value =="")
                     {alert("$(reqFieldError)"); return false;}
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "EVENTCODEMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, " Select * From SYEVNT Where ECEVNT = '$(eventCode)'", stmtSQL)
                          @dtw_concat(stmtSQL, " and ECFILN = '$(fileName)' ", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %if (eventResv == "Y")
          @dtw_assign(sec_03, "N")
      %endif

      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          @Format_Header("Table", $(fileDesc), $(fileName))
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" NAME="Chg" METHOD=POST ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "eventCode")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@evnt", "eventCode")          @dtw_assign(Err_ECEVNT, fieldValue)
                          @DecatErr_Field("@@desc", "eventCodeDesc")      @dtw_assign(Err_ECDESC, fieldValue)
                          @DecatErr_Field("@@img@", "eventImage")         @dtw_assign(Err_ECIMG, fieldValue)
                          @DecatErr_Field("@@auto", "autoGenEvent")       @dtw_assign(Err_ECAUTO, fieldValue)
                          @DecatErr_Field("@@expg", "exitProgram")        @dtw_assign(Err_ECEXPG, fieldValue)
                      %endif

                      @Decat_Field("@@evnt")   @dtw_assign(V_ECEVNT, fieldValue)
                      @Decat_Field("@@desc")   @dtw_assign(V_ECDESC, fieldValue)
                      @Decat_Field("@@img@")   @dtw_assign(V_ECIMG,  fieldValue)
                      @Decat_Field("@@auto")   @dtw_assign(V_ECAUTO, fieldValue)
                      @Decat_Field("@@expg")   @dtw_assign(V_ECEXPG, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "eventCode")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_ECEVNT,  "")
                      @dtw_assign(focusField, "eventCode")
                  %else
                      @dtw_assign(focusField, "eventCodeDesc")
                  %endif

                  @SetTextOvr(Err_ECEVNT)
                  <tr><td class="dsphdr"><span $(textOvr)>Event Code</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="eventCode" type="text"  value="$(V_ECEVNT)" size="10" maxlength="10"> $(reqFieldChar) </td>
                      %else
                          <td class="inputalph"><input name="eventCode" type="hidden" value="$(V_ECEVNT)" size="10" maxlength="10">$(V_ECEVNT)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_ECEVNT)

                  @SetTextOvr(Err_ECDESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="eventCodeDesc" type="text" value="$(V_ECDESC)" size="50" maxlength="100"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_ECDESC)

                  @SetTextOvr(Err_ECIMG)
                  <tr><td class="dsphdr"><span $(textOvr)>Image</span></td>
                      <td class="inputalph"><input name="eventImage" type="text" value="$(V_ECIMG)" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_ECIMG)

                  @RtvFldDesc("FLTYPE='BY' and FLVALU='$(V_ECAUTO)'", "SYFLAG", "FLDESC", fieldReclaimDesc)
                  @SetTextOvr(Err_ECAUTO)
                  <tr><td class="dsphdr"><span $(textOvr)>Auto Generate Event</span></td>
                      <td class="inputalph"><input name="autoGenEvent" type="text" value="$(V_ECAUTO)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=BY&amp;flagSrchHdr=@dtw_rurlescseq("Auto Generate Event")&amp;docName=Chg&amp;fldName=autoGenEvent&amp;fldDesc=autoGenEventDesc" onclick="$(searchWinVar)"> $(searchImage)</a>
                          <input name="autoGenEventDesc" value="$(fieldReclaimDesc)" type="text" size="50" disabled></td>
                  </tr>
                  @DspErrMsg(Err_ECAUTO)

                  @SetTextOvr(Err_ECEXPG)
                  <tr><td class="dsphdr"><span $(textOvr)>Exit Program</span></td>
                      <td class="inputalph"><input name="exitProgram" type="text" value="$(V_ECEXPG)" size="10" maxlength="10"></td>
                  </tr>
                  @DspErrMsg(Err_ECEXPG)

                  <tr><td><input name="timeStamp" type="hidden" value="$(V_ECTSTP)"></td></tr>
              %}
          </table>
	
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSYEVN_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(eventCode)
  @dtw_mUPPERCASE(autoGenEvent)
  @dtw_mUPPERCASE(exitProgram)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@filn", fileName)
  @Concat_Field("@@evnt", eventCode)
  @Concat_Field("@@desc", eventCodeDesc)
  @Concat_Field("@@img@", eventImage)
  @Concat_Field("@@auto", autoGenEvent)
  @Concat_Field("@@expg", exitProgram)
  @Concat_Field("@@tstp", timeStamp)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(eventCodeDesc), $(eventCode), "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)eventcode.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@evnt", "eventCode")
      @Format_ConfMsg_Desc("", $(eventCodeDesc), $(eventCode), "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)eventcode.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;eventCode=@dtw_rurlescseq(eventCode)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
