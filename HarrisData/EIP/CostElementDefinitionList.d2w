%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Cost Element Definition List"
  d2wName                 = "CostElementDefinitionList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"

              function validate(chgForm) {

                  if (document.Chg.manufactured.checked == false &&
                      document.Chg.purchased.checked == false)
                      {alert("Must make at least one 'Select Part Type' selection");
                      return false;}

                  if  (editNum(document.Chg.fromCostSet, 2, 0) &&
                      editNum(document.Chg.toCostSet, 2, 0) &&
                      editNum(document.Chg.fromCostElement, 3, 0) &&
                      editNum(document.Chg.toCostElement, 3, 0) &&
                      editNum(document.Chg.fromCostCategory, 1, 0) &&
                      editNum(document.Chg.toCostCategory, 1, 0) &&
                      editFromToAll(document.Chg.fromCostSet, document.Chg.toCostSet, document.Chg.allCostSet, 2) &&
                      editFromToAll(document.Chg.fromCostElement, document.Chg.toCostElement, document.Chg.allCostElement, 3) &&
                      editFromToAll(document.Chg.fromCostCategory, document.Chg.toCostCategory, document.Chg.allCostCategory, 1) &&
                      editFromToAll(document.Chg.fromCostMethod, document.Chg.toCostMethod, document.Chg.allCostMethod, "A"))
                      return true;

              }
                      function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }

          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "COSTELEMENTDEFINITIONLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromCostSet")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@mfg@", "manufactured")        @dtw_assign(Err_N1MFG,  fieldValue)
                                  @DecatErr_Field("@@pur@", "purchased")        @dtw_assign(Err_N1PUR,  fieldValue)
                                  @DecatErr_Field("@@fset", "fromCostSet")        @dtw_assign(Err_N1FSET,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@mfg@")  @dtw_assign(V_N1MFG,  fieldValue)
                                  @Decat_Field("@@pur@")  @dtw_assign(V_N1PUR,  fieldValue)
                                  @Decat_Field("@@fset")  @dtw_assign(V_N1FSET,  fieldValue)
                                  @Decat_Field("@@tset")  @dtw_assign(V_N1TSET,  fieldValue)
                                  @Decat_Field("@@aset")  @dtw_assign(V_N1ASET,  fieldValue)
                                  @Decat_Field("@@felm")  @dtw_assign(V_N1FELM,  fieldValue)
                                  @Decat_Field("@@telm")  @dtw_assign(V_N1TELM,  fieldValue)
                                  @Decat_Field("@@aelm")  @dtw_assign(V_N1AELM,  fieldValue)
                                  @Decat_Field("@@fcat")  @dtw_assign(V_N1FCAT,  fieldValue)
                                  @Decat_Field("@@tcat")  @dtw_assign(V_N1TCAT,  fieldValue)
                                  @Decat_Field("@@acat")  @dtw_assign(V_N1ACAT,  fieldValue)
                                  @Decat_Field("@@fmet")  @dtw_assign(V_N1FMET,  fieldValue)
                                  @Decat_Field("@@tmet")  @dtw_assign(V_N1TMET,  fieldValue)
                                  @Decat_Field("@@amet")  @dtw_assign(V_N1AMET,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries
 Values %}
                                  %if (V_N1MFG == "01")
                                      @dtw_assign(checkedManufactured, "CHECKED")
                                  %else
                                      @dtw_assign(checkedManufactured, "")
                                  %endif
                                  %if (V_N1PUR == "01")
                                      @dtw_assign(checkedPurchased, "CHECKED")
                                  %else
                                      @dtw_assign(checkedPurchased, "")
                                  %endif
                                  %if (V_N1ASET == "ALL")
                                      @dtw_assign(checkedAllCostSet, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllCostSet, "")
                                  %endif
                                  %if (V_N1AELM == "ALL")
                                      @dtw_assign(checkedAllCostElement, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllCostElement, "")
                                  %endif
                                  %if (V_N1ACAT == "ALL")
                                      @dtw_assign(checkedAllCostCategory, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllCostCategory, "")
                                  %endif
                                  %if (V_N1AMET == "ALL")
                                      @dtw_assign(checkedAllCostMethod, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllCostCostMethod, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedManufactured, "CHECKED")
                                  @dtw_assign(checkedPurchased, "CHECKED")
                                  @dtw_assign(checkedAllCostSet, "CHECKED")
                                  @dtw_assign(checkedAllCostElement, "CHECKED")
                                  @dtw_assign(checkedAllCostCategory, "CHECKED")
                                  @dtw_assign(checkedAllCostMethod, "CHECKED")
                              %endif


                              @SetTextOvr(Err_N1MFG)
                              <tr><td class="dsphdr"><span $(textOvr)>Select Part Type</span></td>
                                  <td class="inputnmbr"><input name="manufactured" type="checkbox" VALUE='01' $(checkedManufactured)>Manufactured</td>
                              </tr>
                              @DspErrMsg(Err_N1MFG)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="purchased" type="checkbox" VALUE='01' $(checkedPurchased)>Purchased</td>
                              </tr>

                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_N1FSET)
                              <tr><td  class="dsphdr"><span $(textOvr)>Cost Set</span></td>
                                  <td class="inputnmbr"><input name="fromCostSet" value="$(V_N1FSET)" type="text" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)CostSetDefinitionSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromCostSet&amp;fldDesc=fcostSetDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fcostSetDesc" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toCostSet" value="$(V_N1TSET)" type="text" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)CostSetDefinitionSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toCostSet&amp;fldDesc=tcostSetDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="tcostSetDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allCostSet" value='ALL' $(checkedAllCostSet) type="checkbox" onClick="if (this.checked) this.form.fromCostSet.value='', this.form.toCostSet.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FSET)

                              <tr><td  class="dsphdr"><span $(textOvr)>Cost Element</span></td>
                                  <td class="inputnmbr"><input name="fromCostElement" value="$(V_N1FELM)" type="text" size="3" maxlength="3"></td>
                                  <td class="inputnmbr"><input name="toCostElement" value="$(V_N1TELM)" type="text" size="3" maxlength="3"></td>
                                  <td class="inputalph"><input name="allCostElement" value='ALL' $(checkedAllCostElement) type="checkbox" onClick="if (this.checked) this.form.fromCostElement.value='', this.form.toCostElement.value='';"></td>
                              </tr>

                              <tr><td  class="dsphdr"><span $(textOvr)>Cost Category</span></td>
                                  <td class="inputnmbr"><input name="fromCostCategory" value="$(V_N1FCAT)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputnmbr"><input name="toCostCategory" value="$(V_N1TCAT)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="allCostCategory" value='ALL' $(checkedAllCostCategory) type="checkbox" onClick="if (this.checked) this.form.fromCostCategory.value='', this.form.toCostCategory.value='';"></td>
                              </tr>

                              <tr><td  class="dsphdr"><span $(textOvr)>Cost Method</span></td>
                                  <td class="inputalph"><input name="fromCostMethod" value="$(V_N1FMET)" type="text" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=COSTMETHOD&amp;flagSrchHdr=@dtw_rurlescseq("Cost Method")&amp;docName=Chg&amp;fldName=fromCostMethod&amp;fldDesc=fcodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fcodeDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="toCostMethod" value="$(V_N1TMET)" type="text" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=COSTMETHOD&amp;flagSrchHdr=@dtw_rurlescseq("Cost Method")&amp;docName=Chg&amp;fldName=toCostMethod&amp;fldDesc=tcodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="tcodeDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allCostMethod" value='ALL' $(checkedAllCostMethod) type="checkbox" onClick="if (this.checked) this.form.fromCostMethod.value='', this.form.toCostMethod.value='';"></td>
                              </tr>

                          @dtw_assign(envProgram, "HSC055")
                          @dtw_assign(envPrinter, "HSC055PF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                          %if (focusField != "")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSCCDS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allCostSet)
  @dtw_mUPPERCASE(allCostElement)
  @dtw_mUPPERCASE(allCostCategory)
  @dtw_mUPPERCASE(fromCostMethod)
  @dtw_mUPPERCASE(toCostMethod)
  @dtw_mUPPERCASE(allCostMethod)

  @dtw_assign(fromCostSet,@dtw_rstrip(fromCostSet))
  @dtw_assign(toCostSet,@dtw_rstrip(toCostSet))
  @dtw_assign(fromCostElement,@dtw_rstrip(fromCostElement))
  @dtw_assign(toCostElement,@dtw_rstrip(toCostElement))
  @dtw_assign(fromCostCategory,@dtw_rstrip(fromCostCategory))
  @dtw_assign(toCostCategory,@dtw_rstrip(toCostCategory))

  %if (allCostSet != "ALL")
      @dtw_assign(allCostSet, "")
  %endif
  %if (allCostElement != "ALL")
      @dtw_assign(allCostElement, "")
  %endif
  %if (allCostCategory != "ALL")
      @dtw_assign(allCostCategory, "")
  %endif
  %if (allCostMethod != "ALL")
      @dtw_assign(allCostMethod, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@mfg@", manufactured)
  @Concat_Field("@@pur@", purchased)
  @Concat_Field("@@fset", fromCostSet)
  @Concat_Field("@@tset", toCostSet)
  @Concat_Field("@@aset", allCostSet)
  @Concat_Field("@@felm", fromCostElement)
  @Concat_Field("@@telm", toCostElement)
  @Concat_Field("@@aelm", allCostElement)
  @Concat_Field("@@fcat", fromCostCategory)
  @Concat_Field("@@tcat", toCostCategory)
  @Concat_Field("@@acat", allCostCategory)
  @Concat_Field("@@fmet", fromCostMethod)
  @Concat_Field("@@tmet", toCostMethod)
  @Concat_Field("@@amet", allCostMethod)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}