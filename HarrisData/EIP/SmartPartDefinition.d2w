%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Smart Part Segment Definition"
  d2wName                 = "SmartPartDefinition.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;template=@dtw_rurlescseq(template)&amp;templateDesc=@dtw_rurlescseq(templateDesc)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemGroup=@dtw_rurlescseq(itemGroup)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HHDSSD_E"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script type="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchSegn, 2, 0))
                      return true;
              }
           </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "SMARTPARTDEFINITION")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " HDSPSD ", fileSQL)
                      @dtw_concat(selectSQL, "SGTEMP=$(template)", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @SmartPart_Definition_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) SmartPart_Definition_Query (IN CHAR(64)    profileHandle,
                                                  CHAR(2)     dataBaseID,
                                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      <a href="$(homeURL)$(cGIPath)SmartPartTemplate.d2w/REPORT$(genericVarBase)" title="Back Home">$(portalHome)</a>
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)SmartPartDefinitionMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      <table $(contentTable)>
          @Format_Header("Template ID", $(templateDesc), $(template))
          %if (plantNumber > "0")
              @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
              @Format_Header_URL("Plant", $(plantName), $(plantNumber), "$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;plantName=@dtw_rurlescseq(plantName)")
          %endif
          %if (itemGroup != "")
              @RtvFldDesc("IGTYPE='F' and IGIGRP='$(itemGroup)'", "HDIGPH", "IGDESC", itemGroupDesc)
              @Format_Header("Feature Family", $(itemGroupDesc), $(itemGroup))
          %endif
      </table>

      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Description</th>
                      <th class="colhdr">Featured<br>Item</th>
                      <th class="colhdr">Feature</th>
                      <th class="colhdr">Option</th>
                      <th class="colhdr">Segment</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="10" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchFprt" size="10" maxlength="15">
                          <input type="hidden" name="operFprt" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchFeat" size="10" maxlength="15">
                          <input type="hidden" name="operFeat" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchOptn" size="10" maxlength="15">
                          <input type="hidden" name="operOtpn" value="LIKE">
                      </td>
                      <td><input type="text" class="inputnbmr" name="srchSegn" size="2" maxlength="2">
                          <input type="hidden" name="operSegn" value="=">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>
      %endif

      <table $(contentTable)>
          <tr>
              <th class="dspalph" colspan="7">
                  %if (formatToPrint != "Y")
                      %INCLUDE "WildCardPage.icl"
                  %else
                      &nbsp;
                  %endif
              </th>
              <th class="grphdr"  colspan="7">Retrieve Segment Value From</th>
          </tr>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("SGFPRT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Fprt" title="Sequence By Featured Item, Segment">Featured Item</a></th>
              @OrderBy_Sort("SGFEAT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Feat" title="Sequence By Feature, Segment">Feature</a></th>
              @OrderBy_Sort("SGOPTN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Optn" title="Sequence By Option, Segment">Option</a></th>
              @OrderBy_Sort("SGDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description, Segment">Description</a></th>
              @OrderBy_Sort("SGSEGN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Segm" title="Sequence By Segment, Option">Segment</a></th>
              @OrderBy_Sort("SGREPL", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Repl" title="Sequence By Replace, Segment">Replace<br>Data</a></th>
              @OrderBy_Sort("SGSMPT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Smart" title="Sequence By Smart Part Code, Segment">Smart<br>Part<br>Code</a></th>
              @OrderBy_Sort("SGDOPT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DftOpt" title="Sequence By Option, Segment">Option</a></th>
              @OrderBy_Sort("SGALPH", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Alph" title="Sequence By Assigned Value, Segment">Assigned<br>Value</a></th>
              @OrderBy_Sort("SGTBLN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Table" title="Sequence By Table/Column, Segment">Table/<br>Column</a></th>
              @OrderBy_Sort("SGSCRP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Prompt" title="Sequence By Screen Prompt, Segment">Screen<br>Prompt</a></th>
              @OrderBy_Sort("SGEXIT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Exit" title="Sequence By Exit Program, Segment">Exit<br>Program</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;featuredItem=@dtw_rurlescseq(V_SGFPRT)&amp;feature=@dtw_rurlescseq(V_SGFEAT)&amp;option=@dtw_rurlescseq(V_SGOPTN)&amp;segmentNum=@dtw_rurlescseq(V_SGSEGN)&amp;segmentDesc=@dtw_rurlescseq(V_SGDESC)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_SGDESC), $(V_SGSEGN), "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)SmartPartDefinitionMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)SmartPartDefinitionMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)SmartPartDefinitionMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_SGFPRT)</td>
                  <td class="colalph">$(V_SGFEAT)</td>
                  <td class="colalph">$(V_SGOPTN)</td>
                  <td class="colalph">$(V_SGDESC)</td>
                  <td class="colcode">$(V_SGSEGN)</td>
                  <td class="colcode">$(V_SGREPL)</td>
                  %if (V_SGSMPT == "Y")
                      <td class="colcode">$(selectedImageSml)</td>
                  %else
                      <td class="colcode">&nbsp;</td>
                  %endif
                  %if (V_SGDOPT == "Y")
                      <td class="colcode">$(selectedImageSml)</td>
                  %else
                      <td class="colcode">&nbsp;</td>
                  %endif
                  <td class="colalph">$(V_SGALPH)</td>
                  %if (V_SGTBLN != "")
                      <td class="colalph">$(V_SGTBLN)/$(V_SGCOLN)</td>
                  %else
                      <td class="colalph">&nbsp;</td>
                  %endif
                  <td class="colalph">$(V_SGSCRP)</td>
                  <td class="colalph">$(V_SGEXIT)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "SGDESCU")
          @DTW_ASSIGN(orderByDisplay, "Description")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Fprt")
      %if (orderBy == "SGFPRT,SGSEGN")
          @DTW_ASSIGN(orderBy, "SGFPRT DESC,SGSEGN")
          @DTW_ASSIGN(orderByDisplay, "Featured Item (descending), Sequence")
      %else
          @DTW_ASSIGN(orderBy, "SGFPRT,SGSEGN")
          @DTW_ASSIGN(orderByDisplay, "Featured Item, Sequence")
      %endif
  %elif (sequence == "Feat")
      %if (orderBy == "SGFEAT,SGSEGN")
          @DTW_ASSIGN(orderBy, "SGFEAT DESC,SGSEGN")
          @DTW_ASSIGN(orderByDisplay, "Feature (descending), Sequence")
      %else
          @DTW_ASSIGN(orderBy, "SGFEAT,SGSEGN")
          @DTW_ASSIGN(orderByDisplay, "Feature, Sequence")
      %endif
  %elif (sequence == "Optn")
      %if (orderBy == "SGOPTN,SGSEGN")
          @DTW_ASSIGN(orderBy, "SGOPTN DESC,SGSEGN")
          @DTW_ASSIGN(orderByDisplay, "Option (descending), Sequence")
      %else
          @DTW_ASSIGN(orderBy, "SGOPTN,SGSEGN")
          @DTW_ASSIGN(orderByDisplay, "Option, Sequence")
      %endif
  %elif (sequence == "Desc")
      %if (orderBy == "SGDESCU,SGSEGN")
          @DTW_ASSIGN(orderBy, "SGDESCU DESC,SGSEGN")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Sequence")
      %else
          @DTW_ASSIGN(orderBy, "SGDESCU,SGSEGN")
          @DTW_ASSIGN(orderByDisplay, "Description, Sequence")
      %endif
  %elif (sequence == "Segm")
      %if (orderBy == "SGSEGN,SGOPTN")
          @DTW_ASSIGN(orderBy, "SGSEGN DESC,SGOPTN")
          @DTW_ASSIGN(orderByDisplay, "Seqment (descending), Option")
      %else
          @DTW_ASSIGN(orderBy, "SGSEGN,SGOPTN")
          @DTW_ASSIGN(orderByDisplay, "Seqment, Option")
      %endif
  %elif (sequence == "Repl")
      %if (orderBy == "SGREPL,SGSEGN")
          @DTW_ASSIGN(orderBy, "SGREPL DESC,SGSEGN")
          @DTW_ASSIGN(orderByDisplay, "Replace (descending), Segment")
      %else
          @DTW_ASSIGN(orderBy, "SGREPL,SGSEGN")
          @DTW_ASSIGN(orderByDisplay, "Replace, Segment")
      %endif
  %elif (sequence == "Smart")
      %if (orderBy == "SGSMPT,SGSEGN")
          @DTW_ASSIGN(orderBy, "SGSMPT DESC,SGSEGN")
          @DTW_ASSIGN(orderByDisplay, "Smart Part Code (descending), Sequence")
      %else
          @DTW_ASSIGN(orderBy, "SGSMPT,SGSEGN")
          @DTW_ASSIGN(orderByDisplay, "Smart Part Code, Sequence")
      %endif
  %elif (sequence == "DftOpt")
      %if (orderBy == "SGDOPT,SGSEGN")
          @DTW_ASSIGN(orderBy, "SGDOPT DESC,SGSEGN")
          @DTW_ASSIGN(orderByDisplay, "Option (descending), Sequence")
      %else
          @DTW_ASSIGN(orderBy, "SGDOPT,SGSEGN")
          @DTW_ASSIGN(orderByDisplay, "Option, Sequence")
      %endif
  %elif (sequence == "Alph")
      %if (orderBy == "SGALPH,SGSEGN")
          @DTW_ASSIGN(orderBy, "SGALPH DESC,SGSEGN")
          @DTW_ASSIGN(orderByDisplay, "Assigned Value (descending), Sequence")
      %else
          @DTW_ASSIGN(orderBy, "SGALPH,SGSEGN")
          @DTW_ASSIGN(orderByDisplay, "Assigned Value, Sequence")
      %endif
  %elif (sequence == "Table")
      %if (orderBy == "SGTBLN,SGCOLN,SGSEGN")
          @DTW_ASSIGN(orderBy, "SGTBLN DESC,SGCOLNS,GSEGN")
          @DTW_ASSIGN(orderByDisplay, "Table (descending), Column, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "SGTBLN,SGCOLN,SGSEGN")
          @DTW_ASSIGN(orderByDisplay, "Table, Column, Sequence")
      %endif
  %elif (sequence == "Prompt")
      %if (orderBy == "SGSCRP,SGSEGN")
          @DTW_ASSIGN(orderBy, "SGSCRP DESC,SGSEGN")
          @DTW_ASSIGN(orderByDisplay, "Screen Prompt (descending), Sequence")
      %else
          @DTW_ASSIGN(orderBy, "SGSCRP,SGSEGN")
          @DTW_ASSIGN(orderByDisplay, "Screen Prompt, Sequence")
      %endif
  %elif (sequence == "Exit")
      %if (orderBy == "SGEXIT,SGSEGN")
          @DTW_ASSIGN(orderBy, "SGEXIT DESC,SGSEGN")
          @DTW_ASSIGN(orderByDisplay, "Exit Program (descending), Sequence")
      %else
          @DTW_ASSIGN(orderBy, "SGEXIT,SGSEGN")
          @DTW_ASSIGN(orderByDisplay, "Exit Program, Sequence")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              function validate(searchForm) {
                  if (editNum(document.Search.srchSegn, 2, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PRICINGLEVELSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      <table $(contentTable)>
                          %INCLUDE "SearchPageTitle.icl"
                          $(hrTagAttr)
                          @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                          %INCLUDE "WildCardReset.icl"

                          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                              %INCLUDE "SearchTop.icl"

                              <tr><td class="dsphdr">Description</td>
                                  @dtw_assign(operNbr, "operDesc")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchDesc" size="15" maxlength="30"></td>
                              </tr>

                              <tr><td class="dsphdr">Featured Item</td>
                                  @dtw_assign(operNbr, "operFprt")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchFprt" size="15" maxlength="15"></td>
                              </tr>

                              <tr><td class="dsphdr">Feature</td>
                                  @dtw_assign(operNbr, "operFeat")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchFeat" size="15" maxlength="15"></td>
                              </tr>

                              <tr><td class="dsphdr">Option</td>
                                  @dtw_assign(operNbr, "operOptn")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchOptn" size="15" maxlength="15"></td>
                              </tr>

                              <tr><td class="dsphdr">Segment</td>
                                  @dtw_assign(operNbr, "operSegn")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchSegn" size="5" maxlength="2"></td>
                              </tr>
                      </table>


                      <table $(contentTable)>
                          <tr><td>&nbsp;</td></tr>
                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchLevel.focus();
                          </script>
                          </form>
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </table>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("SGDESCU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("SGFPRT", "Featured Item", $(srchFprt), "U", operFprt, "A")
  @Build_WildCard ("SGFEAT", "Feature", $(srchFeat), "U", operFeat, "A")
  @Build_WildCard ("SGOPTN", "Option", $(srchOptn), "U", operOptn, "A")
  @Build_WildCard ("SGSEGN", "Segment", $(srchSegn), "", operSegn, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
