%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"

%Define {
  page_title              = "Work Item History Comment"
  d2wName                 = "WFHistoryComment.d2w"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @dtw_assign(edtVar, "")
  @Concat_Field("@@inst", wfInstance)
  @Concat_Field("@@indt", wfInstanceDate)
  @dtw_concat(edtVar, "}{", edtVar)
  @WFWrkItmUserView(profileHandle, dataBaseID, userPass, edtVar)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onLoad="window.focus()" onBlur="window.close()">
              <!-- Start Of Banner Code -->
              %INCLUDE "$(inquiryBanner)"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      <td>
                          @dtw_concat(stmtSQL, " Select WFWICM.*,WFWIPT.* ", stmtSQL)
                          @dtw_concat(fileSQL, " WFWICM ", fileSQL)
                          @dtw_concat(fileSQL, " inner join WFWIPT on WPINST=WCINST and WPINDT=WCINDT and WPWITM=WCWITM and WPWISQ=WCWISQ and WPPTID=WCPTID ", fileSQL)
                          @dtw_concat(selectSQL, " WCINST=$(wfInstance) and WCINDT=$(wfInstanceDate) and WCWITM=$(wfWorkItem) and WCWISQ=$(wfWorkItemSequence)", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By WCINST,WCINDT,WCWITM,WCWISQ,WCPTID,WCCSEQ ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @List_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "$(inquiryTrailer)"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64) profileHandle,
                                   CHAR(2)   dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(displayCloseIcon, "Y")
      %INCLUDE "PageTitle.icl"

      <table $(contentTable)>
          @RtvFldDesc("ININST=$(wfInstance) and ININDT=$(wfInstanceDate)", "WFINST", "INDESC", V_INDESC)
          <tr><td><h2> $(V_INDESC)</h2></td></tr>
          @RtvFldDesc("ININST=$(wfInstance) and ININDT=$(wfInstanceDate)", "WFINST", "INPROC", V_INPROC)
          @RtvFldDesc("WHINST=$(wfInstance) and WHINDT=$(wfInstanceDate) and WHWITM=$(wfWorkItem) and WHWISQ=$(wfWorkItemSequence)", "WFWIHS", "CHAR(WHPONT)", V_WHPONT)
          @RtvFldDesc("WHINST=$(wfInstance) and WHINDT=$(wfInstanceDate) and WHWITM=$(wfWorkItem) and WHWISQ=$(wfWorkItemSequence)", "WFWIHS", "CHAR(WHSEQ)", V_WHSEQ)
          @RtvFldDesc("PDPROC='$(V_INPROC)' and PDPONT=$(V_WHPONT) and PDSEQ=$(V_WHSEQ) ", "WFPRDT", "PDDESC", V_PDDESC)
          @Format_Code("$(V_WHPONT)-$(V_WHSEQ)", F_WHPONT)
          <tr><td><h2> $(V_PDDESC) $(F_WHPONT)</h2></td></tr>
      </table>

      $(inquiryhrTagAttr)

      <table $(contentTable)>
          @dtw_assign(Check_WCPTID, "")

          %ROW{
              %if (V_WCPTID != Check_WCPTID)
                  @dtw_assign(Check_WCPTID, V_WCPTID)
                  @RtvFldDesc("USUSER='$(V_WPPART)'", "SYUSER", "USDESC", V_USDESC)
                  @RtvFldDesc("RSREAS='$(V_WCREAS)'", "WFRSCD", "RSDESC", V_RSDESC)
                  @Format_Code(V_RSDESC, F_RSDESC)
                  <tr><td><h2>$(V_USDESC) $(F_RSDESC):</h2></td></tr>
              %endif

              <tr>
                  <td class="colalph">$(V_WCCMNT)</td>
              </tr>
          %}
      </table>
      $(inquiryhrTagAttr)
      %INCLUDE "CloseWindow.icl"
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}