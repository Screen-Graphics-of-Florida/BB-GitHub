%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Customer Ship Via"
  d2wName                 = "CustomerShipVia.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;forCustNumber=@dtw_rurlescseq(forCustNumber)&amp;forCustName=@dtw_rurlescseq(forCustName)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HHDCSV_E"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @dtw_assign(userPass, "")	
  %if (forCustNumber > "0")
      @CustomerUserView(profileHandle, dataBaseID, userPass, forCustNumber, " ")
  %endif
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
                  %INCLUDE "CheckEnterSearch.icl"
                  %INCLUDE "NoFormValidate.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- Start Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                          @dtw_assign(pageID, "CUSTOMERSHIPVIA")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          @dtw_assign(uv_CustomerName, "CSSHTO")
    	               %INCLUDE "userview.icl"

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select HDCUSV.*, SVSVDS, upper(SVSVDS) as SVSVDSU, CMCNA1, CMCNA1U ", stmtSQL)
                          @dtw_concat(fileSQL, " HDCUSV ", fileSQL)
                          @dtw_concat(fileSQL, " inner join HDSHPV on CSSVSV=SVSVSV ", fileSQL)
                          @dtw_concat(fileSQL, " inner join HDCUST on CSSHTO=CMCUST ", fileSQL)
                          @dtw_concat(selectSQL, "CSSVSV>' ' ", selectSQL)
                          %if (forCustNumber > "0")
                              @dtw_concat(selectSQL, " and CSSHTO=$(forCustNumber) ", selectSQL)
                          %endif
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Customer_ShipVia_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Customer_ShipVia_Query (IN CHAR(64)    profileHandle,
				               CHAR(2)     dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
             <col width="80%">
             <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)CustomerShipViaMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;vcNumber=@dtw_rurlescseq(forCustNumber)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %if (forCustNumber > "0")
          <table $(contentTable)>
              @Format_Header_URL("Ship-To", $(forCustName), $(forCustNumber), "$(homeURL)$(cGIPath)CustomerSelect.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(forCustNumber)&amp;customerName=@dtw_rurlescseq(forCustName)")
          </table>
      %endif
      %INCLUDE "ConfMessageDisplay.icl"
	
      $(hrTagAttr)
	
      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      %if (forCustNumber == "")
                          <th class="colhdr">Name</th>
                      %endif
                      <th class="colhdr">Ship Via</th>
                      <th class="colhdr">Description</th>
                  </tr>
                  <tr>
                      %if (forCustNumber == "")
                          <td><input type="text" class="inputalph" name="srchName" size="15" maxlength="26">
                              <input type="hidden" name="operName" value="LIKE">
                          </td>
                      %endif
                      <td><input type="text" class="inputalph" name="srchShipVia" size="2" maxlength="2">
                          <input type="hidden" name="operShipVia" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchDesc" size="15" maxlength="20">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  %if (forCustNumber == "")
                      document.Search.srchName.focus();
                  %else
                      document.Search.srchShipVia.focus();
                  %endif
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif
			
      <table $(contentTable)>
          <tr>
              %if ((formatToPrint != "Y") && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              %if (forCustNumber == "")
                  @OrderBy_Sort("CSSHTO", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CustNbr" title="Sequence By Ship-To, Ship Via">Ship-To</a></th>
                  @OrderBy_Sort("CMCNA1U", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CustName" title="Sequence By Name, Ship Via">Name</a></th>
              %endif
              @OrderBy_Sort("CSSVSV", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ShipVia" title="Sequence By Ship Via">Ship Via</a></th>
              @OrderBy_Sort("SVSVDSU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ShipViaDesc" title="Sequence By Description">Description</a></th>
              @OrderBy_Sort("CSSVAC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Account" title="Sequence By Account">Account</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"
			
          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;customerNumber=@dtw_rurlescseq(V_CSSHTO)&amp;shipVia=@dtw_rurlescseq(V_CSSVSV)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_CMCNA1), $(V_CSSHTO), $(V_SVSVDS), $(V_CSSVSV), "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if ((formatToPrint != "Y") && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)CustomerShipViaMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_04 == "Y")
                              <a href="$(homeURL)$(cGIPath)CustomerShipViaMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)CustomerShipViaMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  %if (forCustNumber == "")
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)CustomerInquiry.d2w/DISPLAY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(V_CSSHTO)" onclick="$(inquiryWinVar)" title="Ship-To Quickview">$(V_CSSHTO)</a></td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)CustomerSelect.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(V_CSSHTO)&amp;customerName=@dtw_rurlescseq(V_CMCNA1)" title="View Ship-To">$(V_CMCNA1)</a></td>
                  %endif
                  <td class="colalph">$(V_CSSVSV)</td>
                  <td class="colalph">$(V_SVSVDS)</td>
                  <td class="colalph">$(V_CSSVAC)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {	
  @dtw_assign(uv_CustomerName, "CSSHTO")
	               %INCLUDE "userview.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select HDCUSV.*, SVSVDS, upper(SVSVDS) as SVSVDSU, CMCNA1, CMCNA1U ", stmtSQL)
  @dtw_concat(fileSQL, " HDCUSV ", fileSQL)
  @dtw_concat(fileSQL, " inner join HDSHPV on CSSVSV=SVSVSV ", fileSQL)
  @dtw_concat(fileSQL, " inner join HDCUST on CSSHTO=CMCUST ", fileSQL)
  %if (forCustNumber > "0")
      @dtw_concat(selectSQL, "CSSHTO=$(forCustNumber) ", selectSQL)
  %endif
  %if (wildCardSearch!="" || uv_Sql!="")
      @dtw_concat(selectSQL, "CSSVSV>' ' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @Customer_ShipVia_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) Customer_ShipVia_XMLQuery (IN CHAR(64) profileHandle,
				                  CHAR(2)   dataBaseID,
                                                 CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("CustomerShipViaList")
          %ROW{
              @XMLIDTag(V_CSSHTO, "ShipToNumber ID")
              @XMLIDTag(V_CSSVSV, "ShipVia ID")
                  @XMLTag(V_CMCNA1, "CustomerName")
                  @XMLTag(V_SVSVDS, "ShipViaDesc")
                  @XMLTag(V_CSSVAC, "ShipViaAccount")
              @XMLEndTag("ShipVia")
              @XMLEndTag("ShipToNumber")
          %}
      @XMLEndTag("CustomerShipViaList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          %if (forCustNumber > "0")
              @DTW_ASSIGN(orderBy, "CSSVSV")
              @DTW_ASSIGN(orderByDisplay, "Ship Via")
          %else
              @DTW_ASSIGN(orderBy, "CMCNA1U")
              @DTW_ASSIGN(orderByDisplay, "Name")
          %endif
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit ()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "CustNbr")
      %if (orderBy == "CSSHTO,CSSVSV")
          @DTW_ASSIGN(orderBy, "CSSHTO DESC,CSSVSV")
          @DTW_ASSIGN(orderByDisplay, "Ship-To (descending), Ship Via")
      %else
          @DTW_ASSIGN(orderBy, "CSSHTO,CSSVSV")
          @DTW_ASSIGN(orderByDisplay, "Ship-To, Ship Via")
      %endif
  %elseif (sequence == "CustName")
      %if (orderBy == "CMCNA1U,CSSVSV")
          @DTW_ASSIGN(orderBy, "CMCNA1U DESC,CSSVSV")
          @DTW_ASSIGN(orderByDisplay, "Name (descending), Ship Via")
      %else
          @DTW_ASSIGN(orderBy, "CMCNA1U,CSSVSV")
          @DTW_ASSIGN(orderByDisplay, "Name, Ship Via")
      %endif
  %elseif (sequence == "ShipVia")
      %if (orderBy == "CSSVSV")
          @DTW_ASSIGN(orderBy, "CSSVSV DESC")
          @DTW_ASSIGN(orderByDisplay, "Ship Via (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CSSVSV")
          @DTW_ASSIGN(orderByDisplay, "Ship Via")
      %endif
  %elseif (sequence == "ShipViaDesc")
      %if (orderBy == "SVSVDSU")
          @DTW_ASSIGN(orderBy, "SVSVDSU DESC")
          @DTW_ASSIGN(orderByDisplay, "Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SVSVDSU")
          @DTW_ASSIGN(orderByDisplay, "Description")
      %endif
  %elseif (sequence == "Account")
      %if (orderBy == "CSSVAC,CMCNA1U")
          @DTW_ASSIGN(orderBy, "CSSVAC DESC,CMCNA1U")
          @DTW_ASSIGN(orderByDisplay, "Account (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "CSSVAC,CMCNA1U")
          @DTW_ASSIGN(orderByDisplay, "Account, Name")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          @dtw_assign(formName, "Search")
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  %if (forCustNumber == "")
                      if (editNum(document.Search.srchCust, 7, 0))
                  %endif
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CUSTOMERSHIPVIA")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          %if (forCustNumber == "")
                              <tr><td class="dsphdr">Ship-To</td>
                                  @dtw_assign(operNbr, "operCust")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input name="srchCust" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)CustomerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Search&amp;fldName=srchCust&amp;fldDesc=customerName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="customerName" value="$(customerName)" type="text" size="35" disabled></td>
                              </tr>

                              <tr><td class="dsphdr">Name</td>
                                  @dtw_assign(operNbr, "operName")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"> <input type="text" name="srchName" size="30" maxlength="30"></td>
                              </tr>
                          %endif

                          <tr><td class="dsphdr">Ship Via</td>
                              @dtw_assign(operNbr, "operShipVia")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchShipVia" type="text" size="3" maxlength="2"><a href="$(homeURL)$(cGIPath)ShipViaSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Search&amp;fldName=srchShipVia&amp;fldDesc=srchShipViaDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="srchShipViaDesc" type="text" size="35" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchDesc" type="text" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Account</td>
                              @dtw_assign(operNbr, "operAcct")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchAcct" type="text" size="20" maxlength="20"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              %if (forCustNumber == "")
                                  document.Search.srchCust.focus();
                              %else
                                  document.Search.srchShipVia.focus();
                              %endif
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("CMCUST", "Ship-To", $(srchCust), "", operCust, "N")
  @Build_WildCard ("CMCNA1U", "Name", $(srchName), "U", operName, "A")
  @Build_WildCard ("CSSVSV", "Ship Via", $(srchShipVia), "U", operShipVia, "A")
  @Build_WildCard ("upper(SVSVDS)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("CSSVAC", "Account Number", $(srchAcct), "U", operAcct, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
