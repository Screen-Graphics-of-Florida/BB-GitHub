%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Data Queue Display"
  d2wName                 = "DataQueueDisplay.d2w"
  d2wVarBase              = "$(genericVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {

%}

%FUNCTION(dtw_directcall) Display_DataQueue(inout        CHAR(32000) qData)

{%EXEC {HOEDQI.PGM %}
%}

%HTML(DISPLAY) {
       %INCLUDE "setLibraryList.icl"

       @dtw_assign(receiverLength, "32000")
       @dtw_assign(formatName, "RDQM0200")
       @dtw_assign(dataQueueName, "OEDTAQ")
       @dtw_assign(selectionLength, "8")
       @dtw_assign(msgSelectionFormatName, "RDQS0100")
       @dtw_assign(selectionType, "A")
       @dtw_assign(reserved, " ")
       @dtw_assign(nbrMessagesBytes, "32000")
       @dtw_assign(msgSelInfo, @dtw_rconcat(selectionType, @dtw_rconcat(reserved, nbrMessagesBytes)))
       @Display_DataQueue(data, receiverLength, formatName, DataQueueName, msgSelInfo, selectionLength, msgSelectionFormatName, errorCode)


  %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "Menu.js"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "DISPLAYDATAQUEUE")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                               <table><tr><td>
                               Data: $(data)</td></tr><tr><td>
                               Receiver Length: $(receiverLength)</td></tr><tr><td>
                               Format Name: $(formatName)</td></tr><tr><td>
                               Data Queue Name: $(dataQueueName)</td></tr><tr><td>
                               Message Selection Information: $(msgSelInfo)</td></tr><tr><td>
                               Selection Length: $(selectionLength)</td></tr><tr><td>
                               Message Selection Format Name: $(msgSelectionFormatName)</td></tr><tr><td>
                               RDQS100 Format: $(rDQS100Format)</td></tr><tr><td>
                               Error Code: $(errorCode)</td></tr>
                               </table>
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
%}
