%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Portal By Role Maintenance"
  d2wName                 = "PortalByRoleMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;role=@dtw_rurlescseq(role)&amp;roleDesc=@dtw_rurlescseq(roleDesc)&amp;roleSetup=@dtw_rurlescseq(roleSetup)&amp;inclNewRec=@dtw_rurlescseq(inclNewRec)&amp;inclOldRec=@dtw_rurlescseq(inclOldRec)&amp;inclSelRec=@dtw_rurlescseq(inclSelRec)&amp;inclNotSel=@dtw_rurlescseq(inclNotSel)"
  nextPrevVar             = "$(d2wVarBase)&amp;orderBy=@dtw_rurlescseq(orderBy)&amp;wildCardSearch=@dtw_rurlescseq(wildCardSearch)"
  wildDftVar              = "DISPLAY$(d2wVarBase)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=D"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  inclNewRec              = ""
  inclOldRec              = ""
  inclSelRec              = ""
  inclNotSel              = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          @dtw_assign(formName, "Search")
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PORTALBYROLEMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " SYPORW ", fileSQL)
                      @dtw_concat(selectSQL, "PWXHND='$(profileHandle)' and PWROLE='$(role)' and PWPAGE>' ' ", selectSQL)

                      %if ((inclNewRec == "Y") && (inclOldRec != "Y"))
                          @dtw_concat(selectSQL, "  and PWNEW='Y'", selectSQL)
                      %elif ((inclNewRec != "Y") && (inclOldRec == "Y"))
                          @dtw_concat(selectSQL, "  and PWNEW=' '", selectSQL)
                      %elif ((inclNewRec != "Y") && (inclOldRec != "Y"))
                          @dtw_concat(selectSQL, "  and PWNEW='*'", selectSQL)
                      %endif

                      %if ((inclSelRec == "Y") && (inclNotSel != "Y"))
                          @dtw_concat(selectSQL, "  and PWSEL='Y'", selectSQL)
                      %elif ((inclSelRec != "Y") && (inclNotSel == "Y"))
                          @dtw_concat(selectSQL, "  and PWSEL=' '", selectSQL)
                      %elif ((inclSelRec != "Y") && (inclNotSel != "Y"))
                          @dtw_concat(selectSQL, "  and PWSEL='*'", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  <a href="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">$(selectAcceptImage)</a>
                  <a href="$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(d2wVarBase)&amp;updateAll=S&amp;wildCardSearch=@dtw_rurlescseq(wildCardSearch)&amp;orderBy=@dtw_rurlescseq(orderBy)">$(selectAllImage)</a>
                  <a href="$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(d2wVarBase)&amp;updateAll=C&amp;wildCardSearch=@dtw_rurlescseq(wildCardSearch)&amp;orderBy=@dtw_rurlescseq(orderBy)">$(selectClearImage)</a>
                  <a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=203">$(cancelImageMed)</a>
                  %if (roleSetup == "Y")
                      <a onClick="return confirmDelete()" href="$(deleteURL)">$(deleteImageMed)</a>
                  %endif
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>

      <table $(contentTable)>
          @Format_Header("Role", $(roleDesc), $(role))
      </table>
      %INCLUDE "ConfMessageDisplay.icl"
      $(hrTagAttr)

      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr">Portal</th>
                  <th class="colhdr">Page</th>
                  <th class="colhdr">Description</th>
                  <th class="colhdr">URL ID</th>
              </tr>
                  <td><input type="text" class="inputalph" name="srchPortal" size="10" maxlength="20">
                      <input type="hidden" name="operPortal" value="LIKE">
                  </td>
                  <td><input type="text" class="inputalph" name="srchPage" size="10" maxlength="20">
                      <input type="hidden" name="operPage" value="LIKE">
                  </td>
                  <td><input type="text" class="inputalph" name="srchDesc" size="10" maxlength="20">
                      <input type="hidden" name="operDesc" value="LIKE">
                  </td>
                  <td><input type="text" class="inputalph" name="srchURLID" size="10" maxlength="55">
                      <input type="hidden" name="operURLID" value="LIKE">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
          <script TYPE="text/javascript">
              document.Search.srchPortal.focus();
          </script>
      </form>

	
      %if (inclNewRec == "Y")
          @dtw_assign(newRecChecked, "CHECKED")
      %else
          @dtw_assign(newRecChecked, "")
      %endif

      %if (inclOldRec == "Y")
          @dtw_assign(oldRecChecked, "CHECKED")
      %else
          @dtw_assign(oldRecChecked, "")
      %endif

      %if (inclSelRec == "Y")
          @dtw_assign(selRecChecked, "CHECKED")
      %else
          @dtw_assign(selRecChecked, "")
      %endif

      %if (inclNotSel == "Y")
          @dtw_assign(notSelChecked, "CHECKED")
      %else
          @dtw_assign(notSelChecked, "")
      %endif

      @dtw_assign(viewCheckBox, "PortalByRole")
      %INCLUDE "WildCardPage.icl"

      <form class="formClass" METHOD=POST name="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(genericVarBase)&amp;orderBy=@dtw_rurlescseq(orderBy)&amp;wildCardSearch=@dtw_rurlescseq(wildCardSearch)&amp;updateRowNum=@dtw_rurlescseq($(START_ROW_NUM))">
          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  <td class="colhdr">Sel</td>
                  @OrderBy_Sort("PWPORT", sortVar)
                  <td class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Portal" title="Sequence By Portal, Page, Sequence">Portal</a></td>
                  @OrderBy_Sort("PWPAGE", sortVar)
                  <td class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Page" title="Sequence By Page, Portal">Page</a></td>
                  @OrderBy_Sort("PWSEQ", sortVar)
                  <td class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Seq" title="Sequence By Sequence">Sequence</a></td>
                  @OrderBy_Sort("PWDESCU", sortVar)
                  <td class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description">Description</a></td>
                  @OrderBy_Sort("PWID", sortVar)
                  <td class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=URLID" title="Sequence By URL ID">URL ID</a></td>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
    		
              %ROW{
                  %INCLUDE "SetRowClass.icl"
                  %if (V_PWSEL == "Y")
                      @dtw_assign(selected, "CHECKED")
                      @dtw_assign(selDesc, "Deselect")
                  %else
                      @dtw_assign(selected, "")
                      @dtw_assign(selDesc, "Select")
                  %endif

                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;selected=@dtw_rurlescseq(V_PWSEL)&amp;orderBy=@dtw_rurlescseq(orderBy)&amp;wildCardSearch=@dtw_rurlescseq(wildCardSearch)&amp;updateRowNum=@dtw_rurlescseq($(START_ROW_NUM))")
                  <tr class="$(rowClass)">
                      <td class="colcode"><input type="checkbox" name="selc" $(selected) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(maintainVar)&amp;portalName=@dtw_rurlescseq(V_PWPORT)&amp;pageName=@dtw_rurlescseq(V_PWPAGE)&amp;seqNumber=@dtw_rurlescseq(V_PWSEQ)'" title="$(selDesc) this row"></td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(maintainVar)&amp;portalName=@dtw_rurlescseq(V_PWPORT)" title="$(selDesc) all rows for Portal [$(V_PWPORT)]">$(V_PWPORT)</a></td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(maintainVar)&amp;portalName=@dtw_rurlescseq(V_PWPORT)&amp;pageName=@dtw_rurlescseq(V_PWPAGE)" title="$(selDesc) all rows for Portal [$(V_PWPORT)] Page [$(V_PWPAGE)] ">$(V_PWPAGE)</a></td>
                      <td class="colnmbr">$(V_PWSEQ)</a></td>
                      <td class="colalph">$(V_PWDESC)</td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(maintainVar)&amp;urlID=@dtw_rurlescseq(V_PWID)" title="$(selDesc) all rows for URL ID [$(V_PWID)]">$(V_PWID)</a></td>
                  </tr>
              %}
          </table>
      </form>
      %INCLUDE "PageBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint == "Y")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "PWPORT,PWPAGE,PWSEQ")
          @DTW_ASSIGN(orderByDisplay, "Portal, Page, Sequence")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %elif (chgNewRec == "Y" && inclNewRec == "Y")
          @dtw_assign(inclNewRec, "")
      %elif (chgNewRec == "Y")
          @dtw_assign(inclNewRec, "Y")
      %elif (chgOldRec == "Y" && inclOldRec == "Y")
          @dtw_assign(inclOldRec, "")
      %elif (chgOldRec == "Y")
          @dtw_assign(inclOldRec, "Y")
      %elif (chgSelRec == "Y" && inclSelRec == "Y")
          @dtw_assign(inclSelRec, "")
      %elif (chgSelRec == "Y")
          @dtw_assign(inclSelRec, "Y")
      %elif (chgNotSel == "Y" && inclNotSel == "Y")
          @dtw_assign(inclNotSel, "")
      %elif (chgNotSel == "Y")
          @dtw_assign(inclNotSel, "Y")
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %if (inclNewRec == "" && inclOldRec == "" && chgNewRec != "Y" && chgOldRec != "Y")
      @dtw_assign(inclNewRec, "Y")
      @dtw_assign(inclOldRec, "Y")
  %endif
  %if (inclSelRec == "" && inclNotSel == "" && chgSelRec != "Y" && chgNotSel != "Y")
      @dtw_assign(inclSelRec, "Y")
      @dtw_assign(inclNotSel, "Y")
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(UPDATE) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  %if (selected == "Y" || updateAll == "C")
      @dtw_assign(updSel, "")
  %else
      @dtw_assign(updSel, "Y")
  %endif
  @dtw_concat(stmtSQL, " Update SYPORW Set PWSEL='$(updSel)' Where PWPORT>' ' ", stmtSQL)
  %if (wildCardSearch!="")
      @dtw_concat(stmtSQL, " $(wildCardSearch) ", stmtSQL)
  %endif
  %if (updateAll == "" && portalName != "")
      @dtw_concat(stmtSQL, " and PWPORT='$(portalName)' ", stmtSQL)
  %endif
  %if (updateAll == "" && pageName != "")
      @dtw_concat(stmtSQL, " and PWPAGE='$(pageName)' ", stmtSQL)
  %endif
  %if (updateAll == "C")
      @dtw_concat(stmtSQL, " and PWPAGE<>'' ", stmtSQL)
  %endif
  %if (updateAll == "" && seqNumber != "")
      @dtw_concat(stmtSQL, " and PWSEQ=$(seqNumber) ", stmtSQL)
  %endif
  %if (updateAll == "" && urlID != "")
      @dtw_concat(stmtSQL, " and PWID='$(urlID)' ", stmtSQL)
  %endif
  @dtw_concat(stmtSQL, " @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)
  %if (status=="00000")
      @dtw_assign(maintenanceCode, "C")
  %else
      @dtw_assign(maintenanceCode, "E")
  %endif
  %if (updateRowNum=="")
      @dtw_assign(updateRowNum, "1")
  %endif
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/INPUT$(nextPrevVar)&amp;START_ROW_NUM=@dtw_rurlescseq(updateRowNum)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Delete From SYPORW Where PWXHND='$(profileHandle)' @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)

  %INCLUDE "stmtSQLClear.icl"
  %if (roleSetup == "Y")
      @dtw_concat(stmtSQL, " Insert Into SYPORW (PWXHND,PWROLE,PWPORT,PWPAGE,PWSEQ,PWID,PWSEL,PWNEW,PWDESC,PWDESCU) ", stmtSQL)
      @dtw_concat(stmtSQL, " Select '$(profileHandle)',PRROLE,PRPORT,PRPAGE,PRSEQ,PRID,PRSEL,' ',coalesce(FUDESC,' '),coalesce(FUDESCU,' ')", stmtSQL)
      @dtw_concat(stmtSQL, " From SYPORR left join SYURLM on PRID=FUID ", stmtSQL)
      @dtw_concat(stmtSQL, " Where PRROLE='$(role)' @@endsql", stmtSQL)
      @SQL_Update(stmtSQL, status)

      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Insert Into SYPORW (PWXHND,PWROLE,PWPORT,PWPAGE,PWSEQ,PWID,PWSEL,PWNEW,PWDESC,PWDESCU) ", stmtSQL)
      @dtw_concat(stmtSQL, " Select '$(profileHandle)','$(role)',FPPORT,FPPAGE,FPSEQ,FPID,' ','Y',coalesce(FUDESC,' '),coalesce(FUDESCU,' ')", stmtSQL)
      @dtw_concat(stmtSQL, " From SYROLD left join SYPORT on RDPORT=FPPORT join SYURLM on FPID=FUID ", stmtSQL)
      @dtw_concat(stmtSQL, " Where RDROLE='$(role)' and not exists ", stmtSQL)
      @dtw_concat(stmtSQL, " (Select * from SYPORW Where PWXHND='$(profileHandle)' and PWPORT=FPPORT and ", stmtSQL)
      @dtw_concat(stmtSQL, "  PWPAGE=FPPAGE and PWSEQ=FPSEQ)  @@endsql", stmtSQL)
      @SQL_Update(stmtSQL, status)

  %else
      @dtw_concat(stmtSQL, " Insert Into SYPORW (PWXHND,PWROLE,PWPORT,PWPAGE,PWSEQ,PWID,PWSEL,PWNEW,PWDESC,PWDESCU) ", stmtSQL)
      @dtw_concat(stmtSQL, " Select '$(profileHandle)','$(role)',FPPORT,FPPAGE,FPSEQ,FPID,'Y',' ',coalesce(FUDESC,' '),coalesce(FUDESCU,' ')", stmtSQL)
      @dtw_concat(stmtSQL, " From SYROLD left join SYPORT on RDPORT=FPPORT join SYURLM on FPID=FUID ", stmtSQL)
      @dtw_concat(stmtSQL, " Where RDROLE='$(role)'  @@endsql", stmtSQL)
      @SQL_Update(stmtSQL, status)
  %endif

  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Delete From SYPORR Where PRROLE='$(role)' @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)

  %if (maintenanceCode != "D")
      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Insert Into SYPORR (PRROLE,PRPORT,PRPAGE,PRSEQ,PRID,PRSEL,PRTSTP,PRTSUS,PRTSPT) ", stmtSQL)
      @dtw_concat(stmtSQL, " Select PWROLE,PWPORT,PWPAGE,PWSEQ,PWID,PWSEL,CURRENT_TIMESTAMP,'$(userProfile)','Y'", stmtSQL)
      @dtw_concat(stmtSQL, " From SYPORW Where PWXHND='$(profileHandle)' and PWROLE='$(role)' @@endsql", stmtSQL)
      @SQL_Update(stmtSQL, status)
  %endif

  @Format_ConfMsg_Desc(maintenanceCode, $(roleDesc), $(role), "", "", "", "", confMessage)
  @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
  %if (backURL == "")
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=203&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %endif
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Portal")
      %if (orderBy == "PWPORT,PWPAGE,PWSEQ")
          @DTW_ASSIGN(orderBy, "PWPORT DESC,PWPAGE,PWSEQ")
          @DTW_ASSIGN(orderByDisplay, "Portal (descending), Page, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "PWPORT,PWPAGE,PWSEQ")
          @DTW_ASSIGN(orderByDisplay, "Portal, Page, Sequence")
      %endif
  %elif (sequence == "Page")
      %if (orderBy == "PWPAGE,PWPORT")
          @DTW_ASSIGN(orderBy, "PWPAGE DESC,PWPORT")
          @DTW_ASSIGN(orderByDisplay, "Page (descending), Portal")
      %else
          @DTW_ASSIGN(orderBy, "PWPAGE,PWPORT")
          @DTW_ASSIGN(orderByDisplay, "Page, Portal")
      %endif
  %elif (sequence == "Seq")
      %if (orderBy == "PWSEQ,PWPAGE")
          @DTW_ASSIGN(orderBy, "PWSEQ DESC,PWPAGE")
          @DTW_ASSIGN(orderByDisplay, "Sequence (descending), Portal")
      %else
          @DTW_ASSIGN(orderBy, "PWSEQ,PWPAGE")
          @DTW_ASSIGN(orderByDisplay, "Sequence, Portal")
      %endif
  %elif (sequence == "Desc")
      %if (orderBy == "PWDESCU,PWPORT")
          @DTW_ASSIGN(orderBy, "PWDESCU DESC,PWPORT")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Portal")
      %else
          @DTW_ASSIGN(orderBy, "PWDESCU,PWPORT")
          @DTW_ASSIGN(orderByDisplay, "Description, Portal")
      %endif
  %elif (sequence == "URLID")
      %if (orderBy == "PWID,PWPORT")
          @DTW_ASSIGN(orderBy, "PWID DESC,PWPORT")
          @DTW_ASSIGN(orderByDisplay, "URL ID (descending), Portal")
      %else
          @DTW_ASSIGN(orderBy, "PWID,PWPORT")
          @DTW_ASSIGN(orderByDisplay, "URL ID, Portal")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          @dtw_assign(formName, "Search")
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PORTALBYROLEMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Portal</td>
                              @dtw_assign(operNbr, "operPortal")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchPortal" type="text" size="10" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Page</td>
                              @dtw_assign(operNbr, "operPage")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchPage" type="text" size="10" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchDesc" type="text" size="10" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">URL ID</td>
                              @dtw_assign(operNbr, "operURLID")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchURLID" type="text" size="10" maxlength="55"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("PWPORT", "Portal", $(srchPortal), "U", operPortal, "A")
  @Build_WildCard ("PWPAGE", "Page", $(srchPage), "U", operPage, "A")
  @Build_WildCard ("PWDESCU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("PWID", "URL ID", $(srchURLID), "U", operURLID, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}