%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Supplier Contact Event Maintenance"
  d2wName                 = "SupplierContactEventMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;vendorNumber=@dtw_rurlescseq(vendorNumber)&amp;vendorName=@dtw_rurlescseq(vendorName)&amp;eventSequence=@dtw_rurlescseq(eventSequence)&amp;eventCode=@dtw_rurlescseq(eventCode)&amp;origSequence=@dtw_rurlescseq(origSequence)&amp;fromContactNumber=@dtw_rurlescseq(fromContactNumber)&amp;inclOpen=@dtw_rurlescseq(inclOpen)&amp;inclComp=@dtw_rurlescseq(inclComp)&amp;inclOverDue=@dtw_rurlescseq(inclOverDue)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;contactNumber=@dtw_rurlescseq(contactNumber)&amp;desc=@dtw_rurlescseq(desc)&amp;maintenanceCode=D"
  programName             = "HSRCEM_E"
  fileName                = "SRCEVU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  editVariables           = ""
%}

%INCLUDE "userdefined_number.icl"

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @VendorUserView(profileHandle, dataBaseID, userPass, vendorNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      @dtw_assign(editVariables, "")
      @dtw_tb_rows(userDefinedTable, userMaxRows)
      @dtw_assign(ux, "1")
      %while(ux <= userMaxRows){
          @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFFLDN"), V_UFFLDN)
          @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFDESC"), V_UFDESC)
          @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFTYPE"), V_UFTYPE)
          @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFSIZE"), V_UFSIZE)
          @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFDECM"), V_UFDECM)
          @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFREQF"), V_UFREQF)

          %if (V_UFTYPE == "N")
              %if (V_UFREQF == "Y")
                  @dtw_concat(editVariables, " editZero(document.Chg.", editVariables)
              %else
                  @dtw_concat(editVariables, " editNum(document.Chg.", editVariables)
              %endif
              @dtw_concat(editVariables, "$(V_UFFLDN),$(V_UFSIZE),$(V_UFDECM)) &&", editVariables)
          %elif (V_UFTYPE == "D")
              %if (V_UFREQF == "Y")
                  @dtw_concat(editVariables, " editZero(document.Chg.$(V_UFFLDN),6,0) &&", editVariables)
              %endif
              @dtw_concat(editVariables, " editdate(document.Chg.$(V_UFFLDN)) &&", editVariables)
          %elif ((V_UFTYPE == "A" || V_UFTYPE == "C") && V_UFREQF == "Y")
              @dtw_concat(editVariables, " checkReqField(document.Chg.$(V_UFFLDN)) &&", editVariables)
          %endif
          @dtw_add(ux, "1", ux)
      %}
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  function validate(chgForm) {
                      if (document.Chg.desc.value =="" ||
                          document.Chg.user.value =="")
                             {alert("$(reqFieldError)"); return false;}
                      if ($(editVariables)
                          editZero(document.Chg.eventDate,6,0) &&
                          editdate(document.Chg.eventDate) &&
                          editdate(document.Chg.completionDate))
                          return true;
                  }
                  function checkCmtLength(textField) {
                      if (textField.length > 1800) {
                          alert('Maximum field size has been reached.');
                          return false;
                      }
                      return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
                  %INCLUDE "dateedit.icl"
	           %INCLUDE "numedit.icl"
	           %INCLUDE "numzero.icl"
	           %INCLUDE "checkReqField.icl"
                  %INCLUDE "calendar.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- Start Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                       @dtw_assign(pageID, "SUPPCONTACTEVENTMAINT")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, " Select * From SRCEVM Where RMCONT = $(contactNumber)", stmtSQL)
                              @dtw_concat(stmtSQL, " and RMESEQ = $(eventSequence)", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @RtvSuppCont(profileHandle, dataBaseID, contactNumber, lastName, firstName, salutation, companyName)
      @RtvFldDesc("ECFILN='$(fileName)' and ECEVNT='$(eventCode)' ", "SYEVNT", "ECDESC", eventDesc)

      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          %if (vendorNumber > "0")
              @Format_Header("Supplier", $(vendorName), $(vendorNumber))
          %endif
          %if (contactNumber > "0")
              @Format_Header("Contact", "$(firstName) $(lastName)", $(contactNumber))
          %endif
          @Format_Header("Event Code", $(eventDesc), $(eventCode))
      </table>

      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          %if (vendorNumber > "0")
                              @dtw_assign(focusField, "contactNumber")
                          %else
                              @dtw_assign(focusField, "desc")
                          %endif
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          %if (vendorNumber > "0")
                              @DecatErr_Field("@@cont", "contactNumber")  @dtw_assign(Err_RMCONT, fieldValue)
                          %else
                              @DecatErr_Field("@@cont", "desc")           @dtw_assign(Err_RMDESC, fieldValue)
                          %endif
                          @DecatErr_Field("@@desc", "desc")           @dtw_assign(Err_RMDESC, fieldValue)
                          @DecatErr_Field("@@user", "user")           @dtw_assign(Err_RMUSER, fieldValue)
                          @DecatErr_Field("@@evtd", "eventDate")      @dtw_assign(Err_RMEVTD, fieldValue)
                          @DecatErr_Field("@@evtt", "hrsIn")          @dtw_assign(Err_RMEVTT, fieldValue)
                          @DecatErr_Field("@@cmpd", "completionDate") @dtw_assign(Err_RMCMPD, fieldValue)
                      %endif

                      @Decat_Field("@@cont")   @dtw_assign(V_RMCONT, fieldValue)
                      @Decat_Field("@@desc")   @dtw_assign(V_RMDESC, fieldValue)
                      @Decat_Field("@@user")   @dtw_assign(V_RMUSER, fieldValue)
                      @Decat_Field("@@evtd")   @dtw_assign(V_RMEVTD, fieldValue)
                      @Decat_Field("@@evtt")   @dtw_assign(V_RMEVTT, fieldValue)
                      @Decat_Field("@@cmpd")   @dtw_assign(V_RMCMPD, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(V_RMUSER, userProfile)
                          @dtw_date("U", today)
                          @Date_No_Slash(today, V_RMEVTD)
                          @dtw_assign(V_RMEVTT, "@DTW_rREPLACE(@DTW_rTIME(), ":", "")")
                          %if (vendorNumber > "0")
                              @dtw_assign(focusField, "contactNumber")
                          %else
                              @dtw_assign(focusField, "desc")
                          %endif
                      %endif

                  %elif (maintenanceCode == "Z")
                      @dtw_date("U", today)
                      @Date_No_Slash(today, V_RMEVTD)
                      @dtw_assign(focusField, "desc")
                      @dtw_assign(V_RMEVTT, "@DTW_rREPLACE(@DTW_rTIME(), ":", "")")
                      @dtw_assign(V_RMCMPD, "0")
                  %else
                      @DateInputFromISO("$(V_RMEVTD)", V_RMEVTD)
                      @DateInputFromISO("$(V_RMCMPD)", V_RMCMPD)
                      @dtw_assign(focusField, "desc")
                  %endif

                  %if (vendorNumber > "0" && fromContactNumber == "" && (maintenanceCode == "A" || maintenanceCode == "Z"))
                      @SetTextOvr(Err_RMCONT)
                      <tr><td class="dsphdr"><span $(textOvr)>Contact Number</span></td>
                          <td class="inputnmbr"><input name="contactNumber" type="text" value="$(V_RMCONT)" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)suppliercontactsearch.d2w/ENTRY$(genericVarBase)&amp;vendorNumber=@dtw_rurlescseq(vendorNumber)&amp;vendorName=@dtw_rurlescseq(vendorName)&amp;docName=Chg&amp;fldName=contactNumber&amp;fldDesc=contactName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="contactName" value="$(contactName)" type="text" disabled> $(reqFieldChar) </td>
                      </tr>
                      @DspErrMsg(Err_RMCONT)
                  %else
                      %if (focusField == "contactNumber")
                          @dtw_assign(focusField, "desc")
                      %endif
                      <tr><td><input name="contactNumber" type="hidden" value="$(fromContactNumber)"></td></tr>
                  %endif

                  @SetTextOvr(Err_RMDESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="desc" value="$(V_RMDESC)" type="text" size="75" maxlength="256"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_RMDESC)
        			
                  @RtvFldDesc("USUSER='$(V_RMUSER)'", "SYUSER", "USDESC", fieldDesc)
                  @SetTextOvr(Err_RMUSER)
                  <tr><td class="dsphdr"><span $(textOvr)>User Profile</span></td>
                      <td class="inputalph"><input name="user" type="text" value="$(V_RMUSER)" size="15" maxlength="10"><a href="$(homeURL)$(phpPath)UserSearch.php$(altVarBase)&amp;docName=Chg&amp;userFld=user&amp;descFld=userName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="userName" value="$(fieldDesc)" type="text" disabled> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_RMUSER)
     			
                  @SetTextOvr(Err_RMEVTD)
                  <tr><td class="dsphdr"><span $(textOvr)>Event Date</span></td>
                      <td class="inputnmbr"><input type="text" name="eventDate" value="$(V_RMEVTD)" size="6" maxlength="6">
                          <a href="javascript:calWindow('eventDate');">$(calendarImage)</a> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_RMEVTD)
        			
                  %if (@dtw_rlength(V_RMEVTT) == "5")
                      @dtw_insert("0", V_RMEVTT, "0", "1", V_RMEVTT)
                  %endif
                  @dtw_assign(hrsIn, "@dtw_rsubstr(V_RMEVTT, "1", "2")")
                  @dtw_assign(minIn, "@dtw_rsubstr(V_RMEVTT, "3", "2")")
                  @dtw_assign(secIn, "@dtw_rsubstr(V_RMEVTT, "5", "2")")
                  @SetTextOvr(Err_RMEVTT)
                  <tr><td class="dsphdr"><span $(textOvr)>Event Time</span></td>
                      <td class="inputnmbr">
                          %INCLUDE "timeEntry.icl"
                      </td>
                  </tr>
                  @DspErrMsg(Err_RMEVTT)
                    			
                  @SetTextOvr(Err_RMCMPD)
                  <tr><td class="dsphdr"><span $(textOvr)>Completion Date</span></td>
                      <td class="inputnmbr"><input type="text" name="completionDate" value="$(V_RMCMPD)" size="6" maxlength="6">
                          <a href="javascript:calWindow('completionDate');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_RMCMPD)

                  <tr><td><input name="timeStamp" type="hidden" value="$(V_RMTSTP)"></td></tr>
                  <tr><td><input name="chgOrigSequence" type="hidden" value="$(V_RMOSEQ)"></td></tr>
            %}	

              @dtw_tb_rows(userDefinedTable, userMaxRows)
              @dtw_assign(ux, "1")
              %while(ux <= userMaxRows){
                  @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFFLDN"), V_UFFLDN)
                  @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFDESC"), V_UFDESC)
                  @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFTYPE"), V_UFTYPE)
                  @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFSIZE"), V_UFSIZE)
                  @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFDECM"), V_UFDECM)
                  @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFVALU"), V_UFVALU)
                  @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFBOXS"), V_UFBOXS)
                  @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFREQF"), V_UFREQF)
                  @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFVLDV"), V_UFVLDV)

                  %if (eventSequence > "0")
                      @dtw_tb_rows(suppContactEventTable, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(suppContactEventTable, x, @dtw_tb_rQuerycolnonj(suppContactEventTable, "RUFLDN")) != V_UFFLDN) && (x <= maxRows))
                          {@dtw_add(x, "1", x)%}
                      %if (x <=maxRows)
                          @dtw_tb_getv(suppContactEventTable, x, @dtw_tb_rQuerycolnonj(suppContactEventTable, "RUFLDD"), V_RUFLDD)
                          @dtw_tb_getv(suppContactEventTable, x, @dtw_tb_rQuerycolnonj(suppContactEventTable, "RUFLDV"), V_RUFLDV)
                          @dtw_tb_getv(suppContactEventTable, x, @dtw_tb_rQuerycolnonj(suppContactEventTable, "RUFLDR"), V_RUFLDR)
                      %else
                          @dtw_assign(V_RUFLDD, "")
                          @dtw_assign(V_RUFLDV, "")
                          @dtw_assign(V_RUFLDR, "")
                      %endif
                  %endif
                  
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(userEdtVar, "")
                      %else
                          %if (ux == "1")
                              @UsrVarErr(profileHandle, typeUserDef, userEdtVar)
                          %endif
                          @dtw_assign(catFld, V_UFFLDN)
                          %while(@dtw_rlength(catFld) != "6")
                              {@dtw_insert("@", catFld, @dtw_rlength(catFld), catFld) %}
                          @DecatErr_Field("$(catFld)", "$(V_UFFLDN)")
                          @dtw_concat("Err_", "$(V_UFFLDN)", errFldName)
                          @dtw_assign(errFldName, fieldValue)
                      %endif

                      @Decat_UserDef_Field("$(catFld)")
                      %if (V_UFTYPE == "A" || V_UFTYPE == "C")
                          @dtw_assign(V_RUFLDV, fieldValue)
                      %elif (V_UFTYPE == "N")
                          @dtw_assign(V_RUFLDN, fieldValue)
                          @dtw_multiply(V_RUFLDN, "1", "21", V_RUFLDN)
                      %elif (V_UFTYPE == "D")
                          @dtw_assign(V_RUFLDD, fieldValue)
                      %endif
                  %else
                      %if (V_UFTYPE == "N")
                          @dtw_assign(Precision, @dtw_radd(V_UFSIZE, V_UFDECM))
                          @dtw_assign(V_RUFLDN, @dtw_rformat(V_RUFLDR, V_UFSIZE, V_UFDECM, "", "", Precision))
                          @dtw_assign(V_RUFLDN, @dtw_rstrip(V_RUFLDN))
                      %elif (V_UFTYPE == "D")
                          @DateInputFromISO("$(V_RUFLDD)", V_RUFLDD)
                      %endif
                  %endif

                  @SetTextOvr(errFldName)
                  <tr><td class="dsphdr"><span $(textOvr)>$(V_UFDESC)</span></td>
                      %if (V_UFTYPE == "A")
                          <td class="inputalph"><input type="text" name="$(V_UFFLDN)" value="$(V_RUFLDV)" size="$(V_UFSIZE)" maxlength="$(V_UFSIZE)">
                      %elif (V_UFTYPE == "C")
                          <td>
                              %if ("$(V_RUFLDV)" != "")
                                  <textarea name="$(V_UFFLDN)" ROWS=$(V_UFBOXS) COLS=60 onkeyup="checkCmtLength(this.value)" onkeypress="checkCmtLength(this.value)">$(V_RUFLDV)</textarea>
                              %else
                                  <textarea name="$(V_UFFLDN)" ROWS=$(V_UFBOXS) COLS=60 onkeyup="checkCmtLength(this.value)" onkeypress="checkCmtLength(this.value)"></textarea>
                              %endif
                      %elif (V_UFTYPE == "N")
                          @dtw_add(V_UFSIZE, V_UFDECM, V_UFSIZE)
                          %if (V_UFDECM != "0")
                              @dtw_add(V_UFSIZE, "2", V_UFSIZE)
                          %endif
                          <td class="inputnmbr"><input type="text" name="$(V_UFFLDN)" value="$(V_RUFLDN)" size="$(V_UFSIZE)" maxlength="$(V_UFSIZE)">
                      %elif (V_UFTYPE == "D")
                          <td class="inputnmbr"><input type="text" name="$(V_UFFLDN)" value="$(V_RUFLDD)" size="6" maxlength="6">
                               %if (V_UFVLDV != "Y")
                                   <a href="javascript:calWindow('$(V_UFFLDN)');">$(calendarImage)</a>
                               %endif
                      %endif
                      %if (V_UFVALU == "Y" || V_UFVLDV == "Y")
                          <a href="$(homeURL)$(phpPath)UserDefinedSearch.php$(altVarBase)&amp;docName=Chg&amp;fileName=$(fileName)&amp;userEventCode=$(eventCode)&amp;fldName=$(V_UFFLDN)&amp;fldType=$(V_UFTYPE)&amp;fldDesc=$(V_UFDESC)" onclick="$(searchWinVar)"> $(searchImage) </a>
                      %endif
                      %if (V_UFREQF == "Y")
                          $(reqFieldChar)
                      %endif
                      </td>
                  </tr>
                  @DspErrMsg(errFldName)
                  @dtw_add(ux, "1", ux)
              %}
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall)  Validate_Event_Data(INOUT CHAR(64)    profileHandle,
                                               INOUT CHAR(2)     dataBaseID,
                                               INOUT CHAR(1)     maintenanceCode,
                                               INOUT CHAR(1)     errFound,
                                               INOUT CHAR(32000) edtVar,                             	
                                               INOUT CHAR(32000) userEdtVar,                             	
                                               INOUT CHAR(32000) errVar)
{%EXEC {HSRCEM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @UserDefined_Query(profileHandle, dataBaseID, "SRCEVU    ", eventCode, userDefinedTable)	
          @dtw_tb_rows(userDefinedTable, userMaxRows)
      %if (eventSequence > "0")
          @SuppContactEvent_Query(profileHandle, dataBaseID, contactNumber, eventSequence, suppContactEventTable)	
      %endif
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
      @dtw_assign(eventSequence, "0")
  %elif (maintenanceCode != "A")
      @dtw_assign(origSequence, chgOrigSequence)
  %endif
  @dtw_concat(hours, @dtw_rconcat(min, sec), eventTime)
  @dtw_mUPPERCASE(user)

  @dtw_assign(edtVar, "")
  @Concat_Field("@@cont", contactNumber)
  @Concat_Field("@@evnt", eventCode)
  @Concat_Field("@@eseq", eventSequence)
  @Concat_Field("@@desc", desc)
  @Concat_Field("@@user", user)
  @Concat_Field("@@evtd", eventDate)
  @Concat_Field("@@evtt", eventTime)
  @Concat_Field("@@cmpd", completionDate)
  @Concat_Field("@@oseq", origSequence)
  @Concat_Field("@@tstp", timeStamp)
  @dtw_concat(edtVar, "}{", edtVar)

  @UserDefined_Query(profileHandle, dataBaseID, "SRCEVU    ", eventCode, userDefinedTable)		

  @dtw_tb_rows(userDefinedTable, userMaxRows)
  @dtw_assign(ux, "1")
  %while(ux <= userMaxRows){
      @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFFLDN"), V_UFFLDN)
      @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFTYPE"), V_UFTYPE)
      @dtw_assign(UFFLDN, $(V_UFFLDN))
      @dtw_assign(outField, $($(UFFLDN)))
      %if (V_UFTYPE == "A" || V_UFTYPE == "C")
          @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFUPPR"), V_UFUPPR)
          %if (V_UFUPPR == "Y")
              @dtw_mUPPERCASE(outField)
          %endif
      %elif (V_UFTYPE == "N")
          @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFSIZE"), V_UFSIZE)
          @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFDECM"), V_UFDECM)
          @Build_User_Number(outField, V_UFSIZE, V_UFDECM, outField)
      %endif
      %while(@dtw_rlength(V_UFFLDN) != "6")
          {@dtw_insert("@", V_UFFLDN, @dtw_rlength(V_UFFLDN), V_UFFLDN) %}
      @dtw_concat(userEdtVar, @dtw_rconcat("}{$(V_UFFLDN)", $(outField)), userEdtVar)
      @dtw_add(ux, "1", ux)
  %}
  @dtw_concat(userEdtVar, "}{", userEdtVar)

  @Validate_Event_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, userEdtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(desc), $(eventCode), "", "", "", "", confMessage)
      %if (maintenanceCode == "D" || fromD2w != "")
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)SupplierContactEvent.d2w/REPORT$(genericVarBase)&amp;contactNumber=@dtw_rurlescseq(fromContactNumber)&amp;vendorNumber=@dtw_rurlescseq(vendorNumber)&amp;vendorName=@dtw_rurlescseq(vendorName)&amp;inclOpen=@dtw_rurlescseq(inclOpen)&amp;inclComp=@dtw_rurlescseq(inclComp)&amp;inclOverDue=@dtw_rurlescseq(inclOverDue)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)SupplierContactEventSelect.d2w/REPORT$(genericVarBase)&amp;contactNumber=@dtw_rurlescseq(fromContactNumber)&amp;vendorNumber=@dtw_rurlescseq(vendorNumber)&amp;vendorName=@dtw_rurlescseq(vendorName)&amp;eventSequence=@dtw_rurlescseq(eventSequence)&amp;eventCode=@dtw_rurlescseq(eventCode)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@cont", "contactNumber")
      @Format_ConfMsg_Desc("", $(desc), $(eventCode), "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)SupplierContactEvent.d2w/REPORT$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)&amp;contactNumber=@dtw_rurlescseq(contactNumber)&amp;vendorNumber=@dtw_rurlescseq(vendorNumber)&amp;vendorName=@dtw_rurlescseq(vendorName)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @UsrVarErr(profileHandle, typeUserDef, userEdtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;contactNumber=@dtw_rurlescseq(contactNumber)&amp;errFound=@dtw_rurlescseq(errFound)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}