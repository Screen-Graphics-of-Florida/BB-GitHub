%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Part Class Maintenance"
  d2wName                 = "PartClassMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;partClass=@dtw_rurlescseq(partClass)&amp;partClassDesc=@dtw_rurlescseq(partClassDesc)&amp;maintenanceCode=D"
  programName             = "HPD044"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.partClassDesc.value =="")
                         {alert("$(reqFieldError)"); return false;}
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PARTCLASSMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From HDMICM Where ICCLAS = '$(partClass)'", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=216")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "partClass")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@clas", "partClass")        @dtw_assign(Err_ICCLAS, fieldValue)
                          @DecatErr_Field("@@desc", "partClassDesc")    @dtw_assign(Err_ICDESC, fieldValue)
                          @DecatErr_Field("@@alph", "alphaSequence")    @dtw_assign(Err_ICALPH, fieldValue)
                          @DecatErr_Field("@@fdtf", "forecastDateFormat") @dtw_assign(Err_ICFDTF, fieldValue)
                          @DecatErr_Field("@@fspr", "forecastSpreaders") @dtw_assign(Err_ICFSPR, fieldValue)
                          @DecatErr_Field("@@tfnd", "timeFenceDef")      @dtw_assign(Err_ICTFND, fieldValue)
                          @DecatErr_Field("@@pfct", "retainForecast")    @dtw_assign(Err_ICPFCT, fieldValue)
                          @DecatErr_Field("@@cfct", "consumeForecast")   @dtw_assign(Err_ICCFCT, fieldValue)
                      %endif

                      @Decat_Field("@@clas")   @dtw_assign(V_ICCLAS, fieldValue)
                      @Decat_Field("@@desc")   @dtw_assign(V_ICDESC, fieldValue)
                      @Decat_Field("@@alph")   @dtw_assign(V_ICALPH, fieldValue)
                      @Decat_Field("@@fdtf")   @dtw_assign(V_ICFDTF, fieldValue)
                      @Decat_Field("@@fspr")   @dtw_assign(V_ICFSPR, fieldValue)
                      @Decat_Field("@@tfnd")   @dtw_assign(V_ICTFND, fieldValue)
                      @Decat_Field("@@pfct")   @dtw_assign(V_ICPFCT, fieldValue)
                      @Decat_Field("@@cfct")   @dtw_assign(V_ICCFCT, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "partClass")
                      %endif
                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_ICCLAS, "")
                      @dtw_assign(focusField, "partClass")
                  %else
                      @dtw_assign(focusField, "partClassDesc")
                  %endif

                  @SetTextOvr(Err_ICCLAS)
                  <tr><td class="dsphdr"><span $(textOvr)>Part Class</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="partClass" type="text" value="$(V_ICCLAS)" size="3" maxlength="2"> $(reqFieldChar) </td>
                      %else
                          <td class="inputalph"><input name="partClass" type="hidden" value="$(V_ICCLAS)" size="3" maxlength="2">$(V_ICCLAS)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_ICCLAS)

                  @SetTextOvr(Err_ICDESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="partClassDesc" type="text" value="$(V_ICDESC)" size="20" maxlength="30"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_ICDESC)
    			
                  @SetTextOvr(Err_ICALPH)
                  <tr><td class="dsphdr"><span $(textOvr)>Alpha Sequence</span></td>
                      <td class="inputalph"><input type="text" name="alphaSequence" value="$(V_ICALPH)" size="5" maxlength="4"></td>
                  </tr>
                  @DspErrMsg(Err_ICALPH)

                  @RtvFldDesc("FLTYPE='FORECASTDF' and FLVALU='$(V_ICFDTF)'", "SYFLAG", "FLDESC", fieldDesc)
                  @SetTextOvr(Err_ICFDTF)
                  <tr><td class="dsphdr"><span $(textOvr)>Forecast Date Format</span></td>
                      <td class="inputalph"><input name="forecastDateFormat" type="text" value="$(V_ICFDTF)" size="5" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=FORECASTDF&amp;flagSrchHdr=@dtw_rurlescseq("Forecast Date Format")&amp;docName=Chg&amp;fldName=forecastDateFormat&amp;fldDesc=forecastDateFormatDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input disabled name="forecastDateFormatDesc" value="$(fieldDesc)" type="text" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_ICFDTF)

                  @RtvFldDesc("FLTYPE='FORECASTSP' and FLVALU='$(V_ICFSPR)'", "SYFLAG", "FLDESC", fieldDesc)
                  @SetTextOvr(Err_ICFSPR)
                  <tr><td class="dsphdr"><span $(textOvr)>Forecast Spreaders</span></td>
                      <td class="inputalph"><input name="forecastSpreaders" type="text" value="$(V_ICFSPR)" size="5" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=FORECASTSP&amp;flagSrchHdr=@dtw_rurlescseq("Forecast Spreaders")&amp;docName=Chg&amp;fldName=forecastSpreaders&amp;fldDesc=forecastSpreadersDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input disabled name="forecastSpreadersDesc" value="$(fieldDesc)" type="text" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_ICFSPR)

                  @RtvFldDesc("TFDEF='$(V_ICTFND)'", "HDMTFM", "TFDESC", fieldDesc)
                  @SetTextOvr(Err_ICTFND)
                  <tr><td class="dsphdr"><span $(textOvr)>Time Fence Definition</span></td>
                      <td class="inputalph"><input name="timeFenceDef" type="text" value="$(V_ICTFND)" size="5" maxlength="5"><a href="$(homeURL)$(cGIPath)TimeFenceDefinitionSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=timeFenceDef&amp;fldDesc=timeFenceDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input disabled name="timeFenceDesc" value="$(fieldDesc)" type="text" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_ICTFND)

                  @SetTextOvr(Err_ICPFCT)
                  <tr><td class="dsphdr"><span $(textOvr)>Periods To Retain Forecast</span></td>
                      <td class="inputnmbr"><input type="text" name="retainForecast" value="$(V_ICPFCT)" size="5" maxlength="1"></td>
                  </tr>
                  @DspErrMsg(Err_ICPFCT)

                  @SetTextOvr(Err_ICCFCT)
                  <tr><td class="dsphdr"><span $(textOvr)>Periods To Consume Forecast</span></td>
                      <td class="inputnmbr"><input type="text" name="consumeForecast" value="$(V_ICCFCT)" size="5" maxlength="1"></td>
                  </tr>
                  @DspErrMsg(Err_ICCFCT)
              %}
          </table>
	
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HPD044_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(partClass)
  @dtw_mUPPERCASE(alphaSequence)
  @dtw_mUPPERCASE(forecastDateFormat)
  @dtw_mUPPERCASE(forecastSpreaders)
  @dtw_mUPPERCASE(timeFenceDef)

  @dtw_assign(retainForecast,@dtw_rstrip(retainForecast))
  @dtw_assign(consumeForecast,@dtw_rstrip(consumeForecast))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@clas", partClass)
  @Concat_Field("@@desc", partClassDesc)
  @Concat_Field("@@alph", alphaSequence)
  @Concat_Field("@@fdtf", forecastDateFormat)
  @Concat_Field("@@fspr", forecastSpreaders)
  @Concat_Field("@@tfnd", timeFenceDef)
  @Concat_Field("@@pfct", retainForecast)
  @Concat_Field("@@cfct", consumeForecast)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(partClassDesc), $(partClass), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@clas", "partClass")
          @Format_ConfMsg_Desc("", $(partClassDesc), $(partClass), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=216&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;partClass=@dtw_rurlescseq(partClass)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}