%}

%INCLUDE "$(baseVar)"
%HTML(DISPLAY) {
  <html>
      <head>
          <link rel=stylesheet type="text/css" href="$(homeURL)$(homePath)HDSCalendarSearch.css">
          <title>Select Date</title>
          <script type="text/javascript">
              function Calendar(Month,Year) {
                  var output = '';
                  var nextMonth = Month + 1;
                  var prevMonth = Month - 1;
                  var nextYear  = Year + 1;
                  var prevYear  = Year - 1;

                  output += '<form name="Cal"><table>';
                  output += '<tr class="popupcalrow"><td class="popupcaltitle"><a href="javascript:nextPrevMonth('+prevMonth+');">$(previousImage )</a>';
                  output += '<select class="colhdr" name="Month" onChange="changeMonth();">';

                  for (month=0; month<12; month++) {
                      if (month == Month) output += '<option value='+month+' selected>' + names[month] + '</option>';
                      else                output += '<option value='+month+'>'          + names[month] + '</option>';
                  }

                  output += '</select><a href="javascript:nextPrevMonth('+nextMonth+');">$(nextImage)</a></td>';
                  output += '<td class="popupcaltitle"><a href="javascript:nextPrevYear('+prevYear+');">$(previousImage )</a><select name="Year" onChange="changeYear();">';

                  for (year=1900; year<2101; year++) {
                      if (year == Year) output += '<option value='+year+' selected>' + year + '</option>';
                      else              output += '<option value='+year+'>'          + year + '</option>';
                  }

                  output += '</select><a href="javascript:nextPrevYear('+nextYear+');">$(nextImage)</a></td></tr>';
                  output += '<tr class="popupcalrow"><td colspan=2>';

                  firstDay = new Date(Year,Month,1);
                  startDay = firstDay.getDay();

                  if (((Year % 4 == 0) && (Year % 100 != 0)) || (Year % 400 == 0))
                       days[1] = 29;
                  else
                       days[1] = 28;

                  output += '<table $(popupCalTable)><tr class="popupcalrow">';

                  for (i=0; i<7; i++)
                      output += '<td class="popupcaldayhdr">' + dow[i] +'</td>';

                  output += '</tr><tr class="popupcalrow">';

                  var column = 0;
                  var lastMonth = Month - 1;
                  var lastYear  = Year;
                  if (lastMonth == -1) {
                      lastMonth = 11;
                      lastYear = lastYear - 1;
                  }
                  var nextMonth = Month + 1;
                  var nextYear  = Year;
                  if (nextMonth == 12) {
                      nextMonth = 0;
                      nextYear = nextYear + 1;
                  }

                  for (i=0; i<startDay; i++, column++)
                      output += '<td class="popupcalothmth">' + '<a href="javascript:prevNextDay('+(days[lastMonth]-startDay+i+1)+','+lastMonth+','+lastYear+')" title="'+names[lastMonth]+' '+(days[lastMonth]-startDay+i+1)+', '+lastYear+'">' + (days[lastMonth]-startDay+i+1) + '</a>' +'</td>';

                  for (i=1; i<=days[Month]; i++, column++) {
                      output += '<td class="popupcalselmth">' + '<a href="javascript:changeDay('+i+')" title="'+names[Month]+' '+i+', '+Year+'">' + i + '</a>' +'</td>';
                      if (column == 6) {
                          output += '</tr><tr class="popupcalrow">';
                          column = -1;
                      }
                  }

                  if (column > 0) {
                      for (i=1; column<7; i++, column++)
                          output += '<td class="popupcalothmth">' + '<a href="javascript:prevNextDay('+i+','+nextMonth+','+nextYear+')" title="'+names[nextMonth]+' '+i+', '+nextYear+'">' + i + '</a>' +'</td>';
                  }

                  output += '</td></tr></table></form></td></tr></table>';

                  return output;
              }

              function changeDay(day) {
                  opener.day = day + '';
                  opener.restart();
                  self.close;
              }

              function prevNextDay(day,month,year) {
                  lastDate = new Date(year,month,day);
                  lastYear = lastDate.getYear();
                  opener.year = lastYear;
                  opener.month = month;
                  opener.day = day + '';
                  opener.restart();
                  self.close;
              }

              function nextPrevMonth(next) {
                  if (next == -1) {
                      next = 11;
                      opener.year = opener.year - 1;
                  }
                  if (next == 12) {
                      next = 0;
                      opener.year = opener.year + 1;
                  }
                  opener.month = next;
                  location.href='$(homeURL)$(cGIPath)Calendar.d2w/DISPLAY?baseVar=@dtw_rurlescseq(baseVar)';
              }

              function nextPrevYear(next) {
                  opener.year = opener.year - 1;
                  opener.year = next;
                  location.href='$(homeURL)$(cGIPath)Calendar.d2w/DISPLAY?baseVar=@dtw_rurlescseq(baseVar)';
              }

              function changeMonth() {
                  opener.month = document.Cal.Month.options[document.Cal.Month.selectedIndex].value - 0;
                  location.href='$(homeURL)$(cGIPath)Calendar.d2w/DISPLAY?baseVar=@dtw_rurlescseq(baseVar)';
              }

              function changeYear() {
                  opener.year = document.Cal.Year.options[document.Cal.Year.selectedIndex].value - 0;
                  location.href='$(homeURL)$(cGIPath)Calendar.d2w/DISPLAY?baseVar=@dtw_rurlescseq(baseVar)';
              }

              function makeArray0() {
                  for (i = 0; i<makeArray0.arguments.length; i++)
                      this[i] = makeArray0.arguments[i];
              }

              var names = new makeArray0('January','February','March','April','May','June','July','August','September','October','November','December');
              var days  = new makeArray0(31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31);
              var dow   = new makeArray0('Sun','Mon','Tue','Wed','Thu','Fri','Sat');
          </script>
      </head>

      <body onLoad="self.focus()">
          <center>
              <script type="text/javascript">
                  document.write(Calendar(opener.month,opener.year));
              </script>
          </center>
      </body>
  </html>
%}