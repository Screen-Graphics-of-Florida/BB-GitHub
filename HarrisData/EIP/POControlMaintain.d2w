%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HPOCTU_W.PGM %}
  %}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"

  @RtvFldDesc("", "POCTRL", "Char(Count(*))", RecCount)
  %if (RecCount>"0")
      @dtw_assign(maintenanceCode,"C")
  %else
      @dtw_assign(maintenanceCode,"A")
  %endif
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if ((sec_02 == "N" && sec_03 == "N" && maintenanceCode != "A") || (sec_01 == "N" && maintenanceCode == "A") || (sec_04 == "N" && maintenanceCode == "Z"))
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)progOptSecError.d2w/DISPLAY$(genericVarBase)&amp;page_title=@dtw_rurlescseq(page_title)">
  %else

      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @yn02_Table_Query(profileHandle, dataBaseID, "YORN      ", yn02Table)
      @yn03_Table_Query(profileHandle, dataBaseID, "YORN      ", yn03Table)
      @yn04_Table_Query(profileHandle, dataBaseID, "YORN      ", yn04Table)
      @yn05_Table_Query(profileHandle, dataBaseID, "YORN      ", yn05Table)
      @yn06_Table_Query(profileHandle, dataBaseID, "YORN      ", yn06Table)
      @yn07_Table_Query(profileHandle, dataBaseID, "YORN      ", yn07Table)
      @yn08_Table_Query(profileHandle, dataBaseID, "YORN      ", yn08Table)
      @yn09_Table_Query(profileHandle, dataBaseID, "YORN      ", yn09Table)
      @yn10_Table_Query(profileHandle, dataBaseID, "YORN      ", yn10Table)
      @yn11_Table_Query(profileHandle, dataBaseID, "YORN      ", yn11Table)
      @yn12_Table_Query(profileHandle, dataBaseID, "YORN      ", yn12Table)
      @yn13_Table_Query(profileHandle, dataBaseID, "YORN      ", yn13Table)
      @yn14_Table_Query(profileHandle, dataBaseID, "YORN      ", yn14Table)
      @yn15_Table_Query(profileHandle, dataBaseID, "YORN      ", yn15Table)
      @yn16_Table_Query(profileHandle, dataBaseID, "YORN      ", yn16Table)
      @yn17_Table_Query(profileHandle, dataBaseID, "YORN      ", yn17Table)

      @Set_SQL(stmtSQL)
  %endif
%}


%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(reclaimResourceLevel)
  @dtw_mUPPERCASE(glFeedDetailOrSummary)
  @dtw_mUPPERCASE(methodOfLandedCostAllocation)
  @dtw_mUPPERCASE(freightMiscChargeAllocation)
  @dtw_mUPPERCASE(recTicketNbrAssignment)
  @dtw_mUPPERCASE(freight)
  @dtw_mUPPERCASE(salesTax)
  @dtw_mUPPERCASE(specialCharges)
  @dtw_mUPPERCASE(miscCharge1)
  @dtw_mUPPERCASE(miscCharge2)
  @dtw_mUPPERCASE(miscCharge3)
  @dtw_mUPPERCASE(miscCharge4)
  @dtw_mUPPERCASE(miscCharge5)
  @dtw_mUPPERCASE(miscCharge6)

  @dtw_assign(poDistributionPeriod,@dtw_rstrip(poDistributionPeriod))
  @dtw_assign(lastPONumberUsed,@dtw_rstrip(lastPONumberUsed))
  @dtw_assign(lastRecTicketNbrAssigned,@dtw_rstrip(lastRecTicketNbrAssigned))
  @dtw_assign(dftNbrPerAvgQtyShip,@dtw_rstrip(dftNbrPerAvgQtyShip))
  @dtw_assign(miscChargeDuty,@dtw_rstrip(miscChargeDuty))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@assn", poNumberSystemAssigned)
  @Concat_Field("@@lpo@", lastPONumberUsed)
  @Concat_Field("@@aram", recTicketNbrAssignment)
  @Concat_Field("@@lrcv", lastRecTicketNbrAssigned)
  @Concat_Field("@@auto", restorePOFeedIfErrorsExist)
  @Concat_Field("@@cper", poDistributionPeriod)
  @Concat_Field("@@smc1", miscChargesScreenDesc1)
  @Concat_Field("@@smc2", miscChargesScreenDesc2)
  @Concat_Field("@@smc3", miscChargesScreenDesc3)
  @Concat_Field("@@smc4", miscChargesScreenDesc4)
  @Concat_Field("@@smc5", miscChargesScreenDesc5)
  @Concat_Field("@@smc6", miscChargesScreenDesc6)
  @Concat_Field("@@rm11", miscChargesHeading11)
  @Concat_Field("@@rm12", miscChargesHeading12)
  @Concat_Field("@@rm21", miscChargesHeading21)
  @Concat_Field("@@rm22", miscChargesHeading22)
  @Concat_Field("@@rm31", miscChargesHeading31)
  @Concat_Field("@@rm32", miscChargesHeading32)
  @Concat_Field("@@rm41", miscChargesHeading41)
  @Concat_Field("@@rm42", miscChargesHeading42)
  @Concat_Field("@@rm51", miscChargesHeading51)
  @Concat_Field("@@rm52", miscChargesHeading52)
  @Concat_Field("@@rm61", miscChargesHeading61)
  @Concat_Field("@@rm62", miscChargesHeading62)
  @Concat_Field("@@aiwd", autoItemWhsCreation)
  @Concat_Field("@@autr", printAuditTrail)
  @Concat_Field("@@bbal", batchBalancing)
  @Concat_Field("@@lndc", landedCosting)
  @Concat_Field("@@allc", methodOfLandedCostAllocation)
  @Concat_Field("@@feds", glFeedDetailOrSummary)
  @Concat_Field("@@dfto", defaultOpenQtyToReceivedQty)
  @Concat_Field("@@dftc", defaultLastPOCostAtPOEntry)
  @Concat_Field("@@uvgl", feedUnvoucheredReceiptsToGL)
  @Concat_Field("@@poap", feedPurchaseOrdersToAP)
  @Concat_Field("@@adal", freightMiscChargeAllocation)
  @Concat_Field("@@sitm", defaultSeasonalCode)
  @Concat_Field("@@npus", dftNbrPerAvgQtyShip)
  @Concat_Field("@@iqob", inclBOQtyInSugOrdQty)
  @Concat_Field("@@iqor", inclResvQtyInSugOrdQty)
  @Concat_Field("@@iqds", inclDropShipQtyInSugOrdQty)
  @Concat_Field("@@iiqc", inclIssuesInCalcOfAvgQtyPerDay)
  @Concat_Field("@@frtc", freight)
  @Concat_Field("@@sltc", salesTax)
  @Concat_Field("@@scgc", specialCharges)
  @Concat_Field("@@mcc1", miscCharge1)
  @Concat_Field("@@mcc2", miscCharge2)
  @Concat_Field("@@mcc3", miscCharge3)
  @Concat_Field("@@mcc4", miscCharge4)
  @Concat_Field("@@mcc5", miscCharge5)
  @Concat_Field("@@mcc6", miscCharge6)
  @Concat_Field("@@mdty", miscChargeDuty)
  @Concat_Field("@@cpyn", processContainerReceipts)
  @Concat_Field("@@rclr", reclaimResourceLevel)
  @Concat_Field("@@ucc@", updateCurrentCost)
  @Concat_Field("@@tstp", originalTimeStamp)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, "P/O Control", "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(backHome)$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}