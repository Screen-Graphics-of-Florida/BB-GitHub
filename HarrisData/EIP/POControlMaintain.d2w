%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "P/O Control Maintenance"
  d2wName                 = "POControlMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName             = "HPOCTU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "dateedit.icl"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {

                  if (document.Chg.poDistributionPeriod.value =="" ||
                      document.Chg.reclaimResourceLevel.value =="" ||
                      document.Chg.glFeedDetailOrSummary.value =="" ||
                      document.Chg.freightMiscChargeAllocation.value =="" ||
                      document.Chg.recTicketNbrAssignment.value =="")
                         {alert("$(reqFieldError)"); return false;}

                  if (editNum(document.Chg.poDistributionPeriod, 4, 0) &&
                      editNum(document.Chg.lastPONumberUsed, 8, 0) &&
                      editNum(document.Chg.lastRecTicketNbrAssigned, 8, 0))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
	             %INCLUDE "numedit.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "POCONTROLMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " POCTRL ", fileSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
   </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN  CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @dtw_assign(sec_03, "N")
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "poDistributionPeriod")
                      %else
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@tstp", "poDistributionPeriod")           @dtw_assign(Err_COTSTP, fieldValue)
                          @DecatErr_Field("@@cper", "poDistributionPeriod")           @dtw_assign(Err_COCPER, fieldValue)
                          @DecatErr_Field("@@assn", "poNumberSystemAssigned")         @dtw_assign(Err_COASSN, fieldValue)
                          @DecatErr_Field("@@lpo@", "lastPONumberUsed")               @dtw_assign(Err_COLPO#, fieldValue)
                          @DecatErr_Field("@@aram", "recTicketNbrAssignment")         @dtw_assign(Err_COARAM, fieldValue)
                          @DecatErr_Field("@@lrcv", "lastRecTicketNbrAssigned")       @dtw_assign(Err_COLRCV, fieldValue)
                          @DecatErr_Field("@@auto", "restorePOFeedIfErrorsExist")     @dtw_assign(Err_COAUTO, fieldValue)
                          @DecatErr_Field("@@cper", "poDistributionPeriod")           @dtw_assign(Err_COCPER, fieldValue)
                          @DecatErr_Field("@@smc1", "miscChargesScreenDesc1")         @dtw_assign(Err_COSMC1, fieldValue)
                          @DecatErr_Field("@@smc2", "miscChargesScreenDesc2")         @dtw_assign(Err_COSMC2, fieldValue)
                          @DecatErr_Field("@@smc3", "miscChargesScreenDesc3")         @dtw_assign(Err_COSMC3, fieldValue)
                          @DecatErr_Field("@@smc4", "miscChargesScreenDesc4")         @dtw_assign(Err_COSMC4, fieldValue)
                          @DecatErr_Field("@@smc5", "miscChargesScreenDesc5")         @dtw_assign(Err_COSMC5, fieldValue)
                          @DecatErr_Field("@@smc6", "miscChargesScreenDesc6")         @dtw_assign(Err_COSMC6, fieldValue)
                          @DecatErr_Field("@@rm11", "miscChargesHeading11")           @dtw_assign(Err_CORM11, fieldValue)
                          @DecatErr_Field("@@rm12", "miscChargesHeading12")           @dtw_assign(Err_CORM12, fieldValue)
                          @DecatErr_Field("@@rm21", "miscChargesHeading21")           @dtw_assign(Err_CORM21, fieldValue)
                          @DecatErr_Field("@@rm22", "miscChargesHeading22")           @dtw_assign(Err_CORM22, fieldValue)
                          @DecatErr_Field("@@rm31", "miscChargesHeading31")           @dtw_assign(Err_CORM31, fieldValue)
                          @DecatErr_Field("@@rm32", "miscChargesHeading32")           @dtw_assign(Err_CORM32, fieldValue)
                          @DecatErr_Field("@@rm41", "miscChargesHeading41")           @dtw_assign(Err_CORM41, fieldValue)
                          @DecatErr_Field("@@rm42", "miscChargesHeading42")           @dtw_assign(Err_CORM42, fieldValue)
                          @DecatErr_Field("@@rm51", "miscChargesHeading51")           @dtw_assign(Err_CORM51, fieldValue)
                          @DecatErr_Field("@@rm52", "miscChargesHeading52")           @dtw_assign(Err_CORM52, fieldValue)
                          @DecatErr_Field("@@rm61", "miscChargesHeading61")           @dtw_assign(Err_CORM61, fieldValue)
                          @DecatErr_Field("@@rm62", "miscChargesHeading62")           @dtw_assign(Err_CORM62, fieldValue)
                          @DecatErr_Field("@@aiwd", "autoItemWhsCreation")            @dtw_assign(Err_COAIWD, fieldValue)
                          @DecatErr_Field("@@autr", "printAuditTrail")                @dtw_assign(Err_COAUTR, fieldValue)
                          @DecatErr_Field("@@bbal", "batchBalancing")                 @dtw_assign(Err_COBBAL, fieldValue)
                          @DecatErr_Field("@@lndc", "landedCosting")                  @dtw_assign(Err_COLNDC, fieldValue)
                          @DecatErr_Field("@@allc", "methodOfLandedCostAllocation")   @dtw_assign(Err_COALLC, fieldValue)
                          @DecatErr_Field("@@feds", "glFeedDetailOrSummary")          @dtw_assign(Err_COFEDS, fieldValue)
                          @DecatErr_Field("@@dfto", "defaultOpenQtyToReceivedQty")    @dtw_assign(Err_CODFTO, fieldValue)
                          @DecatErr_Field("@@dftc", "defaultLastPOCostAtPOEntry")     @dtw_assign(Err_CODFTC, fieldValue)
                          @DecatErr_Field("@@uvgl", "feedUnvoucheredReceiptsToGL")    @dtw_assign(Err_COUVGL, fieldValue)
                          @DecatErr_Field("@@poap", "feedPurchaseOrdersToAP")         @dtw_assign(Err_COPOAP, fieldValue)
                          @DecatErr_Field("@@adal", "freightMiscChargeAllocation")    @dtw_assign(Err_COADAL, fieldValue)
                          @DecatErr_Field("@@sitm", "defaultSeasonalCode")            @dtw_assign(Err_COSITM, fieldValue)
                          @DecatErr_Field("@@npus", "dftNbrPerAvgQtyShip")            @dtw_assign(Err_CONPUS, fieldValue)
                          @DecatErr_Field("@@iqob", "inclBOQtyInSugOrdQty")           @dtw_assign(Err_COIQOB, fieldValue)
                          @DecatErr_Field("@@iqor", "inclResvQtyInSugOrdQty")         @dtw_assign(Err_COIQOR, fieldValue)
                          @DecatErr_Field("@@iqds", "inclDropShipQtyInSugOrdQty")     @dtw_assign(Err_COIQDS, fieldValue)
                          @DecatErr_Field("@@iiqc", "inclIssuesInCalcOfAvgQtyPerDay") @dtw_assign(Err_COIIQC, fieldValue)
                          @DecatErr_Field("@@frtc", "freight")                        @dtw_assign(Err_COFRTC, fieldValue)
                          @DecatErr_Field("@@sltc", "salesTax")                       @dtw_assign(Err_COSLTC, fieldValue)
                          @DecatErr_Field("@@scgc", "specialCharges")                 @dtw_assign(Err_COSCGC, fieldValue)
                          @DecatErr_Field("@@mcc1", "miscCharge1")                    @dtw_assign(Err_COMCC1, fieldValue)
                          @DecatErr_Field("@@mcc2", "miscCharge2")                    @dtw_assign(Err_COMCC2, fieldValue)
                          @DecatErr_Field("@@mcc3", "miscCharge3")                    @dtw_assign(Err_COMCC3, fieldValue)
                          @DecatErr_Field("@@mcc4", "miscCharge4")                    @dtw_assign(Err_COMCC4, fieldValue)
                          @DecatErr_Field("@@mcc5", "miscCharge5")                    @dtw_assign(Err_COMCC5, fieldValue)
                          @DecatErr_Field("@@mcc6", "miscCharge6")                    @dtw_assign(Err_COMCC6, fieldValue)
                          @DecatErr_Field("@@mdty", "miscChargeDuty")                 @dtw_assign(Err_COMDTY, fieldValue)
                          @DecatErr_Field("@@cpyn", "processContainerReceipts")       @dtw_assign(Err_COCPYN, fieldValue)
                          @DecatErr_Field("@@rclr", "reclaimResourceLevel")           @dtw_assign(Err_CORCLR, fieldValue)
                          @DecatErr_Field("@@ucc@", "updateCurrentCost")              @dtw_assign(Err_COUCC, fieldValue)
                      %endif

                      @Decat_Field("@@assn")   @dtw_assign(V_COASSN, fieldValue)
                      @Decat_Field("@@lpo@")   @dtw_assign(V_COLPO#, fieldValue)
                      @Decat_Field("@@aram")   @dtw_assign(V_COARAM, fieldValue)
                      @Decat_Field("@@lrcv")   @dtw_assign(V_COLRCV, fieldValue)
                      @Decat_Field("@@auto")   @dtw_assign(V_COAUTO, fieldValue)
                      @Decat_Field("@@cper")   @dtw_assign(V_COCPER, fieldValue)
                      @Decat_Field("@@smc1")   @dtw_assign(V_COSMC1, fieldValue)
                      @Decat_Field("@@smc2")   @dtw_assign(V_COSMC2, fieldValue)
                      @Decat_Field("@@smc3")   @dtw_assign(V_COSMC3, fieldValue)
                      @Decat_Field("@@smc4")   @dtw_assign(V_COSMC4, fieldValue)
                      @Decat_Field("@@smc5")   @dtw_assign(V_COSMC5, fieldValue)
                      @Decat_Field("@@smc6")   @dtw_assign(V_COSMC6, fieldValue)
                      @Decat_Field("@@rm11")   @dtw_assign(V_CORM11, fieldValue)
                      @Decat_Field("@@rm12")   @dtw_assign(V_CORM12, fieldValue)
                      @Decat_Field("@@rm21")   @dtw_assign(V_CORM21, fieldValue)
                      @Decat_Field("@@rm22")   @dtw_assign(V_CORM22, fieldValue)
                      @Decat_Field("@@rm31")   @dtw_assign(V_CORM31, fieldValue)
                      @Decat_Field("@@rm32")   @dtw_assign(V_CORM32, fieldValue)
                      @Decat_Field("@@rm41")   @dtw_assign(V_CORM41, fieldValue)
                      @Decat_Field("@@rm42")   @dtw_assign(V_CORM42, fieldValue)
                      @Decat_Field("@@rm51")   @dtw_assign(V_CORM51, fieldValue)
                      @Decat_Field("@@rm52")   @dtw_assign(V_CORM52, fieldValue)
                      @Decat_Field("@@rm61")   @dtw_assign(V_CORM61, fieldValue)
                      @Decat_Field("@@rm62")   @dtw_assign(V_CORM62, fieldValue)
                      @Decat_Field("@@aiwd")   @dtw_assign(V_COAIWD, fieldValue)
                      @Decat_Field("@@autr")   @dtw_assign(V_COAUTR, fieldValue)
                      @Decat_Field("@@bbal")   @dtw_assign(V_COBBAL, fieldValue)
                      @Decat_Field("@@lndc")   @dtw_assign(V_COLNDC, fieldValue)
                      @Decat_Field("@@allc")   @dtw_assign(V_COALLC, fieldValue)
                      @Decat_Field("@@feds")   @dtw_assign(V_COFEDS, fieldValue)
                      @Decat_Field("@@dfto")   @dtw_assign(V_CODFTO, fieldValue)
                      @Decat_Field("@@dftc")   @dtw_assign(V_CODFTC, fieldValue)
                      @Decat_Field("@@uvgl")   @dtw_assign(V_COUVGL, fieldValue)
                      @Decat_Field("@@poap")   @dtw_assign(V_COPOAP, fieldValue)
                      @Decat_Field("@@adal")   @dtw_assign(V_COADAL, fieldValue)
                      @Decat_Field("@@sitm")   @dtw_assign(V_COSITM, fieldValue)
                      @Decat_Field("@@npus")   @dtw_assign(V_CONPUS, fieldValue)
                      @Decat_Field("@@iqob")   @dtw_assign(V_COIQOB, fieldValue)
                      @Decat_Field("@@iqor")   @dtw_assign(V_COIQOR, fieldValue)
                      @Decat_Field("@@iqds")   @dtw_assign(V_COIQDS, fieldValue)
                      @Decat_Field("@@iiqc")   @dtw_assign(V_COIIQC, fieldValue)
                      @Decat_Field("@@frtc")   @dtw_assign(V_COFRTC, fieldValue)
                      @Decat_Field("@@sltc")   @dtw_assign(V_COSLTC, fieldValue)
                      @Decat_Field("@@scgc")   @dtw_assign(V_COSCGC, fieldValue)
                      @Decat_Field("@@mcc1")   @dtw_assign(V_COMCC1, fieldValue)
                      @Decat_Field("@@mcc2")   @dtw_assign(V_COMCC2, fieldValue)
                      @Decat_Field("@@mcc3")   @dtw_assign(V_COMCC3, fieldValue)
                      @Decat_Field("@@mcc4")   @dtw_assign(V_COMCC4, fieldValue)
                      @Decat_Field("@@mcc5")   @dtw_assign(V_COMCC5, fieldValue)
                      @Decat_Field("@@mcc6")   @dtw_assign(V_COMCC6, fieldValue)
                      @Decat_Field("@@mdty")   @dtw_assign(V_COMDTY, fieldValue)
                      @Decat_Field("@@cpyn")   @dtw_assign(V_COCPYN, fieldValue)
                      @Decat_Field("@@rclr")   @dtw_assign(V_CORCLR, fieldValue)
                      @Decat_Field("@@ucc@")   @dtw_assign(V_COUCC,  fieldValue)
                      @Decat_Field("@@tstp")   @dtw_assign(V_COTSTP, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "poDistributionPeriod")
                          @dtw_assign(V_CORCLR, "O")
                          @dtw_assign(V_COUVGL, "Y")
                          @dtw_assign(V_COAUTO, "Y")
                          @dtw_assign(V_COPOAP, "Y")
                          @dtw_assign(V_COFEDS, "S")
                          @dtw_assign(V_COAIWD, "Y")
                          @dtw_assign(V_COAUTR, "Y")
                          @dtw_assign(V_COASSN, "Y")
                          @dtw_assign(V_COARAM, "M")
                          @dtw_assign(V_COUCC,  "N")
                          @dtw_assign(V_COBBAL, "Y")
                          @dtw_assign(V_COLNDC, "N")
                          @dtw_assign(V_COCPYN, "N")
                          @dtw_assign(V_CODFTO, "Y")
                          @dtw_assign(V_CODFTC, "Y")
                          @dtw_assign(V_COSITM, "N")
                          @dtw_assign(V_COIQOB, "N")
                          @dtw_assign(V_COIQOR, "N")
                          @dtw_assign(V_COIQDS, "N")
                          @dtw_assign(V_COIIQC, "N")
                      %endif

                      @dtw_assign(errFound, "")

                  %else
                      @dtw_assign(focusField, "poDistributionPeriod")
                      @PeriodInputFromCYP(V_COCPER)
                  %endif

                  @SetTextOvr(Err_COTSTP)
                  <tr><td class="dsphdr"><span $(textOvr)>P/O Release Version</span></td>
                          <td class="inputnmbr"><input name="poReleaseVersion" type="hidden" value="$(V_HDPORL)" size="5" maxlength="5">$(V_HDPORL)</td>
                  </tr>
                  @DspErrMsg(Err_COTSTP)

                  @SetTextOvr(Err_HDPOLL)
                  <tr><td class="dsphdr"><span $(textOvr)>P/O Library Level</span></td>
                      <td class="inputnmbr"><input name="poLibraryLevel" type="hidden" value="$(V_HDPOLL)" size="3" maxlength="3">$(V_HDPOLL)</td>
                  </tr>
                  @DspErrMsg(Err_HDPOLL)

                  @SetTextOvr(Err_COCPER)
                  <tr><td class="dsphdr"><span $(textOvr)>P/O Distribution Period</span></td>
                      <td class="inputnmbr"><input name="poDistributionPeriod" value="$(V_COCPER)" type="text" size="4" maxlength="4"><a href="$(homeURL)$(cGIPath)PeriodSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldPeriod=poDistributionPeriod&amp;fldBeginDate=begindate&amp;fldEndDate=enddate" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input name="begindate" type="hidden"><input name="enddate" type="hidden"></td>
                  </tr>
                  @DspErrMsg(Err_COCPER)

                  @RtvFldDesc("FLTYPE='RECLAIMLVL' and FLVALU='$(V_CORCLR)'", "SYFLAG", "FLDESC", fieldReclaimDesc)
                  @SetTextOvr(Err_CORCLR)
                  <tr><td class="dsphdr"><span $(textOvr)>Reclaim Resource Level</span></td>
                      <td class="inputalph"><input name="reclaimResourceLevel" type="text" value="$(V_CORCLR)" size="1" maxlength="1"><a href="$(homeURL)$(cGIPath)FlagSearch.d2w/REPORT$(genericVarBase)&amp;flagType=RECLAIMLVL&amp;flagSrchHdr=@dtw_rurlescseq("Reclaim Resource Level")&amp;docName=Chg&amp;fldName=reclaimResourceLevel&amp;fldDesc=reclaimDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage)</a>
                          <input name="reclaimDesc" value="$(fieldReclaimDesc)" type="text" size="20" disabled></td>
                  </tr>
                  @DspErrMsg(Err_CORCLR)

                  @SetTextOvr(Err_COLPO#)
                  <tr><td class="dsphdr"><span $(textOvr)>Last P/O Number Used</span></td>
                      <td class="inputnmbr"><input name="lastPONumberUsed" value="$(V_COLPO#)" type="text" size="10" maxlength="8"></td>
                  </tr>
                  @DspErrMsg(Err_COLPO#)

                  @SetTextOvr(Err_COASSN)
                  <tr><td class="dsphdr"><span $(textOvr)>P/O Number System Assigned</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_COASSN) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "poNumberSystemAssigned", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_COASSN)
               			
                  @SetTextOvr(Err_COUVGL)
                  <tr><td class="dsphdr"><span $(textOvr)>Feed Unvouchered Receipts To G/L</span></td>
                      @dtw_tb_rows(yn02Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn02Table, x, "1") != V_COUVGL) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn02Table, "feedUnvoucheredReceiptsToGL", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_COUVGL)
               			
                  @SetTextOvr(Err_COAUTO)
                  <tr><td class="dsphdr"><span $(textOvr)>Restore P/O Feed If Errors Exist</span></td>
                      @dtw_tb_rows(yn03Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn03Table, x, "1") != V_COAUTO) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn03Table, "restorePOFeedIfErrorsExist", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_COAUTO)
               			
                  @SetTextOvr(Err_COPOAP)
                  <tr><td class="dsphdr"><span $(textOvr)>Feed Purchase Orders To A/P</span></td>
                      @dtw_tb_rows(yn04Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn04Table, x, "1") != V_COPOAP) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn04Table, "feedPurchaseOrdersToAP", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_COPOAP)

                  @RtvFldDesc("FLTYPE='DORS' and FLVALU='$(V_COFEDS)'", "SYFLAG", "FLDESC", fieldDORSDesc)
                  @SetTextOvr(Err_COFEDS)
                  <tr><td class="dsphdr"><span $(textOvr)>G/L Feed Detail Or Summary</span></td>
                      <td class="inputalph"><input name="glFeedDetailOrSummary" type="text" value="$(V_COFEDS)" size="1" maxlength="1"><a href="$(homeURL)$(cGIPath)FlagSearch.d2w/REPORT$(genericVarBase)&amp;flagType=DORS&amp;flagSrchHdr=@dtw_rurlescseq("G/L Feed")&amp;docName=Chg&amp;fldName=glFeedDetailOrSummary&amp;fldDesc=dorsDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage)</a>
                          <input name="dorsDesc" value="$(fieldDORSDesc)" type="text" size="20" disabled></td>
                  </tr>
                  @DspErrMsg(Err_COFEDS)

                  @SetTextOvr(Err_COAIWD)
                  <tr><td class="dsphdr"><span $(textOvr)>Automatic Item/Warehouse Creation</span></td>
                      @dtw_tb_rows(yn05Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn05Table, x, "1") != V_COAIWD) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn05Table, "autoItemWhsCreation", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_COAIWD)

                  @SetTextOvr(Err_COAUTR)
                  <tr><td class="dsphdr"><span $(textOvr)>Print Audit Trail</span></td>
                      @dtw_tb_rows(yn06Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn06Table, x, "1") != V_COAUTR) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn06Table, "printAuditTrail", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_COAUTR)

                  @SetTextOvr(Err_COBBAL)
                  <tr><td class="dsphdr"><span $(textOvr)>Batch Balancing</span></td>
