                  %endif
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(LOAD) {
  %INCLUDE "setLibraryList.icl"
  @Delete_WebReg(webRegCurFile, profileHandle, d2wName)
  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(d2wName)/ENTRY$(d2wVarBase)">
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"

  %if (formatToPrint == "Y")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else

      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "FDFDKY")
          @DTW_ASSIGN(orderByDisplay, "Forecast Type Key")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Customer")
      %if (orderBy == "FDCUST")
          @DTW_ASSIGN(orderBy, "FDCUST DESC")
          @DTW_ASSIGN(orderByDisplay, "Customer (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FDCUST")
          @DTW_ASSIGN(orderByDisplay, "Customer")
      %endif
  %elif (sequence == "CustomerClass")
      %if (orderBy == "FDCCLS")
          @DTW_ASSIGN(orderBy, "FDCCLS DESC")
          @DTW_ASSIGN(orderByDisplay, "Customer Class (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FDCCLS")
          @DTW_ASSIGN(orderByDisplay, "Customer Class")
      %endif
  %elif (sequence == "Region")
      %if (orderBy == "FDCRGN")
          @DTW_ASSIGN(orderBy, "FDCRGN DESC")
          @DTW_ASSIGN(orderByDisplay, "Customer Region (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FDCRGN")
          @DTW_ASSIGN(orderByDisplay, "Customer Region")
      %endif
  %elif (sequence == "Location")
      %if (orderBy == "FDLOC#")
          @DTW_ASSIGN(orderBy, "FDLOC# DESC")
          @DTW_ASSIGN(orderByDisplay, "Location (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FDLOC#")
          @DTW_ASSIGN(orderByDisplay, "Location")
      %endif
  %elif (sequence == "Salesman")
      %if (orderBy == "FDSLSM")
          @DTW_ASSIGN(orderBy, "FDSLSM DESC")
          @DTW_ASSIGN(orderByDisplay, "Salesman (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FDSLSM")
          @DTW_ASSIGN(orderByDisplay, "Salesman")
      %endif
  %elif (sequence == "ProductClass")
      %if (orderBy == "FDPCLS")
          @DTW_ASSIGN(orderBy, "FDPCLS DESC")
          @DTW_ASSIGN(orderByDisplay, "Product Class (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FDPCLS")
          @DTW_ASSIGN(orderByDisplay, "Product Class")
      %endif
  %elif (sequence == "BuyerAnalyst")
      %if (orderBy == "FDBAC")
          @DTW_ASSIGN(orderBy, "FDBAC DESC")
          @DTW_ASSIGN(orderByDisplay, "Buyer Analyst (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FDBAC")
          @DTW_ASSIGN(orderByDisplay, "Buyer Analyst")
      %endif
  %elif (sequence == "PartType")
      %if (orderBy == "FDPTYP")
          @DTW_ASSIGN(orderBy, "FDPTYP DESC")
          @DTW_ASSIGN(orderByDisplay, "Part Type (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FDPTYP")
          @DTW_ASSIGN(orderByDisplay, "Part Type")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  %if (cust != "0")
      @Build_WildCard ("FDCUST", "cust", $(srchcust), "", opercust, "N")
  %endif
  %if (ccls != "0")
      @Build_WildCard ("FDCCLS", "ccls", $(srchccls), "U", operccls, "A")
  %endif
  %if (creg != "0")
      @Build_WildCard ("FDCRGN", "creg", $(srchcrgn), "U", opercrgn, "A")
  %endif
  %if (loc != "0")
      @Build_WildCard ("FDLOC#", "loc", $(srchloc), "", operloc, "N")
  %endif
  %if (slmn != "0")
      @Build_WildCard ("FDSLSM", "slmn", $(srchslsm), "", operslsm, "N")
  %endif
  %if (pcls != "0")
      @Build_WildCard ("FDPCLS", "pcls", $(srchpcls), "U", operpcls, "A")
  %endif
  %if (bac != "0")
      @Build_WildCard ("FDBAC", "bac", $(srchbac), "", operbac, "N")
   %endif
  %if (ptyp != "0")
      @Build_WildCard ("FDPTYP", "ptyp", $(srchptyp), "U", operptyp, "A")
  %endif

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
