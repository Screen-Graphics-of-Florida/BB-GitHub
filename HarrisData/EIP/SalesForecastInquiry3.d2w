%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "WildCard.icl"


%Define {
  page_title              = "Sales Forecast Inquiry"
  d2wName                 = "SalesForecastInquiry3.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;type=@dtw_rurlescseq(type)&amp;reference=@dtw_rurlescseq(reference)&amp;year=@dtw_rurlescseq(year)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
  cust                    = "0"
  ccls                    = "0"
  creg                    = "0"
  loc                     = "0"
  slmn                    = "0"
  pcls                    = "0"
  bac                     = "0"
  ptyp                    = "0"
  srchcust                = "0"
  srchloc                 = "0"
  srchslsm                = "0"
  srchbac                 = "0"
  formatToPrint           = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@type", "@dtw_rurlescseq(type)", "1", "a", workURL)
  @dtw_replace(workURL, "@@reference", "@dtw_rurlescseq(reference)", "1", "a", workURL)
  @dtw_replace(workURL, "@@year", "@dtw_rurlescseq(year)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @RtvFldDesc("FTFTYP=$(type) and FTREFN='$(reference)' and FTYEAR=$(year) ", "HDMFDF", "FTCUST", cust)
          @RtvFldDesc("FTFTYP='$(type)' and FTREFN='$(reference)' and FTYEAR='$(year)' ", "HDMFDF", "FTCCLS", ccls)
          @RtvFldDesc("FTFTYP=$(type) and FTREFN='$(reference)' and FTYEAR=$(year) ", "HDMFDF", "FTCREG", creg)
          @RtvFldDesc("FTFTYP=$(type) and FTREFN='$(reference)' and FTYEAR=$(year) ", "HDMFDF", "FTLOC#", loc)
          @RtvFldDesc("FTFTYP=$(type) and FTREFN='$(reference)' and FTYEAR=$(year) ", "HDMFDF", "FTSLMN", slmn)
          @RtvFldDesc("FTFTYP=$(type) and FTREFN='$(reference)' and FTYEAR=$(year) ", "HDMFDF", "FTPCLS", pcls)
          @RtvFldDesc("FTFTYP=$(type) and FTREFN='$(reference)' and FTYEAR=$(year) ", "HDMFDF", "FTBAC", bac)
          @RtvFldDesc("FTFTYP=$(type) and FTREFN='$(reference)' and FTYEAR=$(year) ", "HDMFDF", "FTPTYP", ptyp)
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                %if (cust != "0")
                 if (editNum(document.Search.srchcust, 7, 0))
                %endif
                %if (loc != "0")
                 if (editNum(document.Search.srchloc, 3, 0))
                %endif
                %if (slmn != "0")
                 if (editNum(document.Search.srchslsm, 3, 0))
                %endif
                %if (bac != "0")
                 if (editNum(document.Search.srchbac, 7, 0))
                %endif
                     return true;
                  }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "SALESFORECASTINQUIRY3")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select FDFTYP, FDREFN, FDYEAR, FDFDKY, FDCUST,  FDCCLS, FDCRGN, FDLOC#, FDSLSM, FDPCLS, FDBAC, FDPTYP", stmtSQL)
                      @dtw_concat(fileSQL, " HDMFDM ", fileSQL)
                      @dtw_concat(selectSQL, " FDFTYP=$(type) and FDREFN='$(reference)' and FDYEAR=$(year) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64) profileHandle,
                                   CHAR(2)   dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{

      @RtvFldDesc("FTFTYP=$(type) and FTREFN='$(reference)' and FTYEAR=$(year) ", "HDMFDF", "FTFCLD", longDescription)
      @RtvFldDesc("FTFTYP=$(type) and FTREFN='$(reference)' and FTYEAR=$(year) ", "HDMFDF", "FTSDAT", startDate)
      @RtvFldDesc("FTFTYP=$(type) and FTREFN='$(reference)' and FTYEAR=$(year) ", "HDMFDF", "FTEDAT", endDate)
      @Format_Date_ISO(startDate, "H", F_FTSDAT)
      @Format_Date_ISO(endDate, "H", F_FTEDAT)

      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      <table $(contentTable)>
          @Format_Header_URL("Forecast Type", $(longDescription), $(type), "")
          @Format_Header_URL("Reference", $(reference), "", "")
          @Format_Header_URL("Forecast Year", $(year), "", "")
          %IF (startDate != "")
              @Format_Header_URL("Start Date", $(F_FTSDAT), "", "")
          %endif
          %IF (endDate != "")
              @Format_Header_URL("End Date", $(F_FTEDAT), "", "")
          %endif
      </table>

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST name="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;cust=@dtw_rurlescseq(cust)&amp;ccls=@dtw_rurlescseq(ccls)&amp;creg=@dtw_rurlescseq(creg)&amp;loc=@dtw_rurlescseq(loc)&amp;slmn=@dtw_rurlescseq(slmn)&amp;pcls=@dtw_rurlescseq(pcls)&amp;bac=@dtw_rurlescseq(bac)&amp;ptyp=@dtw_rurlescseq(ptyp)">
              <table $(quickSearchTable)>
                  <tr>
                      %if (cust == "1")
                          <th class="colhdr"> Customer</th>
                      %elif (ccls == "1")
                          <th class="colhdr"> Customer<br>Class</th>
                      %elif (creg == "1")
                          <th class="colhdr"> Customer<br>Region</th>
                      %elif (loc == "1")
                          <th class="colhdr"> Location</th>
                      %elif (slmn == "1")
                          <th class="colhdr"> Salesman</th>
                      %elif (pcls == "1")
                          <th class="colhdr"> Product<br>Class</th>
                      %elif (bac == "1")
                          <th class="colhdr"> Buyer/<br>Analyst</th>
                      %elif (ptyp == "1")
                          <th class="colhdr"> Part<br>Type</th>
                      %endif
                      %if (cust == "2")
                          <th class="colhdr"> Customer</th>
                      %elif (ccls == "2")
                          <th class="colhdr"> Customer<br>Class</th>
                      %elif (creg == "2")
                          <th class="colhdr"> Customer<br>Region</th>
                      %elif (loc == "2")
                          <th class="colhdr"> Location</th>
                      %elif (slmn == "2")
                          <th class="colhdr"> Salesman</th>
                      %elif (pcls == "2")
                          <th class="colhdr"> Product<br>Class</th>
                      %elif (bac == "2")
                          <th class="colhdr"> Buyer/<br>Analyst</th>
                      %elif (ptyp == "2")
                          <th class="colhdr"> Part<br>Type</th>
                      %endif
                      %if (cust == "3")
                          <th class="colhdr"> Customer</th>
                      %elif (ccls == "3")
                          <th class="colhdr"> Customer<br>Class</th>
                      %elif (creg == "3")
                          <th class="colhdr"> Customer<br>Region</th>
                      %elif (loc == "3")
                          <th class="colhdr"> Location</th>
                      %elif (slmn == "3")
                          <th class="colhdr"> Salesman</th>
                      %elif (pcls == "3")
                          <th class="colhdr"> Product<br>Class</th>
                      %elif (bac == "3")
                          <th class="colhdr"> Buyer/<br>Analyst</th>
                      %elif (ptyp == "3")
                          <th class="colhdr"> Part<br>Type</th>
                      %endif
                  </tr>
                  <tr>
                      %if (cust == "1")
                          <td><input type="text" class="inputnum" name="srchcust" size="7"
 maxlength="7">
                              <input type="hidden" name="opercust" value="=">
                          </td>
                      %elif (ccls == "1")
                          <td><input type="text" class="inputalph" name="srchccls" size="2" maxlength="2">
                              <input type="hidden" name="operccls" value="LIKE">
                          </td>
                      %elif (creg == "1")
                          <td><input type="text" class="inputalph" name="srchcrgn" size="5" maxlength="5">
                              <input type="hidden" name="opercrgn" value="LIKE">
                          </td>
                      %elif (loc == "1")
                          <td><input type="text" class="inputnum" name="srchloc" size="3" maxlength="3">
                              <input type="hidden" name="operloc" value="=">
                          </td>
                      %elif (slmn == "1")
                          <td><input type="text" class="inputnum" name="srchslsm" size="3" maxlength="3">
                              <input type="hidden" name="operslsm" value="=">
                          </td>
                      %elif (pcls == "1")
                          <td><input type="text" class="inputalph" name="srchpcls" size="4" maxlength="4">
                              <input type="hidden" name="operpcls" value="LIKE">
                          </td>
                      %elif (bac == "1")
                          <td><input type="text" class="inputnum" name="srchbac" size="7" maxlength="7">
                              <input type="hidden" name="operbac" value="=">
                          </td>
                      %elif (ptyp == "1")
                          <td><input type="text" class="inputalph" name="srchptyp" size="1" maxlength="1">
                              <input type="hidden" name="operptyp" value="LIKE">
                          </td>
                      %endif
                      %if (cust == "2")
                          <td><input type="text" class="inputnum" name="srchcust" size="7"
 maxlength="7">
                              <input type="hidden" name="opercust" value="=">
                          </td>
                      %elif (ccls == "2")
                          <td><input type="text" class="inputalph" name="srchccls" size="2" maxlength="2">
                              <input type="hidden" name="operccls" value="LIKE">
                          </td>
                      %elif (creg == "2")
                          <td><input type="text" class="inputalph" name="srchcrgn" size="5" maxlength="5">
                              <input type="hidden" name="opercrgn" value="LIKE">
                          </td>
                      %elif (loc == "2")
                          <td><input type="text" class="inputnum" name="srchloc" size="3" maxlength="3">
                              <input type="hidden" name="operloc" value="=">
                          </td>
                      %elif (slmn == "2")
                          <td><input type="text" class="inputnum" name="srchslsm" size="3" maxlength="3">
                              <input type="hidden" name="operslsm" value="=">
                          </td>
                      %elif (pcls == "2")
                          <td><input type="text" class="inputalph" name="srchpcls" size="4" maxlength="4">
                              <input type="hidden" name="operpcls" value="LIKE">
                          </td>
                      %elif (bac == "2")
                          <td><input type="text" class="inputnum" name="srchbac" size="7" maxlength="7">
                              <input type="hidden" name="operbac" value="=">
                          </td>
                      %elif (ptyp == "2")
                          <td><input type="text" class="inputalph" name="srchptyp" size="1" maxlength="1">
                              <input type="hidden" name="operptyp" value="LIKE">
                          </td>
                      %endif
                      %if (cust == "3")
                          <td><input type="text" class="inputnum" name="srchcust" size="7"
 maxlength="7">
                              <input type="hidden" name="opercust" value="=">
                          </td>
                      %elif (ccls == "3")
                          <td><input type="text" class="inputalph" name="srchccls" size="2" maxlength="2">
                              <input type="hidden" name="operccls" value="LIKE">
                          </td>
                      %elif (creg == "3")
                          <td><input type="text" class="inputalph" name="srchcrgn" size="5" maxlength="5">
                              <input type="hidden" name="opercrgn" value="LIKE">
                          </td>
                      %elif (loc == "3")
                          <td><input type="text" class="inputnum" name="srchloc" size="3" maxlength="3">
                              <input type="hidden" name="operloc" value="=">
                          </td>
                      %elif (slmn == "3")
                          <td><input type="text" class="inputnum" name="srchslsm" size="3" maxlength="3">
                              <input type="hidden" name="operslsm" value="=">
                          </td>
                      %elif (pcls == "3")
                          <td><input type="text" class="inputalph" name="srchpcls" size="4" maxlength="4">
                              <input type="hidden" name="operpcls" value="LIKE">
                          </td>
                      %elif (bac == "3")
                          <td><input type="text" class="inputnum" name="srchbac" size="7" maxlength="7">
                              <input type="hidden" name="operbac" value="=">
                          </td>
                      %elif (ptyp == "3")
                          <td><input type="text" class="inputalph" name="srchptyp" size="1" maxlength="1">
                              <input type="hidden" name="operptyp" value="LIKE">
                          </td>
                      %endif
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  %if (cust == "1")
                      document.Search.srchcust.focus();
                  %elif (ccls == "1")
                      document.Search.srchccls.focus();
                  %elif (creg == "1")
                      document.Search.srchcrgn.focus();
                  %elif (loc == "1")
                      document.Search.srchloc.focus();
                  %elif (slmn == "1")
                      document.Search.srchslsm.focus();
                  %elif (pcls == "1")
                      document.Search.srchpcls.focus();
                  %elif (bac == "1")
                      document.Search.srchbac.focus();
                  %elif (ptyp == "1")
                      document.Search.srchptyp.focus();
                  %endif
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")

          <tr>
              <th class="colhdr">$(optionHeading)</th>
              %if (cust == "1")
                  @OrderBy_Sort("FDCUST", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Customer" title="Sequence By Customer"> Customer</a></th>
              %endif
              %if (ccls == "1")
                  @OrderBy_Sort("FDCCLS", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CustomerClass" title="Sequence By Customer Class"> Customer<br>Class</a></th>
              %endif
              %if (creg == "1")
                  @OrderBy_Sort("FDCRGN", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Region" title="Sequence By Region"> Region</a></th>
              %endif
              %if (loc == "1")
                  @OrderBy_Sort("FDLOC#", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Location" title="Sequence By Location"> Customer<br>Location</a></th>
              %endif
              %if (slmn == "1")
                  @OrderBy_Sort("FDSLSM", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Salesman" title="Sequence By Salesman"> Salesman</a></th>
              %endif
              %if (pcls == "1")
                  @OrderBy_Sort("FDPCLS", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ProductClass" title="Sequence By Product Class"> Product<br>Class</a></th>
              %endif
              %if (bac == "1")
                  @OrderBy_Sort("FDBAC", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BuyerAnalyst" title="Sequence By Buyer/Analyst"> Buyer/<br>Analyst</a></th>
              %endif
              %if (ptyp == "1")
                  @OrderBy_Sort("FDPTYP", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PartType" title="Sequence By Part Type"> Part<br>Type</a></th>
              %endif
              %if (cust == "2")
                  @OrderBy_Sort("FDCUST", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Customer" title="Sequence By Customer"> Customer</a></th>
              %endif
              %if (ccls == "2")
                  @OrderBy_Sort("FDCCLS", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CustomerClass" title="Sequence By Customer Class"> Customer<br>Class</a></th>
              %endif
              %if (creg == "2")
                  @OrderBy_Sort("FDCRGN", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Region" title="Sequence By Region"> Region</a></th>
              %endif
              %if (loc == "2")
                  @OrderBy_Sort("FDLOC#", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Location" title="Sequence By Location"> Customer<br>Location</a></th>
              %endif
              %if (slmn == "2")
                  @OrderBy_Sort("FDSLSM", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Salesman" title="Sequence By Salesman"> Salesman</a></th>
              %endif
              %if (pcls == "2")
                  @OrderBy_Sort("FDPCLS", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ProductClass" title="Sequence By Product Class"> Product<br>Class</a></th>
              %endif
              %if (bac == "2")
                  @OrderBy_Sort("FDBAC", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BuyerAnalyst" title="Sequence By Buyer/Analyst"> Buyer/<br>Analyst</a></th>
              %endif
              %if (ptyp == "2")
                  @OrderBy_Sort("FDPTYP", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PartType" title="Sequence By Part Type"> Part<br>Type</a></th>
              %endif
              %if (cust == "3")
                  @OrderBy_Sort("FDCUST", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Customer" title="Sequence By Customer"> Customer</a></th>
              %endif
              %if (ccls == "3")
                  @OrderBy_Sort("FDCCLS", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CustomerClass" title="Sequence By Customer Class"> Customer<br>Class</a></th>
              %endif
              %if (creg == "3")
                  @OrderBy_Sort("FDCRGN", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Region" title="Sequence By Region"> Region</a></th>
              %endif
              %if (loc == "3")
                  @OrderBy_Sort("FDLOC#", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Location" title="Sequence By Location"> Customer<br>Location</a></th>
              %endif
              %if (slmn == "3")
                  @OrderBy_Sort("FDSLSM", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Salesman" title="Sequence By Salesman"> Salesman</a></th>
              %endif
              %if (pcls == "3")
                  @OrderBy_Sort("FDPCLS", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ProductClass" title="Sequence By Product Class"> Product<br>Class</a></th>
              %endif
              %if (bac == "3")
                  @OrderBy_Sort("FDBAC", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BuyerAnalyst" title="Sequence By Buyer/Analyst"> Buyer/<br>Analyst</a></th>
              %endif
              %if (ptyp == "3")
                  @OrderBy_Sort("FDPTYP", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PartType" title="Sequence By Part Type"> Part<br>Type</a></th>
              %endif
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{

              %INCLUDE "SetRowClass.icl"
              @Format_Nbr(V_FDCUST, F_FDCUST, "0", "Z", "", "", "")
              @Format_Nbr(V_FDLOC#, F_FDLOC#, "0", "Z", "", "", "")
              @Format_Nbr(V_FDSLSM, F_FDSLSM, "0", "Z", "", "", "")
              @Format_Nbr(V_FDBAC, F_FDBAC, "0", "Z", "", "", "")

              <tr class="$(rowClass)">
                  <td class="opticon">
                                      <a href="$(homeURL)$(cGIPath)SalesForecastInquiry4.d2w/ENTRY$(genericVarBase)&amp;type=@dtw_rurlescseq(type)&amp;reference=@dtw_rurlescseq(reference)&amp;year=@dtw_rurlescseq(year)&amp;fdky=@dtw_rurlescseq(V_FDFDKY)&amp;cust=@dtw_rurlescseq(cust)&amp;FDCUST=@dtw_rurlescseq(V_FDCUST)&amp;ccls=@dtw_rurlescseq(ccls)&amp;FDCCLS=@dtw_rurlescseq(V_FDCCLS)&amp;creg=@dtw_rurlescseq(creg)&amp;FDCRGN=@dtw_rurlescseq(V_FDCRGN)&amp;loc=@dtw_rurlescseq(loc)&amp;FDLOC=@dtw_rurlescseq(V_FDLOC#)&amp;slmn=@dtw_rurlescseq(slmn)&amp;FDSLSM=@dtw_rurlescseq(V_FDSLSM)&amp;pcls=@dtw_rurlescseq(pcls)&amp;FDPCLS=@dtw_rurlescseq(V_FDPCLS)&amp;bac=@dtw_rurlescseq(bac)&amp;FDBAC=@dtw_rurlescseq(V_FDBAC)&amp;ptyp=@dtw_rurlescseq(ptyp)&amp;FDPTYP=@dtw_rurlescseq(V_FDPTYP)&amp;backHome=$(backHome)">$(selectImage)</a>
                  </td>
                  %if (cust == "1")
                      <td class="colnmbr">$(F_FDCUST)</td>
                  %endif
                  %if (ccls == "1")
                      <td class="colcode">$(V_FDCCLS)</td>
                  %endif
                  %if (creg == "1")
                      <td class="colcode">$(V_FDCRGN)</td>
                  %endif
                  %if (loc == "1")
                      <td class="colnmbr">$(F_FDLOC#)</td>
                  %endif
                  %if (slmn == "1")
                      <td class="colnmbr">$(F_FDSLSM)</td>
                  %endif
                  %if (pcls == "1")
                      <td class="colcode">$(V_FDPCLS)</td>
                  %endif
                  %if (bac == "1")
                      <td class="colnmbr">$(F_FDBAC)</td>
                  %endif
                  %if (ptyp == "1")
                      <td class="colcode">$(V_FDPTYP)</td>
                  %endif
                  %if (cust == "2")
                      <td class="colnmbr">$(F_FDCUST)</td>
                  %endif
                  %if (ccls == "2")
                      <td class="colcode">$(V_FDCCLS)</td>
                  %endif
                  %if (creg == "2")
                      <td class="colcode">$(V_FDCRGN)</td>
                  %endif
                  %if (loc == "2")
                      <td class="colnmbr">$(F_FDLOC#)</td>
                  %endif
                  %if (slmn == "2")
                      <td class="colnmbr">$(F_FDSLSM)</td>
                  %endif
                  %if (pcls == "2")
                      <td class="colcode">$(V_FDPCLS)</td>
                  %endif
                  %if (bac == "2")
                      <td class="colnmbr">$(F_FDBAC)</td>
                  %endif
                  %if (ptyp == "2")
                      <td class="colcode">$(V_FDPTYP)</td>
                  %endif
                  %if (cust == "3")
                      <td class="colnmbr">$(F_FDCUST)</td>
                  %endif
                  %if (ccls == "3")
                      <td class="colcode">$(V_FDCCLS)</td>
                  %endif
                  %if (creg == "3")
                      <td class="colcode">$(V_FDCRGN)</td>
                  %endif
                  %if (loc == "3")
