%INCLUDE "$(baseVar)"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Order Entry - Feature/Options In Error"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;vendCustItemsFound=@dtw_rurlescseq(vendCustItemsFound)&amp;catalogVarName=@dtw_rurlescseq(catalogVarName)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@customerName", "@dtw_rurlescseq(customerName)", "1", "a", workURL)
  @dtw_replace(workURL, "@@customerNumber", "@dtw_rurlescseq(customerNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@orderControlNumber", "@dtw_rurlescseq(orderControlNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@lineNumber", "@dtw_rurlescseq(lineNumber)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  <html>
      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
      @dtw_concat(fileSQL, " OEDTWK ", fileSQL)
      @dtw_concat(selectSQL, "O1OCTL=$(orderControlNumber) and O1KIT='F' and O1KTRL='$(reliefCode)' ", selectSQL)
      %INCLUDE "stmtSQLSelect.icl"
      @dtw_concat(stmtSQL, " Order By O1ORL# DESC ", stmtSQL)
      %INCLUDE "stmtSQLEnd.icl"
      %INCLUDE "stmtSQLTotalRows.icl"
      @Feature_Option_Error_Query(profileHandle, dataBaseID, stmtSQL)
  </html>
%}

%FUNCTION(dtw_sql) Feature_Option_Error_Query (IN CHAR(64)    profileHandle,
                                                  CHAR(2)     dataBaseID,
                                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count == "0")
          %if (reliefCode == "E")
              <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)OrderEntryOrderReview.d2w/ACCEPT$(d2wVarBase)&amp;orderNumber=@dtw_rurlescseq(orderNumber)">
          %elif (reliefCode == "D" && addToOrder == "C")
              <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)OrderEntryByCustomerItem.d2w/ENTRY$(d2wVarBase)">
          %elif (reliefCode == "D" && addToOrder == "I")
              <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)OrderEntryByItem.d2w/ENTRY$(d2wVarBase)">
          %endif
      %endif

      %ROW{
          %if (productCfgFormat == "O")
              <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)OrderEntryFeatureOption2.d2w/INPUT$(d2wVarBase)&amp;lineNumber=@dtw_rurlescseq(V_O1ORL#)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;reliefCode=@dtw_rurlescseq(reliefCode)&amp;addToOrder=@dtw_rurlescseq(addToOrder)&amp;maintenanceCode=L&amp;recordDisplay=A&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">          
          %else
              <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)OrderEntryFeatureOption.d2w/INPUT$(d2wVarBase)&amp;lineNumber=@dtw_rurlescseq(V_O1ORL#)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;reliefCode=@dtw_rurlescseq(reliefCode)&amp;addToOrder=@dtw_rurlescseq(addToOrder)&amp;maintenanceCode=L&amp;recordDisplay=A&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
          %endif
      %}
  %}
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}