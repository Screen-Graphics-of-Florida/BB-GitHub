%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Import Table"
  d2wName                 = "MapImportTableSelect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;importKey=@dtw_rurlescseq(importKey)&amp;passedImportTable=@dtw_rurlescseq(passedImportTable)"
  programName             = "HSYITM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
  V_PRDESC                = ""	
  quickLinkByUser         = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_assign(backHome, "$(d2wName)/REPORT")
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "FHDESC", V_FHDESC)
          @Format_Code(importKey, F_importKey)
          @dtw_assign(title, "$(V_FHDESC) $(F_importKey)")
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "MAPIMPORTTABLESELECT")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif

                  <td class="content">

%{ QuickLink Table %}     %INCLUDE "QuickLinkTable.icl"

%{ QuickLink By User %}   %INCLUDE "QuickLinkByUser.icl"

%{ Heading %}
                      @dtw_assign(RPT_MAX_ROWS, "99")
                      @dtw_assign(dspMaxRows, "10")
                      @dtw_assign(wildCardSearch, "")  %{ No wildCardSearch %}
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select SYMITB.*,  ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(b.FLDESC,' ') as FixedFLDESC, upper(coalesce(b.FLDESC,' ')) as FixedFLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(c.FLDESC,' ') as DateFLDESC, upper(coalesce(c.FLDESC,' ')) as DateFLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(d.FLDESC,' ') as PeriodFLDESC, upper(coalesce(d.FLDESC,' ')) as PeriodFLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(e.FLDESC,' ') as TimeFLDESC, upper(coalesce(e.FLDESC,' ')) as TimeFLDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " SYMITB ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG b on b.FLTYPE='BY'      and b.FLVALU=FFFIXF ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG c on c.FLTYPE='DATEFMT' and c.FLVALU=FFDTFM ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG d on d.FLTYPE='PDFMT'   and d.FLVALU=FFPDFM ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG e on e.FLTYPE='TIMEFMT' and e.FLVALU=FFTMFM ", fileSQL)
                      @dtw_concat(selectSQL, " FFIMKY=$(importKey) and FFIFIL='$(passedImportTable)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Select_Header(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Begin %}     %INCLUDE "QuickLinkBegLoop.icl"

    %{ Row Type %}
                          %if (quicklinkRef == "recordtype")
                              %INCLUDE "QuickLinkClear.icl"
                              @Retrieve_WebReg(userProfile, "", "MapImportRecordType.d2w", wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select SYMIRT.*,  ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(MFDESC,' ') as MFDESC, coalesce(MFDESCU,' ') as MFDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(FFDESC,' ') as FFDESC, coalesce(FFDESCU,' ') as FFDESCU ", stmtSQL)
                              @dtw_concat(fileSQL, " SYMIRT ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYMIHD on FHIMKY=FRIMKY ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYMMTB on MFMPKY=FHMPKY and MFMFIL=FRMFIL ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYMITB on FFIMKY=FRIMKY and FFIFIL=FRIFIL ", fileSQL)
                              @dtw_concat(selectSQL, " FRIMKY=$(importKey) and FRIFIL='$(passedImportTable)' ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %if (orderBy == "")
                                  @dtw_assign(orderBy, "FRDESCU, FRRTYP")
                                  @dtw_assign(orderByDisplay, "Description, Row Type")
                              %endif
                              @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @Process_Select_Record_Type(profileHandle, dataBaseID, stmtSQL)
                          %endif

    %{ Key %}
                          %if (quicklinkRef == "key")
                              %INCLUDE "QuickLinkClear.icl"
                              @Retrieve_WebReg(userProfile, "", "MapImportKey.d2w", wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select SYMIKY.*,  ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(FFDESC,' ') as FFDESC, coalesce(FFDESCU,' ') as FFDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(FRDESC,' ') as FRDESC, coalesce(FRDESCU,' ') as FRDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(a.MFDESC,' ') as MFDESC, coalesce(a.MFDESCU,' ') as MFDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(b.MFDESC,' ') as parentMFDESC, coalesce(b.MFDESCU,' ') as parentMFDESCU ", stmtSQL)
                              @dtw_concat(fileSQL, " SYMIKY ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYMIHD on FHIMKY=FKIMKY ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYMITB on FFIMKY=FKIMKY and FFIFIL=FKIFIL ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYMIRT on FRIMKY=FKIMKY and FRIFIL=FKIFIL and FRRTYP=FKRTYP ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYMMTB a on a.MFMPKY=FHMPKY and a.MFMFIL=FKMFIL ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYMMTB b on b.MFMPKY=FHMPKY and b.MFMFIL=FKPFIL ", fileSQL)
                              @dtw_concat(selectSQL, " FKIMKY=$(importKey) and FKIFIL='$(passedImportTable)'", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %if (orderBy == "")
                                  @dtw_assign(orderBy, "FFDESCU,FRDESCU,FFDESCU")
                                  @dtw_assign(orderByDisplay, "Import Table, Row Type")
                              %endif
                              @dtw_concat(stmtSQL, " ORDER BY $(orderBy),FKIFIL,FKRTYP,FKMFIL,FKPFIL,FKKYSQ ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @Process_Select_Key(profileHandle, dataBaseID, stmtSQL)
                          %endif

    %{ Template %}
                          %if (quicklinkRef == "template")
                              %INCLUDE "QuickLinkClear.icl"
                              @dtw_assign(wildCardSearch, "")
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select SYMITP.*,  ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(MFDESC,' ') as MFDESC, coalesce(MFDESCU,' ') as MFDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(MDDPOS,0) as MDDPOS, coalesce(MDDESC,' ') as MDDESC, coalesce(MDDLGC,' ') as MDDLGC, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(MDNOTE,' ') as MDNOTE, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(FFDESC,' ') as FFDESC, coalesce(FFDESCU,' ') as FFDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(FRDESC,' ') as FRDESC, coalesce(FRDESCU,' ') as FRDESCU ", stmtSQL)
                              @dtw_concat(fileSQL, " SYMITP ", fileSQL)
                              @dtw_concat(fileSQL, " inner join SYMIHD on FHIMKY=FDIMKY ", fileSQL)
                              @dtw_concat(fileSQL, " inner join SYMMTB on MFMPKY=FHMPKY and MFMFIL=FDMFIL ", fileSQL)
                              @dtw_concat(fileSQL, " inner join SYMMCL on MDMPKY=FHMPKY and MDMFIL=FDMFIL and MDMFLD=FDMFLD ", fileSQL)
                              @dtw_concat(fileSQL, " left  join SYMITB on FFIMKY=FDIMKY and FFIFIL=FDIFIL ", fileSQL)
                              @dtw_concat(fileSQL, " left  join SYMIRT on FRIMKY=FDIMKY and FRIFIL=FDIFIL and FRRTYP=FDRTYP ", fileSQL)
                              @dtw_concat(selectSQL, " FDIMKY=$(importKey) and FDIFIL='$(passedImportTable)' ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              @dtw_concat(stmtSQL, " ORDER BY FDMFIL,MDDPOS,FDMFLD ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @Process_Select_Template(profileHandle, dataBaseID, stmtSQL)
                          %endif

    %{ Cross Reference %}
                          %if (quicklinkRef == "crossreference")
                              %INCLUDE "QuickLinkClear.icl"
                              @dtw_assign(wildCardSearch, "")
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select SYMXRF.*, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(PMPRMD,' ') as PMPRMD, coalesce(PMPRMDU,' ') as PMPRMDU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(a.FLDESC,' ') as fldtFLDESC, coalesce(upper(a.FLDESC),' ') as fldtFLDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(b.FLDESC,' ') as upprFLDESC, coalesce(upper(b.FLDESC),' ') as upprFLDESCU ", stmtSQL)
                              @dtw_concat(fileSQL, " SYMXRF ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFPARM on PMPARM=MXPARM ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYFLAG a on a.FLTYPE='MAPFLDTYP' and a.FLVALU=MXFLDT ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYFLAG b on b.FLTYPE='BY' and b.FLVALU=MXUPPR ", fileSQL)
                              @dtw_concat(selectSQL, " MXIFIL='$(passedImportTable)' ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              @dtw_concat(stmtSQL, " ORDER BY MXDESCU,MXXREF,MXIFIL ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @Process_Select_CrossReference(profileHandle, dataBaseID, stmtSQL)
                          %endif

%{ Quicklink End %}       %INCLUDE "QuickLinkEndLoop.icl"

                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Select_Header (IN CHAR(64)    profileHandle,
                                     CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              @RtvFldDesc("FFIMKY=$(importKey) and FFIFIL='$(passedImportTable)' ", "SYMITB", "FFDESC", V_FFDESC)
              %if (formatToPrint != "Y")
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;importTable=@dtw_rurlescseq(passedImportTable)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)MapImportTableMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (sec_01=="Y" && sec_04=="Y")
                          <a href="$(homeURL)$(cGIPath)MapImportTableMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromImportTable=@dtw_rurlescseq(passedImportTable)&amp;maintenanceCode=Z">$(copyImageLrg)</a>
                      %endif
                      %if (sec_02 == "Y" || sec_03 == "Y")
                          <a href="$(homeURL)$(cGIPath)MapImportTableMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageLrg)</a>
                      %endif
                      %if (sec_03 == "Y")
                          @Format_Confirm_Desc($(V_FFDESC), "$(passedImportTable)", "", "", "", "", confirmDesc)
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)MapImportTableMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      <table $(contentTable)>
          @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "FHDESC", V_FHDESC)
          @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "CHAR(FHMPKY)", V_FHMPKY)
          @Format_Header_URL("Import Definition", $(V_FHDESC), $(importKey), "$(homeURL)$(cGIPath)MapImportDefinitionSelect.d2w/REPORT$(d2wVarBase)")

          @RtvFldDesc("MHMPKY=$(V_FHMPKY)", "SYMMHD", "MHDESC", V_MHDESC)
          @RtvFldDesc("MHMPKY=$(V_FHMPKY)", "SYMMHD", "MHWPGM", V_MHWPGM)
          @Format_Header_URL("Map Definition", $(V_MHDESC), $(V_MHWPGM), "")
      </table>

      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %ROW{
          <table $(contentTable)>

              <tr><td class="dsphdr">Import Table</td>
                  <td class="dspalph">$(V_FFIFIL)</td>
              </tr>

              <tr><td class="dsphdr">Description</td>
                  <td class="dspalph">$(V_FFDESC)</td>
              </tr>

              <tr><td class="dsphdr">Fixed Format</td>
                  @Format_Code(V_FFFIXF, F_FFFIXF)
                  <td class="dspalph">$(V_FixedFLDESC) $(F_FFFIXF)</td>
              </tr>

              <tr><td class="dsphdr">Column Delimiter</td>
                  <td class="dspalph">$(V_FFFDLM)</td>
              </tr>

              <tr><td class="dsphdr">Row Type Position/Placement</td>
                  <td class="dspnmbr">$(V_FFRTPS)</td>
              </tr>

              <tr><td class="dsphdr">Row Type Length</td>
                  <td class="dspnmbr">$(V_FFRTLN)</td>
              </tr>

              <tr><td class="dsphdr">Date Format</td>
                  @Format_Code(V_FFDTFM, F_FFDTFM)
                  <td class="dspalph">$(V_DateFLDESC) $(F_FFDTFM)</td>
              </tr>

              <tr><td class="dsphdr">Period Format</td>
                  @Format_Code(V_FFPDFM, F_FFPDFM)
                  <td class="dspalph">$(V_PeriodFLDESC) $(F_FFPDFM)</td>
              </tr>

              <tr><td class="dsphdr">Time Format</td>
                  @Format_Code(V_FFTMFM, F_FFTMFM)
                  <td class="dspalph">$(V_TimeFLDESC) $(F_FFTMFM)</td>
              </tr>
          </table>

          $(hrTagAttr)

          %INCLUDE "QuickLinkDisplay.icl"
      %}
  %}
%}

%FUNCTION(dtw_sql) Process_Select_Record_Type (IN CHAR(64)    profileHandle,
                                                  CHAR(2)     dataBaseID,
                                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("FFIMKY=$(importKey) and FFIFIL='$(passedImportTable)'", "SYMITB", "CHAR(Max(FFRTPS))", importTableRecTypePlc)

      <a name="recordtype"></a>
      %if (importTableRecTypePlc > "0")
          @dtw_assign(moreURL, "$(homeURL)$(cGIPath)MapImportRecordType.d2w/REPORT$(d2wVarBase)")
      %else
          @dtw_assign(moreURL, "")
      %endif
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("FRDESCU", "Description")
                  @Format_Column_Header("FRRTYP",  "Row Type")
                  @Format_Column_Header("MFDESCU", "Primary Interface Table")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">$(V_FRDESC)</td>
                  <td class="colalph">$(V_FRRTYP)</td>
                  <td class="colalph" $(helpCursor)><span title="$(V_FRMFIL)">$(V_MFDESC)</span></td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Process_Select_Key (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("FRIMKY=$(importKey) and FRIFIL='$(passedImportTable)'", "SYMIRT", "CHAR(COUNT(*))", recordTypeCount)

      <a name="key"></a>
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)MapImportKey.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  %if (recordTypeCount > "1")
                      @Format_Column_Header("FRDESCU",  "Row Type")
                  %endif
                  @Format_Column_Header("MFDESCU", "Interface Table")
                  @Format_Column_Header("parentMFDESCU", "Parent Interface Table")
                  @Format_Column_Header("", "Key Position/<br>Placement")
                  @Format_Column_Header("", "Key Length")

              </tr>
          %endif

          @dtw_assign(test_FKIFIL, "")
          @dtw_assign(test_FKRTYP, "")
          @dtw_assign(test_FKMFIL, "")
          @dtw_assign(test_FKPFIL, "")

          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  %if (test_FKIFIL!=V_FKIFIL || test_FKRTYP!=V_FKRTYP || test_FRDESC!=V_FRDESC || test_FKMFIL!=V_FKMFIL || test_FKPFIL!=V_FKPFIL)
                      @dtw_assign(test_FKIFIL, V_FKIFIL)
                      @dtw_assign(test_FKRTYP, V_FKRTYP)
                      @dtw_assign(test_FKMFIL, V_FKMFIL)
                      @dtw_assign(test_FKPFIL, V_FKPFIL)
                      %if (recordTypeCount > "1")
                          <td class="colalph" $(helpCursor)><span title="$(V_FKRTYP)">$(V_FRDESC)</span></td>
                      %endif
                      <td class="colalph" $(helpCursor)><span title="$(V_FKMFIL)">$(V_MFDESC)</span></td>
                      <td class="colalph" $(helpCursor)><span title="$(V_FKPFIL)">$(V_parentMFDESC)</span></td>
                  %else
                      %if (recordTypeCount > "1")
                          <td class="colnmbr">&nbsp;</td>                                      	
                      %endif
                      <td class="colnmbr">&nbsp;</td>                                      	
                      <td class="colalph">&nbsp;</td>
                  %endif
                  <td class="colnmbr">$(V_FKKYPS)</td>                                      	
                  <td class="colnmbr">$(V_FKKYLN)</td>                                      	
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Process_Select_Template (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "CHAR(FHMPKY)", V_FHMPKY)
      @RtvFldDesc("FFIMKY=$(importKey) and FFIFIL='$(passedImportTable)'", "SYMITB", "char(Count(distinct FFFIXF))", placementCount)
      @RtvFldDesc("FRIMKY=$(importKey) and FRIFIL='$(passedImportTable)'", "SYMIRT", "CHAR(COUNT(*))", recordTypeCount)
      @RtvFldDesc("FDIMKY=$(importKey) and FDIFIL='$(passedImportTable)' and (FDXIFL<>' ' or FDXREF<>' ') ", "SYMITP", "CHAR(COUNT(*))", xrefCount)
      %if (placementCount > "1")
          @dtw_assign(fixedFormat, "Y")
      %elif (placementCount == "1")
          @RtvFldDesc("FFIMKY=$(importKey) and FFIFIL='$(passedImportTable)'", "SYMITB", "distinct FFFIXF", fixedFormat)
      %else
          @dtw_assign(fixedFormat, "")
      %endif

      <a name="template"></a>
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)MapImportTemplateMaintain.d2w/REFRESH$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      @dtw_assign(interfaceTable, "")

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("", "Interface Table")
                  @Format_Column_Header("", "Column")
                  @Format_Column_Header("", "Description")
                  @Format_Column_Header("", "Note")
                  %if (recordTypeCount > "1")
                      @Format_Column_Header("", "Row Type")
                  %endif
                  @Format_Column_Header("", "Column Type")
                  %if (placementCount > "1")
                      @Format_Column_Header("", "Position/<br>Placement")
                  %elif (fixedFormat == "Y")
                      @Format_Column_Header("", "Position")
                  %else
                      @Format_Column_Header("", "Placement")
                  %endif
                  %if (fixedFormat == "Y")
                      @Format_Column_Header("", "Column Length")
                  %endif
                  @Format_Column_Header("", "Implied Decimal Point")
                  @Format_Column_Header("", "Decimal Precision")
                  %if (xrefCount > "0")
                      @Format_Column_Header("", "Cross Reference")
                  %endif
                  @Format_Column_Header("", "Map Function")
                  @Format_Column_Header("", "Default Logic For Mapped")
                  @Format_Column_Header("", "Value")
                  @Format_Column_Header("", "Reverse Sign")
                  @Format_Column_Header("", "Date Format")
                  @Format_Column_Header("", "Period Format")
                  @Format_Column_Header("", "Time Format")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph" $(helpCursor)><span title="$(V_FDMFIL)">$(V_MFDESC)</span></td>
                  <td class="colalph">$(V_FDMFLD)</td>
                  <td class="colalph">$(V_MDDESC)</td>
                  %if (V_MDNOTE != "")
                      <td class="colcode" $(helpCursor)><span title="$(V_MDNOTE)">Y</span></td>                                      	
                  %else
                      <td class="colalph">&nbsp;</td>                                      	
                  %endif
                  %if (recordTypeCount > "1")
                      <td class="colalph" $(helpCursor)><span title="$(V_FDRTYP)">$(V_FRDESC)</span></td>
                  %endif
                  <td class="colalph">$(V_FDFLDT)</td>
                  <td class="colnmbr">$(V_FDFLPL)</td>
                  %if (fixedFormat == "Y")
                      <td class="colnmbr">$(V_FDLNGT)</td>
                  %endif
                  <td class="colcode">$(V_FDIDEC)</td>
                  <td class="colnmbr">$(V_FDDECM)</td>
                  %if (xrefCount > "0")
                      <td class="colalph">$(V_FDXREF) $(V_FDXIFL)</td>
                  %endif
                  <td class="colalph">$(V_FDMFNC)</td>
                  <td class="colalph">$(V_FDDFMP)</td>
                  <td class="colalph">$(V_FDVALU)</td>
                  <td class="colalph">$(V_FDANAB)</td>
                  <td class="colalph">$(V_FDDTFM)</td>
                  <td class="colalph">$(V_FDPDFM)</td>
                  <td class="colalph">$(V_FDTMFM)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Process_Select_CrossReference (IN CHAR(64)    profileHandle,
                                                     CHAR(2)     dataBaseID,
                                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "CHAR(FHMPKY)", V_FHMPKY)
      @RtvFldDesc("FFIMKY=$(importKey) and FFIFIL='$(passedImportTable)'", "SYMITB", "char(Count(distinct FFFIXF))", placementCount)
      @RtvFldDesc("FRIMKY=$(importKey) and FRIFIL='$(passedImportTable)'", "SYMIRT", "CHAR(COUNT(*))", recordTypeCount)
      @RtvFldDesc("FDIMKY=$(importKey) and FDIFIL='$(passedImportTable)' and (FDXIFL<>' ' or FDXREF<>' ') ", "SYMITP", "CHAR(COUNT(*))", xrefCount)
      %if (placementCount > "1")
          @dtw_assign(fixedFormat, "Y")
      %elif (placementCount == "1")
          @RtvFldDesc("FFIMKY=$(importKey) and FFIFIL='$(passedImportTable)'", "SYMITB", "distinct FFFIXF", fixedFormat)
      %else
          @dtw_assign(fixedFormat, "")
      %endif

      <a name="crossreference"></a>
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      @dtw_assign(interfaceTable, "")

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("", "Description")
                  @Format_Column_Header("", "Cross Reference")
                  @Format_Column_Header("", "Column Type")
                  @Format_Column_Header("", "Whole Number Precision")
                  @Format_Column_Header("", "Decimal Precision")
                  @Format_Column_Header("", "Convert To Upper")
                  @Format_Column_Header("", "Workflow Parameter")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">$(V_MXDESC)</td>
                  <td class="colalph">$(V_MXXREF)</td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_MXFLDT)">$(V_fldtFLDESC)</span></td>
                  <td class="colnmbr">$(V_MXSIZE)</td>                                      	
                  <td class="colnmbr">$(V_MXDECM)</td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_MXUPPR)">$(V_upprFLDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_MXPARM)">$(V_PMPRMD)</span></td>                                      	
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %if (overrideImportTable>"0")
      @dtw_assign(passedImportTable, overrideImportTable)
  %endif
  @Set_SQL(stmtSQL)
%}