%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = ""
  d2wName                 = "BillingEditBatch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;viewSelUpdate=@dtw_rurlescseq(viewSelUpdate)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"	
  advanceSearch           = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@orderBy", "@dtw_rurlescseq(orderBy)", "1", "a", workURL)
  @dtw_replace(workURL, "@@wildCardSearch", "@dtw_rurlescseq(wildCardSearch)", "1", "a", workURL)
%}
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %if (viewSelUpdate == "Y")
      @dtw_assign(page_title, "Select Update")
  %else
      @dtw_assign(page_title, "Edit List")
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
	       %INCLUDE "numedit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.batch, 4, 0) &&
                      editdate(document.Search.shipDate) &&
                      editdate(document.Search.recurDate))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "BILLINGEDITBATCH")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " OEBIPB ", fileSQL)
                      @dtw_concat(selectSQL, "BBSTAT='E' ", selectSQL)
                      %if (viewSelUpdate == "Y")
                          @dtw_concat(selectSQL, " and BBPROC<>'Y'", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Edit_List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Edit_List_Query (IN  CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count == "0" && viewSelUpdate != "Y")
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)BillingEditCodeEntry.d2w/ENTRY$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
          @dtw_exit()
      %endif

      %if (sql_Record_Count != "1" || viewSelUpdate != "Y")
          <table $(contentTable)>
    	   <colgroup>
    	       <col width="80%">
    	       <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                          %endif
                          %if (viewSelUpdate != "Y")
                              <a href="$(homeURL)$(cGIPath)BillingEditCodeEntry.d2w/ENTRY$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">$(addImageLrg)</a>
                          %endif
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
          </table>
    	
          %INCLUDE "ConfMessageDisplay.icl"
          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST name="Search" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Batch<br>Number</th>
                          <th class="colhdr">Shipments<br>Through</th>
                          <th class="colhdr">Recurring<br>Through</th>
                      </tr>
                      <tr><td><input type="text" class="inputnmbr" name="batch" size="4" maxlength="4">
                              <input type="hidden" name="operBatch" value="=">
                          </td>
                          <td><input type="text" class="inputnmbr" name="shipDate" size="6" maxlength="6">
                              <a href="javascript:calWindow('shipDate');">$(calendarImage)</a>
                              <input type="hidden" name="operShip" value="=">
                          </td>
                          <td><input type="text" class="inputnmbr" name="recurDate" size="6" maxlength="6">
                              <a href="javascript:calWindow('recurDate');">$(calendarImage)</a>
                              <input type="hidden" name="operRecur" value="=">
                          </td>
                          <td><input name="Search" type="hidden"><a href="javascript:document.data.submit()">$(goSearchImage)</a></td>
                    </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.shipDate.focus();
                  </script>
              </form>

              %INCLUDE "WildCardPage.icl"
          %endif
    	   		
          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("BBBTCH", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=batch" title="Sequence By Batch Number">Batch<br>Number</a></th>
                  @OrderBy_Sort("BBPROC", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=status" title="Sequence By Status, Batch Number">Status</a></th>
                  @OrderBy_Sort("BBSTDT", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=shipDate" title="Sequence By Shipment Through Date, Batch Number">Shipments<br>Through</a></th>
                  @OrderBy_Sort("BBRODT", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=recurDate" title="Sequence By Recurring Through Date, Batch Number">Recurring<br>Through</a></th>
                  <th class="colhdr">Locations</th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %endif

          %ROW{
              %if (sql_Record_Count == "1" && viewSelUpdate == "Y")
                  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)BillingSelectUpdate.d2w/REPORT$(d2wVarBase)&amp;batchNumber=@dtw_rurlescseq(V_BBBTCH)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
                  @dtw_exit()
              %endif
              %INCLUDE "SetRowClass.icl"
              @Format_Date(V_BBSTDT, "D", F_BBSTDT)
              @Format_Date(V_BBRODT, "D", F_BBRODT)

              %if (V_BBPROC == "Y")
                  @dtw_assign(process, "Edit In Process")
              %else
                  @dtw_assign(process, "Edited")
              %endif

              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_BBBTCH)</td>
                  %if (viewSelUpdate == "Y")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)BillingSelectUpdate.d2w/REPORT$(d2wVarBase)&amp;batchNumber=@dtw_rurlescseq(V_BBBTCH)" title="Select Update">$(process)</a></td>
                  %else
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)BillingEditBatchList.d2w/REPORT$(d2wVarBase)&amp;batchNumber=@dtw_rurlescseq(V_BBBTCH)" title="Print Edit List">$(process)</a></td>
                  %endif
                  <td class="coldate">$(F_BBSTDT)</td>
                  <td class="coldate">$(F_BBRODT)</td>
                  <td class="colcode">
                      %if (V_BBFLOC=="1" && V_BBTLOC=="999")
                          All
                      %else
                          $(V_BBFLOC) - $(V_BBTLOC)
                      %endif
                  </td>
              </tr>
          %}
      %if (sql_Record_Count != "1" || viewSelUpdate != "Y")
          </table>
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
          $(hrTagAttr)
          %INCLUDE "Copyright.icl"
      %endif
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  @dtw_assign(errorNbr, "")
  @dtw_assign(apid, "OE")
  @CrCardProc(apid, ws, dataQ, ccPgm, errorNbr)
  %if (errorNbr == "HOE0437") @dtw_assign(errorNbr, "") %endif
  %if (errorNbr != "")
      @Rtv_Error_Desc(errorNbr, alertMessage)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)Billing.d2w/REPORT$(d2wVarBase)&amp;alertMessage=@dtw_rurlescseq(alertMessage)">
  %else
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "BBBTCH")
              @DTW_ASSIGN(orderByDisplay, "Batch Number")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "batch")
      %if (orderBy == "BBBTCH")
          @DTW_ASSIGN(orderBy, "BBBTCH DESC")
          @DTW_ASSIGN(orderByDisplay, "Batch Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "BBBTCH")
          @DTW_ASSIGN(orderByDisplay, "Batch Number")
      %endif
  %elif (sequence == "status")
      %if (orderBy == "BBPROC,BBBTCH")
          @DTW_ASSIGN(orderBy, "BBPROC DESC,BBBTCH")
          @DTW_ASSIGN(orderByDisplay, "Status (descending), Batch Number")
      %else
          @DTW_ASSIGN(orderBy, "BBPROC,BBBTCH")
          @DTW_ASSIGN(orderByDisplay, "Status, Batch Number")
      %endif
  %elif (sequence == "shipDate")
      %if (orderBy == "BBSTDT,BBBTCH")
          @DTW_ASSIGN(orderBy, "BBSTDT DESC,BBBTCH")
          @DTW_ASSIGN(orderByDisplay, "Shipment Through Date (descending), Batch Number")
      %else
          @DTW_ASSIGN(orderBy, "BBSTDT,BBBTCH")
          @DTW_ASSIGN(orderByDisplay, "Shipment Through Date, Batch Number")
      %endif
  %elif (sequence == "recurDate")
      %if (orderBy == "BBRODT,BBBTCH")
          @DTW_ASSIGN(orderBy, "BBRODT DESC,BBBTCH")
          @DTW_ASSIGN(orderByDisplay, "Recurring Through Date (descending), Batch Number")
      %else
          @DTW_ASSIGN(orderBy, "BBRODT,BBBTCH")
          @DTW_ASSIGN(orderByDisplay, "Recurring Through Date, Batch Number")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("BBBTCH", "Batch Number", $(batch), "", operBatch, "N")
  @Build_WildCard ("BBSTDT", "Shipments Through", $(shipDate), "", operShip, "D")
  @Build_WildCard ("BBRODT", "Recurring Through", $(recurDate), "", operRecur, "D")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}