%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Item Group"
  d2wName                 = "ItemGroup.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;groupType=@dtw_rurlescseq(groupType)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HHDIGM_W"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script type="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
           </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "ITEMGROUP")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %if (groupType == "F" || groupType == "G")
                         @dtw_assign(uv_PlantName, "IGPLT")
                         %INCLUDE "userview.icl"
                      %endif
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select IGIGRP, IGPLT, IGDESC, IGDESCU ", stmtSQL)
                      %if (groupType == "F" || groupType == "G")
                          @dtw_concat(stmtSQL, " , coalesce(PLNAME,' ') as PLNAME, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(upper(PLNAME),' ') as PLNAMEU ", stmtSQL)
                      %endif
                      @dtw_concat(fileSQL, " HDIGPH ", fileSQL)
                      %if (groupType == "F" || groupType == "G")
                          @dtw_concat(fileSQL, " inner join HDPLNT on IGPLT=PLPLNT ", fileSQL)
                      %endif
                      @dtw_concat(selectSQL, "IGTYPE='$(groupType)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @ItemGroup_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) ItemGroup_Query (IN  CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (groupType == "G")
          @dtw_assign(maintScript, "FeatureGroupMaintain.d2w")
      %else
          @dtw_assign(maintScript, "ItemGroupMaintain.d2w")
      %endif
      @RtvFldDesc("(FLTYPE='ITMGRPTYPE' and FLVALU='$(groupType)')", "SYFLAG", "FLDESC", groupTypeDesc)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(groupTypeDesc)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)$(maintScript)/ADD$(d2wVarBase)&amp;groupTypeDesc=@dtw_rurlescseq(groupTypeDesc)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">$(groupTypeDesc)</th>
                      <th class="colhdr">Description</th>
                      %if (groupType == "F" || groupType == "G")
                          <th class="colhdr">Plant</th>
                      %endif
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchGroup" size="15" maxlength="15">
                          <input type="hidden" name="operGroup" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchDescription" size="15" maxlength="30">
                          <input type="hidden" name="operDescription" value="LIKE">
                      </td>
                      %if (groupType == "F" || groupType == "G")
                          <td><input type="text" class="inputnmbr" name="srchPlant" size="3" maxlength="3">
                              <input type="hidden" name="operPlant" value="=">
                          </td>
                      %endif
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchGroup.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("IGIGRP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Group" title="Sequence By $(groupTypeDesc)"> $(groupTypeDesc)</a></th>
              @OrderBy_Sort("IGDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Description"> Description</a></th>
              %if (groupType == "F" || groupType == "G")
                  @OrderBy_Sort("IGPLT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlantNumber" title="Sequence By Plant, Group ID">Plant</a></th>
                  @OrderBy_Sort("PLNAMEU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlantName" title="Sequence By Plant Name">Plant Name</a></th>
              %endif
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;groupTypeDesc=@dtw_rurlescseq(groupTypeDesc)&amp;itemGroup=@dtw_rurlescseq(V_IGIGRP)&amp;plantNumber=@dtw_rurlescseq(V_IGPLT)&amp;groupDesc=@dtw_rurlescseq(V_IGDESC)&amp;loadWork=Y")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_IGDESC), $(V_IGIGRP), "", "", "", "", confirmDesc)
              %if (groupType == "F")
                  @RtvFldDesc("RUPLT=$(V_IGPLT) and RUFPRT='$(V_IGIGRP)'", "HDRULE", "char(count(*))", delCount)
                  %if (delCount == "0")
                      @RtvFldDesc("FIPLT=$(V_IGPLT) and FIFPRT='$(V_IGIGRP)'", "HDMFIT", "char(count(*))", delCount)
                      %if (delCount == "0")
                          @RtvFldDesc("FOPLT=$(V_IGPLT) and FOFPRT='$(V_IGIGRP)'", "HDMFOP", "char(count(*))", delCount)
                      %endif
                  %endif
              %else
                  @dtw_assign(delCount, "0")
              %endif

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)$(maintScript)/ADD$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_03 == "Y" && delCount == "0")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)ItemGroupMaintain.d2w/Edit_Data$(d2wVarBase)&amp;groupTypeDesc=@dtw_rurlescseq(groupTypeDesc)&amp;forGroup=@dtw_rurlescseq(V_IGIGRP)&amp;forPlant=@dtw_rurlescseq(V_IGPLT)&amp;forDesc=@dtw_rurlescseq(V_IGDESC)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_IGIGRP)</td>
                  <td class="colalph">$(V_IGDESC)</td>
                  %if (groupType == "F" || groupType == "G")
                      <td class="colnmbr">$(V_IGPLT)</td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(V_IGPLT)&amp;plantName=@dtw_rurlescseq(V_PLNAME)" title="View Plant">$(V_PLNAME)</a></td>
                  %endif
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %if (groupType == "F" || groupType == "G")
     @dtw_assign(uv_PlantName, "IGPLT")
     %INCLUDE "userview.icl"
  %endif
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "Select IGIGRP, IGPLT, IGDESC, IGDESCU ", stmtSQL)
  %if (groupType == "F" || groupType == "G")
      @dtw_concat(stmtSQL, " , coalesce(PLNAME,' ') as PLNAME ", stmtSQL)
  %endif
  @dtw_concat(fileSQL, " HDIGPH ", fileSQL)
  %if (groupType == "F" || groupType == "G")
      @dtw_concat(fileSQL, " inner join HDPLNT on IGPLT=PLPLNT ", fileSQL)
  %endif
  @dtw_concat(selectSQL, "IGTYPE='$(groupType)' ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order BY $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @ItemGroup_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) ItemGroup_XMLQuery (IN CHAR(64)    profileHandle,
			                   CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @RtvFldDesc("(FLTYPE='ITMGRPTYPE' and FLVALU='$(groupType)')", "SYFLAG", "FLDESC", groupTypeDesc)
      @XMLBeginTag("ItemGroupList")

      %ROW{
          @XMLIDTag("$(V_IGIGRP)", "ItemGroup ID")
              @XMLTag(V_IGIGRP, "ItemGroup")
              @XMLTag(V_IGDESC, "GroupDescription")
              %if (groupType == "F" || groupType == "G")
                  @XMLTag(V_IGPLT, "PlantNumber")
                  @XMLTag(V_PLNAME, "PlantName")
              %endif
          @XMLEndTag("ItemGroup")
      %}
      @XMLEndTag("ItemGroupList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "IGDESCU")
          @DTW_ASSIGN(orderByDisplay, "Description")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("(FLTYPE='ITMGRPTYPE' and FLVALU='$(groupType)')", "SYFLAG", "FLDESC", groupTypeDesc)
  %if (sequence == "Group")
      %if (orderBy == "IGIGRP")
          @DTW_ASSIGN(orderBy, "IGIGRP DESC")
          @DTW_ASSIGN(orderByDisplay, "$(groupTypeDesc) (descending)")
      %else
          @DTW_ASSIGN(orderBy, "IGIGRP")
          @DTW_ASSIGN(orderByDisplay, "$(groupTypeDesc)")
      %endif
  %elseif (sequence == "Description")
      %if (orderBy == "IGDESCU")
          @DTW_ASSIGN(orderBy, "IGDESCU DESC")
          @DTW_ASSIGN(orderByDisplay, "Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "IGDESCU")
          @DTW_ASSIGN(orderByDisplay, "Description")
      %endif
  %elseif (sequence == "PlantNumber")
      %if (orderBy == "IGPLT,IGIGRP")
          @DTW_ASSIGN(orderBy, "IGPLT DESC,IGIGRP")
          @DTW_ASSIGN(orderByDisplay, "Plant Number (descending), $(groupTypeDesc)")
      %else
          @DTW_ASSIGN(orderBy, "IGPLT,IGIGRP")
          @DTW_ASSIGN(orderByDisplay, "Plant Number, $(groupTypeDesc)")
      %endif
  %elseif (sequence == "PlantName")
      %if (orderBy == "PLNAMEU,IGIGRP")
          @DTW_ASSIGN(orderBy, "PLNAMEU DESC,IGIGRP")
          @DTW_ASSIGN(orderByDisplay, "Plant Name (descending), $(groupTypeDesc)")
      %else
          @DTW_ASSIGN(orderBy, "PLNAMEU,IGIGRP")
          @DTW_ASSIGN(orderByDisplay, "Plant Name, $(groupTypeDesc)")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("(FLTYPE='ITMGRPTYPE' and FLVALU='$(groupType)')", "SYFLAG", "FLDESC", groupTypeDesc)
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("IGIGRP", "$(groupTypeDesc)", $(srchGroup), "U", operGroup, "A")
  @Build_WildCard ("IGPLT", "Plant Number", $(srchPlant), "", operPlant, "N")
  @Build_WildCard ("IGDESCU", "Description", $(srchDescription), "U", operDescription, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
