%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Lot Number Where Used"
  d2wName                 = "LotNumberWhereUsedInquiry.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;lotNumber=@dtw_rurlescseq(lotNumber)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  quantityRequired        = ""
%}
	
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onLoad="window.focus()" onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " WRK320 ", fileSQL)
                      @dtw_concat(selectSQL, "LZXHND='$(profileHandle)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By LZXHND, LZRSEQ ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @LotMaster_Inquiry(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) LotMaster_Inquiry (IN CHAR(64)    profileHandle,
				          CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
      @RtvFldDesc("WHWHS=$(warehouseNumber)", "HDWHSM", "WHWHNM", whsName)
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      @dtw_assign(medIcon, "Y")
      @dtw_assign(displayCloseIcon, "Y")
      %INCLUDE "PageTitle.icl"

      <table $(contentTable)>
          @Format_Header("Item", $(itemDescription), $(itemNumber))
          @Format_Header("Warehouse", $(whsName), $(warehouseNumber))
          @Format_Header("Plant", $(plantName), $(plantNumber))
          @Format_Header("Lot Number", $(lotNumber), "")
      </table>

      $(inquiryhrTagAttr)
      <table $(contentTable)>
         <tr>
              <th class="colhdr">Issued To<br>Order</th>
              <th class="colhdr">Parent Item</th>
              <th class="colhdr">Level</th>
              <th class="colhdr">Component Item</th>
              <th class="colhdr">Description</th>
              <th class="colhdr">Lot Number</th>
              <th class="colhdr">Quantity<br>Issued</th>
              <th class="colhdr">Quantity<br>Scrapped</th>
              <th class="colhdr">Ship-To<br>Customer</th>
              <th class="colhdr">Name</th>
              <th class="colhdr">Order #</th>
              <th class="colhdr">Line #</th>
          </tr>
              %ROW{
                  %INCLUDE "SetRowClass.icl"
                  @RtvFldDesc("OHPLT=$(plantNumber) and OHORD='$(V_LZIORD)'", "HDMOHM", "CHAR(COUNT(*))", issueOrderCnt)
                  @RtvFldDesc("LTLT#='$(V_LZLOTN)'", "HDLOT", "CHAR(COUNT(*))", lotCnt)

                  <tr class="$(rowClass)">
                     <td class="colalph">
                         %if (recvOrderCnt > "0")
                             <a href="$(homeURL)$(cGIPath)SelectMfgOrder.d2w/REPORT$(d2wVarBase)&amp;mfgOrder=@dtw_rurlescseq(V_LZIORD)" onclick="$(inquiryWinVar)" title="View Mfg Order">$(V_LZIORD)</a>
                         %else
                             $(V_LZIORD)
                         %endif
                     </td>
                     <td class="colalph"><a href="$(homeURL)$(cGIPath)iteminquiry.d2w/DISPLAY$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_LZITEM)&amp;plantNumber=@dtw_rurlescseq(plantNumber)" onclick="$(inquiryWinVar)" title="Item Quickview">$(V_LZITEM)</a></td>
                     <td class="colalph">$(V_LZLVL)</td>
                     <td class="colalph"><a href="$(homeURL)$(cGIPath)iteminquiry.d2w/DISPLAY$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_LZPN)&amp;plantNumber=@dtw_rurlescseq(plantNumber)" onclick="$(inquiryWinVar)" title="Item Quickview">$(V_LZPN)</a></td>
                     <td class="colalph">$(V_LZIMDS)</td>
                     <td class="colalph">
                         %if (lotCnt > "0")
                             <a href="$(homeURL)$(cGIPath)LotInquiry.d2w/DISPLAY$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;lotNumber=@dtw_rurlescseq(V_LZLOTN)&amp;backHome=$(d2wName)/report" title="Lot Quickview">$(V_LZLOTN)</a>
                         %else
                             $(V_LZLOTN)
                         %endif
                     </td>
                     <td class="colnmbr">$(V_LZQISS)</td>
                     <td class="colnmbr">$(V_LZQSCR)</td>
                     <td class="colnmbr">
                         %if (V_LZVEND > "0")
                             <a href="$(homeURL)$(cGIPath)customerinquiry.d2w/DISPLAY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(V_LZVEND)" onclick="$(inquiryWinVar)" title="Customer Quickview">$(V_LZVEND)</a>
                         %else
                             $(V_LZVEND)
                         %endif
                     </td>
                     <td class="colalph">$(V_LZVNA1)</td>
                     <td class="colnmbr">$(V_LZPO)</td>
                     <td class="colnmbr">$(V_LZPOL#)</td>
                  </tr>

              %}
      </table>
      $(inquiryhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Create_Work_File (IN    CHAR(64)    profileHandle,
                                                  CHAR(32000) edtVar)

{%EXEC {HSI321_W.PGM %}
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @dtw_strip(lotNumber, lotNumber)
  @Concat_Field("@@lt#@", lotNumber)
  @Concat_Field("@print", printRequest)
  @dtw_concat(edtVar, "}{", edtVar)
  @Create_Work_File (profileHandle, edtVar)
  @Set_SQL(stmtSQL)
%}