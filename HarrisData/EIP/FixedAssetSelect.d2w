%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Fixed Asset Status"
  d2wName                 = "FixedAssetSelect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
  quickLinkByUser         = "Y"
  allCustomers            = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          @dtw_assign(title, page_title)
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                       @dtw_assign(pageID, "FIXEDASSETSELECT")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
%{ QuickLink Table %}   %INCLUDE "QuickLinkTable.icl"
	
%{ QuickLink By User %} %INCLUDE "QuickLinkByUser.icl"

%{ Heading %}
                      @dtw_assign(RPT_MAX_ROWS, "99")
                      @dtw_assign(dspMaxRows, "10")
                      %INCLUDE "AddRecordSQL.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      @FA_Select_Header(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Begin %}     %INCLUDE "QuickLinkBegLoop.icl"

%{ Demographics %}
                          %if (quicklinkRef == "demographics")
                              %INCLUDE "QuickLinkClear.icl"
                              @dtw_assign(uv_Sql, "")  %{ No user view security. %}
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                              @dtw_concat(fileSQL, " FACTRL ", fileSQL)
                              @dtw_concat(selectSQL, "RRN(FACTRL)=1 ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %INCLUDE "stmtSQLEnd.icl"
                              @FA_Select_Demographics(profileHandle, dataBaseID, stmtSQL)

%{ Site %}
                          %elif (quicklinkRef == "site")
                              %INCLUDE "QuickLinkClear.icl"
                              @dtw_assign(uv_CompanyName, "ACCO#")
                              @dtw_assign(uv_FacilityName, "ACFAC#")
                              @dtw_assign(uv_SiteName, "ACLOCN")
                              %INCLUDE "userview.icl"
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select FASITE.*, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(CFCFNM,' ') as CFCFNM, coalesce(CFCFNMU,' ') as CFCFNMU ", stmtSQL)
                              @dtw_concat(fileSQL, " FASITE ", fileSQL)
                              @dtw_concat(fileSQL, " left join HDCFAC on CFCO#=ACCO# and CFFAC#=ACFAC# ", fileSQL)
                              %if (uv_Sql!="")
                                  @dtw_concat(selectSQL, "ACLOCN<>0 ", selectSQL)
                              %endif
                              %INCLUDE "stmtSQLSelect.icl"
                              @dtw_concat(stmtSQL, " Order By ACLONM,ACLOCN  ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @FA_Select_Site(profileHandle, dataBaseID, stmtSQL)

%{ Property Type %}
                          %elif (quicklinkRef == "property")
                              %INCLUDE "QuickLinkClear.icl"
                              @dtw_assign(uv_PropertyTypeName, "PTTYPE")
                              %INCLUDE "userview.icl"
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select FAPROP.*, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(a.CHCHDS,' ') as AsstCHCHDS, coalesce(a.CHCHDSU,' ') as AsstCHCHDSU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(b.CHCHDS,' ') as AcumCHCHDS, coalesce(b.CHCHDSU,' ') as AcumCHCHDSU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(c.CHCHDS,' ') as ExpsCHCHDS, coalesce(c.CHCHDSU,' ') as ExpsCHCHDSU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(d.CHCHDS,' ') as GainCHCHDS, coalesce(d.CHCHDSU,' ') as GainCHCHDSU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(e.CHCHDS,' ') as CashCHCHDS, coalesce(e.CHCHDSU,' ') as CashCHCHDSU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(f.CHCHDS,' ') as TrnfCHCHDS, coalesce(f.CHCHDSU,' ') as TrnfCHCHDSU  ", stmtSQL)
                              @dtw_concat(fileSQL, " FAPROP ", fileSQL)
                              @dtw_concat(fileSQL, " left join HDCHRT a on a.CHACCT=PTAAAC and a.CHSUB=PTAASU ", fileSQL)
                              @dtw_concat(fileSQL, " left join HDCHRT b on b.CHACCT=PTADAC and b.CHSUB=PTADSU ", fileSQL)
                              @dtw_concat(fileSQL, " left join HDCHRT c on c.CHACCT=PTDEAC and c.CHSUB=PTDESU ", fileSQL)
                              @dtw_concat(fileSQL, " left join HDCHRT d on d.CHACCT=PTGLAC and d.CHSUB=PTGLSU ", fileSQL)
                              @dtw_concat(fileSQL, " left join HDCHRT e on e.CHACCT=PTCAAC and e.CHSUB=PTCASU ", fileSQL)
                              @dtw_concat(fileSQL, " left join HDCHRT f on f.CHACCT=PTTRAC and f.CHSUB=PTTRSU ", fileSQL)
                              %if (uv_Sql!="")
                                  @dtw_concat(selectSQL, "PTTYPE<>' ' ", selectSQL)
                              %endif
                              %INCLUDE "stmtSQLSelect.icl"
                              @dtw_concat(stmtSQL, " Order By PTDESC,PTTYPE ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @FA_Select_Property(profileHandle, dataBaseID, stmtSQL)

%{ Unposted Sub Ledger %}
                          %elif (quicklinkRef == "unpostedsubledger")
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Delete From  GLUSFDWK ", stmtSQL)
                              @dtw_concat(stmtSQL, " Where WFXHND='$(profileHandle)'  ", stmtSQL)
                              @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
                              @SQL_Update(stmtSQL, status)

                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Insert Into GLUSFDWK (WFXHND,            WFFILE,  WFJRNL,WFPER#,WFDATE,WFTTYP,WFFCUR,WFDESC,        WFUAMT,    WFDESCU) ", stmtSQL)
                              @dtw_concat(stmtSQL, " Select                '$(profileHandle)','HDFATR',JFJRNL,JFPER#,JFDATE,JFTTYP,' '   ,'Fixed Assets',SUM(JFAMT),Upper('Fixed Assets')  ", stmtSQL)
                              @dtw_concat(stmtSQL, " From HDFATR   ", stmtSQL)
                              @dtw_concat(stmtSQL, " Where JFAMT>0  ", stmtSQL)
                              @dtw_concat(stmtSQL, " GROUP BY JFJRNL,JFPER#,JFDATE,JFTTYP ", stmtSQL)
                              @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
                              @SQL_Update(stmtSQL, status)

                              %INCLUDE "QuickLinkClear.icl"
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select GLUSFDWK.*, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(FLDESC,' ') as transFLDESC, upper(coalesce(FLDESC,' ')) as transFLDESCU ", stmtSQL)
                              @dtw_concat(fileSQL, " GLUSFDWK ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYFLAG on FLTYPE='GLTRANTYP' and FLVALU=WFTTYP ", fileSQL)
                              @dtw_concat(selectSQL, "WFXHND='$(profileHandle)' ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              @dtw_concat(stmtSQL, " Order By WFDESC,WFFILE,WFPER# ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @FA_Select_UnpostedSubLedger(profileHandle, dataBaseID, stmtSQL)
                          %endif

%{ Quicklink End %}       %INCLUDE "QuickLinkEndLoop.icl"

                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) FA_Select_Header (IN  CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                      <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                  %endif
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>
      <table $(contentTable)>
          %ROW{
          %}
      </table>

      $(hrTagAttr)
      %INCLUDE "QuickLinkDisplay.icl"
  %}
%}

%FUNCTION(dtw_sql) FA_Select_Demographics (IN  CHAR(64)    profileHandle,
                                               CHAR(2)     dataBaseID,
                                               CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      <a name="demographics"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      %ROW{
          <table $(contentTable)>
              @PeriodFromCYP(V_ACURPD)
              <tr><td class="dsphdr">Current Accounting Period</td>
                  <td class="dspnmbr">$(V_ACURPD)</td>
              </tr>

              @RtvYNDesc($(V_ACNOPD), fieldDesc)
              @Format_Code(V_ACNOPD, F_ACNOPD)
              <tr><td class="dsphdr">Calculate Depreciation On An Annual System</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_ACNOPD)</td>
              </tr>

              @RtvFldDesc("SMSCHD=$(V_ACBSCH)", "FASCHD", "SMDESC", fieldDesc)
              @Format_Code(V_ACBSCH, F_ACBSCH)
              <tr><td class="dsphdr">Schedule To Feed To G/L</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_ACBSCH)</td>
              </tr>

              @RtvFldDesc("FLTYPE='DORS' and FLVALU='$(V_ACGLTR)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_ACGLTR, F_ACGLTR)
              <tr><td class="dsphdr">G/L Distribution Feed</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_ACGLTR)</td>
              </tr>

              @RtvYNDesc($(V_ACGLRP), fieldDesc)
              @Format_Code(V_ACGLRP, F_ACGLRP)
              <tr><td class="dsphdr">Feed F/A to G/L</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_ACGLRP)</td>
              </tr>

              @PeriodFromCYP(V_ACLPDU)
              <tr><td class="dsphdr">F/A Last Period Updated</td>
                  <td class="dspnmbr">$(V_ACLPDU)</td>
              </tr>

              @RtvFldDesc("SMSCHD=$(V_ACMSCH)", "FASCHD", "SMDESC", fieldDesc)
              @Format_Code(V_ACMSCH, F_ACMSCH)
              <tr><td class="dsphdr">Schedule For Midquarter Test</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_ACMSCH)</td>
              </tr>

              @RtvFldDesc("SMSCHD=$(V_ACTSCH)", "FASCHD", "SMDESC", fieldDesc)
              @Format_Code(V_ACTSCH, F_ACTSCH)
              <tr><td class="dsphdr">Schedule For Tax Reports</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_ACTSCH)</td>
              </tr>

              @RtvYNDesc($(V_ACDIFC), fieldDesc)
              @Format_Code(V_ACDIFC, F_ACDIFC)
              <tr><td class="dsphdr">Calculate Differential</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_ACDIFC)</td>
              </tr>

              @RtvYNDesc($(V_ACYEFG), fieldDesc)
              @Format_Code(V_ACYEFG, F_ACYEFG)
              <tr><td class="dsphdr">Year End Flag</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_ACYEFG)</td>
              </tr>

              <tr><td class="dsphdr">Anticipated Data Base Prefix</td>
                  <td class="dspalph">$(V_ACALIB)</td>
              </tr>
          </table>
      %}
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) FA_Select_Site (IN  CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      <a name="site"></a>
      %if (backHome == "")
          @dtw_assign(backHome, "$(d2wName)/REPORT")
      %endif
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)FASite.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("", "Site")
                  @Format_Column_Header("", "Name")
                  @Format_Column_Header("", "Address")
                  @Format_Column_Header("", "Company/Facility")
              </tr>
          %endif

          %ROW{
              @Format_CoFac("$(V_ACCO#)", "$(V_ACFAC#)", "", F_CoFac)

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_ACLOCN)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)FAAsset.d2w/REPORT$(genericVarBase)&amp;passedSite=@dtw_rurlescseq(V_ACLOCN)" title="View Assets">$(V_ACLONM)</a></td>
                  <td class="colalph">
                      %if (V_ACLOAD != "") $(V_ACLOAD) %endif
                      %if (V_ACLOA2 != "")
                          %if (V_ACLOAD != "") <br> %endif
                          $(V_ACLOA2)
                      %endif
                      %if (V_ACLOAD != "" || V_ACLOA2 != "") <br> %endif
                      $(V_ACLOCT) $(V_ACLOST) $(V_ACLOZP)
                  </td>
                  <td class="colalph" $(helpCursor)><span title="$(F_CoFac)">$(V_CFCFNM)</span></td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) FA_Select_Property (IN  CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      <a name="property"></a>
      %if (backHome == "")
          @dtw_assign(backHome, "$(d2wName)/REPORT")
      %endif
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)FAProperty.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("", "Property Type")
                  @Format_Column_Header("", "Description")
                  @Format_Column_Header("", "Asset Account")
                  @Format_Column_Header("", "Accumulated Depreciation Account")
                  @Format_Column_Header("", "Depreciation Expense Account")
                  @Format_Column_Header("", "Gain/Loss Account")
                  @Format_Column_Header("", "Cash or A/R Account")
                  @Format_Column_Header("", "Transfer Account")
              </tr>
          %endif

          %ROW{
              @Format_Acct("$(V_PTAAAC)", "$(V_PTAASU)", "", F_PTAAAC)
              @Format_Acct("$(V_PTADAC)", "$(V_PTADSU)", "", F_PTADAC)
              @Format_Acct("$(V_PTDEAC)", "$(V_PTDESU)", "", F_PTDEAC)
              @Format_Acct("$(V_PTGLAC)", "$(V_PTGLSU)", "", F_PTGLAC)
              @Format_Acct("$(V_PTCAAC)", "$(V_PTCASU)", "", F_PTCAAC)
              @Format_Acct("$(V_PTTRAC)", "$(V_PTTRSU)", "", F_PTTRAC)

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">$(V_PTTYPE)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)FAAsset.d2w/REPORT$(genericVarBase)&amp;passedProperty=@dtw_rurlescseq(V_PTTYPE)" title="View Assets">$(V_PTDESC)</a></td>
                  <td class="colalph" $(helpCursor)><span title="$(F_PTAAAC)">$(V_AsstCHCHDS)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(F_PTADAC)">$(V_AcumCHCHDS)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(F_PTDEAC)">$(V_ExpsCHCHDS)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(F_PTGLAC)">$(V_GainCHCHDS)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(F_PTCAAC)">$(V_CashCHCHDS)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(F_PTTRAC)">$(V_TrnfCHCHDS)</span></td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) FA_Select_UnpostedSubLedger (IN  CHAR(64)    profileHandle,
                                                    CHAR(2)     dataBaseID,
                                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="unpostedsubledger"></a>
      %if (backHome == "")
          @dtw_assign(backHome, "$(d2wName)/REPORT")
      %endif
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)GLUnpostSubLedger.d2w/REPORT$(d2wVarBase)&amp;SubLedger=FA")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("WFFILE", "Sub-Ledger")
                  @Format_Column_Header("WFPER#", "Period")
                  @Format_Column_Header("WFJRNL", "Journal")
                  @Format_Column_Header("WFDATE", "Transaction Date")
                  @Format_Column_Header("WFTTYP", "Transaction Type")
                  @Format_Column_Header("WFDESC", "Description")
                  @Format_Column_Header("WFUAMT", "Amount")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @dtw_assign(F_WFPER#, V_WFPER#)
              @PeriodFromCYP(F_WFPER#)
              @Format_Date(V_WFDATE, "D", F_WFDATE)
              @Format_Nbr($(V_WFUAMT), F_WFUAMT, "2", $(amtEditCode), "Y", "", "")

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)GLHDFATRJrnl.d2w/ENTRY$(genericVarBase)&amp;glJournal=@dtw_rurlescseq(V_WFJRNL)&amp;glPer=@dtw_rurlescseq(V_WFPER#)&amp;glDate=@dtw_rurlescseq(V_WFDATE)&amp;glTransType=@dtw_rurlescseq(V_WFTTYP)&amp;glFrCur=@dtw_rurlescseq(V_WFFCUR)" title="View Unposted $(V_WFDESC)">$(V_WFFILE)</a></td>
                  <td class="colnmbr">$(F_WFPER#)</td>
                  <td class="colalph">$(V_WFJRNL)</td>
                  <td class="colnmbr">$(F_WFDATE)</td>
                  <td class="colalph" $(helpCursor)><span title="$(V_WFTTYP)">$(V_transFLDESC)</span></td>
                  <td class="colalph">$(V_WFDESC)</td>
                  <td class="colnmbr">$(F_WFUAMT)</td>
              </tr>
	   %}
      </table>
      </fieldset>
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"

  @Set_SQL(stmtSQL)
%}