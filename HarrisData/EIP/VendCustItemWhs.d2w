%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "$(vendCustHdg) Item/Warehouse"
  d2wName                 = "VendCustItemWhs.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;vendCustNumber=@dtw_rurlescseq(vendCustNumber)&amp;vendCustName=@dtw_rurlescseq(vendCustName)&amp;vendCustHdg=@dtw_rurlescseq(vendCustHdg)&amp;vendCustFlag=@dtw_rurlescseq(vendCustFlag)&amp;vendCustId=@dtw_rurlescseq(vendCustId)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;itemDescr=@dtw_rurlescseq(itemDescr)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HHDVCW"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  helpExt                 = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %if (vendCustFlag == "C")
      @dtw_assign(helpExt, " (Customer)")
      @dtw_assign(customerNumber, $(vendCustNumber))
      @CustomerUserView(profileHandle, dataBaseID, userPass, customerNumber, " ")
  %else
      @dtw_assign(helpExt, " (Vendor)")
      @dtw_assign(vendorNumber, $(vendCustNumber))
      @VendorUserView(profileHandle, dataBaseID, userPass, vendorNumber)
  %endif

  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
                  %INCLUDE "CheckEnterSearch.icl"
                  %INCLUDE "Menu.js"
                  %INCLUDE "NoFormValidate.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                          @dtw_assign(pageID, "VENDCUSTITEMWHS")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select WIWHS, WILOR#, WILORC, WILORD, WILRSD, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(WHWHNM,' ') as WHWHNM, upper(coalesce(WHWHNM,' ')) as WHWHNMU ", stmtSQL)
                          @dtw_concat(fileSQL, " HDVCIW ", fileSQL)
                          @dtw_concat(fileSQL, " left join HDWHSM on WHWHS=WIWHS ", fileSQL)
                          @dtw_concat(selectSQL, "WIID=$(vendCustId) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @VendCustItemWhs_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
  %}

%FUNCTION(dtw_sql) VendCustItemWhs_Query (IN CHAR(64)    profileHandle,
                                             CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (vendCustFlag == "C")
          @dtw_assign(vendCustHdg, "Customer")
      %else
          @dtw_assign(vendCustHdg, "Vendor")
      %endif
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      <a href="$(homeURL)$(cGIPath)VendCustItem.d2w/REPORT$(genericVarBase)&amp;vendCustNumber=@dtw_rurlescseq(vendCustNumber)&amp;vendCustName=@dtw_rurlescseq(vendCustName)&amp;vendCustFlag=@dtw_rurlescseq(vendCustFlag)&amp;vendCustId=@dtw_rurlescseq(vendCustId)">$(portalHome)</a>
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)VendCustItemWhsMaint.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      <table $(contentTable)>
          %if (vendCustFlag == "C")
              @Format_Header_URL("Customer", $(vendCustName), $(vendCustNumber), "$(homeURL)$(cGIPath)CustomerSelect.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(vendCustNumber)&amp;customerName=@dtw_rurlescseq(vendCustName)")
          %else
              @Format_Header_URL("Vendor", $(vendCustName), $(vendCustNumber), "$(homeURL)$(cGIPath)VendorSelect.d2w/REPORT$(genericVarBase)&amp;vendorNumber=@dtw_rurlescseq(vendCustNumber)&amp;vendorName=@dtw_rurlescseq(vendCustName)")
          %endif
          @Format_Header_URL("Item", $(itemDescr), $(itemNumber), "$(homeURL)$(cGIPath)ItemSelect.d2w/REPORT$(d2wVarBase)&amp;itemDescription=@dtw_rurlescseq(itemDescr)")
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Name</th></tr>
                  <tr><td><input type="text" class="inputalph" name="srchName" size="26" maxlength="26">
                          <input type="hidden" name="operName" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchName.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          %if (vendCustFlag == "C")
              @dtw_assign(shipRcvDesc, "Shipped")
              @dtw_assign(costPriceDesc, "Price")
          %else
              @dtw_assign(shipRcvDesc, "Received")
              @dtw_assign(costPriceDesc, "Cost")
          %endif

          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("WIWHS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=whs" title="Sequence By Warehouse"> Whs</a></th>
              @OrderBy_Sort("WHWHNMU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=whsName" title="Sequence By Warehouse Name, Warehouse"> Warehouse Name</a></th>
              @OrderBy_Sort("WILOR#", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=orderNo" title="Sequence By Last Order Number, Warehouse"> Order<br>Number</a></th>
              @OrderBy_Sort("WILORC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=price" title="Sequence By Last Order $(costPriceDesc), Warehouse">$(costPriceDesc)</a></th>
              @OrderBy_Sort("WILORD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=orderDate" title="Sequence By Last Order Date, Warehouse"> Required<br>Date</a></th>
              @OrderBy_Sort("WILRSD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=shippedDate" title="Sequence By Last $(shipRcvDesc) Date, Warehouse"> $(shipRcvDesc)<br>Date</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;whsNumber=@dtw_rurlescseq(V_WIWHS)&amp;whsName=@dtw_rurlescseq(V_WHWHNM)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              @Format_Nbr(V_WILORC, F_WILORC, $(prcNbrDec), $(amtEditCode), "", "", "")
              @Format_Date(V_WILORD, "D", F_WILORD)
              @Format_Date(V_WILRSD, "D", F_WILRSD)

              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_WHWHNM), $(V_WIWHS), "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)VendCustItemWhsMaint.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)VendCustItemWhsMaint.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)vendcustitemwhsmaint.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)WarehouseSelect.d2w/REPORT$(maintainVar)&amp;warehouseNumber=@dtw_rurlescseq(V_WIWHS)&amp;warehouseName=@dtw_rurlescseq(V_WHWHNM)" title="View Warehouse"> $(V_WIWHS)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemWarehouseSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;warehouseNumber=@dtw_rurlescseq(V_WIWHS)" title="View Item/Warehouse"> $(V_WHWHNM)</a></td>
                  %if (vendCustFlag == "C" && V_WILOR# > "0")
                       @RtvFldDesc("(HHBLTO=$(vendCustNumber) or HHSHTO=$(vendCustNumber)) and HHORD#=$(V_WILOR#)", "OEORHH", "Char(Count(*))", recordsHave)
                  %elif (vendCustFlag == "V" && V_WILOR# > "0")
                       @RtvFldDesc("(PHVEND=$(vendCustNumber) or PHRTOV=$(vendCustNumber)) and PHPO=$(V_WILOR#)", "POPOHH", "Char(Count(*))", recordsHave)
                  %else
                       @dtw_assign(haveRecords, "")
                  %endif
                  %if (vendCustFlag == "C" && recordsHave>"0")
                      <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=205&amp;fKey1=HHSHTO&amp;fVal1=@dtw_rurlescseq(vendCustNumber)&amp;fKey2=HHORD&amp;fVal2=@dtw_rurlescseq(V_WILOR#)" title="View Customer Order History">$(V_WILOR#)</a></td>
                  %elif (vendCustFlag == "V" && recordsHave>"0")
                      <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=215&amp;fKey1=PHVEND&amp;fVal1=@dtw_rurlescseq(vendCustNumber)&amp;fKey2=PHPO&amp;fVal2=@dtw_rurlescseq(V_WILOR#)" title="View Vendor Order History">$(V_WILOR#)</a></td>
                  %else
                      <td class="colnmbr">$(V_WILOR#)</td>
                  %endif
                  <td class="colnmbr">$(F_WILORC)</td>
                  <td class="coldate">$(F_WILORD)</td>
                  <td class="coldate">$(F_WILRSD)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"

  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "WHWHNMU,WIWHS")
          @DTW_ASSIGN(orderByDisplay, "Warehouse Name, Warehouse")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}
%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"

  %if (sequence == "whs")
      %if (orderBy == "WIWHS")
          @DTW_ASSIGN(orderBy, "WIWHS DESC")
          @DTW_ASSIGN(orderByDisplay, "Warehouse (descending)")
      %else
          @DTW_ASSIGN(orderBy, "WIWHS")
          @DTW_ASSIGN(orderByDisplay, "Warehouse")
      %endif
  %elif (sequence == "whsName")
      %if (orderBy == "WHWHNMU,WIWHS")
          @DTW_ASSIGN(orderBy, "WHWHNMU DESC,WIWHS")
          @DTW_ASSIGN(orderByDisplay, "Warehouse Name (descending), Warehouse")
      %else
          @DTW_ASSIGN(orderBy, "WHWHNMU,WIWHS")
          @DTW_ASSIGN(orderByDisplay, "Warehouse Name, Warehouse")
      %endif
  %elif (sequence == "orderNo")
      %if (orderBy == "WILOR#,WIWHS")
          @DTW_ASSIGN(orderBy, "WILOR# DESC,WIWHS")
          @DTW_ASSIGN(orderByDisplay, "Last Order Number (descending), Warehouse")
      %else
          @DTW_ASSIGN(orderBy, "WILOR#,WIWHS")
          @DTW_ASSIGN(orderByDisplay, "Last Order Number, Warehouse")
      %endif
  %elif (sequence == "price")
      %if (orderBy == "WILORC,WIWHS")
          @DTW_ASSIGN(orderBy, "WILORC DESC,WIWHS")
          @DTW_ASSIGN(orderByDisplay, "Last Order Cost/Price (descending), Warehouse")
      %else
          @DTW_ASSIGN(orderBy, "WILORC,WIWHS")
          @DTW_ASSIGN(orderByDisplay, "Last Order Cost/Price, Warehouse")
      %endif
  %elif (sequence == "orderDate")
      %if (orderBy == "WILORD,WIWHS")
          @DTW_ASSIGN(orderBy, "WILORD DESC,WIWHS")
          @DTW_ASSIGN(orderByDisplay, "Last Order Date (descending), Warehouse")
      %else
          @DTW_ASSIGN(orderBy, "WILORD,WIWHS")
          @DTW_ASSIGN(orderByDisplay, "Last Order Date, Warehouse")
      %endif
  %elif (sequence == "shippedDate")
      %if (orderBy == "WILRSD,WIWHS")
          @DTW_ASSIGN(orderBy, "WILRSD DESC,WIWHS")
          @DTW_ASSIGN(orderByDisplay, "Last $(shipRcvDesc) Date (descending), Warehouse")
      %else
          @DTW_ASSIGN(orderBy, "WILRSD,WIWHS")
          @DTW_ASSIGN(orderByDisplay, "Last $(shipRcvDesc) Date, Warehouse")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "numedit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              function validate(searchForm) {
                  if (editNum(document.Search.srchWhs, 3, 0) &&
                      editNum(document.Search.srchOrder, 8, 0) &&
                      editNum(document.Search.srchPrice, 8, 5) &&
                      editdate(document.Search.srchOrdDate) &&
                      editdate(document.Search.srchShipDate))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "VENDCUSTITEMWHSSRCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Warehouse</td>
                              @dtw_assign(operNbr, "operWhs")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchWhs" size="3" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Warehouse Name</td>
                              @dtw_assign(operNbr, "operName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchName" size="26" maxlength="26"></td>
                          </tr>

                          <tr><td class="dsphdr"> Order Number</td>
                              @dtw_assign(operNbr, "operOrder")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchOrder" size="8" maxlength="8"></td>
                          </tr>

                          <tr><td class="dsphdr"> Price</td>
                              @dtw_assign(operNbr, "operPrice")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchPrice" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr"> Required Date</td>
                              @dtw_assign(operNbr, "operOrdDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchOrdDate" size="6" maxlength="6"><a href="javascript:calWindow('srchOrdDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr"> Shipped Date</td>
                              @dtw_assign(operNbr, "operShipDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchShipDate" size="6" maxlength="6"><a href="javascript:calWindow('srchShipDate');">$(calendarImage)</a></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchWhs.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("WIWHS", "Warehouse", $(srchWhs), "", operWhs, "N")
  @Build_WildCard ("upper(WHWHNM)", "Warehouse Name", $(srchName), "U", operName, "A")
  @Build_WildCard ("WILOR#", "Order Number", $(srchOrder), "", operOrder, "N")
  @Build_WildCard ("WILORC", "Price", $(srchPrice), "", operPrice, "N")
  @Build_WildCard ("WILORD", "Required Date", $(srchOrdDate), "", operOrdDate, "D")
  @Build_WildCard ("WILRSD", "Shipped Date", $(srchShipDate), "", operShipDate, "D")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}