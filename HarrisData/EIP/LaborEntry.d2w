%INCLUDE "$(baseVar)"
%INCLUDE "EdtVar.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "ETControl$(dataBaseID).icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Labor Entry"
  d2wName                 = "LaborEntry.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;touchScreen=Y"
  currentURL              = "$(d2wName)/REPORT$(d2wVarBase)"
  programName             = "HETLBE"
  programName2            = "HSI214"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  groupNbr                = "0"
  sec_01                  = ""
  sec_02                  = ""
  sec_03                  = ""
  sec_04                  = ""
  sec_05                  = ""
  sec_06                  = ""
  sec_07                  = ""
  sec_08                  = ""
  sec_09                  = ""
  sec_10                  = ""
  sec_11                  = ""
  sec_12                  = ""
  sec_13                  = ""
  sec_14                  = ""
  sec_15                  = ""
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  @dtw_assign(timeOutM, "0")
  %if (sfdTimeOut > "0")
      @dtw_multiply(sfdTimeOut, "1000", timeOutM)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  %if (sec_01 == "Y" && V_TAALRT == "Y")
                      if (document.Chg.transDate.value =="" ||
                          document.Chg.transTime.value =="")
                         {alert("$(reqFieldError)"); return false;}
                      if (editNum(document.Chg.transDate, 6, 0) &&
                          editdate(document.Chg.transDate) &&
                          %if (V_TADSSF == "Y")
                              editNum(document.Chg.transTime, 6, 0)
                          %else
                              editNum(document.Chg.transTime, 4, 0)
                          %endif
                      )
                  %endif
                  return true;
              }
              %INCLUDE "DateEdit.icl"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "KeyboardFunctionsTS.icl"
              %INCLUDE "ShowHideSelCriteria.icl"
              function setTrans(transCode) {
                 document.Chg.currTrans.value = transCode;
                 if (validate(document.Chg)) {
                     document.Chg.submit();
                 }
              }
              
              %if (timeOutM > "0")
                  setTimeout("window.location.assign('$(homeURL)$(cGIPath)ShopFloorDispatch.d2w/REPORT?baseVar=@dtw_rurlescseq(baseVar)&portal=@dtw_rurlescseq(portal)&eID=@dtw_rurlescseq(eID)&touchScreen=Y');",$(timeOutM));
              %endif
              
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">

%{ Labor Entry Heading %}
                      @dtw_assign(stmtSQL, "")
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(stmtSQL, " From SIDCTW Where WDXHND='$(profileHandle)' ", stmtSQL)
                      @dtw_concat(stmtSQL, " Fetch First 1 Row Only With NC  @@endsql", stmtSQL)
                      @Labor_Entry_Header(profileHandle, dataBaseID, stmtSQL)

%{ Data Collection Codes %}
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select DFCODE, DFDESC, DFONOF ", stmtSQL)
                      @dtw_concat(fileSQL, " ETDCDF ", fileSQL)
                      @dtw_concat(selectSQL, " DFCODE<'60' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By DFONOF desc,DFCODE ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @dcCode_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
                  <td>
                      <ul class="toolbarTS">
                          @pgmOptSecurity(profileHandle, dataBaseID, programName2, HSI214_01, HSI214_02, HSI214_03, HSI214_04, HSI214_05, HSI214_06, HSI214_07, HSI214_08, HSI214_09, HSI214_10, HSI214_11, HSI214_12, HSI214_13, HSI214_14, HSI214_15)
                          <li class="optionTS"><a href="$(homeURL)$(cGIPath)ShopFloorDispatch.d2w/REPORT$(d2wVarBase)">&nbsp;<br>Back</a></li>
                          %if (groupNbr > "0")
                              <li class="optionTS"><a href="$(homeURL)$(cGIPath)LaborEntryEmployees.d2w/REPORT$(d2wVarBase)">&nbsp;<br>Maintain Employees</a></li>
                          %endif
                          <li class="optionTS"><a href="$(homeURL)$(cGIPath)LaborEntryOrders.d2w/REPORT$(d2wVarBase)">&nbsp;<br>Maintain Orders</a></li>
                      </ul>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Labor_Entry_Header (IN CHAR(64)    profileHandle,
				           CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <tr><td><h1> $(page_title)</h1></td></tr>
      </table>

      %ROW{
          <table $(contentTable)>
              %if (V_WDGRP == "0")
                  @dtw_assign(groupNbr, "0")
                  @Format_Header("Employee", $(V_WDENAM), "")
              %else
                  @dtw_assign(groupNbr, V_WDGRP)
                  @Format_Header("Group", $(V_WDGDSC), "")
              %endif
              @RtvFldDesc("DFCODE='$(V_WDLSTR)'", "ETDCDF", "DFDESC", lastTranDesc)
              @Format_Header("Last Transaction", $(lastTranDesc), $(V_WDLSTR))
          </table>
       %}

      %INCLUDE "ConfMessageDisplay.icl"
      $(hrTagAttr)
  %}
%}


%FUNCTION(dtw_sql) dcCode_Query (IN CHAR(64)    profileHandle,
				     CHAR(2)     dataBaseID,
                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(saveDFONOF, "")
      @dtw_assign(optionClass, "optionNTS")
      <table $(contentTable)>
          <tr>
          %ROW{
              %if (V_DFONOF != saveDFONOF)
                  %if (saveDFONOF != "")
                      </ul></td>
                      @dtw_assign(optionClass, "optionFTS")
                  %endif
                  <td><ul class="toolbarLTS">
                  @dtw_assign(saveDFONOF, V_DFONOF)
              %endif
              <li class="$(optionClass)"><a href="javascript:setTrans($(V_DFCODE))">&nbsp;<br>$(V_DFDESC)</a></li>
	      %}
 	  </ul></td></tr>
      </table>

      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" method="post" name="Chg" action="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
          <input type="hidden" name="currTrans">
          %if (sec_01 == "Y" && V_TAALRT == "Y")
              %INCLUDE "RequiredFieldTS.icl"
          %endif
          <table $(contentTable)>
              %if (errFound != "")
                  @dtw_assign(focusField, "")
                  @EdtVarErr(profileHandle, typeValue, edtVar)
                  @ErrVarErr(profileHandle, typeError, errVar)
                  @DecatErr_Field("@@dtcl", "currTrans")         @dtw_assign(Err_TRAN, fieldValue)
                  @DecatErr_Field("@@date", "transDate")         @dtw_assign(Err_DATE, fieldValue)
                  @DecatErr_Field("@@time", "transTime")         @dtw_assign(Err_TIME, fieldValue)

                  @Decat_Field("@@date")   @dtw_assign(V_DATE,  fieldValue)
                  @Decat_Field("@@time")   @dtw_assign(V_TIME,  fieldValue)

                  @dtw_assign(errFound, "")
              %else
                  @RtvFldDesc("WDXHND='$(profileHandle)'", "SIDCTW", "WDDATE", V_DATE)
                  @DateInputFromCYMD(V_DATE)
                  @DTW_TIME(F_TIME)
                  @DTW_TIME(V_TIME)
                  @dtw_REPLACE(V_TIME, ":", "", V_TIME)
                  %while(@dtw_rlength(V_TIME) != "6") {@dtw_insert("0", V_TIME, V_TIME)%}
                  %if (V_TADSSF != "Y")
                      @dtw_assign(h, "@dtw_rsubstr(V_TIME, "1", "2")")
                      @dtw_assign(m, "@dtw_rsubstr(V_TIME, "3", "2")")
                      @dtw_assign(V_TIME, "@dtw_rconcat(h, m)")
                  %endif

                  @dtw_assign(focusField, "transDate")
              %endif

              @DspErrMsg(Err_TRAN)

              @SetTextOvr(Err_DATE)
              <tr><td class="dsphdr"><span $(textOvr)>Date</span></td>
                  %if (sec_01 == "Y" && V_TAALRT == "Y")
                      <td class="input"><input class="input" id="transDate" onfocus="kbActive(this, 'dtpDiv');" name="transDate" type="text" value="$(V_DATE)" size="6" maxlength="6"> $(reqFieldChar)</td>
                  %else
                      @dtw_assign(F_DATE, V_DATE)
                      @DateToCYMD(F_DATE)
                      @Format_Date(F_DATE, "H", F_DATE)
                      <td class="dspnmbr"><input class="input" name="transDate" type="hidden" value="$(V_DATE)">$(F_DATE)</td>
                  %endif
                  <td>&nbsp;</td>
                  @SetTextOvr(Err_TIME)
                  <td class="dsphdr"><span $(textOvr)>Time</span></td>
                  %if (sec_01 == "Y" && V_TAALRT == "Y")
                      @dtw_assign(transTimeMax, "6")
                      %if (V_TADSSF != "Y")
                          @dtw_assign(transTimeMax, "4")
                      %endif
                      <td class="input"><input class="input" id="transTime" onfocus="kbActive(this, 'numericKeyboard');" name="transTime" type="text" value="$(V_TIME)" size="6" maxlength="$(transTimeMax)"> $(reqFieldChar)</td>
                  %else
                      @dtw_assign(F_TIME, V_TIME)
                      %if (V_TADSSF == "Y")
                          @EditHrsMinSec(F_TIME)
                      %else
                          @EditHrsMin(F_TIME)
                      %endif
                      <td class="dspnmbr"><input class="input" name="transTime" type="hidden" value="$(V_TIME)">$(F_TIME)</td>
                  %endif
              </tr>
              @DspErrMsg(Err_DATE)
              @DspErrMsg(Err_TIME)

          </table>
          %INCLUDE "KeyboardTS.icl"
      </form>

       $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HETLBE_W.PGM %}
%}

%HTML(BUILD) {
  %INCLUDE "setLibraryList.icl"

  @dtw_assign(edtVar, "")
  @Concat_Field("@@subr", "SrFillWk")
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, errFound, edtVar, errVar)
  %if (errFound == "X")
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)EmployeeSignOn.d2w/REPORT$(d2wVarBase)">
  %else
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)">
  %endif
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(transDate,    @dtw_rstrip(transDate))
  @dtw_assign(transTime,    @dtw_rstrip(transTime))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@subr", "SrEditT")
  @Concat_Field("@@dtcl", currTrans)
  @Concat_Field("@@date", transDate)
  @Concat_Field("@@time", transTime)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, errFound, edtVar, errVar)

  %if (errFound == "")
  %{ 25,35,45 or 55 %}
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)LaborEntryQuantities.d2w/REPORT$(d2wVarBase)">
  %elif (errFound == "X")
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)EmployeeSignOn.d2w/REPORT$(d2wVarBase)">  
  %elif (errFound == "C")
  %{ ON transaction or Shift Off %}
      @DecatErr_Field("@@cmsg", "confMessage")
      @dtw_assign(confMessage, fieldValue)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ShopFloorDispatch.d2w/BUILD$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}

%HTML(NOUPDATE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(confMessage, "")
  @dtw_assign(returnURL, "ShopFloorDispatch.d2w/REPORT$(d2wVarBase)")
  %INCLUDE "ReturnTS.icl"
%}