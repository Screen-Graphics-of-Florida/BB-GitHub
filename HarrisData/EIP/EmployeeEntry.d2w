                          <td class="inputalph"><input disabled name="groupDesc" value="$(fieldDesc)"  type="text" size="20" maxlength="20"></td>
                      </tr>
                      @DspErrMsg(Err_WIBGRP)

                      @SetTextOvr(Err_WISCRS)
                      @RtvFldDesc("ODCOMP=$(V_WIPECP) and ODTYPE='I' and ODCODE='$(V_WISCRS)' ", "PECODE", "CHAR(ODDESC)", fieldDesc)
                      <tr><td class="dsphdr"><span $(textOvr)>Salary Change Reason</span></td>
