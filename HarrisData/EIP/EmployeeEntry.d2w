                                                <a href="javascript:calWindow('terminationDate');">$(calendarImage)</a></td>
                          <td class="inputalph">&nbsp;</td>
                      </tr>
                      @DspErrMsg(Err_WITRDT)

                      @RtvFldDesc("ODCOMP=$(V_WIPECP) and ODTYPE='T' and ODCODE='$(V_WITRCD)' ", "PECODE", "CHAR(ODDESC)", fieldDesc)
                      @SetTextOvr(Err_WITRCD)
                      <tr><td class="dsphdr"><span $(textOvr)>Termination Code</span></td>
                          <td class="inputalph"><input name="terminationCode" type="text" value="$(V_WITRCD)" size="4" maxlength="4">
                                                <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Chg&amp;fldComp=@dtw_rurlescseq(hrCompany)&amp;fldType=T&amp;fldName=terminationCode&amp;fldDesc=terminationCodeDesc&amp;hrCompany=@dtw_rurlescseq(V_WIPECP)" onclick="$(searchWinVar)">$(searchImage)</a></td>
                          <td class="inputalph"><input disabled name="terminationCodeDesc" value="$(fieldDesc)"  type="text" size="20" maxlength="20"></td>
                      </tr>
                      @DspErrMsg(Err_WITRCD)

                      @RtvFldDesc("PLPLNT=$(V_WIPLNT)", "HDPLNT", "PLNAME", fieldDesc)
                      @SetTextOvr(Err_WIPLNT)
