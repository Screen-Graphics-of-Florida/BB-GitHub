                      @RtvFldDesc("PPCOMP=$(V_WICOMP) and PPFACL=$(V_WIFACL) and PPDEPT='$(V_WIDEPT)' and PPSHFT='$(V_WISHFT)' ", "PRPREM", "CHAR(PPDESC)", fieldDesc)
