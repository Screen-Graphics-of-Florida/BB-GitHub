                      @SetTextOvr(Err_WICOMP)
                      <tr><td class="dsphdr"><span $(textOvr)>Company/Facility</span></td>
                          %if (V_WICODE=="A")
                              <td class="inputnmbr"><input name="prCompany"  value="$(V_WICOMP)" type="text" size="2" maxlength="2"> /
                                                    <input name="prFacility" value="$(V_WIFACL)" type="text" size="4" maxlength="4">
                                                    <a href="$(homeURL)$(cGIPath)CoFacSearchHr.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldCo=prCompany&amp;fldFac=prFacility&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage)</a></td>
                          %else
                              <td class="inputalph"><input name="prCompany"  type="hidden" value="$(V_WICOMP)">$(V_WICOMP) /
                                                    <input name="prFacility" type="hidden" value="$(V_WIFACL)">$(V_WIFACL)</td>
                          %endif
                          <td class="inputalph"><input disabled name="coFacDesc" value="$(fieldDesc)"  type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_WICOMP)

                      @SetTextOvr(Err_WIEMPL)
                      <tr><td class="dsphdr"><span $(textOvr)>Employee Number</span></td>
                          %if (V_WICODE=="A")
                              <td class="inputnmbr"><input name="prEmployee" type="text" value="$(V_WIEMPL)" size="5" maxlength="5">
                                                    <a href="$(homeURL)$(phpPath)EmployeeSearch.php$(altVarBase)&amp;docName=Chg&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;fldCo=prCompany&amp;fldFacl=prFacility&amp;fldEmpl=prEmployee&amp;fldHrCo=hrCompany&amp;fldHrEmpl=hrEmployee" onclick="$(searchWinVar)">$(searchImage)</a></td>
                          %else
                              <td class="inputnmbr"><input name="prEmployee" type="hidden" value="$(V_WIEMPL)">$(V_WIEMPL)</td>
                          %endif
                          <td class="inputalph">&nbsp;</td>
                      </tr>
                      @DspErrMsg(Err_WIEMPL)

                      @SetTextOvr(Err_WIPECP)
                      <tr><td class="dsphdr"><span $(textOvr)>H/R Company Number</span></td>
                          %if (V_WICODE=="A")
                              <td class="inputnmbr"><input name="hrCompany" type="text" value="$(V_WIPECP)" size="2" maxlength="2"></td>
                          %else
                              <td class="inputnmbr"><input name="hrCompany" type="hidden" value="$(V_WIPECP)">$(V_WIPECP)</td>
                          %endif
