                      %endif
                      <tr><td class="dsphdr"><span $(textOvr)>Company Position Level/Sequence</span></td>
                          <td class="inputnmbr"><input name="orgLevel" value="$(V_WILEVL)" type="text" size="1" maxlength="1"> /
                                                <input name="orgSeq" value="$(V_WIOSEQ)" type="text" size="5" maxlength="5">
                                                <input name="orgComp" value="$(V_WIPECP)" type="hidden" size="2" maxlength="2">
