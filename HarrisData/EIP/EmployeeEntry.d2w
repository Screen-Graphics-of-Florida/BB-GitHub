                                          <td class="inputalph">&nbsp;</td>
                                      </tr>
                                      @DspErrMsg(Err_WILPE2)                                      
                                      
                                       @SetTextOvr(Err_WIERES)
                                      @RtvFldDesc("TLID='$(V_WIERES)'", "PRLTAX", "CHAR(TLLCNM)", fieldDesc)
                                      <tr><td class="dsphdr"><span $(textOvr)>Employee Resident Local Tax ID</span></td>
                                          <td class="inputalph"><input name="empResId" type="text" value="$(V_WIERES)" size="2" maxlength="2">
                                                                <a href="$(homeURL)$(cGIPath)LocalIdSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=empResId&amp;fldDesc=empResDesc" onclick="$(searchWinVar)">$(searchImage)</a></td>
                                          <td class="inputalph"><input name="empResDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                                      </tr>
                                      @DspErrMsg(Err_WIERES)
                                      
                                  </table>
                              </fieldset>
                          </td>
                      </tr>
                      <tr>
                          <td>
                              <a name="taxReporting"></a>
                              <fieldset class="legendBody">
                                  <legend class="legendTitle">Tax Reporting</legend>
                                  <div class="quickLinksTop">
                                      <a href="#top">$(topOfFormImage)</a>
                                  </div>
                                  <table $(contentTable)>

                                      @RtvYNDesc($(V_WIPEN), fieldDesc)
                                      @SetTextOvr(Err_WIPEN)
