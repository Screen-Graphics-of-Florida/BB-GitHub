                      <a href="#top">$(topOfFormImage)</a>
                  </div>
                  <table $(contentTable)>
                      <tr><td><input type="hidden" name="updateOption"></td></tr>

                      @SetTextOvr(Err_WICODE)
                      <tr><td class="dsphdr"><span $(textOvr)>Type Of Import</span></td>
                          <td class="inputalph"><input name="typeOfImport" type="hidden" value="$(V_WICODE)">$(V_WICODE)</td>
                      </tr>
                      @DspErrMsg(Err_WICODE)

                      @RtvFldDesc("FLTYPE='HRACTIVE' and FLVALU='$(V_WIPRAC)'", "SYFLAG", "FLDESC", fieldDesc)
                      @SetTextOvr(Err_WIPRAC)
