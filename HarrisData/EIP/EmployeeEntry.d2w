      @dtw_concat(editVariables, " editNum(document.Chg.sitCommRate, 2, 3) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.sitBonusRate, 2, 3) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.jobClass, 4, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.loc1Dep, 2, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.loc2Dep, 2, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.loc1PersExempt, 2, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.loc2PersExempt, 2, 0) && ", editVariables)      
      @dtw_concat(editVariables, " editNum(document.Chg.occIndCode, 6, 0) && ", editVariables)
      @dtw_concat(editVariables, " editdate(document.Chg.probationDate) && ", editVariables)
