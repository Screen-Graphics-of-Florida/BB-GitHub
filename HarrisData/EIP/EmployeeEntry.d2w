      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Insert Into HRIMEW (WIXHND,            WIINST,       WIINDT,           WIWITM,       WIWISQ,                WICODE,   WIPRAC,  WICOMP, WIFACL, WIEMPL, WIPECP, WIPEMP, WIAPDT, WIAPSQ, WILEVL, WIOSEQ,  WIRNAM,   WILNAM,   WIFNAM,   WIMIDI,   WIADR1,   WIADR2,   WICITY,   WIST,   WIPROV,   WIZIP,   WICNTR,  WIPHON,  WILOC,   WIDEPT,  WIDOB, WISSNO,  WISSSF,   WIGNDR,   WIMSTA,  WINODP, WIHIRE, WISTRT, WISENR,  WICTZN,   WIALRG,   WIJOB,  WIEEO,  WIUNCD,   WIUNMN,   WISHFT,  WIANHR, WISCHD, WITRDT,  WITRCD,  WIPLNT,  WIMDPT,   WIWC,  WIHGRP, WIUSR1, WIUSR2, WIUSR3,  WIUSR4,   WIUSR5,   WIUSR6,   WITYPE,   WIEXMT,  WIFREQ, WIAMT, WISRCD,  WIOVTM,   WIHCE,   WIOFCR,   WIKEYE,   WIBGRP,   WISCRS,  WIDLIN,  WIVASC,   WIMSAC,  WIACDT, WIACVH, WIVHA, WIACVD, WIVDA, WIASH, WISHA, WIASD, WISDA, WIAMH, WIMHA, WIAMD, WIMDA, WIGNID,  WIMGN,   WIMCN,   WIMVN,   WITITL,  WIETHN,  WIOTID,   WIHSRC,  WIFASC,  WISDEP,   WISTAT,   WIPENS,   WILABC,   WIMAIL,   WIMILT,  WIWCMP, WIWPHN, WIEXTN,  WICLAS,   WILVRE,  WILVDT, WILVRT, WIRTEM, WIRVEM,  WITEMP,  WISBHR,  WISCCL,   WISCID,  WISCDT, WISCEX,  WIPARK,   WILCST,   WILCPL,   WIHNDC,   WIPHYS,  WIPPHN,  WIBLOD,  WILBD,  WICNME,   WICADR,   WICAD2,   WIC1CT,   WIC1ST,   WIC1ZP,  WICPHN,  WIC2NM,   WIC2A1,   WIC2A2,   WIC2CT,   WIC2ST,   WIC2ZP,  WIC2PH, WIGRAD,  WIDGRE,   WISUBJ,   WISCHL,   WIPDPT,  WIDPCD,  WIPJOB,  WIJBCD,  WIPSTS,  WISTCD,  WIREHR,  WIACCT, WISACT,  WIXFIT,   WIXFIC,   WIEXSU,   WIFWHS,  WIDFDP, WIFDAP, WIFDAA, WICFTP, WIBFTP,  WIEIC,  WIGWGS, WIGPCT,  WIEXST,   WISTID,  WISDC, WISTDP, WIPEC, WIAEC, WIEXAM, WITAXC, WICRC, WIADC, WISTAP, WISTAA, WICSTP, WIBSTP,  WISUID,   WIEXWC,   WISWID,  WIJBCL,  WISDID,   WILTX1,  WILDP1,  WILPE1, WILTX2,  WILDP2,  WILPE2, WIERES, WIPEN,   WIETYP,  WIINDS,  WIOPCD,   WINQPC,   WISTEM,   WILGRP,   WIPBCD,  WIPBDT, WICNTY, WIEHLT, WIRHLT,  WIWGPC,   WISEAS,   WIUNIT,  WIDCDT, WIW420, WISTP2, WICDAM, WIOTHI, WIDED) ", stmtSQL)
      @dtw_concat(stmtSQL, "            Values ('$(profileHandle)', $(wfInstance),$(wfInstanceDate),$(wfWorkItem),$(wfWorkItemSequence),'$(CODE)','$(PRAC)',$(COMP),$(FACL),$(EMPL),$(PECP),$(PEMP),$(APDT),$(APSQ),$(LEVL),$(OSEQ),'$(RNAM)','$(LNAM)','$(FNAM)','$(MIDI)','$(ADR1)','$(ADR2)','$(CITY)','$(ST)','$(PROV)','$(ZIP)','$(CNTR)',$(PHON),'$(LOC)','$(DEPT)',$(DOB),'$(SSNO)','$(SSSF)','$(GNDR)','$(MSTA)',$(NODP),$(HIRE),$(STRT),$(SENR),'$(CTZN)','$(ALRG)','$(JOB)',$(EEO),'$(UNCD)','$(UNMN)','$(SHFT)',$(ANHR),$(SCHD),$(TRDT),'$(TRCD)',$(PLNT),'$(MDPT)','$(WC)',$(HGRP),$(USR1),$(USR2),$(USR3),'$(USR4)','$(USR5)','$(USR6)','$(TYPE)','$(EXMT)',$(FREQ),$(AMT),$(SRCD),'$(OVTM)','$(HCE)','$(OFCR)','$(KEYE)','$(BGRP)','$(SCRS)',$(DLIN),'$(VASC)','$(MSAC)',$(ACDT),$(ACVH),$(VHA),$(ACVD),$(VDA),$(ASH),$(SHA),$(ASD),$(SDA),$(AMH),$(MHA),$(AMD),$(MDA),$(GNID),'$(MGN)','$(MCN)','$(MVN)','$(TITL)',$(ETHN),'$(OTID)','$(HSRC)',$(FASC),'$(SDEP)','$(STAT)','$(PENS)','$(LABC)','$(MAIL)','$(MILT)',$(WCMP),$(WPHN),$(EXTN),'$(CLAS)','$(LVRE)',$(LVDT),$(LVRT),$(RTEM),$(RVEM),'$(TEMP)',$(SBHR),'$(SCCL)','$(SCID)',$(SCDT),$(SCEX),'$(PARK)','$(LCST)','$(LCPL)','$(HNDC)','$(PHYS)',$(PPHN),'$(BLOD)',$(LBD),'$(CNME)','$(CADR)','$(CAD2)','$(C1CT)','$(C1ST)','$(C1ZP)',$(CPHN),'$(C2NM)','$(C2A1)','$(C2A2)','$(C2CT)','$(C2ST)','$(C2ZP)',$(C2PH),$(GRAD),'$(DGRE)','$(SUBJ)','$(SCHL)','$(PDPT)',$(DPCD),'$(PJOB)',$(JBCD),'$(PSTS)',$(STCD),'$(REHR)',$(ACCT),$(SACT),'$(XFIT)','$(XFIC)','$(EXSU)','$(FWHS)',$(DFDP),$(FDAP),$(FDAA),$(CFTP),$(BFTP),'$(EIC)',$(GWGS),$(GPCT),'$(EXST)','$(STID)',$(SDC),$(STDP),$(PEC),$(AEC),$(EXAM),$(TAXC),$(CRC),$(ADC),$(STAP),$(STAA),$(CSTP),$(BSTP),'$(SUID)','$(EXWC)','$(SWID)',$(JBCL),'$(SDID)','$(LTX1)',$(LDP1),$(LPE1),'$(LTX2)',$(LDP2),$(LPE2),'$(ERES)','$(PEN)','$(ETYP)',$(INDS),'$(OPCD)','$(NQPC)','$(STEM)','$(LGRP)','$(PBCD)',$(PBDT),$(CNTY),$(EHLT),$(RHLT),'$(WGPC)','$(SEAS)','$(UNIT)',$(DCDT),'$(W420)','$(STP2)',$(CDAM),$(OTHI),$(DED) ) ", stmtSQL)
