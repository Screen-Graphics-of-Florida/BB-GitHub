              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a NAME="top"></a>
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  <a href="javascript:document.Chg.updateOption.value='1E'; check(document.Chg)">$(editNoUpdateSml)</a>
                  <a href="javascript:document.Chg.updateOption.value='1U'; check(document.Chg)">$(nextImage)</a>
                  <a onClick="return confirmRefresh()" href="$(refreshURL)">$(selectResetImage)</a>
                  %if (WFReview=="Y")
                      <a href="$(homeURL)$(cGIPath)WFWorkListOptions.d2w/CANCEL$(d2wVarBase)&amp;refreshD2W=N">$(cancelImageMed)</a>
                  %endif
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>
      $(hrTagAttr)

      <table $(quickLinkTable)>
          <tr>
              <td class="quickLinkTabs"><a href="#employee">Employee</a></td>
              <td class="quickLinkTabs"><a href="#demographics1">Demographics 1</a></td>
              <td class="quickLinkTabs"><a href="#demographics2">Demographics 2</a></td>
              <td class="quickLinkTabs"><a href="#demographics3">Demographics 3</a></td>
              <td class="quickLinkTabs"><a href="#payInformation">Pay Information</a></td>
          </tr>
          <tr>
              <td class="quickLinkTabs"><a href="#accruals">Accruals</a></td>
              <td class="quickLinkTabs"><a href="#cobra">COBRA</a></td>
              <td class="quickLinkTabs"><a href="#generalEmployment">General Employment</a></td>
              <td class="quickLinkTabs"><a href="#supervision">Supervision</a></td>
              <td class="quickLinkTabs"><a href="#security">Security</a></td>
          </tr>
          <tr>
              <td class="quickLinkTabs"><a href="#emergencyInformation">Emergency Information</a></td>
              <td class="quickLinkTabs"><a href="#emergencyContact1">Emergency Contact 1</a></td>
              <td class="quickLinkTabs"><a href="#emergencyContact2">Emergency Contact 2</a></td>
              <td class="quickLinkTabs"><a href="#highestEduction">Highest Education</a></td>
              <td class="quickLinkTabs"><a href="#latestEmployment">Latest Employment Changes</a></td>
          </tr>
          <tr>
              <td class="quickLinkTabs"><a href="#federalTaxes">Federal</a></td>
              <td class="quickLinkTabs"><a href="#stateTaxes">State Income Tax</a></td>
              <td class="quickLinkTabs"><a href="#unemploymentTax">State Unemployment Insurance</a></td>
              <td class="quickLinkTabs"><a href="#workerComp">State Workers' Compensation</a></td>
              <td class="quickLinkTabs"><a href="#disabilityInsurance">State Disability Insurance</a></td>
          </tr>
          <tr>
              <td class="quickLinkTabs"><a href="#taxReporting">Tax Reporting</a></td>
              <td class="quickLinkTabs"><a href="#localTax">Local Tax</a></td>
          </tr>

      </table>

      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
		
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          %ROW {
              @dtw_assign(focusField, "prActivityCode")
              %if (errFound != "")
                  @dtw_assign(focusField, "")
                  @EdtVarErr(profileHandle, typeValue, edtVar)
