              <a name="accruals"></a>
              <fieldset class="legendBody">
                  <legend class="legendTitle">Accruals</legend>
                  <div class="quickLinksTop">
                      <a href="#top">$(topOfFormImage)</a>
                  </div>
                  <table $(contentTable)>
                      <tr>
                          <td>
                              <fieldset class="legendBody">
                                  <legend class="legendTitle">Accrual Codes and Date</legend>
                                  <table $(contentTable)>

                                      @SetTextOvr(Err_WIVASC)
                                      <tr><td class="dsphdr"><span $(textOvr)>Vacation/Sick Accrual Code</span></td>
                                          <td class="inputalph"><input name="vacSickAccrCode" type="text" value="$(V_WIVASC)" size="2" maxlength="2">
