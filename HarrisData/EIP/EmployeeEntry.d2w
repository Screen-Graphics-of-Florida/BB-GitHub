                      </tr>
                      @DspErrMsg(Err_WIEEO)

                      @RtvFldDesc("ODCOMP=$(V_WIPECP) and ODTYPE='U' and ODCODE='$(V_WIUNCD)' ", "PECODE", "CHAR(ODDESC)", fieldDesc)
