                          <td class="inputalph"><input disabled name="unionDesc" value="$(fieldDesc)"  type="text" size="20" maxlength="20"></td>
                      </tr>
                      @DspErrMsg(Err_WIUNCD)

                      @SetTextOvr(Err_WIUNMN)
