      @dtw_concat(editVariables, " editNum(document.Chg.budgetHours, 2, 0) &&  ", editVariables)
      @dtw_concat(editVariables, " editdate(document.Chg.securityIssue) &&  ", editVariables)
      @dtw_concat(editVariables, " editdate(document.Chg.securityExpiration) &&  ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.physicianPhone, 10, 0) && ", editVariables)
      @dtw_concat(editVariables, " editdate(document.Chg.bloodDonation) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.contactOnePhone, 10, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.contactTwoPhone, 10, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.yearGraduated, 4, 0) && ", editVariables)
      @dtw_concat(editVariables, " editdate(document.Chg.deptChangeDate) && ", editVariables)
      @dtw_concat(editVariables, " editdate(document.Chg.jobChangeDate) && ", editVariables)
      @dtw_concat(editVariables, " editdate(document.Chg.statusChangeDate) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.wageExpAcct, 4, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.wageExpSub, 4, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.fitDependents, 2, 2) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.fitAddPercent, 2, 3) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.fitAddAmount, 5, 2) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.fitCommRate, 2, 1) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.fitBonusRate, 2, 1) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.guaranteedAmount, 7, 2) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.guaranteedPercent, 2, 3) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.stdDedCat, 1, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.sitDependents, 2, 2) && ", editVariables)
