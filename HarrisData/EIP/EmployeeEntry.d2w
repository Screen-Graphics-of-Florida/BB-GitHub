      @dtw_concat(editVariables, " editdate(document.Chg.firstAssocDate) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.workersCompNbr, 9, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.workPhone, 10, 0) && ", editVariables)
