                          <td class="inputalph"><input name="prActivityCode" type="text" value="$(V_WIPRAC)" size="1" maxlength="1">
                                                <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=HRACTIVE&amp;flagSrchHdr=@dtw_rurlescseq("P/R Activity Code")&amp;docName=Chg&amp;fldName=prActivityCode&amp;fldDesc=prActivityCodeDesc" onclick="$(searchWinVar)">$(searchImage)</a></td>
                          <td class="inputalph"><input name="prActivityCodeDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                      </tr>
                      @DspErrMsg(Err_WIPRAC)

