                          <td class="inputalph"><input name="keyEmployeeDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                      </tr>
                      @DspErrMsg(Err_WIKEYE)

                      @SetTextOvr(Err_WIBGRP)
