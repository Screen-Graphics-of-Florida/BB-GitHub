  @dtw_assign(firstTimeIn, "")

  @dtw_assign(edtVar, "")
  @Concat_Field("@@wfid", wfInstance)
  @Concat_Field("@@wfdt", wfInstanceDate)
  @Concat_Field("@@wfcn", wfWorkItem)
  @Concat_Field("@@wfsq", wfWorkItemSequence)
  @Concat_Field("@@wfpt", wfParticipantId)
  @Concat_Field("@@seq#", invoiceSequence)
  @Concat_Field("@@@upd", updateOption)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, errFound, edtVar, errVar, wrnVar)
  %if (errFound == "" && updateOption=="1U")
      %if (WFReview == "Y")
          @dtw_assign(firstTimeIn, "Y")
      %else
          @dtw_assign(firstTimeIn, "")
      %endif

      @RtvFldDesc("FFIMKY=$(wfInstance) and FFIFIL='$(importTable)'", "SYMITB", "FFDESC", importTableDescription)
      @Format_ConfMsg_Desc(maintenanceCode, $(importTableDescription), "$(importTable)-$(importRecordType)-$(interfaceTable)-$(parentInterfaceTable)", "", "", "", "", confMessage)
      %if (WFReview=="Y")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)WFWorkList.d2w/REPORT$(d2wVarBase)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
