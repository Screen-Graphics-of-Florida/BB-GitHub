      @dtw_concat(editVariables, " editNum(document.Chg.prFacility, 4, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.prEmployee, 5, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.hrCompany, 2, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.hrEmployee, 9, 0) && ", editVariables)
      @dtw_concat(editVariables, " editdate(document.Chg.applDate) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.applSeq, 4, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.orgLevel, 1, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.orgSeq, 5, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.homePhone, 10, 0) && ", editVariables)
      @dtw_concat(editVariables, " editdate(document.Chg.dateOfBirth) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.socSecNumber, 9, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.numberOfDependents, 2, 0) && ", editVariables)
      @dtw_concat(editVariables, " editdate(document.Chg.hireDate) && ", editVariables)
      @dtw_concat(editVariables, " editdate(document.Chg.startDate) && ", editVariables)
      @dtw_concat(editVariables, " editdate(document.Chg.seniorityDate) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.eeoCategory, 2, 3) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.standardAnnualHours, 4, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.schedule, 3, 0) && ", editVariables)
      @dtw_concat(editVariables, " editdate(document.Chg.terminationDate) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.plantNumber, 3, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.groupNumber, 5, 0) &&  ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.payFrequency, 1, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.payRate, 6, 5) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.amountCode, 1, 0) && ", editVariables)
      @dtw_concat(editVariables, " editdate(document.Chg.salChangeDate) && ", editVariables)
      @dtw_concat(editVariables, " editdate(document.Chg.accrualDate) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.accruedVacHours, 5, 2) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.availVacHours, 5, 2) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.accruedVacDol, 7, 2) && ", editVariables)
