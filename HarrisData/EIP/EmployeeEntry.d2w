                                          <td class="inputalph"><input name="qualPension" type="text" value="$(V_WIPEN)" size="1" maxlength="1">
                                                                <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=YORN&amp;flagSrchHdr=@dtw_rurlescseq("Covered By Qualified Pension")&amp;docName=Chg&amp;fldName=qualPension&amp;fldDesc=qualPensionDesc" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage)</a></td>
                                          <td class="inputalph"><input name="qualPensionDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                                      </tr>
                                      @DspErrMsg(Err_WIPEN)

                                      @RtvFldDesc("FLTYPE='EMPLOYMENT' and FLVALU='$(V_WIETYP)'", "SYFLAG", "FLDESC", fieldDesc)
                                      @SetTextOvr(Err_WIETYP)
                                      <tr><td class="dsphdr"><span $(textOvr)>Employment Type</span></td>
                                          <td class="inputalph"><input name="employmentType" type="text" value="$(V_WIETYP)" size="1" maxlength="1">
                                                                <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=EMPLOYMENT&amp;flagSrchHdr=@dtw_rurlescseq("Employment Type")&amp;docName=Chg&amp;fldName=employmentType&amp;fldDesc=employmentTypeDesc" onclick="$(searchWinVar)">$(searchImage)</a></td>
                                          <td class="inputalph"><input name="employmentTypeDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                                      </tr>
                                      @DspErrMsg(Err_WIETYP)

                                      @SetTextOvr(Err_WIINDS)
                                      <tr><td class="dsphdr"><span $(textOvr)>Occupation/Industry Code</span></td>
                                          <td class="inputnmbr"><input name="occIndCode" type="text" value="$(V_WIINDS)" size="6" maxlength="6"> </td>
                                          <td class="inputalph">&nbsp;</td>
                                      </tr>
                                      @DspErrMsg(Err_WIINDS)

                                      @SetTextOvr(Err_WIOPCD)
                                      <tr><td class="dsphdr"><span $(textOvr)>Area Classifications</span></td>
                                          <td class="inputalph"><input name="areaClass" type="text" value="$(V_WIOPCD)" size="2" maxlength="2"> </td>
                                          <td class="inputalph">&nbsp;</td>
                                      </tr>
                                      @DspErrMsg(Err_WIOPCD)

                                      @SetTextOvr(Err_WINQPC)
                                      <tr><td class="dsphdr"><span $(textOvr)>Nonqualified Plan Code</span></td>
                                          <td class="inputalph"><input name="nonQualPlan" type="text" value="$(V_WINQPC)" size="1" maxlength="1"> </td>
                                          <td class="inputalph">&nbsp;</td>
                                      </tr>
                                      @DspErrMsg(Err_WINQPC)

                                      @RtvFldDesc("FLTYPE='STATUTORY' and FLVALU='$(V_WISTEM)'", "SYFLAG", "FLDESC", fieldDesc)
                                      @SetTextOvr(Err_WISTEM)
                                      <tr><td class="dsphdr"><span $(textOvr)>Statutory Employee</span></td>
                                          <td class="inputalph"><input name="statutoryEmpl" type="text" value="$(V_WISTEM)" size="1" maxlength="1">
                                                                <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=STATUTORY&amp;flagSrchHdr=@dtw_rurlescseq("Statutory Employee")&amp;docName=Chg&amp;fldName=statutoryEmpl&amp;fldDesc=statutoryEmplDesc" onclick="$(searchWinVar)">$(searchImage)</a></td>
                                          <td class="inputalph"><input name="statutoryEmplDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                                      </tr>
                                      @DspErrMsg(Err_WISTEM)

                                      @RtvYNDesc($(V_WILGRP), fieldDesc)
                                      @SetTextOvr(Err_WILGRP)
                                      <tr><td class="dsphdr"><span $(textOvr)>Legal Representative</span></td>
                                          <td class="inputalph"><input name="legalRep" type="text" value="$(V_WILGRP)" size="1" maxlength="1">
                                                                <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=YORN&amp;flagSrchHdr=@dtw_rurlescseq("Legal Representative")&amp;docName=Chg&amp;fldName=legalRep&amp;fldDesc=legalRepDesc" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage)</a></td>
                                          <td class="inputalph"><input name="legalRepDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                                      </tr>
                                      @DspErrMsg(Err_WILGRP)

                                      @SetTextOvr(Err_WIPBCD)
                                      <tr><td class="dsphdr"><span $(textOvr)>Probationary Code</span></td>
                                          <td class="inputalph"><input name="probationCode" type="text" value="$(V_WIPBCD)" size="1" maxlength="1"> </td>
                                          <td class="inputalph">&nbsp;</td>
                                      </tr>
                                      @DspErrMsg(Err_WIPBCD)

                                      @SetTextOvr(Err_WIPBDT)
                    	               <tr><td class="dsphdr"><span $(textOvr)>Probationary Date</span></td>
                                          <td class="inputnmbr"><input type="text" name="probationDate" value="$(V_WIPBDT)" size="6" maxlength="6"> 		
                                                                <a href="javascript:calWindow('probationDate');"> $(calendarImage)</a></td>
                                          <td class="inputalph">&nbsp;</td>
                                      </tr>
                                      @DspErrMsg(Err_WIPBDT)

                                      @SetTextOvr(Err_WICNTY)
                                      <tr><td class="dsphdr"><span $(textOvr)>County Code</span></td>
                                          <td class="inputnmbr"><input name="countyCode" type="text" value="$(V_WICNTY)" size="3" maxlength="3"> </td>
                                          <td class="inputalph">&nbsp;</td>
                                      </tr>
                                      @DspErrMsg(Err_WICNTY)

                                      @SetTextOvr(Err_WIEHLT)
                                      <tr><td class="dsphdr"><span $(textOvr)>Employee Health Insurance Code</span></td>
                                          <td class="inputnmbr"><input name="emplHealthCode" type="text" value="$(V_WIEHLT)" size="1" maxlength="1"> </td>
                                          <td class="inputalph">&nbsp;</td>
                                      </tr>
                                      @DspErrMsg(Err_WIEHLT)

                                      @SetTextOvr(Err_WIRHLT)
                                      <tr><td class="dsphdr"><span $(textOvr)>Employer Health Insurance Code</span></td>
                                          <td class="inputnmbr"><input name="employerHealthCode" type="text" value="$(V_WIRHLT)" size="1" maxlength="1"> </td>
                                          <td class="inputalph">&nbsp;</td>
                                      </tr>
                                      @DspErrMsg(Err_WIRHLT)

                                      @SetTextOvr(Err_WIWGPC)
                                      <tr><td class="dsphdr"><span $(textOvr)>Wage Plan Code</span></td>
                                          <td class="inputalph"><input name="wagePlanCode" type="text" value="$(V_WIWGPC)" size="1" maxlength="1"> </td>
                                          <td class="inputalph">&nbsp;</td>
                                      </tr>
                                      @DspErrMsg(Err_WIWGPC)

                                      @SetTextOvr(Err_WISEAS)
                                      <tr><td class="dsphdr"><span $(textOvr)>Seasonal Indicator</span></td>
                                          <td class="inputalph"><input name="seasonalInd" type="text" value="$(V_WISEAS)" size="2" maxlength="2"> </td>
                                          <td class="inputalph">&nbsp;</td>
                                      </tr>
                                      @DspErrMsg(Err_WISEAS)

                                      @SetTextOvr(Err_WIUNIT)
                                      <tr><td class="dsphdr"><span $(textOvr)>Unit/Div/Loc/Plant</span></td>
                                          <td class="inputalph"><input name="unitDivLocPlant" type="text" value="$(V_WIUNIT)" size="15" maxlength="15"> </td>
                                          <td class="inputalph">&nbsp;</td>
                                      </tr>
                                      @DspErrMsg(Err_WIUNIT)

                                      @SetTextOvr(Err_WIDCDT)
                    	               <tr><td class="dsphdr"><span $(textOvr)>Date Deceased</span></td>
                                          <td class="inputnmbr"><input type="text" name="dateDeceased" value="$(V_WIDCDT)" size="6" maxlength="6"> 		
                                                                <a href="javascript:calWindow('dateDeceased');"> $(calendarImage)</a></td>
                                          <td class="inputalph">&nbsp;</td>
                                      </tr>
                                      @DspErrMsg(Err_WIDCDT)
                                  </table>
                              </fieldset>
                          </td>
                      </tr>
                  </table>
              </fieldset>
          %}

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      <table $(contentTable)>
          <tr>
              <td class="toolbar">
                  <a href="javascript:document.Chg.updateOption.value='1E'; check(document.Chg)">$(editNoUpdateSml)</a>
                  <a href="javascript:document.Chg.updateOption.value='1U'; check(document.Chg)">$(nextImage)</a>
                  <a onClick="return confirmRefresh()" href="$(refreshURL)">$(selectResetImage)</a>
                  %if (WFReview=="Y")
                      <a href="$(homeURL)$(cGIPath)WFWorkListOptions.d2w/CANCEL$(d2wVarBase)&amp;refreshD2W=N">$(cancelImageMed)</a>
                  %endif
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar,
                                        INOUT CHAR(32000) wrnVar)
{%EXEC {HHRMEM_W.PGM %}
%}

%FUNCTION(dtw_directcall) SetApprove_Data(IN    CHAR(64)    profileHandle,
                                                CHAR(2)     dataBaseID,
                                                CHAR(1)     approveCode,
                                                CHAR(32000) edtVar)
{%EXEC {HWFWIA_S.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(REFRESH) {
  %INCLUDE "setLibraryList.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Delete From HRIMEW Where WIXHND='$(profileHandle)'", stmtSQL)
  @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
  @SQL_Update(stmtSQL, status)

  @Set_SQL(stmtSQL)
%}

%HTML(WFREVIEW) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(firstTimeIn, "Y")

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Delete From HRIMEW Where WIXHND='$(profileHandle)'", stmtSQL)
  @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
  @SQL_Update(stmtSQL, status)

  @dtw_assign(setFlag, "Y")
  @dtw_assign(edtVar, "")
  @Concat_Field("@@inst", wfInstance)
  @Concat_Field("@@indt", wfInstanceDate)
  @Concat_Field("@@witm", wfWorkItem)
  @Concat_Field("@@wisq", wfWorkItemSequence)
  @Concat_Field("@@ptid", wfParticipantId)
  @dtw_concat(edtVar, "}{", edtVar)
  @SetApprove_Data(profileHandle, dataBaseID, setFlag, edtVar)

  @RtvFldDesc("ADINST=$(wfInstance) and ADINDT=$(wfInstanceDate)", "WFDTAA", "ADVAR", V_ADVAR)
  @dtw_assign(edtVar, V_ADVAR)
  @dtw_assign(WFReview, "Y")
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Insert Into HRIMEW (WIXHND,WIINST,       WIINDT,           WIWITM,       WIWISQ,                WICODE, WIPRAC, WICOMP, WIFACL, WIEMPL, WIPECP, WIPEMP, WIAPDT, WIAPSQ, WILEVL, WIOSEQ, WIRNAM, WILNAM, WIFNAM, WIMIDI, WIADR1, WIADR2, WICITY, WIST  , WIPROV, WIZIP , WICNTR, WIPHON, WILOC , WIDEPT, WIDOB , WISSNO, WISSSF, WIGNDR, WIMSTA, WINODP, WIHIRE, WISTRT, WISENR, WICTZN, WIALRG, WIJOB , WIEEO , WIUNCD, WIUNMN, WISHFT, WIANHR, WISCHD, WITRDT, WITRCD, WIPLNT, WIMDPT, WIWC  , WIHGRP, WIUSR1, WIUSR2, WIUSR3, WIUSR4, WIUSR5, WIUSR6, WITYPE, WIEXMT, WIFREQ, WIAMT , WISRCD, WIOVTM, WIHCE , WIOFCR, WIKEYE, WIBGRP, WISCRS, WIDLIN, WIVASC, WIMSAC, WIACDT, WIACVH, WIVHA , WIACVD, WIVDA , WIASH , WISHA , WIASD , WISDA , WIAMH , WIMHA , WIAMD , WIMDA , WIGNID, WIMGN , WIMCN , WIMVN , WITITL, WIETHN, WIOTID, WIHSRC, WIFASC, WISDEP, WISTAT, WIPENS, WILABC, WIMAIL, WIMILT, WIWCMP, WIWPHN, WIEXTN, WICLAS, WILVRE, WILVDT, WILVRT, WIRTEM, WIRVEM, WITEMP, WISBHR, WISCCL, WISCID, WISCDT, WISCEX, WIPARK, WILCST, WILCPL, WIHNDC, WIPHYS, WIPPHN, WIBLOD, WILBD , WICNME, WICADR, WICAD2, WIC1CT, WIC1ST, WIC1ZP, WICPHN, WIC2NM, WIC2A1, WIC2A2, WIC2CT, WIC2ST, WIC2ZP, WIC2PH, WIGRAD, WIDGRE, WISUBJ, WISCHL, WIPDPT, WIDPCD, WIPJOB, WIJBCD, WIPSTS, WISTCD, WIREHR, WIACCT, WISACT, WIXFIT, WIXFIC, WIEXSU, WIFWHS, WIDFDP, WIFDAP, WIFDAA, WICFTP, WIBFTP, WIEIC , WIGWGS, WIGPCT, WIEXST, WISTID, WISDC , WISTDP, WIPEC , WIAEC , WIEXAM, WITAXC, WICRC , WIADC , WISTAP, WISTAA, WICSTP, WIBSTP, WISUID, WIEXWC, WISWID, WIJBCL, WISDID, WILTX1, WILDP1, WILPE1, WILTX2, WILDP2, WILPE2, WIERES, WIPEN , WIETYP, WIINDS, WIOPCD, WINQPC, WISTEM, WILGRP, WIPBCD, WIPBDT, WICNTY, WIEHLT, WIRHLT, WIWGPC, WISEAS, WIUNIT, WIDCDT, WIW420, WISTP2, WICDAM, WIOTHI, WIDED ) ", stmtSQL)
  @dtw_concat(stmtSQL, " Select '$(profileHandle)', $(wfInstance),$(wfInstanceDate),$(wfWorkItem),$(wfWorkItemSequence), IECODE, IEPRAC, IECOMP, IEFACL, IEEMPL, IEPECP, IEPEMP, IEAPDT, IEAPSQ, IELEVL, IEOSEQ, IERNAM, IELNAM, IEFNAM, IEMIDI, IEADR1, IEADR2, IECITY, IEST  , IEPROV, IEZIP , IECNTR, IEPHON, IELOC , IEDEPT, IEDOB , IESSNO, IESSSF, IEGNDR, IEMSTA, IENODP, IEHIRE, IESTRT, IESENR, IECTZN, IEALRG, IEJOB , IEEEO , IEUNCD, IEUNMN, IESHFT, IEANHR, IESCHD, IETRDT, IETRCD, IEPLNT, IEMDPT, IEWC  , IEHGRP, IEUSR1, IEUSR2, IEUSR3, IEUSR4, IEUSR5, IEUSR6, IETYPE, IEEXMT, IEFREQ, IEAMT , IESRCD, IEOVTM, IEHCE , IEOFCR, IEKEYE, IEBGRP, IESCRS, IEDLIN, IEVASC, IEMSAC, IEACDT, IEACVH, IEVHA , IEACVD, IEVDA , IEASH , IESHA , IEASD , IESDA , IEAMH , IEMHA , IEAMD , IEMDA , IEGNID, IEMGN , IEMCN , IEMVN , IETITL, IEETHN, IEOTID, IEHSRC, IEFASC, IESDEP, IESTAT, IEPENS, IELABC, IEMAIL, IEMILT, IEWCMP, IEWPHN, IEEXTN, IECLAS, IELVRE, IELVDT, IELVRT, IERTEM, IERVEM, IETEMP, IESBHR, IESCCL, IESCID, IESCDT, IESCEX, IEPARK, IELCST, IELCPL, IEHNDC, IEPHYS, IEPPHN, IEBLOD, IELBD , IECNME, IECADR, IECAD2, IEC1CT, IEC1ST, IEC1ZP, IECPHN, IEC2NM, IEC2A1, IEC2A2, IEC2CT, IEC2ST, IEC2ZP, IEC2PH, IEGRAD, IEDGRE, IESUBJ, IESCHL, IEPDPT, IEDPCD, IEPJOB, IEJBCD, IEPSTS, IESTCD, IEREHR, IEACCT, IESACT, IEXFIT, IEXFIC, IEEXSU, IEFWHS, IEDFDP, IEFDAP, IEFDAA, IECFTP, IEBFTP, IEEIC , IEGWGS, IEGPCT, IEEXST, IESTID, IESDC , IESTDP, IEPEC , IEAEC , IEEXAM, IETAXC, IECRC , IEADC , IESTAP, IESTAA, IECSTP, IEBSTP, IESUID, IEEXWC, IESWID, IEJBCL, IESDID, IELTX1, IELDP1, IELPE1, IELTX2, IELDP2, IELPE2, IEERES, IEPEN , IEETYP, IEINDS, IEOPCD, IENQPC, IESTEM, IELGRP, IEPBCD, IEPBDT, IECNTY, IEEHLT, IERHLT, IEWGPC, IESEAS, IEUNIT, IEDCDT, IEW420, IESTP2, IECDAM, IEOTHI, IEDED ", stmtSQL)
  @dtw_concat(stmtSQL, " From HRIMEM Where IEINST=$(wfInstance) and IEINDT=$(wfInstanceDate) and IECLOS=' ' ", stmtSQL)
  @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
  @SQL_Update(stmtSQL, status)

  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  %if (updateOption=="")
      @dtw_assign(updateOption, "1E")
  %endif

  %if (firstTimeIn == "")
      @RtvFldDesc("WIXHND='$(profileHandle)' and WIINST=$(wfInstance) and WIINDT=$(wfInstanceDate) ", "HRIMEW", "char(count(*))", recCount)	

      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Delete From HRIMEW Where WIXHND='$(profileHandle)'", stmtSQL)
      @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)

      @dtw_assign(CODE, @dtw_rUPPERCASE(typeOfImport))
      @dtw_assign(PRAC, @dtw_rUPPERCASE(prActivityCode))
      @dtw_assign(COMP, @dtw_rstrip(prCompany))           %if (COMP=="")   @dtw_assign(COMP, "0")  %endif
      @dtw_assign(FACL, @dtw_rstrip(prFacility))          %if (FACL=="")   @dtw_assign(FACL, "0")  %endif
      @dtw_assign(EMPL, @dtw_rstrip(prEmployee))          %if (EMPL=="")   @dtw_assign(EMPL, "0")  %endif
      @dtw_assign(PECP, @dtw_rstrip(hrCompany))           %if (PECP=="")   @dtw_assign(PECP, "0")  %endif
      @dtw_assign(PEMP, @dtw_rstrip(hrEmployee))          %if (PEMP=="")   @dtw_assign(PEMP, "0")  %endif
      @dtw_assign(APDT, @dtw_rstrip(applDate))            %if (APDT=="")   @dtw_assign(APDT, "0")  %endif @DateToCYMD(APDT)
      @dtw_assign(APSQ, @dtw_rstrip(applSeq))             %if (APSQ=="")   @dtw_assign(APSQ, "0")  %endif
      @dtw_assign(LEVL, @dtw_rstrip(orgLevel))            %if (LEVL=="")   @dtw_assign(LEVL, "0")  %endif
      @dtw_assign(OSEQ, @dtw_rstrip(orgSeq))              %if (OSEQ=="")   @dtw_assign(OSEQ, "0")  %endif

      @dtw_assign(RNAM, reportName)
      @dtw_assign(LNAM, lastName)
      @dtw_assign(FNAM, firstName)
      @dtw_assign(MIDI, @dtw_rUPPERCASE(middleInitial))
      @dtw_assign(ADR1, addressOne)
      @dtw_assign(ADR2, addressTwo)
      @dtw_assign(CITY, city)
      @dtw_assign(ST  , @dtw_rUPPERCASE(state))
      @dtw_assign(PROV, @dtw_rUPPERCASE(canadianProvince))
      @dtw_assign(ZIP , @dtw_rUPPERCASE(zipCode))
      @dtw_assign(CNTR, @dtw_rUPPERCASE(country))
      @dtw_assign(PHON, @dtw_rstrip(homePhone))           %if (PHON=="")  @dtw_assign(PHON, "0") %endif
      @dtw_assign(LOC , @dtw_rUPPERCASE(location))
      @dtw_assign(DEPT, @dtw_rUPPERCASE(department))
      @dtw_assign(DOB , @dtw_rstrip(dateOfBirth))         %if (DOB=="")   @dtw_assign(DOB, "0")  %endif @DateToCYMD(DOB)
      @dtw_assign(SSNO, socSecNumber)                     %if (SSNO=="")  @dtw_assign(SSNO, "000000000") %endif 
      @dtw_assign(SSSF, @dtw_rUPPERCASE(socSecSuffix))
      @dtw_assign(GNDR, @dtw_rUPPERCASE(gender))
      @dtw_assign(MSTA, @dtw_rUPPERCASE(maritalStatus))
      @dtw_assign(NODP, @dtw_rstrip(numberOfDependents))  %if (NODP=="")  @dtw_assign(NODP, "0") %endif
      @dtw_assign(HIRE, @dtw_rstrip(hireDate))            %if (HIRE=="")  @dtw_assign(HIRE, "0") %endif @DateToCYMD(HIRE)
      @dtw_assign(STRT, @dtw_rstrip(startDate))           %if (STRT=="")  @dtw_assign(STRT, "0") %endif @DateToCYMD(STRT)
      @dtw_assign(SENR, @dtw_rstrip(seniorityDate))       %if (SENR=="")  @dtw_assign(SENR, "0") %endif @DateToCYMD(SENR)
      @dtw_assign(CTZN, @dtw_rUPPERCASE(citizen))
      @dtw_assign(ALRG, @dtw_rUPPERCASE(alienRegNumber))
      @dtw_assign(JOB , @dtw_rUPPERCASE(jobCode))
      @dtw_assign(EEO , @dtw_rstrip(eeoCategory))         %if (EEO=="")  @dtw_assign(EEO, "0") %endif
      @dtw_assign(UNCD, @dtw_rUPPERCASE(union))
      @dtw_assign(UNMN, @dtw_rUPPERCASE(unionMemNumber))
      @dtw_assign(SHFT, @dtw_rUPPERCASE(shift))
      @dtw_assign(ANHR, @dtw_rstrip(standardAnnualHours)) %if (ANHR=="")  @dtw_assign(ANHR, "0") %endif
      @dtw_assign(SCHD, @dtw_rstrip(schedule))            %if (SCHD=="")  @dtw_assign(SCHD, "0") %endif
      @dtw_assign(TRDT, @dtw_rstrip(terminationDate))     %if (TRDT=="")  @dtw_assign(TRDT, "0") %endif @DateToCYMD(TRDT)
      @dtw_assign(TRCD, @dtw_rUPPERCASE(terminationCode))
      @dtw_assign(PLNT, @dtw_rstrip(plantNumber))         %if (PLNT=="")  @dtw_assign(PLNT, "0") %endif
      @dtw_assign(MDPT, @dtw_rUPPERCASE(mfgDepartment))
