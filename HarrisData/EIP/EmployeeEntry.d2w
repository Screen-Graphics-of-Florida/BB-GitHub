                      @dtw_assign(deptwcDesc, "")
                      @RtvFldDesc("WCPLT=$(V_WIPLNT) and WCDEPT='$(V_WIMDPT)' and WCWC='$(V_WIWC)'", "HDMWCM", "WCDESC", fieldDesc)
                      @SetTextOvr(Err_WIMDPT)
