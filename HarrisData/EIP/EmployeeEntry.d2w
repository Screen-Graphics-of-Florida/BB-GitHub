                                                <input name="applSeq"  type="hidden" value="$(V_WIAPSQ)">$(V_WIAPSQ)
                          <td class="inputalph">$(fieldDesc)</td>
                      </tr>
                      @DspErrMsg(Err_WIAPDT)

