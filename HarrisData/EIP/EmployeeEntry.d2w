      @dtw_concat(editVariables, " editNum(document.Chg.accruedSickDol, 7, 2) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.availSickDol, 7, 2) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.accruedMiscHours, 5, 2) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.availMiscHours, 5, 2) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.accruedMiscDol, 7, 2) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.availMiscDol, 7, 2) &&  ", editVariables)
      @dtw_concat(editVariables, " editdate(document.Chg.COBRAGenNoticeDate) && ", editVariables)
