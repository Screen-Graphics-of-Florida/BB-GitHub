%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Labor Code Maintenance"
  d2wName                 = "LaborCodeMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;laborCode=@dtw_rurlescseq(laborCode)&amp;shortDesc=@dtw_rurlescseq(shortDesc)&amp;maintenanceCode=D"
  programName             = "HSI284"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.laborCode.value =="" ||
                      document.Chg.fullDesc1.value =="")
                         {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.accountNumber, 4, 0) &&
                      editNum(document.Chg.subaccountNumber, 4, 0))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "LABORCODEMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From SIMLRC Where LRLCOD = '$(laborCode)'", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=115")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "laborCode")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@lcod", "laborCode")        @dtw_assign(Err_LRLCOD, fieldValue)
                          @DecatErr_Field("@@ades", "shortDesc")        @dtw_assign(Err_LRADES, fieldValue)
                          @DecatErr_Field("@@des1", "fullDesc1")        @dtw_assign(Err_LRDES1, fieldValue)
                          @DecatErr_Field("@@des2", "fullDesc2")        @dtw_assign(Err_LRDES2, fieldValue)
                          @DecatErr_Field("@@maj@", "accountNumber")    @dtw_assign(Err_LRMAJ, fieldValue)
                          @DecatErr_Field("@@sub@", "subaccountNumber") @dtw_assign(Err_LRSUB, fieldValue)
                      %endif

                      @Decat_Field("@@lcod")   @dtw_assign(V_LRLCOD,  fieldValue)
                      @Decat_Field("@@ades")   @dtw_assign(V_LRADES, fieldValue)
                      @Decat_Field("@@des1")   @dtw_assign(V_LRDES1, fieldValue)
                      @Decat_Field("@@des2")   @dtw_assign(V_LRDES2, fieldValue)
                      @Decat_Field("@@maj@")   @dtw_assign(V_LRMAJ, fieldValue)
                      @Decat_Field("@@sub@")   @dtw_assign(V_LRSUB, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "laborCode")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_LRLCOD,  "")
                      @dtw_assign(focusField, "laborCode")
                  %else
                      @dtw_assign(focusField, "shortDesc")
                  %endif

                  @SetTextOvr(Err_LRLCOD)
                  <tr><td class="dsphdr"><span $(textOvr)>Labor Code</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="laborCode" type="text" value="$(V_LRLCOD)" size="2" maxlength="2"> $(reqFieldChar) </td>
                      %else
                          <td class="inputalph"><input name="laborCode" type="hidden" value="$(V_LRLCOD)" size="2" maxlength="2">$(V_LRLCOD)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_LRLCOD)

                  @SetTextOvr(Err_LRADES)
                  <tr><td class="dsphdr"><span $(textOvr)>Short Description</span></td>
                      <td class="inputalph"><input name="shortDesc" type="text" value="$(V_LRADES)" size="30" maxlength="16"> </td>
                  </tr>
                  @DspErrMsg(Err_LRADES)
	   		
                  @SetTextOvr(Err_LRDES1)
                  <tr><td class="dsphdr"><span $(textOvr)>Full Description 1</span></td>
                      <td class="inputalph"><input name="fullDesc1" type="text" value="$(V_LRDES1)" size="30" maxlength="22"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_LRDES1)
	   		
                  @SetTextOvr(Err_LRDES2)
                  <tr><td class="dsphdr"><span $(textOvr)>Full Description 2</span></td>
                      <td class="inputalph"><input name="fullDesc2" type="text" value="$(V_LRDES2)" size="30" maxlength="22"> </td>
                  </tr>
                  @DspErrMsg(Err_LRDES2)
	   		
                  @Default_Zero(V_LRMAJ)
                  @Default_Zero(V_LRSUB)
                  @RtvFldDesc("CHACCT=$(V_LRMAJ) and CHSUB=$(V_LRSUB) ", "HDCHRT", "CHCHDS", acctDesc)
                  @SetTextOvr(Err_LRMAJ)
                  <tr><td class="dsphdr"><span $(textOvr)>Account</span></td>
                      <td class="inputnmbr"><input name="accountNumber" value="$(V_LRMAJ)" type="text" size="4" maxlength="4"> - <input name="subaccountNumber" value="$(V_LRSUB)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=accountNumber&amp;subFld=subaccountNumber&amp;descFld=acctDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="acctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_LRMAJ)
              %}
          </table>
	
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSI284_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(laborCode)
  @dtw_mUPPERCASE(shortDesc)
  @dtw_assign(accountNumber,@dtw_rstrip(accountNumber))
  @dtw_assign(subaccountNumber,@dtw_rstrip(subaccountNumber))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@lcod", laborCode)
  @Concat_Field("@@ades", shortDesc)
  @Concat_Field("@@des1", fullDesc1)
  @Concat_Field("@@des2", fullDesc2)
  @Concat_Field("@@maj@", accountNumber)
  @Concat_Field("@@sub@", subaccountNumber)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(shortDesc), $(laborCode), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@lcod", "laborCode")
          @Format_ConfMsg_Desc("", $(shortDesc), $(laborCode), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=115&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;laborCode=@dtw_rurlescseq(laborCode)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}