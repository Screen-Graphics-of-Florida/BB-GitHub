%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Delegated Participant"
  d2wName                 = "WFDelegate.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HWFDLM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  noMsg                   = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "WFDELEGATE")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select WFDELG.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(a.USDESC,' ') as partUSDESC, ifnull(a.USDESCU,' ') as partUSDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(b.USDESC,' ') as delgUSDESC, ifnull(b.USDESCU,' ') as delgUSDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(PRDESC,' ') as PRDESC,ifnull(PRDESCU,' ') as PRDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(PDDESC,' ') as PDDESC,ifnull(PDDESCU,' ') as PDDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " WFDELG ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYUSER a on a.USUSER=DLPART", fileSQL)
                      @dtw_concat(fileSQL, " left join SYUSER b on b.USUSER=DLDPRT", fileSQL)
                      @dtw_concat(fileSQL, " left join WFPRHD on PRPROC=DLPROC", fileSQL)
                      @dtw_concat(fileSQL, " left join WFPRDT on PDPROC=DLPROC and PDPONT=DLPONT and PDSEQ=DLSEQ ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, " DLPART>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (backHome != "$(d2wName)/report" && backHome != "")
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)WFDelegateMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint == "")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Participant</th>
                      <th class="colhdr">Delegated Participant</th>
                      <th class="colhdr">Process</th>
                      <th class="colhdr">Detail Point</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchParticipant" size="15" maxlength="30">
                          <input type="hidden" name="operParticipant" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchDelegate" size="15" maxlength="30">
                          <input type="hidden" name="operDelegate" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchProcess" size="15" maxlength="50">
                          <input type="hidden" name="operProcess" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchPoint" size="15" maxlength="50">
                          <input type="hidden" name="operPoint" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchParticipant.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("partUSDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Participant"  title="Sequence By Participant, Effective From Date, Effective From Time">Participant</a></th>
              @OrderBy_Sort("DLERPT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Repeat"  title="Sequence By Repeat Every Day, Participant, Delegated Participant">Repeat Every Day</a></th>
              @OrderBy_Sort("DLFDAT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FromDate"  title="Sequence By Effective From Date, Effective From Time, Participant, Delegated Participant">Effective From Date</a></th>
              @OrderBy_Sort("DLFTIM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FromTime"  title="Sequence By Effective From Time, Effective From Date, Participant, Delegated Participant">Effective From Time</a></th>
              @OrderBy_Sort("DLTDAT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ToDate"  title="Sequence By Effective To Date, Participant, Delegated Participant">Effective To Date</a></th>
              @OrderBy_Sort("DLTTIM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ToTime"  title="Sequence By Effective To Time, Effective To Date, Participant, Delegated Participant">Effective To Time</a></th>
              @OrderBy_Sort("delgUSDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Delegate"    title="Sequence By Delegated Participant, Effective From Date">Delegated Participant</a></th>
              @OrderBy_Sort("PRDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Process"  title="Sequence By Process, Detail Point">Process</a></th>
              @OrderBy_Sort("PDDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Point"  title="Sequence By Point, Process">Detail Point</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %if (V_DLPROC=="")
                  @dtw_assign(F_PRDESC, "All")
              %else
                  @dtw_assign(F_PRDESC, V_PRDESC)
              %endif
              %if (V_DLPONT>"0")
                  @dtw_assign(F_PDDESC, V_PDDESC)
              %else
                  @dtw_assign(F_PDDESC, "All")
              %endif
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;wfParticipant=@dtw_rurlescseq(V_DLPART)&amp;wfDelegationId=@dtw_rurlescseq(V_DLDLID)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;updRecNbr=@dtw_rurlescseq(START_ROW_NUM)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_partUSDESC), $(V_delgUSDESC), "", "", "", "", confirmDesc)

              @Format_Date(V_DLFDAT, "D", F_DLFDAT)
              @Format_Date(V_DLTDAT, "D", F_DLTDAT)
              %if (V_DLFTIM>"0")
                  %while(@dtw_rlength( V_DLFTIM) != "4") {@dtw_insert("0",  V_DLFTIM,  V_DLFTIM)%}
                  @dtw_insert(":", V_DLFTIM, "2", F_DLFTIM)
              %else
                  @dtw_assign(F_DLFTIM, "")
              %endif
              %if (V_DLTTIM>"0")
                  %while(@dtw_rlength( V_DLTTIM) != "4") {@dtw_insert("0",  V_DLTTIM,  V_DLTTIM)%}
                  @dtw_insert(":", V_DLTTIM, "2", F_DLTTIM)
              %else
                  @dtw_assign(F_DLTTIM, "")
              %endif

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)WFDelegateMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_04 == "Y")
                              <a href="$(homeURL)$(cGIPath)WFDelegateMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)WFDelegateMaintain.d2w/EDIT_DATA$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph" $(helpCursor)><span title="$(V_DLPART)">$(V_partUSDESC)</span></td>                                      	
                  <td class="colcode">$(V_DLERPT)</td>                                      	
                  <td class="colnmbr">$(F_DLFDAT)</td>                                      	
                  <td class="colcode">$(F_DLFTIM)</td>                                      	
                  <td class="colnmbr">$(F_DLTDAT)</td>                                      	
                  <td class="colcode">$(F_DLTTIM)</td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_DLDPRT)">$(V_delgUSDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_DLPROC)">$(F_PRDESC)</span></td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_DLPONT)-$(V_DLSEQ)">$(F_PDDESC)</span></td>                                      	
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select WFDELG,*, ", stmtSQL)
  @dtw_concat(stmtSQL, " ifnull(a.USDESC,' ') as partUSDESC, ifnull(a.USDESCU,' ') as partUSDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " ifnull(b.USDESC,' ') as delgUSDESC, ifnull(b.USDESCU,' ') as delgUSDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " ifnull(PRDESC,' ') as PRDESC,ifnull(PRDESCU,' ') as PRDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " ifnull(PDDESC,' ') as PDDESC,ifnull(PDDESCU,' ') as PDDESCU ", stmtSQL)
  @dtw_concat(fileSQL, " WFDELG ", fileSQL)
  @dtw_concat(fileSQL, " left join SYUSER a on a.USUSER=DLPART", fileSQL)
  @dtw_concat(fileSQL, " left join SYUSER b on b.USUSER=DLDPRT", fileSQL)
  @dtw_concat(fileSQL, " left join WFPRHD on PRPROC=DLPROC", fileSQL)
  @dtw_concat(fileSQL, " left join WFPRDT on PDPROC=DLPROC and PDPONT=DLPONT and PDSEQ=DLSEQ ", fileSQL)
  %if (wildCardSearch!="")
      @dtw_concat(selectSQL, " DLPART>' ' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_XMLQuery (IN  CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("WFDelegatedParticipantList")
          %ROW{
              @XMLIDTag("$(V_DLPART)-$(V_DLDLID)", "DelegatedParticipant ID")
                  @XMLTag(V_DLPART, "Participant")
                  @XMLTag(V_DLDLID, "DelegationId")
                  @XMLTag(V_DLDPRT, "DelegatedParticipant")
                  @XMLTag(V_DLERPT, "RepeatEveryDay")
                  @XMLTag(V_DLFDAT, "EffectiveFromDate")
                  @XMLTag(V_DLFTIM, "EffectiveFromTime")
                  @XMLTag(V_DLTDAT, "EffectiveToDate")
                  @XMLTag(V_DLTTIM, "EffectiveToTime")
                  @XMLTag(V_DLPROC, "Process")
                  @XMLTag(V_DLPONT, "Point")
                  @XMLTag(V_DLSEQ,  "Sequence")
              @XMLEndTag("DelegatedParticipant")
          %}
      @XMLEndTag("WFDelegatedParticipantList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "partUSDESCU,DLFDAT,DLFTIM")
          @DTW_ASSIGN(orderByDisplay, "Participant, Effective From Date, Effective From Time")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %if (updRecNbr > "0")
      @dtw_assign(START_ROW_NUM, updRecNbr)
      @dtw_assign(updRecNbr, "")
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Participant")
      %if (orderBy == "partUSDESCU,DLFDAT,DLFTIM")
          @DTW_ASSIGN(orderBy, "partUSDESCU DESC,DLFDAT,DLFTIM")
          @DTW_ASSIGN(orderByDisplay, "Participant (descending), Effective From Date, Effective From Time")
      %else
          @DTW_ASSIGN(orderBy, "partUSDESCU,DLFDAT,DLFTIM")
          @DTW_ASSIGN(orderByDisplay, "Participant, Effective From Date, Effective From Time")
      %endif
 %elseif (sequence == "Repeat")
      %if (orderBy == "DLERPT,partUSDESCU,delgUSDESCU")
          @DTW_ASSIGN(orderBy, "DLERPT DESC,partUSDESCU,delgUSDESCU")
          @DTW_ASSIGN(orderByDisplay, "Repeat Every Day (descending), Participant, Delegated Participant")
      %else
          @DTW_ASSIGN(orderBy, "DLERPT,partUSDESCU,delgUSDESCU")
          @DTW_ASSIGN(orderByDisplay, "Repeat Every Day, Participant, Delegated Participant")
      %endif
 %elseif (sequence == "FromDate")
      %if (orderBy == "DLFDAT,DLFTIM,partUSDESCU,delgUSDESCU")
          @DTW_ASSIGN(orderBy, "DLFDAT DESC,DLFTIM DESC,partUSDESCU,delgUSDESCU")
          @DTW_ASSIGN(orderByDisplay, "Effective From Date (descending), Effective From Time (descending), Participant, Delegated Participant")
      %else
          @DTW_ASSIGN(orderBy, "DLFDAT,DLFTIM,partUSDESCU,delgUSDESCU")
          @DTW_ASSIGN(orderByDisplay, "Effective From Date, Effective From Time, Participant, Delegated Participant")
      %endif
 %elseif (sequence == "FromTime")
      %if (orderBy == "DLFTIM,DLFDAT,partUSDESCU,delgUSDESCU")
          @DTW_ASSIGN(orderBy, "DLFTIM DESC,DLFDAT DESC,partUSDESCU,delgUSDESCU")
          @DTW_ASSIGN(orderByDisplay, "Effective From Time, Effective From Date (descending), Participant, Delegated Participant")
      %else
          @DTW_ASSIGN(orderBy, "DLFTIM,DLFDAT,partUSDESCU,delgUSDESCU")
          @DTW_ASSIGN(orderByDisplay, "Effective From Time, Effective From Date, Participant, Delegated Participant")
      %endif
 %elseif (sequence == "ToDate")
      %if (orderBy == "DLTDAT,DLTTIM,partUSDESCU,delgUSDESCU")
          @DTW_ASSIGN(orderBy, "DLTDAT DESC,DLTTIM DESC,partUSDESCU,delgUSDESCU")
          @DTW_ASSIGN(orderByDisplay, "Effective To Date (descending), Effective To Time (descending), Participant, Delegated Participant")
      %else
          @DTW_ASSIGN(orderBy, "DLTDAT,DLTTIM,partUSDESCU,delgUSDESCU")
          @DTW_ASSIGN(orderByDisplay, "Effective To Date, Effective To Time, Participant, Delegated Participant")
      %endif
 %elseif (sequence == "ToTime")
      %if (orderBy == "DLTTIM,DLTDAT,partUSDESCU,delgUSDESCU")
          @DTW_ASSIGN(orderBy, "DLTTIM DESC,DLTDAT DESC,partUSDESCU,delgUSDESCU")
          @DTW_ASSIGN(orderByDisplay, "Effective To Time (descending), Effective To Date (descending), Participant, Delegated Participant")
      %else
          @DTW_ASSIGN(orderBy, "DLTTIM,DLTDAT,partUSDESCU,delgUSDESCU")
          @DTW_ASSIGN(orderByDisplay, "Effective To Time, Effective To Date, Participant, Delegated Participant")
      %endif
 %elseif (sequence == "Delegate")
      %if (orderBy == "delgUSDESCU,DLFDAT,DLFTIM")
          @DTW_ASSIGN(orderBy, "delgUSDESCU DESC,DLFDAT,DLFTIM")
          @DTW_ASSIGN(orderByDisplay, "Delegated Participant (descending), Effective From Date, Effective From Time")
      %else
          @DTW_ASSIGN(orderBy, "delgUSDESCU,DLFDAT,DLFTIM")
          @DTW_ASSIGN(orderByDisplay, "Delegated Participant, Effective From Date, Effective From Time")
      %endif
  %elseif (sequence == "Process")
      %if (orderBy == "PRDESCU,PDDESCU,partUSDESCU")
          @DTW_ASSIGN(orderBy, "PRDESCU DESC,PDDESCU,partUSDESCU")
          @DTW_ASSIGN(orderByDisplay, "Process (descending), Point, Participant")
      %else
          @DTW_ASSIGN(orderBy, "PRDESCU,PDDESCU,partUSDESCU")
          @DTW_ASSIGN(orderByDisplay, "Process, Point, Participant")
      %endif
  %elseif (sequence == "Point")
      %if (orderBy == "PDDESCU,PRDESCU,partUSDESCU")
          @DTW_ASSIGN(orderBy, "PDDESCU DESC,PRDESCU,partUSDESCU")
          @DTW_ASSIGN(orderByDisplay, "Point (descending), Process, Participant")
      %else
          @DTW_ASSIGN(orderBy, "PDDESCU,PRDESCU,partUSDESCU")
          @DTW_ASSIGN(orderByDisplay, "Point, Process, Participant")
      %endif
  %endif
	
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "TimeEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editdate(document.Search.srchFromDate) &&
                      editTimeHM(document.Search.srchFromTime) &&
                      editdate(document.Search.srchToDate) &&
                      editTimeHM(document.Search.srchToTime))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFDELEGATESEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Participant</td>
                              @dtw_assign(operNbr, "operParticipant")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchParticipant" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Repeat Every Day</td>
                              @dtw_assign(operNbr, "operRepeat")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchRepeat" size="1" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Effective From Date</td>
                              @dtw_assign(operNbr, "operFromDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchFromDate" size="6" maxlength="6"><a href="javascript:calWindow('srchFromDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Effective From Time</td>
                              @dtw_assign(operNbr, "operFromTime")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchFromTime" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Effective To Date</td>
                              @dtw_assign(operNbr, "operToDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchToDate" size="6" maxlength="6"><a href="javascript:calWindow('srchToDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Effective To Time</td>
                              @dtw_assign(operNbr, "operToTime")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchToTime" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Delegated Participant</td>
                              @dtw_assign(operNbr, "operDelegate")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDelegate" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Process</td>
                              @dtw_assign(operNbr, "operProcess")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchProcess" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Detail Point</td>
                              @dtw_assign(operNbr, "operPoint")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchPoint" size="15" maxlength="50"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchParticipant.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("a.USDESCU",  "Participant", $(srchParticipant), "U", operParticipant, "A")
  @Build_WildCard ("DLERPT",  "Repeat Every Day", $(srchRepeat), "U", operRepeat, "A")
  @Build_WildCard ("DLFDAT",  "Effective From Date", $(srchFromDate), "", operFromDate, "D")
  @Build_WildCard ("DLFTIM",  "Effective From Time", $(srchFromTime), "", operFromTime, "N")
  @Build_WildCard ("DLTDAT",  "Effective To Date", $(srchToDate), "", operToDate, "D")
  @Build_WildCard ("DLTTIM",  "Effective To Time", $(srchToTime), "", operToTime, "N")
  @Build_WildCard ("b.USDESCU",  "Delegated Participant", $(srchDelegate), "U", operDelegate, "A")
  @Build_WildCard ("IFNULL(PRDESCU,'ALL')",  "Process", $(srchProcess), "U", operProcess, "A")
  @Build_WildCard ("IFNULL(PDDESCU,'ALL')",  "Detail Point", $(srchPoint), "U", operPoint, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}