%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "ItemPlantMaintain.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Item/Plant Maintenance"
  d2wName                 = "ItemPlantMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromItemNumber=@dtw_rurlescseq(fromItemNumber)&amp;fromPlant=@dtw_rurlescseq(fromPlant)&amp;fromSel=@dtw_rurlescseq(fromSel)&amp;noMenu=@dtw_rurlescseq(noMenu)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;maintenanceCode=D"
  programName             = "HHDIPU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  itemDescription         = ""
  plantName               = ""
  screenNumeric1          = ""
  screenNumeric2          = ""
  screenNumeric3          = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %if (userPass == "Y")
      @ItemUserView(profileHandle, dataBaseID, userPass, itemNumber)
  %endif
  %if (userPass == "Y")
      @ItemPlantUserView(profileHandle, dataBaseID, userPass, plantNumber, itemNumber)
  %endif
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              @dtw_assign(title, @dtw_rconcat(itemNumber, @dtw_rconcat(" ", @dtw_rconcat(itemDescription, @dtw_rconcat(" ", @dtw_rconcat(plantNumber, @dtw_rconcat(" ", plantName)))))))
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")

              @dtw_assign(editFields, "")
              %if (screenNumeric1 != "")		
                  @dtw_concat(editFields, " editNum(document.Chg.numeric01, 8, 5) && ", editFields)
              %endif
              %if (screenNumeric2 != "")		
                  @dtw_concat(editFields, " editNum(document.Chg.numeric02, 8, 5) && ", editFields)
              %endif
              %if (screenNumeric3 != "")		
                  @dtw_concat(editFields, " editNum(document.Chg.numeric03, 8, 5) && ", editFields)
              %endif

              <script TYPE="text/javascript">
                  %INCLUDE "dateedit.icl"
                  %INCLUDE "Menu.js"
                  %INCLUDE "numedit.icl"
                  %INCLUDE "numzero.icl"
                  %INCLUDE "calendar.icl"
                  %INCLUDE "CheckEnterChg.icl"
                  function validate(chgForm) {
                      if (document.Chg.partType.value =="" ||
                          document.Chg.kanbanFlow.value =="" ||
                          document.Chg.leadTimeCode.value =="" ||
                          document.Chg.accountLotSize.value =="" ||
                          document.Chg.checkCompAvail.value =="" ||
                          document.Chg.orderPolicy.value =="" ||
                          document.Chg.mrpCalcCode.value =="")
                          {alert("$(reqFieldError)"); return false;}
                      if (editNum(document.Chg.safetyLeadTime, 3, 0) &&
                          editNum(document.Chg.fixedLeadTime, 4, 1) &&
                          editNum(document.Chg.fixedTimePeriods, 2, 0) &&
                          editNum(document.Chg.orderShrinkagePct, 3, 0) &&
                          editNum(document.Chg.analyst, 7, 0) &&
                          editNum(document.Chg.vendor, 7, 0) &&
                          editZero(document.Chg.accountLotSize, 11, 0) &&
                          editNum(document.Chg.accountLotSize, 11, 0) &&
                          editNum(document.Chg.fixedOrderQty, 11, 0) &&
                          editNum(document.Chg.minimumOrderQty, 11, 0) &&
                          editNum(document.Chg.maximumOrderQty, 11, 0) &&
                          editNum(document.Chg.multipleOrderQty, 11, 0) &&
                          editNum(document.Chg.safetyStockQty, 11, 0) &&
                          editNum(document.Chg.featureFactorRate, 2, 3) &&
                          editNum(document.Chg.standardCost, 6, 5) &&
                          editNum(document.Chg.currentCost, 6, 5) &&
                          editNum(document.Chg.futureCost, 6, 5) &&
                          editdate(document.Chg.drawingDate) &&
                          editdate(document.Chg.ecnDate) &&
                          editNum(document.Chg.overrideCycleDays, 3, 0) &&
                          $(editFields)
                          editNum(document.Chg.anticAnnualUsage, 9, 4) &&
                          editNum(document.Chg.retainForecast, 1, 0) &&
                          editNum(document.Chg.consumeForecast, 1, 0))
                          return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "" && noMenu !="Y")
                          @dtw_assign(pageID, "ITEMPLANTMAINTAIN")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                              @dtw_concat(fileSQL, " HDIPLT ", fileSQL)
                              @dtw_concat(selectSQL, " IPPLT=$(fromPlant) and IPITEM='$(fromItemNumber)'", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN  CHAR(64) profileHandle,
                                       CHAR(2)   dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=227")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMPTYP", itemPartType)
          @Format_Header("Item", $(itemDescription), $(itemNumber))
          @Format_Header("Plant", $(plantName), $(plantNumber))
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (itemPartType != "B" && itemPartType != "S")
                      @dtw_assign(focusField, "partType")
                  %else
                      @dtw_assign(focusField, "backflush")
                  %endif

                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                      %else
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @dtw_assign(focusField, "")
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@plt@", "plantNumber")       @dtw_assign(Err_IPPLT,  fieldValue)
                          @DecatErr_Field("@@item", "itemNumber")        @dtw_assign(Err_IPITEM,  fieldValue)
                          @DecatErr_Field("@@ptyp", "partType")          @dtw_assign(Err_IPPTYP,  fieldValue)
                          @DecatErr_Field("@@stwc", "backflush")         @dtw_assign(Err_IPSTWC,  fieldValue)
                          @DecatErr_Field("@@kdfc", "kanbanFlow")        @dtw_assign(Err_IPKDFC,  fieldValue)
                          @DecatErr_Field("@@matc", "materialCode")      @dtw_assign(Err_IPMATC,  fieldValue)
                          @DecatErr_Field("@@clas", "partClass")         @dtw_assign(Err_IPCLAS,  fieldValue)
                          @DecatErr_Field("@@itc@", "inventoryType")     @dtw_assign(Err_IPITC,  fieldValue)
                          @DecatErr_Field("@@ltc@", "leadTimeCode")      @dtw_assign(Err_IPLTC,  fieldValue)
                          @DecatErr_Field("@@slt@", "safetyLeadTime")    @dtw_assign(Err_IPSLT,  fieldValue)
                          @DecatErr_Field("@@tlt@", "fixedLeadTime")     @dtw_assign(Err_IPTLT,  fieldValue)
                          @DecatErr_Field("@@ssq@", "safetyStockQty")    @dtw_assign(Err_IPSSQ,  fieldValue)
                          @DecatErr_Field("@@alts", "accountLotSize")    @dtw_assign(Err_IPALTS,  fieldValue)
                          @DecatErr_Field("@@seg1", "smartPartSeg1")     @dtw_assign(Err_IPSEG1,  fieldValue)
                          @DecatErr_Field("@@spc1", "smartPartCod1")     @dtw_assign(Err_IPSPC1,  fieldValue)
                          @DecatErr_Field("@@seg2", "smartPartSeg2")     @dtw_assign(Err_IPSEG2,  fieldValue)
                          @DecatErr_Field("@@spc2", "smartPartCod2")     @dtw_assign(Err_IPSPC2,  fieldValue)
                          @DecatErr_Field("@@seg3", "smartPartSeg3")     @dtw_assign(Err_IPSEG3,  fieldValue)
                          @DecatErr_Field("@@spc3", "smartPartCod3")     @dtw_assign(Err_IPSPC3,  fieldValue)
                          @DecatErr_Field("@@seg4", "smartPartSeg4")     @dtw_assign(Err_IPSEG4,  fieldValue)
                          @DecatErr_Field("@@spc4", "smartPartCod4")     @dtw_assign(Err_IPSPC4,  fieldValue)
                          @DecatErr_Field("@@seg5", "smartPartSeg5")     @dtw_assign(Err_IPSEG5,  fieldValue)
                          @DecatErr_Field("@@spc5", "smartPartCod5")     @dtw_assign(Err_IPSPC5,  fieldValue)
                          @DecatErr_Field("@@fort", "featureFactorRate") @dtw_assign(Err_IPFORT,  fieldValue)
                          @DecatErr_Field("@@bac@", "analyst")           @dtw_assign(Err_IPBAC,  fieldValue)
                          @DecatErr_Field("@@avlc", "checkCompAvail")    @dtw_assign(Err_IPAVLC,  fieldValue)
                          @DecatErr_Field("@@opc@", "orderPolicy")       @dtw_assign(Err_IPOPC,  fieldValue)
                          @DecatErr_Field("@@calc", "mrpCalcCode")       @dtw_assign(Err_IPCALC,  fieldValue)
                          @DecatErr_Field("@@msff", "scheduleForecast")  @dtw_assign(Err_IPMSFF,  fieldValue)
                          @DecatErr_Field("@@dmdc", "demandCode")        @dtw_assign(Err_IPDMDC,  fieldValue)
                          @DecatErr_Field("@@fixp", "fixedTimePeriods")  @dtw_assign(Err_IPFIXP,  fieldValue)
                          @DecatErr_Field("@@shrp", "orderShrinkagePct") @dtw_assign(Err_IPSHRP,  fieldValue)
                          @DecatErr_Field("@@foq@", "fixedOrderQty")     @dtw_assign(Err_IPFOQ,  fieldValue)
                          @DecatErr_Field("@@mnq@", "minimumOrderQty")   @dtw_assign(Err_IPMNQ,  fieldValue)
                          @DecatErr_Field("@@mxq@", "maximumOrderQty")   @dtw_assign(Err_IPMXQ,  fieldValue)
                          @DecatErr_Field("@@muq@", "multipleOrderQty")  @dtw_assign(Err_IPMUQ,  fieldValue)
                          @DecatErr_Field("@@fdtf", "forecastDateFormat") @dtw_assign(Err_IPFDTF, fieldValue)
                          @DecatErr_Field("@@fspr", "forecastSpreaders") @dtw_assign(Err_IPFSPR, fieldValue)
                          @DecatErr_Field("@@tfnd", "timeFenceDef")      @dtw_assign(Err_IPTFND, fieldValue)
                          @DecatErr_Field("@@pfct", "retainForecast")    @dtw_assign(Err_IPPFCT, fieldValue)
                          @DecatErr_Field("@@cfct", "consumeForecast")   @dtw_assign(Err_IPCFCT, fieldValue)
                          @DecatErr_Field("@@rrtg", "resourceRtgDef")    @dtw_assign(Err_IPRRTG, fieldValue)
                          @DecatErr_Field("@@dwgs", "drawingSize")       @dtw_assign(Err_IPDWGS,  fieldValue)
                          @DecatErr_Field("@@dwgr", "drawingRevisionLetter") @dtw_assign(Err_IPDWGR,  fieldValue)
                          @DecatErr_Field("@@dwgd", "drawingDate")       @dtw_assign(Err_IPDWGD,  fieldValue)
                          @DecatErr_Field("@@dwgn", "drawingNumber")     @dtw_assign(Err_IPDWGN,  fieldValue)
                          @DecatErr_Field("@@ecn@", "engineerChange")    @dtw_assign(Err_IPECN,  fieldValue)
                          @DecatErr_Field("@@eftd", "ecnDate")           @dtw_assign(Err_IPEFTD,  fieldValue)
                          @DecatErr_Field("@@ecdp", "ecnComponentDisp")  @dtw_assign(Err_IPECDP,  fieldValue)
                          @DecatErr_Field("@@estc", "engineerStatus")    @dtw_assign(Err_IPESTC,  fieldValue)
                          @DecatErr_Field("@@vend", "vendor")            @dtw_assign(Err_IPVEND,  fieldValue)
                          @DecatErr_Field("@@psum", "standardCost")      @dtw_assign(Err_IPPSUM,  fieldValue)
                          @DecatErr_Field("@@pcum", "currentCost")       @dtw_assign(Err_IPPCUM,  fieldValue)
                          @DecatErr_Field("@@nyps", "futureCost")        @dtw_assign(Err_IPNYPS,  fieldValue)
                          @DecatErr_Field("@@abcc", "abcClass")          @dtw_assign(Err_IPABCC,  fieldValue)
                          @DecatErr_Field("@@abco", "abcOverride")       @dtw_assign(Err_IPABCO,  fieldValue)
                          @DecatErr_Field("@@onc@", "overrideCycleDays") @dtw_assign(Err_IPONC,  fieldValue)
                          @DecatErr_Field("@@aau@", "anticAnnualUsage")  @dtw_assign(Err_IPAAU,  fieldValue)
                          @DecatErr_Field("@@uda1", "alpha01")           @dtw_assign(Err_IPUDA1,  fieldValue)
                          @DecatErr_Field("@@uda2", "alpha02")           @dtw_assign(Err_IPUDA2,  fieldValue)
                          @DecatErr_Field("@@uda3", "alpha03")           @dtw_assign(Err_IPUDA3,  fieldValue)
                          @DecatErr_Field("@@udn1", "numeric01")         @dtw_assign(Err_IPUDN1,  fieldValue)
                          @DecatErr_Field("@@udn2", "numeric02")         @dtw_assign(Err_IPUDN2,  fieldValue)
                          @DecatErr_Field("@@udn3", "numeric03")         @dtw_assign(Err_IPUDN3,  fieldValue)
                      %endif

                      @Decat_Field("@@plt@")   @dtw_assign(V_IPPLT,  fieldValue)
                      @Decat_Field("@@item")   @dtw_assign(V_IPITEM, fieldValue)
                      @Decat_Field("@@ptyp")   @dtw_assign(V_IPPTYP, fieldValue)
                      @Decat_Field("@@stwc")   @dtw_assign(V_IPSTWC, fieldValue)
                      @Decat_Field("@@kdfc")   @dtw_assign(V_IPKDFC, fieldValue)
                      @Decat_Field("@@matc")   @dtw_assign(V_IPMATC, fieldValue)
                      @Decat_Field("@@clas")   @dtw_assign(V_IPCLAS, fieldValue)
                      @Decat_Field("@@itc@")   @dtw_assign(V_IPITC,  fieldValue)
                      @Decat_Field("@@ltc@")   @dtw_assign(V_IPLTC,  fieldValue)
                      @Decat_Field("@@slt@")   @dtw_assign(V_IPSLT,  fieldValue)
                      @Decat_Field("@@tlt@")   @dtw_assign(V_IPTLT,  fieldValue)
                      @Decat_Field("@@ssq@")   @dtw_assign(V_IPSSQ,  fieldValue)
                      @Decat_Field("@@alts")   @dtw_assign(V_IPALTS, fieldValue)
                      @Decat_Field("@@seg1")   @dtw_assign(V_IPSEG1, fieldValue)
                      @Decat_Field("@@spc1")   @dtw_assign(V_IPSPC1, fieldValue)
                      @Decat_Field("@@seg2")   @dtw_assign(V_IPSEG2, fieldValue)
                      @Decat_Field("@@spc2")   @dtw_assign(V_IPSPC2, fieldValue)
                      @Decat_Field("@@seg3")   @dtw_assign(V_IPSEG3, fieldValue)
                      @Decat_Field("@@spc3")   @dtw_assign(V_IPSPC3, fieldValue)
                      @Decat_Field("@@seg4")   @dtw_assign(V_IPSEG4, fieldValue)
                      @Decat_Field("@@spc4")   @dtw_assign(V_IPSPC4, fieldValue)
                      @Decat_Field("@@seg5")   @dtw_assign(V_IPSEG5, fieldValue)
                      @Decat_Field("@@spc5")   @dtw_assign(V_IPSPC5, fieldValue)
                      @Decat_Field("@@iavo")   @dtw_assign(V_IPIAVO, fieldValue)
                      @Decat_Field("@@fort")   @dtw_assign(V_IPFORT, fieldValue)
                      @Decat_Field("@@bac@")   @dtw_assign(V_IPBAC,  fieldValue)
                      @Decat_Field("@@avlc")   @dtw_assign(V_IPAVLC, fieldValue)
                      @Decat_Field("@@opc@")   @dtw_assign(V_IPOPC,  fieldValue)
                      @Decat_Field("@@calc")   @dtw_assign(V_IPCALC, fieldValue)
                      @Decat_Field("@@msff")   @dtw_assign(V_IPMSFF, fieldValue)
                      @Decat_Field("@@dmdc")   @dtw_assign(V_IPDMDC, fieldValue)
                      @Decat_Field("@@fixp")   @dtw_assign(V_IPFIXP, fieldValue)
                      @Decat_Field("@@shrp")   @dtw_assign(V_IPSHRP, fieldValue)
                      @Decat_Field("@@foq@")   @dtw_assign(V_IPFOQ,  fieldValue)
                      @Decat_Field("@@mnq@")   @dtw_assign(V_IPMNQ,  fieldValue)
                      @Decat_Field("@@mxq@")   @dtw_assign(V_IPMXQ,  fieldValue)
                      @Decat_Field("@@muq@")   @dtw_assign(V_IPMUQ,  fieldValue)
                      @Decat_Field("@@fdtf")   @dtw_assign(V_IPFDTF, fieldValue)
                      @Decat_Field("@@fspr")   @dtw_assign(V_IPFSPR, fieldValue)
                      @Decat_Field("@@tfnd")   @dtw_assign(V_IPTFND, fieldValue)
                      @Decat_Field("@@pfct")   @dtw_assign(V_IPPFCT, fieldValue)
                      @Decat_Field("@@cfct")   @dtw_assign(V_IPCFCT, fieldValue)
                      @Decat_Field("@@rrtg")   @dtw_assign(V_IPRRTG, fieldValue)
                      @Decat_Field("@@dwgs")   @dtw_assign(V_IPDWGS, fieldValue)
                      @Decat_Field("@@dwgr")   @dtw_assign(V_IPDWGR, fieldValue)
                      @Decat_Field("@@dwgd")   @dtw_assign(V_IPDWGD, fieldValue)
                      @Decat_Field("@@dwgn")   @dtw_assign(V_IPDWGN, fieldValue)
                      @Decat_Field("@@ecn@")   @dtw_assign(V_IPECN,  fieldValue)
                      @Decat_Field("@@eftd")   @dtw_assign(V_IPEFTD, fieldValue)
                      @Decat_Field("@@ecdp")   @dtw_assign(V_IPECDP, fieldValue)
                      @Decat_Field("@@estc")   @dtw_assign(V_IPESTC, fieldValue)
                      @Decat_Field("@@vend")   @dtw_assign(V_IPVEND, fieldValue)
                      @Decat_Field("@@psum")   @dtw_assign(V_IPPSUM, fieldValue)
                      @Decat_Field("@@pcum")   @dtw_assign(V_IPPCUM, fieldValue)
                      @Decat_Field("@@nyps")   @dtw_assign(V_IPNYPS, fieldValue)
                      @Decat_Field("@@abcc")   @dtw_assign(V_IPABCC, fieldValue)
                      @Decat_Field("@@abco")   @dtw_assign(V_IPABCO, fieldValue)
                      @Decat_Field("@@onc@")   @dtw_assign(V_IPONC,  fieldValue)
                      @Decat_Field("@@aau@")   @dtw_assign(V_IPAAU,  fieldValue)
                      @Decat_Field("@@uda1")   @dtw_assign(V_IPUDA1, fieldValue)
                      @Decat_Field("@@uda2")   @dtw_assign(V_IPUDA2, fieldValue)
                      @Decat_Field("@@uda3")   @dtw_assign(V_IPUDA3, fieldValue)
                      @Decat_Field("@@udn1")   @dtw_assign(V_IPUDN1, fieldValue)
                      @Decat_Field("@@udn2")   @dtw_assign(V_IPUDN2, fieldValue)
                      @Decat_Field("@@udn3")   @dtw_assign(V_IPUDN3, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(V_IPBAC, "0")
                          @dtw_assign(V_IPVEND, "0")
                          @dtw_assign(V_IPPTYP, itemPartType)
                          @dtw_assign(V_IPITC, itemInvType)
                          @dtw_assign(V_IPALTS, "1")
                          @dtw_assign(V_IPCALC, "B")
                          @dtw_assign(V_IPOPC, "A")
                          @dtw_assign(V_IPKDFC, "M")
                          @dtw_assign(V_IPAVLC, "Y")
                          %if (itemPartType == "B" || itemPartType == "S" || itemPartType == "P")
                              @dtw_assign(V_IPLTC, "F")
                          %else
                              @dtw_assign(V_IPLTC, "V")
                          %endif
                          %if (itemPartType != "B" && itemPartType != "S")
                              @dtw_assign(V_IPABCC, "C")
                              @dtw_assign(V_IPABCO, "S")
                          %endif
                      %endif

                      @dtw_assign(errFound, "")
                  %else
                      @DateInputFromISO("$(V_IPDWGD)", V_IPDWGD)
                      @DateInputFromISO("$(V_IPEFTD)", V_IPEFTD)
                  %endif

                  %if (Err_IPPLT != "")
                      @DspErrMsg(Err_IPPLT)
                  %endif
                  %if (Err_IPITEM != "")
                      @DspErrMsg(Err_IPITEM)
                  %endif

                  @SetTextOvr(Err_IPPTYP)
                  <tr><td class="dsphdr"><span $(textOvr)>Part Type</span></td>
                      %if (itemPartType != "B" && itemPartType != "S")
                          @RtvFldDesc("FLTYPE='PARTTYPEMP' and FLVALU='$(V_IPPTYP)'", "SYFLAG", "FLDESC", fieldDesc)
                          <td class="inputalph"><input name="partType" type="text" value="$(V_IPPTYP)" size="15" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=PARTTYPEMP&amp;flagSrchHdr=@dtw_rurlescseq("Part Type")&amp;docName=Chg&amp;fldName=partType&amp;fldDesc=partTypeDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input disabled name="partTypeDesc" value="$(fieldDesc)" type="text" size="30"></td>
                      %else
                          @RtvFldDesc("FLTYPE='PARTTYPE' and FLVALU='$(itemPartType)'", "SYFLAG", "FLDESC", fieldDesc)
                          @Format_Code(itemPartType, F_itemPartType)
                          <td><input name="partType" type="hidden" value="$(itemPartType)" maxlength="1">$(fieldDesc) &nbsp; $(F_itemPartType)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_IPPTYP)

                  @RtvFldDesc("FLTYPE='BACKFLUSH' and FLVALU='$(V_IPSTWC)'", "SYFLAG", "FLDESC", fieldDesc)
                  @SetTextOvr(Err_IPSTWC)
                  <tr><td class="dsphdr"><span $(textOvr)>Backflush Code</span></td>
