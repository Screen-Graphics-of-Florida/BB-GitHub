                      %endif
                      <tr><td class="dsphdr">Installed At Vendor Only</td>
                          <td class="inputalph"><input type="checkbox" name="vendOnly" $(vendOnlyChecked) VALUE='Y'></td>
                      </tr>
                  %endif

                  %if (V_CIUSMP == "Y")		
                      <tr><td class="dsphdr"><span $(textOvr)>Smart Part</span></td>
                          <td>
                              <table $(contentTable)>
                                 <tr><td class="colhdr">Segment</td><td class="colhdr">Code</td></tr>

                      @SetTextOvr(Err_IPSEG1)
                      <tr>
                          @dtw_assign(cnt, "0")
                          <td class="inputalph">
                              <select class="page" name="smartPartSeg1">
                                  %while(@dtw_rformat(cnt, "2", "1") <= "99"){
                                      %if (cnt == V_IPSEG1)
                                          <option value="$(cnt)" SELECTED>$(cnt)
                                      %else
                                          <option value="$(cnt)">$(cnt)
                                      %endif
                                      @dtw_add(cnt, "1", cnt)
                                  %}
                              </select>
                          </td>
                          <td class="inputalph"><input name="smartPartCod1" type="text" value="$(V_IPSPC1)" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_IPSEG1)

                      @SetTextOvr(Err_IPSEG2)
                      <tr>
                          @dtw_assign(cnt, "0")
                          <td class="inputalph">
                              <select class="page" name="smartPartSeg2">
                                  %while(@dtw_rformat(cnt, "2", "1") <= "99"){
                                      %if (cnt == V_IPSEG2)
                                          <option value="$(cnt)" SELECTED>$(cnt)
                                      %else
                                          <option value="$(cnt)">$(cnt)
                                      %endif
                                      @dtw_add(cnt, "1", cnt)
                                  %}
                              </select>
                          </td>
                          <td class="inputalph"><input name="smartPartCod2" type="text" value="$(V_IPSPC2)" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_IPSEG2)

                      @SetTextOvr(Err_IPSEG3)
                      <tr>
                          @dtw_assign(cnt, "0")
                          <td class="inputalph">
                              <select class="page" name="smartPartSeg3">
                                  %while(@dtw_rformat(cnt, "2", "1") <= "99"){
                                      %if (cnt == V_IPSEG3)
                                          <option value="$(cnt)" SELECTED>$(cnt)
                                      %else
                                          <option value="$(cnt)">$(cnt)
                                      %endif
                                      @dtw_add(cnt, "1", cnt)
                                  %}
                              </select>
                          </td>
                          <td class="inputalph"><input name="smartPartCod3" type="text" value="$(V_IPSPC3)" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_IPSEG3)

                      @SetTextOvr(Err_IPSEG4)
                      <tr>
                          @dtw_assign(cnt, "0")
                          <td class="inputalph">
                              <select class="page" name="smartPartSeg4">
                                  %while(@dtw_rformat(cnt, "2", "1") <= "99"){
                                      %if (cnt == V_IPSEG4)
                                          <option value="$(cnt)" SELECTED>$(cnt)
                                      %else
                                          <option value="$(cnt)">$(cnt)
                                      %endif
                                      @dtw_add(cnt, "1", cnt)
                                  %}
                              </select>
                          </td>
                          <td class="inputalph"><input name="smartPartCod4" type="text" value="$(V_IPSPC4)" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_IPSEG4)

                      @SetTextOvr(Err_IPSEG5)
                      <tr>
                          @dtw_assign(cnt, "0")
                          <td class="inputalph">
                              <select class="page" name="smartPartSeg5">
                                  %while(@dtw_rformat(cnt, "2", "1") <= "99"){
                                      %if (cnt == V_IPSEG5)
                                          <option value="$(cnt)" SELECTED>$(cnt)
                                      %else
                                          <option value="$(cnt)">$(cnt)
                                      %endif
                                      @dtw_add(cnt, "1", cnt)
                                  %}
                              </select>
                          </td>
                          <td class="inputalph"><input name="smartPartCod5" type="text" value="$(V_IPSPC5)" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_IPSEG5)
                      </table>
                      </td>


                  %endif
              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDIPU_W.PGM %}
%}

%FUNCTION(dtw_directcall) Validate_Plant(INOUT CHAR(64) profileHandle,
                                         INOUT CHAR(2) dataBaseID,
                                         INOUT CHAR(1) maintCode,
                                         INOUT CHAR(1) errFound,
                                         INOUT CHAR(32000) edtVar,                             	
                                         INOUT CHAR(32000) errVar)
{%EXEC {HHDIPU_W1.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @Release_Version(profileHandle, dataBaseID, "MS", releaseMS, libLevMS)
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLPAS1", screenAlpha1)
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLPAS2", screenAlpha2)
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLPAS3", screenAlpha3)
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLPNS1", screenNumeric1)
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLPNS2", screenNumeric2)
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLPNS3", screenNumeric3)
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMUOMS", stockUOM)
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMPTYP", itemPartType)
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMITC", itemInvType)

      @ScheduleForecast_Query(profileHandle, dataBaseID, "SCHDFORCST", scheduleForecastTable)
      @ECNComonent_Query(profileHandle, dataBaseID, "ECNCOMPONT", ecnComponentTable)
      @ABCClass_Query(profileHandle, dataBaseID, "ABCCLASS  ", abcClassTable)
      @ABCOverride_Query(profileHandle, dataBaseID, "ABCOVERRID", abcOverrideTable)

      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)

      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(ADD) {
  @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
  %if (backURL == "")
      @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=227")
  %endif
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.plantNumber, 3, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "" && noMenu !="Y")
                      @dtw_assign(pageID, "ITEMPLANTMAINTAIN")
                     <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      <table $(contentTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1>Add Item/Plant</h1></td>
                              <td class="toolbar">
                                  %INCLUDE "MaintainTopNoTable.icl"
                              </td>
                          </tr>
                      </table>

                      $(hrTagAttr)
                      %INCLUDE "RequiredField.icl"
                      %INCLUDE "ErrorDisplay.icl"

                      <form class="formClass" METHOD=POST name=Chg ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Plant$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
                          <table $(contentTable)>
                              %if (errFound != "" || maintenanceCode == "A")
                                  %if (errFound == "" && maintenanceCode == "A")
                                     @dtw_assign(edtVar, "")
                                  %else
                                      @EdtVarErr(profileHandle, typeValue, edtVar)
                                      @dtw_assign(focusField, "")
                                      @ErrVarErr(profileHandle, typeError, errVar)
                                      @DecatErr_Field("@@plt@", "plantNumber")  @dtw_assign(Err_IPPLT,  fieldValue)
                                      @DecatErr_Field("@@item", "itemNumber")   @dtw_assign(Err_IPITEM,  fieldValue)
                                  %endif

                                  @Decat_Field("@@plt@")   @dtw_assign(V_IPPLT,  fieldValue)
                                  @Decat_Field("@@item")   @dtw_assign(V_IPITEM,  fieldValue)
                                  %if (V_IPPLT == "")
                                      @dtw_assign(V_IPPLT, "0")
                                  %endif

                                  %if (errFound == "")
                                     @dtw_assign(focusField, "itemNumber")
                                     %if (fKey1 != "")
                                         %if (fKey1 == "IPPLT")
                                             @dtw_assign(V_IPPLT,  fVal1)
                                         %else
                                             @dtw_assign(focusField, "plantNumber")
                                             @dtw_assign(V_IPITEM,  fVal1)
                                         %endif
                                     %endif
                                  %endif
                                  @dtw_assign(errFound, "")

                              %elif (maintenanceCode == "Z")
                                  @dtw_assign(V_IPITEM, "")
                                  @dtw_assign(V_IPPLT, "0")
                                  @dtw_assign(focusField, "itemNumber")
                                  %if (fKey1 != "")
                                      %if (fKey1 == "IPPLT")
                                          @dtw_assign(V_IPPLT,  fVal1)
                                      %else
                                          @dtw_assign(focusField, "plantNumber")
                                          @dtw_assign(V_IPITEM,  fVal1)
                                      %endif
                                  %endif
                              %endif

                              @RtvFldDesc("IMITEM='$(V_IPITEM)'", "HDIMST", "IMIMDS", fieldDesc)
                              @SetTextOvr(Err_IPITEM)
	                           <tr><td class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="itemNumber" value="$(V_IPITEM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=itemNumber&amp;fldDesc=itemDescription" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input name="itemDescription" value="$(fieldDesc)" type="text" size="30" maxlength="30"></td>
                              </tr>
                              @DspErrMsg(Err_IPITEM)

                              @RtvFldDesc("PLPLNT=$(V_IPPLT)", "HDPLNT", "PLNAME", fieldDesc)
                              @SetTextOvr(Err_IPPLT)
                              <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                  <td class="inputnmbr"><input name="plantNumber" value="$(V_IPPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=plantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input name="plantName" value="$(fieldDesc)" type="text" size="30" maxlength="30"></td>
                              </tr>
                              @DspErrMsg(Err_IPPLT)
                          </table>

                          <script TYPE="text/javascript">
                              document.Chg.$(focusField).focus();
                          </script>

                      </form>
                      %INCLUDE "MaintainBottom.icl"
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>

          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(Edit_Plant) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(itemNumber)
  @dtw_assign(plantNumber,@dtw_rstrip(plantNumber))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintCode, "A")
  %else
      @dtw_assign(maintCode, maintenanceCode)
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@item", itemNumber)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Plant(profileHandle, dataBaseID, maintCode, errFound, edtVar, errVar)

  %if (errFound == "")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/ADD$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(itemNumber)
  @dtw_mUPPERCASE(partType)
  @dtw_mUPPERCASE(backFlush)
  @dtw_mUPPERCASE(kanbanFlow)
  @dtw_mUPPERCASE(materialCode)
  @dtw_mUPPERCASE(partClass)
  @dtw_mUPPERCASE(inventoryType)
  @dtw_mUPPERCASE(leadTimeCode)
  @dtw_mUPPERCASE(checkCompAvail)
  @dtw_mUPPERCASE(orderPolicy)
  @dtw_mUPPERCASE(mrpCalcCode)
  @dtw_mUPPERCASE(demandCode)
  @dtw_mUPPERCASE(scheduleForecast)
  @dtw_mUPPERCASE(forecastDateFormat)
  @dtw_mUPPERCASE(forecastSpreaders)
  @dtw_mUPPERCASE(timeFenceDef)
  @dtw_mUPPERCASE(resourceRtgDef)
  @dtw_mUPPERCASE(drawingSize)
  @dtw_mUPPERCASE(drawingRevisionLetter)
  @dtw_mUPPERCASE(drawingNumber)
  @dtw_mUPPERCASE(engineerChange)
  @dtw_mUPPERCASE(ecnComponentDisp)
  @dtw_mUPPERCASE(engineerStatus)
  @dtw_mUPPERCASE(abcClass)
  @dtw_mUPPERCASE(abcOverride)
  @dtw_mUPPERCASE(alpha01)
  @dtw_mUPPERCASE(alpha02)
  @dtw_mUPPERCASE(alpha03)

  @dtw_assign(safetyLeadTime,@dtw_rstrip(safetyLeadTime))
  @dtw_assign(fixedLeadTime,@dtw_rstrip(fixedLeadTime))
  @dtw_assign(safetyStockQty,@dtw_rstrip(safetyStockQty))
  @dtw_assign(accountLotSize,@dtw_rstrip(accountLotSize))
  @dtw_assign(featureFactorRate,@dtw_rstrip(featureFactorRate))
  @dtw_assign(analyst,@dtw_rstrip(analyst))
  @dtw_assign(fixedTimePeriod,@dtw_rstrip(fixedTimePeriod))
  @dtw_assign(orderShrinkagePct,@dtw_rstrip(orderShrinkagePct))
  @dtw_assign(fixedOrderQty,@dtw_rstrip(fixedOrderQty))
  @dtw_assign(minimumOrderQty,@dtw_rstrip(minimumOrderQty))
  @dtw_assign(maximumOrderQty,@dtw_rstrip(maximumOrderQty))
  @dtw_assign(multipleOrderQty,@dtw_rstrip(multipleOrderQty))
  @dtw_assign(retainForecast,@dtw_rstrip(retainForecast))
  @dtw_assign(consumeForecast,@dtw_rstrip(consumeForecast))
  @dtw_assign(drawingDate,@dtw_rstrip(drawingDate))
  @dtw_assign(ecnDate,@dtw_rstrip(ecnDate))
  @dtw_assign(vendor,@dtw_rstrip(vendor))
  @dtw_assign(standardCost,@dtw_rstrip(standardCost))
  @dtw_assign(currentCost,@dtw_rstrip(currentCost))
  @dtw_assign(futureCost,@dtw_rstrip(futureCost))
  @dtw_assign(overideCycleDays,@dtw_rstrip(overideCycleDays))
  @dtw_assign(anticAnnualUsage,@dtw_rstrip(anticAnnualUsage))
  @dtw_assign(numeric01,@dtw_rstrip(numeric01))
  @dtw_assign(numeric02,@dtw_rstrip(numeric02))
  @dtw_assign(numeric03,@dtw_rstrip(numeric03))

  %if (orderShrinkagePct != "0" && orderShrinkagePct != "")
      @dtw_Divide(orderShrinkagePct, "100", orderShrinkagePct)
  %endif

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@item", itemNumber)
  @Concat_Field("@@ptyp", partType)
  @Concat_Field("@@stwc", backflush)
  @Concat_Field("@@kdfc", kanbanFlow)
  @Concat_Field("@@matc", materialCode)
  @Concat_Field("@@clas", partClass)
  @Concat_Field("@@itc@", inventoryType)
  @Concat_Field("@@ltc@", leadTimeCode)
  @Concat_Field("@@slt@", safetyLeadTime)
  @Concat_Field("@@tlt@", fixedLeadTime)
  @Concat_Field("@@ssq@", safetyStockQty)
  @Concat_Field("@@alts", accountLotSize)
  @Concat_Field("@@fort", featureFactorRate)
  @Concat_Field("@@bac@", analyst)
  @Concat_Field("@@avlc", checkCompAvail)
  @Concat_Field("@@opc@", orderPolicy)
  @Concat_Field("@@calc", mrpCalcCode)
  @Concat_Field("@@msff", scheduleForecast)
  @Concat_Field("@@dmdc", demandCode)
  @Concat_Field("@@fixp", fixedTimePeriods)
  @Concat_Field("@@shrp", orderShrinkagePct)
  @Concat_Field("@@foq@", fixedOrderQty)
  @Concat_Field("@@mnq@", minimumOrderQty)
  @Concat_Field("@@mxq@", maximumOrderQty)
  @Concat_Field("@@muq@", multipleOrderQty)
  @Concat_Field("@@fdtf", forecastDateFormat)
  @Concat_Field("@@fspr", forecastSpreaders)
  @Concat_Field("@@tfnd", timeFenceDef)
  @Concat_Field("@@pfct", retainForecast)
  @Concat_Field("@@cfct", consumeForecast)
  @Concat_Field("@@rrtg", resourceRtgDef)
  @Concat_Field("@@dwgs", drawingSize)
  @Concat_Field("@@dwgr", drawingRevisionLetter)
  @Concat_Field("@@dwgd", drawingDate)
  @Concat_Field("@@dwgn", drawingNumber)
  @Concat_Field("@@ecn@", engineerChange)
  @Concat_Field("@@eftd", ecnDate)
  @Concat_Field("@@ecdp", ecnComponentDisp)
  @Concat_Field("@@estc", engineerStatus)
  @Concat_Field("@@vend", vendor)
  @Concat_Field("@@psum", standardCost)
  @Concat_Field("@@pcum", currentCost)
  @Concat_Field("@@nyps", futureCost)
  @Concat_Field("@@abcc", abcClass)
  @Concat_Field("@@abco", abcOverride)
  @Concat_Field("@@onc@", overrideCycleDays)
  @Concat_Field("@@aau@", anticAnnualUsage)
  @Concat_Field("@@uda1", alpha01)
  @Concat_Field("@@uda2", alpha02)
  @Concat_Field("@@uda3", alpha03)
  @Concat_Field("@@udn1", numeric01)
  @Concat_Field("@@udn2", numeric02)
  @Concat_Field("@@udn3", numeric03)
  %if (V_CIUVCT == "Y")
      @Concat_Field("@@iavo", vendOnly)
  %endif
  %if (V_CIUSMP == "Y")
      @Concat_Field("@@seg1", smartPartSeg1)
      @Concat_Field("@@spc1", smartPartCod1)
      @Concat_Field("@@seg2", smartPartSeg2)
      @Concat_Field("@@spc2", smartPartCod2)
      @Concat_Field("@@seg3", smartPartSeg3)
      @Concat_Field("@@spc3", smartPartCod3)
      @Concat_Field("@@seg4", smartPartSeg4)
      @Concat_Field("@@spc4", smartPartCod4)
      @Concat_Field("@@seg5", smartPartSeg5)
      @Concat_Field("@@spc5", smartPartCod5)
  %endif
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (formatToPrint == "" && noMenu == "Y")
         <script TYPE="text/javascript">
             window.close()
         </script>
      %endif
      %if (errFound == "")
          @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
          @Format_ConfMsg_Desc(maintenanceCode, $(itemDescription), $(itemNumber), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@plt@", "plantNumber")
          %if (fieldValue == "")
              @DecatErr_Field("@@item", "itemNumber")
          %endif
          @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
          @Format_ConfMsg_Desc("", $(itemDescription), $(itemNumber), "", "", "<br>$(fieldValue)", "", confMessage)
      %endif
      %if (fromSel == "Y" && maintenanceCode != "D")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ItemPlantSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;itemDescription=@dtw_rurlescseq(itemDescription)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
          %if (backURL == "")
              <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=227&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %else
              <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %endif
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
