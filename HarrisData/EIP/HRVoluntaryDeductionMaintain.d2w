%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Voluntary Deduction Maintenance"
  d2wName                 = "HRVoluntaryDeductionMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;deductionNumber=@dtw_rurlescseq(deductionNumber)&amp;maintenanceCode=D"
  programName             = "HPRVDM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  function validate(chgForm) {
                      if (document.Chg.deductionNumber.value =="" ||
                          document.Chg.deductionName.value =="" ||
                          document.Chg.priority.value =="" ||
                          document.Chg.cycle.value =="" ||
                          document.Chg.accumulateYN.value =="" ||
                          document.Chg.fullAmountOnly.value =="" ||
                          document.Chg.takeOnSeparateCheck.value =="")
                         {alert("$(reqFieldError)"); return false;}

                      if (editNum(document.Chg.deductionNumber,      3, 0) &&
                          editNum(document.Chg.priority,             3, 0) &&
                          editNum(document.Chg.cycle,                1, 0) &&
                          editNum(document.Chg.glAcctNumber,         4, 0) &&
                          editNum(document.Chg.glSubAcctNumber,      4, 0) &&
                          editNum(document.Chg.calculationMethod,    2, 0))
                          return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
	           %INCLUDE "numedit.icl"
                  %INCLUDE "dateedit.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "VOLUNTARYDEDUCTIONMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "SELECT * FROM HRDEDM WHERE HVDDNO=$(deductionNumber)", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "deductionNumber")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@ddno", "deductionNumber")      @dtw_assign(Err_HVDDNO, fieldValue)
                          @DecatErr_Field("@@ddnm", "deductionName")        @dtw_assign(Err_HVDDNM, fieldValue)
                          @DecatErr_Field("@@prty", "priority")             @dtw_assign(Err_HVPRTY, fieldValue)
                          @DecatErr_Field("@@cycl", "cycle")                @dtw_assign(Err_HVCYCL, fieldValue)
                          @DecatErr_Field("@@acum", "accumulateYN")         @dtw_assign(Err_HVACUM, fieldValue)
                          @DecatErr_Field("@@fao@", "fullAmountOnly")       @dtw_assign(Err_HVFAO,  fieldValue)
                          @DecatErr_Field("@@tosc", "takeOnSeparateCheck")  @dtw_assign(Err_HVTOSC, fieldValue)
                          @DecatErr_Field("@@glac", "glAcctNumber")         @dtw_assign(Err_HVGLAC, fieldValue)
                          @DecatErr_Field("@@glsb", "glSubAcctNumber")      @dtw_assign(Err_HVGLSB,  fieldValue)
                          @DecatErr_Field("@@mthd", "calculationMethod")    @dtw_assign(Err_HVMTHD, fieldValue)
                          @DecatErr_Field("@@ldsc", "longDescription")      @dtw_assign(Err_HVLDSC, fieldValue)

                      %endif

                      @Decat_Field("@@ddno")   @dtw_assign(V_HVDDNO, fieldValue)
                      @Decat_Field("@@ddnm")   @dtw_assign(V_HVDDNM, fieldValue)
                      @Decat_Field("@@prty")   @dtw_assign(V_HVPRTY, fieldValue)
                      @Decat_Field("@@cycl")   @dtw_assign(V_HVCYCL, fieldValue)
                      @Decat_Field("@@acum")   @dtw_assign(V_HVACUM, fieldValue)
                      @Decat_Field("@@fao@")   @dtw_assign(V_HVFAO,  fieldValue)
                      @Decat_Field("@@tosc")   @dtw_assign(V_HVTOSC, fieldValue)
                      @Decat_Field("@@glac")   @dtw_assign(V_HVGLAC, fieldValue)
                      @Decat_Field("@@glsb")   @dtw_assign(V_HVGLSB, fieldValue)
                      @Decat_Field("@@mthd")   @dtw_assign(V_HVMTHD, fieldValue)
                      @Decat_Field("@@ldsc")   @dtw_assign(V_HVLDSC, fieldValue)



                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(V_HVACUM, "N")
                          @dtw_assign(V_HVFAO,  "N")
                          @dtw_assign(V_HVTOSC, "N")
                          @dtw_assign(focusField, "deductionNumber")
                      %endif

                      @dtw_assign(errFound, "")

                  %elseif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "deductionNumber")
                  %else
                      @dtw_assign(focusField, "deductionName")
                  %endif


                  @SetTextOvr(Err_HVDDNO)
                  <tr><td class="dsphdr"><span $(textOvr)>Deduction Number</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input type="text" name="deductionNumber" value="$(V_HVDDNO)" size="3" maxlength="3">$(reqFieldChar)</td>
                      %else
                          <td class="inputnmbr"><input type="hidden" name="deductionNumber" value="$(V_HVDDNO)" size="3" maxlength="3">$(V_HVDDNO)</td>
                      %endif
                      @DspErrMsg(Err_HVDDNO)
                  </tr>


                  @SetTextOvr(Err_HVDDNM)
                  <tr><td class="dsphdr"><span $(textOvr)>Deduction Name</span></td>
                      <td class="inputalph"><input name="deductionName" type="text" value="$(V_HVDDNM)" size="10" maxlength="10"> $(reqFieldChar) </td>
                      @DspErrMsg(Err_HVDDNM)
                  </tr>

                  @SetTextOvr(Err_HVPRTY)
                  <tr><td class="dsphdr"><span $(textOvr)>Priority</span></td>
                      <td class="inputnmbr"><input name="priority" type="text" value="$(V_HVPRTY)" size="3" maxlength="3"> $(reqFieldChar) </td>
                      @DspErrMsg(Err_HVPRTY)
                  </tr>

                  @SetTextOvr(Err_HVCYCL)
                  <tr><td class="dsphdr"><span $(textOvr)>Cycle</span></td>
                      <td class="inputnmbr"><input name="cycle" type="text" value="$(V_HVCYCL)" size="1" maxlength="1"> $(reqFieldChar) </td>
                      @DspErrMsg(Err_C2SMTY)
                  </tr>

                  @SetTextOvr(Err_HVACUM)
                  <tr><td class="dsphdr"><span $(textOvr)>Accumulate</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_HVACUM) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "accumulateYN", "2", "1", "N", "", x, "1") $(reqFieldChar)</td>
                      @DspErrMsg(Err_HVACUM)
                  </tr>

                  @SetTextOvr(Err_HVFAO)
                  <tr><td class="dsphdr"><span $(textOvr)>Full Amount Only</span></td>
                      @dtw_tb_rows(yn02Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn02Table, x, "1") != V_HVFAO) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn02Table, "fullAmountOnly", "2", "1", "N", "", x, "1") $(reqFieldChar)</td>
                      @DspErrMsg(Err_HVFAO)
                  </tr>

                  @SetTextOvr(Err_HVTOSC)
                  <tr><td class="dsphdr"><span $(textOvr)>Take On Separate Check</span></td>
                      @dtw_tb_rows(yn03Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn03Table, x, "1") != V_HVTOSC) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn03Table, "takeOnSeparateCheck", "2", "1", "N", "", x, "1") $(reqFieldChar)</td>
                      @DspErrMsg(Err_HVTOSC)
                  </tr>

                  @Default_Zero(V_HVGLAC)
                  @Default_Zero(V_HVGLSB)
                  @RtvFldDesc("CHACCT=$(V_HVGLAC) and CHSUB=$(V_HVGLSB) ", "HDCHRT", "CHCHDS", acctDesc)
                  @SetTextOvr(Err_HVGLAC)
                  <tr><td class="dsphdr"><span $(textOvr)>G/L Account Number</span></td>
                      <td class="inputnmbr"><input name="glAcctNumber" value="$(V_HVGLAC)" type="text" size="4" maxlength="4"> - <input name="glSubAcctNumber" value="$(V_HVGLSB)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(cGIPath)accountsearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;acctFld=glAcctNumber&amp;subFld=glSubAcctNumber&amp;descFld=glAcctDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="glAcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                      @DspErrMsg(Err_HVGLAC)
                      @DspErrMsg(Err_HVGLSB)
                  </tr>

                  @RtvFldDesc("FLTYPE='DEDCALCMTH' and FLVALU=$(V_HVMTHD)", "SYFLAG", "FLDESC", fieldCalcMethodDesc)
                  @SetTextOvr(Err_HVMTHD)
                  <tr><td class="dsphdr"><span $(textOvr)>Calculation Method</span></td>
                      <td class="inputalph"><input name="calculationMethod" type="text" value="$(V_HVMTHD)" size="2" maxlength="2"> <a href="$(homeURL)$(cGIPath)FlagSearch.d2w/REPORT$(genericVarBase)&amp;flagType=DEDCALCMTH&amp;flagSrchHdr=Calculation Method&amp;docName=Chg&amp;fldName=calculationMethod&amp;fldDesc=calcMethodDesc" onclick="$(searchWinVar)"> $(searchImage)</a>
                          <input name="calcMethodDesc" value="$(fieldCalcMethodDesc)" type="text" size="20" disabled></td>
                      @DspErrMsg(Err_HVMTHD)
                  </tr>

                  @SetTextOvr(Err_HVLDSC)
                  <tr><td class="dsphdr"><span $(textOvr)>Long Description</span></td>
                      <td class="inputalph"><input name="longDescription" type="text" value="$(V_HVLDSC)" size="30" maxlength="30"> </td>
                      @DspErrMsg(Err_HVLDSC)
                  </tr>


              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar,
                                        INOUT CHAR(8)     SUBR)

{%EXEC {HPRVDM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if ((sec_02 == "N" && sec_03 == "N" && maintenanceCode != "A") || (sec_01 == "N" && maintenanceCode == "A") || (sec_04 == "N" && maintenanceCode == "Z"))
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)ProgOptSecError.d2w/DISPLAY$(genericVarBase)&amp;page_title=@dtw_rurlescseq(page_title)">
  %else
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @yn02_Table_Query(profileHandle, dataBaseID, "YORN      ", yn02Table)
      @yn03_Table_Query(profileHandle, dataBaseID, "YORN      ", yn03Table)

      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(accumulateYN)
  @dtw_mUPPERCASE(fullAmountOnly)
  @dtw_mUPPERCASE(takeOnSeparateCheck)

  @dtw_assign(deductionNumber,@dtw_rstrip(deductionNumber))
  @dtw_assign(deductionName,@dtw_rstrip(deductionName))
  @dtw_assign(priority,@dtw_rstrip(priority))
  @dtw_assign(cycle,@dtw_rstrip(cycle))
  @dtw_assign(accumulateYN,@dtw_rstrip(accumulateYN))
  @dtw_assign(fullAmountOnly,@dtw_rstrip(fullAmountOnly))
  @dtw_assign(takeOnSeparateCheck,@dtw_rstrip(takeOnSeparateCheck))
  @dtw_assign(glAcctNumber,@dtw_rstrip(glAcctNumber))
  @dtw_assign(glSubAcctNumber,@dtw_rstrip(glSubAcctNumber))
  @dtw_assign(calculationMethod,@dtw_rstrip(calculationMethod))
  @dtw_assign(longDescription,@dtw_rstrip(longDescription))


  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(SUBR, "")

  @dtw_assign(edtVar, "")
  @Concat_Field("@@ddno", deductionNumber)
  @Concat_Field("@@ddnm", deductionName)
  @Concat_Field("@@prty", priority)
  @Concat_Field("@@cycl", cycle)
  @Concat_Field("@@acum", accumulateYN)
  @Concat_Field("@@fao@", fullAmountOnly)
  @Concat_Field("@@tosc", takeOnSeparateCheck)
  @Concat_Field("@@glac", glAcctNumber)
  @Concat_Field("@@glsb", glSubAcctNumber)
  @Concat_Field("@@mthd", calculationMethod)
  @Concat_Field("@@ldsc", longDescription)

  @dtw_concat(edtVar, "}{", edtVar)


  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar, SUBR)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(deductionNumber), "", "", "", "", "", confMessage)
      %if (maintenanceCode == "D" || fromD2w != "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)HRVoluntaryDeduction.d2w/REPORT$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)HRVoluntaryDeduction.d2w/REPORT$(genericVarBase)&amp;deductionNumber=@dtw_rurlescseq(deductionNumber)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %elseif (maintenanceCode == "D")
      @DecatErr_Field("@@ddno", "deductionNumber")
      @Format_ConfMsg_Desc($(deductionNumber), $(deductionName), "", "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)HRVoluntaryDeduction.d2w/REPORT$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;deductionNumber=@dtw_rurlescseq(deductionNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}



%HTML(COPYALL) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
	       %INCLUDE "numedit.icl"
              %INCLUDE "NewWindowOpen.icl"
              function validate(chgForm) {
                 if (document.Chg.fromcoNumber.value =="" ||
                     document.Chg.fromfacNumber.value =="" ||
                     document.Chg.tocoNumber.value =="" ||
                     document.Chg.tofacNumber.value =="")
                       {alert("$(reqFieldError)");
                           return false;}
                 if (editNum(document.Chg.fromcoNumber,  2, 0) &&
                     editNum(document.Chg.fromfacNumber, 4, 0) &&
                     editNum(document.Chg.tocoNumber,    2, 0) &&
                     editNum(document.Chg.tofacNumber,   4, 0))
                          return true;

              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PAYCODEMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      <table $(baseTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1> Copy Company/Facility Pay Code</h1></td>
                          <td class="toolbar">
                              %INCLUDE "MaintainTopNoTable.icl"
                          </td></tr>
                      </table>

                      $(hrTagAttr)
                      %INCLUDE "RequiredField.icl"
                      %INCLUDE "ErrorDisplay.icl"

                      <form class="formClass" METHOD=POST name=Chg onSubmit="return (editNum(tocoNumber, 3, 0) &&
                                                                                     editChg())"
                          ACTION="$(homeURL)$(cGIPath)$(d2wName)/EDIT_COPYALL$(d2wVarBase)&amp;fromcoNumber=@dtw_rurlescseq(fromcoNumber)&amp;fromfacNumber=@dtw_rurlescseq(fromfacNumber)&amp;tocoNumber=@dtw_rurlescseq(tocoNumber)&amp;tofacNumber=@dtw_rurlescseq(tofacNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromcoNumber")
                              %if (errFound != "" || maintenanceCode == "A")
                                  %if (errFound == "" && maintenanceCode == "A")
                                      @dtw_assign(edtVar, "")
                                  %else
                                      @EdtVarErr(profileHandle, typeValue, edtVar)
                                      @ErrVarErr(profileHandle, typeError, errVar)
                                      @DecatErr_Field("@@fcom", "fromcoNumber")    @dtw_assign(Err_FROMCOM,  fieldValue)
                                      @DecatErr_Field("@@ffac", "fromfacNumber")   @dtw_assign(Err_FROMFAC,  fieldValue)
                                      @DecatErr_Field("@@tcom", "tocoNumber")      @dtw_assign(Err_TOCOM,  fieldValue)
                                      @DecatErr_Field("@@tfac", "tofacNumber")     @dtw_assign(Err_TOFAC,  fieldValue)
                                  %endif

                                  @Decat_Field("@@fcom")   @dtw_assign(V_C2FCOM,  fieldValue)
                                  @Decat_Field("@@ffac")   @dtw_assign(V_C2FFAC,  fieldValue)
                                  @Decat_Field("@@tcom")   @dtw_assign(V_C2TCOM,  fieldValue)
                                  @Decat_Field("@@tfac")   @dtw_assign(V_C2TFAC,  fieldValue)

                                  @dtw_assign(errFound, "")

                              %elseif (maintenanceCode == "Z")
                                  @dtw_assign(V_C2TCOM, "")
                                  @dtw_assign(V_C2TFAC, "")
                              %endif

                              @Default_Zero(V_C2FCOM)
                              @Default_Zero(V_C2FFAC)
                              @RtvFldDesc("CFCOMP=$(V_C2FCOM) and CFFACL=$(V_C2FFAC)", "HRCOFC", "CFNAME", fieldDesc)
                              @SetTextOvr(Err_FROMCOM)
                              <tr><td class="dsphdr"><span $(textOvr)>From Company/Facility</span></td>
                                  <td class="inputnmbr"><input name="fromcoNumber" value="$(V_C2FCOM)" type="text" size="4" maxlength="2"> / <input name="fromfacNumber" value="$(V_C2FFAC)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(cGIPath)CoFacSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldCo=fromcoNumber&amp;fldFac=fromfacNumber&amp;fldDesc=fromcoFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="fromcoFacDesc" value="$(fieldDesc)"  type="text" size="30" maxlength="30">$(reqFieldChar)</td>
                                  @DspErrMsg(Err_FROMCOM)
                                  @DspErrMsg(Err_FROMFAC)
                              </tr>

                              @Default_Zero(V_C2TCOM)
                              @Default_Zero(V_C2TFAC)
                              @RtvFldDesc("CFCOMP=$(V_C2TCOM) and CFFACL=$(V_C2TFAC)", "HRCOFC", "CFNAME", fieldDesc)
                              @SetTextOvr(Err_TOCOM)
                              <tr><td class="dsphdr"><span $(textOvr)>To Company/Facility</span></td>
                                  <td class="inputnmbr"><input name="tocoNumber" value="$(V_C2TCOM)" type="text" size="4" maxlength="2"> / <input name="tofacNumber" value="$(V_C2TFAC)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(cGIPath)CoFacSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldCo=tocoNumber&amp;fldFac=tofacNumber&amp;fldDesc=tocoFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="tocoFacDesc" value="$(fieldDesc)"  type="text" size="30" maxlength="30">$(reqFieldChar)</td>
                                  @DspErrMsg(Err_TOCOM)
                                  @DspErrMsg(Err_TOFAC)
                              </tr>

                          </table>
                          %INCLUDE "MaintainBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </form>
                  </td>
              </tr>
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(EDIT_COPYALL) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(fromcoNumber,@dtw_rstrip(fromcoNumber))
  @dtw_assign(fromfacNumber,@dtw_rstrip(fromfacNumber))
  @dtw_assign(tocoNumber,@dtw_rstrip(tocoNumber))
  @dtw_assign(tofacNumber,@dtw_rstrip(tofacNumber))
  @dtw_assign(SUBR, "SRCpyAll")

  @dtw_assign(edtVar, "")
  @Concat_Field("@@fcom", fromcoNumber)
  @Concat_Field("@@ffac", fromfacNumber)
  @Concat_Field("@@tcom", tocoNumber)
  @Concat_Field("@@tfac", tofacNumber)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, maintCode, errFound, edtVar, errVar, SUBR)

  %if (errFound == "")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)HRPaycode.d2w/REPORT$(d2wVarBase)&amp;coNumber=@dtw_rurlescseq(tocoNumber)&amp;facNumber=@dtw_rurlescseq(tofacNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/COPYALL$(d2wVarBase)&amp;fromcoNumber=@dtw_rurlescseq(fromcoNumber)&amp;fromfacNumber=@dtw_rurlescseq(fromfacNumber)&amp;tocoNumber=@dtw_rurlescseq(tocoNumber)&amp;tofacNumber=@dtw_rurlescseq(tofacNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}