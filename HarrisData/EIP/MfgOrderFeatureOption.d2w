%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Manufacturing Order Product Configuration"
  d2wName                 = "MfgOrderFeatureOption.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;mfgOrder=@dtw_rurlescseq(mfgOrder)&amp;parentItem=@dtw_rurlescseq(parentItem)&amp;parentItemDesc=@dtw_rurlescseq(parentItemDesc)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "1000"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "1000"
  prtMaxRows              = "1000"
  rowIndexNext            = "1"
  totalPages              = "0"
  errFound                = ""
  imageExists             = ""
  mandatory               = ""
  allowMultiple           = ""
  variableQty             = ""
  linkVariable            = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              var optionWin;
              function confirmNoUpdate() {
                  return confirm("Confirm No Update Of Featured Item")
              }
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "NewWindowOpen.icl"
              function submitForm(action) {document.Chg.action = action; return true;}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "MOFEATOPTIONS")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">

                      %if (formatToPrint == "")
                          @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                          @dtw_assign(SAVE_MAX_ROWS, RPT_MAX_ROWS)
                          @dtw_assign(START_ROW_NUM, "1")
                          @dtw_assign(RPT_MAX_ROWS, "9999")
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " HDFOPW ", fileSQL)
                          @dtw_concat(selectSQL, "SAXHND='$(profileHandle)' and SAFEAT>' ' and SAOPTN=' ' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                          @Link_Query(profileHandle, dataBaseID, stmtSQL)
                          @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                          @dtw_assign(RPT_MAX_ROWS, SAVE_MAX_ROWS)
                      %endif

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " HDFOPW ", fileSQL)
                      @dtw_concat(selectSQL, "SAXHND='$(profileHandle)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @dtw_assign(stmtSQL, "")
                      @dtw_concat(stmtSQL, " Select * From HDFOPW", stmtSQL)
                      @dtw_concat(stmtSQL, " Where SAXHND='$(profileHandle)' ", stmtSQL)
                      %if (formatToPrint == "Y")
                          @dtw_concat(stmtSQL, " and SAMNCD='S' ", stmtSQL)
                      %endif
                      @dtw_concat(stmtSQL, " Order By SARSEQ ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %if (formatToPrint == "Y")
                          @Feature_Item_Print(profileHandle, dataBaseID, stmtSQL)
                      %else
                          @Feature_Item_Query(profileHandle, dataBaseID, stmtSQL)
                      %endif
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Link_Query (IN CHAR(64)    profileHandle,
                                  CHAR(2)     dataBaseID,
                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(linkVariable, "")

      %ROW{
          @dtw_concat(linkVariable, "<tr><td class=""dspalph""><a href=""#$(V_SAFEAT)"">$(V_SADESC)</a>", linkVariable)
          %if (V_SAMAND == "Y")
              @dtw_concat(linkVariable, "$(reqFieldChar)", linkVariable)
          %endif
          @dtw_concat(linkVariable, "</td>", linkVariable)
          @RtvFldDesc("SAXHND='$(V_SAXHND)' and SAFEAT='$(V_SAFEAT)' and SAMNCD='S'", "HDFOPW", " char(count(SAOPTN))", optionCount)
          %if (optionCount > "0")
              @dtw_concat(linkVariable, "<td align=""center"">$(selectedOptionImage)</td>", linkVariable)
          %else
              @dtw_concat(linkVariable, "<td>&nbsp;</td>", linkVariable)
          %endif
          %if (V_SAER# != "")
              @Ret_Error_Msg(profileHandle, dataBaseID, $(V_SAER#), errorMessage)
              @dtw_concat(linkVariable, "<td class=""error"">$(errorMessage)</td>", linkVariable)
          %endif
          @dtw_concat(linkVariable, "</tr>", linkVariable)
      %}
  %}
%}

%FUNCTION(dtw_sql) Feature_Item_Query (IN  CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      <a name="top"></a>
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint == "")
                  <td class="toolbar">
                      <a href="javascript:document.Chg.submit()">$(acceptImageLrg)</a>
                      <a href="$(homeURL)$(cGIPath)$(d2wName)/NOUPDATE$(d2wVarBase)">$(cancelImageLrg)</a>
                      <a href="$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)&amp;formatToPrint=Y" target=_blank>$(formatPrintMed)</a>
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      <table $(contentTable)>
          @Format_Header_URL("Plant", $(plantName), $(plantNumber), "$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;plantName=@dtw_rurlescseq(plantName)")
          @Format_Header_URL("Mfg Order", $(mfgOrder), "", "")
          @Format_Header_URL("Parent Item", $(parentItemDesc), $(parentItem), "$(homeURL)$(cGIPath)ItemPlantSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(parentItem)&amp;plantNumber=@dtw_rurlescseq(plantNumber)")
      </table>

      $(hrTagAttr)

      %if (formatToPrint == "")
          <table $(contentTable)>
              <tr>
                  <td class="colhdr">Feature</td>
                  <td class="colhdr">Selected</td>
                  <td colspan="2">&nbsp; %INCLUDE "RequiredField.icl"</td>
              </tr>
              $(linkVariable)
          </table>
      %endif

      <form class="formClass" Name="Chg" METHOD=POST action="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)">

      @dtw_assign(saveFeature, "")
		
      %ROW{
          %if (saveFeature != "" && saveFeature != V_SAFEAT)
              %if (saveBiLevel != "" && V_SABLVL != "")
                  </td></tr>
              %endif
              </table>
              %if (saveBiLevel != "")
                  </fieldset>
              %endif
              </table>
              </fieldset>
          %endif
          %if (saveFeature != V_SAFEAT)
              @dtw_assign(mandatory, V_SAMAND)
              %if (mandatory == "Y")
                  @dtw_assign(reqField, $(reqFieldChar))
              %else
                  @dtw_assign(reqField, "")
              %endif
              @dtw_assign(allowMultiple, V_SAMULT)
              @dtw_assign(variableQty, V_SAVARQ)
              @dtw_assign(saveFeature, V_SAFEAT)
              @dtw_assign(featureSeq, V_SARSEQ)
              %while(@dtw_rlength(featureSeq) != "5") {@dtw_insert("0", featureSeq, featureSeq)%}
              <a name="$(V_SAFEAT)"></a>
              <fieldset class="legendBodyFO">
              <legend class="legendTitleFO">$(V_SADESC) $(reqField)</legend>
              <table $(contentTable)>
                  <colgroup>
                      <col width="90%">
                      <col width="10%">
                  %if (formatToPrint == "")
                      <tr>
                          %if (V_SAER# != "")
                              @Ret_Error_Msg(profileHandle, dataBaseID, $(V_SAER#), errorMessage)
                              <td class="error"  colspan=8>$(errorMessage)</td>
                          %else
                              <td>&nbsp;</td>
                          %endif
                          <td><a href="#top">$(topOfFormImage)</a> <a href="#bottom">$(botOfFormImage)</a></td>
                      </tr>
                  %endif
                  %if (allowMultiple != "Y")
                      @RtvFldDesc("SAXHND='$(V_SAXHND)' and SAFEAT='$(V_SAFEAT)' and SAOPTN<>' ' ", "HDFOPW", " char(count(SAOPTN))", optionCount)
                  %endif
                  @dtw_assign(saveBiLevel, "beginNewLevel")
                  <tr><td>
          %else
              %if (saveBiLevel != V_SABLVL)
                  %if (saveBiLevel != "beginNewLevel")
                      </table>
                      %if (saveBiLevel != "")
                          </fieldset>
                      %endif
                  %endif
                  @dtw_assign(saveBiLevel, V_SABLVL)
                  %if (saveBiLevel != "")
                      <fieldset class="legendSubBodyFO">
                          <legend class="legendSubTitleFO">$(V_SABLDS)</legend>
                  %endif
                  <table $(contentTable)>
                      <colgroup>
                          <col width="30%">
                          <col width="25%">
                          <col width="25%">
                          <col width="10%">
                          <col width="10%">
                      <tr><td class="colalph">Select</td>
                          %if (variableQty == "Y")
                              <td class="colnmbr">Quantity</td>
                          %else
                              <td>&nbsp;</td>
                          %endif
                          <td>&nbsp;</td>
                      </tr>
                      <tr><td>
              %endif

              <tr>
                  @Check_Item_Comments(profileHandle, dataBaseID, V_SAOPTN, "", customerNumber, "WEB", headerTrailer, itemComments)
                  @dtw_assign(itemImage, "$(V_SAOPTN)$(itemImageExt)")
                  @dtwf_exists(itemImage, imageExists)
                  %if (V_SAMNCD == "S")
                      @dtw_assign(optionChecked, "CHECKED")
                  %else
                      @dtw_assign(optionChecked, "")
                  %endif
                  %while(@dtw_rlength(V_SARSEQ) != "5") {@dtw_insert("0", V_SARSEQ, V_SARSEQ)%}
                  <td class="colalph">
                      %if (allowMultiple == "Y")
                          <input type="checkbox" name="S$(V_SARSEQ)" value="S" $(optionChecked)>$(V_SADESC)
                      %elif (allowMultiple != "Y" && optionCount == "1")
                          <input type="checkbox" name="S$(featureSeq)" value="$(V_SARSEQ)" $(optionChecked)>$(V_SADESC)
                      %else
                          <input type="radio" name="S$(featureSeq)" value="$(V_SARSEQ)" $(optionChecked)>$(V_SADESC)
                      %endif
                  </td>
                  %if (variableQty == "Y")
                      <td class="colnmbr"><input name="Q$(V_SARSEQ)" type="text" value="$(V_SAOQTY)" size="8" maxlength="14"></td>
                  %endif
                  <td class="colicon">
                      @dtw_assign(commentVar, "$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(V_SAOPTN)&amp;itemDesc=@dtw_rurlescseq(V_SADESC)")
                      %if (itemComments == "Y" && formatToPrint == "")
                          <a href="$(homeURL)$(cGIPath)ItemComments.d2w/REPORT$(commentVar)" onclick="$(commentWinVar)">$(commentExistImage)</a>
                      %elif (itemComments != "" && formatToPrint == "")
                          <a href="$(homeURL)$(cGIPath)VendCustItemComments.d2w/REPORT$(commentVar)" onclick="$(commentWinVar)">$(commentExistImage)</a>
                      %endif
                      %if (imageExists == "Y" && formatToPrint == "")
                          <a href="$(homeURL)$(cGIPath)ImageDisplay.d2w/DISPLAY$(genericVarBase)&amp;imageDisplayPath=$(homeURL)$(itemImage)&amp;imageDesc=@dtw_rurlescseq(V_SADESC)" onclick="$(itemImageWinVar)">$(foundImage)</a>
                      %endif
                  </td>
              </tr>
          %endif
      %}
          <tr>
              <td><input type="hidden" name="rows" value="$(sql_Record_Count)">
              </td>
          </tr>
      </table>
      %if (saveBiLevel != "")
          </fieldset>
      %endif
      </table>
      </fieldset>
          %if (formatToPrint == "")
              <a href="javascript:document.Chg.submit()">$(acceptImageLrg)</a>
              <a href="$(homeURL)$(cGIPath)$(d2wName)/NOUPDATE$(d2wVarBase)">$(cancelImageLrg)</a>
          %endif
          </form>
      <a name="bottom"></a>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_sql) Feature_Item_Print (IN  CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td></tr>
      </table>

      <table $(contentTable)>
          @Format_Header_URL("Plant", $(plantName), $(plantNumber), "$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;plantName=@dtw_rurlescseq(plantName)")
          @Format_Header_URL("Mfg Order", $(mfgOrder), "", "")
          @Format_Header_URL("Parent Item", $(parentItemDesc), $(parentItem), "$(homeURL)$(cGIPath)ItemPlantSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(parentItem)&amp;plantNumber=@dtw_rurlescseq(plantNumber)")
      </table>

      $(hrTagAttr)

      <table $(contentTable)>
          <tr>
              <td class="colhdr">Feature</td>
              <td class="colhdr">Option</td>
              <td class="colhdr">Description</td>
              <td class="colhdr">Quantity</td>
          </tr>
          @dtw_assign(saveFeature, "")
		
          %ROW{
              %if (saveFeature != V_SAFEAT)
                  %INCLUDE "SetRowClass.icl"
                  @dtw_assign(saveFeature, V_SAFEAT)
                  @dtw_assign(newFeature, V_SAFEAT)
              %else
                  @dtw_assign(newFeature, "")
              %endif
              <tr class="$(rowClass)">
                  <td class="colalph">$(newFeature)</td>
                  <td class="colalph">$(V_SAOPTN)</td>
                  <td class="colalph">$(V_SADESC)</td>
                  @Format_Nbr(V_SAOQTY, F_SAOQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  <td class="colnmbr">$(F_SAOQTY)</td>
              </tr>
          %}
      </table>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Update_Feature_Option (INOUT CHAR(64)    profileHandle,
                                                 INOUT CHAR(2)     dataBaseID,
                                                 INOUT CHAR(1)     maintenanceCode,
                                                 INOUT CHAR(1)     errFound,
                                                 INOUT CHAR(32000) edtVar,
                                                 INOUT CHAR(32000) optVar,
                                                 INOUT CHAR(32000) errVar,
                                                 INOUT CHAR(10)    SUBR)

{%EXEC {HSI205_W.PGM %}
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @EdtVarErr(profileHandle, typeValue, edtVar)
  @dtw_assign(optVar, "")
  @dtw_assign(x, "10000")
  @dtw_assign(y, "1")
  %while(y <= rows) {
      @dtw_assign(S, "S$(x)")
      @dtw_assign(Q, "Q$(x)")
      @dtw_add(x, "1", x)
      @dtw_add(y, "1", y)
      %if (optVar == "")
          @dtw_concat(optVar, "$(S)$($(S))", optVar)
      %else
          @dtw_concat(optVar, "}{$(S)$($(S))", optVar)
      %endif
      %if (optVar == "")
          @dtw_concat(optVar, "$(Q)$($(Q))", optVar)
      %else
          @dtw_concat(optVar, "}{$(Q)$($(Q))", optVar)
      %endif
  %}
  @dtw_concat(optVar, "}{", optVar)

  @dtw_assign(SUBR, "FOACCEPT")

  @Update_Feature_Option(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, optVar, errVar, SUBR)

  %if (errFound == "Y")
      @EdtVarErr(profileHandle, typeValue, edtVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %else
      @Decat_Field("@@ord@")   @dtw_assign(mfgOrder,  fieldValue)
      @Format_ConfMsg_Desc(maintenanceCode, "Mfg Order", $(mfgOrder), "in $(plantName)", $(plantNumber), "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=445&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %endif
%}

%HTML(NOUPDATE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @EdtVarErr(profileHandle, typeValue, edtVar)

  @dtw_assign(SUBR, "FONOUPDATE")

  @Update_Feature_Option(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, optVar, errVar, SUBR)

  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)MfgOrderMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;reDisplay=Y">
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @EdtVarErr(profileHandle, typeValue, edtVar)
  @Decat_Field("@@plt@")   @dtw_assign(plantNumber, fieldValue)
  @Decat_Field("@@ord@")   @dtw_assign(mfgOrder,    fieldValue)
  @Decat_Field("@@pn@@")   @dtw_assign(parentItem,  fieldValue)
  @RtvFldDesc("IMITEM='$(parentItem)'", "HDIMST", "IMIMDS", parentItemDesc)

  @dtw_assign(SUBR, "FOINPUT")

  @Update_Feature_Option(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, optVar, errVar, SUBR)

  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)&amp;updateRowNum=@dtw_rurlescseq(updateRowNum)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  %if (updateRowNum > "0")
      @dtw_assign(START_ROW_NUM,  "$(updateRowNum)")
  %endif
  @Set_SQL(stmtSQL)
%}