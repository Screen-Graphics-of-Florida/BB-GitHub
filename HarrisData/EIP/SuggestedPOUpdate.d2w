%}

%INCLUDE "$(baseVar)"
%INCLUDE "GenericDirectCallVariables.icl"

%Define {	
  d2wName  = "SuggestedPOUpdate.d2w"
  DATABASE = "*LOCAL"
%}

%HTML(UPDATE) {	
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @RtvFldDesc("PTREQN='$(transReqNbr)' and PTITEM='$(item)'", "POSGPT", "PTREQN", PTREQN)
  %if (PTREQN == $(transReqNbr))
      @RtvFldDesc("PTREQN='$(transReqNbr)' and PTITEM='$(item)'", "POSGPT", "PTTRST", transReq)
      @RtvFldDesc("PTREQN='$(transReqNbr)' and PTITEM='$(item)'", "POSGPT", "PTNOSB", noSub)
      %if (chgReq == "R" && transReq == "R" && noSub == "Y")
          @dtw_concat(stmtSQL, " Update POSGPT Set PTTRST='N', PTNOSB='$(noSub)' ", stmtSQL)
          @dtw_concat(stmtSQL, " Where PTREQN=$(transReqNbr) and PTITEM='$(item)' @@endsql ", stmtSQL)
      %elif (chgReq == "R" && transReq != "R" && noSub == "Y")
          @dtw_concat(stmtSQL, " Update POSGPT Set PTTRST='R', PTNOSB='$(noSub)' ", stmtSQL)
          @dtw_concat(stmtSQL, " Where PTREQN=$(transReqNbr) and PTITEM='$(item)' @@endsql ", stmtSQL)
      %elif (chgReq == "S" && transReq == "R" && noSub != "Y")
          @dtw_concat(stmtSQL, " Update POSGPT Set PTNOSB='Y' ", stmtSQL)
          @dtw_concat(stmtSQL, " Where PTREQN=$(transReqNbr) and PTITEM='$(item)' @@endsql ", stmtSQL)
      %elif (chgReq == "S" && transReq == "R" && noSub == "Y")
          @dtw_concat(stmtSQL, " Update POSGPT Set PTNOSB=' ' ", stmtSQL)
          @dtw_concat(stmtSQL, " Where PTREQN=$(transReqNbr) and PTITEM='$(item)' @@endsql ", stmtSQL)
      %else
          @dtw_concat(stmtSQL, " Delete From POSGPT ", stmtSQL)
          @dtw_concat(stmtSQL, " Where PTREQN=$(transReqNbr) and PTITEM='$(item)' @@endsql ", stmtSQL)
      %endif
  %else
      @dtw_concat(stmtSQL, " Insert Into POSGPT (PTREQN,PTITEM,PTTRST,PTTNBR,PTTQTY,PTNOSB,PTSITM) ", stmtSQL)
      @dtw_concat(stmtSQL, " Select PSREQN,PSITEM,'$(transReq)',0,PSSQOR,'$(noSub)',' ' ", stmtSQL)
      @dtw_concat(stmtSQL, " From POSGPO Where PSTYPE='S' and PSREQN='$(transReqNbr)' and PSITEM='$(item)' @@endsql", stmtSQL)
  %endif
  @SQL_Update(stmtSQL, status)
%}