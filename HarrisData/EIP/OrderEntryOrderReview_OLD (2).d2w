%HTML(REVIEW) {
  %INCLUDE "setLibraryList.icl"
  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)">
%}

%HTML(CALCTAXES) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(updateTotal, "T")
  @Update_Misc_Charges (profileHandle, dataBaseID, orderControlNumber, freightCharge, specialCharge, updateTotal)
  @Set_SQL(stmtSQL)
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(updateTotal, "Y")
  @Update_Misc_Charges (profileHandle, dataBaseID, orderControlNumber, freightCharge, specialCharge, updateTotal)
  @Set_SQL(stmtSQL)
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(updateTotal, "T")
  @Update_Misc_Charges (profileHandle, dataBaseID, orderControlNumber, freightCharge, specialCharge, updateTotal)
  @dtw_assign(maintenanceCode, "")
  @Process_Order (profileHandle, dataBaseID, orderControlNumber, orderNumber, maintenanceCode)
  %if (maintenanceCode == "A")
      @dtw_assign(confMessage, "Confirm Addition Of Order Number $(orderNumber)")
  %elif (maintenanceCode == "N" && orderNumber == "0")
      @dtw_assign(confMessage, "Order Not Added - Had No Line Items")
  %elif (maintenanceCode == "N")
      @dtw_assign(confMessage, "Order Number $(orderNumber) Deleted - Had No Line Items")
  %else
      @dtw_assign(confMessage, "Confirm Update Of Order Number $(orderNumber)")
  %endif
  @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
  %if (backURL == "")
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)CustomerSelect.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %endif
%}

%HTML(CANCEL) {
  %INCLUDE "setLibraryList.icl"
  %if (creditCardAllowed == "X")
      @dtw_assign(edtVar, "")
      @Concat_Field("@@octl", orderControlNumber)
      @Concat_Field("@@rmcc", "Y")
      @dtw_concat(edtVar, "}{", edtVar)
      @Update_Credit_Card(profileHandle, dataBaseID, errFound, edtVar, errVar)
  %endif
  @dtw_assign(maintenanceCode, "D")
  @dtw_assign(confMessage, "Confirm Cancel Of Order")
  @Process_Order (profileHandle, dataBaseID, orderControlNumber, orderNumber, maintenanceCode)
  @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
  %if (backURL == "")
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)CustomerSelect.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %endif
%}

%HTML(NOUPDATE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(maintenanceCode, "D")
  @dtw_assign(confMessage, "Confirm No Update Of Order Number $(orderNumber)")
  @Process_Order (profileHandle, dataBaseID, orderControlNumber, orderNumber, maintenanceCode)
  @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
  %if (backURL == "")
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)CustomerSelect.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %endif
%}

%HTML(CHGREQDATE) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Update OEDTWK Set O1RQDT=$(newReqDate) ", stmtSQL)
  @dtw_concat(stmtSQL, " Where O1OCTL=$(orderControlNumber) and O1ORL#=$(lineNumber) @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)
  <meta http-equiv="refresh" content="0; URL= $(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(RECALC) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(updateTotal, "R")
  @Update_Misc_Charges (profileHandle, dataBaseID, orderControlNumber, freightCharge, specialCharge, updateTotal)
  <meta http-equiv="refresh" content="0; URL= $(homeURL)$(cGIPath)$(d2wName)/REVIEW$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(SETPRINTACK) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Update OEHDWK Set H1OEF=SUBSTRING(H1OEF, 1, 2) || '1' || SUBSTRING(H1OEF, 4, 16)", stmtSQL)
  @dtw_concat(stmtSQL, " Where H1OCTL=$(orderControlNumber) @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)
  <meta http-equiv="refresh" content="0; URL= $(homeURL)$(cGIPath)$(d2wName)/REVIEW$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(REMOVELINE) {
  %INCLUDE "setLibraryList.icl"
  @Remove_Line (profileHandle, dataBaseID, orderControlNumber, lineNumber)
  @dtw_assign(updateTotal, "Y")
  @Update_Misc_Charges (profileHandle, dataBaseID, orderControlNumber, freightCharge, specialCharge, updateTotal)
  @Set_SQL(stmtSQL)
%}

%HTML(REMOVESEL) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(x, "001")
  %while(x <= "999"){
     %while(@dtw_rlength(x) != "3") {@dtw_insert("0", x, x)%}
     @dtw_assign(ln, "ln$(x)")
     %if ($($(ln)) == "Y")
         @Remove_Line (profileHandle, dataBaseID, orderControlNumber, x)
     %endif
     @dtw_add(x, "1", x)
  %}
  @DTW_ASSIGN(updateTotal, "Y")
  @Update_Misc_Charges (profileHandle, dataBaseID, orderControlNumber, freightCharge, specialCharge, updateTotal)
  <meta http-equiv="refresh" content="0; URL= $(homeURL)$(cGIPath)$(d2wName)/REVIEW$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(CHGPO) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Update OEDTWK Set O1GNPO='$(genPO)' ", stmtSQL)
  @dtw_concat(stmtSQL, " Where O1OCTL=$(orderControlNumber) and O1ORL#=$(lineNumber) @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)

  %INCLUDE "stmtSQLClear.icl"
  %if (genPO == "Y" && poNumber == "0")
      @RtvFldDesc("VCVCF='C' and VCVNCS=$(customerNumber) and VCITEM='$(itemNumber)'", "HDVCIT", "coalesce(VCADS,' ')", VCADS)
      %if (VCADS == "N")
          @dtw_assign(dshp, "N")
      %else
          @dtw_assign(dshp, dropShip)
      %endif
      @dtw_concat(stmtSQL, " Insert Into OEPOWK (O5OCTL,O5PO#,O5POL#,O5ITEM,O5WH,O5DSHP,O5SHTO,O5VEND,O5QORD, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     O5COST,O5CSTO,O5ORD#,O5ORL#,O5BLKT,O5BLN#,O5EDT,O5MSHT,O5BUOM,O5PCPB) ", stmtSQL)
      @dtw_concat(stmtSQL, " Select $(orderControlNumber),0,0,O1ITEM,O1WH,'$(dshp)',O1SHTO,O1VEN1,O1QORD-O1QSTD-O1QSTC, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     O1COST,' ',0,O1ORL#,O1BLKT,O1BLN#,' ',' ',' ',0 ", stmtSQL)
      @dtw_concat(stmtSQL, " From OEDTWK Where O1OCTL=$(orderControlNumber) and O1ORL#=$(lineNumber) @@endsql ", stmtSQL)
  %else
      @dtw_concat(stmtSQL, " Delete From OEPOWK Where O5OCTL=$(orderControlNumber) and O5ORL#=$(lineNumber) @@endsql", stmtSQL)
  %endif
  @SQL_Update(stmtSQL, status)

  @Update_OEPOWK(orderControlNumber, lineNumber)

  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)">
%}


%HTML(ASSIGNORDER) {
  %INCLUDE "setLibraryList.icl"
  @Assign_OrderNumber(orderControlNumber, newOrder)
  <meta http-equiv="refresh" content="0; URL= $(homeURL)$(cGIPath)OrderEntryByItem.d2w/ENTRY$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}
