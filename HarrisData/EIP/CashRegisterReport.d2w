%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Cash Register Report"
  d2wName                 = "CashRegisterReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromLocation, 3, 0) &&
                      editNum(document.Chg.toLocation, 3, 0) &&
                      editNum(document.Chg.fromOrderNumber, 8, 0) &&
                      editNum(document.Chg.toOrderNumber, 8, 0) &&
                      editNum(document.Chg.fromBillTo, 7, 0) &&
                      editNum(document.Chg.toBillTo, 7, 0) &&
                      editdate(document.Chg.fromTranDate) &&
                      editdate(document.Chg.toTranDate) &&
                      editFromToAll(document.Chg.fromLocation, document.Chg.toLocation, document.Chg.allLocation, 3) &&
                      editFromToAll(document.Chg.fromOrderNumber, document.Chg.toOrderNumber, document.Chg.allOrderNumber, 8) &&
                      editFromToAll(document.Chg.fromBillTo, document.Chg.toBillTo, document.Chg.allBillTo, 7) &&
                      editFromToAll(document.Chg.fromTranDate, document.Chg.toTranDate, document.Chg.allTranDate, "D"))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CASHREGISTERREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromLocation")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)

                                  @DecatErr_Field("@@floc", "fromLocation")     @dtw_assign(Err_N1FLOC,  fieldValue)
                                  @DecatErr_Field("@@tloc", "toLocation")       @dtw_assign(Err_N1TLOC,  fieldValue)
                                  @DecatErr_Field("@@aloc", "allLocation")      @dtw_assign(Err_N1ALOC,  fieldValue)
                                  @DecatErr_Field("@@ford", "fromOrderNumber")  @dtw_assign(Err_N1FORD,  fieldValue)
                                  @DecatErr_Field("@@tord", "toOrderNumber")    @dtw_assign(Err_N1TORD,  fieldValue)
                                  @DecatErr_Field("@@aord", "allOrderNumber")   @dtw_assign(Err_N1AORD,  fieldValue)
                                  @DecatErr_Field("@@fcus", "fromBillTo")     @dtw_assign(Err_N1FCUS,  fieldValue)
                                  @DecatErr_Field("@@tcus", "toBillTo")       @dtw_assign(Err_N1TCUS,  fieldValue)
                                  @DecatErr_Field("@@acus", "allBillTo")      @dtw_assign(Err_N1ACUS,  fieldValue)
                                  @DecatErr_Field("@@frtd", "fromTranDate")     @dtw_assign(Err_N1FRTD,  fieldValue)
                                  @DecatErr_Field("@@totd", "toTranDate")       @dtw_assign(Err_N1TOTD,  fieldValue)
                                  @DecatErr_Field("@@altd", "allTranDate")      @dtw_assign(Err_N1ALTD,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}

                                  @Decat_Field("@@floc")   @dtw_assign(V_N1FLOC,  fieldValue)
                                  @Decat_Field("@@tloc")   @dtw_assign(V_N1TLOC,  fieldValue)
                                  @Decat_Field("@@aloc")   @dtw_assign(V_N1ALOC,  fieldValue)
                                  @Decat_Field("@@ford")   @dtw_assign(V_N1FORD,  fieldValue)
                                  @Decat_Field("@@tord")   @dtw_assign(V_N1TORD,  fieldValue)
                                  @Decat_Field("@@aord")   @dtw_assign(V_N1AORD,  fieldValue)
                                  @Decat_Field("@@fcus")   @dtw_assign(V_N1FCUS,  fieldValue)
                                  @Decat_Field("@@tcus")   @dtw_assign(V_N1TCUS,  fieldValue)
                                  @Decat_Field("@@acus")   @dtw_assign(V_N1ACUS,  fieldValue)
                                  @Decat_Field("@@frtd")   @dtw_assign(V_N1FRTD,  fieldValue)
                                  @Decat_Field("@@totd")   @dtw_assign(V_N1TOTD,  fieldValue)
                                  @Decat_Field("@@altd")   @dtw_assign(V_N1ALTD,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}

                                  %if (V_N1ALOC == "ALL")
                                      @dtw_assign(checkedallLocation, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallLocation, "")
                                  %endif
                                  %if (V_N1AORD == "ALL")
                                      @dtw_assign(checkedallOrderNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallOrderNumber, "")
                                  %endif
                                  %if (V_N1ACUS == "ALL")
                                      @dtw_assign(checkedallBillTo, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallBillTo, "")
                                  %endif
                                  %if (V_N1ALTD == "ALL")
                                      @dtw_assign(checkedallTranDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallTranDate, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedallLocation, "CHECKED")
                                  @dtw_assign(checkedallOrderNumber, "CHECKED")
                                  @dtw_assign(checkedallBillTo, "CHECKED")
                                  @dtw_assign(checkedallTranDate, "CHECKED")
                              %endif
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_N1FLOC)
                              %if (textOvr == "") @SetTextOvr(Err_N1TLOC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ALOC) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Location Number</span></td>
                                  <td class="inputnmbr"><input name="fromLocation" value="$(V_N1FLOC)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)LocationSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromLocation&amp;fldDesc=flocDesc" onclick="$(searchWinVar)">$(searchImage) </a> <input name="flocDesc" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toLocation" value="$(V_N1TLOC)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)LocationSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toLocation&amp;fldDesc=tlocDesc" onclick="$(searchWinVar)">$(searchImage) </a> <input name="tlocDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allLocation" value='ALL' $(checkedallLocation) type="checkbox" onClick="if (this.checked) this.form.fromLocation.value='', this.form.toLocation.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FLOC)
                              @DspErrMsg(Err_N1TLOC)
                              @DspErrMsg(Err_N1ALOC)

                              @SetTextOvr(Err_N1FORD)
                              %if (textOvr == "") @SetTextOvr(Err_N1TORD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AORD) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Order Number</span></td>
                                  <td class="inputnmbr"><input name="fromOrderNumber" value="$(V_N1FORD)" type="text" size="8" maxlength="8"></td>
                                  <td class="inputnmbr"><input name="toOrderNumber" value="$(V_N1TORD)" type="text" size="8" maxlength="8"></td>
                                  <td class="inputalph"><input name="allOrderNumber" value='ALL' $(checkedallOrderNumber) type="checkbox" onClick="if (this.checked) this.form.fromOrderNumber.value='', this.form.toOrderNumber.value='';"></td>
                              </tr>  			
                              @DspErrMsg(Err_N1FORD)
                              @DspErrMsg(Err_N1TORD)
                              @DspErrMsg(Err_N1AORD)

                              @SetTextOvr(Err_N1FCUS)
                              %if (textOvr == "") @SetTextOvr(Err_N1TCUS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ACUS) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Bill-To Customer</span></td>
                                  <td class="inputnmbr"><input name="fromBillTo" value="$(V_N1FCUS)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromBillTo&amp;fldDesc=fbilltoName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="fbilltoName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toBillTo" value="$(V_N1TCUS)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toBillTo&amp;fldDesc=tbilltoName" onclick="$(searchWinVar)">$(searchImage) </a> <input name="tbilltoName" type="hidden"></td>
                                  <td class="inputalph"><input name="allBillTo" value='ALL' $(checkedallBillTo) type="checkbox" onClick="if (this.checked) this.form.fromBillTo.value='', this.form.toBillTo.value='';"></td>
                              </tr>  			
                              @DspErrMsg(Err_N1FCUS)
                              @DspErrMsg(Err_N1TCUS)
                              @DspErrMsg(Err_N1ACUS)

                              @SetTextOvr(Err_N1FRTD)
                              %if (textOvr == "") @SetTextOvr(Err_N1TOTD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ALTD) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Transaction Date</span></td>
                                  <td class="inputnmbr"><input name="fromTranDate" value="$(V_N1FRTD)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromTranDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toTranDate" value="$(V_N1TOTD)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toTranDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allTranDate" value='ALL' $(checkedallTranDate) type="checkbox" onClick="if (this.checked) this.form.fromTranDate.value='', this.form.toTranDate.value='';"></td>
                              </tr>  			
                              @DspErrMsg(Err_N1FRTD)
                              @DspErrMsg(Err_N1TOTD)
                              @DspErrMsg(Err_N1ALTD)
                          </table>

                          @dtw_assign(envProgram, "HOECRR")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HOESCR_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allLocation)
  @dtw_mUPPERCASE(allOrderNumber)
  @dtw_mUPPERCASE(allBillTo)
  @dtw_mUPPERCASE(allTranDate)

  @dtw_assign(fromLocation,@dtw_rstrip(fromLocation))
  @dtw_assign(toLocation,@dtw_rstrip(toLocation))
  @dtw_assign(fromOrderNumber,@dtw_rstrip(fromOrderNumber))
  @dtw_assign(toOrderNumber,@dtw_rstrip(toOrderNumber))
  @dtw_assign(fromBillTo,@dtw_rstrip(fromBillTo))
  @dtw_assign(toBillTo,@dtw_rstrip(toBillTo))
  @dtw_assign(fromInvoiceDate,@dtw_rstrip(fromTranDate))
  @dtw_assign(toInvoiceDate,@dtw_rstrip(toTranDate))

  %if (allLocation != "ALL")
      @dtw_assign(allLocation, "")
  %endif

  %if (allOrderNumber != "ALL")
      @dtw_assign(allOrderNumber, "")
  %endif

  %if (allBillTo != "ALL")
      @dtw_assign(allBillTo, "")
  %endif

  %if (allTranDate != "ALL")
      @dtw_assign(allTranDate, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@floc", fromLocation)
  @Concat_Field("@@tloc", toLocation)
  @Concat_Field("@@aloc", allLocation)
  @Concat_Field("@@ford", fromOrderNumber)
  @Concat_Field("@@tord", toOrderNumber)
  @Concat_Field("@@aord", allOrderNumber)
  @Concat_Field("@@fcus", fromBillTo)
  @Concat_Field("@@tcus", toBillTo)
  @Concat_Field("@@acus", allBillTo)
  @Concat_Field("@@frtd", fromTranDate)
  @Concat_Field("@@totd", toTranDate)
  @Concat_Field("@@altd", allTranDate)
  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}