%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Backorder Analysis Report"
  d2wName                 = "BackorderAnalysisReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromWarehouse, 3, 0) &&
                      editNum(document.Chg.toWarehouse, 3, 0) &&
                      editNum(document.Chg.fromBillTo, 7, 0) &&
                      editNum(document.Chg.toBillTo, 7, 0) &&
                      editNum(document.Chg.fromVendorNumber, 7, 0) &&
                      editNum(document.Chg.toVendorNumber, 7, 0) &&
                      editNum(document.Chg.fromOrderNumber, 8, 0) &&
                      editNum(document.Chg.toOrderNumber, 8, 0) &&
                      editdate(document.Chg.fromRequiredDate) &&
                      editdate(document.Chg.toRequiredDate) &&
                      editFromToAll(document.Chg.fromWarehouse, document.Chg.toWarehouse, document.Chg.allWarehouse, 3) &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromBillTo, document.Chg.toBillTo, document.Chg.allBillTo, 7) &&
                      editFromToAll(document.Chg.fromVendorNumber, document.Chg.toVendorNumber, document.Chg.allVendorNumber, 7) &&
                      editFromToAll(document.Chg.fromOrderNumber, document.Chg.toOrderNumber, document.Chg.allOrderNumber, 8) &&
                      editFromToAll(document.Chg.fromRequiredDate,  document.Chg.toRequiredDate, document.Chg.allRequiredDate, "D"))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "BACKORDERANALYSISREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromWarehouse")

                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)

                                  @DecatErr_Field("@@comb", "combineWhs")     @dtw_assign(Err_N1COMB,  fieldValue)
                                  @DecatErr_Field("@@fwhs", "fromWarehouse")       @dtw_assign(Err_N2FWHS, fieldValue)
                                  @DecatErr_Field("@@twhs", "toWarehouse")         @dtw_assign(Err_N2TWHS, fieldValue)
                                  @DecatErr_Field("@@awhs", "allWarehouse")        @dtw_assign(Err_N21AWH, fieldValue)
                                  @DecatErr_Field("@@fitm", "fromItemNumber")          @dtw_assign(Err_N2FITM,  fieldValue)
                                  @DecatErr_Field("@@titm", "toItemNumber")            @dtw_assign(Err_N2TITM,  fieldValue)
                                  @DecatErr_Field("@@aitm", "allItemNumber")           @dtw_assign(Err_N2AITM,  fieldValue)
                                  @DecatErr_Field("@@fcus", "fromBillTo")         @dtw_assign(Err_N2FCUS, fieldValue)
                                  @DecatErr_Field("@@tcus", "toBillTo")           @dtw_assign(Err_N2TCUS, fieldValue)
                                  @DecatErr_Field("@@acus", "allBillTo")          @dtw_assign(Err_N2ACUS, fieldValue)
                                  @DecatErr_Field("@@fvnd", "fromVendorNumber")    @dtw_assign(Err_N2FVND, fieldValue)
                                  @DecatErr_Field("@@tvnd", "toVendorNumber")      @dtw_assign(Err_N2TVND, fieldValue)
                                  @DecatErr_Field("@@avnd", "allVendorNumber")     @dtw_assign(Err_N2AVND, fieldValue)
                                  @DecatErr_Field("@@fpo@", "fromOrderNumber")    @dtw_assign(Err_N2FPO, fieldValue)
                                  @DecatErr_Field("@@tpo@", "toOrderNumber")      @dtw_assign(Err_N2TPO, fieldValue)
                                  @DecatErr_Field("@@apo@", "allOrderNumber")     @dtw_assign(Err_N2APO, fieldValue)
                                  @DecatErr_Field("@@frqd", "fromRequiredDate")    @dtw_assign(Err_N2FRQD, fieldValue)
                                  @DecatErr_Field("@@trqd", "toRequiredDate")      @dtw_assign(Err_N2TRQD, fieldValue)
                                  @DecatErr_Field("@@arqd", "allRequiredDate")     @dtw_assign(Err_N2ARQD, fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}

                                  @Decat_Field("@@comb")   @dtw_assign(V_N1COMB,  fieldValue)
                                  @Decat_Field("@@fwhs")   @dtw_assign(V_N2FWHS, fieldValue)
                                  @Decat_Field("@@twhs")   @dtw_assign(V_N2TWHS, fieldValue)
                                  @Decat_Field("@@awhs")   @dtw_assign(V_N2AWHS, fieldValue)
                                  @Decat_Field("@@fitm")   @dtw_assign(V_N2FITM, fieldValue)
                                  @Decat_Field("@@titm")   @dtw_assign(V_N2TITM, fieldValue)
                                  @Decat_Field("@@aitm")   @dtw_assign(V_N2AITM, fieldValue)
                                  @Decat_Field("@@fcus")   @dtw_assign(V_N2FCUS, fieldValue)
                                  @Decat_Field("@@tcus")   @dtw_assign(V_N2TCUS, fieldValue)
                                  @Decat_Field("@@acus")   @dtw_assign(V_N2ACUS, fieldValue)
                                  @Decat_Field("@@fvnd")   @dtw_assign(V_N2FVND, fieldValue)
                                  @Decat_Field("@@tvnd")   @dtw_assign(V_N2TVND, fieldValue)
                                  @Decat_Field("@@avnd")   @dtw_assign(V_N2AVND, fieldValue)
                                  @Decat_Field("@@fpo@")   @dtw_assign(V_N2FPO, fieldValue)
                                  @Decat_Field("@@tpo@")   @dtw_assign(V_N2TPO, fieldValue)
                                  @Decat_Field("@@apo@")   @dtw_assign(V_N2APO, fieldValue)
                                  @Decat_Field("@@frqd")   @dtw_assign(V_N2FRQD, fieldValue)
                                  @Decat_Field("@@trqd")   @dtw_assign(V_N2TRQD, fieldValue)
                                  @Decat_Field("@@arqd")   @dtw_assign(V_N2ARQD, fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}

                                  %if (V_N1COMB == "02")
                                      @dtw_assign(combNo, "")
                                      @dtw_assign(combYes, "CHECKED")
                                  %else
                                      @dtw_assign(combNo, "CHECKED")
                                      @dtw_assign(combYes, "")
                                  %endif
                                  %if (V_N2AWHS == "ALL")
                                      @dtw_assign(checkedallWarehouse, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallWarehouse, "")
                                  %endif
                                  %if (V_N2AITM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_N2ACUS == "ALL")
                                      @dtw_assign(checkedallBillTo, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallBillTo, "")
                                  %endif
                                  %if (V_N2AVND == "ALL")
                                      @dtw_assign(checkedallVendorNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallVendorNumber, "")
                                  %endif
                                  %if (V_N2APO == "ALL")
                                      @dtw_assign(checkedallOrderNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallOrderNumber, "")
                                  %endif
                                  %if (V_N2ARQD == "ALL")
                                      @dtw_assign(checkedallRequiredDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallRequiredDate, "")
                                  %endif
                              %else
                                  @dtw_assign(combNo, "CHECKED")
                                  @dtw_assign(combYes, "")
                                  @dtw_assign(checkedallWarehouse, "CHECKED")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallBillTo, "CHECKED")
                                  @dtw_assign(checkedallVendorNumber, "CHECKED")
                                  @dtw_assign(checkedallOrderNumber, "CHECKED")
                                  @dtw_assign(checkedallRequiredDate, "CHECKED")
                              %endif

                              @SetTextOvr(Err_N1COMB)
                              <tr><td  class="dsphdr"><span $(textOvr)>Combine All Warehouses</span></td>
                                  <td class="inputnmbr"><input name="combineWhs" type="radio" VALUE='01' $(combNo)>No</td>
                              </tr>
                              @DspErrMsg(Err_N1COMB)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="combineWhs" type="radio" VALUE='02' $(combYes)>Yes</td>
                              </tr>

                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_N2FWHS)
                              %if (textOvr == "") @SetTextOvr(Err_N2TWHS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2AWHS) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Warehouse Number</span></td>
                                  <td class="inputnmbr"><input name="fromWarehouse" value="$(V_N2FWHS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromWarehouse&amp;fldDesc=warehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="warehouseName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toWarehouse" value="$(V_N2TWHS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toWarehouse&amp;fldDesc=warehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="warehouseName" type="hidden"></td>
                                  <td class="inputalph"><input name="allWarehouse" value='ALL' $(checkedallWarehouse) type="checkbox" onClick="if (this.checked) this.form.fromWarehouse.value='', this.form.toWarehouse.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N2FWHS)
                              @DspErrMsg(Err_N2TWHS)
                              @DspErrMsg(Err_N2AWHS)

                              @SetTextOvr(Err_N2FITM)
                              %if (textOvr == "") @SetTextOvr(Err_N2TITM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2AITM) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputnmbr"><input name="fromItemNumber" value="$(V_N2FITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=itemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="itemDescription" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toItemNumber" value="$(V_N2TITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=itemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="itemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N2FITM)
                              @DspErrMsg(Err_N2TITM)
                              @DspErrMsg(Err_N2AITM)

                              @SetTextOvr(Err_N2FCUS)
                              %if (textOvr == "") @SetTextOvr(Err_N2TCUS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2ACUS) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Bill-To Customer</span></td>
                                  <td class="inputnmbr"><input name="fromBillTo" value="$(V_N2FCUS)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromBillTo&amp;fldDesc=fbilltoName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="fbilltoName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toBillTo" value="$(V_N2TCUS)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toBillTo&amp;fldDesc=tobilltoName" onclick="$(searchWinVar)">$(searchImage) </a> <input name="tobilltoName" type="hidden"></td>
                                  <td class="inputalph"><input name="allBillTo" value='ALL' $(checkedallBillTo) type="checkbox" onClick="if (this.checked) this.form.fromBillTo.value='', this.form.toBillTo.value='';"></td>
                              </tr>  			
                              @DspErrMsg(Err_N2FCUS)
                              @DspErrMsg(Err_N2TCUS)
                              @DspErrMsg(Err_N2ACUS)

                              @SetTextOvr(Err_N2FVND)
                              %if (textOvr == "") @SetTextOvr(Err_N2TVND) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2AVND) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Vendor Number</span></td>
                                  <td class="inputnmbr"><input name="fromVendorNumber" value="$(V_N2FVND)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="vendorName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toVendorNumber" value="$(V_N2TVND)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="vendorName" type="hidden"></td>
                                  <td class="inputalph"><input name="allVendorNumber" value='ALL' $(checkedallVendorNumber) type="checkbox" onClick="if (this.checked) this.form.fromVendorNumber.value='', this.form.toVendorNumber.value='';"></td>
                              </tr>  			
                              @DspErrMsg(Err_N2FVND)
                              @DspErrMsg(Err_N2TVND)
                              @DspErrMsg(Err_N2AVND)

                              @SetTextOvr(Err_N2FPO)
                              %if (textOvr == "") @SetTextOvr(Err_N2TPO) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2APO) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Purchase Order Number</span></td>
                                  <td class="inputnmbr"><input name="fromOrderNumber" value="$(V_N2FPO)" type="text" size="8" maxlength="8"></td>
                                  <td class="inputnmbr"><input name="toOrderNumber" value="$(V_N2TPO)" type="text" size="8" maxlength="8"></td>
                                  <td class="inputalph"><input name="allOrderNumber" value='ALL' $(checkedallOrderNumber) type="checkbox" onClick="if (this.checked) this.form.fromOrderNumber.value='', this.form.toOrderNumber.value='';"></td>
                              </tr>  			
                              @DspErrMsg(Err_N2FPO)
                              @DspErrMsg(Err_N2TPO)
                              @DspErrMsg(Err_N2APO)

                              @SetTextOvr(Err_N2FRQD)
                              %if (textOvr == "") @SetTextOvr(Err_N2TRQD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2ARQD) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Required Date</span></td>
                               <td class="inputnmbr"><input name="fromRequiredDate" value="$(V_N2FRQD)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromRequiredDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toRequiredDate" value="$(V_N2TRQD)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toRequiredDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allRequiredDate" value='ALL' $(checkedallRequiredDate) type="checkbox" onClick="if (this.checked) this.form.fromRequiredDate.value='', this.form.toRequiredDate.value='';"></td>
                              </tr>  			
                              @DspErrMsg(Err_N2FRQD)
                              @DspErrMsg(Err_N2TRQD)
                              @DspErrMsg(Err_N2ARQD)
                          </table>

                          @dtw_assign(envProgram, "HOEBAR")
                          @dtw_assign(envPrinter, "HOEBARPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HOEBAS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allWarehouse)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(allBillTo)
  @dtw_mUPPERCASE(allVendorNumber)
  @dtw_mUPPERCASE(allOrderNumber)
  @dtw_mUPPERCASE(allRequiredDate)

  @dtw_assign(fromWarehouse,@dtw_rstrip(fromWarehouse))
  @dtw_assign(toWarehouse,@dtw_rstrip(toWarehouse))
  @dtw_assign(fromBillTo,@dtw_rstrip(fromBillTo))
  @dtw_assign(toBillTo,@dtw_rstrip(toBillTo))
  @dtw_assign(fromVendorNumber,@dtw_rstrip(fromVendorNumber))
  @dtw_assign(toVendorNumber,@dtw_rstrip(toVendorNumber))
  @dtw_assign(fromOrderNumber,@dtw_rstrip(fromOrderNumber))
  @dtw_assign(toOrderNumber,@dtw_rstrip(toOrderNumber))
  @dtw_assign(fromRequiredDate,@dtw_rstrip(fromRequiredDate))
  @dtw_assign(toRequiredDate,@dtw_rstrip(toRequiredDate))

  %if (allWarehouse != "ALL")
      @dtw_assign(allWarehouse, "")
  %endif

  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif

  %if (allBillTo != "ALL")
      @dtw_assign(allBillTo, "")
  %endif

  %if (allVendorNumber != "ALL")
      @dtw_assign(allVendorNumber, "")
  %endif

  %if (allOrderNumber != "ALL")
      @dtw_assign(allOrderNumber, "")
  %endif

  %if (allRequiredDate != "ALL")
      @dtw_assign(allRequiredDate, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@comb", combineWhs)
  @Concat_Field("@@fwhs", fromWarehouse)
  @Concat_Field("@@twhs", toWarehouse)
  @Concat_Field("@@awhs", allWarehouse)
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@fcus", fromBillTo)
  @Concat_Field("@@tcus", toBillTo)
  @Concat_Field("@@acus", allBillTo)
  @Concat_Field("@@fvnd", fromVendorNumber)
  @Concat_Field("@@tvnd", toVendorNumber)
  @Concat_Field("@@avnd", allVendorNumber)
  @Concat_Field("@@fpo@", fromOrderNumber)
  @Concat_Field("@@tpo@", toOrderNumber)
  @Concat_Field("@@apo@", allOrderNumber)
  @Concat_Field("@@frqd", fromRequiredDate)
  @Concat_Field("@@trqd", toRequiredDate)
  @Concat_Field("@@arqd", allRequiredDate)
  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}