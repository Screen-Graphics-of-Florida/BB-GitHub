%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title 		= "Check History"
  d2wName              = "EmployeePayHistory.d2w"
  d2wVarBase           = "$(genericVarBase)$(employeeVarBase)&amp;processingReference=@dtw_rurlescseq(processingReference)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar          = "$(d2wVarBase)"
  wildDftVar           = "REPORT$(d2wVarBase)"
  programName          = "HPRCHI"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  DTW_PAD_PGM_PARMS    = "YES"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext		= "1"
  totalPages		= "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
   @dtw_replace(workURL, "@@processingReference", "@dtw_rurlescseq(processingReference)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @dtw_assign(applicationID, "PR")
  %INCLUDE "EmplUV.icl"
  @dtw_assign(prUserPass, userPass)

  %if (prUserPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function goToPage(selectedPage) {if (selectedPage != "") {self.location=selectedPage;}}
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "EMPLOYEEPAYHISTORY")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, "Select EHCOMP, EHFACL, EHEMPL, EHCKDT, EHCKNO, EHRCCD, EHRSP, EHNETP, EHPPDT, EHCKTY, EHPREF, EMCOMP, EMFACL, EMEMPL, EMDEPT, EMLOC, EMTYPE", stmtSQL)
                          @dtw_concat(fileSQL, " PRCKHS INNER JOIN HREMPL ON EHCOMP=EMCOMP AND EHFACL=EMFACL AND EHEMPL=EMEMPL ", fileSQL)
                          @dtw_concat(selectSQL, " (EHCOMP=$(prCompany) and EHFACL=$(prFacility) and EHEMPL=$(prEmployee))", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Pay_History_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- Start Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Pay_History_Query (IN CHAR(64)    profileHandle,
				          CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(genericVarBase)&amp;prCompany=@dtw_rurlescseq(prCompany)&amp;prFacility=@dtw_rurlescseq(prFacility)&amp;prEmployee=@dtw_rurlescseq(prEmployee)&amp;hrCompany=@dtw_rurlescseq(hrCompany)&amp;hrEmployee=@dtw_rurlescseq(hrEmployee)&amp;backHome=@dtw_rurlescseq(backHome)" title="Return To Employee">$(portalHome)</a>
                      %endif
                      <a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(genericVarBase)&amp;prCompany=@dtw_rurlescseq(prCompany)&amp;prFacility=@dtw_rurlescseq(prFacility)&amp;prEmployee=@dtw_rurlescseq(prEmployee)&amp;hrCompany=@dtw_rurlescseq(hrCompany)&amp;hrEmployee=@dtw_rurlescseq(hrEmployee)&amp;orderBy=@dtw_rurlescseq(orderBy)&amp;formatToPrint=Y&amp;backHome=@dtw_rurlescseq(backHome)" target=_blank>$(formatPrintDesc)</a>
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>

          @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
          <tr><td><h2>$(F_EmpName)</h2></td></tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"	
      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <table $(contentTable)>
              <tr><td> %INCLUDE "AssignPageValue.icl" </td>
          </table>
      %endif

      <table $(contentTable)>
          <tr>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("EHCKDT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CheckDate" title="Sequence By Check Date"> Check<br>Date</a></th>
              @OrderBy_Sort("EHCKNO", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CheckNumber" title="Sequence By Check Number"> Check<br>Number</a></th>
              @OrderBy_Sort("EHRCCD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Type" title="Sequence By Type"> Type</a></th>	
              @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMTYPE", PAYTYPECODE)
              %if ((sec_06 == "Y" && PAYTYPECODE == "H") || (sec_07 == "Y" && PAYTYPECODE != "H"))
                  @OrderBy_Sort("EHRSP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=GrossPay" title="Sequence By Gross Pay"> Gross Pay</a></th>
                  @OrderBy_Sort("EHNETP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=NetPay" title="Sequence By Net Pay"> Net Pay</a></th>
              %endif
              @OrderBy_Sort("EHPPDT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PayPeriod" title="Sequence By Pay Period End Date"> Pay Period<br>End Date</a></th>
          </tr>		
          %INCLUDE "NoRecordsFound.icl"
          %ROW{
              %if( V_EHCKTY == "1")
                  @dtw_assign(checkType, "Void")
              %elif(V_EHCKTY == "2")
                  @dtw_assign(checkType, "Manual")
              %elif(V_EHCKTY == "3")
                  @dtw_assign(checkType, "Regular")
              %else
                  @dtw_assign(checkType, "401(k)")
              %endif

              @Format_Date(V_EHCKDT, "D", F_EHCKDT)
              @Format_Date(V_EHPPDT, "D", F_EHPPDT)

              %INCLUDE "SetRowClass.icl"
	       <tr class="$(rowClass)">
                  <td class="coldate">$(F_EHCKDT)</td>
                  %if ((sec_06 == "Y" && V_EMTYPE == "H") || (sec_07 == "Y" && V_EMTYPE != "H"))
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)employeeCheckSelect.d2w/report$(genericVarBase)&amp;prCompany=@dtw_rurlescseq(prCompany)&amp;prFacility=@dtw_rurlescseq(prFacility)&amp;prEmployee=@dtw_rurlescseq(prEmployee)&amp;hrCompany=@dtw_rurlescseq(hrCompany)&amp;hrEmployee=@dtw_rurlescseq(hrEmployee)&amp;processingReference=@dtw_rurlescseq(V_EHPREF)&amp;backHome=@dtw_rurlescseq(backHome)" title="View Check Information">$(V_EHCKNO)</a></td>
                  %else
                      <td class="coldate">$(V_EHCKNO)</td>
                  %endif
                  <td class="colcode">$(V_EHRCCD)</td>
                  %if ((sec_06 == "Y" && V_EMTYPE == "H") || (sec_07 == "Y" && V_EMTYPE != "H"))
                      @Format_Nbr($(V_EHRSP), F_EHRSP, "2", $(amtEditCode), "", "", "")
                      @Format_Nbr($(V_EHNETP), F_EHNETP, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_EHRSP)</td>
                      <td class="colnmbr">$(F_EHNETP)</td>
                  %endif
                  <td class="coldate">$(F_EHPPDT)</td>
	       </tr>
          %}
      </table>
      %if (sql_Record_Count != "1")
          %INCLUDE "PageBottom.icl"
          $(hrTagAttr)
          %INCLUDE "Copyright.icl"
      %endif
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "EHCKDT,EHCKNO DESC")
              @DTW_ASSIGN(orderByDisplay, "Check Date, Check Number (descending)")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "CheckDate")
      %if (orderBy == "EHCKDT,EHCKNO DESC")
          @DTW_ASSIGN(orderBy, "EHCKDT DESC,EHCKNO DESC")
          @DTW_ASSIGN(orderByDisplay, "Check Date (descending), Check Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "EHCKDT,EHCKNO DESC")
          @DTW_ASSIGN(orderByDisplay, "Check Date, Check Number (descending)")
      %endif
  %elif (sequence == "CheckNumber")
      %if (orderBy == "EHCKNO,EHCKDT DESC")
          @DTW_ASSIGN(orderBy, "EHCKNO DESC,EHCKDT DESC")
          @DTW_ASSIGN(orderByDisplay, "Check Number (descending), Check Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "EHCKNO,EHCKDT DESC")
          @DTW_ASSIGN(orderByDisplay, "Check Number, Check Date (descending)")
      %endif
  %elif (sequence == "Type")
      %if (orderBy == "EHRCCD,EHCKDT DESC,EHCKNO DESC")
          @DTW_ASSIGN(orderBy, "EHRCCD DESC,EHCKDT DESC,EHCKNO DESC")
          @DTW_ASSIGN(orderByDisplay, "Type (descending), Check Date (descending), Check Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "EHRCCD,EHCKDT DESC,EHCKNO DESC")
          @DTW_ASSIGN(orderByDisplay, "Type, Check Date (descending), Check Number (descending)")
      %endif
  %elif (sequence == "GrossPay")
      %if (orderBy == "EHRSP,EHCKDT DESC,EHCKNO DESC")
          @DTW_ASSIGN(orderBy, "EHRSP DESC,EHCKDT DESC,EHCKNO DESC")
          @DTW_ASSIGN(orderByDisplay, "Gross Pay (descending), Check Date (descending), Check Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "EHRSP,EHCKDT DESC,EHCKNO DESC")
          @DTW_ASSIGN(orderByDisplay, "Gross Pay, Check Date (descending), Check Number (descending)")
      %endif
  %elif (sequence == "NetPay")
      %if (orderBy == "EHNETP,EHCKDT DESC,EHCKNO DESC")
          @DTW_ASSIGN(orderBy, "EHNETP DESC,EHCKDT DESC,EHCKNO DESC")
          @DTW_ASSIGN(orderByDisplay, "Net Pay (descending), Check Date (descending), Check Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "EHNETP,EHCKDT DESC,EHCKNO DESC")
          @DTW_ASSIGN(orderByDisplay, "Net Pay, Check Date (descending), Check Number (descending)")
      %endif
  %elif (sequence == "PayPeriod")
      %if (orderBy == "EHPPDT,EHCKDT DESC,EHCKNO DESC")
          @DTW_ASSIGN(orderBy, "EHPPDT DESC,EHCKDT DESC,EHCKNO DESC")
          @DTW_ASSIGN(orderByDisplay, "Pay Period End Date (descending), Check Date (descending), Check Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "EHPPDT,EHCKDT DESC,EHCKNO DESC")
          @DTW_ASSIGN(orderByDisplay, "Pay Period End Date, Check Date (descending), Check Number (descending)")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}