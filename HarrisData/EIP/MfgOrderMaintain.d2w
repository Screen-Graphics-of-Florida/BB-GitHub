%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Manufacturing Order Maintenance"
  d2wName                 = "MfgOrderMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;plantNunmber=@dtw_rurlescseq(plantNunmber)&amp;mfgOrder=@dtw_rurlescseq(mfgOrder)&amp;maintenanceCode=D"
  programName             = "HSI205"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  fldreleased             = "Y"
  itemNumber              = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %if (maintenanceCode == "C")	
      @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %else
      @dtw_assign(userPass, "")
  %endif

  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  function validate(chgForm) {
                      if (document.Chg.plantNumber.value =="" ||
                          document.Chg.itemNumber.value =="" ||
                          document.Chg.orderQty.value =="")
                         {alert("$(reqFieldError)"); return false;}
                      if (editNum(document.Chg.plantNumber, 3, 0) &&
                          editNum(document.Chg.orderQty, 9, 4) &&
                          editNum(document.Chg.dueDate, 6, 0) &&
                          editdate(document.Chg.dueDate) &&
                          editNum(document.Chg.startDate, 6, 0) &&
                          editdate(document.Chg.startDate) &&
                          editNum(document.Chg.unitPrice, 7, 5) &&
                          editNum(document.Chg.unitCost, 7, 5) &&
                          editNum(document.Chg.mgtPriority, 2, 1) &&
                          editNum(document.Chg.analyst, 7, 0) &&
                          editNum(document.Chg.slsOrder, 8, 0) &&
                          editNum(document.Chg.slsLine, 3, 0) &&
                          editNum(document.Chg.slsRelease, 3, 0))
                          return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
                  %INCLUDE "calendar.icl"
                  %INCLUDE "dateedit.icl"
                  %INCLUDE "Menu.js"
                  %INCLUDE "NumEdit.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "MFGORDERMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "SELECT OHSTC, OHPLT, OHORD, OHPN, OHOTYP, OHHLDC, OHHLDT, OHRELD, OHOSDT, OHODDT, OHCSDT, OHCDDT, OHOQTY, OHCQTY, OHFLDT, OHFRDT, OHLRDT, OHLADT, OHLATY, OHFTDT, OHQTYR, OHNRCP, OHRSCR, OHECN, OHDWGR, OHRORD, OHPAPS, OHMGTP, coalesce(O2UNIT,'0') as O2UNIT, OHBAC, OHPRIC, OHDELD, OHORDT, OHORD#, OHORL#, OHBLN#, OHORDO, OHPAS, OHPTOV, OHORTN, OHFTTN, OHREWK, OHTSUS, OHTSWS, OHTSTP, OHTSPT, OHCPNS, OHCFGT, OHCFGI, OHFREL, OHSEQN, OHODTA   FROM HDMOHM Left Join HDMOHME on OHPLT=O2PLT and OHORD=O2ORD and OHSEQN=O2SEQN WHERE OHPLT = $(plantNumber) and OHORD = '$(mfgOrder)'", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=445")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A" && reDisplay == "")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "plantNumber")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@plt@", "plantNumber")         @dtw_assign(Err_OHPLT,  fieldValue)
                          @DecatErr_Field("@@ord@", "mfgOrder")            @dtw_assign(Err_OHORD,  fieldValue)
                          @DecatErr_Field("@@pn@@", "itemNumber")          @dtw_assign(Err_OHPN,   fieldValue)
                          @DecatErr_Field("@@cqty", "orderQty")            @dtw_assign(Err_OHCQTY, fieldValue)
                          @DecatErr_Field("@@cddt", "dueDate")             @dtw_assign(Err_OHCDDT, fieldValue)
                          @DecatErr_Field("@@csdt", "startDate")           @dtw_assign(Err_OHCSDT, fieldValue)

                          @DecatErr_Field("@@frel", "forceRelease")        @dtw_assign(Err_OHFREL, fieldValue)
                          @DecatErr_Field("@@firm", "firmPlanned")         @dtw_assign(Err_OHFIRM, fieldValue)
                          @DecatErr_Field("@@hldc", "holdCode")            @dtw_assign(Err_OHHLDC, fieldValue)

                          @DecatErr_Field("@@rord", "refNumber")           @dtw_assign(Err_OHRORD, fieldValue)
                          @DecatErr_Field("@@otyp", "orderType")           @dtw_assign(Err_OHOTYP, fieldValue)
                          @DecatErr_Field("@@pric", "unitPrice")           @dtw_assign(Err_OHPRIC, fieldValue)
                          @DecatErr_Field("@@unit", "unitCost")            @dtw_assign(Err_O2UNIT, fieldValue)
                          @DecatErr_Field("@@dwgr", "dwgRevision")         @dtw_assign(Err_OHDWGR, fieldValue)
                          @DecatErr_Field("@@mgtp", "mgtPriority")         @dtw_assign(Err_OHMGTP, fieldValue)
                          @DecatErr_Field("@@bac@", "analyst")             @dtw_assign(Err_OHBAC,  fieldValue)
                          @DecatErr_Field("@@paps", "paperSW")             @dtw_assign(Err_OHPAPS, fieldValue)
                          @DecatErr_Field("@@ord#", "slsOrder")            @dtw_assign(Err_OHORD#, fieldValue)
                          @DecatErr_Field("@@orl#", "slsLine")             @dtw_assign(Err_OHORL#, fieldValue)
                          @DecatErr_Field("@@bln#", "slsRelease")          @dtw_assign(Err_OHBLN#, fieldValue)
                          @DecatErr_Field("@@cfgt", "configType")          @dtw_assign(Err_OHCFGT, fieldValue)
                          @DecatErr_Field("@@cfgi", "configID")            @dtw_assign(Err_OHCFGI, fieldValue)
                      %endif

                      @Decat_Field("@@plt@")   @dtw_assign(V_OHPLT,  fieldValue)
                      @Decat_Field("@@ord@")   @dtw_assign(V_OHORD,  fieldValue)
                      @Decat_Field("@@pn@@")   @dtw_assign(V_OHPN,   fieldValue)
                      @Decat_Field("@@cqty")   @dtw_assign(V_OHCQTY, fieldValue)
                      @Decat_Field("@@cddt")   @dtw_assign(V_OHCDDT, fieldValue)
                      @Decat_Field("@@csdt")   @dtw_assign(V_OHCSDT, fieldValue)

                      @Decat_Field("@@frel")   @dtw_assign(V_OHFREL, fieldValue)
                      @Decat_Field("@@firm")   @dtw_assign(V_OHFIRM, fieldValue)
                      @Decat_Field("@@hldc")   @dtw_assign(V_OHHLDC, fieldValue)

                      @Decat_Field("@@rord")   @dtw_assign(V_OHRORD, fieldValue)
                      @Decat_Field("@@otyp")   @dtw_assign(V_OHOTYP, fieldValue)
                      @Decat_Field("@@pric")   @dtw_assign(V_OHPRIC, fieldValue)
                      @Decat_Field("@@unit")   @dtw_assign(V_O2UNIT, fieldValue)
                      @Decat_Field("@@dwgr")   @dtw_assign(V_OHDWGR, fieldValue)
                      @Decat_Field("@@mgtp")   @dtw_assign(V_OHMGTP, fieldValue)
                      @Decat_Field("@@bac@")   @dtw_assign(V_OHBAC,  fieldValue)
                      @Decat_Field("@@paps")   @dtw_assign(V_OHPAPS, fieldValue)
                      @Decat_Field("@@ord#")   @dtw_assign(V_OHORD#, fieldValue)
                      @Decat_Field("@@orl#")   @dtw_assign(V_OHORL#, fieldValue)
                      @Decat_Field("@@bln#")   @dtw_assign(V_OHBLN#, fieldValue)
                      @Decat_Field("@@cfgt")   @dtw_assign(V_OHCFGT, fieldValue)
                      @Decat_Field("@@cfgi")   @dtw_assign(V_OHCFGI, fieldValue)
                      @Decat_Field("@@laty")   @dtw_assign(V_OHLATY, fieldValue)
                      %if (errFound == "" && maintenanceCode == "A" && reDisplay == "")
                          %if (plantNumber == "")
                              @RtvDftPlant(V_OHPLT, plantName)
                          %else
                              @dtw_assign(V_OHPLT, "$(plantNumber)")
                          %endif
                          %if (V_OHPLT > "0")
                              @dtw_assign(focusField, "mfgOrder")
                          %else
                              @dtw_assign(focusField, "plantNumber")
                          %endif
                          @dtw_assign(edtVar, "")
                          @dtw_assign(V_OHORD, "")
                          @dtw_assign(V_OHPN, "$(itemNumber)")
                          @DateInputFromISO("$(dueDate)", V_OHCDDT)
                     	  @DateInputFromISO("$(startDate)", V_OHCSDT)
                          @dtw_assign(V_OHCQTY, "$(orderQty)")

                          @dtw_assign(V_OHFREL, "N")
                          @dtw_assign(V_OHFIRM, "N")
                          @dtw_assign(V_OHHLDC, "N")

                          @dtw_assign(V_OHOTYP, "S")
                          @dtw_assign(V_OHPAPS, "R")
                          @dtw_assign(V_OHORDO, "S")
                          @dtw_assign(V_OHLATY, "CR")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_OHORD, "")
                      @DateInputFromISO("$(V_OHCDDT)", V_OHCDDT)
                      @DateInputFromISO("$(V_OHCSDT)", V_OHCSDT)

                      %if ($(V_OHSTC) == "P")
                          @dtw_assign(V_OHFIRM, "Y")
                      %else
                          @dtw_assign(V_OHFIRM, "N")
                      %endif

                      @dtw_assign(V_OHORDO, "S")
                      @dtw_assign(V_OHORD#, "")
                      @dtw_assign(V_OHORL#, "")
                      @dtw_assign(V_OHBLN#, "")
                      @dtw_assign(V_OHLATY, "CR")
                      @dtw_assign(focusField, "orderQty")
                  %else
                      @DateInputFromISO("$(V_OHCDDT)", V_OHCDDT)
                      @DateInputFromISO("$(V_OHCSDT)", V_OHCSDT)

                      %if ($(V_OHSTC) == "P")
                          @dtw_assign(V_OHFIRM, "Y")
                      %else
                          @dtw_assign(V_OHFIRM, "N")
                      %endif

                      @dtw_assign(focusField, "orderQty")
                  %endif
                  %if (focusField == "")
                      @dtw_assign(focusField, "orderQty")
                  %endif

                  @RtvFldDesc("PLPLNT=$(V_OHPLT)", "HDPLNT", "PLNAME", plantName)
                  @SetTextOvr(Err_OHPLT)
                  <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                      %if (maintenanceCode == "A")
                          <td class="inputnmbr"><input name="plantNumber" type="text" value="$(V_OHPLT)" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=plantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="plantName" value="$(plantName)" type="text" size="30"></td>
                      %else
                          <td class="inputnmbr"><input name="plantNumber" type="hidden" value="$(V_OHPLT)">$(V_OHPLT) &nbsp; $(plantName)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_OHPLT)

                  @SetTextOvr(Err_OHORD)
                  <tr><td class="dsphdr"><span $(textOvr)>Order Number</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="mfgOrder" type="text" value="$(V_OHORD)" size="9" maxlength="9"></td>
                      %else
                          <td class="inputalph"><input name="mfgOrder" type="hidden" value="$(V_OHORD)">$(V_OHORD)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_OHORD)

                  @RtvFldDesc("IMITEM='$(V_OHPN)'", "HDIMST", "IMIMDS", itemdesc)
                  @SetTextOvr(Err_OHPN)
                  <tr><td class="dsphdr"><span $(textOvr)>Item Number</span></td>
                      %if (maintenanceCode == "C" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="itemNumber" type="hidden" value="$(V_OHPN)">$(V_OHPN) &nbsp; $(itemdesc)</td>
                      %else
                          <td class="inputalph"><input name="itemNumber" type="text" value="$(V_OHPN)" size="15" maxlength="15"> $(reqFieldChar) <a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=itemNumber&amp;fldDesc=itemdesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input disabled name="itemdesc" value="$(itemdesc)"  type="text" size="30"></td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_OHPN)
    	
                  @SetTextOvr(Err_OHCQTY)
                  <tr><td class="dsphdr"><span $(textOvr)>Order Quantity</span></td>
                      <td class="inputnmbr"><input name="orderQty" type="text" value="$(V_OHCQTY)" size="14" maxlength="14"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_OHCQTY)
    	
                  @SetTextOvr(Err_OHCDDT)
                  <tr><td class="dsphdr"><span $(textOvr)>Due Date</span></td>
                      <td class="inputnmbr"><input name="dueDate" type="text" value="$(V_OHCDDT)" size="6" maxlength="6"> <a href="javascript:calWindow('dueDate');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_OHCDDT)

                  @SetTextOvr(Err_OHCSDT)
                  <tr><td class="dsphdr"><span $(textOvr)>Start Date</span></td>
                      <td class="inputnmbr"><input name="startDate" type="text" value="$(V_OHCSDT)" size="6" maxlength="6"> <a href="javascript:calWindow('startDate');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_OHCSDT)
    	
                  @SetTextOvr(Err_OHFREL)
                  <tr><td class="dsphdr"><span $(textOvr)>Force Release</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_OHFREL) && (x < maxRows)) {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "forceRelease", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_OHFREL)
    	
                  @SetTextOvr(Err_OHFIRM)
                  <tr><td class="dsphdr"><span $(textOvr)>Firm Planned</span></td>
                      %if (maintenanceCode == "C")
                          @RtvFldDesc("(FLTYPE='YORN' and FLVALU='$(V_OHFIRM)')", "SYFLAG", "FLDESC", firmDesc)
                          <td class="inputalph"><input name="firmPlanned" type="hidden" value="$(V_OHFIRM)">$(firmDesc)</td>
                      %else
                          @dtw_tb_rows(yn02Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn02Table, x, "1") != V_OHFIRM) && (x < maxRows)) {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(yn02Table, "firmPlanned", "2", "1", "N", "", x, "1")</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_OHFIRM)
    	
                  @SetTextOvr(Err_OHHLDC)
                  <tr><td class="dsphdr"><span $(textOvr)>Hold Order</span></td>
                      %if (maintenanceCode == "C")
                          @RtvFldDesc("(FLTYPE='YORN' and FLVALU='$(V_OHHLDC)')", "SYFLAG", "FLDESC", hldcDesc)
                          <td class="inputalph"><input name="holdCode" type="hidden" value="$(V_OHHLDC)">$(hldcDesc)</td>
                      %else
                          @dtw_tb_rows(yn03Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn03Table, x, "1") != V_OHHLDC) && (x < maxRows)) {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(yn03Table, "holdCode", "2", "1", "N", "", x, "1")</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_OHHLDC)
    	
                  @SetTextOvr(Err_OHRORD)
                  <tr><td class="dsphdr"><span $(textOvr)>Reference Number</span></td>
                      <td class="inputalph"><input name="refNumber" type="text" value="$(V_OHRORD)" size="20" maxlength="20"></td>
                  </tr>
                  @DspErrMsg(Err_OHRORD)

    	           @RtvFldDesc("FLTYPE='MFGORDTYPE' and FLVALU='$(V_OHOTYP)'", "SYFLAG", "FLDESC", typedesc)
                  @SetTextOvr(Err_OHOTYP)
                  <tr><td class="dsphdr"><span $(textOvr)>Order Type</span></td>
                      <td class="inputalph"><input name="orderType" type="text" value="$(V_OHOTYP)" size="2" maxlength="1">  $(reqFieldChar) <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=MFGORDTYPE&amp;flagSrchHdr=@dtw_rurlescseq("Mfg Order Type")&amp;docName=Chg&amp;fldName=orderType&amp;fldDesc=typedesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="typedesc" value="$(typedesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_OHOTYP)

                  @SetTextOvr(Err_OHPRIC)
                  <tr><td class="dsphdr"><span $(textOvr)>Unit Price</span></td>
                      <td class="inputnmbr"><input name="unitPrice" type="text" value="$(V_OHPRIC)" size="14" maxlength="13"></td>
                  </tr>
                  @DspErrMsg(Err_OHPRIC)

                  @SetTextOvr(Err_O2UNIT)
                  <tr><td class="dsphdr"><span $(textOvr)>Unit Cost</span></td>
                      <td class="inputnmbr"><input type="text" name="unitCost" value="$(V_O2UNIT)" size="14" maxlength="13"></td>
                  </tr>
                  @DspErrMsg(Err_O2UNIT)

                  @SetTextOvr(Err_OHDWGR)
                  <tr><td class="dsphdr"><span $(textOvr)>Drawing Revision Number</span></td>
                      <td class="inputalph"><input name="dwgRevision" type="text" value="$(V_OHDWGR)" size="2" maxlength="2"></td>
                  </tr>
                  @DspErrMsg(Err_OHDWGR)

                  @SetTextOvr(Err_OHMGTP)
                  <tr><td class="dsphdr"><span $(textOvr)>Management Priority</span></td>
                      <td class="inputnmbr"><input type="text" name="mgtPriority" value="$(V_OHMGTP)" size="4" maxlength="4"></td>
                  </tr>
                  @DspErrMsg(Err_OHMGTP)

                  @Default_Zero(V_OHBAC)
   	           @RtvFldDesc("BMBUYR=$(V_OHBAC)", "HDBUYR", "BMBNA1", analystname)
                  @SetTextOvr(Err_OHBAC)
                  <tr><td class="dsphdr"><span $(textOvr)>Analyst</span></td>
                      <td class="inputnmbr"><input type="text" name="analyst" value="$(V_OHBAC)" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)BuyerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=analyst&amp;fldDesc=analystname&amp;buyerAnalyst=Analyst" onclick="$(searchWinVar)"> $(searchImage) </a><input name="analystname" value="$(analystname)" type="text" size="40" disabled></td>
                  </tr>
                  @DspErrMsg(Err_OHBAC)

    	           @RtvFldDesc("FLTYPE='PAPERSW' and FLVALU='$(V_OHPAPS)'", "SYFLAG", "FLDESC", switchdesc)
                  @SetTextOvr(Err_OHPAPS)
                  <tr><td class="dsphdr"><span $(textOvr)>Print Status</span></td>
                      <td class="inputalph"><input name="paperSW" type="text" value="$(V_OHPAPS)" size="2" maxlength="1"> $(reqFieldChar)  <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=PAPERSW&amp;flagSrchHdr=@dtw_rurlescseq("Print Status")&amp;docName=Chg&amp;fldName=paperSW&amp;fldDesc=switchdesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="switchdesc" value="$(switchdesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_OHPAPS)

                  @SetTextOvr(Err_OHORD#)
                  <tr><td class="dsphdr"><span $(textOvr)>Sales Order Number</span></td>
                      %if ($(V_OHORDO) == "O")
                          <td class="inputnmbr"><input type="hidden" name="slsOrder" value="$(V_OHORD#)" size="8" maxlength="8">$(V_OHORD#)</td>
                      %else
                          <td class="inputnmbr"><input type="text" name="slsOrder" value="$(V_OHORD#)" size="8" maxlength="8"></td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_OHORD#)

                  @SetTextOvr(Err_OHORL#)
                  <tr><td class="dsphdr"><span $(textOvr)>Sales Line Number</span></td>
                      %if ($(V_OHORDO) == "O")
                          <td class="inputnmbr"><input type="hidden" name="slsLine" value="$(V_OHORL#)" size="3" maxlength="3">$(V_OHORL#)</td>
                      %else
                          <td class="inputnmbr"><input type="text" name="slsLine" value="$(V_OHORL#)" size="3" maxlength="3"></td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_OHORL#)

                  @SetTextOvr(Err_OHBLN#)
                  <tr><td class="dsphdr"><span $(textOvr)>Sales Release Number</span></td>
                      %if ($(V_OHORDO) == "O")
                          <td class="inputnmbr"><input type="hidden" name="slsRelease" value="$(V_OHBLN#)" size="3" maxlength="3">$(V_OHBLN#)</td>
                      %else
                          <td class="inputnmbr"><input type="text" name="slsRelease" value="$(V_OHBLN#)" size="3" maxlength="3"></td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_OHBLN#)

                  @Default_Zero(V_OHPLT)
                  @dtw_assign(configdesc, "")
                  @RtvFldDesc("CHPLT=$(V_OHPLT) and CHITEM='$(V_OHPN)' and CHCFGT='$(V_OHCFGT)' and CHCFGI='$(V_OHCFGI)'", "HDCFGH", "CHCDSC", configdesc)
                  @SetTextOvr(Err_OHCFGT)
                  <tr><td class="dsphdr"><span $(textOvr)>Configuration Type / ID</span></td>
                      %if ($(V_OHLATY) != "CR" || maintenanceCode == "Z")
                          %if ($(V_OHCFGT) != "" && $(V_OHCFGI) != "")
                              <td class="inputalph"><input name="configType" type="hidden" value="$(V_OHCFGT)" size="5" maxlength="5">$(V_OHCFGT) / <input name="configID" type="hidden" value="$(V_OHCFGI)" size="5" maxlength="5">$(V_OHCFGI) <input disabled name="configdesc" value="$(configdesc)"  type="text" size="30" maxlength="30"></td>
                          %endif
                      %else
                          <td class="inputalph"><input name="configType" type="text" value="$(V_OHCFGT)" size="5" maxlength="5"> / <input name="configID" type="text" value="$(V_OHCFGI)" size="5" maxlength="5"> <a href="$(homeURL)$(cGIPath)ConfigHeaderSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldreleased=@dtw_rurlescseq(fldreleased)&amp;fldplt=@dtw_rurlescseq(V_OHPLT)&amp;flditem=@dtw_rurlescseq(V_OHPN)&amp;fldtype=configType&amp;fldid=configID&amp;fldDesc=configdesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input disabled name="configdesc" value="$(configdesc)"  type="text" size="30" maxlength="30"></td>
                      %endif
                  <input name="LastActivity" type="hidden" value="$(V_OHLATY)">
                  </tr>
                  @DspErrMsg(Err_OHCFGT)
   	   		
              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) optVar,                             	
                                        INOUT CHAR(32000) errVar,
                                        INOUT CHAR(10)    SUBR)
{%EXEC {HSI205_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @yn02_Table_Query(profileHandle, dataBaseID, "YORN      ", yn02Table)
      @yn03_Table_Query(profileHandle, dataBaseID, "YORN      ", yn03Table)
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(mfgOrder)
  @dtw_mUPPERCASE(itemNumber)
  @dtw_mUPPERCASE(refNumber)
  @dtw_mUPPERCASE(orderType)
  @dtw_mUPPERCASE(dwgRevision)
  @dtw_mUPPERCASE(paperSW)
  @dtw_mUPPERCASE(configType)
  @dtw_mUPPERCASE(configID)

  @dtw_assign(plantNumber, @dtw_rstrip(plantNumber))
  @dtw_assign(orderQty,    @dtw_rstrip(orderQty))
  @dtw_assign(dueDate,     @dtw_rstrip(dueDate))
  @dtw_assign(startDate,   @dtw_rstrip(startDate))
  @dtw_assign(unitPrice,   @dtw_rstrip(unitPrice))
  @dtw_assign(unitCost,    @dtw_rstrip(unitCost))
  @dtw_assign(mgtPriority, @dtw_rstrip(mgtPriority))
  @dtw_assign(analyst,     @dtw_rstrip(analyst))
  @dtw_assign(slsOrder,    @dtw_rstrip(slsOrder))
  @dtw_assign(slsLine,     @dtw_rstrip(slsLine))
  @dtw_assign(slsRelease,  @dtw_rstrip(slsRelease))


  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@ord@", mfgOrder)
  @Concat_Field("@@pn@@", itemNumber)
  @Concat_Field("@@cqty", orderQty)
  @Concat_Field("@@cddt", dueDate)
  @Concat_Field("@@csdt", startDate)

  @Concat_Field("@@frel", forceRelease)
  @Concat_Field("@@firm", firmPlanned)
  @Concat_Field("@@hldc", holdCode)

  @Concat_Field("@@rord", refNumber)
  @Concat_Field("@@otyp", orderType)
  @Concat_Field("@@pric", unitPrice)
  @Concat_Field("@@unit", unitCost)
  @Concat_Field("@@dwgr", dwgRevision)
  @Concat_Field("@@mgtp", mgtPriority)
  @Concat_Field("@@bac@", analyst)
  @Concat_Field("@@paps", paperSW)
  @Concat_Field("@@ord#", slsOrder)
  @Concat_Field("@@orl#", slsLine)
  @Concat_Field("@@bln#", slsRelease)
  @Concat_Field("@@cfgt", configType)
  @Concat_Field("@@cfgi", configID)
  @Concat_Field("@@pcfc", productCfgFormat)
  @Concat_Field("@@laty", LastActivity)
  @dtw_concat(edtVar, "}{", edtVar)

  @dtw_assign(SUBR, "")
  %if (maintenanceCode == "A")
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMKIT", featuredItem)
      %if (featuredItem == "F")
          @dtw_assign(SUBR, "FEATURE")
      %endif
  %endif

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, optVar, errVar, SUBR)

  @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
  %if (errFound == "")
      %if (maintenanceCode == "A")
          @EdtVarErr(profileHandle, typeValue, edtVar)
          @Decat_Field("@@ord@")   @dtw_assign(mfgOrder,  fieldValue)
          %if (featuredItem == "F")
              @dtw_assign(errVar, "$(typeReset)")
              @ErrVarErr(profileHandle, typeError, errVar)
              %if (productCfgFormat == "O")
                  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)MfgOrderFeatureOption2.d2w/INPUT$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
              %else
                  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)MfgOrderFeatureOption.d2w/INPUT$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
              %endif
          %endif
      %endif
      @Format_ConfMsg_Desc(maintenanceCode, "Mfg Order", $(mfgOrder), "in $(plantName)", $(plantNumber), "", "", confMessage)
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=445&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %elif (maintenanceCode == "D" || maintenanceCode == "P" || maintenanceCode == "X")
      @DecatErr_Field("@@plt@", "plantNumber")
      @Format_ConfMsg_Desc("", "Mfg Order", $(mfgOrder), "in $(plantName)", $(plantNumber), "<br>$(fieldValue)", "", confMessage)
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=445&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;mfgOrder=@dtw_rurlescseq(mfgOrder)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
