                              %if (textOvr == "") @SetTextOvr(Err_N2PITC) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Inventory Type</span></td>
                                  <td class="inputalph"><input name="fromInventoryType" value="$(V_N2FITC)" type="text" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)invtypesearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromInventoryType&amp;fldDesc=finventoryTypeDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="finventoryTypeDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="toInventoryType" value="$(V_N2TITC)" type="text" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)invtypesearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toInventoryType&amp;fldDesc=tinventoryTypeDesc" onclick="$(searchWinVar)">$(searchImage) </a><input name="tinventoryTypeDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="allInventoryType" value='ALL' $(checkedallInventoryType) type="checkbox" onClick="if (this.checked) this.form.fromInventoryType.value='', this.form.toInventoryType.value='';"></td>
                                  @Build_Sort_Select("sortInventoryType", "$(V_N2SITC)")
                                  <td align=center ><input name="totalInventoryType" type="checkbox" $(checkedInventoryTypeTotals) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N2FITC)
                              @DspErrMsg(Err_N2TITC)
                              @DspErrMsg(Err_N2AITC)
                              @DspErrMsg(Err_N2SITC)
                              @DspErrMsg(Err_N2PITC)

                              @SetTextOvr(Err_N2FPCL)
                              %if (textOvr == "") @SetTextOvr(Err_N2TPCL) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2APCL) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SPCL) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2PPCL) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Product Class</span></td>
                                  <td class="inputalph"><input name="fromProductClass" value="$(V_N2FPCL)" type="text" size="8" maxlength="4"><a href="$(homeURL)$(cGIPath)ProdClassSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromProductClass&amp;fldDesc=fproductClassDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="fproductClassDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="toProductClass" value="$(V_N2TPCL)" type="text" size="8" maxlength="4"><a href="$(homeURL)$(cGIPath)ProdClassSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toProductClass&amp;fldDesc=tproductClassDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="tproductClassDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allProductClass" value='ALL' $(checkedallProductClass) type="checkbox" onClick="if (this.checked) this.form.fromProductClass.value='', this.form.toProductClass.value='';"></td>
                                  @Build_Sort_Select("sortProductClass", "$(V_N2SPCL)")
                                  <td align=center ><input name="totalProductClass" type="checkbox" $(checkedProductClassTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2FPCL)
                              @DspErrMsg(Err_N2TPCL)
                              @DspErrMsg(Err_N2APCL)
                              @DspErrMsg(Err_N2SPCL)
                              @DspErrMsg(Err_N2PPCL)

                              @SetTextOvr(Err_N2FCO)
                              %if (textOvr == "") @SetTextOvr(Err_N2TCO) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2ACO) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SCO) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2PCO) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Company Number</span></td>
                                  <td class="inputalph"><input name="fromCompanyNumber" value="$(V_N2FCO)" type="text" size="2" maxlength="2"><a href="$(homeURL)$(phpPath)CoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=fromCompanyNumber&amp;fldFac=fromFacilityNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="coFacDesc"   type="hidden"></td>
                                  <td class="inputalph"><input name="toCompanyNumber" value="$(V_N2TCO)" type="text" size="2" maxlength="2"><a href="$(homeURL)$(phpPath)CoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=toCompanyNumber&amp;fldFac=toFacilityNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="coFacDesc"   type="hidden"></td>
                                  <td class="inputalph"><input name="allCompanyNumber" value='ALL' $(checkedallCompanyNumber) type="checkbox" onClick="if (this.checked) this.form.fromCompanyNumber.value='', this.form.toCompanyNumber.value='';"></td>
                                  @Build_Sort_Select("sortCompanyNumber", "$(V_N2SCO)")
                                  <td align=center ><input name="totalCompanyNumber" type="checkbox" $(checkedCompanyNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2FCO)
                              @DspErrMsg(Err_N2TCO)
                              @DspErrMsg(Err_N2ACO)
                              @DspErrMsg(Err_N2SCO)
                              @DspErrMsg(Err_N2PCO)

                              @SetTextOvr(Err_N2FFAC)
                              %if (textOvr == "") @SetTextOvr(Err_N2TFAC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2AFAC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SFAC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2PFAC) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Facility Number</span></td>
                                  <td class="inputalph"><input name="fromFacilityNumber" value="$(V_N2FFAC)" type="text" size="4" maxlength="4"><a href="$(homeURL)$(phpPath)CoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=fromCompanyNumber&amp;fldFac=fromFacilityNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="coFacDesc"   type="hidden"></td>
                                  <td class="inputalph"><input name="toFacilityNumber" value="$(V_N2TFAC)" type="text" size="4" maxlength="4"><a href="$(homeURL)$(phpPath)CoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=toCompanyNumber&amp;fldFac=toFacilityNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input name="coFacDesc"   type="hidden"></td>
                                  <td class="inputalph"><input name="allFacilityNumber" value='ALL' $(checkedallFacilityNumber) type="checkbox" onClick="if (this.checked) this.form.fromFacilityNumber.value='', this.form.toFacilityNumber.value='';"></td>
                                  @Build_Sort_Select("sortFacilityNumber", "$(V_N2SFAC)")
                                  <td align=center ><input name="totalFacilityNumber" type="checkbox" $(checkedFacilityNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2FFAC)
                              @DspErrMsg(Err_N2TFAC)
                              @DspErrMsg(Err_N2AFAC)
                              @DspErrMsg(Err_N2SFAC)
                              @DspErrMsg(Err_N2PFAC)

                              @SetTextOvr(Err_N2FACT)
                              %if (textOvr == "") @SetTextOvr(Err_N2TACT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2AACT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SACT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2PACT) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Account Number</span></td>
                                  <td class="inputalph"><input name="fromAccountNumber" value="$(V_N2FACT)" type="text" size="4" maxlength="4"><a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=fromAccountNumber&amp;subFld=fromSubaccountNumber&amp;descFld=accDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="accDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="toAccountNumber" value="$(V_N2TACT)" type="text" size="4" maxlength="4"><a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=toAccountNumber&amp;subFld=toSubaccountNumber&amp;descFld=accDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="accDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allAccountNumber" value='ALL' $(checkedallAccountNumber) type="checkbox" onClick="if (this.checked) this.form.fromAccountNumber.value='', this.form.toAccountNumber.value='';"></td>
                                  @Build_Sort_Select("sortAccountNumber", "$(V_N2SACT)")
                                  <td align=center ><input name="totalAccountNumber" type="checkbox" $(checkedAccountNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2FACT)
                              @DspErrMsg(Err_N2TACT)
                              @DspErrMsg(Err_N2AACT)
                              @DspErrMsg(Err_N2SACT)
                              @DspErrMsg(Err_N2PACT)

                              @SetTextOvr(Err_N2FSUB)
                              %if (textOvr == "") @SetTextOvr(Err_N2TSUB) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2ASUB) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SSUB) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2PSUB) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Subaccount Number</span></td>
                                  <td class="inputalph"><input name="fromSubaccountNumber" value="$(V_N2FSUB)" type="text" size="4" maxlength="4"><a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=fromAccountNumber&amp;subFld=fromSubaccountNumber&amp;descFld=accDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="accDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="toSubaccountNumber" value="$(V_N2TSUB)" type="text" size="4" maxlength="4"><a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=toAccountNumber&amp;subFld=toSubaccountNumber&amp;descFld=accDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="accDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allSubaccountNumber" value='ALL' $(checkedallSubaccountNumber) type="checkbox" onClick="if (this.checked) this.form.fromSubaccountNumber.value='', this.form.toSubaccountNumber.value='';"></td>
                                  @Build_Sort_Select("sortSubaccountNumber", "$(V_N2SSUB)")
                                  <td align=center ><input name="totalSubaccountNumber" type="checkbox" $(checkedSubaccountNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2FSUB)
                              @DspErrMsg(Err_N2TSUB)
                              @DspErrMsg(Err_N2ASUB)
                              @DspErrMsg(Err_N2SSUB)
                              @DspErrMsg(Err_N2PSUB)

                              @SetTextOvr(Err_N2FPER)
                              %if (textOvr == "") @SetTextOvr(Err_N2TPER) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2APER) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SPER) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2PPER) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Dist Period</span></td>
                                  <td class="inputalph"><input name="fromDistPeriod" value="$(V_N2FPER)" type="text" size="4" maxlength="4"><a href="$(homeURL)$(phpPath)PeriodSearch.php$(altVarBase)&amp;docName=Chg&amp;periodFld=fromDistPeriod&amp;beginDateFld=begindate&amp;endDateFld=enddate" onclick="$(searchWinVar)"> $(searchImage) </a><input name="begindate" type="hidden"><input name="enddate" type="hidden"></td>
                                  <td class="inputalph"><input name="toDistPeriod" value="$(V_N2TPER)" type="text" size="4" maxlength="4"><a href="$(homeURL)$(phpPath)PeriodSearch.php$(altVarBase)&amp;docName=Chg&amp;periodFld=toDistPeriod&amp;beginDateFld=begindate&amp;endDateFld=enddate" onclick="$(searchWinVar)"> $(searchImage) </a><input name="begindate" type="hidden"><input name="enddate" type="hidden"></td>
                                  <td class="inputalph"><input name="allDistPeriod" value='ALL' $(checkedallDistPeriod) type="checkbox" onClick="if (this.checked) this.form.fromDistPeriod.value='', this.form.toDistPeriod.value='';"></td>
                                  @Build_Sort_Select("sortDistPeriod", "$(V_N2SPER)")
                                  <td align=center ><input name="totalDistPeriod" type="checkbox" $(checkedDistPeriodTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2FPER)
                              @DspErrMsg(Err_N2TPER)
                              @DspErrMsg(Err_N2APER)
                              @DspErrMsg(Err_N2SPER)
                              @DspErrMsg(Err_N2PPER)
                          </table>

                          @dtw_assign(envProgram, "HIVOHB")
                          @dtw_assign(envPrinter, "HIVOHBPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HIVOHS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(allWarehouse)
  @dtw_mUPPERCASE(fromInventoryType)
  @dtw_mUPPERCASE(toInventoryType)
  @dtw_mUPPERCASE(allInventoryType)
  @dtw_mUPPERCASE(fromProductClass)
  @dtw_mUPPERCASE(toProductClass)
  @dtw_mUPPERCASE(allProductClass)
  @dtw_mUPPERCASE(allCompanyNumber)
  @dtw_mUPPERCASE(allFacilityNumber)
  @dtw_mUPPERCASE(allAccountNumber)
  @dtw_mUPPERCASE(allSubaccountNumber)
  @dtw_mUPPERCASE(allDistPeriod)

  @dtw_assign(sortItemNumber,@dtw_rstrip(sortItemNumber))
  @dtw_assign(fromWarehouse,@dtw_rstrip(fromWarehouse))
  @dtw_assign(toWarehouse,@dtw_rstrip(toWarehouse))
  @dtw_assign(sortWarehouse,@dtw_rstrip(sortWarehouse))
  @dtw_assign(sortInventoryType,@dtw_rstrip(sortInventoryType))
  @dtw_assign(sortProductClass,@dtw_rstrip(sortProductClass))
  @dtw_assign(fromCompanyNumber,@dtw_rstrip(fromCompanyNumber))
  @dtw_assign(toCompanyNumber,@dtw_rstrip(toCompanyNumber))
  @dtw_assign(sortCompanyNumber,@dtw_rstrip(sortCompanyNumber))
  @dtw_assign(fromFacilityNumber,@dtw_rstrip(fromFacilityNumber))
  @dtw_assign(toFacilityNumber,@dtw_rstrip(toFacilityNumber))
  @dtw_assign(sortFacilityNumber,@dtw_rstrip(sortFacilityNumber))
  @dtw_assign(fromAccountNumber,@dtw_rstrip(fromAccountNumber))
  @dtw_assign(toAccountNumber,@dtw_rstrip(toAccountNumber))
  @dtw_assign(sortAccountNumber,@dtw_rstrip(sortAccountNumber))
  @dtw_assign(fromSubaccountNumber,@dtw_rstrip(fromSubaccountNumber))
  @dtw_assign(toSubaccountNumber,@dtw_rstrip(toSubaccountNumber))
  @dtw_assign(sortSubaccountNumber,@dtw_rstrip(sortSubaccountNumber))
  @dtw_assign(fromDistPeriod,@dtw_rstrip(fromDistPeriod))
  @dtw_assign(toDistPeriod,@dtw_rstrip(toDistPeriod))
  @dtw_assign(sortDistPeriod,@dtw_rstrip(sortDistPeriod))


  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allWarehouse != "ALL")
      @dtw_assign(allWarehouse, "")
  %endif
  %if (allInventoryType != "ALL")
      @dtw_assign(allInventoryType, "")
  %endif
  %if (allProductClass != "ALL")
      @dtw_assign(allProductClass, "")
  %endif
  %if (allCompanyNumber != "ALL")
      @dtw_assign(allCompanyNumber, "")
  %endif
  %if (allFacilityNumber != "ALL")
      @dtw_assign(allFacilityNumber, "")
  %endif
  %if (allAccountNumber != "ALL")
      @dtw_assign(allAccountNumber, "")
  %endif
  %if (allSubaccountNumber != "ALL")
      @dtw_assign(allSubaccountNumber, "")
  %endif
  %if (allDistPeriod != "ALL")
      @dtw_assign(allDistPeriod, "")
  %endif

  %if (totalItemNumber != "Y")
      @dtw_assign(totalItemNumber, "N")
  %endif
  %if (totalWarehouse != "Y")
      @dtw_assign(totalWarehouse, "N")
  %endif
  %if (totalInventoryType != "Y")
      @dtw_assign(totalInventoryType, "N")
  %endif
  %if (totalProductClass != "Y")
      @dtw_assign(totalProductClass, "N")
  %endif
  %if (totalCompanyNumber != "Y")
      @dtw_assign(totalCompanyNumber, "N")
  %endif
  %if (totalFacilityNumber != "Y")
      @dtw_assign(totalFacilityNumber, "N")
  %endif
  %if (totalAccountNumber != "Y")
      @dtw_assign(totalAccountNumber, "N")
  %endif
  %if (totalSubaccountNumber != "Y")
      @dtw_assign(totalSubaccountNumber, "N")
  %endif
  %if (totalDistPeriod != "Y")
      @dtw_assign(totalDistPeriod, "N")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@selc", reportContent)
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@sitm", sortItemNumber)
  @Concat_Field("@@pitm", totalItemNumber)
  @Concat_Field("@@fwhs", fromWarehouse)
  @Concat_Field("@@twhs", toWarehouse)
  @Concat_Field("@@awhs", allWarehouse)
  @Concat_Field("@@swhs", sortWarehouse)
  @Concat_Field("@@pwhs", totalWarehouse)
  @Concat_Field("@@fitc", fromInventoryType)
  @Concat_Field("@@titc", toInventoryType)
  @Concat_Field("@@aitc", allInventoryType)
  @Concat_Field("@@sitc", sortInventoryType)
  @Concat_Field("@@pitc", totalInventoryType)
  @Concat_Field("@@fpcl", fromProductClass)
  @Concat_Field("@@tpcl", toProductClass)
  @Concat_Field("@@apcl", allProductClass)
  @Concat_Field("@@spcl", sortProductClass)
  @Concat_Field("@@ppcl", totalProductClass)
  @Concat_Field("@@fco@", fromCompanyNumber)
  @Concat_Field("@@tco@", toCompanyNumber)
  @Concat_Field("@@aco@", allCompanyNumber)
  @Concat_Field("@@sco@", sortCompanyNumber)
  @Concat_Field("@@pco@", totalCompanyNumber)
  @Concat_Field("@@ffac", fromFacilityNumber)
  @Concat_Field("@@tfac", toFacilityNumber)
  @Concat_Field("@@afac", allFacilityNumber)
  @Concat_Field("@@sfac", sortFacilityNumber)
  @Concat_Field("@@pfac", totalFacilityNumber)
  @Concat_Field("@@fact", fromAccountNumber)
  @Concat_Field("@@tact", toAccountNumber)
  @Concat_Field("@@aact", allAccountNumber)
  @Concat_Field("@@sact", sortAccountNumber)
  @Concat_Field("@@pact", totalAccountNumber)
  @Concat_Field("@@fsub", fromSubaccountNumber)
  @Concat_Field("@@tsub", toSubaccountNumber)
  @Concat_Field("@@asub", allSubaccountNumber)
  @Concat_Field("@@ssub", sortSubaccountNumber)
  @Concat_Field("@@psub", totalSubaccountNumber)
  @Concat_Field("@@fper", fromDistPeriod)
  @Concat_Field("@@tper", toDistPeriod)
  @Concat_Field("@@aper", allDistPeriod)
  @Concat_Field("@@sper", sortDistPeriod)
  @Concat_Field("@@pper", totalDistPeriod)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}