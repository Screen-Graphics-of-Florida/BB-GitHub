%Define {
  page_title              = "On Hand Ending Balances Report"
  d2wName                 = "OnHandEndingBalancesReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "9"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromWarehouse, 3, 0) &&
                      editNum(document.Chg.toWarehouse, 3, 0) &&
                      editNum(document.Chg.fromCompanyNumber, 2, 0) &&
                      editNum(document.Chg.toCompanyNumber, 2, 0) &&
                      editNum(document.Chg.fromFacilityNumber, 4, 0) &&
                      editNum(document.Chg.toFacilityNumber, 4, 0) &&
                      editNum(document.Chg.fromAccountNumber, 4, 0) &&
                      editNum(document.Chg.toAccountNumber, 4, 0) &&
                      editNum(document.Chg.fromSubaccountNumber, 4, 0) &&
                      editNum(document.Chg.toSubaccountNumber, 4, 0) &&
                      editNum(document.Chg.fromDistPeriod, 4, 0) &&
                      editNum(document.Chg.toDistPeriod, 4, 0) &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromWarehouse, document.Chg.toWarehouse, document.Chg.allWarehouse, 3) &&
                      editFromToAll(document.Chg.fromInventoryType, document.Chg.toInventoryType, document.Chg.allInventoryType, "A") &&
                      editFromToAll(document.Chg.fromProductClass, document.Chg.toProductClass, document.Chg.allProductClass, "A") &&
                      editFromToAll(document.Chg.fromCompanyNumber, document.Chg.toCompanyNumber, document.Chg.allCompanyNumber, 2) &&
                      editFromToAll(document.Chg.fromFacilityNumber, document.Chg.toFacilityNumber, document.Chg.allFacilityNumber, 4) &&
                      editFromToAll(document.Chg.fromAccountNumber, document.Chg.toAccountNumber, document.Chg.allAccountNumber, 4) &&
                      editFromToAll(document.Chg.fromSubaccountNumber, document.Chg.toSubaccountNumber, document.Chg.allSubaccountNumber, 4) &&
                      editFromToAll(document.Chg.fromDistPeriod, document.Chg.toDistPeriod, document.Chg.allDistPeriod, "P"))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ONHANDENDINGBALANCESREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromItemNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@selc", "reportContent")     @dtw_assign(Err_N1SEL,  fieldValue)
                                  @DecatErr_Field("@@fitm", "fromItemNumber")        @dtw_assign(Err_N2FITM,  fieldValue)
                                  @DecatErr_Field("@@titm", "toItemNumber")        @dtw_assign(Err_N2TITM,  fieldValue)
                                  @DecatErr_Field("@@aitm", "allItemNumber")        @dtw_assign(Err_N2AITM,  fieldValue)
                                  @DecatErr_Field("@@sitm", "sortItemNumber")        @dtw_assign(Err_N2SITM,  fieldValue)
                                  @DecatErr_Field("@@pitm", "totalItemNumber")        @dtw_assign(Err_N2PITM,  fieldValue)
                                  @DecatErr_Field("@@fwhs", "fromWarehouse")        @dtw_assign(Err_N2FWHS,  fieldValue)
                                  @DecatErr_Field("@@twhs", "toWarehouse")        @dtw_assign(Err_N2TWHS,  fieldValue)
                                  @DecatErr_Field("@@awhs", "allWarehouse")        @dtw_assign(Err_N2AWHS,  fieldValue)
                                  @DecatErr_Field("@@swhs", "sortWarehouse")        @dtw_assign(Err_N2SWHS,  fieldValue)
                                  @DecatErr_Field("@@pwhs", "totalWarehouse")        @dtw_assign(Err_N2PWHS,  fieldValue)
                                  @DecatErr_Field("@@fitc", "fromInventoryType")        @dtw_assign(Err_N2FITC,  fieldValue)
                                  @DecatErr_Field("@@titc", "toInventoryType")        @dtw_assign(Err_N2TITC,  fieldValue)
                                  @DecatErr_Field("@@aitc", "allInventoryType")        @dtw_assign(Err_N2AITC,  fieldValue)
                                  @DecatErr_Field("@@sitc", "sortInventoryType")        @dtw_assign(Err_N2SITC,  fieldValue)
                                  @DecatErr_Field("@@pitc", "totalInventoryType")        @dtw_assign(Err_N2PITC,  fieldValue)
                                  @DecatErr_Field("@@fpcl", "fromProductClass")        @dtw_assign(Err_N2FPCL,  fieldValue)
                                  @DecatErr_Field("@@tpcl", "toProductClass")        @dtw_assign(Err_N2TPCL,  fieldValue)
                                  @DecatErr_Field("@@apcl", "allProductClass")        @dtw_assign(Err_N2APCL,  fieldvalue)
                                  @DecatErr_Field("@@spcl", "sortProductClass")        @dtw_assign(Err_N2SPCL,  fieldValue)
                                  @DecatErr_Field("@@ppcl", "totalProductClass")        @dtw_assign(Err_N2PPCL,  fieldValue)
                                  @DecatErr_Field("@@fco@", "fromCompanyNumber")        @dtw_assign(Err_N2FCO,  fieldValue)
                                  @DecatErr_Field("@@tco@", "toCompanyNumber")        @dtw_assign(Err_N2TCO,  fieldValue)
                                  @DecatErr_Field("@@aco@", "allCompanyNumber")        @dtw_assign(Err_N2ACO,  fieldValue)
                                  @DecatErr_Field("@@sco@", "sortCompanyNumber")        @dtw_assign(Err_N2SCO,  fieldValue)
                                  @DecatErr_Field("@@pco@", "totalCompanyNumber")        @dtw_assign(Err_N2PCO,  fieldValue)
                                  @DecatErr_Field("@@ffac", "fromFacilityNumber")        @dtw_assign(Err_N2FFAC,  fieldValue)
                                  @DecatErr_Field("@@tfac", "toFacilityNumber")        @dtw_assign(Err_N2TFAC,  fieldValue)
                                  @DecatErr_Field("@@afac", "allFacilityNumber")        @dtw_assign(Err_N2AFAC,  fieldValue)
                                  @DecatErr_Field("@@sfac", "sortFacilityNumber")        @dtw_assign(Err_N2SFAC,  fieldValue)
                                  @DecatErr_Field("@@pfac", "totalFacilityNumber")        @dtw_assign(Err_N2PFAC,  fieldValue)
                                  @DecatErr_Field("@@fact", "fromAccountNumber")        @dtw_assign(Err_N2FACT,  fieldValue)
                                  @DecatErr_Field("@@tact", "toAccountNumber")        @dtw_assign(Err_N2TACT,  fieldValue)
                                  @DecatErr_Field("@@aact", "allAccountNumber")        @dtw_assign(Err_N2AACT,  fieldValue)
                                  @DecatErr_Field("@@sact", "sortAccountNumber")        @dtw_assign(Err_N2SACT,  fieldValue)
                                  @DecatErr_Field("@@pact", "totalAccountNumber")        @dtw_assign(Err_N2PACT,  fieldValue)
                                  @DecatErr_Field("@@fsub", "fromSubaccountNumber")        @dtw_assign(Err_N2FSUB,  fieldValue)
                                  @DecatErr_Field("@@tsub", "toSubaccountNumber")        @dtw_assign(Err_N2TSUB,  fieldValue)
                                  @DecatErr_Field("@@asub", "allSubaccountNumber")        @dtw_assign(Err_N2ASUB,  fieldValue)
                                  @DecatErr_Field("@@ssub", "sortSubaccountNumber")        @dtw_assign(Err_N2SSUB,  fieldValue)
                                  @DecatErr_Field("@@psub", "totalSubaccountNumber")        @dtw_assign(Err_N2PSUB,  fieldValue)
                                  @DecatErr_Field("@@fper", "fromDistPeriod")        @dtw_assign(Err_N2FPER,  fieldValue)
                                  @DecatErr_Field("@@tper", "toDistPeriod")        @dtw_assign(Err_N2TPER,  fieldValue)
                                  @DecatErr_Field("@@aper", "allDistPeriod")        @dtw_assign(Err_N2APER,  fieldValue)
                                  @DecatErr_Field("@@sper", "sortDistPeriod")        @dtw_assign(Err_N2SPER,  fieldValue)
                                  @DecatErr_Field("@@pper", "totalDistPeriod")        @dtw_assign(Err_N2TPER,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@selc")  @dtw_assign(V_N1SEL,  fieldValue)
                                  @Decat_Field("@@fitm")  @dtw_assign(V_N2FITM,  fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N2TITM,  fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N2AITM,  fieldValue)
                                  @Decat_Field("@@sitm")  @dtw_assign(V_N2SITM,  fieldValue)
                                  @Decat_Field("@@pitm")  @dtw_assign(V_N2PITM,  fieldValue)
                                  @Decat_Field("@@fwhs")  @dtw_assign(V_N2FWHS,  fieldValue)
                                  @Decat_Field("@@twhs")  @dtw_assign(V_N2TWHS,  fieldValue)
                                  @Decat_Field("@@awhs")  @dtw_assign(V_N2AWHS,  fieldValue)
                                  @Decat_Field("@@swhs")  @dtw_assign(V_N2SWHS,  fieldValue)
                                  @Decat_Field("@@pwhs")  @dtw_assign(V_N2PWHS,  fieldValue)
                                  @Decat_Field("@@fitc")  @dtw_assign(V_N2FITC,  fieldValue)
                                  @Decat_Field("@@titc")  @dtw_assign(V_N2TITC,  fieldValue)
                                  @Decat_Field("@@aitc")  @dtw_assign(V_N2AITC,  fieldValue)
                                  @Decat_Field("@@sitc")  @dtw_assign(V_N2SITC,  fieldValue)
                                  @Decat_Field("@@pitc")  @dtw_assign(V_N2PITC,  fieldValue)
                                  @Decat_Field("@@fpcl")  @dtw_assign(V_N2FPCL,  fieldValue)
                                  @Decat_Field("@@tpcl")  @dtw_assign(V_N2TPCL,  fieldValue)
                                  @Decat_Field("@@apcl")  @dtw_assign(V_N2APCL,  fieldValue)
                                  @Decat_Field("@@spcl")  @dtw_assign(V_N2SPCL,  fieldValue)
                                  @Decat_Field("@@ppcl")  @dtw_assign(V_N2PPCL,  fieldValue)
                                  @Decat_Field("@@fco@")  @dtw_assign(V_N2FCO,  fieldValue)
                                  @Decat_Field("@@tco@")  @dtw_assign(V_N2TCO,  fieldValue)
                                  @Decat_Field("@@aco@")  @dtw_assign(V_N2ACO,  fieldValue)
                                  @Decat_Field("@@sco@")  @dtw_assign(V_N2SCO,  fieldValue)
                                  @Decat_Field("@@pco@")  @dtw_assign(V_N2PCO,  fieldValue)
                                  @Decat_Field("@@ffac")  @dtw_assign(V_N2FFAC,  fieldValue)
                                  @Decat_Field("@@tfac")  @dtw_assign(V_N2TFAC,  fieldValue)
                                  @Decat_Field("@@afac")  @dtw_assign(V_N2AFAC,  fieldValue)
                                  @Decat_Field("@@sfac")  @dtw_assign(V_N2SFAC,  fieldValue)
                                  @Decat_Field("@@pfac")  @dtw_assign(V_N2PFAC,  fieldValue)
                                  @Decat_Field("@@fact")  @dtw_assign(V_N2FACT,  fieldValue)
                                  @Decat_Field("@@tact")  @dtw_assign(V_N2TACT,  fieldValue)
                                  @Decat_Field("@@aact")  @dtw_assign(V_N2AACT,  fieldValue)
                                  @Decat_Field("@@sact")  @dtw_assign(V_N2SACT,  fieldValue)
                                  @Decat_Field("@@pact")  @dtw_assign(V_N2PACT,  fieldValue)
                                  @Decat_Field("@@fsub")  @dtw_assign(V_N2FSUB,  fieldValue)
                                  @Decat_Field("@@tsub")  @dtw_assign(V_N2TSUB,  fieldValue)
                                  @Decat_Field("@@asub")  @dtw_assign(V_N2ASUB,  fieldValue)
                                  @Decat_Field("@@ssub")  @dtw_assign(V_N2SSUB,  fieldValue)
                                  @Decat_Field("@@psub")  @dtw_assign(V_N2PSUB,  fieldValue)
                                  @Decat_Field("@@fper")  @dtw_assign(V_N2FPER,  fieldValue)
                                  @Decat_Field("@@tper")  @dtw_assign(V_N2TPER,  fieldValue)
                                  @Decat_Field("@@aper")  @dtw_assign(V_N2APER,  fieldValue)
                                  @Decat_Field("@@sper")  @dtw_assign(V_N2SPER,  fieldValue)
                                  @Decat_Field("@@pper")  @dtw_assign(V_N2PPER,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1SEL == "02")
                                      @dtw_assign(detail, "")
                                      @dtw_assign(summary, "CHECKED")
                                  %else
                                      @dtw_assign(detail, "CHECKED")
                                      @dtw_assign(summary, "")
                                  %endif
                                  %if (V_N2AITM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_N2AWHS == "ALL")
                                      @dtw_assign(checkedallWarehouse, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallWarehouse, "")
                                  %endif
                                  %if (V_N2AITC == "ALL")
                                      @dtw_assign(checkedallInventoryType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallInventoryType, "")
                                  %endif
                                  %if (V_N2APCL == "ALL")
                                      @dtw_assign(checkedallProductClass, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallProductClass, "")
                                  %endif
                                  %if (V_N2ACO == "ALL")
                                      @dtw_assign(checkedallCompanyNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallCompanyNumber, "")
                                  %endif
                                  %if (V_N2AFAC == "ALL")
                                      @dtw_assign(checkedallFacilityNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallFacilityNumber, "")
                                  %endif
                                  %if (V_N2AACT == "ALL")
                                      @dtw_assign(checkedallAccountNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallAccountNumber, "")
                                  %endif
                                  %if (V_N2ASUB == "ALL")
                                      @dtw_assign(checkedallSubaccountNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallSubaccountNumber, "")
                                  %endif
                                  %if (V_N2APER == "ALL")
                                      @dtw_assign(checkedallDistPeriod, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallDistPeriod, "")
                                  %endif

                                  %if (V_N2PITM == "Y")
                                      @dtw_assign(checkedItemNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedItemNumberTotals, "")
                                  %endif
                                  %if (V_N2PWHS == "Y")
                                      @dtw_assign(checkedWarehouseTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedWarehouseTotals, "")
                                  %endif
                                  %if (V_N2PITC == "Y")
                                      @dtw_assign(checkedInventoryTypeTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedInventoryTypeTotals, "")
                                  %endif
                                  %if (V_N2PPCL == "Y")
                                      @dtw_assign(checkedProductClassTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedProductClassTotals, "")
                                  %endif
                                  %if (V_N2PCO == "Y")
                                      @dtw_assign(checkedCompanyNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedCompanyNumberTotals, "")
                                  %endif
                                  %if (V_N2PFAC == "Y")
                                      @dtw_assign(checkedFacilityNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedFacilityNumberTotals, "")
                                  %endif
                                  %if (V_N2PACT == "Y")
                                      @dtw_assign(checkedAccountNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAccountNumberTotals, "")
                                  %endif
                                  %if (V_N2PSUB == "Y")
                                      @dtw_assign(checkedSubaccountNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedSubaccountNumberTotals, "")
                                  %endif
                                  %if (V_N2PPER == "Y")
                                      @dtw_assign(checkedDistPeriodTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedDistPeriodTotals, "")
                                  %endif
                              %else
                                  @dtw_assign(detail, "CHECKED")
                                  @dtw_assign(summary, "")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallWarehouse, "CHECKED")
                                  @dtw_assign(checkedallInventoryType, "CHECKED")
                                  @dtw_assign(checkedallProductClass, "CHECKED")
                                  @dtw_assign(checkedallCompanyNumber, "CHECKED")
                                  @dtw_assign(checkedallFacilityNumber, "CHECKED")
                                  @dtw_assign(checkedallAccountNumber, "CHECKED")
                                  @dtw_assign(checkedallSubaccountNumber, "CHECKED")
                                  @dtw_assign(checkedallDistPeriod, "CHECKED")
                                  @dtw_assign(checkedItemNumberTotals, "")
                                  @dtw_assign(checkedWarehouseTotals, "")
