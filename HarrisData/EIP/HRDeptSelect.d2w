%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title 	        = "Department"
  d2wName              = "HRDeptSelect.d2w"
  d2wVarBase           = "$(genericVarBase)&amp;deptNumber=@dtw_rurlescseq(deptNumber)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName          = "HPREAM"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  RPT_MAX_ROWS         = "99"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext	        = "1"
  totalPages	        = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@deptNumber", "@dtw_rurlescseq(deptNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                       @dtw_assign(pageID, "DEPTSELECT")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      @dtw_concat(stmtSQL, "Select * From PREXAC ", stmtSQL)
                      @dtw_concat(stmtSQL, " Where EADEPT='$(deptNumber)'", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Dept_Inquiry(profileHandle, dataBaseID, stmtSQL)

                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Dept_Inquiry (IN CHAR(64)    profileHandle,
				     CHAR(2)     dataBaseID,
                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td> </td>
                  <td class="toolbar">
                      %if ((backHome != "")  && (backHome != "$(d2wName)/report"))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
              </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"
      $(hrTagAttr)
      %ROW {

          <table $(contentTable)>
              <tr><td class="dsphdr">Department</td>
                  <td class="dspalph">$(V_EADEPT)</td></tr>
              <tr><td class="dsphdr">Name</td>
                  <td class="dspalph">$(V_EANAME)</td></tr>
          </table>
          <table $(contentTable)>
              <tr><td class="colhdr">ExpenseType</td>
                  <td class="colhdr">Co/Fac</td>
                  <td class="colhdr">Account</td>
                  <td class="colhdr">Premium Only</td>
                  <td class="colhdr">Account Description</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">Regular Wages</td>
                  @Format_HRCoFac("$(V_EARWCO)", "$(V_EARWFA)", "", F_CoFac)
                  <td class="colalph">$(F_CoFac)</td>
                  @Format_Acct("$(V_EARWAC)", "$(V_EARWSB)", "", F_AcctSub)
                  <td class="colalph">$(F_AcctSub)</td>
                  <td class="colalph"> </td>
                  @RtvFldDesc("CHACCT=$(V_EARWAC) and CHSUB=$(V_EARWSB) ", "HDCHRT", "CHCHDS", acctDesc)
                  <td class="colalph">$(acctDesc)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">Overtime Wages</td>
                  <td class="colalph"> </td>
                  @Format_Acct("$(V_EAOVAC)", "$(V_EAOVSB)", "", F_AcctSub)
                  <td class="colalph">$(F_AcctSub)</td>
                  @RtvYNDesc($(V_EAOTPO), syFlagDesc)
                  <td class="colcode">$(syFlagDesc)</td>
                  @RtvFldDesc("CHACCT=$(V_EAOVAC) and CHSUB=$(V_EAOVSB) ", "HDCHRT", "CHCHDS", acctDesc)
                  <td class="colalph">$(acctDesc)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">Double Time Wages</td>
                  <td class="colalph"> </td>
                  @Format_Acct("$(V_EADTAC)", "$(V_EADTSB)", "", F_AcctSub)
                  <td class="colalph">$(F_AcctSub)</td>
                  @RtvYNDesc($(V_EADTPO), syFlagDesc)
                  <td class="colcode">$(syFlagDesc)</td>
                  @RtvFldDesc("CHACCT=$(V_EADTAC) and CHSUB=$(V_EADTSB) ", "HDCHRT", "CHCHDS", acctDesc)
                  <td class="colalph">$(acctDesc)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">Vacation Wages</td>
                  <td class="colalph"> </td>
                  @Format_Acct("$(V_EAVCAC)", "$(V_EAVCSB)", "", F_AcctSub)
                  <td class="colalph">$(F_AcctSub)</td>
                  <td class="colalph"> </td>
                  @RtvFldDesc("CHACCT=$(V_EAVCAC) and CHSUB=$(V_EAVCSB) ", "HDCHRT", "CHCHDS", acctDesc)
                  <td class="colalph">$(acctDesc)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">Holiday Wages</td>
                  <td class="colalph"> </td>
                  @Format_Acct("$(V_EAHOAC)", "$(V_EAHOSB)", "", F_AcctSub)
                  <td class="colalph">$(F_AcctSub)</td>
                  <td class="colalph"> </td>
                  @RtvFldDesc("CHACCT=$(V_EAHOAC) and CHSUB=$(V_EAHOSB) ", "HDCHRT", "CHCHDS", acctDesc)
                  <td class="colalph">$(acctDesc)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">Sick Wages</td>
                  <td class="colalph"> </td>
                  @Format_Acct("$(V_EASIAC)", "$(V_EASISB)", "", F_AcctSub)
                  <td class="colalph">$(F_AcctSub)</td>
                  <td class="colalph"> </td>
                  @RtvFldDesc("CHACCT=$(V_EASIAC) and CHSUB=$(V_EASISB) ", "HDCHRT", "CHCHDS", acctDesc)
                  <td class="colalph">$(acctDesc)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">Other Taxable Wages</td>
                  <td class="colalph"> </td>
                  @Format_Acct("$(V_EAOTAC)", "$(V_EAOTSB)", "", F_AcctSub)
                  <td class="colalph">$(F_AcctSub)</td>
                  <td class="colalph"> </td>
                  @RtvFldDesc("CHACCT=$(V_EAOTAC) and CHSUB=$(V_EAOTSB) ", "HDCHRT", "CHCHDS", acctDesc)
                  <td class="colalph">$(acctDesc)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">Non-Taxable</td>
                  <td class="colalph"> </td>
                  @Format_Acct("$(V_EAONAC)", "$(V_EAONSB)", "", F_AcctSub)
                  <td class="colalph">$(F_AcctSub)</td>
                  <td class="colalph"> </td>
                  @RtvFldDesc("CHACCT=$(V_EAONAC) and CHSUB=$(V_EAONSB) ", "HDCHRT", "CHCHDS", acctDesc)
                  <td class="colalph">$(acctDesc)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">Commission Wages</td>
                  <td class="colalph"> </td>
                  @Format_Acct("$(V_EACMAC)", "$(V_EACMSB)", "", F_AcctSub)
                  <td class="colalph">$(F_AcctSub)</td>
                  <td class="colalph"> </td>
                  @RtvFldDesc("CHACCT=$(V_EACMAC) and CHSUB=$(V_EACMSB) ", "HDCHRT", "CHCHDS", acctDesc)
                  <td class="colalph">$(acctDesc)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">Bonus Wages</td>
                  <td class="colalph"> </td>
                  @Format_Acct("$(V_EABOAC)", "$(V_EABOSB)", "", F_AcctSub)
                  <td class="colalph">$(F_AcctSub)</td>
                  <td class="colalph"> </td>
                  @RtvFldDesc("CHACCT=$(V_EABOAC) and CHSUB=$(V_EABOSB) ", "HDCHRT", "CHCHDS", acctDesc)
                  <td class="colalph">$(acctDesc)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">FICA Tax</td>
                  @Format_HRCoFac("$(V_EATXCO)", "$(V_EATXFA)", "", F_CoFac)
                  <td class="colalph">$(F_CoFac)</td>
                  @Format_Acct("$(V_EAFIAC)", "$(V_EAFISB)", "", F_AcctSub)
                  <td class="colalph">$(F_AcctSub)</td>
                  <td class="colalph"> </td>
                  @RtvFldDesc("CHACCT=$(V_EAFIAC) and CHSUB=$(V_EAFISB) ", "HDCHRT", "CHCHDS", acctDesc)
                  <td class="colalph">$(acctDesc)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">Federal Unemployment Insurance</td>
                  <td class="colalph"> </td>
                  @Format_Acct("$(V_EAFUAC)", "$(V_EAFUSB)", "", F_AcctSub)
                  <td class="colalph">$(F_AcctSub)</td>
                  <td class="colalph"> </td>
                  @RtvFldDesc("CHACCT=$(V_EAFUAC) and CHSUB=$(V_EAFUSB) ", "HDCHRT", "CHCHDS", acctDesc)
                  <td class="colalph">$(acctDesc)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">State Unemployment Insurance</td>
                  <td class="colalph"> </td>
                  @Format_Acct("$(V_EASUAC)", "$(V_EASUSB)", "", F_AcctSub)
                  <td class="colalph">$(F_AcctSub)</td>
                  <td class="colalph"> </td>
                  @RtvFldDesc("CHACCT=$(V_EASUAC) and CHSUB=$(V_EASUSB) ", "HDCHRT", "CHCHDS", acctDesc)
                  <td class="colalph">$(acctDesc)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">State Disability Insurance</td>
                  <td class="colalph"> </td>
                  @Format_Acct("$(V_EASDAC)", "$(V_EASDSB)", "", F_AcctSub)
                  <td class="colalph">$(F_AcctSub)</td>
                  <td class="colalph"> </td>
                  @RtvFldDesc("CHACCT=$(V_EASDAC) and CHSUB=$(V_EASDSB) ", "HDCHRT", "CHCHDS", acctDesc)
                  <td class="colalph">$(acctDesc)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">State  Workers' Compensation</td>
                  <td class="colalph"> </td>
                  @Format_Acct("$(V_EASWAC)", "$(V_EASWSB)", "", F_AcctSub)
                  <td class="colalph">$(F_AcctSub)</td>
                  <td class="colalph"> </td>
                  @RtvFldDesc("CHACCT=$(V_EASWAC) and CHSUB=$(V_EASWSB) ", "HDCHRT", "CHCHDS", acctDesc)
                  <td class="colalph">$(acctDesc)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">Local Tax</td>
                  <td class="colalph"> </td>
                  @Format_Acct("$(V_EALIAC)", "$(V_EALISB)", "", F_AcctSub)
                  <td class="colalph">$(F_AcctSub)</td>
                  <td class="colalph"> </td>
                  @RtvFldDesc("CHACCT=$(V_EALIAC) and CHSUB=$(V_EALISB) ", "HDCHRT", "CHCHDS", acctDesc)
                  <td class="colalph">$(acctDesc)</td>
              </tr>
          </table>
      %}	
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}