%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Detail Pay History"
  d2wName                 = "DetailPayHistoryReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  programName             = "HPRCHI"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  %INCLUDE "SelEmplActiveTerm.icl"
                  if (
                      editNum(document.Chg.fromCompany, 2, 0) &&
                      editNum(document.Chg.toCompany, 2, 0) &&
                      editNum(document.Chg.fromFacility, 4, 0) &&
                      editNum(document.Chg.toFacility, 4, 0) &&
                      editNum(document.Chg.fromPrEmpl, 5, 0) &&
                      editNum(document.Chg.toPrEmpl, 5, 0) &&
                      editNum(document.Chg.fromHrEmpl, 9, 0) &&
                      editNum(document.Chg.toHrEmpl, 9, 0) &&
                      editdate(document.Chg.fromCheckDate) &&
                      editdate(document.Chg.toCheckDate) &&
                      editdate(document.Chg.fromWorkDate) &&
                      editdate(document.Chg.toWorkDate) &&
                      editNum(document.Chg.fromAccount, 4, 0) &&
                      editNum(document.Chg.toAccount, 4, 0) &&
                      editNum(document.Chg.fromSubaccount, 4, 0) &&
                      editNum(document.Chg.toSubaccount, 4, 0) &&
                      editFromToAll(document.Chg.fromCompany, document.Chg.toCompany, document.Chg.allCompany,2) &&
                      editFromToAll(document.Chg.fromFacility, document.Chg.toFacility, document.Chg.allFacility,4) &&
                      editFromToAll(document.Chg.fromLocation, document.Chg.toLocation, document.Chg.allLocation,"A") &&
                      editFromToAll(document.Chg.fromDepartment, document.Chg.toDepartment, document.Chg.allDepartment,"A") &&
                      editFromToAll(document.Chg.fromPrEmpl, document.Chg.toPrEmpl, document.Chg.allPrEmpl,5) &&
                      editFromToAll(document.Chg.fromHrEmpl, document.Chg.toHrEmpl, document.Chg.allHrEmpl,9) &&
                      editFromToAll(document.Chg.fromCheckDate, document.Chg.toCheckDate, document.Chg.allCheckDate,"D") &&
                      editFromToAll(document.Chg.fromWorkDate, document.Chg.toWorkDate, document.Chg.allWorkDate,"D") &&
                      editFromToAll(document.Chg.fromHistDept, document.Chg.toHistDept, document.Chg.allHistDept,"A") &&
                      editFromToAll(document.Chg.fromWorkDept, document.Chg.toWorkDept, document.Chg.allWorkDept,"A") &&
                      editFromToAll(document.Chg.fromSumType, document.Chg.toSumType, document.Chg.allSumType,"A") &&
                      editFromToAll(document.Chg.fromAccount, document.Chg.toAccount, document.Chg.allAccount, 4) &&
                      editFromToAll(document.Chg.fromSubaccount, document.Chg.toSubaccount, document.Chg.allSubaccount, 4) &&
                      editFromToAll(document.Chg.fromPayCode, document.Chg.toPayCode, document.Chg.allPayCode,"A"))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "DETAILPAYRP")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                     <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                         <table $(contentTable)>
                             @dtw_assign(focusField, "fromCompany")
                             %if (errFound != "" || scheduleJobSwitch == "Y")
                                 @EdtVarErr(profileHandle, typeValue, edtVar)
                                 @dtw_assign(focusField, "")
                                 @ErrVarErr(profileHandle, typeError, errVar)
                                 @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)

                                 @DecatErr_Field("@@rpcn", "reportContent")    @dtw_assign(Err_SLRPCN,  fieldValue)

                                 %INCLUDE "SelEmplDecatErr.icl"   %{ Decat Employee Report Selection Errors %}

                                 @DecatErr_Field("@@fdat", "fromCheckDate")    @dtw_assign(Err_SLFDAT,  fieldValue)
                                 @DecatErr_Field("@@tdat", "toCheckDate")      @dtw_assign(Err_SLTDAT,  fieldValue)
                                 @DecatErr_Field("@@adat", "allCheckDate")     @dtw_assign(Err_SLADAT,  fieldValue)

                                 @DecatErr_Field("@@fwkd", "fromWorkDate")     @dtw_assign(Err_SLFWKD,  fieldValue)
                                 @DecatErr_Field("@@twkd", "toWorkDate")       @dtw_assign(Err_SLTWKD,  fieldValue)
                                 @DecatErr_Field("@@awkd", "allWorkDate")      @dtw_assign(Err_SLAWKD,  fieldValue)

                                 @DecatErr_Field("@@fdpw", "fromHistDept")     @dtw_assign(Err_SLFHDP,  fieldValue)
                                 @DecatErr_Field("@@tdpw", "toHistDept")       @dtw_assign(Err_SLTHDP,  fieldValue)
                                 @DecatErr_Field("@@adpw", "allHistDept")      @dtw_assign(Err_SLAHDP,  fieldValue)

                                 @DecatErr_Field("@@fdpw", "fromWorkDept")     @dtw_assign(Err_SLFDPW,  fieldValue)
                                 @DecatErr_Field("@@tdpw", "toWorkDept")       @dtw_assign(Err_SLTDPW,  fieldValue)
                                 @DecatErr_Field("@@adpw", "allWorkDept")      @dtw_assign(Err_SLADPW,  fieldValue)

                                 @DecatErr_Field("@@ftyp", "fromSumType")      @dtw_assign(Err_SLFTYP,  fieldValue)
                                 @DecatErr_Field("@@ttyp", "toSumType")        @dtw_assign(Err_SLTTYP,  fieldValue)
                                 @DecatErr_Field("@@atyp", "allSumType")       @dtw_assign(Err_SLATYP,  fieldValue)

                                 @DecatErr_Field("@@fact", "fromAccount")      @dtw_assign(Err_SLFACT,  fieldValue)
                                 @DecatErr_Field("@@tact", "toAccount")        @dtw_assign(Err_SLTACT,  fieldValue)
                                 @DecatErr_Field("@@aact", "allAccount")       @dtw_assign(Err_SLAACT,  fieldValue)

                                 @DecatErr_Field("@@fsub", "fromSubaccount")   @dtw_assign(Err_SLFSUB,  fieldValue)
                                 @DecatErr_Field("@@tsub", "toSubaccount")     @dtw_assign(Err_SLTSUB,  fieldValue)
                                 @DecatErr_Field("@@asub", "allSubaccount")    @dtw_assign(Err_SLASUB,  fieldValue)

                                 @DecatErr_Field("@@fcod", "fromPayCode")      @dtw_assign(Err_SLFCOD,  fieldValue)
                                 @DecatErr_Field("@@tcod", "toPayCode")        @dtw_assign(Err_SLTCOD,  fieldValue)
                                 @DecatErr_Field("@@acod", "allPaycode")       @dtw_assign(Err_SLACOD,  fieldValue)

                                 %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}

                                 @Decat_Field("@@rpcn")   @dtw_assign(V_SLRPCN,  fieldValue)

                                 %INCLUDE "SelEmplDecatSel.icl"   %{ Decat Employee Report Selections %}

                                 @Decat_Field("@@fdat")   @dtw_assign(V_SLFDAT,  fieldValue)
                                 @Decat_Field("@@tdat")   @dtw_assign(V_SLTDAT,  fieldValue)
                                 @Decat_Field("@@adat")   @dtw_assign(V_SLADAT,  fieldValue)

                                 @Decat_Field("@@fwkd")   @dtw_assign(V_SLFWKD,  fieldValue)
                                 @Decat_Field("@@twkd")   @dtw_assign(V_SLTWKD,  fieldValue)
                                 @Decat_Field("@@awkd")   @dtw_assign(V_SLAWKD,  fieldValue)

                                 @Decat_Field("@@fhdp")   @dtw_assign(V_SLFHDP,  fieldValue)
                                 @Decat_Field("@@thdp")   @dtw_assign(V_SLTHDP,  fieldValue)
                                 @Decat_Field("@@ahdp")   @dtw_assign(V_SLAHDP,  fieldValue)

                                 @Decat_Field("@@fdpw")   @dtw_assign(V_SLFDPW,  fieldValue)
                                 @Decat_Field("@@tdpw")   @dtw_assign(V_SLTDPW,  fieldValue)
                                 @Decat_Field("@@adpw")   @dtw_assign(V_SLADPW,  fieldValue)

                                 @Decat_Field("@@ftyp")   @dtw_assign(V_SLFTYP,  fieldValue)
                                 @Decat_Field("@@ttyp")   @dtw_assign(V_SLTTYP,  fieldValue)
                                 @Decat_Field("@@atyp")   @dtw_assign(V_SLATYP,  fieldValue)

                                 @Decat_Field("@@fact")   @dtw_assign(V_SLFACT,  fieldValue)
                                 @Decat_Field("@@tact")   @dtw_assign(V_SLTACT,  fieldValue)
                                 @Decat_Field("@@aact")   @dtw_assign(V_SLAACT,  fieldValue)

                                 @Decat_Field("@@fsub")   @dtw_assign(V_SLFSUB,  fieldValue)
                                 @Decat_Field("@@tsub")   @dtw_assign(V_SLTSUB,  fieldValue)
                                 @Decat_Field("@@asub")   @dtw_assign(V_SLASUB,  fieldValue)

                                 @Decat_Field("@@fcod")   @dtw_assign(V_SLFCOD,  fieldValue)
                                 @Decat_Field("@@tcod")   @dtw_assign(V_SLTCOD,  fieldValue)
                                 @Decat_Field("@@acod")   @dtw_assign(V_SLACOD,  fieldValue)

                                 %INCLUDE "ScheduleJobValue.icl"  %{ Schedule Entries Values %}
                                 %if (V_SLRPCN == "02")
                                     @dtw_assign(byEmployee, "")
                                     @dtw_assign(byPayCode, "CHECKED")
                                     @dtw_assign(byDept, "")
                                     @dtw_assign(byWorkDept, "")
                                 %elif (V_SLRPCN == "03")
                                     @dtw_assign(byEmployee, "")
                                     @dtw_assign(byPayCode, "")
                                     @dtw_assign(byDept, "CHECKED")
                                     @dtw_assign(byWorkDept, "")
                                 %elif (V_SLRPCN == "04")
                                     @dtw_assign(byEmployee, "")
                                     @dtw_assign(byPayCode, "")
                                     @dtw_assign(byDept, "")
                                     @dtw_assign(byWorkDept, "CHECKED")
                                 %else
                                     @dtw_assign(byEmployee, "CHECKED")
                                     @dtw_assign(byPayCode, "")
                                     @dtw_assign(byDept, "")
                                     @dtw_assign(byWorkDept, "")
                                 %endif
                                 %if (V_SLADAT == "ALL")
                                     @dtw_assign(checkedCheckDate, "CHECKED")
                                 %else
                                     @dtw_assign(checkedCheckDate, "")
                                 %endif
                                 %if (V_SLAWKD == "ALL")
                                     @dtw_assign(checkedWorkDate, "CHECKED")
                                 %else
                                     @dtw_assign(checkedWorkDate, "")
                                 %endif
                                 %if (V_SLAHDP == "ALL")
                                     @dtw_assign(checkedHistDept, "CHECKED")
                                 %else
                                     @dtw_assign(checkedHistDept, "")
                                 %endif
                                 %if (V_SLADPW == "ALL")
                                     @dtw_assign(checkedWorkDept, "CHECKED")
                                 %else
                                     @dtw_assign(checkedWorkDept, "")
                                 %endif
                                 %if (V_SLATYP == "ALL")
                                     @dtw_assign(checkedSumType, "CHECKED")
                                 %else
                                     @dtw_assign(checkedSumType, "")
                                 %endif
                                 %if (V_SLAACT == "ALL")
                                     @dtw_assign(checkedAccount, "CHECKED")
                                 %else
                                     @dtw_assign(checkedAccount, "")
                                 %endif
                                 %if (V_SLASUB == "ALL")
                                     @dtw_assign(checkedSubaccount, "CHECKED")
                                 %else
                                     @dtw_assign(checkedSubaccount, "")
                                 %endif
                                 %if (V_SLACOD == "ALL")
                                     @dtw_assign(checkedPayCode, "CHECKED")
                                 %else
                                     @dtw_assign(checkedPayCode, "")
                                 %endif
                             %else
                                 @dtw_assign(byEmployee, "CHECKED")
                                 @dtw_assign(bypayCode, "")
                                 @dtw_assign(byDept, "")
                                 @dtw_assign(byWorkDept, "")
                                 @dtw_assign(checkedCheckDate, "CHECKED")
                                 @dtw_assign(checkedWorkDate, "CHECKED")
                                 @dtw_assign(checkedHistDept, "CHECKED")
                                 @dtw_assign(checkedWorkDept, "CHECKED")
                                 @dtw_assign(checkedSumType, "CHECKED")
                                 @dtw_assign(checkedAccount, "CHECKED")
                                 @dtw_assign(checkedSubaccount, "CHECKED")
                                 @dtw_assign(checkedPayCode, "CHECKED")
                             %endif

                             @SetTextOvr(Err_SLRPCN)
                             <tr><td class="dsphdr"><span $(textOvr)>Report Content Selection</span></td>
                                 <td class="inputnmbr"><input name="reportContent" type="radio" VALUE='01' $(byEmployee)>Employee</td>
                             </tr>
                             @DspErrMsg(Err_SLRPSQ)

                             <tr><td>&nbsp;</td>
                                 <td class="inputnmbr"><input name="reportContent" type="radio" VALUE='02' $(byPayCode)>Pay Code</td>
                             </tr>
                             <tr><td>&nbsp;</td>
                                 <td class="inputnmbr"><input name="reportContent" type="radio" VALUE='03' $(byDept)>Department, Pay Code</td>
                             </tr>
                             <tr><td>&nbsp;</td>
                                 <td class="inputnmbr"><input name="reportContent" type="radio" VALUE='04' $(byWorkDept)>Department Worked, Pay Code</td>
                             </tr>

                              %INCLUDE "SelEmplCheckBoxes.icl"     %{ Set Employee Report Selection Check Box Values %}

                              @dtw_assign(scheduleJobSwitch, "")
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              %INCLUDE "SelEmplSetText.icl"       %{ Employee Report Selection Fields %}

                              @SetTextOvr(Err_SLFDAT)
                              %if (textOvr == "") @SetTextOvr(Err_SLTDAT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SLADAT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Check Date</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromCheckDate" VALUE="$(V_SLFDAT)" size="5" maxlength="6"> 		
                                      <a href="javascript:calWindow('fromCheckDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input type="text" name="toCheckDate" VALUE="$(V_SLTDAT)" size="5" maxlength="6"> 		
                                      <a href="javascript:calWindow('toCheckDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="allCheckDate" VALUE='ALL' $(checkedCheckDate) type="checkbox" onClick="if (this.checked) this.form.fromCheckDate.value='', this.form.toCheckDate.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_SLFDAT)
                              @DspErrMsg(Err_SLTDAT)
                              @DspErrMsg(Err_SLADAT)

                              @SetTextOvr(Err_SLFWKD)
                              %if (textOvr == "") @SetTextOvr(Err_SLTWKD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SLAWKD) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Date Worked</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromWorkDate" VALUE="$(V_SLFWKD)" size="5" maxlength="6"> 		
                                      <a href="javascript:calWindow('fromWorkDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input type="text" name="toWorkDate" VALUE="$(V_SLTWKD)" size="5" maxlength="6"> 		
                                      <a href="javascript:calWindow('toWorkDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="allWorkDate" VALUE='ALL' $(checkedWorkDate) type="checkbox" onClick="if (this.checked) this.form.fromWorkDate.value='', this.form.toWorkDate.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_SLFWKD)
                              @DspErrMsg(Err_SLTWKD)
                              @DspErrMsg(Err_SLAWKD)

                              @SetTextOvr(Err_SLFHDP)
                              %if (textOvr == "") @SetTextOvr(Err_SLTHDP) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SLAHDP) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Check History Department</span></td>
                                  <td class="inputalph"><input name="fromHistDept" value="$(V_SLFHDP)" type="text" size="5" maxlength="5"> <a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromHistDept&amp;fldDesc=fromDeptDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input  name="fromDeptDesc" value="$(fromDeptDesc)"  type="hidden" size="20" maxlength="20"></td>
                                  <td class="inputalph"><input name="toHistDept"   value="$(V_SLTHDP)" type="text" size="5" maxlength="5"> <a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toHistDept&amp;fldDesc=toDeptDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input  name="toDeptDesc" value="$(toDeptDesc)"  type="hidden" size="20" maxlength="20"></td>
                                  <td class="inputalph"><input name="allHistDept" VALUE='ALL' $(checkedHistDept) type="checkbox" onClick="if (this.checked) this.form.fromHistDept.value='', this.form.toHistDept.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_SLFHDP)
                              @DspErrMsg(Err_SLTHDP)
                              @DspErrMsg(Err_SLAHDP)

                              @SetTextOvr(Err_SLFDWP)
                              %if (textOvr == "") @SetTextOvr(Err_SLTDPW) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SLADPW) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Department Worked</span></td>
                                  <td class="inputalph"><input name="fromWorkDept" value="$(V_SLFDPW)" type="text" size="5" maxlength="5"> <a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromWorkDept&amp;fldDesc=fromDeptDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input  name="fromDeptDesc" value="$(fromDeptDesc)"  type="hidden" size="20" maxlength="20"></td>
                                  <td class="inputalph"><input name="toWorkDept"   value="$(V_SLTDPW)" type="text" size="5" maxlength="5"> <a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toWorkDept&amp;fldDesc=toDeptDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input  name="toDeptDesc" value="$(toDeptDesc)"  type="hidden" size="20" maxlength="20"></td>
                                  <td class="inputalph"><input name="allWorkDept" VALUE='ALL' $(checkedWorkDept) type="checkbox" onClick="if (this.checked) this.form.fromWorkDept.value='', this.form.toWorkDept.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_SLFDPW)
                              @DspErrMsg(Err_SLTDPW)
                              @DspErrMsg(Err_SLADPW)

                              @SetTextOvr(Err_SLFTYP)
                              %if (textOvr == "") @SetTextOvr(Err_SLTTYP) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SLATYP) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Summary Pay Type</span></td>
                                  <td class="inputalph"><input name="fromSumType" VALUE="$(V_SLFTYP)"type="text" size="5" maxlength="1"> <a href="$(homeURL)$(cGIPath)SummaryTypeSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Chg&amp;fldName=fromSumType&amp;fldDesc=typeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="typeDesc" value="$(typeDesc)"  type="hidden" size="14" maxlength="14"></td>
                                  <td class="inputalph"><input name="toSumType" VALUE="$(V_SLTTYP)" type="text" size="5" maxlength="1"> <a href="$(homeURL)$(cGIPath)SummaryTypeSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Chg&amp;fldName=toSumType&amp;fldDesc=typeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="typeDesc" value="$(typeDesc)"  type="hidden" size="14" maxlength="14"></td>
                                  <td class="inputalph"><input name="allSumType" VALUE='ALL' $(checkedSumType) type="checkbox" onClick="if (this.checked) this.form.fromSumType.value='', this.form.toSumType.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_SLFTYP)
                              @DspErrMsg(Err_SLTTYP)
                              @DspErrMsg(Err_SLATYP)

                              @SetTextOvr(Err_SLFACT)
                              %if (textOvr == "") @SetTextOvr(Err_SLTACT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SLAACT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Account Number</span></td>
                                  <td class="inputnmbr"><input name="fromAccount" value="$(V_SLFACT)" type="text" size="5" maxlength="4"><a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=fromAccount&amp;subFld=fromSubaccount&amp;descFld=accountDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="accountDesc" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toAccount" value="$(V_SLTACT)" type="text" size="5" maxlength="4"><a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=toAccount&amp;subFld=toSubaccount&amp;descFld=accountDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="accountDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allAccount" value='ALL' $(checkedAccount) type="checkbox" onClick="if (this.checked) this.form.fromAccount.value='', this.form.toAccount.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_SLFACT)
                              @DspErrMsg(Err_SLTACT)
                              @DspErrMsg(Err_SLAACT)

                              @SetTextOvr(Err_SLFSUB)
                              %if (textOvr == "") @SetTextOvr(Err_SLTSUB) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SLASUB) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Subaccount Number</span></td>
                                  <td class="inputnmbr"><input name="fromSubaccount" value="$(V_SLFSUB)" type="text" size="5" maxlength="4"><a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=fromAccount&amp;subFld=fromSubaccount&amp;descFld=accountDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="accountDesc" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toSubaccount" value="$(V_SLTSUB)" type="text" size="5" maxlength="4"><a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=toAccount&amp;subFld=toSubaccount&amp;descFld=accountDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="accountDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allSubaccount" value='ALL' $(checkedSubaccount) type="checkbox" onClick="if (this.checked) this.form.fromSubaccount.value='', this.form.toSubaccount.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_SLFSUB)
                              @DspErrMsg(Err_SLTSUB)
                              @DspErrMsg(Err_SLASUB)

                              @SetTextOvr(Err_SLFCOD)
                              %if (textOvr == "") @SetTextOvr(Err_SLTCOD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SLACOD) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Pay Code</span></td>
                                  <td class="inputalph"><input name="fromPayCode" VALUE="$(V_SLFCOD)"type="text" size="5" maxlength="3"><input name="noCompany" value="" type="hidden"><input name="noFacility" value="" type="hidden"> <a href="$(homeURL)$(phpPath)PayCodeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=noCompany&amp;fldFac=noFacility&amp;fldName=fromPayCode&amp;fldDesc=payCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="payCodeDesc" value="$(fieldDesc)"  type="hidden" size="20" maxlength="20"></td>
                                  <td class="inputalph"><input name="toPayCode" VALUE="$(V_SLTCOD)" type="text" size="5" maxlength="3"><input name="noCompany" value="" type="hidden"><input name="noFacility" value="" type="hidden"> <a href="$(homeURL)$(phpPath)PayCodeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=noCompany&amp;fldFac=noFacility&amp;fldName=toPayCode&amp;fldDesc=payCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="payCodeDesc" value="$(fieldDesc)"  type="hidden" size="20" maxlength="20"></td>
                                  <td class="inputalph"><input name="allPayCode" VALUE='ALL' $(checkedPayCode) type="checkbox" onClick="if (this.checked) this.form.fromPayCode.value='', this.form.toPayCode.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_SLFCOD)
                              @DspErrMsg(Err_SLTCOD)
                              @DspErrMsg(Err_SLACOD)
                          </table>

                          %if (V_SLRPCN == "01")
                              @dtw_assign(envProgram, "HPRPD1")
                              @dtw_assign(envPrinter, "HPRPD1PF")
                          %else
                              @dtw_assign(envProgram, "HPRPD2")
                              @dtw_assign(envPrinter, "HPRPD2PF")
                          %endif
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HPRHRS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL()
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  %if (byEmployee != "1")
      @dtw_assign(byEmployee, "0")
  %endif
  %if (byPayCode != "1")
      @dtw_assign(byPayCode, "0")
  %endif
  %if (byDept != "1")
      @dtw_assign(byDept, "0")
  %endif
  %if (byWorkDept != "1")
      @dtw_assign(byWorkDept, "0")
  %endif

  %INCLUDE "SelEmplEdit.icl"       %{ Prepare Employee Report Selections For Edit %}

  @dtw_mUPPERCASE(allCheckDate)
  @dtw_assign(fromCheckDate,@dtw_rstrip(fromCheckDate))
  @dtw_assign(toCheckDate,@dtw_rstrip(toCheckDate))
  %if (allCheckDate != "ALL")
      @dtw_assign(allCheckDate, "")
  %endif

  @dtw_mUPPERCASE(allWorkDate)
  @dtw_assign(fromWorkDate,@dtw_rstrip(fromWorkDate))
  @dtw_assign(toWorkDate,@dtw_rstrip(toWorkDate))
  %if (allWorkDate != "ALL")
      @dtw_assign(allWorkDate, "")
  %endif

  @dtw_mUPPERCASE(fromHistDept)
  @dtw_mUPPERCASE(toHistDept)
  @dtw_mUPPERCASE(allHistDept)
  %if (allHistDept != "ALL")
      @dtw_assign(allHistDept, "")
  %endif

  @dtw_mUPPERCASE(fromWorkDept)
  @dtw_mUPPERCASE(toWorkDept)
  @dtw_mUPPERCASE(allWorkDept)
  %if (allWorkDept != "ALL")
      @dtw_assign(allWorkDept, "")
  %endif

  @dtw_mUPPERCASE(fromSumType)
  @dtw_mUPPERCASE(toSumType)
  @dtw_mUPPERCASE(allSumType)
  %if (allSumType != "ALL")
      @dtw_assign(allSumType, "")
  %endif

  @dtw_assign(fromAccount,@dtw_rstrip(fromAccount))
  @dtw_assign(toAccount,@dtw_rstrip(toAccount))
  %if (allAccount != "ALL")
      @dtw_assign(allAccount, "")
  %endif

  @dtw_assign(fromSubaccount,@dtw_rstrip(fromSubaccount))
  @dtw_assign(toSubaccount,@dtw_rstrip(toSubaccount))
  %if (allSubaccount != "ALL")
      @dtw_assign(allSubaccount, "")
  %endif

  @dtw_mUPPERCASE(fromPayCode)
  @dtw_mUPPERCASE(toPayCode)
  @dtw_mUPPERCASE(allPayCode)
  %if (allPayCode != "ALL")
      @dtw_assign(allPayCode, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@rpcn", reportContent)

  %INCLUDE "SelEmplConcat.icl"       %{ Concat Employee Report Selections For Edit %}

  @Concat_Field("@@fdat", fromCheckDate)
  @Concat_Field("@@tdat", toCheckDate)
  @Concat_Field("@@adat", allCheckDate)

  @Concat_Field("@@fwkd", fromWorkDate)
  @Concat_Field("@@twkd", toWorkDate)
  @Concat_Field("@@awkd", allWorkDate)

  @Concat_Field("@@fhdp", fromHistDept)
  @Concat_Field("@@thdp", toHistDept)
  @Concat_Field("@@ahdp", allHistDept)

  @Concat_Field("@@fdpw", fromWorkDept)
  @Concat_Field("@@tdpw", toWorkDept)
  @Concat_Field("@@adpw", allWorkDept)

  @Concat_Field("@@ftyp", fromSumType)
  @Concat_Field("@@ttyp", toSumType)
  @Concat_Field("@@atyp", allSumType)

  @Concat_Field("@@fact", fromAccount)
  @Concat_Field("@@tact", toAccount)
  @Concat_Field("@@aact", allAccount)

  @Concat_Field("@@fsub", fromSubaccount)
  @Concat_Field("@@tsub", toSubaccount)
  @Concat_Field("@@asub", allSubaccount)

  @Concat_Field("@@fcod", fromPayCode)
  @Concat_Field("@@tcod", toPayCode)
  @Concat_Field("@@acod", allPayCode)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}