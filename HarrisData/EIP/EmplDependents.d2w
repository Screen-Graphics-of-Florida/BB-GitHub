%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Spouse/Dependents"
  d2wName                 = "EmplDependents.d2w"
  d2wVarBase              = "$(genericVarBase)$(employeeVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(d2wName)"
  nextPrevVar             = "$(d2wVarBase)"
  programName             = "HPESDU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  DTW_PAD_PGM_PARMS       = "YES"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
  @dtw_replace(workURL, "@@fromD2w", "@dtw_rurlescseq(fromD2w)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "EMPLDEPENDENTS")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "UserViewEmpl.icl"
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select SDLNAM, SDFNAM, SDMIDI, SDCLAS, SDREL, SDDOB, SDSPDP, SDSSN, EMCOMP, EMFACL, EMEMPL, EMPECP, EMPEMP, EMDEPT, EMLOC, EMTYPE", stmtSQL)
                      @dtw_concat(fileSQL, " HREMPL inner join HRSPDP on EMCOMP=SDCOMP and EMFACL=SDFACL and EMPEMP=SDEMPL ", fileSQL)
                      @dtw_concat(selectSQL, " EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMPEMP=$(hrEmployee)", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Dependent_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Dependent_Query (IN CHAR(64) profileHandle,
				        CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/report") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Return To Employee">$(portalHome)</a>
                          %endif
                          %if (sec_01 == "Y")
                              <a href="$(homeURL)$(cGIPath)EmplDependentsMaintain.d2w/EMPLDEPENDENTS$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                          %endif
                          <a href="$(homeURL)$(cGIPath)EmployeeMaintainSelect.d2w/REPORT$(d2wVarBase)">$(emplMaintImage)</a>
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>

              @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
              <tr><td><h2>Dependents of $(F_EmpName)</h2></td></tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"	
          $(hrTagAttr)	

              %if (formatToPrint != "Y")
                  <table $(contentTable)>
                      <tr><td> %INCLUDE "AssignPageValue.icl" </td></tr>
                  </table>
              %endif

          <table $(contentTable)>
              <tr>
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y"))
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("SDLNAM", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Name" title="Sequence By Last Name, First Name">Name</a></th>
                  @OrderBy_Sort("SDREL", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Relationship" title="Sequence By Relationship"> Relationship</a></th>
                  @OrderBy_Sort("SDDOB", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DateOfBirth" title="Sequence By Date Of Birth"> Date Of<br>Birth</a></th>	
                  <th class="colhdr">Age</th>
              </tr>		
              %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @Format_EmplName(V_SDFNAM, V_SDLNAM, V_SDMIDI, "", "", "D", F_dependentName)
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;dependentNbr=@dtw_rurlescseq(V_SDSPDP)")
              %if (V_SDDOB > "0")
                  %while(@dtw_rlength(V_SDDOB) != "7") {@dtw_insert("0", V_SDDOB, V_SDDOB)%}
                  %if (V_SDCLAS == "D")
                      @Calc_Years(profileHandle, dataBaseID, V_SDDOB, "", years)
                  %else
                      @dtw_assign(years, "")
                  %endif
              %endif
              @Format_Date(V_SDDOB, "D", F_SDDOB)

              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(F_dependentName), "", "", "", "", "", confirmDesc)
              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                             <a href="$(homeURL)$(cGIPath)EmplDependentsMaintain.d2w/EMPLDEPENDENTS$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                             <a onClick="return confirmDelete('$(confirmDesc)')" href=$(homeURL)$(cGIPath)EmplDependentsMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D&amp;firstName=@dtw_rurlescseq(V_SDFNAM)&amp;lastName=@dtw_rurlescseq(V_SDLNAM)>$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)EmplDependentsSelect.d2w/REPORT$(d2wVarBase)&amp;dependentNbr=@dtw_rurlescseq(V_SDSPDP)" title="View Dependent">$(F_dependentName)</a></td>
                  <td class="colalph">$(V_SDREL)</td>
                  <td class="coldate">$(F_SDDOB)</td>
                  <td class="colnmbr">$(years)</td>
              </tr>
	   %}
      </table>
      %INCLUDE "PageBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "SDDOB,SDLNAM")
              @DTW_ASSIGN(orderByDisplay, "Date Of Birth")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Name")
      %if (orderBy == "SDLNAM,SDFNAM")
          @DTW_ASSIGN(orderBy, "SDLNAM DESC,SDFNAM DESC")
          @DTW_ASSIGN(orderByDisplay, "Last Name (descending), First Name (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SDLNAM,SDFNAM")
          @DTW_ASSIGN(orderByDisplay, "Last Name, First Name")
      %endif
  %elif (sequence == "Relationship")
      %if (orderBy == "SDREL")
          @DTW_ASSIGN(orderBy, "SDREL DESC")
          @DTW_ASSIGN(orderByDisplay, "Relationship (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SDREL")
          @DTW_ASSIGN(orderByDisplay, "Relationship")
      %endif
  %elif (sequence == "DateOfBirth")
      %if (orderBy == "SDDOB,SDLNAM")
          @DTW_ASSIGN(orderBy, "SDDOB DESC,SDLNAM")
          @DTW_ASSIGN(orderByDisplay, "Date Of Birth (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SDDOB,SDLNAM")
          @DTW_ASSIGN(orderByDisplay, "Date Of Birth")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
