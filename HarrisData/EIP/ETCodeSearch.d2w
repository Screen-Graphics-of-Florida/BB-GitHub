%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title 	           = " Code Search"
  d2wName                 = "ETCodeSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)&amp;etCodeType=@dtw_rurlescseq(etCodeType)&amp;touchScreen=@dtw_rurlescseq(touchScreen)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
  advanceSearch           = "N"
  V_CTDESC                = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <link rel=stylesheet type="text/css" href="$(homeURL)$(homePath)HDSLaborEntry.css">
          %if (touchScreen == "Y")
              <link rel=stylesheet type="text/css" href="$(homeURL)$(homePath)HDSTouchScreen.css">
          %endif
          <script type="text/javascript">
              function selectCode(etCode, codeDesc){
                  window.opener.document.$(docName).$(fldName).value = etCode;
                  window.opener.document.$(docName).$(fldDesc).value = codeDesc;
                  %if (touchScreen != "Y")
                      window.opener.document.$(docName).$(fldName).focus();
                  %endif
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
              %if (touchScreen == "Y")
                  %INCLUDE "KeyboardFunctionsTS.icl"
              %endif
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select EVCODE, EVDESC,  ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(EVDESC) as EVDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " HDEVNT ", fileSQL)
                      @dtw_concat(selectSQL, "EVTYPE='$(etCodeType)'", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @EtCode_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) EtCode_Search (IN CHAR(64)    profileHandle,
				      CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (touchScreen == "Y")
          @dtw_assign(displayCloseIcon, "Y")
      %endif
      @RtvFldDesc("CTTYPE='$(etCodeType)'", "ETCTYP", "CTDESC", V_CTDESC)
      @dtw_assign(page_title, "$(V_CTDESC) $(page_title)")
      @dtw_assign(displayCloseIcon, "Y")
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr">Description</th>
                  <th class="colhdr">Code</th>
              </tr>
              <tr>
                  <td class="inputalph">
                      %if (touchScreen == "Y")
          		   <input class="input" id="srchDesc" onfocus="kbActive(this, 'keyboard');" name="srchDesc" type="text" size="20" maxlength="30">
                      %else
                          <input type="text" name="srchDesc" size="20" maxlength="30">
                      %endif
                      <input type="hidden" name="operDesc" value="LIKE">
                  </td>
                  <td class="inputalph">
                      %if (touchScreen == "Y")
          		   <input class="input" id="srchCode" onfocus="kbActive(this, 'keyboard');" name="srchCode" type="text" size="2" maxlength="2">
                      %else
                          <input type="text" name="srchCode" size="2" maxlength="2">
                      %endif
                      <input type="hidden" name="operCode" value="LIKE">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  <td><input type="hidden" id="submitSearch"></td>
              </tr>
          </table>
          %if (touchScreen != "Y")
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          %endif
      </form>

      %if (touchScreen == "Y")
         @dtw_assign(pageSelectList, "N")
         @dtw_assign(wildCardDefault, "N")
         @dtw_assign(advanceSearch, "N")
      %endif
      %INCLUDE "WildCardPage.icl"

      <table $(contentTable)>
          <tr>	
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("EVDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description, Code">Description</a></th>
              @OrderBy_Sort("EVCODE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Code" title="Sequence By Code">Code</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Quote(V_EVDESC, F_EVDESC)
              <tr class="$(rowClass)">
                  <td class="colalph"><a href="javascript:selectCode('$(V_EVCODE)','$(F_EVDESC)')" title="Select Code $(V_EVDESC)">$(V_EVDESC)</a></td>
                  <td class="colalph">$(V_EVCODE)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
      %if (touchScreen == "Y")
         %INCLUDE "KeyboardTS.icl"
      %endif
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "EVDESCU,EVCODE")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Code")
      %if (orderBy == "EVCODE")
          @DTW_ASSIGN(orderBy, "EVCODE DESC")
          @DTW_ASSIGN(orderByDisplay, "Code (descending)")
      %else
          @DTW_ASSIGN(orderBy, "EVCODE")
          @DTW_ASSIGN(orderByDisplay, "Code")
      %endif
  %elseif (sequence == "Desc")
      %if (orderBy == "EVDESCU,EVCODE")
          @DTW_ASSIGN(orderBy, "EVDESCU DESC,EVCODE")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Code")
      %else
          @DTW_ASSIGN(orderBy, "EVDESCU,EVCODE")
          @DTW_ASSIGN(orderByDisplay, "Description, Code")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("EVCODE", "$(V_CTDESC) Code", $(srchCode), "U", operCode, "A")
  @Build_WildCard ("upper(EVDESC)", "Description", $(srchDesc), "U", operDesc, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}