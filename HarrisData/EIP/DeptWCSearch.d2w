%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Department/Work Center Search"
  d2wName                 = "DeptWCSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;forPlant=@dtw_rurlescseq(forPlant)&amp;docName=@dtw_rurlescseq(docName)&amp;fldPlant=@dtw_rurlescseq(fldPlant)&amp;fldPltName=@dtw_rurlescseq(fldPltName)&amp;flddept=@dtw_rurlescseq(flddept)&amp;fldWC=@dtw_rurlescseq(fldWC)&amp;fldDesc=@dtw_rurlescseq(fldDesc)&amp;touchScreen=@dtw_rurlescseq(touchScreen)&amp;dispatch=@dtw_rurlescseq(dispatch)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldPlant                = ""
  fldPltName              = ""
  flddept                 = ""
  fldWC                   = ""
  fldDesc                 = ""
  plant                   = ""
  department              = ""
  workcenter              = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %if (forPlant == "")
                  function selectPltDeptWC(plant, pltname, department, workcenter, desc){
                      window.opener.document.$(docName).$(fldPlant).value = plant;
                      window.opener.document.$(docName).$(fldPltName).value = pltname;
                      window.opener.document.$(docName).$(flddept).value = department;
                      window.opener.document.$(docName).$(fldWC).value = workcenter;
                      window.opener.document.$(docName).$(fldDesc).value = desc;
                      %if (touchScreen != "Y")
                          window.opener.document.$(docName).$(flddept).focus();
                      %endif
                      %if (dispatch == "Y")
                          window.opener.document.$(docName).submit();
                      %endif
                      window.close();
                  }
              %else
                  function selectPltDeptWC(department, workcenter, desc){
                      window.opener.document.$(docName).$(flddept).value = department;
                      window.opener.document.$(docName).$(fldWC).value = workcenter;
                      window.opener.document.$(docName).$(fldDesc).value = desc;
                      %if (touchScreen != "Y")
                      window.opener.document.$(docName).$(flddept).focus();
                      %endif
                      %if (dispatch == "Y")
                      window.opener.document.$(docName).submit();
                      %endif
                      window.close();
                  }
              %endif
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %if (touchScreen == "Y")
                      %INCLUDE "KeyboardFunctionsTS.icl"
              %endif
              function validate(searchForm) {
                  %if (forPlant == "")
                      if (editNum(document.Search.srchPlant, 3, 0))
                          return true;
                  %else
                      return true;
                  %endif
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(uv_PlantName, "WCPLT")
                      @dtw_assign(uv_MfgDepartmentName, "WCDEPT")
                      @dtw_assign(uv_WorkCenterName, "WCWC")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " HDMWCM ", fileSQL)
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, " WCPLT=$(plant) and WCDEPT='$(department)' and WCWC='$(workcenter)'", selectSQL)
                      %elif (forPlant != "")
                          @dtw_concat(selectSQL, " WCPLT=$(forPlant)", selectSQL)
                      %elif (wildCardSearch!="" || uv_Sql != "")
                          @dtw_concat(selectSQL, " WCPLT<>0", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @DeptWC_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) DeptWC_Search (IN CHAR(64)    profileHandle,
     	                              CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
  	  %if (touchScreen == "Y")
          @dtw_assign(displayCloseIcon, "Y")
      %endif
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Plant</th>
                      <th class="colhdr">Dept / Work<br>Center</th>
                  </tr>
                  <tr>
                      %if (forPlant != "")
                          <td class="colnmbr">$(forPlant)
                          <input type="hidden" name="operPlant" value="=">
                          </td>
                      %else
                          <td class="inputnmbr">
                      	       %if (touchScreen == "Y")
              		    	      <input class="input" id="srchPlant" onfocus="kbActive(this, 'numericKeyboard');" name="srchPlant" type="text" size="3" maxlength="3">
                    	          <input type="hidden" id="submitSearch">
              		       %else		
                                  <input type="text" name="srchPlant" size="3" maxlength="3" value=$(forPlant)>
                              %endif
                              <input type="hidden" name="operPlant" value="=">
                          </td>
                      %endif

                      <td class="inputalph">
                          %if (touchScreen == "Y")
              		          <input class="input" id="srchDept" onfocus="kbActive(this, 'keyboard');" name="srchDept" type="text" size="5" maxlength="5"> / <input class="input" id="srchWC" onfocus="kbActive(this, 'keyboard');" name="srchWC" type="text" size="5" maxlength="5">
                          %else
                              <input type="text" name="srchDept" size="5" maxlength="5"> / <input type="text" name="srchWC" size="5" maxlength="5">
                          %endif
                          <input type="hidden" name="operDept" value="LIKE">
                          <input type="hidden" name="operWC" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              %if (touchScreen != "Y")
                  <script TYPE="text/javascript">
                      %if (forPlant != "")
                          document.Search.srchDept.focus();
                      %else
                          document.Search.srchPlant.focus();
                      %endif
                  </script>
              %endif
          </form>
		
          %if (touchScreen == "Y")
             @dtw_assign(pageSelectList, "N")
             @dtw_assign(wildCardDefault, "N")
             @dtw_assign(advanceSearch, "N")
          %endif
      	
          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("WCPLT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=plant" title="Sequence By Plant"> Plant</a></th>
                  @OrderBy_Sort("WCDEPT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=dept" title="Sequence By Department"> Department</a></th>
                  @OrderBy_Sort("WCWC", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=wc" title="Sequence By Work Center"> Work Center</a></th>
                  <th class="colhdr">Description</th
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %else
          <table $(contentTable)>
      %endif		

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @RtvFldDesc("PLPLNT=$(V_WCPLT)", "HDPLNT", "PLNAME", plantName)
              @Format_Quote(plantName, F_plantName)
              @Format_Quote(V_WCDEPT, F_WCDEPT)
              @Format_Quote(V_WCWC, F_WCWC)
              @Format_Quote(V_WCDESC, F_WCDESC)


              %if (moreInfo != "Y")	
                  <tr class="$(rowClass)">
                      <td class="colnmbr">$(V_WCPLT)</td>
                      <td class="colalph">$(V_WCDEPT)</td>
                      <td class="colalph">$(V_WCWC)</td>
                      <td class="colalph">
                          %if (forPlant == "")
                              <a href="javascript:selectPltDeptWC('$(V_WCPLT)', '$(F_plantName)', '$(F_WCDEPT)', '$(F_WCWC)', '$(F_WCDESC)')" title="Select Department/Work Center">$(V_WCDESC)</a>
                          %else
                             <a href="javascript:selectPltDeptWC('$(F_WCDEPT)', '$(F_WCWC)', '$(F_WCDESC)')" title="Select Department/Work Center">$(V_WCDESC)</a>
                          %endif
                      </td>
                      <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;plant=@dtw_rurlescseq(V_WCPLT)&amp;department=@dtw_rurlescseq(V_WCDEPT)&amp;workcenter=@dtw_rurlescseq(V_WCWC)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                  </tr>

              %else
                  %{ More Information Page %}

                  <tr><td>
                      %if (forPlant == "")
                          <a href="javascript:selectPltDeptWC('$(V_WCPLT)', '$(F_plantName)', '$(F_WCDEPT)', '$(F_WCWC)', '$(F_WCDESC)')" title="Select Department/Work Center">$(selectImageLrg)</a>
                      %else
                         <a href="javascript:selectPltDeptWC('$(F_WCDEPT)', '$(F_WCWC)', '$(F_WCDESC)')" title="Select Department/Work Center">$(selectImageLrg)</a>
                      %endif
                      </td>
                  </tr>

                  <tr><td class="dsphdr">Plant Number</td>
                      <td class="dspalph">$(V_WCPLT)</td>
                      <td class="dspalph">$(plantName)</td>
                  </tr>
	      		
                  <tr><td class="dsphdr">Department/Work Center</td>
                      <td class="dspalph">$(V_WCDEPT) / $(V_WCWC)</td>
                      <td class="dspalph">$(V_WCDESC)</td>
                  </tr>
	      		
                  <tr><td class="dsphdr">Labor Utilization %</td>
                      <td class="dspalph">$(V_WCLAUT)</td>
                  </tr>
	      		
                  <tr><td class="dsphdr">Labor Efficiency %</td>
                      <td class="dspalph">$(V_WCLAEF)</td>
                  </tr>
	      		
                  <tr><td class="dsphdr">Direct Labor Hours Per Day</td>
                      <td class="dspalph">$(V_WCLHRD)</td>
                  </tr>
	      		
                  <tr><td class="dsphdr">Machine Utilization %</td>
                      <td class="dspalph">$(V_WCMAUT)</td>
                  </tr>
	      		
                  <tr><td class="dsphdr">Machine Hours Per Day</td>
                      <td class="dspalph">$(V_WCMHRD)</td>
                  </tr>
	      		
                  <tr><td class="dsphdr">Setup Hours Per Day</td>
                      <td class="dspalph">$(V_WCSHRD)</td>
                  </tr>
	      		
                  <tr><td class="dsphdr">Transit Days</td>
                      <td class="dspalph">$(V_WCMTD)</td>
                  </tr>
	      		
                  <tr><td class="dsphdr">Key Load Code</td>
                      <td class="dspalph">$(V_WCKLCD)</td>
                  </tr>

                  @Format_CoFac("$(V_WCCO)", "$(V_WCFAC)", "", F_CoFac)
                  <tr><td class="dsphdr">Company/Facility</td>
                      <td class="dspalph">$(F_CoFac)</td>
                  </tr>
	      		
                  <tr><td class="dsphdr">Schedule</td>
                      <td class="dspalph">$(V_WCSCHD)</td>
                  </tr>

                  @Format_Nbr($(V_WCTDEH), F_WCTDEH, "2", $(hrsEditCode), "", "", "")
                  <tr><td class="dsphdr">YTD Earned Hours</td>
                      <td class="dspnmbr">$(F_WCTDEH)</td>
                  </tr>

                  @Format_Nbr($(V_WCTDAH), F_WCTDAH, "2", $(hrsEditCode), "", "", "")
                  <tr><td class="dsphdr">YTD Actual Hours</td>
                      <td class="dspnmbr">$(F_WCTDAH)</td>
                  </tr>

                  @Format_Nbr($(V_WCTDMH), F_WCTDMH, "2", $(hrsEditCode), "", "", "")
                  <tr><td class="dsphdr">YTD Misc Hours</td>
                      <td class="dspnmbr">$(F_WCTDMH)</td>
                  </tr>

                  @Format_Nbr($(V_WCTDAE), F_WCTDAE, "2", $(hrsEditCode), "", "", "")
                  <tr><td class="dsphdr">YTD Earned Rework</td>
                      <td class="dspnmbr">$(F_WCTDAE)</td>
                  </tr>

                  @Format_Nbr($(V_WCTDAR), F_WCTDAR, "2", $(hrsEditCode), "", "", "")
                  <tr><td class="dsphdr">YTD Actual Rework</td>
                      <td class="dspnmbr">$(F_WCTDAR)</td>
                  </tr>

                  @Format_Nbr($(V_WCTDSU), F_WCTDSU, "2", $(hrsEditCode), "", "", "")
                  <tr><td class="dsphdr">YTD Setup Hours</td>
                      <td class="dspnmbr">$(F_WCTDSU)</td>
                  </tr>

              %endif
          %}
      </table>
      %if (moreInfo != "Y")	
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
      %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
      %if (touchScreen == "Y")
         %INCLUDE "KeyboardTS.icl"
      %endif
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "WCPLT,WCDEPT,WCWC")
      @DTW_ASSIGN(orderByDisplay, "Plant, Department, Work Center")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(orderBy, "WCPLT")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "plant")
      %if (orderBy == "WCPLT")
          @DTW_ASSIGN(orderBy, "WCPLT DESC")
          @DTW_ASSIGN(orderByDisplay, "Plant (descending)")
      %else
          @DTW_ASSIGN(orderBy, "WCPLT")
          @DTW_ASSIGN(orderByDisplay, "Plant")
      %endif
  %elif (sequence == "dept")
      %if (orderBy == "WCDEPT")
          @DTW_ASSIGN(orderBy, "WCDEPT DESC")
          @DTW_ASSIGN(orderByDisplay, "Department (descending)")
      %else
          @DTW_ASSIGN(orderBy, "WCDEPT")
          @DTW_ASSIGN(orderByDisplay, "Department")
      %endif
  %elif (sequence == "wc")
      %if (orderBy == "WCWC")
          @DTW_ASSIGN(orderBy, "WCWC DESC")
          @DTW_ASSIGN(orderByDisplay, "Work Center (descending)")
      %else
          @DTW_ASSIGN(orderBy, "WCWC")
          @DTW_ASSIGN(orderByDisplay, "Work Center")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %if (forPlant == "")
                  function validate(searchForm) {
                      if (editNum(document.Search.srchPlant, 3, 0))
                      return true;
                  }
              %else
                  %INCLUDE "NoFormValidate.icl"
              %endif
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          %if (forPlant == "")
                              <tr><td class="dsphdr">Plant</td>
                                  @dtw_assign(operNbr, "operPlant")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"> <input type="text" name="srchPlant" size="3" maxlength="3"></td>
                              </tr>
                          %endif

                          <tr><td class="dsphdr">Department</td>
                              @dtw_assign(operNbr, "operDept")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchDept" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">Work Center</td>
                              @dtw_assign(operNbr, "operWC")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchWC" size="5" maxlength="5"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("WCPLT", "Plant", $(srchPlant), "", operPlant, "N")
  @Build_WildCard ("WCDEPT", "Department", $(srchDept), "U", operDept, "A")
  @Build_WildCard ("WCWC", "Work Center", $(srchWC), "U", operWC, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}