%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "WildCardAcct.icl"

%Define {	
  page_title              = "Site Search"
  d2wName                 = "FASiteSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectSite(faSite, faSiteName){
                  window.opener.document.$(docName).$(fldName).value = faSite;
                  window.opener.document.$(docName).$(fldDesc).value = faSiteName;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(uv_CompanyName, "ACCO#")
                      @dtw_assign(uv_FacilityName, "ACFAC#")
                      @dtw_assign(uv_SiteName, "ACLOCN")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select FASITE.*, upper(ACLONM) as ACLONMU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(CFCFNM,' ') as CFCFNM, coalesce(CFCFNMU,' ') as CFCFNMU ", stmtSQL)
                      @dtw_concat(fileSQL, " FASITE ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDCFAC on CFCO#=ACCO# and CFFAC#=ACFAC# ", fileSQL)
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, " ACLOCN=$(faSite)", selectSQL)
                      %elif (wildCardSearch!="")
                          @dtw_concat(selectSQL, " ACLOCN<>0 ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN CHAR(64)    profileHandle,
                                  CHAR(2)     dataBaseID,
                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Name</th>
                      <th class="colhdr">Site</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchName" size="20" maxlength="26">
                          <input type="hidden" name="operName" value="LIKE">
                      </td>
                      <td><input type="text" class="inputnmbr" name="srchSite" size="5" maxlength="3">
                          <input type="hidden" name="operSite" value="=">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchName.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("ACLOCN", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Site" title="Sequence By Site">Site</a></th>
                  @OrderBy_Sort("ACLONMU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Name" title="Sequence By Name, Site">Name</a></th>
                  @OrderBy_Sort("ACLOAD", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Address" title="Sequence By Address, Site">Address</a></th>
                  @OrderBy_Sort("CFCFNMU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CoFac" title="Sequence By Co/Fac, Site">Co/Fac</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %else
          <table $(contentTable)>
      %endif		

              %ROW{
                  %INCLUDE "SetRowClass.icl"
                  @Format_CoFac(V_ACCO#, V_ACFAC#, "", F_CoFac)
                  @Format_Quote(V_ACLONM, F_ACLONM)

                  %if (moreInfo != "Y")	
                      <tr class="$(rowClass)">
                          <td class="colnmbr">$(V_ACLOCN)</td>
                          <td class="colalph"><a href="javascript:selectSite($(V_ACLOCN),'$(F_ACLONM)')" title="Select Site">$(V_ACLONM)</a></td>
                          <td class="colalph">$(V_ACLOAD)
                              %if (V_ACLOA2 != "")
                                  <br>$(V_ACLOA2)
                              %endif
                              <br>$(V_ACLOCT) $(V_ACLOST) $(V_ACLOZP)
                          </td>
                          <td class="colalph" $(helpCursor)><span title="$(F_CoFac)">$(V_CFCFNM)</span></td>
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;faSite=@dtw_rurlescseq(V_ACLOCN)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                      </tr>

                  %else

                      <tr><td><a href="javascript:selectSite($(V_ACLOCN),'$(F_ACLONM)')" title="Select Site">$(selectImageLrg)</a></td></tr>

                      <tr><td class="dsphdr">Site</td>
                          <td class="dspnmbr">$(V_ACLOCN)</td>
                      </tr>

                      <tr><td class="dsphdr">Name</td>
                          <td class="dspalph">$(V_ACLONM)</td>
                      </tr>

                      <tr><td class="dsphdr">Address</td>
                          <td class="dspalph">$(V_ACLOAD)</td>
                      </tr>	

                      %if (V_ACLOA2 != "")
                          <tr><td class="dsphdr">&nbsp;</td>
                              <td class="dspalph">$(V_ACLOA2)</td>
                          </tr>
                      %endif

                      <tr><td class="dsphdr">&nbsp;</td>
                          <td class="dspalph">$(V_ACLOCT) $(V_ACLOST) $(V_ACLOZP)</td>
                      </tr>	

                      @RtvFldDesc("CFCO#=$(V_ACCO#) and CFFAC#=$(V_ACFAC#)", "HDCFAC", "CFCFNM", coFacDesc)
                      <tr><td class="dsphdr">Company/Facility</td>
                          <td class="dspnmbr">$(F_CoFac) &nbsp; $(coFacDesc)</td></tr>

                  %endif
              %}
          </table>
          %if (moreInfo != "Y")	
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
          %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "ACLONMU,ACLOCN")
      @DTW_ASSIGN(orderByDisplay, "Name< Site")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Site")
      %if (orderBy == "ACLOCN")
          @DTW_ASSIGN(orderBy, "ACLOCN DESC")
          @DTW_ASSIGN(orderByDisplay, "Site (descending)")
      %else
          @DTW_ASSIGN(orderBy, "ACLOCN")
          @DTW_ASSIGN(orderByDisplay, "Site")
      %endif
  %elif (sequence == "Name")
      %if (orderBy == "ACLONMU,ACLOCN")
          @DTW_ASSIGN(orderBy, "ACLONMU DESC,ACLOCN")
          @DTW_ASSIGN(orderByDisplay, "Name (descending), Site")
      %else
          @DTW_ASSIGN(orderBy, "ACLONMU,ACLOCN")
          @DTW_ASSIGN(orderByDisplay, "Name, Site")
      %endif
  %elif (sequence == "Address")
      %if (orderBy == "ACLOAD,ACLOCN")
          @DTW_ASSIGN(orderBy, "ACLOAD DESC,ACLOCN")
          @DTW_ASSIGN(orderByDisplay, "Address (descending), Site")
      %else
          @DTW_ASSIGN(orderBy, "ACLOAD,ACLOCN")
          @DTW_ASSIGN(orderByDisplay, "Address, Site")
      %endif
  %elif (sequence == "CoFac")
      %if (orderBy == "CFCFNMU,ACLOCN")
          @DTW_ASSIGN(orderBy, "CFCFNMU DESC,ACLOCN")
          @DTW_ASSIGN(orderByDisplay, "Co/Fac (descending), Site")
      %else
          @DTW_ASSIGN(orderBy, "CFCFNMU,ACLOCN")
          @DTW_ASSIGN(orderByDisplay, "Co/Fac, Site")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "dateedit.icl"
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchSite, 3, 0) &&
                      editNum(document.Search.srchCo, 2, 0) &&
                      editNum(document.Search.srchFac, 4, 0))
                  return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "FASITESEARCH")
                  <td>
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Site</td>
                              @dtw_assign(operNbr, "operSite")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchSite" size="3" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Name</td>
                              @dtw_assign(operNbr, "operName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchName" size="26" maxlength="26"></td>
                          </tr>

                          <tr><td class="dsphdr">Company</td>
                              @dtw_assign(operNbr, "operCo")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchCo" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Facility</td>
                              @dtw_assign(operNbr, "operFac")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchFac" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Address</td>
                              <td>&nbsp;</td>
                              <td class="inputalph"><input type="text" name="srchAddress" size="26" maxlength="26"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchSite.focus();
                          </script>
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("ACLOCN", "Site", $(srchSite), "", operSite, "N")
  @Build_WildCard ("upper(ACLONM)", "Name", $(srchName), "U", operName, "A")
  @Build_WildCard ("ACCO#", "Company", $(srchCo), "", operCo, "N")
  @Build_WildCard ("ACFAC#", "Facility", $(srchFac), "", operFac, "N")
  @dtw_assign(srchAddress,@dtw_rstrip(srchAddress))
  %if (srchAddress != "")
      @Build_WildCard ("upper(ACLOAD)", "Address", $(srchAddress), "U", "LIKE", "V")
      @dtw_assign(srchAddress,"@dtw_rUPPERCASE(srchAddress)%")
      @dtw_replace(srchAddress, "?", "_", "1", "a", srchAddress)
      @dtw_replace(srchAddress, "*", "%", "1", "a", srchAddress)
      @dtw_concat(wildCardTemp, " (trim(upper(ACLOAD)) LIKE '$(srchAddress)'", wildCardTemp)
      @dtw_concat(wildCardTemp, " OR   trim(upper(ACLOA2)) LIKE '$(srchAddress)'", wildCardTemp)
      @dtw_concat(wildCardTemp, " OR   trim(upper(ACLOCT)) LIKE '$(srchAddress)'", wildCardTemp)
      @dtw_concat(wildCardTemp, " OR   trim(upper(ACLOST)) LIKE '$(srchAddress)')", wildCardTemp)
  %endif

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
