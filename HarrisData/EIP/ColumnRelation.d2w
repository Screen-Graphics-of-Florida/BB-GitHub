%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Column Relation"
  d2wName                 = "ColumnRelation.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;tblID=@dtw_rurlescseq(tblID)&amp;tableName=@dtw_rurlescseq(tableName)&amp;tableDesc=@dtw_rurlescseq(tableDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HSYTCR_E"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "COLUMNRELATION")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " SYTBCR", fileSQL)
                      @dtw_concat(selectSQL, "CRTBID=$(tblID) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy)", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Column_Relation_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Column_Relation_Query (IN CHAR(64)    profileHandle,
                                             CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)ColumnRelationMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      <table $(contentTable)>
	      @dtw_assign(customTable, "")
		  %if (tblID >= "5000")
			@dtw_assign(customTable, "Custom")
		  %endif
          @Format_Header_URL("Table", $(tableDesc), $(tableName), "$(homeURL)$(cGIPath)$(customTable)Table.d2w/REPORT$(genericVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))")
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">Column Name</th>
                  </tr>
                  <tr>
                      <td>
                          <input type="text" class="inputalph" name="srchDesc" size="10" maxlength="50">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td>
                          <input type="text" class="inputalph" name="srchCol" size="10" maxlength="130">
                          <input type="hidden" name="operCol" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("CRDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description">Description</a></th>
              @OrderBy_Sort("CRCOLN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Column" title="Sequence By Column Name">Column<br>Name</a></th>
              @OrderBy_Sort("CRRLC1", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Rel1" title="Sequence By Related Column 1">Related<br>Column 1</a></th>
              @OrderBy_Sort("CRRLC2", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Rel2" title="Sequence By Related Column 2">Related<br>Column 2</a></th>
              @OrderBy_Sort("CRRLC3", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Rel3" title="Sequence By Related Column 3">Related<br>Column 3</a></th>
              @OrderBy_Sort("CRRLC4", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Rel4" title="Sequence By Related Column 4">Related<br>Column 4</a></th>
              @OrderBy_Sort("CRRLC5", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Rel5" title="Sequence By Related Column 5">Related<br>Column 5</a></th>
              @OrderBy_Sort("CRFTYP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Type" title="Sequence By Table Name">Format<br>Type</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;relID=@dtw_rurlescseq(V_CRRLID)&amp;relDesc=@dtw_rurlescseq(V_CRDESC)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_CRDESCU), $(V_CRCOLN), "", "", "", "", confirmDesc)
              @RtvFldDesc("TCTBLN='$(tableName)' and TCCOLN='$(V_CRCOLN)' ", "SYTBLC", "TCCTXT", columnDesc)
              @RtvFldDesc("TCTBLN='$(tableName)' and TCCOLN='$(V_CRRLC1)' ", "SYTBLC", "TCCTXT", relCol1Desc)
              @RtvFldDesc("TCTBLN='$(tableName)' and TCCOLN='$(V_CRRLC2)' ", "SYTBLC", "TCCTXT", relCol2Desc)
              @RtvFldDesc("TCTBLN='$(tableName)' and TCCOLN='$(V_CRRLC3)' ", "SYTBLC", "TCCTXT", relCol3Desc)
              @RtvFldDesc("TCTBLN='$(tableName)' and TCCOLN='$(V_CRRLC4)' ", "SYTBLC", "TCCTXT", relCol4Desc)
              @RtvFldDesc("TCTBLN='$(tableName)' and TCCOLN='$(V_CRRLC5)' ", "SYTBLC", "TCCTXT", relCol5Desc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)ColumnRelationMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)ColumnRelationMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)ColumnRelationMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_CRDESC)</td>
                  <td class="colalph" $(helpCursor)><span title="$(columnDesc)">$(V_CRCOLN)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(relCol1Desc)">$(V_CRRLC1)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(relCol2Desc)">$(V_CRRLC2)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(relCol3Desc)">$(V_CRRLC3)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(relCol4Desc)">$(V_CRRLC4)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(relCol5Desc)">$(V_CRRLC5)</span></td>
                  <td class="colalph">$(V_CRFTYP)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "CRCOLN")
          @DTW_ASSIGN(orderByDisplay, "Column Name")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Column")
      %if (orderBy == "CRCOLN")
          @DTW_ASSIGN(orderBy, "CRCOLN DESC")
          @DTW_ASSIGN(orderByDisplay, "Column Name (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CRCOLN")
          @DTW_ASSIGN(orderByDisplay, "Column Name")
      %endif
  %elif (sequence == "Desc")
      %if (orderBy == "CRDESCU")
          @DTW_ASSIGN(orderBy, "CRDESCU DESC")
          @DTW_ASSIGN(orderByDisplay, "Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Description")
      %endif
  %elif (sequence == "Type")
      %if (orderBy == "CRFTYP")
          @DTW_ASSIGN(orderBy, "CRFTYP DESC")
          @DTW_ASSIGN(orderByDisplay, "Format Type (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CRFTYP")
          @DTW_ASSIGN(orderByDisplay, "Format Type")
      %endif
  %elif (sequence == "Rel1")
      %if (orderBy == "CRRLC1")
          @DTW_ASSIGN(orderBy, "CRRLC1 DESC")
          @DTW_ASSIGN(orderByDisplay, "Related Column 1 (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CRRLC1")
          @DTW_ASSIGN(orderByDisplay, "Related Column 1")
      %endif
  %elif (sequence == "Rel2")
      %if (orderBy == "CRRLC2")
          @DTW_ASSIGN(orderBy, "CRRLC2 DESC")
          @DTW_ASSIGN(orderByDisplay, "Related Column 2 (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CRRLC2")
          @DTW_ASSIGN(orderByDisplay, "Related Column 2")
      %endif
  %elif (sequence == "Rel3")
      %if (orderBy == "CRRLC3")
          @DTW_ASSIGN(orderBy, "CRRLC3 DESC")
          @DTW_ASSIGN(orderByDisplay, "Related Column 3 (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CRRLC3")
          @DTW_ASSIGN(orderByDisplay, "Related Column 3")
      %endif
  %elif (sequence == "Rel4")
      %if (orderBy == "CRRLC4")
          @DTW_ASSIGN(orderBy, "CRRLC4 DESC")
          @DTW_ASSIGN(orderByDisplay, "Related Column 4 (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CRRLC4")
          @DTW_ASSIGN(orderByDisplay, "Related Column 4")
      %endif
  %elif (sequence == "Rel5")
      %if (orderBy == "CRRLC5")
          @DTW_ASSIGN(orderBy, "CRRLC5 DESC")
          @DTW_ASSIGN(orderByDisplay, "Related Column 5 (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CRRLC5")
          @DTW_ASSIGN(orderByDisplay, "Related Column 5")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          @dtw_assign(formName, "Search")
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "COLUMNRELATION")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Column Name</td>
                              @dtw_assign(operNbr, "operCol")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchCol" type="text" size="10" maxlength="130"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchDesc" type="text" size="10" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Format Type</td>
                              @dtw_assign(operNbr, "operType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchType" type="text" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Related Column 1</td>
                              @dtw_assign(operNbr, "operRel1")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchRel1" type="text" size="10" maxlength="130"></td>
                          </tr>

                          <tr><td class="dsphdr">Related Column 2</td>
                              @dtw_assign(operNbr, "operRel2")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchRel2" type="text" size="10" maxlength="130"></td>
                          </tr>

                          <tr><td class="dsphdr">Related Column 3</td>
                              @dtw_assign(operNbr, "operRel3")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchRel3" type="text" size="10" maxlength="130"></td>
                          </tr>

                          <tr><td class="dsphdr">Related Column 4</td>
                              @dtw_assign(operNbr, "operRel4")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchRel4" type="text" size="10" maxlength="130"></td>
                          </tr>

                          <tr><td class="dsphdr">Related Column 5</td>
                              @dtw_assign(operNbr, "operRel5")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchRel5" type="text" size="10" maxlength="130"></td>
                          </tr>
                          %INCLUDE "SearchBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
  @Build_WildCard ("CRCOLN", "Column Name", $(srchID), "U", $(operID), "A")
  @Build_WildCard ("CRDESCU", "Description", $(srchDesc), "U", $(operDesc), "A")
  @Build_WildCard ("CRFTYP", "Format Type", $(srchType), "U", $(operType), "A")
  @Build_WildCard ("CRRLC1", "Related Column 1", $(srchRel1), "U", $(operRel1), "A")
  @Build_WildCard ("CRRLC2", "Related Column 2", $(srchRel2), "U", $(operRel2), "A")
  @Build_WildCard ("CRRLC3", "Related Column 3", $(srchRel3), "U", $(operRel3), "A")
  @Build_WildCard ("CRRLC4", "Related Column 4", $(srchRel4), "U", $(operRel4), "A")
  @Build_WildCard ("CRRLC5", "Related Column 5", $(srchRel5), "U", $(operRel5), "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}