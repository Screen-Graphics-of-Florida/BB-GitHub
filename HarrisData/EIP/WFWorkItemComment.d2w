%INCLUDE "$(baseVar)"
%INCLUDE "BrowserType.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Work Item Comment"
  d2wName                 = "WFWorkItemComment.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfInstance=@dtw_rurlescseq(wfInstance)&amp;wfInstanceDate=@dtw_rurlescseq(wfInstanceDate)&amp;wfWorkItem=@dtw_rurlescseq(wfWorkItem)&amp;wfWorkItemSequence=@dtw_rurlescseq(wfWorkItemSequence)&amp;wfParticipantId=@dtw_rurlescseq(wfParticipantId)&amp;expireDate=@dtw_rurlescseq(expireDate)&amp;specWfInstance=@dtw_rurlescseq(specWfInstance)&amp;specWfInstanceDate=@dtw_rurlescseq(specWfInstanceDate)&amp;specWfWorkItem=@dtw_rurlescseq(specWfWorkItem)&amp;specWfWorkItemSequence=@dtw_rurlescseq(specWfWorkItemSequence)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "headcmt.icl"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(cmtBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      @dtw_concat(stmtSQL, " Select WFWICM.*,WFWIPT.* ", stmtSQL)
                      @dtw_concat(fileSQL, " WFWICM ", fileSQL)
                      @dtw_concat(fileSQL, " inner join WFWIPT on WPINST=WCINST and WPINDT=WCINDT and WPWITM=WCWITM and WPWISQ=WCWISQ and WPPTID=WCPTID ", fileSQL)
                      @dtw_concat(selectSQL, " WCINST=$(wfInstance) and WCINDT=$(wfInstanceDate) and (WCWITM<>$(wfWorkItem) or WCWISQ<>$(wfWorkItemSequence) or WCPTID<>$(wfParticipantId))", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By WCINST,WCINDT,WCWITM,WCWISQ,WCPTID,WCCSEQ ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(cmtTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64) profileHandle,
                                   CHAR(2)   dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (cmtSelection=="C")
          @dtw_assign(V_WCREAS, "")
          @dtw_assign(V_WCCMNT, "")
      %elseif (errFound == "")
          @dtw_assign(edtVar, "")
          @Concat_Field("@@inst", wfInstance)
          @Concat_Field("@@indt", wfInstanceDate)
          @Concat_Field("@@witm", wfWorkItem)
          @Concat_Field("@@wisq", wfWorkItemSequence)
          @Concat_Field("@@ptid", wfParticipantId)
          @dtw_concat(edtVar, "}{", edtVar)
          @Get_WF_Comments(profileHandle, dataBaseID, edtVar, V_WCREAS, V_WCCMNT)
      %endif
      @dtw_assign(comments, "")

      @dtw_assign(displayCloseIcon, "Y")
      %INCLUDE "PageTitle.icl"

      <table $(contentTable)>
          @RtvFldDesc("ININST=$(wfInstance) and ININDT=$(wfInstanceDate)", "WFINST", "INDESC", V_INDESC)
          <tr><td><h2> $(V_INDESC)</h2></td></tr>
          @RtvFldDesc("WPINST=$(wfInstance) and WPINDT=$(wfInstanceDate) and WPWITM=$(wfWorkItem) and WPWISQ=$(wfWorkItemSequence) and WPPTID=$(wfParticipantId)", "WFWIPT", "WPPART", V_WPPART)
          @RtvFldDesc("USUSER='$(V_WPPART)'", "SYUSER", "USDESC", V_USDESC)
          @Format_Code("$(V_WPPART)", F_WPPART)
          <tr><td><h2> $(V_USDESC) $(F_WPPART)</h2></td></tr>
          @RtvFldDesc("ININST=$(wfInstance) and ININDT=$(wfInstanceDate)", "WFINST", "INPROC", V_INPROC)
          @RtvFldDesc("WHINST=$(wfInstance) and WHINDT=$(wfInstanceDate) and WHWITM=$(wfWorkItem) and WHWISQ=$(wfWorkItemSequence)", "WFWIHS", "CHAR(WHPONT)", V_WHPONT)
          @RtvFldDesc("WHINST=$(wfInstance) and WHINDT=$(wfInstanceDate) and WHWITM=$(wfWorkItem) and WHWISQ=$(wfWorkItemSequence)", "WFWIHS", "CHAR(WHSEQ)", V_WHSEQ)
          @RtvFldDesc("PDPROC='$(V_INPROC)' and PDPONT=$(V_WHPONT) and PDSEQ=$(V_WHSEQ) ", "WFPRDT", "PDDESC", V_PDDESC)
          @Format_Code("$(V_WHPONT)-$(V_WHSEQ)", F_WHPONT)
          <tr><td><h2>$(V_PDDESC) $(F_WHPONT)</h2></td></tr>
      </table>

      $(inquiryhrTagAttr)

      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
          %if (errFound != "")
              @dtw_assign(focusField, "")
              @EdtVarErr(profileHandle, typeValue, edtVar)
              @ErrVarErr(profileHandle, typeError, errVar)
              @DecatErr_Field("@@reas", "wfReason")            @dtw_assign(Err_WCREAS, fieldValue)

              @Decat_Field("@@reas")   @dtw_assign(V_WCREAS, fieldValue)
              @Decat_Field("@@cmnt")   @dtw_assign(V_WCCMNT, fieldValue)

              @dtw_assign(errFound, "")
          %else
              @dtw_assign(focusField, "wfReason")
          %endif

          <table $(contentTable)>
              @SetTextOvr(Err_WCREAS)
              @RtvFldDesc("RSREAS='$(V_WCREAS)' ", "WFRSCD", "RSDESC", fieldDesc)
              <tr><td class="dsphdr"><span $(textOvr)>Reason Code</span></td>
                  <td class="inputalph"><input name="wfReason" type="text" value="$(V_WCREAS)" size="4" maxlength="4"><a href="$(homeURL)$(cGIPath)WFReasonSearch.d2w/REPORT$(genericVarBase)&amp;docName=Chg&amp;fldName=wfReason&amp;fldDesc=wfReasonDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                                        <input disabled name="wfReasonDesc" value="$(fieldDesc)" type="text" size="30"></td>
              </tr>
              @DspErrMsg(Err_WCREAS)
          </table>

          <table $(contentTable)>
              <tr><td><input type="hidden" name="cmtSelection"></td>
                  <td>
                      %if ("$(V_WCCMNT)" != "")
                          <textarea name="comments" ROWS=5 COLS=60 WRAP="hard">$(V_WCCMNT)</textarea>
                      %else
                          <textarea name="comments" ROWS=5 COLS=60 WRAP="hard"></textarea>
                      %endif
                  </td>
              </tr>
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>

      <table $(contentTable)>
          <tr>
              <td valign="top">
                  <a href="javascript:document.Chg.cmtSelection.value='A'; check(document.Chg)">$(commentAcceptImage)</a>
                  <a href="$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)" onclick="$(commentWinVar)">$(commentResetImage)</a>
                  <a href="$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;cmtSelection=C" onclick="$(commentWinVar)">$(commentClearImage)</a>
              </td>
          </tr>
      </table>

      <fieldset class="legendBody">
          <legend class="legendTitle">Other Comments</legend>
          <table $(contentTable)>
              @dtw_assign(Check_WCPTID, "")
              @dtw_assign(Check_WCWITM, "")
              @dtw_assign(Check_WCWISQ, "")

              %ROW{
                  %if (V_WCWITM != Check_WCWITM || V_WCWISQ != Check_WCWISQ || V_WCPTID != Check_WCPTID)
                      @dtw_assign(Check_WCPTID, V_WCPTID)
                      @dtw_assign(Check_WCWITM, V_WCWITM)
                      @dtw_assign(Check_WCWISQ, V_WCWISQ)
                      @RtvFldDesc("USUSER='$(V_WPPART)'", "SYUSER", "USDESC", V_USDESC)
                      @RtvFldDesc("RSREAS='$(V_WCREAS)'", "WFRSCD", "RSDESC", V_RSDESC)
                      @Format_Code(V_RSDESC, F_RSDESC)
                      <tr><td><h2>$(V_USDESC) $(F_RSDESC):</h2></td></tr>
                  %endif

                  <tr>
                      <td class="colalph">$(V_WCCMNT)</td>
                  </tr>
              %}
          </table>
      </fieldset>
      $(inquiryhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HWFWIC_W.PGM %}
%}

%FUNCTION(DTW_directcall) Get_WF_Comments(INOUT CHAR(64)    profileHandle,
                                          INOUT CHAR(2)     dataBaseID,
                                          INOUT CHAR(32000) edtVar,                             	
                                          INOUT CHAR(4)     V_WCREAS,                             	
                                          INOUT CHAR(30000) V_WCCMNT)

{%EXEC {HWFWIC_P.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("WIINST=$(wfInstance) and WIINDT=$(wfInstanceDate) and WIWITM=$(wfWorkItem) and WIWISQ=$(wfWorkItemSequence)", "WFWITM", "Char(Count(*))", RecCount)
  %if (RecCount >"0")
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      @Set_SQL(stmtSQL)
  %elseif (refreshD2W!="N")
      <script TYPE="text/javascript">
          opener.location.href=opener.location.href;
          opener.focus();
          window.close();
      </script>
  %else
      @BrowserType(browserCode)
      %if (browserCode == "IE")
          <script TYPE="text/javascript">
              opener.location.href='$(homeURL)$(cGIPath)WFWorkList.d2w/REPORT$(d2wVarBase)';
              window.close();
          </script>
      %else
          <meta http-equiv="refresh" content="0; URL=javascript:opener.document.location='$(homeURL)$(cGIPath)WFWorkList.d2w/REPORT$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))';self.close();">
      %endif
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(wfReason)
  @dtw_replace(comments, "'", "", "1", "a", comments)

  @dtw_assign(edtVar, "")
  @Concat_Field("@@inst", wfInstance)
  @Concat_Field("@@indt", wfInstanceDate)
  @Concat_Field("@@witm", wfWorkItem)
  @Concat_Field("@@wisq", wfWorkItemSequence)
  @Concat_Field("@@ptid", wfParticipantId)
  @Concat_Field("@@reas", wfReason)
  @Concat_Field("@@cmnt", comments)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, errFound, edtVar, errVar)

  %if (errFound == "")
      %if (cmtSelection != "A")
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)">
      %else
          <script TYPE="text/javascript">
              window.close()
          </script>
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
