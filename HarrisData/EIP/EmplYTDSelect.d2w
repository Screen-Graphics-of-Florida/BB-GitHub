%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "QuickLink.icl"

%Define {
  page_title 	        = "Employee Year To Date Totals"
  d2wName              = "EmplYTDSelect.d2w"
  attachFolder         = "EmployeeYTD"
  d2wVarBase           = "$(genericVarBase)$(employeeVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName          = "HPRCHI"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  RPT_MAX_ROWS         = "99"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext	        = "1"
  CHI_06               = ""
  CHI_07               = ""
  payTypeCode          = ""
  quickLinkByUser      = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @dtw_assign(applicationID, "PR")
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "EMPLOYEEYTD  ")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif

                      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                      @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMTYPE", payTypeCode)
                      @dtw_assign(CHI_06, sec_06)
                      @dtw_assign(CHI_07, sec_07)
                      <td class="content">

%{ QuickLink Table %}     %INCLUDE "QuickLinkTable.icl"

%{ QuickLink By User %}   %INCLUDE "QuickLinkByUser.icl"

%{ Year To Date Header%}
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                          @dtw_concat(fileSQL, " PREMPL ", fileSQL)
                          @dtw_concat(selectSQL, " ERCOMP=$(prCompany) and ERFACL=$(prFacility) and EREMPL=$(prEmployee)", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                          @Employee_YTD_Header(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Begin %}     %INCLUDE "QuickLinkBegLoop.icl"

   %{ ytdearningssummary %}
                              %if (quicklinkRef == "ytdearningssummary")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                                  @dtw_concat(fileSQL, " PREMPL ", fileSQL)
                                  @dtw_concat(selectSQL, " ERCOMP=$(prCompany) and ERFACL=$(prFacility) and EREMPL=$(prEmployee)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Employee_YTD_EarningsSummary(profileHandle, dataBaseID, stmtSQL)
   %{ ytdemployeetax %}
                              %elif ((quicklinkRef == "ytdemployeetax") && ((payTypeCode == "H" && CHI_06 == "Y") || (payTypeCode != "H" && CHI_07 == "Y")))
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                                  @dtw_concat(fileSQL, " PREMPL ", fileSQL)
                                  @dtw_concat(selectSQL, " ERCOMP=$(prCompany) and ERFACL=$(prFacility) and EREMPL=$(prEmployee)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Employee_YTD_EmployeeTax(profileHandle, dataBaseID, stmtSQL)
   %{ ytdemployertax %}
                              %elif ((quicklinkRef == "ytdemployertax") && ((payTypeCode == "H" && CHI_06 == "Y") || (payTypeCode != "H" && CHI_07 == "Y")))
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                                  @dtw_concat(fileSQL, " PREMPL ", fileSQL)
                                  @dtw_concat(selectSQL, " ERCOMP=$(prCompany) and ERFACL=$(prFacility) and EREMPL=$(prEmployee)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Employee_YTD_EmployerTax(profileHandle, dataBaseID, stmtSQL)
    %{ ytdpaydetail %}
                              %elif (quicklinkRef == "ytdpaydetail")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " PRYTPC inner join PRCODE on YPCOMP=C2COMP and YPFACL=C2FACL and YPCODE=C2CODE ", fileSQL)
                                  @dtw_concat(selectSQL, " YPCOMP=$(prCompany) and YPFACL=$(prFacility) and YPEMPL=$(prEmployee)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_concat(stmtSQL, " ORDER BY C2SEQ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Employee_YTD_PayDetail(profileHandle, dataBaseID, stmtSQL)

    %{ ytddeductions %}
                              %elif (quicklinkRef == "ytddeductions")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HREDED inner join HRDEDM on EDDDNO=HVDDNO  ", fileSQL)
                                  @dtw_concat(selectSQL, " EDCOMP=$(prCompany) and EDFACL=$(prFacility) and EDEMPL=$(prEmployee)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_concat(stmtSQL, " Order By EDDDNO", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Employee_YTD_Deductions(profileHandle, dataBaseID, stmtSQL)

    %{ ytd401k %}
                              %elif ((quicklinkRef == "ytd401k") && ((payTypeCode == "H" && CHI_06 == "Y") || (payTypeCode != "H" && CHI_07 == "Y")))
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                                  @dtw_concat(fileSQL, " PR401Y ", fileSQL)
                                  @dtw_concat(selectSQL, " KDCOMP=$(prCompany) and KDFACL=$(prFacility) and KDEMPL=$(prEmployee)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Employee_YTD_401k(profileHandle, dataBaseID, stmtSQL)
                              %endif

     %{ Attachments %}        %INCLUDE "AttachmentSQL.icl"

%{ Quicklink End %}       %INCLUDE "QuickLinkEndLoop.icl"

                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Employee_YTD_Header (IN CHAR(64)    profileHandle,
				            CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if ((payTypeCode == "H" && CHI_06 == "N") || (payTypeCode != "H" && CHI_07 == "N"))
          @Remove_Quick_Link("YTDEMPLOYEETAX")
          @Remove_Quick_Link("YTDEMPLOYERTAX")
          @Remove_Quick_Link("YTD401K")
      %endif

      %ROW {
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
                  @dtw_assign(attVar, "YTD")
                  %INCLUDE "emplAttachment.icl"
                  @dtw_assign(attachForDesc, "$(F_EmpName)")
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="BackHome">$(portalHome)</a>
                          %endif
                          %INCLUDE "Attachment.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>

              <tr><td><h2>$(F_EmpName)</h2></td></tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"

          %if ((payTypeCode == "H" && CHI_06 == "Y") || (payTypeCode != "H" && CHI_07 == "Y"))
              $(hrTagAttr)
              <table $(contentTable)>
                  @Format_Nbr($(V_ERYGRS), F_ERYGRS, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Gross Pay</td>
                      <td class="dspalph">$(F_ERYGRS)</td>
                  </tr>

                  @Format_Nbr($(V_ERYNET), F_ERYNET, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Net Pay</td>
                      <td class="dspalph">$(F_ERYNET)</td>
                  </tr>
              </table>
          %endif
          $(hrTagAttr)
          %INCLUDE "QuickLinkDisplay.icl"
      %}
  %}
%}

%FUNCTION(dtw_sql) Employee_YTD_EarningsSummary (IN  CHAR(64)    profileHandle,
				                      CHAR(2)     dataBaseID,
                                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="ytdearningssummary"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          <tr><td class="colhdr">Description</td>
              <td class="colhdr">Hours/Units</td>
              %if ((payTypeCode == "H" && sec_06 == "Y") || (payTypeCode != "H" && sec_07 == "Y"))
                  <td class="colhdr">Earnings</td>
              %endif
          </tr>

          %ROW{
              @dtw_assign(totalHoursUnits, "0")
              @dtw_assign(totalEarnings, "0")
              @dtw_assign(holdHours, "0")

              %if (V_ERYRGH != ".00" || V_ERYRGE != ".00")
                  <tr><td class="dsphdr">Regular</td>
    	   	       @dtw_add($(V_ERYRGH), totalHoursUnits, totalHoursUnits)
    	               @dtw_add($(V_ERYRGE), totalEarnings, totalEarnings)
                      @Format_Nbr($(V_ERYRGH), F_ERYRGH, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_ERYRGH)</td>
                      %if ((payTypeCode == "H" && sec_06 == "Y") || (payTypeCode != "H" && sec_07 == "Y"))
                          @Format_Nbr($(V_ERYRGE), F_ERYRGE, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ERYRGE)</td>
                      %endif
                  </tr>
              %endif

              %if (V_ERYOTH != ".00" || V_ERYOTE != ".00")
                  <tr><td class="dsphdr">Overtime</td>
    	   	       @dtw_add($(V_ERYOTH), totalHoursUnits, totalHoursUnits)
    	               @dtw_add($(V_ERYOTE), totalEarnings, totalEarnings)
                      @Format_Nbr($(V_ERYOTH), F_ERYOTH, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_ERYOTH)</td>
                      %if ((payTypeCode == "H" && sec_06 == "Y") || (payTypeCode != "H" && sec_07 == "Y"))
                          @Format_Nbr($(V_ERYOTE), F_ERYOTE, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ERYOTE)</td>
                      %endif
                  </tr>
              %endif

              %if (V_ERYDBH != ".00" || V_EYYDBE != ".00")
                  <tr><td class="dsphdr">Double Time</td>
    	   	       @dtw_add($(V_ERYDBH), totalHoursUnits, totalHoursUnits)
    	               @dtw_add($(V_EYYDBE), totalEarnings, totalEarnings)
                      @Format_Nbr($(V_ERYDBH), F_ERYDBH, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_ERYDBH)</td>
                      %if ((payTypeCode == "H" && sec_06 == "Y") || (payTypeCode != "H" && sec_07 == "Y"))
                          @Format_Nbr($(V_EYYDBE), F_EYYDBE, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_EYYDBE)</td>
                      %endif
                  </tr>
              %endif

              %if (V_ERYVCH != ".00" || V_ERYVCE != ".00")
                  <tr><td class="dsphdr">Vacation</td>
    	   	       @dtw_add($(V_ERYVCH), totalHoursUnits, totalHoursUnits)
    	               @dtw_add($(V_ERYVCE), totalEarnings, totalEarnings)
                      @Format_Nbr($(V_ERYVCH), F_ERYVCH, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_ERYVCH)</td>
                      %if ((payTypeCode == "H" && sec_06 == "Y") || (payTypeCode != "H" && sec_07 == "Y"))
                          @Format_Nbr($(V_ERYVCE), F_ERYVCE, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ERYVCE)</td>
                      %endif
                  </tr>
              %endif

              %if (V_ERYHLH != ".00" || V_ERYHLE != ".00")
                  <tr><td class="dsphdr">Holiday</td>
    	   	       @dtw_add($(V_ERYHLH), totalHoursUnits, totalHoursUnits)
    	               @dtw_add($(V_ERYHLE), totalEarnings, totalEarnings)
                      @Format_Nbr($(V_ERYHLH), F_ERYHLH, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_ERYHLH)</td>
                      %if ((payTypeCode == "H" && sec_06 == "Y") || (payTypeCode != "H" && sec_07 == "Y"))
                          @Format_Nbr($(V_ERYHLE), F_ERYHLE, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ERYHLE)</td>
                      %endif
                  </tr>
              %endif

              %if (V_ERYSCH != ".00" || V_ERYSCE != ".00")
                  <tr><td class="dsphdr">Sick</td>
    	   	       @dtw_add($(V_ERYSCH), totalHoursUnits, totalHoursUnits)
    	               @dtw_add($(V_ERYSCE), totalEarnings, totalEarnings)
                      @Format_Nbr($(V_ERYSCH), F_ERYSCH, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_ERYSCH)</td>
                      %if ((payTypeCode == "H" && sec_06 == "Y") || (payTypeCode != "H" && sec_07 == "Y"))
                          @Format_Nbr($(V_ERYSCE), F_ERYSCE, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ERYSCE)</td>
                      %endif
                  </tr>
              %endif

              %if (V_ERYTHH != ".00" || V_ERYTHE != ".00")
                  <tr><td class="dsphdr">Other Taxable</td>
    	   	       @dtw_add($(V_ERYTHH), totalHoursUnits, totalHoursUnits)
    	               @dtw_add($(V_ERYTHE), totalEarnings, totalEarnings)
                      @Format_Nbr($(V_ERYTHH), F_ERYTHH, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_ERYTHH)</td>
                      %if ((payTypeCode == "H" && sec_06 == "Y") || (payTypeCode != "H" && sec_07 == "Y"))
                          @Format_Nbr($(V_ERYTHE), F_ERYTHE, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ERYTHE)</td>
                      %endif
                  </tr>
              %endif

              %if ((payTypeCode == "H" && sec_06 == "Y") || (payTypeCode != "H" && sec_07 == "Y"))
                  %if (V_ERYNTE != ".00")
                      <tr><td class="dsphdr">Nontaxable</td>
        	           @dtw_add($(V_ERYNTE), totalEarnings, totalEarnings)
                          <td class="colnmbr">&nbsp;</td>
                          @Format_Nbr($(V_ERYNTE), F_ERYNTE, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ERYNTE)</td>
                      </tr>
                  %endif

                  %if (V_ERYCME != ".00")
                      <tr><td class="dsphdr">Commission</td>
        	           @dtw_add($(V_ERYCME), totalEarnings, totalEarnings)
                          <td class="colnmbr">&nbsp;</td>
                          @Format_Nbr($(V_ERYCME), F_ERYCME, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ERYCME)</td>
                      </tr>
                  %endif

                  %if (V_ERYBNE != ".00")
                      <tr><td class="dsphdr">Bonus</td>
        	           @dtw_add($(V_ERYBNE), totalEarnings, totalEarnings)
                          <td class="colnmbr">&nbsp;</td>
                          @Format_Nbr($(V_ERYBNE), F_ERYBNE, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ERYBNE)</td>
                      </tr>
                  %endif

                  %if (V_ERYFRN != ".00")
                      <tr><td class="dsphdr">Fringe Benefits</td>
        	           @dtw_add($(V_ERYFRN), totalEarnings, totalEarnings)
                          <td class="colnmbr">&nbsp;</td>
                          @Format_Nbr($(V_ERYFRN), F_ERYFRN, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ERYFRN)</td>
                      </tr>
                  %endif

                  %if (V_ERYCST != ".00")
                      <tr><td class="dsphdr">Cash Tips</td>
        	           @dtw_add($(V_ERYCST), totalEarnings, totalEarnings)
                          <td class="colnmbr">&nbsp;</td>
                          @Format_Nbr($(V_ERYCST), F_ERYCST, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ERYCST)</td>
                      </tr>
                  %endif

                  %if (V_ERYCHT != ".00")
                      <tr><td class="dsphdr">Charge Tips</td>
        	           @dtw_add($(V_ERYCHT), totalEarnings, totalEarnings)
                          <td class="colnmbr">&nbsp;</td>
                          @Format_Nbr($(V_ERYCHT), F_ERYCHT, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ERYCHT)</td>
                      </tr>
                  %endif

                  %if (V_ERYMLA != ".00")
                      <tr><td class="dsphdr">Meal Allowance</td>
        	           @dtw_add($(V_ERYMLA), totalEarnings, totalEarnings)
                          <td class="colnmbr">&nbsp;</td>
                          @Format_Nbr($(V_ERYMLA), F_ERYMLA, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ERYMLA)</td>
                      </tr>
                  %endif
              %endif

              <tr><td class="colnmbr">Total Hours/Units</td>
                  @Format_Nbr($(totalHoursUnits), F_totalHoursUnits, "2", $(hrsEditCode), "", "", "")
                  <td class="colnmbr">$(F_totalHoursUnits)</td>
              </tr>

              %if ((payTypeCode == "H" && sec_06 == "Y") || (payTypeCode != "H" && sec_07 == "Y"))
                  <tr><td class="colnmbr">Total Earnings</td>
                      <td class="colnmbr">&nbsp;</td>
                      @Format_Nbr($(totalEarnings), F_totalEarnings, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_totalEarnings)</td>
                  </tr>
                  %if (V_ERYGRC != ".00")
                      <tr><td class="dsphdr">Gross Reciepts</td>
                          @Format_Nbr($(V_ERYGRC), F_ERYGRC, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ERYGRC)</td>
                      </tr>
                  %endif
                  %if (V_ERYTAT != ".00")
                      <tr><td class="dsphdr">Allocated Tips</td>
                          @Format_Nbr($(V_ERYTAT), F_ERYTAT, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ERYTAT)</td>
                      </tr>
                  %endif
              %endif
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Employee_YTD_EmployeeTax (IN  CHAR(64)    profileHandle,
				                  CHAR(2)     dataBaseID,
                                                 CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="ytdemployeetax"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          @dtw_assign(employeeTax, "0")
          @dtw_assign(employerTax, "0")
          <tr><th class="colhdr"> Tax Type</th>
              <th class="colhdr"> Employee Tax</th>
          </tr>

          %ROW{

              @dtw_add($(V_ERYFIT), employeeTax, employeeTax)
              @Format_Nbr($(V_ERYFIT), F_ERYFIT, "2", $(amtEditCode), "", "", "")
              <tr class="$(rowClass)">
                  <td class="dsphdr">Federal Tax</td>
                  <td class="colnmbr">$(F_ERYFIT)</td>
              </tr>

              @dtw_add($(V_ERYEHI), employeeTax, employeeTax)
              @Format_Nbr($(V_ERYEHI), F_ERYEHI, "2", $(amtEditCode), "", "", "")
              <tr class="$(rowClass)">
                  <td class="dsphdr"> FICA HI Tax</td>
                  <td class="colnmbr"> $(F_ERYEHI)</td>
              </tr>

              @dtw_add($(V_ERYEOA), employeeTax, employeeTax)
              @Format_Nbr($(V_ERYEOA), F_ERYEOA, "2", $(amtEditCode), "", "", "")
              <tr class="$(rowClass)">
                  <td class="dsphdr"> FICA OASDI Tax</td>
                  <td class="colnmbr"> $(F_ERYEOA)</td>
              </tr>
              @dtw_assign(totalEmployeeFica, "0")
              @dtw_add(V_ERYEHI, V_ERYEOA, totalEmployeeFica)

              @Format_Nbr($(totalEmployeeFica), F_totalEmployeeFica, "2", $(amtEditCode), "", "", "")
              <tr class="$(rowClass)">
                  <td class="colalph">Total FICA Tax</td>
                  <td class="colnmbr"> $(F_totalEmployeeFica)</td>
              </tr>

              %if ($(V_ERYEIC) != ".00")
              @dtw_add($(V_ERYEIC), employeeTax, employeeTax)
                  @Format_Nbr($(V_ERYEIC), F_ERYEIC, "2", $(amtEditCode), "", "", "")
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> EIC</td>
                      <td class="colnmbr"> $(F_ERYEIC)</td>
                  </tr>
              %endif

              %if ($(V_ERYSIT) != ".00")
              @dtw_add($(V_ERYSIT), employeeTax, employeeTax)
                  @Format_Nbr($(V_ERYSIT), F_ERYSIT, "2", $(amtEditCode), "", "", "")
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> State Tax</td>
                      <td class="colnmbr"> $(F_ERYSIT)</td>
                  </tr>

              %endif

              %if ($(V_ERYSUI) != ".00")
                  @dtw_add($(V_ERYSUI), employeeTax, employeeTax)
                  @Format_Nbr($(V_ERYSUI), F_ERYSUI, "2", $(amtEditCode), "", "", "")
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> Employee SUI Tax</td>
                      <td class="colnmbr"> $(F_ERYSUI)</td>
                  </tr>
              %endif

              %if ($(V_ERYSDI) != ".00")
                  @dtw_add($(V_ERYSDI), employeeTax, employeeTax)
                  @Format_Nbr($(V_ERYSDI), F_ERYSDI, "2", $(amtEditCode), "", "", "")
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> Employee SDI Tax</td>
                      <td class="colnmbr"> $(F_ERYSDI)</td>
                  </tr>
              %endif

              %if ($(V_ERYSWC) != ".00")
                  @dtw_add($(V_ERYSWC), employeeTax, employeeTax)
                  @Format_Nbr($(V_ERYSWC), F_ERYSWC, "2", $(amtEditCode), "", "", "")
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> SWC Tax</td>
                      <td class="colnmbr"> $(F_ERYSWC)</td>
                  </tr>
              %endif

              %if ($(V_ERYLIT) != ".00")
                  @dtw_add($(V_ERYLIT), employeeTax, employeeTax)
                  @Format_Nbr($(V_ERYLIT), F_ERYLIT, "2", $(amtEditCode), "", "", "")
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> Local Tax</td>
                      <td class="colnmbr"> $(V_ERYLIT)</td>
                  </tr>
              %endif

              @Format_Nbr($(employeeTax), F_employeeTax, "2", $(amtEditCode), "", "", "")
              <tr class="$(rowClass)">
                  <td class="colalph"> Total Tax</td>
                  <td class="colnmbr"> $(F_employeeTax)</td>
              </tr>
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Employee_YTD_EmployerTax (IN  CHAR(64)    profileHandle,
				                  CHAR(2)     dataBaseID,
                                                 CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="ytdemployertax"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          @dtw_assign(employeeTax, "0")
          @dtw_assign(employerTax, "0")
          <tr><th class="colhdr">Tax Type</th>
              <th class="colhdr">Employee Tax</th>
              <th class="colhdr">Employer Tax</th>
              <th class="colhdr">Taxable Wages</th>
              <th class="colhdr">Exempt Wages</th>	
              <th class="colhdr">Deferred Wages</th>
          </tr>	

          %ROW{

              @dtw_add($(V_ERYFIT), employeeTax, employeeTax)
              @Format_Nbr($(V_ERYFIT), F_ERYFIT, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_ERYFTW), F_ERYFTW, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_ERYFTX), F_ERYFTX, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_ERYFTD), F_ERYFTD, "2", $(amtEditCode), "", "", "")
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Federal Tax</td>
                  <td class="colnmbr">$(F_ERYFIT)</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr">$(F_ERYFTW)</td>
                  <td class="colnmbr">$(F_ERYFTX)</td>
                  <td class="colnmbr">$(F_ERYFTD)</td>
              </tr>

              @dtw_add($(V_ERYEHI), employeeTax, employeeTax)
              @dtw_add($(V_ERYRHI), employerTax, employerTax)
              @Format_Nbr($(V_ERYEHI), F_ERYEHI, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_ERYRHI), F_ERYRHI, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_ERYHIW), F_ERYHIW, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_ERYEFX), F_ERYEFX, "2", $(amtEditCode), "", "", "")
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">FICA HI Tax</td>
                  <td class="colnmbr">$(F_ERYEHI)</td>
                  <td class="colnmbr">$(F_ERYRHI)</td>
                  <td class="colnmbr">$(F_ERYHIW)</td>
                  <td class="colnmbr">$(F_ERYEFX)</td>
                  <td class="colnmbr">&nbsp;</td>
              </tr>


              @dtw_add($(V_ERYEOA), employeeTax, employeeTax)
              @dtw_add($(V_ERYROA), employerTax, employerTax)
              @Format_Nbr($(V_ERYEOA), F_ERYEOA, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_ERYROA), F_ERYROA, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_ERYFCW), F_ERYFCW, "2", $(amtEditCode), "", "", "")
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">FICA OASDI Tax</td>
                  <td class="colnmbr">$(F_ERYEOA)</td>
                  <td class="colnmbr">$(F_ERYROA)</td>
                  <td class="colnmbr">$(F_ERYFCW)</td>
                  <td class="colnmbr">$(F_ERYEFX)</td>
                  <td class="colnmbr">&nbsp;</td>
              </tr>

              @dtw_assign(totalEmployeeFica, "0")
              @dtw_add(V_ERYEHI, V_ERYEOA, totalEmployeeFica)
              @dtw_assign(totalEmployerFica, "0")
              @dtw_add(V_ERYRHI, V_ERYROA, totalEmployerFica)

              @Format_Nbr($(totalEmployeeFica), F_totalEmployeeFica, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(totalEmployerFica), F_totalEmployerFica, "2", $(amtEditCode), "", "", "")
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">Total FICA Tax</td>
                  <td class="colnmbr">$(F_totalEmployeeFica)</td>
                  <td class="colnmbr">$(F_totalEmployerFica)</td>
              </tr>

              @dtw_add($(V_ERYRFU), employerTax, employerTax)
              @Format_Nbr($(V_ERYRFU), F_ERYRFU, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_ERYFUW), F_ERYFUW, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_ERYFUX), F_ERYFUX, "2", $(amtEditCode), "", "", "")
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">FUI Tax</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr">$(F_ERYRFU)</td>
                  <td class="colnmbr">$(F_ERYFUW)</td>
                  <td class="colnmbr">$(F_ERYFUX)</td>
                  <td class="colnmbr">&nbsp;</td>
              </tr>

              %if ($(V_ERYEIC) != ".00")
              @dtw_add($(V_ERYEIC), employeeTax, employeeTax)
                  @Format_Nbr($(V_ERYEIC), F_ERYEIC, "2", $(amtEditCode), "", "", "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr">EIC</td>
                      <td class="colnmbr">$(F_ERYEIC)</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                  </tr>
              %endif

              %if ($(V_ERYSIT) != ".00")
              @dtw_add($(V_ERYSIT), employeeTax, employeeTax)
                  @Format_Nbr($(V_ERYSIT), F_ERYSIT, "2", $(amtEditCode), "", "", "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr">State Tax</td>
                      <td class="colnmbr">$(F_ERYSIT)</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                  </tr>

              %endif

              %if ($(V_ERYSUI) != ".00")
                  @dtw_add($(V_ERYSUI), employeeTax, employeeTax)
                  @Format_Nbr($(V_ERYSUI), F_ERYSUI, "2", $(amtEditCode), "", "", "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr">Employee SUI Tax</td>
                      <td class="colnmbr">$(F_ERYSUI)</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                  </tr>
              %endif

              %if ($(V_ERYSDI) != ".00")
                  @dtw_add($(V_ERYSDI), employeeTax, employeeTax)
                  @Format_Nbr($(V_ERYSDI), F_ERYSDI, "2", $(amtEditCode), "", "", "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr">Employee SDI Tax</td>
                      <td class="colnmbr">$(F_ERYSDI)</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                  </tr>
              %endif

              %if ($(V_ERYSWC) != ".00")
                  @dtw_add($(V_ERYSWC), employeeTax, employeeTax)
                  @Format_Nbr($(V_ERYSWC), F_ERYSWC, "2", $(amtEditCode), "", "", "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr">Employee SWC Tax</td>
                      <td class="colnmbr">$(F_ERYSWC)</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                  </tr>
              %endif

              %if ($(V_ERYLIT) != ".00")
                  @dtw_add($(V_ERYLIT), employeeTax, employeeTax)
                  @Format_Nbr($(V_ERYLIT), F_ERYLIT, "2", $(amtEditCode), "", "", "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr">Local Tax</td>
                      <td class="colnmbr">$(V_ERYLIT)</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                  </tr>
              %endif

              @Format_Nbr($(employeeTax), F_employeeTax, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(employerTax), F_employerTax, "2", $(amtEditCode), "", "", "")
              <tr><td class="colalph">Total Tax</td>
                  <td class="colnmbr">$(F_employeeTax)</td>
                  <td class="colnmbr">$(F_employerTax)</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr">&nbsp;</td>
              </tr>
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Employee_YTD_PayDetail (IN  CHAR(64)    profileHandle,
				                  CHAR(2)     dataBaseID,
                                                 CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="ytdpaydetail"></a>
      @dtw_assign(displayMaxRowsMsg, "Y")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  <th class="colhdr">Pay<br>Code</th>
        	   <th class="colhdr">Description</th>
        	   <th class="colhdr">Hours</th>
        	   <th class="colhdr">Units</th>
                  %if ((payTypeCode == "H" && CHI_06 == "Y") || (payTypeCode != "H" && CHI_07 == "Y"))
                      <th class="colhdr">Earnings</th>
                  %endif
     	       </tr>
              @dtw_assign(workedHours, "0")
              @dtw_assign(notWorked, "0")
              @dtw_assign(totalUnits, "0")
              @dtw_assign(totalEarnings, "0")
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @RtvFldDesc("C2COMP=$(prCompany) and C2FACL=$(prFacility) and C2CODE='$(V_YPCODE)'", "PRCODE", "C2DESC", payCodeDesc)
              <tr class="$(rowClass)">
	       	   <td class="colcode">$(V_YPCODE)</td>
	           <td class="colalph">$(payCodeDesc)</td>
	       	   %if (V_C2HRCD == "H")
                      @Format_Nbr($(V_YPHRS), F_YPHRS, "2", $(hrsEditCode), "", "", "")
    	       	       <td class="colnmbr">$(F_YPHRS)</td>
                      <td class="colnmbr">&nbsp;</td>
    	       	       %if (V_C2RPHR == "Y")
    	                   @dtw_add(V_YPHRS, workedHours, workedHours)
    	       	       %else
    	                   @dtw_add(V_YPHRS, notWorked, notWorked)
    	       	       %endif
	       	   %elif (V_C2HRCD == "U")
                      @Format_Nbr($(V_YPHRS), F_YPHRS, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">$(F_YPHRS)</td>
	       		   @dtw_add(V_YPHRS, totalUnits, totalUnits)
	       	   %else
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
	       	   %endif
                  @RtvFldDesc("C2COMP=$(prCompany) and C2FACL=$(prFacility) and C2CODE='$(V_YPCODE)'", "PRCODE", "C2SMTY", summarytype)
                  %if (summarytype != "G")
	       	       @dtw_add(V_YPEARN, totalEarnings, totalEarnings)
                  %endif
                  %if ((payTypeCode == "H" && sec_06 == "Y") || (payTypeCode != "H" && sec_07 == "Y"))
                  @Format_Nbr($(V_YPEARN), F_YPEARN, "2", $(amtEditCode), "", "", "")
	       	           <td class="colnmbr">$(F_YPEARN)</td>
                  %endif
	       </tr>	
          %}

          %if (sql_Record_Count != "0")
              @Format_Nbr($(workedHours), F_workedHours, "2", $(hrsEditCode), "", "", "")
              @Format_Nbr($(totalEarnings), F_totalEarnings, "2", $(amtEditCode), "", "", "")
              <tr><td>&nbsp;</td>
    	       <td class="colalph">Total Worked</td>
                  <td class="colnmbr"> $(F_workedHours)</td>
    	       %if (totalUnits == "0")
    	           @dtw_assign(totalUnits, "")
                      <td class="colnmbr">$(totalUnits)</td>
                  %else
                      @Format_Nbr($(totalUnits), F_totalUnits, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_totalUnits)</td>
    	       %endif
              </tr>
              %if (notWorked != "0")
                  @Format_Nbr($(notWorked), F_notWorked, "2", $(hrsEditCode), "", "", "")
                  <tr><td>&nbsp;</td>
                      <td class="colalph">Not Worked</td>
                      <td class="colnmbr">$(F_notWorked)</td>
                      <td class="colnmbr">&nbsp;</td>
                      %if ((payTypeCode == "H" && sec_06 == "Y") || (payTypeCode != "H" && sec_07 == "Y"))
                          <td class="colnmbr">&nbsp;</td>
                      %endif
                  </tr>
              %endif
              %if ((payTypeCode == "H" && sec_06 == "Y") || (payTypeCode != "H" && sec_07 == "Y"))
                  <tr><td class="colnmbr">&nbsp;</td>
                      <td class="colalph"> Total Earnings</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">$(F_totalEarnings)</td>
                  </tr>
              %endif
          %endif
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Employee_YTD_Deductions (IN  CHAR(64)    profileHandle,
				                 CHAR(2)     dataBaseID,
                                                CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="ytddeductions"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @dtw_assign(totalDeductions, "0")
                  <th class="colhdr">Deduction<br>Number</th>
    	           <th class="colhdr">Deduction<br>Name</th>
    	           <th class="colhdr">Calculation<br>Method</th>
    	           <th class="colhdr">Priority</th>    	
    	           <th class="colhdr">Cycle</th>    	
                  <th class="colhdr">Deduction<br>Amt/Pct</th>
                  %if ((payTypeCode == "H" && sec_06 == "Y") || (payTypeCode != "H" && sec_07 == "Y"))
                      <th class="colhdr">Year To Date</th>
    	           <th class="colhdr">Inception To Date</th>
                  %endif
    	           <th class="colhdr">Limit</th>
    	           <th class="colhdr">Effective<br>Date</th>
                  <th class="colhdr">Expiration<br>Date</th>
    	           <th class="colhdr">Accumulated<br>Amount Due</th>
              </tr>
          %endif

          %ROW{
              @Format_Date(V_EDEFDT, "D", F_EDEFDT)
              @Format_Date(V_EDEXDT, "D", F_EDEXDT)

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  @dtw_add($(V_EDYTD), totalDeductions, totalDeductions)
    	           <td class="colcode">$(V_EDDDNO)</td>
    	           <td class="colalph">$(V_HVDDNM)</td>
    	           <td class="colcode">$(V_EDMTHD)</td>
    	           <td class="colalph">$(V_HVPRTY)</td>    	
    	           <td class="colalph">$(V_HVCYCL)</td>    	               	
                  %if (V_EDAMT > ".00")
                      @Format_Nbr($(V_EDAMT), F_EDAMT, "2", $(amtEditCode), "", "$", "")
    	               <td class="colnmbr">$(F_EDAMT)</td>
                  %else
                      @Format_Nbr("@dtw_rmultiply(V_EDPCT, "100")", F_EDPCT, "3", $(pctEditCode), "", "", "%")
    	               <td class="colnmbr">$(F_EDPCT)</td>
                  %endif
                  %if ((payTypeCode == "H" && sec_06 == "Y") || (payTypeCode != "H" && sec_07 == "Y"))
                      @Format_Nbr($(V_EDYTD), F_EDYTD, "2", $(amtEditCode), "", "", "")
    	               <td class="colnmbr">$(F_EDYTD)</td>
                      @Format_Nbr($(V_EDITD), F_EDITD, "2", $(amtEditCode), "", "", "")
    	               <td class="colnmbr">$(F_EDITD)</td>
                  %endif
                  @Format_Nbr($(V_EDLIMT), F_EDLIMT, "2", $(amtEditCode), "", "", "")
    	           <td class="colnmbr">$(F_EDLIMT)</td>
    	           <td class="coldate">$(F_EDEFDT)</td>
    	           <td class="coldate">$(F_EDEXDT)</td>
                  @Format_Nbr($(V_EDACUM), F_EDACUM, "2", $(amtEditCode), "", "", "")
    	           <td class="colnmbr">$(F_EDACUM)</td>
    	       </tr>
          %}	
          %if ((payTypeCode == "H" && sec_06 == "Y") || (payTypeCode != "H" && sec_07 == "Y"))
              %if (sql_Record_Count != "0")
                  <tr>
                      <td class="colalph"> Total Deductions</td>
                      <td>&nbsp;</td>
                      <td>&nbsp;</td>
                      <td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td>
                      @Format_Nbr($(totalDeductions), F_totalDeductions, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_totalDeductions)</td>
                  </tr>
              %endif
          %endif
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Employee_YTD_401k (IN  CHAR(64)    profileHandle,
				           CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

