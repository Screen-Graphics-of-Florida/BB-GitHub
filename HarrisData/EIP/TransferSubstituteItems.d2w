%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "IMITEM,IWWHS")
      @DTW_ASSIGN(orderByDisplay, "Item Number, Warehouse")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Item")
      %if (orderBy == "IMITEM,IWWHS")
          @DTW_ASSIGN(orderBy, "IMITEM DESC,IWWHS")
          @DTW_ASSIGN(orderByDisplay, "Item Number (descending), Warehouse")
      %else
          @DTW_ASSIGN(orderBy, "IMITEM,IWWHS")
          @DTW_ASSIGN(orderByDisplay, "Item Number, Warehouse")
      %endif
  %elif (sequence == "Whs")
      %if (orderBy == "IWWHS,IMITEM")
          @DTW_ASSIGN(orderBy, "IWWHS DESC,IMITEM")
          @DTW_ASSIGN(orderByDisplay, "Warehouse (descending), Item Number")
      %else
          @DTW_ASSIGN(orderBy, "IWWHS,IMITEM")
          @DTW_ASSIGN(orderByDisplay, "Warehouse, Item Number")
      %endif
  %elif (sequence == "Desc")
      %if (orderBy == "IMIMDSU,IMITEM,IWWHS")
          @DTW_ASSIGN(orderBy, "IMIMDSU DESC,IMITEM,IWWHS")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Item Number, Warehouse")
      %else
          @DTW_ASSIGN(orderBy, "IMIMDSU,IMITEM,IWWHS")
          @DTW_ASSIGN(orderByDisplay, "Description, Item Number, Warehouse")
      %endif
  %elif (sequence == "Cat")
      %if (orderBy == "IXCTG$(V_CITRUD),IMITEM")
          @DTW_ASSIGN(orderBy, "IXCTG$(V_CITRUD) DESC,IMITEM")
          @DTW_ASSIGN(orderByDisplay, "$(itemExtCat$(V_CITRUD)) (descending), Item Number")
      %else
          @DTW_ASSIGN(orderBy, "IXCTG$(V_CITRUD),IMITEM")
          @DTW_ASSIGN(orderByDisplay, "$(itemExtCat$(V_CITRUD)), Item Number")
      %endif
  %elif (sequence == "OnHand")
      %if (orderBy == "IWOHQT,IMITEM,IWWHS")
          @DTW_ASSIGN(orderBy, "IWOHQT DESC,IMITEM,IWWHS")
          @DTW_ASSIGN(orderByDisplay, "Quantity On Hand (descending), Item Number, Warehouse")
      %else
          @DTW_ASSIGN(orderBy, "IWOHQT,IMITEM,IWWHS")
          @DTW_ASSIGN(orderByDisplay, "Quantity On Hand, Item Number, Warehouse")
      %endif
  %elif (sequence == "Resv")
      %if (orderBy == "IWRESQ,IMITEM,IWWHS")
          @DTW_ASSIGN(orderBy, "IWRESQ DESC,IMITEM,IWWHS")
          @DTW_ASSIGN(orderByDisplay, "Quantity Reserved (descending), Item Number, Warehouse")
      %else
          @DTW_ASSIGN(orderBy, "IWRESQ,IMITEM,IWWHS")
          @DTW_ASSIGN(orderByDisplay, "Quantity Reserved, Item Number, Warehouse")
      %endif
  %elif (sequence == "OnOrder")
      %if (orderBy == "IWQOO,IMITEM,IWWHS")
          @DTW_ASSIGN(orderBy, "IWQOO DESC,IMITEM,IWWHS")
          @DTW_ASSIGN(orderByDisplay, "Quantity On Order (descending), Item Number, Warehouse")
      %else
          @DTW_ASSIGN(orderBy, "IWQOO,IMITEM,IWWHS")
          @DTW_ASSIGN(orderByDisplay, "Quantity On Order, Item Number, Warehouse")
      %endif
  %elif (sequence == "Vendor")
      %if (orderBy == "VMVNA1U,IMITEM,IWWHS")
          @DTW_ASSIGN(orderBy, "VMVNA1U DESC,IMITEM,IWWHS")
          @DTW_ASSIGN(orderByDisplay, "Vendor (descending), Item Number, Warehouse")
      %else
          @DTW_ASSIGN(orderBy, "VMVNA1U,IMITEM,IWWHS")
          @DTW_ASSIGN(orderByDisplay, "Vendor, Item Number, Warehouse")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(SELECT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Update POSGPO Set PSITEM='$(selectItem)' Where PSREQN='$(reqNumber)' and PSITEM='$(itemNumber)' @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Update POSGPT Set PTSITM=case When PTSITM=' ' Then PTITEM Else ' ' End ", stmtSQL)
  @dtw_concat(stmtSQL, " Where PTREQN='$(reqNumber)' and PTITEM='$(itemNumber)' and (PTSITM=' ' or PTSITM='$(selectItem)') @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Update POSGPT Set PTITEM='$(selectItem)' Where PTREQN='$(reqNumber)' and PTITEM='$(itemNumber)' @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)

  <script TYPE="text/javascript">
      opener.location.href=opener.location.href;
      window.close()
  </script>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("DGITEM", "Item Number", $(srchItem), "U", operItem, "A")
  @Build_WildCard ("coalesce(IWWHS,0)", "Warehouse", $(srchWhs), "", operWhs, "N")
  @Build_WildCard ("IMIMDSU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("IXCTG$(V_CITRUD)", "$(itemExtCat$(V_CITRUD))", $(srchCAT), "U", operCAT, "A")
  @Build_WildCard ("VMVNA1U", "Vendor", $(srchVend), "U", operVend, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}