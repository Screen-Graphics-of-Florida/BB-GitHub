%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Substitute Items"
  d2wName                 = "TransferSubstituteItems.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;transferTicket=@dtw_rurlescseq(transferTicket)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;whsNumber=@dtw_rurlescseq(whsNumber)&amp;orderQty=@dtw_rurlescseq(orderQty)&amp;subGroup=@dtw_rurlescseq(subGroup)&amp;reqNumber=@dtw_rurlescseq(reqNumber)&amp;transStatus=@dtw_rurlescseq(transStatus)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "9999"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "9999"
  rowIndexNext            = "1"
  totalPages              = "0"
  popUpWin                = "Y"
  displayCloseIcon        = "Y"
  advanceSearch           = "N"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script type="text/javascript">
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
           </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(uv_WarehouseName, "IWWHS")
                      @dtw_assign(uv_ProductClassName, "IMPCLS")
                      @dtw_assign(uv_ProductGroupName, "IWPGRP")
                      @dtw_assign(uv_ProdInventoryTypeName, "IMITC")
                      @dtw_assign(uv_ProdPartTypeName, "IMPTYP")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select ", stmtSQL)
                      %if (subGroup != "")
                          @dtw_concat(stmtSQL, " HDIGPD.*, ", stmtSQL)
                      %endif
                      @dtw_concat(stmtSQL, " HDIMST.*, HDIWHS.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(VMVNA1,' ') as VMVNA1, coalesce(VMVNA1U,' ') as VMVNA1U, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(WHWHNM,' ') as WHWHNM, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(IXCTG1,' ') as IXCTG1, coalesce(IXCTG2,' ') as IXCTG2, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(IXCTG3,' ') as IXCTG3, coalesce(IXCTG4,' ') as IXCTG4, coalesce(IXCTG5,' ') as IXCTG5 ", stmtSQL)
                      %if (subGroup != "")
                          @dtw_concat(fileSQL, " HDIGPD inner join HDIMST on DGITEM=IMITEM ", fileSQL)
                          @dtw_concat(fileSQL, "        inner join HDIWHS on DGITEM=IWITEM and IWWHS=$(whsNumber)", fileSQL)
                          @dtw_concat(fileSQL, "        left  join HDIMSX on DGITEM=IXITEM ", fileSQL)
                      %else
                          @dtw_concat(fileSQL, " HDIMST inner join HDIWHS on IMITEM=IWITEM and IWWHS=$(whsNumber)", fileSQL)
                          @dtw_concat(fileSQL, "        left  join HDIMSX on IMITEM=IXITEM ", fileSQL)
                      %endif
                      @dtw_concat(fileSQL, "        left  join HDVEND on IWVEND=VMVEND ", fileSQL)
                      @dtw_concat(fileSQL, "        left  join HDWHSM on coalesce(IWWHS,0)=WHWHS ", fileSQL)
                      %if (subGroup != "")
                          @dtw_concat(selectSQL, "DGIGRP='$(subGroup)'", selectSQL)
                      %else
                          @dtw_concat(selectSQL, "IMITEM='$(itemNumber)'", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy)", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Substitute_Item_Query(profileHandle, dataBaseID, stmtSQL)
                      @dtw_assign(wildCardSearch, "")

                      %if (onOrderWhs > "0")
                          @dtw_assign(uv_WarehouseName, "PDOVWH")
                          @dtw_assign(uv_ProductClassName, "PDPCLS")
                          %INCLUDE "userview.icl"

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select POPOMD.*, POVEND, VMVNA1 ", stmtSQL)
                          @dtw_concat(fileSQL, " POPOMS inner join POPOMD on PDPO=POPO ", fileSQL)
                          @dtw_concat(fileSQL, "        inner join HDVEND on VMVEND=POVEND ", fileSQL)
                          @dtw_concat(selectSQL, "POSTAT='O' and PDSTAT='O' and PDPOLT<>'B' and PDPOEC='S' and ", selectSQL)
                          @dtw_concat(selectSQL, "POFL02='1' and PODSHP=0 and PDITEM='$(selectItem)' ", selectSQL)
                          @dtw_concat(selectSQL, " and PDOVWH=$(onOrderWhs) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By PDOVWH,PDRQDT,PDPO,PDPOL#,PDPORL ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @OnOrder_Qty_Query(profileHandle, dataBaseID, stmtSQL)
                      %elif (resQtyWhs > "0")
                          @dtw_assign(uv_WarehouseName, "ODWH")
                          @dtw_assign(uv_ProductClassName, "ODPCLS")
                          @dtw_assign(uv_ProductGroupName, "ODPGRP")
                          %INCLUDE "userview.icl"

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select OEORDT.*, OESHTO, CMCNA1", stmtSQL)
                          @dtw_concat(fileSQL, " OEORHD inner join OEORDT on ODORD#=OEORD# ", fileSQL)
                          @dtw_concat(fileSQL, "        inner join HDCUST on CMCUST=OESHTO ", fileSQL)
                          @dtw_concat(selectSQL, "OEORST='O' and ODORST='O'and ODBLKT<>'Y' ", selectSQL)
                          @dtw_concat(selectSQL, "and OEFL02='1' and ODITEM='$(selectItem)' and ODOREC='S' ", selectSQL)
                          @dtw_concat(selectSQL, " and ODWH=$(resQtyWhs) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By ODWH,ODRQDT,ODORD#,ODORL#,ODBLN# ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Reserved_Qty_Query(profileHandle, dataBaseID, stmtSQL)
                      %elif (atpPlant > "0")
                          @dtw_assign(uv_Sql, "")

                          @Fill_ATP_Work_File(profileHandle, dataBaseID, atpPlant, selectItem)
                          @MS230A_Query(profileHandle, dataBaseID, atpPlant, selectItem, headerTable)
                          %if (@dtw_tb_rrows(headerTable)>"0")
                              @dtw_assign(haveHeader, "Y")
                          %else
                              @dtw_assign(haveHeader, "")
                          %endif
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " MS230W ", fileSQL)
                          @dtw_concat(selectSQL, "E_PLNT=$(atpPlant) and E_ITEM='$(selectItem)' and E_XHND='$(profileHandle)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By E_DATE,E_PAST DESC ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Avail_To_Promise(profileHandle, dataBaseID, stmtSQL)
                      %endif

                      %INCLUDE "stmtSQLClear.icl"
                      %if (subGroup != "")
                          @dtw_assign(groupSQL, " inner join HDIGPD on DGITEM=IHITEM and DGIGRP='$(subGroup)' ")
                          @dtw_assign(itemSQL, " and IHWHS=$(whsNumber) ")
                      %else
                          @dtw_assign(groupSQL, "")
                          @dtw_assign(itemSQL, " and IHITEM='$(itemNumber)' and IHWHS=$(whsNumber) ")
                      %endif
                      @dtw_concat(stmtSQL, " Select IHCYR, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce((Select sum(IHQSLD) From HDISLH b $(groupSQL) Where substr(digits(b.IHPERD),4,2)='01' and b.IHCYR=a.IHCYR $(itemSQL)),0) as p01,", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce((Select sum(IHQSLD) From HDISLH c $(groupSQL) Where substr(digits(c.IHPERD),4,2)='02' and c.IHCYR=a.IHCYR $(itemSQL)),0) as p02,", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce((Select sum(IHQSLD) From HDISLH d $(groupSQL) Where substr(digits(d.IHPERD),4,2)='03' and d.IHCYR=a.IHCYR $(itemSQL)),0) as p03,", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce((Select sum(IHQSLD) From HDISLH e $(groupSQL) Where substr(digits(e.IHPERD),4,2)='04' and e.IHCYR=a.IHCYR $(itemSQL)),0) as p04,", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce((Select sum(IHQSLD) From HDISLH f $(groupSQL) Where substr(digits(f.IHPERD),4,2)='05' and f.IHCYR=a.IHCYR $(itemSQL)),0) as p05,", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce((Select sum(IHQSLD) From HDISLH g $(groupSQL) Where substr(digits(g.IHPERD),4,2)='06' and g.IHCYR=a.IHCYR $(itemSQL)),0) as p06,", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce((Select sum(IHQSLD) From HDISLH h $(groupSQL) Where substr(digits(h.IHPERD),4,2)='07' and h.IHCYR=a.IHCYR $(itemSQL)),0) as p07,", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce((Select sum(IHQSLD) From HDISLH i $(groupSQL) Where substr(digits(i.IHPERD),4,2)='08' and i.IHCYR=a.IHCYR $(itemSQL)),0) as p08,", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce((Select sum(IHQSLD) From HDISLH j $(groupSQL) Where substr(digits(j.IHPERD),4,2)='09' and j.IHCYR=a.IHCYR $(itemSQL)),0) as p09,", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce((Select sum(IHQSLD) From HDISLH k $(groupSQL) Where substr(digits(k.IHPERD),4,2)='10' and k.IHCYR=a.IHCYR $(itemSQL)),0) as p10,", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce((Select sum(IHQSLD) From HDISLH l $(groupSQL) Where substr(digits(l.IHPERD),4,2)='11' and l.IHCYR=a.IHCYR $(itemSQL)),0) as p11,", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce((Select sum(IHQSLD) From HDISLH m $(groupSQL) Where substr(digits(m.IHPERD),4,2)='12' and m.IHCYR=a.IHCYR $(itemSQL)),0) as p12,", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce((Select sum(IHQSLD) From HDISLH n $(groupSQL) Where n.IHCYR=a.IHCYR $(itemSQL)),0) as tqty", stmtSQL)
                      %if (subGroup != "")
                          @dtw_concat(fileSQL, " HDIGPD inner join HDISLH a on DGITEM=IHITEM ", fileSQL)
                          @dtw_concat(selectSQL, "DGIGRP='$(subGroup)' and ", selectSQL)
                      %else
                          @dtw_concat(fileSQL, " HDISLH a ", fileSQL)
                      %endif
                      @dtw_concat(selectSQL, "IHCYR>0 $(itemSQL)", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Group By IHCYR", stmtSQL)
                      @dtw_concat(stmtSQL, " Order By IHCYR DESC", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Period_Sales_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Substitute_Item_Query (IN CHAR(64)    profileHandle,
				              CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(progName, "HHDIWU")
      @pgmOptSecurity(profileHandle, dataBaseID, progName, iw_sec_01, iw_sec_02, iw_sec_03, iw_sec_04, iw_sec_05, iw_sec_06, iw_sec_07, iw_sec_08, iw_sec_09, iw_sec_10, iw_sec_11, iw_sec_12, iw_sec_13, iw_sec_14, iw_sec_15)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
                  <a href="javascript:window.close()">$(closeImageMed)</a>
              </td>
          </tr>
      </table>
      %INCLUDE "OrderEntryRetInfo.icl"
      %INCLUDE "OrderEntryProgOpt.icl"

      <table $(contentTable)>
          @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
          @Format_Header("Item Number", $(itemDescription), $(itemNumber))
          @Format_Nbr(orderQty, F_orderQty, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Header("Suggested Quantity", $(F_orderQty), "")
      </table>

      $(hrTagAttr)

      %if (subGroup != "")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(contentTable)>
                  <tr>
                      <th class="colhdr">Item Number</th>
                      %if (dspSubstituteItemDesc == "Y")
                          <th class="colhdr">Description</th>
                      %endif
                      %if (V_CITRUD > "0")
                          <th class="colhdr">$(itemExtCat$(V_CITRUD))</th>
                      %endif
                      <th class="colhdr">Vendor</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchItem" size="10" maxlength="15">
                          <input type="hidden" name="operItem" value="LIKE">
                      </td>
                      %if (dspSubstituteItemDesc == "Y")
                          <td><input type="text" class="inputalph" name="srchDesc" size="10" maxlength="30">
                              <input type="hidden" name="operDesc" value="LIKE">
                          </td>
                      %endif
                      %if (V_CITRUD > "0")
                          <td class="inputalph"><input type="text" class="inputalph" name="srchCAT" size="5" maxlength="15">
                                                <input type="hidden" name="operCAT" value="LIKE">
                          </td>
                      %endif
                      <td><input type="text" class="inputalph" name="srchVend" size="10" maxlength="26">
                          <input type="hidden" name="operVend" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchItem.focus();
              </script>
          </form>
      %endif

      <table $(contentTable)>
          <tr>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("DGITEM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Item" title="Sequence By Item Number, Warehouse">Item Number</a></th>
              @OrderBy_Sort("IWWHS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Whs" title="Sequence By Warehouse, Item Number">Whs</a></th>
              %if (dspSubstituteItemDesc == "Y")
                  @OrderBy_Sort("IMIMDSU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description, Item Number, Warehouse">Description</a></th>
              %endif
              %if (V_CITRUD > "0")
                  @OrderBy_Sort("IXCTG$(V_CITRUD)", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Cat" title="Sequence By $(itemExtCat$(V_CITRUD)), Item Number">$(itemExtCat$(V_CITRUD))</a></th>
              %endif
              %if (oe_sec_08 == "Y" || transferTicket == "")
                  <th class="colhdr">Cost</th>
              %endif
              <th class="colhdr">Selling<br>Price</th>
              @OrderBy_Sort("IWOHQT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=OnHand" title="Sequence By Quantity On Hand, Item Number, Warehosue">Quantity<br>On Hand</a></th>
              <th class="colhdr">Quantity<br>Available</th>
              @OrderBy_Sort("IWRESQ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Resv" title="Sequence By Quantity Reserved, Item Number, Warehosue">Quantity<br>Reserved</a></th>
              @OrderBy_Sort("IWQOO", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=OnOrder" title="Sequence By Quantity On Order, Item Number, Warehosue">Quantity<br>On Order</a></th>
              %if (transferTicket == "")
                  @OrderBy_Sort("IWMINQ", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MinQty" title="Sequence By Minimum Quantity, Item Number">Minimum<br>Quantity</a></th>
                  @OrderBy_Sort("IWMAXQ", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MaxQty" title="Sequence By Maximum Quantity, Item Number">Maximum<br>Quantity</a></th>
              %endif
              @OrderBy_Sort("VMVNA1U", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Vendor" title="Sequence By Vendor, Item Number, Warehosue">Vendor</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Nbr(V_IWLIST, F_IWLIST, $(prcNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Nbr(V_IWOHQT, F_IWOHQT, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_IWRESQ, F_IWRESQ, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_IWQOO,  F_IWQOO, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_IWMINQ,  F_IWMINQ, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_IWMAXQ,  F_IWMAXQ, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @dtw_assign(qtyAvailable, ".0000")
              @Get_Qty_Avail(profileHandle, dataBaseID, V_DGITEM, V_IWWHS, qtyAvailable)
              @Format_Nbr($(qtyAvailable), F_qtyAvailable, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              %if (V_IWWHS > "0")
                  @Rtv_Unit_Price(H1SHTO, V_IMITEM, V_IWWHS, orderQty, unitPrice)
                  %if (oe_sec_08 == "Y" || transferTicket == "")
                      @Rtv_Unit_Cost(noPlt, V_IMITEM, V_IWWHS, noLot, totalCost, cat1Cost, cat2Cost, cat3Cost, cat4Cost, cat5Cost)
                  %endif
              %else
                  @dtw_assign(unitPrice, "0")
                  @dtw_assign(totalCost, "0")
              %endif
              @Format_Nbr($(totalCost), F_totalCost, $(cstNbrDec), $(cstEditCode), "", "", "")
              @Format_Nbr($(unitPrice), F_unitPrice, $(prcNbrDec), $(amtEditCode), "", "", "")
              %if (V_HDPDRL > "0")
                  @RetPltNbr(profileHandle, dataBaseID, subr, V_IWWHS, V_IMITEM, V_atpPlant)
              %endif
              @dtw_assign(W_orderQty, orderQty)
              @dtw_assign(W_IWOHQT, V_IWOHQT)
              %while(@dtw_rlength(W_IWOHQT) != "16") {@dtw_insert("0", W_IWOHQT, W_IWOHQT)%}
              %while(@dtw_rlength(W_orderQty) != "16") {@dtw_insert("0", W_orderQty, W_orderQty)%}
              %while(@dtw_rlength(qtyAvailable) != "16") {@dtw_insert("0", qtyAvailable, qtyAvailable)%}
              %if (qtyAvailable > W_orderQty)
                  @dtw_assign(availClass, "oeqtyavail")
              %else
                  @dtw_assign(availClass, "colnmbr")
              %endif
              %if (W_IWOHQT > W_orderQty)
                  @dtw_assign(onHandClass, "oeqtyavail")
              %else
                  @dtw_assign(onHandClass, "colnmbr")
              %endif
              <tr class="$(rowClass)">
                  <td class="colalph">
                      %if (V_IMITEM != $(itemNumber) && reqNumber > "0" && subGroup != "" && (transStatus == "N" || transStatus == "R" || (transStatus == "P" && transferTicket != "")))
                          <a href="$(homeURL)$(cGIPath)$(d2wName)/SELECT$(d2wVarBase)&amp;selectItem=@dtw_rurlescseq(V_IMITEM)" title="Select Item">$(V_IMITEM)</a>
                      %else
                          $(V_IMITEM)
                      %endif
                  </td>
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)ItemWarehouseSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_IMITEM)&amp;warehouseNumber=@dtw_rurlescseq(V_IWWHS)" title="View Item/Warehouse" onclick="winNew=window.open(this.href, 'item_whs_win'); winNew.focus(); return false;">$(V_IWWHS)</a></td>
                  %if (dspSubstituteItemDesc == "Y")
                      <td class="colalph">$(V_IMIMDS)</td>
                  %endif
                  %if (V_CITRUD > "0")
                      <td class="colalph">$(V_IXCTG$(V_CITRUD))</td>
                  %endif
                  %if (oe_sec_08 == "Y" || transferTicket == "")
                      <td class="colnmbr">$(F_totalCost)</td>
                  %endif
                  <td class="colnmbr">$(F_unitPrice)</td>
                  <td class="$(onHandClass)">$(F_IWOHQT)</td>
                  %if (V_HDPDRL > "0" && V_atpPlant > "0")
                      <td class="$(availClass)"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;selectItem=@dtw_rurlescseq(V_IMITEM)&amp;atpPlant=@dtw_rurlescseq(V_atpPlant)" title="View Available To Promise">$(F_qtyAvailable)</a></td>
                  %else
                      <td class="$(availClass)">$(F_qtyAvailable)</td>
                  %endif
                  %if (V_IWRESQ > "0")
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;selectItem=@dtw_rurlescseq(V_IMITEM)&amp;resQtyWhs=@dtw_rurlescseq(V_IWWHS)&amp;viewWhs=@dtw_rurlescseq(viewWhs)&amp;resQtyWhsName=@dtw_rurlescseq(V_WHWHNM)" title="View Open Orders for this Item/Whs">$(F_IWRESQ)</a></td>
                  %else
                      <td class="colnmbr">$(F_IWRESQ)</td>
                  %endif
                  %if (V_IWQOO > "0")
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;selectItem=@dtw_rurlescseq(V_IMITEM)&amp;onOrderWhs=@dtw_rurlescseq(V_IWWHS)&amp;viewWhs=@dtw_rurlescseq(viewWhs)&amp;onOrderWhsName=@dtw_rurlescseq(V_WHWHNM)" title="View Purchase Orders for this Item/Whs">$(F_IWQOO)</a></td>
                  %else
                      <td class="colnmbr">$(F_IWQOO)</td>
                  %endif
                  %if (transferTicket == "")
                      %if (iw_sec_02 == "Y")
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)ItemWarehouseMinMaxMaintain.d2w/MAINTAIN$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_IMITEM)&amp;itemDescription=@dtw_rurlescseq(V_IMIMDS)&amp;warehouseNumber=@dtw_rurlescseq(V_IWWHS)&amp;rowNum=@dtw_rurlescseq($(ROW_NUM))" title="Update Minimum/Maximum Quantities" onclick="$(smallPromptWinVar)"><span id="minQty$(ROW_NUM)">$(F_IWMINQ)</span></a></td>
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)ItemWarehouseMinMaxMaintain.d2w/MAINTAIN$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_IMITEM)&amp;itemDescription=@dtw_rurlescseq(V_IMIMDS)&amp;warehouseNumber=@dtw_rurlescseq(V_IWWHS)&amp;rowNum=@dtw_rurlescseq($(ROW_NUM))" title="Update Minimum/Maximum Quantities" onclick="$(smallPromptWinVar)"><span id="maxQty$(ROW_NUM)">$(F_IWMAXQ)</span></a></td>
                      %else
                          <td class="colnmbr">$(F_IWMINQ)</td>
                          <td class="colnmbr">$(F_IWMAXQ)</td>
                      %endif
                  %endif
                  <td class="colalph">$(V_VMVNA1)</td>
              </tr>
          %}
      </table>
  %}
%}

%FUNCTION(dtw_sql) OnOrder_Qty_Query (IN CHAR(64)    profileHandle,
				          CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="qtyOnOrder"></a>
      <fieldset class="legendBody">
          <legend class="legendTitle">Purchase Orders for Item $(selectItem) in Whs $(onOrderWhs) </legend>
          <div class="quickLinksTop">
              <a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)">$(closeImageMed)</a>
          </div>

      <table $(contentTable)>
          <tr>
              %if (onOrderWhs == "All")
                  <th class="colhdr">Whs</th>
                  @dtw_assign(spanCount, "5")
              %else
                  @dtw_assign(spanCount, "4")
              %endif
              <th class="colhdr">Order<br>Number</th>
              <th class="colhdr">Line</th>
              <th class="colhdr">Rel</th>
              <th class="colhdr">Required<br>Date</th>
              <th class="colhdr">Quantity<br>Ordered</th>
              <th class="colhdr">Quantity<br>Received</th>
              <th class="colhdr">Quantity<br>Open</th>
              <th class="colhdr">Vendor<br>Number</th>
              <th class="colhdr">Name</th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"
	   		
          %ROW{
              %INCLUDE "SetRowClass.icl"
              @dtw_assign(mmyy, @dtw_rsubstr(V_PDRQDT, "2", "4"))
              %if (mmyy != W_mmyy)
                  %if (W_mmyy != "")
                      @dtw_assign(mm, @dtw_rsubstr(W_mmyy, "3", "2"))
                      @dtw_assign(yy, @dtw_rsubstr(W_mmyy, "1", "2"))
                      @Format_Nbr(T_PDQTOR, F_PDQTOR, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                      @Format_Nbr(T_QRECVD, F_QRECVD, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                      @Format_Nbr(T_QOPEN, F_QOPEN, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                      <tr>
                          <td class="colnmbr" colspan="$(spanCount)">Total for $(mm)$(dateEdit)$(yy)</td>
                          <td class="coltotal">$(F_PDQTOR)</td>
                          <td class="coltotal">$(F_QRECVD)</td>
                          <td class="coltotal">$(F_QOPEN)</td>
                      </tr>
                  %endif
                  @dtw_assign(W_mmyy, mmyy)
                  @dtw_assign(T_PDQTOR, "0")
                  @dtw_assign(T_QRECVD, "0")
                  @dtw_assign(T_QOPEN, "0")
              %endif

              @Format_Date(V_PDRQDT, "D", F_PDRQDT)
              @Format_Nbr(V_PDQTOR, F_PDQTOR, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @dtw_add(V_PDQRST, V_PDQRRT, subTotal)
              @dtw_add(subTotal, V_PDQRFT, V_QRECVD)
              @Format_Nbr(V_QRECVD, F_QRECVD, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @dtw_subtract(V_PDQTOR, V_QRECVD, V_QOPEN)
              @Format_Nbr(V_QOPEN, F_QOPEN, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")

              @dtw_add(T_PDQTOR, V_PDQTOR, T_PDQTOR)
              @dtw_add(T_QRECVD, V_QRECVD, T_QRECVD)
              @dtw_add(T_QOPEN, V_QOPEN, T_QOPEN)

              <tr class="$(rowClass)">
                  %if (onOrderWhs == "All")
                      <td class="colnmbr">
                          %if (inquiryOnly == "Y")
                              $(V_PDOVWH)
                          %else
                              <a href="$(homeURL)$(cGIPath)$(d2wName)/SELECT$(d2wVarBase)&amp;warehouseNumber=@dtw_rurlescseq(V_PDOVWH)" title="Select Warehouse">$(V_PDOVWH)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colnmbr">$(V_PDPO)</td>
                  <td class="colnmbr">$(V_PDPOL#)</td>
                  <td class="colnmbr">$(V_PDPORL)</td>
                  <td class="coldate">$(F_PDRQDT)</td>
                  <td class="colnmbr">$(F_PDQTOR)</td>
                  <td class="colnmbr">$(F_QRECVD)</td>
                  <td class="colnmbr">$(F_QOPEN)</td>
                  <td class="colnmbr">$(V_POVEND)</td>
                  <td class="colalph">$(V_VMVNA1)</td>
              </tr>
          %}
          %if (W_mmyy != "")
              @dtw_assign(mm, @dtw_rsubstr(W_mmyy, "3", "2"))
              @dtw_assign(yy, @dtw_rsubstr(W_mmyy, "1", "2"))
              @Format_Nbr(T_PDQTOR, F_PDQTOR, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(T_QRECVD, F_QRECVD, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(T_QOPEN, F_QOPEN, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              <tr>
                  <td class="colnmbr" colspan="$(spanCount)">Total for $(mm)$(dateEdit)$(yy)</td>
                  <td class="coltotal">$(F_PDQTOR)</td>
                  <td class="coltotal">$(F_QRECVD)</td>
                  <td class="coltotal">$(F_QOPEN)</td>
              </tr>
          %endif
      </table>
      </fieldset>
      <script TYPE="text/javascript">
          window.location.hash='qtyOnOrder';
      </script>
  %}
%}

%FUNCTION(dtw_sql) Reserved_Qty_Query (IN CHAR(64)    profileHandle,
				           CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="qtyReserved"></a>
      <fieldset class="legendBody">
          <legend class="legendTitle">Open Orders for Item $(selectItem) in Whs $(resQtyWhs) </legend>
          <div class="quickLinksTop">
              <a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)">$(closeImageMed)</a>
          </div>

      <table $(contentTable)>
          %if (sql_Record_Count > "0")
              <tr>
                  %if (resQtyWhs == "All")
                      <th class="colhdr">Whs</th>
                      @dtw_assign(spanCount, "5")
                  %else
                      @dtw_assign(spanCount, "4")
                  %endif
                  <th class="colhdr">Order<br>Number</th>
                  <th class="colhdr">Line</th>
                  <th class="colhdr">Rel</th>
                  <th class="colhdr">Required<br>Date</th>
                  <th class="colhdr">Quantity<br>Ordered</th>
                  <th class="colhdr">Quantity<br>Shipped</th>
                  <th class="colhdr">Quantity<br>Open</th>
                  <th class="colhdr">Customer<br>Number</th>
                  <th class="colhdr">Name</th>
              </tr>
          %endif
          %INCLUDE "NoRecordsFound.icl"
	   		
          %ROW{
              %INCLUDE "SetRowClass.icl"
              @dtw_assign(mmyy, @dtw_rsubstr(V_ODRQDT, "2", "4"))
              %if (mmyy != W_mmyy)
                  %if (W_mmyy != "")
                      @dtw_assign(mm, @dtw_rsubstr(W_mmyy, "3", "2"))
                      @dtw_assign(yy, @dtw_rsubstr(W_mmyy, "1", "2"))
                      @Format_Nbr(T_ODQORD, F_ODQORD, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                      @Format_Nbr(T_qtyShip, F_qtyShip, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                      @Format_Nbr(T_QOPEN, F_QOPEN, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                      <tr>
                          <td class="colnmbr" colspan="$(spanCount)">Total for $(mm)$(dateEdit)$(yy)</td>
                          <td class="coltotal">$(F_ODQORD)</td>
                          <td class="coltotal">$(F_qtyShip)</td>
                          <td class="coltotal">$(F_QOPEN)</td>
                      </tr>
                  %endif
                  @dtw_assign(W_mmyy, mmyy)
                  @dtw_assign(T_ODQORD, "0")
                  @dtw_assign(T_qtyShip, "0")
                  @dtw_assign(T_QOPEN, "0")
              %endif

              @Format_Date(V_ODRQDT, "D", F_ODRQDT)
              @Format_Nbr(V_ODQORD, F_ODQORD, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @dtw_add(V_ODQSTD, V_ODQSTC, qtyShip)
              @Format_Nbr(qtyShip, F_qtyShip, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @dtw_subtract(V_ODQORD, qtyShip, V_QOPEN)
              @Format_Nbr(V_QOPEN, F_QOPEN, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")

              @dtw_add(T_ODQORD, V_ODQORD, T_ODQORD)
              @dtw_add(T_qtyShip, qtyShip, T_qtyShip)
              @dtw_add(T_QOPEN, V_QOPEN, T_QOPEN)

              <tr class="$(rowClass)">
                  %if (resQtyWhs == "All")
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)$(d2wName)/SELECT$(d2wVarBase)&amp;warehouseNumber=@dtw_rurlescseq(V_ODWH)" title="Select Warehouse">$(V_ODWH)</a></td>
                  %endif
                  <td class="colnmbr">$(V_ODORD#)</td>
                  <td class="colnmbr">$(V_ODORL#)</td>
                  <td class="colnmbr">$(V_ODBLN#)</td>
                  <td class="coldate">$(F_ODRQDT)</td>
                  <td class="colnmbr">$(F_ODQORD)</td>
                  <td class="colnmbr">$(F_qtyShip)</td>
                  <td class="colnmbr">$(F_QOPEN)</td>
                  <td class="colnmbr">$(V_OESHTO)</td>
                  <td class="colalph">$(V_CMCNA1)</td>
              </tr>
          %}
          %if (W_mmyy != "")
              @dtw_assign(mm, @dtw_rsubstr(W_mmyy, "3", "2"))
              @dtw_assign(yy, @dtw_rsubstr(W_mmyy, "1", "2"))
              @Format_Nbr(T_ODQORD, F_ODQORD, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(T_qtyShip, F_qtyShip, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(T_QOPEN, F_QOPEN, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              <tr>
                  <td class="colnmbr" colspan="$(spanCount)">Total for $(mm)$(dateEdit)$(yy)</td>
                  <td class="coltotal">$(F_ODQORD)</td>
                  <td class="coltotal">$(F_qtyShip)</td>
                  <td class="coltotal">$(F_QOPEN)</td>
              </tr>
          %endif
      </table>
      </fieldset>
      <script TYPE="text/javascript">
          window.location.hash='qtyReserved';
      </script>
  %}
%}

%FUNCTION(dtw_sql) Avail_To_Promise (IN CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="qtyAvailable"></a>
      <fieldset class="legendBody">
          <legend class="legendTitle">Available To Promise for Item $(selectItem) in Plant $(atpPlant)</legend>
          <div class="quickLinksTop">
              <a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)">$(closeImageMed)</a>
          </div>

      %if (sql_Record_Count > "0")
          <table $(contentTable)>
              <tr><td class="colhdr">Lead<br>Time</td>
                  <td class="colhdr">Part<br>Type</td>
                  <td class="colhdr">UM</td>
                  <td class="colhdr">On Hand</td>
                  <td class="colhdr">Released</td>
                  <td class="colhdr">Firm</td>
                  <td class="colhdr">Demand</td>
                  <td class="colhdr">Sold MTD</td>
                  <td class="colhdr">Analyst<br>Number</td>
                  <td class="colhdr">ABC</td>
                  <td class="colhdr">MPS</td>
                  <td class="colhdr">Demand</td>
              </tr>

              %if (haveHeader == "Y")
                  @dtw_tb_getv(headerTable, "1", "7", partType)
                  @RtvFldDesc("FLTYPE='PARTTYPE' and FLVALU='$(partType)'", "SYFLAG", "FLDESC", partTypeDesc)
                  @dtw_tb_getv(headerTable, "1", "8", uom)
                  @RtvFldDesc("UMUOM='$(uom)'", "HDUOM", "UMUMLD", uomDesc)
                  @dtw_tb_getv(headerTable, "1", "14", analyst)
                  @RtvFldDesc("BMBUYR=$(analyst)", "HDBUYR", "BMBNA1", analystName)
                  @dtw_tb_getv(headerTable, "1", "17", demandCode)
                  @RtvFldDesc("FLTYPE='SCHDDEMAND' and FLVALU='$(demandCode)'", "SYFLAG", "FLDESC", demandCodeDesc)
                  @Format_Nbr("@dtw_tb_rgetv(headerTable, "1", "9")", onHand, "0", $(qtyEditCode), "", "", "")
                  @Format_Nbr("@dtw_tb_rgetv(headerTable, "1", "10")", released, "0", $(qtyEditCode), "", "", "")
                  @Format_Nbr("@dtw_tb_rgetv(headerTable, "1", "11")", firm, "0", $(qtyEditCode), "", "", "")
                  @Format_Nbr("@dtw_tb_rgetv(headerTable, "1", "12")", demand, "0", $(qtyEditCode), "", "", "")
                  @Format_Nbr("@dtw_tb_rgetv(headerTable, "1", "13")", soldMTD, "0", $(qtyEditCode), "", "", "")
                  <tr><td class="colnmbr">@dtw_tb_rgetv(headerTable, "1", "6")</td>
                      <td class="colcode" $(helpCursor)><span title="$(partTypeDesc)">$(partType)</span></td>
                      <td class="colcode" $(helpCursor)><span title="$(uomDesc)">$(uom)</span></td>
                      <td class="colnmbr">$(onHand)</td>
                      <td class="colnmbr">$(released)</td>
                      <td class="colnmbr">$(firm)</td>
                      <td class="colnmbr">$(demand)</td>
                      <td class="colnmbr">$(soldMTD)</td>
                      <td class="colnmbr" $(helpCursor)><span title="$(analystName)">$(analyst)</span></td>
                      <td class="colcode">@dtw_tb_rgetv(headerTable, "1", "15")</td>
                      <td class="colcode">@dtw_tb_rgetv(headerTable, "1", "16")</td>
                      <td class="colcode" $(helpCursor)><span title="$(demandCodeDesc)">$(demandCode)</span></td>
                  </tr>
              %endif
          </table>
      %endif

	   <table $(contentTable)>
              %if (sql_Record_Count > "0")
                  <th class="colhdr">Date</th>
                  <th class="colhdr">Sales<br>Forecast</th>
                  <th class="colhdr">Customer<br>Demand</th>
                  <th class="colhdr">Pegged<br>Requirements</th>
                  <th class="colhdr">Available<br>To<br>Promise</th>
                  <th class="colhdr">Released/<br>Firm</th>
                  <th class="colhdr">Planned<br>Orders</th>
              %endif
              %INCLUDE "NoRecordsFound.icl"

          %ROW {
	       %INCLUDE "SetRowClass.icl"

              %if (V_E_PAST == "Y")
                  @dtw_assign(F_E_DATE, "Past Due")
                  @dtw_assign(once, "Y")
              %elif (V_E_DATE == "9999999")
                  @dtw_assign(F_E_DATE, "Future")
              %else
                  @Format_Date(V_E_DATE, "D", F_E_DATE)
              %endif

              @Format_Nbr(V_E_FOR, F_E_FOR, "0", $(qtyEditCode), "", "", "")
              @Format_Nbr(V_E_COR, F_E_COR, "0", $(qtyEditCode), "", "", "")
              @Format_Nbr(V_E_PEG, F_E_PEG, "0", $(qtyEditCode), "", "", "")
              @Format_Nbr(V_E_AVL, F_E_AVL, "0", $(qtyEditCode), "", "", "")
              @Format_Nbr(V_E_REC, F_E_REC, "0", $(qtyEditCode), "", "", "")
              @Format_Nbr(V_E_PLN, F_E_PLN, "0", $(qtyEditCode), "", "", "")

	       <tr class="$(rowClass)">
                  <td class="coldate">$(F_E_DATE)</td>
                  <td class="colnmbr">$(F_E_FOR)</td>
                  <td class="colnmbr">$(F_E_COR)</td>
                  <td class="colnmbr">$(F_E_PEG)</td>
                  <td class="colnmbr">$(F_E_AVL)</td>
                  <td class="colnmbr">$(F_E_REC)</td>
                  <td class="colnmbr">$(F_E_PLN)</td>
	       </tr>
          %}
      </table>
      </fieldset>
      <script TYPE="text/javascript">
          window.location.hash='qtyAvailable';
      </script>
  %}
%}

%FUNCTION(dtw_sql) Period_Sales_Query (IN CHAR(64)    profileHandle,
				           CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <fieldset class="legendBody">
          <legend class="legendTitle">Quantity Sold By Period</legend>

      <table $(contentTable)>
          <tr>
              <th class="colhdr">Year</th>
              <th class="colhdr">Total</th>
              <th class="colhdr">Jan</th>
              <th class="colhdr">Feb</th>
              <th class="colhdr">Mar</th>
              <th class="colhdr">Apr</th>
              <th class="colhdr">May</th>
              <th class="colhdr">Jun</th>
              <th class="colhdr">Jul</th>
              <th class="colhdr">Aug</th>
              <th class="colhdr">Sep</th>
              <th class="colhdr">Oct</th>
              <th class="colhdr">Nov</th>
              <th class="colhdr">Dec</th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"
          @dtw_assign(curYY, @dtw_rsubstr(@dtw_rdate("O"),"1","2"))	
	   @dtw_assign(curMM, @dtw_rsubstr(@dtw_rdate("O"),"4","2"))	
	
          %ROW{
              %INCLUDE "SetRowClass.icl"
              %while(@dtw_rlength(V_IHCYR) != "3") {@dtw_insert("0", V_IHCYR, V_IHCYR)%}
              @dtw_assign(Year, @dtw_rsubstr(V_IHCYR,"2","2"))
              @Format_Nbr(V_TQTY, F_TQTY, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_P01, F_P01, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @dtw_assign(F_P02, "")
              @dtw_assign(F_P03, "")
              @dtw_assign(F_P04, "")
              @dtw_assign(F_P05, "")
              @dtw_assign(F_P06, "")
              @dtw_assign(F_P07, "")
              @dtw_assign(F_P08, "")
              @dtw_assign(F_P09, "")
              @dtw_assign(F_P10, "")
              @dtw_assign(F_P11, "")
              @dtw_assign(F_P12, "")
              %if (Year != curYY || (Year == curYY && curMM > "01"))
                  @Format_Nbr(V_P02, F_P02, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              %endif
              %if (Year != curYY || (Year == curYY && curMM > "02"))
                  @Format_Nbr(V_P03, F_P03, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              %endif
              %if (Year != curYY || (Year == curYY && curMM > "03"))
                  @Format_Nbr(V_P04, F_P04, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              %endif
              %if (Year != curYY || (Year == curYY && curMM > "04"))
                  @Format_Nbr(V_P05, F_P05, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              %endif
              %if (Year != curYY || (Year == curYY && curMM > "05"))
                  @Format_Nbr(V_P06, F_P06, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              %endif
              %if (Year != curYY || (Year == curYY && curMM > "06"))
                  @Format_Nbr(V_P07, F_P07, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              %endif
              %if (Year != curYY || (Year == curYY && curMM > "07"))
                  @Format_Nbr(V_P08, F_P08, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              %endif
              %if (Year != curYY || (Year == curYY && curMM > "08"))
                  @Format_Nbr(V_P09, F_P09, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              %endif
              %if (Year != curYY || (Year == curYY && curMM > "09"))
                  @Format_Nbr(V_P10, F_P10, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              %endif
              %if (Year != curYY || (Year == curYY && curMM > "10"))
                  @Format_Nbr(V_P11, F_P11, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              %endif
              %if (Year != curYY || (Year == curYY && curMM > "11"))
                  @Format_Nbr(V_P12, F_P12, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              %endif

              <tr class="$(rowClass)">
                  <td class="colnmbr">$(Year)</td>
                  <td class="colnmbr">$(F_TQTY)</td>
                  <td class="colnmbr">$(F_P01)</td>
                  <td class="colnmbr">$(F_P02)</td>
                  <td class="colnmbr">$(F_P03)</td>
                  <td class="colnmbr">$(F_P04)</td>
                  <td class="colnmbr">$(F_P05)</td>
                  <td class="colnmbr">$(F_P06)</td>
                  <td class="colnmbr">$(F_P07)</td>
                  <td class="colnmbr">$(F_P08)</td>
                  <td class="colnmbr">$(F_P09)</td>
                  <td class="colnmbr">$(F_P10)</td>
                  <td class="colnmbr">$(F_P11)</td>
                  <td class="colnmbr">$(F_P12)</td>
              </tr>
          %}
      </table>
      </fieldset>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
      <script TYPE="text/javascript">
          window.location.hash='qtyOnOrder';
      </script>
  %}
%}

