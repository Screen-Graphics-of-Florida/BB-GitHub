%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Customer Search"
  d2wName                 = "CustomerSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;forCustomer=@dtw_rurlescseq(forCustomer)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function selectCustomer(customerNumber, customerName){
                      window.opener.document.$(docName).$(fldName).value = customerNumber;
                      window.opener.document.$(docName).$(fldDesc).value = customerName;
                      window.opener.document.$(docName).$(fldName).focus();
                      window.close();
                  }
                  %INCLUDE "CheckEnterSearch.icl"
                  %INCLUDE "NoFormValidate.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "$(searchBanner)"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      <td class="content">
                          @dtw_assign(uv_CustomerName, "CMCUST")
                          %INCLUDE "userview.icl"

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " HDCUST ", fileSQL)
                          %if (moreInfo == "Y")
                              @dtw_concat(selectSQL, " CMCUST=$(customerNumber)", selectSQL)
                          %elseif (forCustomer != "")
                              @dtw_concat(selectSQL, " (CMCUST=$(forCustomer) or CMBLTO=$(forCustomer)) ", selectSQL)
                          %elseif (wildCardSearch!="" || uv_Sql!="")
                              @dtw_concat(selectSQL, " CMCUST>0 ", selectSQL)
                          %endif
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"

                          @Customer_Search(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "$(searchTrailer)"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Customer_Search (IN  CHAR(64)    profileHandle,
				         CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Name</th></tr>
                  <tr><td><input type="text" class="inputalph" name="customerName" size="26" maxlength="26">
                          <input type="hidden" name="operName" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.customerName.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("CMCNA1U", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Name" title="Sequence By Name"> Name</a></th>
                  @OrderBy_Sort("CMCNA2U", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Address" title="Sequence By Address"> Address</a></th>
                  @OrderBy_Sort("CMCCTYU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=City" title="Sequence By City, Name"> City</a></th>
                  @OrderBy_Sort("CMST", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=State" title="Sequence By State, Name"> State</a></th>
                  @OrderBy_Sort("CMZIP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Zip" title="Sequence By Zip, Name"> Zip</a></th>
                  @OrderBy_Sort("CMPHON", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Phone" title="Sequence By Phone"> Phone Number</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %else
          <table $(contentTable)>
      %endif		

              %ROW{
                  @EditPhoneNumber(V_CMPHON)
                  @Format_Quote(V_CMCNA1, F_CMCNA1)

                  %if (moreInfo != "Y")	
                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          <td class="colalph"><a href="javascript:selectCustomer($(V_CMCUST), '$(F_CMCNA1)')" title="Select Customer">$(V_CMCNA1)</a></td>
                          <td class="colalph">$(V_CMCNA2)</td>
                          <td class="colalph">$(V_CMCCTY)</td>
                          <td class="colcode">$(V_CMST)</td>
                          <td class="colnmbr">$(V_CMZIP)</td>
                          <td class="colnmbr">$(V_CMPHON)</td>
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;customerNumber=@dtw_rurlescseq(V_CMCUST)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                      </tr>

                  %else

                      <tr><td><a href="javascript:selectCustomer($(V_CMCUST),'$(F_CMCNA1)')" title="Select Customer">$(selectImageLrg)</a>
                          </td>
                      </tr>

                      <tr><td class="dsphdr">Customer Number</td>
                          <td class="dspalph">$(V_CMCUST)</td>
                      </tr>

                      <tr><td class="dsphdr">Customer Name</td>
                          <td class="dspalph">$(V_CMCNA1)</td></tr>

                      <tr><td class="dsphdr">Address</td>
                          <td class="dspalph">$(V_CMCNA2)</td></tr>	

                      <tr><td class="dsphdr">City</td>
                          <td class="dspalph">$(V_CMCCTY)</td></tr>

                      @RtvFldDesc("STID='$(V_CMST)'", "HDSTID", "STDESC", fieldDesc)
                      <tr><td class="dsphdr">State</td>
                          <td class="dspalph">$(fieldDesc)</td></tr>

                      <tr><td class="dsphdr">Zip</td>
                          <td class="dspalph">$(V_CMZIP)</td></tr>

                      <tr><td class="dsphdr">Phone Number</td>
                          <td class="dspnmbr">$(V_CMPHON)</td></tr>

                      @RtvFldDesc("CNCTCD='$(V_CMCTRY)'", "HDCTRY", "CNCDES", fieldDesc)
                      <tr><td class="dsphdr">Country</td>
                          <td class="dspalph">$(fieldDesc)</td></tr>

                      @RtvFldDesc("CRSCR1<>' '", "ARCTRL", "CRSCR1", V_CRSCR1)
                      %if (V_CRSCR1 != "")
                          <tr><td class="dsphdr">$(V_CRSCR1)</td>
                              <td class="dspalph">$(V_CMUDF1)</td></tr>
                      %endif

                      @RtvFldDesc("CRSCR2<>' '", "ARCTRL", "CRSCR2", V_CRSCR2)
                      %if (V_CRSCR2 != "")
                          <tr><td class="dsphdr">$(V_CRSCR2)</td>
                              <td class="dspalph">$(V_CMUDF2)</td></tr>
                      %endif

                      @RtvFldDesc("CRSCR3<>' '", "ARCTRL", "CRSCR3", V_CRSCR3)
                      %if (V_CRSCR3 != "")
                          <tr><td class="dsphdr">$(V_CRSCR3)</td>
                              <td class="inputalph">$(V_CMUDF3)</td></tr>
                      %endif

                      @RtvFldDesc("CRSCR4<>' '", "ARCTRL", "CRSCR4", V_CRSCR4)
                      %if (V_CRSCR4 != "")
                          <tr><td class="dsphdr">$(V_CRSCR4)</td>
                              <td class="dspalph">$(V_CMUDF4)</td></tr>
                      %endif

                      @RtvFldDesc("CRSCR5<>' '", "ARCTRL", "CRSCR5", V_CRSCR5)
                      %if (V_CRSCR5 != "")
                          <tr><td class="dsphdr">$(V_CRSCR5)</td>
                              <td class="dspalph">$(V_CMUDF5)</td></tr>
                      %endif
                  %endif
              %}
          </table>
          %if (moreInfo != "Y")	
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
          %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "CMCNA1U")
      @DTW_ASSIGN(orderByDisplay, "Name")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Name")
      %if (orderBy == "CMCNA1U")
          @DTW_ASSIGN(orderBy, "CMCNA1U DESC")
          @DTW_ASSIGN(orderByDisplay, "Name (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CMCNA1U")
          @DTW_ASSIGN(orderByDisplay, "Name")
      %endif
  %elseif (sequence == "Address")
      %if (orderBy == "CMCNA2U,CMCNA3U,CMCNA4U")
          @DTW_ASSIGN(orderBy, "CMCNA2U DESC,CMCNA3U,CMCNA4U")
          @DTW_ASSIGN(orderByDisplay, "Address (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CMCNA2U,CMCNA3U,CMCNA4U")
          @DTW_ASSIGN(orderByDisplay, "Address")
      %endif
  %elseif (sequence == "City")
      %if (orderBy == "CMCCTYU,CMCNA1U")
          @DTW_ASSIGN(orderBy, "CMCCTYU DESC,CMCNA1U")
          @DTW_ASSIGN(orderByDisplay, "City (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "CMCCTYU,CMCNA1U")
          @DTW_ASSIGN(orderByDisplay, "City, Name")
      %endif
  %elseif (sequence == "State")
      %if (orderBy == "CMST,CMCNA1U")
          @DTW_ASSIGN(orderBy, "CMST DESC,CMCNA1U")
          @DTW_ASSIGN(orderByDisplay, "State (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "CMST,CMCNA1U")
          @DTW_ASSIGN(orderByDisplay, "State, Name")
      %endif
  %elseif (sequence == "Zip")
      %if (orderBy == "CMZIP,CMCNA1U")
          @DTW_ASSIGN(orderBy, "CMZIP DESC,CMCNA1U")
          @DTW_ASSIGN(orderByDisplay, "Zip (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "CMZIP,CMCNA1U")
          @DTW_ASSIGN(orderByDisplay, "Zip, Name")
      %endif
  %elseif (sequence == "Phone")
      %if (orderBy == "CMPHON")
          @DTW_ASSIGN(orderBy, "CMPHON DESC")
          @DTW_ASSIGN(orderByDisplay, "Phone Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CMPHON")
          @DTW_ASSIGN(orderByDisplay, "Phone Number")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.customerPhone, 11, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "customersearch")
                  <td>
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      @RtvFldDesc("CRSCR1<>' '", "ARCTRL", "CRSCR1", V_CRSCR1)
                      @RtvFldDesc("CRSCR2<>' '", "ARCTRL", "CRSCR2", V_CRSCR2)
                      @RtvFldDesc("CRSCR3<>' '", "ARCTRL", "CRSCR3", V_CRSCR3)
                      @RtvFldDesc("CRSCR4<>' '", "ARCTRL", "CRSCR4", V_CRSCR4)
                      @RtvFldDesc("CRSCR5<>' '", "ARCTRL", "CRSCR5", V_CRSCR5)

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Customer Name</td>
                              @dtw_assign(operNbr, "operName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="customerName" size="26" maxlength="26"></td>
                          </tr>

                          <tr><td class="dsphdr">Address</td>
                              @dtw_assign(operNbr, "operAddr")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="customerAddress" size="26" maxlength="26"></td>
                          </tr>

                          <tr><td class="dsphdr">State</td>
                              @dtw_assign(operNbr, "operState")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="customerState" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Zip</td>
                              @dtw_assign(operNbr, "operZip")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="customerZip" size="14" maxlength="14"></td>
                          </tr>

                          <tr><td class="dsphdr">Phone Number</td>
                              <td>&nbsp;</td>
                              <td class="inputnmbr"> <input type="text" name="customerPhone" size="11" maxlength="11"></td>
                          </tr>

                          <tr><td class="dsphdr">Country</td>
                              @dtw_assign(operNbr, "operCountry")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="customerCountry" size="3" maxlength="3"></td>
                          </tr>

                          %if (V_CRSCR1 != "")
                              <tr><td class="dsphdr">$(V_CRSCR1)</td>
                                  @dtw_assign(operNbr, "operUDF1")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="customerUDF1" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CRSCR2 != "")
                              <tr><td class="dsphdr">$(V_CRSCR2)</td>
                                  @dtw_assign(operNbr, "operUDF2")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="customerUDF2" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CRSCR3 != "")
                              <tr><td class="dsphdr">$(V_CRSCR3)</td>
                                  @dtw_assign(operNbr, "operUDF3")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="customerUDF3" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CRSCR4 != "")
                              <tr><td class="dsphdr">$(V_CRSCR4)</td>
                                  @dtw_assign(operNbr, "operUDF4")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="customerUDF4" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CRSCR5 != "")
                              <tr><td class="dsphdr">$(V_CRSCR5)</td>
                                  @dtw_assign(operNbr, "operUDF5")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="customerUDF5" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.customerName.focus();
                          </script>
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @RtvFldDesc("CRSCR1<>' '", "ARCTRL", "CRSCR1", V_CRSCR1)
  @RtvFldDesc("CRSCR2<>' '", "ARCTRL", "CRSCR2", V_CRSCR2)
  @RtvFldDesc("CRSCR3<>' '", "ARCTRL", "CRSCR3", V_CRSCR3)
  @RtvFldDesc("CRSCR4<>' '", "ARCTRL", "CRSCR4", V_CRSCR4)
  @RtvFldDesc("CRSCR5<>' '", "ARCTRL", "CRSCR5", V_CRSCR5)

  @Build_WildCard ("CMCNA1U", "Customer Name", $(customerName), "U", operName, "A")

  @dtw_assign(customerAddress,@dtw_rstrip(customerAddress))
  %if (customerAddress != "")
      @Build_WildCard ("CMCNA2U", "Address", $(customerAddress), "U", "LIKE", "V")
      @dtw_mUPPERCASE(customerAddress)
      @dtw_replace(customerAddress, "?", "_", "1", "a", customerAddress)
      @dtw_replace(customerAddress, "*", "%", "1", "a", customerAddress)
      @dtw_concat(wildCardTemp, " (trim(CMCNA2U) LIKE '$(customerAddress)'", wildCardTemp)
      @dtw_concat(wildCardTemp, " OR   trim(CMCNA3U) LIKE '$(customerAddress)'", wildCardTemp)
      @dtw_concat(wildCardTemp, " OR   trim(CMCNA4U) LIKE '$(customerAddress)'", wildCardTemp)
      @dtw_concat(wildCardTemp, " OR   trim(CMCCTYU) LIKE '$(customerAddress)')", wildCardTemp)
  %endif
		
  @Build_WildCard ("CMST", "State", $(customerState), "U", operState, "A")
  @Build_WildCard ("CMZIP", "Zip", $(customerZip), "", operZip, "A")
  @Build_WildCard ("CMPHON", "Phone Number", $(customerPhone), "", "", "P")
  @Build_WildCard ("CMCTRY", "Country", $(customerCountry), "", operCountry, "A")
  @Build_WildCard ("upper(CMUDF1)", "$(V_CRSCR1)", $(customerUDF1), "U", operUDF1, "A")
  @Build_WildCard ("upper(CMUDF2)", "$(V_CRSCR2)", $(customerUDF2), "U", operUDF2, "A")
  @Build_WildCard ("upper(CMUDF3)", "$(V_CRSCR3)", $(customerUDF3), "U", operUDF3, "A")
  @Build_WildCard ("upper(CMUDF4)", "$(V_CRSCR4)", $(customerUDF4), "U", operUDF4, "A")
  @Build_WildCard ("upper(CMUDF5)", "$(V_CRSCR5)", $(customerUDF5), "U", operUDF5, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
