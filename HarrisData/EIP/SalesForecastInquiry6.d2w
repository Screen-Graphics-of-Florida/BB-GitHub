%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "WildCard.icl"


%Define {
  page_title              = "Sales Forecast Inquiry Where Used"
  d2wName                 = "SalesForecastInquiry6.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plant=@dtw_rurlescseq(plant)&amp;item=@dtw_rurlescseq(item)&amp;ptyp=@dtw_rurlescseq(ptyp)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                 if (editNum(document.Search.srchType, 3, 0) &&
                     editNum(document.Search.srchYear, 4, 0))
                     return true;
                  }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "SALESFORECASTINQUIRY6")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(distinctSQL, "FFFTYP||FFREFN||FFYEAR", distinctSQL)
                      @dtw_concat(stmtSQL, "Select Distinct FFFTYP, FFREFN, FFYEAR, FFPLT, FFITEM,  FTSDAT, FTEDAT, FTFCLD, FTFCLDU, FTACTF", stmtSQL)
                      @dtw_concat(fileSQL, " HDMFD2 ", fileSQL)
                      @dtw_concat(fileSQL, " join HDMFDF on FFFTYP=FTFTYP and FFREFN=FTREFN and FFYEAR=FTYEAR ", fileSQL)
                      @dtw_concat(selectSQL, " FFPLT=$(plant) and FFITEM='$(item)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64) profileHandle,
                                   CHAR(2)   dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      <a href="$(homeURL)$(cGIPath)$(d2wName)/ENTRY$(d2wVarBase)&amp;formatToPrint=Y" target=_blank>$(formatPrintDesc)</a>
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      @RtvFldDesc("PLPLNT='$(plant)'", "HDPLNT", "PLNAME", plantDescription)
      @RtvFldDesc("IMITEM='$(item)'", "HDIMST", "IMIMDS", itemDescription)

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST name="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr"> Type</th>
                      <th class="colhdr"> Reference</th>
                      <th class="colhdr"> Year</th>
                      <th class="colhdr"> Description</th>
                  </tr>
                  <tr><td><input type="text" class="inputnum" name="srchType" size="3"
 maxlength="3">
                          <input type="hidden" name="operType" value="=">
                      </td>
                      <td><input type="text" class="inputalph" name="srchReference" size="8" maxlength="8">
                          <input type="hidden" name="operReference" value="LIKE">
                      </td>
                      <td><input type="text" class="inputnum" name="srchYear" size="4" maxlength="4">
                          <input type="hidden" name="operYear" value="=">
                      </td>
                      <td><input type="text" class="inputalph" name="srchDesc" size="30" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchType.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")

          <tr>
              @OrderBy_Sort("FFFTYP", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Type" title="Sequence By Type, Reference, Year"> Type</a></th>
              @OrderBy_Sort("FTFCLDU", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Description"> Description</a></th>
              @OrderBy_Sort("FFREFN", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Reference" title="Sequence By Reference, Type, Year"> Reference</a></th>
              @OrderBy_Sort("FFYEAR", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Year" title="Sequence By Year, Type, Reference"> Year</a></th>
              @OrderBy_Sort("FTSDAT", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=StartDate" title="Sequence By Start Date, End Date"> Start<br>Date</a></th>
              @OrderBy_Sort("FTEDAT", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=EndDate" title="Sequence By End Date"> End<br>Date</a></th>
              @OrderBy_Sort("FTACTF", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Active" title="Sequence By Active Forcast Flag, Type, Reference, Year"> Active<br>Forecast</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Date_ISO(V_FTSDAT, "H", F_FTSDAT)
              @Format_Date_ISO(V_FTEDAT, "H", F_FTEDAT)

              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_FFFTYP)</td>
                  <td class="colalph">
                      %if (V_FFFTYP == "1")
                          <a href="$(homeURL)$(cGIPath)SalesForecastInquiryA.d2w/LOAD$(d2wVarBase)&amp;type=@dtw_rurlescseq(V_FFFTYP)&amp;reference=@dtw_rurlescseq(V_FFREFN) &amp;year=@dtw_rurlescseq(V_FFYEAR)" title="View Forecast">$(V_FTFCLD)</a>
                      %else
                          <a href="$(homeURL)$(cGIPath)SalesForecastInquiry3.d2w/ENTRY$(genericVarBase)&amp;type=@dtw_rurlescseq(V_FFFTYP)&amp;reference=@dtw_rurlescseq(V_FFREFN) &amp;year=@dtw_rurlescseq(V_FFYEAR)&amp;backHome=$(backHome)" title="View Selection">$(V_FTFCLD)</a>
                      %endif
                  </td>
                  <td class="colalph">$(V_FFREFN)</td>
                  <td class="colnmbr">$(V_FFYEAR)</td>
                  <td class="coldate">$(F_FTSDAT)</td>
                  <td class="coldate">$(F_FTEDAT)</td>
                  <td class="colcode">$(V_FTACTF)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"

  %if (formatToPrint == "Y")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else

      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "FFFTYP,FFREFN,FFYEAR")
          @DTW_ASSIGN(orderByDisplay, "Description")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Type")
      %if (orderBy == "FFFTYP,FFREFN,FFYEAR")
          @DTW_ASSIGN(orderBy, "FFFTYP DESC,FFREFN DESC,FFYEAR DESC")
          @DTW_ASSIGN(orderByDisplay, "Type (descending), Reference (descending), Year (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FFFTYP,FFREFN,FFYEAR")
          @DTW_ASSIGN(orderByDisplay, "Type, Reference, Year")
      %endif
  %elif (sequence == "Description")
      %if (orderBy == "FTFCLDU")
          @DTW_ASSIGN(orderBy, "FTFCLDU DESC")
          @DTW_ASSIGN(orderByDisplay, "Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FTFCLDU")
          @DTW_ASSIGN(orderByDisplay, "Description")
      %endif
  %elif (sequence == "Reference")
      %if (orderBy == "FFREFN,FFFTYP,FFYEAR")
          @DTW_ASSIGN(orderBy, "FFREFN DESC,FFFTYP DESC,FFYEAR DESC")
          @DTW_ASSIGN(orderByDisplay, "Reference (descending), Type (descending), Year (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FFREFN,FFFTYP,FFYEAR")
          @DTW_ASSIGN(orderByDisplay, "Reference, Type, Year")
      %endif
  %elif (sequence == "Year")
      %if (orderBy == "FFYEAR,FFFTYP,FFREFN")
          @DTW_ASSIGN(orderBy, "FFYEAR DESC,FFFTYP DESC,FFREFN DESC")
          @DTW_ASSIGN(orderByDisplay, "Year (descending), Type (descending), Reference (descending")
      %else
          @DTW_ASSIGN(orderBy, "FFYEAR,FFFTYP,FFREFN")
          @DTW_ASSIGN(orderByDisplay, "Year, Type, Reference")
      %endif
  %elif (sequence == "StartDate")
      %if (orderBy == "FTSDAT,FTEDAT")
          @DTW_ASSIGN(orderBy, "FTSDAT DESC,FTEDAT DESC")
          @DTW_ASSIGN(orderByDisplay, "Start Date (descending), End Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FTSDAT,FTEDAT")
          @DTW_ASSIGN(orderByDisplay, "Start Date, End Date")
      %endif
  %elif (sequence == "EndDate")
      %if (orderBy == "FTEDAT,FTSDAT")
          @DTW_ASSIGN(orderBy, "FTEDAT DESC,FTSDAT DESC")
          @DTW_ASSIGN(orderByDisplay, "End Date (descending), Start Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FTEDAT,FTSDAT")
          @DTW_ASSIGN(orderByDisplay, "End Date, Start Date")
      %endif
  %elif (sequence == "Active")
      %if (orderBy == "FTACTF,FFFTYP,FFREFN,FFYEAR")
          @DTW_ASSIGN(orderBy, "FTACTF DESC,FFFTYP DESC,FFREFN DESC,FFYEAR DESC")
          @DTW_ASSIGN(orderByDisplay, "Active (descending), Type (descending), Reference (descending), Year (descending")
      %else
          @DTW_ASSIGN(orderBy, "FTACTF,FFFTYP,FFREFN,FFYEAR")
          @DTW_ASSIGN(orderByDisplay, "Active, Type, Reference, Year")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("FFFTYP", "Type", $(srchType), "", operType, "N")
  @Build_WildCard ("FFREFN", "Reference", $(srchReference), "U", operReference, "A")
  @Build_WildCard ("FFYEAR", "Year", $(srchYear), "", operYear, "N")
  @Build_WildCard ("FTFCLDU", "Description", $(srchDesc), "U", operDesc, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
