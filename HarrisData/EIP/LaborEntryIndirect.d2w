%INCLUDE "$(baseVar)"
%INCLUDE "EdtVar.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "ETControl$(dataBaseID).icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Labor Entry Indirect/Downtime"
  d2wName                 = "LaborEntryIndirect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;touchScreen=Y"
  altVarBaseT             = "$(altVarBase)&amp;touchScreen=Y"
  currentURL              = "$(d2wName)/REPORT$(d2wVarBase)"
  programName             = "HETLBE"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  lastTran                = ""
  V_PLT                   = ""
  V_DATE                  = ""
  sec_01                  = ""
  sec_02                  = ""
  sec_03                  = ""
  sec_04                  = ""
  sec_05                  = ""
  sec_06                  = ""
  sec_07                  = ""
  sec_08                  = ""
  sec_09                  = ""
  sec_10                  = ""
  sec_11                  = ""
  sec_12                  = ""
  sec_13                  = ""
  sec_14                  = ""
  sec_15                  = ""
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  @dtw_assign(timeOutM, "0")
  %if (sfdTimeOut > "0")
      @dtw_multiply(sfdTimeOut, "1000", timeOutM)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.code.value =="" ||
                      document.Chg.deptNumber.value =="" ||
                      document.Chg.workcenterNumber.value ==""
                      %if (sec_01 == "Y" && V_TAALRT == "Y")
                          || document.Chg.transDate.value ==""
                          || document.Chg.transTime.value ==""
                      %endif
                      )
                     {alert("$(reqFieldError)"); return false;}
                  %if (sec_01 == "Y" && V_TAALRT == "Y")
                      if (editNum(document.Chg.transDate, 6, 0) &&
                          editdate(document.Chg.transDate) &&
                          %if (V_TADSSF == "Y")
                              editNum(document.Chg.transTime, 6, 0)
                          %else
                              editNum(document.Chg.transTime, 4, 0)
                          %endif
                      )
                  %endif
                  return true;
              }
              %INCLUDE "DateEdit.icl"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "KeyboardFunctionsTS.icl"
              %INCLUDE "ShowHideSelCriteria.icl"
              function setTrans(transCode) {
                 document.Chg.currTrans.value = transCode;
                 if (validate(document.Chg)) {
                     document.Chg.submit();
                 }
              }

              %if (timeOutM > "0")
                  setTimeout("window.location.assign('$(homeURL)$(cGIPath)ShopFloorDispatch.d2w/REPORT?baseVar=@dtw_rurlescseq(baseVar)&portal=@dtw_rurlescseq(portal)&eID=@dtw_rurlescseq(eID)&touchScreen=Y');",$(timeOutM));
              %endif
              
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">

%{ Labor Entry Heading %}
                      @dtw_assign(stmtSQL, "")
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(stmtSQL, " From SIDCTW Where WDXHND='$(profileHandle)' ", stmtSQL)
                      @dtw_concat(stmtSQL, " Fetch First 1 Row Only With NC  @@endsql", stmtSQL)
                      @Labor_Entry_Header(profileHandle, dataBaseID, stmtSQL)

%{ Data Collection Codes %}
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select DFCODE, DFDESC, DFONOF ", stmtSQL)
                      @dtw_concat(fileSQL, " ETDCDF ", fileSQL)
                      @dtw_concat(selectSQL, " DFCODE in ('50','55') ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By DFONOF desc,DFCODE ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @dcCode_Query(profileHandle, dataBaseID, stmtSQL)
%{ Indirect Query %}
                      %INCLUDE "stmtSQLClear.icl"
                      %if (lastTran != "50")
                          %INCLUDE "AddRecordSQL.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                      %else                      
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(stmtSQL, " From SILOPW Where WOXHND='$(profileHandle)' ", stmtSQL)
                          @dtw_concat(stmtSQL, " Fetch First 1 Row Only With NC  @@endsql", stmtSQL)
                      %endif    
                      @Indirect_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
                  <td>
                      <ul class="toolbarTS">
                          <li class="optionTS"><a href="$(homeURL)$(cGIPath)ShopFloorDispatch.d2w/REPORT$(d2wVarBase)">&nbsp;<br>Back</a></li>
                      </ul>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Labor_Entry_Header (IN CHAR(64)    profileHandle,
				                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <tr><td><h1> $(page_title)</h1></td></tr>
      </table>

      %ROW{
          <table $(contentTable)>
              @dtw_assign(lastTran, V_WDLSTR)
              @dtw_assign(V_PLT, V_WDPLT)
              @dtw_assign(V_DATE, V_WDDATE)
              %if (V_DATE == "0")
                  @DateTodayCYMD(V_DATE)
              %endif
              @Format_Header("Plant", V_WDPNAM, V_WDPLT)
              %if (V_WDGRP == "0")
                  @Format_Header("Employee", $(V_WDENAM), "")
              %else
                  @Format_Header("Group", $(V_WDGDSC), "")
              %endif
              @RtvFldDesc("DFCODE='$(V_WDLSTR)'", "ETDCDF", "DFDESC", lastTranDesc)
              @Format_Header("Last Transaction", $(lastTranDesc), $(V_WDLSTR))
          </table>
       %}

      %INCLUDE "ConfMessageDisplay.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredFieldTS.icl"
  %}
%}


%FUNCTION(dtw_sql) dcCode_Query (IN CHAR(64)    profileHandle,
				                    CHAR(2)     dataBaseID,
                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(saveDFONOF, "")
      @dtw_assign(optionClass, "optionNTS")
      <table $(contentTable)>
          <tr>
          %ROW{
              %if (V_DFONOF != saveDFONOF)
                  %if (saveDFONOF != "")
                      </ul></td>
                      @dtw_assign(optionClass, "optionFTS")
                  %endif
                  <td><ul class="toolbarLTS">
                  @dtw_assign(saveDFONOF, V_DFONOF)
              %endif
              <li class="$(optionClass)"><a href="javascript:setTrans($(V_DFCODE))">&nbsp;<br>$(V_DFDESC)</a></li>
	      %}
 	  </ul></td></tr>
      </table>

      %INCLUDE "ErrorDisplay.icl"

  %}
%}

%FUNCTION(dtw_sql) Indirect_Query (IN CHAR(64)    profileHandle,
				                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
  
      <form class="formClass" method="post" name="Chg" action="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
          <input type="hidden" name="currTrans"> 
          <table $(contentTable)>  

          %ROW{
              %if (errFound != "")
                  @dtw_assign(focusField, "")
                  @EdtVarErr(profileHandle, typeValue, edtVar)
                  @ErrVarErr(profileHandle, typeError, errVar)
                  @DecatErr_Field("@@dtcl", "currTrans")         @dtw_assign(Err_TRAN, fieldValue)
                  %if (Err_TRAN == "")
                      @DecatErr_Field("@@code", "code")              @dtw_assign(Err_CODE, fieldValue)
                      @DecatErr_Field("@@dept", "deptNumber")        @dtw_assign(Err_DEPT, fieldValue)
                      @DecatErr_Field("@@date", "transDate")         @dtw_assign(Err_DATE, fieldValue)
                      @DecatErr_Field("@@time", "transTime")         @dtw_assign(Err_TIME, fieldValue)

                      @Decat_Field("@@code")   @dtw_assign(V_WODTRC,  fieldValue)
                      @Decat_Field("@@dept")   @dtw_assign(V_WODEPT,  fieldValue)
                      @Decat_Field("@@wc@@")   @dtw_assign(V_WOWC,    fieldValue)
                  %endif
                  @Decat_Field("@@date")   @dtw_assign(V_DATE,  fieldValue)
                  @Decat_Field("@@time")   @dtw_assign(V_TIME,  fieldValue)

                  @dtw_assign(errFound, "")
              %else
                  @DateInputFromCYMD(V_DATE)
                  @DTW_TIME(V_TIME)
                  @dtw_REPLACE(V_TIME, ":", "", V_TIME)
                  %while(@dtw_rlength(V_TIME) != "6") {@dtw_insert("0", V_TIME, V_TIME)%}
                  %if (V_TADSSF != "Y")
                      @dtw_assign(h, "@dtw_rsubstr(V_TIME, "1", "2")")
                      @dtw_assign(m, "@dtw_rsubstr(V_TIME, "3", "2")")
                      @dtw_assign(V_TIME, "@dtw_rconcat(h, m)")
                  %endif

                  @dtw_assign(focusField, "code")
              %endif

              @DspErrMsg(Err_TRAN)

              @RtvFldDesc("EVCODE='$(V_WODTRC)' AND EVTYPE='I' ", "HDEVNT", "EVDESC", codeDesc)
              @SetTextOvr(Err_CODE)
              <tr><td class="dsphdr"><span $(textOvr)>Indirect/Downtime Code</span></td>
                  <td class="input"><input class="input" id="code" onfocus="kbActive(this, 'keyboard');" name="code" type="text" value="$(V_WODTRC)" size="2" maxlength="2">  $(reqFieldChar)<a href="$(homeURL)$(phpPath)ETCodeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=code&amp;fldDesc=codeDesc&amp;fldType=I&amp;touchScreen=Y" onclick="$(searchWinVar)"> $(searchImage) </a> <input class="input" disabled name="codeDesc" value="$(codeDesc)"  type="text" size="30" maxlength="30"> </td>
              </tr>
              @DspErrMsg(Err_CODE)

              @dtw_assign(deptwcDesc, "")
              @RtvFldDesc("WCPLT=$(V_PLT) and WCDEPT='$(V_WODEPT)' and WCWC='$(V_WOWC)'", "HDMWCM", "WCDESC", deptwcDesc)
              @SetTextOvr(Err_DEPT)
              <tr><td class="dsphdr"><span $(textOvr)>Department/Work Center</span></td>
                  <td class="input"><input class="input" id="deptNumber" onfocus="kbActive(this, 'keyboard');" name="deptNumber" type="text" value="$(V_WODEPT)" size="5" maxlength="5"> / <input class="input" id="workcenterNumber" onfocus="kbActive(this, 'keyboard');" name="workcenterNumber" type="text" value="$(V_WOWC)" size="5" maxlength="5"> $(reqFieldChar) <a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBaseT)&amp;forPlant=$(V_PLT)&amp;docName=Chg&amp;flddept=deptNumber&amp;fldWC=workcenterNumber&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input class="input" disabled name="WCDesc" value="$(deptwcDesc)"  type="text" size="30" maxlength="30">
                  </td>
              </tr>
              @DspErrMsg(Err_DEPT)

              @SetTextOvr(Err_DATE)
              <tr><td class="dsphdr"><span $(textOvr)>Date</span></td>
                  %if (sec_01 == "Y" && V_TAALRT == "Y")
                      <td class="input"><input class="input" id="transDate" onfocus="kbActive(this, 'dtpDiv');" name="transDate" type="text" value="$(V_DATE)" size="5" maxlength="6"> $(reqFieldChar)</td>
                  %else
                      @dtw_assign(F_DATE, V_DATE)
                      @DateToCYMD(F_DATE)
                      @Format_Date(F_DATE, "H", F_DATE)
                      <td class="dspnmbr"><input class="input" name="transDate" type="hidden" value="$(V_DATE)">$(F_DATE)</td>
                  %endif
                  <td>&nbsp;</td>
              </tr>
              @DspErrMsg(Err_DATE)

              @SetTextOvr(Err_TIME)
              <tr><td class="dsphdr"><span $(textOvr)>Time</span></td>
                  %if (sec_01 == "Y" && V_TAALRT == "Y")
                      @dtw_assign(transTimeMax, "6")
                      %if (V_TADSSF != "Y")
                          @dtw_assign(transTimeMax, "4")
                      %endif
                      <td class="input"><input class="input" id="transTime" onfocus="kbActive(this, 'numericKeyboard');" name="transTime" type="text" value="$(V_TIME)" size="5" maxlength="$(transTimeMax)"> $(reqFieldChar)</td>
                  %else
                      @dtw_assign(F_TIME, V_TIME)
                      %if (V_TADSSF == "Y")
                          @EditHrsMinSec(F_TIME)
                      %else
                          @EditHrsMin(F_TIME)
                      %endif
                      <td class="dspnmbr"><input class="input" name="transTime" type="hidden" value="$(V_TIME)">$(F_TIME)</td>
                  %endif
              </tr>
              @DspErrMsg(Err_TIME)

	      %}

          </table>
          %INCLUDE "KeyboardTS.icl"
                    
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
          
          
      </form>

      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}


%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HETLBE_W.PGM %}
%}

%HTML(BUILD) {
  %INCLUDE "setLibraryList.icl"

  @dtw_assign(edtVar, "")
  @Concat_Field("@@subr", "SrFillInd")
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, errFound, edtVar, errVar)
    %if (errFound == "X")
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)EmployeeSignOn.d2w/REPORT$(d2wVarBase)">
  %else
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)">
  %endif
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  
  @dtw_mUPPERCASE(code)
  @dtw_mUPPERCASE(deptNumber)
  @dtw_mUPPERCASE(workcenterNumber)
  
  @dtw_assign(transDate,    @dtw_rstrip(transDate))
  @dtw_assign(transTime,    @dtw_rstrip(transTime))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@subr", "SrEditI")
  @Concat_Field("@@dtcl", currTrans)
  @Concat_Field("@@code", code)
  @Concat_Field("@@dept", deptNumber)
  @Concat_Field("@@wc@@", workcenterNumber)
  @Concat_Field("@@date", transDate)
  @Concat_Field("@@time", transTime)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, errFound, edtVar, errVar)

  %if (errFound == "" || errFound == "C")
      @DecatErr_Field("@@cmsg", "confMessage")
      @dtw_assign(confMessage, fieldValue)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ShopFloorDispatch.d2w/BUILD$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (errFound == "X")
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)EmployeeSignOn.d2w/REPORT$(d2wVarBase)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}