%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Ship Via Maintenance"
  d2wName                 = "ShipViaMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;shipVia=@dtw_rurlescseq(shipVia)&amp;shipViaDesc=@dtw_rurlescseq(shipViaDesc)&amp;maintenanceCode=D"
  programName             = "HPOSVU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "4"
%}

%MACRO_FUNCTION Build_Seq_Select (IN CHAR(20) sortName,
                                     CHAR(2)  sortValue)
{
  <td class="inputalph">
      <select name="$(sortName)">
          <option value="0">
          @dtw_assign(cnt, "1")
          %while(cnt <= sortSeqMax){
              %if (cnt == sortValue)
                  <option value="$(cnt)" SELECTED>$(cnt)
              %else
                  <option value="$(cnt)">$(cnt)
              %endif
              @dtw_add(cnt, "1", cnt)
          %}
      </select>
  </td>
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.shipVia.value =="" ||
                      document.Chg.shipViaDesc.value =="")
                      {alert("$(reqFieldError)"); return false;}
                  return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "SHIPVIAMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From HDSHPV left join HDSVTR on TVSVSV=SVSVSV ", stmtSQL)
                          @dtw_concat(stmtSQL, "Where SVSVSV='$(shipVia)'", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=171")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" NAME="Chg" METHOD=POST ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "shipVia")
                      %else
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @dtw_assign(focusField, "")
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@svsv", "shipVia")      @dtw_assign(Err_SVSVSV, fieldValue)
                          @DecatErr_Field("@@svds", "shipViaDesc")  @dtw_assign(Err_SVSVDS, fieldValue)
                          @DecatErr_Field("@@casv", "carShipVia")   @dtw_assign(Err_TVCASV, fieldValue)
                          @DecatErr_Field("@@scac", "alphacode")    @dtw_assign(Err_SVSCAC, fieldValue)
                          @DecatErr_Field("@@bolr", "bolr")         @dtw_assign(Err_SVBOLR, fieldValue)
                          @DecatErr_Field("@@trby", "trackBy")      @dtw_assign(Err_TVTRBY, fieldValue)
                          @DecatErr_Field("@@dsrf", "dftSeqRef")    @dtw_assign(Err_TVDSRF, fieldValue)
                          @DecatErr_Field("@@dsiv", "dftSeqInv")    @dtw_assign(Err_TVDSIV, fieldValue)
                          @DecatErr_Field("@@dsor", "dftSeqOrd")    @dtw_assign(Err_TVDSOR, fieldValue)
                          @DecatErr_Field("@@dsst", "dftSeqShp")    @dtw_assign(Err_TVDSST, fieldValue)
                          @DecatErr_Field("@@lzer", "leadZeros")    @dtw_assign(Err_TVLZER, fieldValue)
                          @DecatErr_Field("@@sepc", "separator")    @dtw_assign(Err_TVSEPC, fieldValue)
                          @DecatErr_Field("@@acrq", "acctReq")      @dtw_assign(Err_TVACRQ, fieldValue)
                          @DecatErr_Field("@@turl", "turl")         @dtw_assign(Err_TVTURL, fieldValue)
                      %endif

                      @Decat_Field("@@svsv")   @dtw_assign(V_SVSVSV, fieldValue)
                      @Decat_Field("@@svds")   @dtw_assign(V_SVSVDS, fieldValue)
                      @Decat_Field("@@casv")   @dtw_assign(V_TVCASV, fieldValue)
                      @Decat_Field("@@scac")   @dtw_assign(V_SVSCAC, fieldValue)
                      @Decat_Field("@@bolr")   @dtw_assign(V_SVBOLR, fieldValue)
                      @Decat_Field("@@trby")   @dtw_assign(V_TVTRBY, fieldValue)
                      @Decat_Field("@@dsrf")   @dtw_assign(V_TVDSRF, fieldValue)
                      @Decat_Field("@@dsiv")   @dtw_assign(V_TVDSIV, fieldValue)
                      @Decat_Field("@@dsor")   @dtw_assign(V_TVDSOR, fieldValue)
                      @Decat_Field("@@dsst")   @dtw_assign(V_TVDSST, fieldValue)
                      @Decat_Field("@@lzer")   @dtw_assign(V_TVLZER, fieldValue)
                      @Decat_Field("@@sepc")   @dtw_assign(V_TVSEPC, fieldValue)
                      @Decat_Field("@@acrq")   @dtw_assign(V_TVACRQ, fieldValue)
                      @Decat_Field("@@turl")   @dtw_assign(V_TVTURL, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(V_SVBOLR, "N")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "shipVia")
                      @dtw_assign(V_SVSVSV,  "")
                  %else
                      @dtw_assign(focusField, "shipViaDesc")
                  %endif

                  @SetTextOvr(Err_SVSVSV)
                  <tr><td class="dsphdr"><span $(textOvr)>Ship Via</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="shipVia" type="text" value="$(V_SVSVSV)" size="2" maxlength="2"> $(reqFieldChar) </td>
                      %else
                          <td class="inputalph"><input name="shipVia" type="hidden" value="$(V_SVSVSV)" size="2" maxlength="2">$(V_SVSVSV)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_SVSVSV)

                  @SetTextOvr(Err_SVSVDS)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="shipViaDesc" type="text" value="$(V_SVSVDS)" size="15" maxlength="15"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_SVSVDS)
    			
                  @SetTextOvr(Err_TVCASV)
                  <tr>
                      @RtvFldDesc("SVSVSV='$(V_TVCASV)'", "HDSHPV", "SVSVDS", fieldDesc)
                      <td class="dsphdr"><span $(textOvr)>Carrier Ship Via</span></td>
                      <td class="inputnmbr"><input name="carShipVia" type="text" value="$(V_TVCASV)" size="3" maxlength="2"><a href="$(homeURL)$(phpPath)ShipViaSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=carShipVia&amp;fldDesc=carShipViaDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="carShipViaDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_TVCASV)

                  @SetTextOvr(Err_SVSCAC)
                  <tr><td class="dsphdr"><span $(textOvr)>Standard Carrier Alpha Code</span></td>
                      <td class="inputalph"><input type="text" name="alphacode" value="$(V_SVSCAC)" size="3" maxlength="4"></td>
                  </tr>
                  @DspErrMsg(Err_SVSCAC)

                  @SetTextOvr(Err_SVBOLR)
                  <tr><td class="dsphdr"><span $(textOvr)>Bill Of Lading Required</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_SVBOLR) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "bolr", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_SVBOLR)

                  @SetTextOvr(Err_TVACRQ)
                  <tr><td class="dsphdr"><span $(textOvr)>Account Required</span></td>
                      @dtw_tb_rows(yn03Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn03Table, x, "1") != V_TVACRQ) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn03Table, "acctReq", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_TVACRQ)
    			
                  @RtvFldDesc("FLTYPE='TRACKBY' and FLVALU='$(V_TVTRBY)'", "SYFLAG", "FLDESC", trackByDesc)
                  @SetTextOvr(Err_TVTRBY)
                  <tr><td class="dsphdr"><span $(textOvr)>Track By</span></td>
                      <td class="inputalph"><input name="trackBy" type="text" value="$(V_TVTRBY)" size="3" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=TRACKBY&amp;flagSrchHdr=@dtw_rurlescseq("Track By")&amp;docName=Chg&amp;fldName=trackBy&amp;fldDesc=trackByDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="trackByDesc" value="$(trackByDesc)" type="text" size="30" disabled></td>
                  </tr>
                  @DspErrMsg(Err_TVTRBY)

                  @SetTextOvr(Err_TVTURL)
                  <tr><td class="dsphdr"><span $(textOvr)>Tracking URL</span></td>
                      <td class="inputalph"><input type="text" name="trackingURL" value="$(V_TVTURL)" size="400" maxlength="3000"></td>
                  </tr>
                  @DspErrMsg(Err_TVTURL)
          </table>

          <fieldset class="legendBody">
              <legend class="legendTitle">Reference Tracking Default</legend>
              <table $(contentTable)>
                      <tr><td class="copr">Use the Sequence Number to select fields and combine together to build a Reference Tracking Number. <br>
                                           If Leading Zeros is 'Y', each selected field will be filled with leading zeros up to its field size. <br>
                                           If a Separator field is entered, it will be defaulted between selected fields.
                          </td>
                      </tr>
              </table>
              <table $(contentTable)>
                      <tr><td>&nbsp;</td><td class="colhdr">Sequence<br>Number</td></tr>

                      @SetTextOvr(Err_TVDSRF)
                      <tr><td class="dsphdr"><span $(textOvr)>Reference Number</span></td>
                          @Build_Seq_Select("dftSeqRef", "$(V_TVDSRF)")
                      </tr>
                      @DspErrMsg(Err_TVDSRF)

                      @SetTextOvr(Err_TVDSIV)
                      <tr><td class="dsphdr"><span $(textOvr)>Invoice Number</span></td>
                          @Build_Seq_Select("dftSeqInv", "$(V_TVDSIV)")
                      </tr>
                      @DspErrMsg(Err_TVDSIV)

                      @SetTextOvr(Err_TVDSOR)
                      <tr><td class="dsphdr"><span $(textOvr)>Order Number</span></td>
                          @Build_Seq_Select("dftSeqOrd", "$(V_TVDSOR)")
                      </tr>
                      @DspErrMsg(Err_TVDSOR)

                      @SetTextOvr(Err_TVDSST)
                      <tr><td class="dsphdr"><span $(textOvr)>Ship-To Number</span></td>
                          @Build_Seq_Select("dftSeqShp", "$(V_TVDSST)")
                      </tr>
                      @DspErrMsg(Err_TVDSST)

                      @SetTextOvr(Err_TVLZER)
                      <tr><td class="dsphdr"><span $(textOvr)>Leading Zeros</span></td>
                          @dtw_tb_rows(yn02Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn02Table, x, "1") != V_TVLZER) && (x < maxRows))
                              {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(yn02Table, "leadZeros", "2", "1", "N", "", x, "1")</td>
                      </tr>
                      @DspErrMsg(Err_TVLZER)
        			
                      @SetTextOvr(Err_TVSEPC)
                      <tr><td class="dsphdr"><span $(textOvr)>Separator</span></td>
                          <td class="inputalph"><input type="text" name="separator" value="$(V_TVSEPC)" size="2" maxlength="1"></td>
                      </tr>
                      @DspErrMsg(Err_TVSEPC)
              </table>
          </fieldset>
          %}	

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HPOSVU_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn02Table)
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn03Table)
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(shipVia)
  @dtw_mUPPERCASE(carShipVia)
  @dtw_mUPPERCASE(alphacode)
  @dtw_mUPPERCASE(bolr)
  @dtw_mUPPERCASE(trackBy)
  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@svsv", shipVia)
  @Concat_Field("@@svds", shipViaDesc)
  @Concat_Field("@@casv", carShipVia)
  @Concat_Field("@@scac", alphacode)
  @Concat_Field("@@bolr", bolr)
  @Concat_Field("@@trby", trackBy)
  @Concat_Field("@@dsrf", dftSeqRef)
  @Concat_Field("@@dsiv", dftSeqInv)
  @Concat_Field("@@dsor", dftSeqOrd)
  @Concat_Field("@@dsst", dftSeqShp)
  @Concat_Field("@@lzer", leadZeros)
  @Concat_Field("@@sepc", separator)
  @Concat_Field("@@acrq", acctReq)
  @Concat_Field("@@turl", trackingURL)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(shipViaDesc), $(shipVia), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@svsv", "shipVia")
          @Format_ConfMsg_Desc("", $(shipViaDesc), $(shipVia), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=171&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;shipVia=@dtw_rurlescseq(shipVia)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}