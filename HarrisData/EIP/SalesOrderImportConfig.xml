<?xml version="1.0" encoding="utf-8"?>

<sales_order_import>
    <processing>
        <key_column></key_column>  <!-- Groups rows to an order -->
        <import_total_column></import_total_column> <!-- if defined and found in the csv, any variance between the calculated total and the import total to Special Charges -->
        <accept_prices>true</accept_prices> <!-- (true/false) if true and the Selling Price column (O1SLPR) is mapped that price will be retained as a price override -->
        <log_transactions>true</log_transactions>  <!-- (true/false) if true, a <csv>.log file will be created and displayed on the Sales Order Import page -->
        <address_match>false</address_match> <!-- (true/false) if true and customer number not provided, search for using address 1, city and state -->
        <phone_match>false</phone_match> <!-- (true/false) if true and a customer number was not found based on address, check using phone number -->
        <copy_default_customer>false</copy_default_customer> <!-- (true/false) if true and a customer is not found, copy the defaults->customer and update with the address_columns->ship_to information -->
        <use_customer_item>false</use_customer_item> <!-- (true/false) if true and item number is not found and ship-to customer was found, check for item using the customer item number-->
        <uppercase_alpha>false</uppercase_alpha> <!-- (true/false) if true, all character values imported will be converted to uppercase -->
    </processing>

    <defaults>
        <customer></customer> <!-- if a customer number was not found based on address/phone (if used), use as ship-to customer -->
        <non_stock_item></non_stock_item> <!-- if item number was not found, use this item's values to create a non-stock item -->
        <order_type></order_type>
        <hold_code>
            <order></order>  <!-- If defined, always set the Order Hold Code to this value -->
            <error></error>  <!-- If defined and any errors occur, set the Order Hold Code to this value -->
        </hold_code>
        <required_date_offset></required_date_offset>  <!-- If the header required date is not provided, the offset will be applied to the current date -->
    </defaults>

    <email>
        <import_column></import_column>
        <update_customer>false</update_customer> <!-- (true/false) if true and Customer/Fax (HDVCFM) not found for a document set to true, create it -->
        <documents>
            <acknowledgment>false</acknowledgment> <!-- (true/false) if true and email import column defined, add the email to the Acknowledgment -->
            <invoice>false</invoice>               <!-- (true/false) if true and email import column defined, add the email to the Invoice -->
            <pick_ticket>false</pick_ticket>       <!-- (true/false) if true and email import column defined, add the email to the Pick Ticket -->
            <packing_list>false</packing_list>     <!-- (true/false) if true and email import column defined, add the email to the Packing List -->
        </documents>
    </email>

    <address_columns>
        <bill_to>
            <H1BLTO></H1BLTO>            <!-- Bill-To Number (7N) -->
            <name></name>                <!-- Name (26A) -->
            <address_1></address_1>      <!-- Address 1 (26A) -->
            <address_2></address_2>      <!-- Address 2 (26A) -->
            <address_3></address_3>      <!-- Address 3 (19A) -->
            <city></city>                <!-- City (26A) -->
            <state></state>              <!-- State (2A) -->
            <zip_code></zip_code>        <!-- Zip Code (13A) -->
            <phone_number></phone_number><!-- Phone Number (11N) -->
        </bill_to>
        <ship_to>
            <H1SHTO></H1SHTO>            <!-- Ship-To Number (7N) -->
            <name></name>                <!-- Name (26A) -->
            <address_1></address_1>      <!-- Address 1 (26A) -->
            <address_2></address_2>      <!-- Address 2 (26A) -->
            <address_3></address_3>      <!-- Address 3 (19A) -->
            <city></city>                <!-- City (26A) -->
            <state></state>              <!-- State (2A) -->
            <zip_code></zip_code>        <!-- Zip Code (13A) -->
            <phone_number></phone_number><!-- Phone Number (11N) -->
        </ship_to>
        <drop_ship>
            <H1DSHP></H1DSHP>            <!-- Drop Ship Number (7N) -->
            <name></name>                <!-- Name (26A) -->
            <address_1></address_1>      <!-- Address 1 (26A) -->
            <address_2></address_2>      <!-- Address 2 (26A) -->
            <address_3></address_3>      <!-- Address 3 (19A) -->
            <city></city>                <!-- City (26A) -->
            <state></state>              <!-- State (2A) -->
            <zip_code></zip_code>        <!-- Zip Code (13A) -->
            <phone_number></phone_number><!-- Phone Number (11N) -->
        </drop_ship>
    </address_columns>

    <header_columns><!-- OEHDWK -->
        <!-- An optional <default_value></default_value> element can be added within a column element -->
        <H1ORTY><!-- Order Type (1A) -->
            <import_column></import_column>
        </H1ORTY>
        <H1CTRM><!-- Terms Code (2A) -->
            <import_column></import_column>
        </H1CTRM>
        <H1FRT><!-- Freight Amount (9,2) -->
            <import_column></import_column>
        </H1FRT>
        <H1CHRG><!-- Special Charge Amount (9,2) -->
            <import_column></import_column>
        </H1CHRG>
        <H1LOC><!-- Location Number (3N) -->
            <import_column></import_column>
        </H1LOC>
        <H1BDTE><!-- Order Date (MMDDYY) -->
            <import_column></import_column>
            <format></format><!-- defines the format of the column -->
        </H1BDTE>
        <H1RQDT><!-- Required Date (MMDDYY) -->
            <import_column></import_column>
            <format></format><!-- defines the format of the column -->
        </H1RQDT>
        <H1DTE2><!-- User Date 2 (MMDDYY) -->
            <import_column></import_column>
            <format></format><!-- defines the format of the column -->
        </H1DTE2>
        <H1DTE3><!-- User Date 3 (MMDDYY) -->
            <import_column></import_column>
            <format></format><!-- defines the format of the column -->
        </H1DTE3>
        <H1DTE4><!-- User Date 4 (MMDDYY) -->
            <import_column></import_column>
            <format></format><!-- defines the format of the column -->
        </H1DTE4>
        <H1ATTN><!-- Attention (22A) -->
            <import_column></import_column>
        </H1ATTN>
        <H1ORRF><!-- Reference Number (22A) -->
            <import_column></import_column>
        </H1ORRF>
        <H1STOR><!-- Store Number (20A) -->
            <import_column></import_column>
        </H1STOR>
        <H1UCA1><!-- User-Defined Customer Alpha 1 (2A) -->
            <import_column></import_column>
        </H1UCA1>
        <H1UCA2><!-- User-Defined Customer Alpha 2 (2A) -->
            <import_column></import_column>
        </H1UCA2>
        <H1UCA3><!-- User-Defined Customer Alpha 3 (2A) -->
            <import_column></import_column>
        </H1UCA3>
        <H1UCA4><!-- User-Defined Customer Alpha 4 (2A) -->
            <import_column></import_column>
        </H1UCA4>
        <H1UCA5><!-- User-Defined Customer Alpha 5 (2A) -->
            <import_column></import_column>
        </H1UCA5>
        <H1UDF1><!-- User-Defined Alpha 1 (15A) -->
            <import_column></import_column>
        </H1UDF1>
        <H1UDF2><!-- User-Defined Alpha 2 (15A) -->
            <import_column></import_column>
        </H1UDF2>
        <H1UDF3><!-- User-Defined Alpha 3 (15A) -->
            <import_column></import_column>
        </H1UDF3>
        <H1UDF4><!-- User-Defined Alpha 4 (15A) -->
            <import_column></import_column>
        </H1UDF4>
        <H1UDF5><!-- User-Defined Alpha 5 (15A) -->
            <import_column></import_column>
        </H1UDF5>
        <H1UDF6><!-- User-Defined Alpha 6 (30A) -->
            <import_column></import_column>
        </H1UDF6>
        <H1UDF7><!-- User-Defined Alpha 7 (30A) -->
            <import_column></import_column>
        </H1UDF7>
        <H1UDF8><!-- User-Defined Alpha 8 (30A) -->
            <import_column></import_column>
        </H1UDF8>
        <H1UDF9><!-- User-Defined Alpha 9 (30A) -->
            <import_column></import_column>
        </H1UDF9>
        <H1UDF0><!-- User-Defined Alpha 10 (30A) -->
            <import_column></import_column>
        </H1UDF0>
    </header_columns>

    <detail_columns><!-- OEDTWK -->
        <!-- An optional <default_value></default_value> element can be added within a column element -->
        <O1RQDT><!-- Required Date (MMDDYY) -->
            <import_column></import_column>
            <format>date_time_format</format><!-- defines the format for a date/time column -->
        </O1RQDT>
        <O1ITEM><!-- Item Number (15A) -->
            <import_column></import_column>
        </O1ITEM>
        <O1IMDS><!-- Item Description (30A) -->
            <import_column></import_column>
        </O1IMDS>
        <O1ORCS><!-- Customer Item Number (30A) -->
            <import_column></import_column>
        </O1ORCS>
        <O1PCLS><!-- Product Class (4A) -->
            <import_column></import_column>
        </O1PCLS>
        <O1WH><!-- Warehouse Number (3N) -->
            <import_column></import_column>
        </O1WH>
        <O1QORD><!-- Order Quantity (9,4) -->
            <import_column></import_column>
        </O1QORD>
        <O1SLPR><!-- Selling Price (8,5) -->
            <import_column></import_column>
        </O1SLPR>
        <O1TAXC><!-- Taxable Y/N (1A) -->
            <import_column></import_column>
        </O1TAXC>
        <O1UDF1><!-- User-Defined Alpha 1 (15A) -->
            <import_column></import_column>
        </O1UDF1>
        <O1UDF2><!-- User-Defined Alpha 2 (15A) -->
            <import_column></import_column>
        </O1UDF2>
        <O1UDF3><!-- User-Defined Alpha 3 (15A) -->
            <import_column></import_column>
        </O1UDF3>
        <O1UDF4><!-- User-Defined Alpha 4 (15A) -->
            <import_column></import_column>
        </O1UDF4>
        <O1UDF5><!-- User-Defined Alpha 5 (15A) -->
            <import_column></import_column>
        </O1UDF5>
        <O1UDF6><!-- User-Defined Alpha 6 (30A) -->
            <import_column></import_column>
        </O1UDF6>
        <O1UDF7><!-- User-Defined Alpha 7 (30A) -->
            <import_column></import_column>
        </O1UDF7>
        <O1UDF8><!-- User-Defined Alpha 8 (30A) -->
            <import_column></import_column>
        </O1UDF8>
        <O1UDF9><!-- User-Defined Alpha 9 (30A) -->
            <import_column></import_column>
        </O1UDF9>
        <O1UDF0><!-- User-Defined Alpha 10 (30A) -->
            <import_column></import_column>
        </O1UDF0>
        <O1UDN1><!-- User-Defined Numeric 1 (8,5) -->
            <import_column></import_column>
        </O1UDN1>
        <O1UDN2><!-- User-Defined Numeric 2 (8,5) -->
            <import_column></import_column>
        </O1UDN2>
        <O1UDN3><!-- User-Defined Numeric 3 (8,5) -->
            <import_column></import_column>
        </O1UDN3>
        <O1UDN4><!-- User-Defined Numeric 4 (8,5) -->
            <import_column></import_column>
        </O1UDN4>
        <O1UDN5><!-- User-Defined Numeric 5 (8,5) -->
            <import_column></import_column>
        </O1UDN5>
    </detail_columns>

</sales_order_import>
