               %else
                  <tr><td> <input name="am6" type="hidden" value="$(V_CKD06)"> </td></tr>
               %endif

               %if (V_CKDN07 != "0")
                  @SetTextOvr(Err_CKDN07)
                  @RtvFldDesc("HVDDNO=$(V_CKDN07)", "HRDEDM", "HVLDSC", HVLDSC)
