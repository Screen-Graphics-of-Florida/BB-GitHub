                  <tr class="$(rowClass)">
                      <td class="colnmbr"><input name="dn7" type="hidden" value=$(V_CKDN07) size="3" maxlength="3"><span $(textOvr)>$(V_CKDN07)</span></td>
	   	       <td class="colalph">$(HVLDSC)</td>
                      <td class="inputnmbr"><input name="am7" type="text" value="$(V_CKD07)" size=9 maxlength="8"></td>
