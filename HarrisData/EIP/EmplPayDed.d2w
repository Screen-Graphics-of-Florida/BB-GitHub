               %else
                  <tr><td> <input name="am8" type="hidden" value="$(V_CKD08)"> </td></tr>
               %endif

               %if (V_CKDN09 != "0")
                  @SetTextOvr(Err_CKDN09)
                  @RtvFldDesc("HVDDNO=$(V_CKDN09)", "HRDEDM", "HVLDSC", HVLDSC)
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colnmbr"><input name="dn9" type="hidden" value=$(V_CKDN09) size="3" maxlength="3"><span $(textOvr)>$(V_CKDN09)</span></td>
	               <td class="colalph">$(HVLDSC)</td>
                      <td class="inputnmbr"><input name="am9" type="text" value="$(V_CKD09)" size=9 maxlength="8"></td>
