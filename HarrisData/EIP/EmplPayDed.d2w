               %if (V_CKDN08 != "0")
                  @SetTextOvr(Err_CKDN08)
                  @RtvFldDesc("HVDDNO=$(V_CKDN08)", "HRDEDM", "HVLDSC", HVLDSC)
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colnmbr"><input name="dn8" type="hidden" value=$(V_CKDN08) size="3" maxlength="3"><span $(textOvr)>$(V_CKDN08)</span></td>
	               <td class="colalph">$(HVLDSC)</td>
                      <td class="inputnmbr"><input name="am8" type="text" value="$(V_CKD08)" size=9 maxlength="8"></td>
                          @dtw_tb_rows(yn01Table, maxRows)
