%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64) profileHandle,
                                               INOUT CHAR(2) dataBaseID,
                                               INOUT CHAR(1) maintenanceCode,
                                               INOUT CHAR(1) errFound,
                                               INOUT CHAR(32000) edtVar,
                                               INOUT CHAR(32000) errVar)

 {%EXEC {HPRPAY_W.PGM %}
%}

%HTML(DEDUCTIONS) {
      %INCLUDE "setLibraryList.icl"
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %if (sec_02 == "N" || sec_05 == "N")
          %INCLUDE "ProgSecurityError.icl"
      %else
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
      %endif
%}
%HTML(UPDATE) {
  %INCLUDE "setLibraryList.icl"
  @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
  @Set_SQL(stmtSQL)
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(dn1,@dtw_rstrip(dn1))
  @dtw_assign(dn2,@dtw_rstrip(dn2))
  @dtw_assign(dn3,@dtw_rstrip(dn3))
  @dtw_assign(dn4,@dtw_rstrip(dn4))
  @dtw_assign(dn5,@dtw_rstrip(dn5))
  @dtw_assign(dn6,@dtw_rstrip(dn6))
  @dtw_assign(dn7,@dtw_rstrip(dn7))
  @dtw_assign(dn8,@dtw_rstrip(dn8))
  @dtw_assign(dn9,@dtw_rstrip(dn9))
  @dtw_assign(dn10,@dtw_rstrip(dn10))
  @dtw_assign(dn11,@dtw_rstrip(dn11))
  @dtw_assign(dn12,@dtw_rstrip(dn12))
  @dtw_assign(dn13,@dtw_rstrip(dn13))
  @dtw_assign(dn14,@dtw_rstrip(dn14))
  @dtw_assign(dn15,@dtw_rstrip(dn15))
  @dtw_assign(dn16,@dtw_rstrip(dn16))
  @dtw_assign(dn17,@dtw_rstrip(dn17))
  @dtw_assign(dn18,@dtw_rstrip(dn18))
  @dtw_assign(dn19,@dtw_rstrip(dn19))
  @dtw_assign(dn20,@dtw_rstrip(dn20))

  @dtw_assign(am1,@dtw_rstrip(am1))
  @dtw_assign(am2,@dtw_rstrip(am2))
  @dtw_assign(am3,@dtw_rstrip(am3))
  @dtw_assign(am4,@dtw_rstrip(am4))
  @dtw_assign(am5,@dtw_rstrip(am5))
  @dtw_assign(am6,@dtw_rstrip(am6))
  @dtw_assign(am7,@dtw_rstrip(am7))
  @dtw_assign(am8,@dtw_rstrip(am8))
  @dtw_assign(am9,@dtw_rstrip(am9))
  @dtw_assign(am10,@dtw_rstrip(am10))
  @dtw_assign(am11,@dtw_rstrip(am11))
  @dtw_assign(am12,@dtw_rstrip(am12))
  @dtw_assign(am13,@dtw_rstrip(am13))
  @dtw_assign(am14,@dtw_rstrip(am14))
  @dtw_assign(am15,@dtw_rstrip(am15))
  @dtw_assign(am16,@dtw_rstrip(am16))
  @dtw_assign(am17,@dtw_rstrip(am17))
  @dtw_assign(am18,@dtw_rstrip(am18))
  @dtw_assign(am19,@dtw_rstrip(am19))
  @dtw_assign(am20,@dtw_rstrip(am20))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@call", caller)
  @Concat_Field("@@comp", prCompany)
  @Concat_Field("@@facl", prFacility)
  @Concat_Field("@@empl", prEmployee)
  @Concat_Field("@@type", prCKTYPE)
  @Concat_Field("@@sepc", prCKSEPC)
  @Concat_Field("@@rccd", "H")
  %if (dn1 != "0")
    @Concat_Field("@@dn1@", dn1)
    @Concat_Field("@@am1@", am1)
    @Concat_Field("@@de1@", de1)
  %endif
  %if (dn2 != "0")
    @Concat_Field("@@dn2@", dn2)
    @Concat_Field("@@am2@", am2)
    @Concat_Field("@@de2@", de2)
  %endif
  %if (dn3 != "0")
    @Concat_Field("@@dn3@", dn3)
    @Concat_Field("@@am3@", am3)
    @Concat_Field("@@de3@", de3)
  %endif
  %if (dn4 != "0")
    @Concat_Field("@@dn4@", dn4)
    @Concat_Field("@@am4@", am4)
    @Concat_Field("@@de4@", de4)
  %endif
  %if (dn5 != "0")
    @Concat_Field("@@dn5@", dn5)
    @Concat_Field("@@am5@", am5)
    @Concat_Field("@@de5@", de5)
  %endif
  %if (dn6 != "0")
    @Concat_Field("@@dn6@", dn6)
    @Concat_Field("@@am6@", am6)
    @Concat_Field("@@de6@", de6)
  %endif
  %if (dn7 != "0")
    @Concat_Field("@@dn7@", dn7)
    @Concat_Field("@@am7@", am7)
    @Concat_Field("@@de7@", de7)
  %endif
  %if (dn8 != "0")
    @Concat_Field("@@dn8@", dn8)
    @Concat_Field("@@am8@", am8)
    @Concat_Field("@@de8@", de8)
  %endif
  %if (dn9 != "0")
    @Concat_Field("@@dn9@", dn9)
    @Concat_Field("@@am9@", am9)
    @Concat_Field("@@de9@", de9)
  %endif
  %if (dn10 != "0")
    @Concat_Field("@@dn10", dn10)
    @Concat_Field("@@am10", am10)
    @Concat_Field("@@de10", de10)
  %endif
  %if (dn11 != "0")
    @Concat_Field("@@dn11", dn11)
    @Concat_Field("@@am11", am11)
    @Concat_Field("@@de11", de11)
  %endif
  %if (dn12 != "0")
    @Concat_Field("@@dn12", dn12)
    @Concat_Field("@@am12", am12)
    @Concat_Field("@@de12", de12)
  %endif
  %if (dn13 != "0")
    @Concat_Field("@@dn13", dn13)
    @Concat_Field("@@am13", am13)
    @Concat_Field("@@de13", de13)
  %endif
  %if (dn14 != "0")
    @Concat_Field("@@dn14", dn14)
    @Concat_Field("@@am14", am14)
    @Concat_Field("@@de14", de14)
  %endif
  %if (dn15 != "0")
    @Concat_Field("@@dn15", dn15)
    @Concat_Field("@@am15", am15)
    @Concat_Field("@@de15", de15)
  %endif
  %if (dn16 != "0")
    @Concat_Field("@@dn16", dn16)
    @Concat_Field("@@am16", am16)
    @Concat_Field("@@de16", de16)
  %endif
  %if (dn17 != "0")
    @Concat_Field("@@dn17", dn17)
    @Concat_Field("@@am17", am17)
    @Concat_Field("@@de17", de17)
  %endif
  %if (dn18 != "0")
    @Concat_Field("@@dn18", dn18)
    @Concat_Field("@@am18", am18)
    @Concat_Field("@@de18", de18)
  %endif
  %if (dn19 != "0")
    @Concat_Field("@@dn19", dn19)
    @Concat_Field("@@am19", am19)
    @Concat_Field("@@de19", de19)
  %endif
  %if (dn20 != "0")
    @Concat_Field("@@dn20", dn20)
    @Concat_Field("@@am20", am20)
    @Concat_Field("@@de20", de20)
  %endif
  @Concat_Field("@@tstp", timeStamp)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
    %if (maintenanceCode == "A")
    @Decat_Field("@@sepc")   @dtw_assign(prCKSEPC, fieldValue)
    %endif
    @Format_ConfMsg_Desc(maintenanceCode, "Sep Ck", $(prCKSEPC), "Check Type", $(checkType), "", "", confMessage)
    %if (fromD2w == "")
        <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)emplpaytran.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
    %else
        <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
    %endif
  %else
    @EdtVarErr(profileHandle, typeValue, edtVar)
    @ErrVarErr(profileHandle, typeError, errVar)
    <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/DEDUCTIONS$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}