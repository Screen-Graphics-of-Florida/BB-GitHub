%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "Employee.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "ynFlagTable.icl"

%Define {
  page_title 	           = "Employee Pay Transaction Entry"
  d2wName                 = "EmplPayDed.d2w"
  d2wVarBase              = "$(genericVarBase)$(employeeVarBase)&amp;prCKTYPE=@dtw_rurlescseq(prCKTYPE)&amp;prCKSEPC=@dtw_rurlescseq(prCKSEPC)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "99"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  programName             = "HPRSBE"
  caller                  = "ded       "
  rowIndexNext	           = "1"
  totalPages	           = "0"	
  showError               = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
  @dtw_replace(workURL, "@@prCKTYPE", "@dtw_rurlescseq(prCKTYPE)", "1", "a", workURL)
  @dtw_replace(workURL, "@@prCKSEPC", "@dtw_rurlescseq(prCKSEPC)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(applicationID, "PR")
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
          <html>
              <head>
	           %INCLUDE "$(headInclude)"
                  @dtw_assign(formName, "Chg")
                  <script type="text/javascript">
                      %INCLUDE "Menu.js"
                      %INCLUDE "numedit.icl"
                      %INCLUDE "CheckEnterChg.icl"
                      function validate(chgForm) {
                      if (
                                editNum(document.Chg.am1, 5, 2)
                             && editNum(document.Chg.am2, 5, 2)
                             && editNum(document.Chg.am3, 5, 2)
                             && editNum(document.Chg.am4, 5, 2)
                             && editNum(document.Chg.am5, 5, 2)
                             && editNum(document.Chg.am6, 5, 2)
                             && editNum(document.Chg.am7, 5, 2)
                             && editNum(document.Chg.am8, 5, 2)
                             && editNum(document.Chg.am9, 5, 2)
                             && editNum(document.Chg.am10, 5, 2)
                             && editNum(document.Chg.am11, 5, 2)
                             && editNum(document.Chg.am12, 5, 2)
                             && editNum(document.Chg.am13, 5, 2)
                             && editNum(document.Chg.am14, 5, 2)
                             && editNum(document.Chg.am15, 5, 2)
                             && editNum(document.Chg.am16, 5, 2)
                             && editNum(document.Chg.am17, 5, 2)
                             && editNum(document.Chg.am18, 5, 2)
                             && editNum(document.Chg.am19, 5, 2)
                             && editNum(document.Chg.am20, 5, 2)
                         )
                      return true;
                  }
                  </script>
                  %INCLUDE "$(genericHead)"
              </head>
              <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
                  <!-- Start Of Banner Code -->
                  %INCLUDE "banner.icl"
                  <!-- End Of Banner Code -->
                  <table $(baseTable)>
                      <tr valign="top">
                          @dtw_assign(pageID, "EMPLPAYDED")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                          <td class="content">

                              @dtw_assign(stmtSQL, "")
                              @dtw_concat(stmtSQL, "SELECT * FROM PRCHCK", stmtSQL)
                              @dtw_concat(stmtSQL, " WHERE CKCOMP=$(prCompany) and CKFACL=$(prFacility) and CKEMPL=$(prEmployee) and CKTYPE='$(prCKTYPE)' and CKSEPC='$(prCKSEPC)'", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                          </td>
                      </tr>
                  </table>
                  <!-- Start Of Trailer Code -->
                  %INCLUDE "trailer.icl"
                  <!-- End Of Trailer Code -->
              </body>
          </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN  CHAR(64) profileHandle,
				     CHAR(2)   dataBaseID,
                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

   %REPORT{
      @In_Process(profileHandle, dataBaseID, INPROCESS)

      %if (INPROCESS != "Y")
          %INCLUDE "ErrorDisplay.icl"
      %endif
      %if (INPROCESS == "Y")
          <table $(contentTable)>
              <tr><td class="colalph"> %include "InProcessMessage.icl" </td></tr>
          </table>
      %endif
      @dtw_assign(sec_03, "N")
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
          <tr><td><h2> $(F_EmpName)</h2></td></tr>
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          %ROW {
              %if (errFound != "")
                  @dtw_assign(focusField, "")
                  @EdtVarErr(profileHandle, typeValue, edtVar)
                  @ErrVarErr(profileHandle, typeError, errVar)
                  @DecatErr_Field("@@type", "checktype")    @dtw_assign(Err_checktype, fieldValue)
                  @DecatErr_Field("@@dn01", "dn1")          @dtw_assign(Err_CKDN01, fieldValue)
                  @DecatErr_Field("@@dn02", "dn2")          @dtw_assign(Err_CKDN02, fieldValue)
                  @DecatErr_Field("@@dn03", "dn3")          @dtw_assign(Err_CKDN03, fieldValue)
                  @DecatErr_Field("@@dn04", "dn4")          @dtw_assign(Err_CKDN04, fieldValue)
                  @DecatErr_Field("@@dn05", "dn5")          @dtw_assign(Err_CKDN05, fieldValue)
                  @DecatErr_Field("@@dn06", "dn6")          @dtw_assign(Err_CKDN06, fieldValue)
                  @DecatErr_Field("@@dn07", "dn7")          @dtw_assign(Err_CKDN07, fieldValue)
                  @DecatErr_Field("@@dn08", "dn8")          @dtw_assign(Err_CKDN08, fieldValue)
                  @DecatErr_Field("@@dn09", "dn9")          @dtw_assign(Err_CKDN09, fieldValue)
                  @DecatErr_Field("@@dn10", "dn10")         @dtw_assign(Err_CKDN10, fieldValue)
                  @DecatErr_Field("@@dn11", "dn11")         @dtw_assign(Err_CKDN11, fieldValue)
                  @DecatErr_Field("@@dn12", "dn12")         @dtw_assign(Err_CKDN12, fieldValue)
                  @DecatErr_Field("@@dn13", "dn13")         @dtw_assign(Err_CKDN13, fieldValue)
                  @DecatErr_Field("@@dn14", "dn14")         @dtw_assign(Err_CKDN14, fieldValue)
                  @DecatErr_Field("@@dn15", "dn15")         @dtw_assign(Err_CKDN15, fieldValue)
                  @DecatErr_Field("@@dn16", "dn16")         @dtw_assign(Err_CKDN16, fieldValue)
                  @DecatErr_Field("@@dn17", "dn17")         @dtw_assign(Err_CKDN17, fieldValue)
                  @DecatErr_Field("@@dn18", "dn18")         @dtw_assign(Err_CKDN18, fieldValue)
                  @DecatErr_Field("@@dn19", "dn19")         @dtw_assign(Err_CKDN19, fieldValue)
                  @DecatErr_Field("@@dn20", "dn20")         @dtw_assign(Err_CKDN20, fieldValue)
                  @DecatErr_Field("@@tstp", "timeStamp")    @dtw_assign(Err_TSTP, fieldValue)

                  @Decat_Field("@@am1")   @dtw_assign(V_CKD01, fieldValue)
                  @Decat_Field("@@am2")   @dtw_assign(V_CKD02, fieldValue)
                  @Decat_Field("@@am3")   @dtw_assign(V_CKD03, fieldValue)
                  @Decat_Field("@@am4")   @dtw_assign(V_CKD04, fieldValue)
                  @Decat_Field("@@am5")   @dtw_assign(V_CKD05, fieldValue)

                  @Decat_Field("@@am6")   @dtw_assign(V_CKD06, fieldValue)
                  @Decat_Field("@@am7")   @dtw_assign(V_CKD07, fieldValue)
                  @Decat_Field("@@am8")   @dtw_assign(V_CKD08, fieldValue)
                  @Decat_Field("@@am9")   @dtw_assign(V_CKD09, fieldValue)
                  @Decat_Field("@@am10")  @dtw_assign(V_CKD10, fieldValue)

                  @Decat_Field("@@am11")  @dtw_assign(V_CKD11, fieldValue)
                  @Decat_Field("@@am12")  @dtw_assign(V_CKD12, fieldValue)
                  @Decat_Field("@@am13")  @dtw_assign(V_CKD13, fieldValue)
                  @Decat_Field("@@am14")  @dtw_assign(V_CKD14, fieldValue)
                  @Decat_Field("@@am15")  @dtw_assign(V_CKD15, fieldValue)

                  @Decat_Field("@@am16")  @dtw_assign(V_CKD16, fieldValue)
                  @Decat_Field("@@am17")  @dtw_assign(V_CKD17, fieldValue)
                  @Decat_Field("@@am18")  @dtw_assign(V_CKD18, fieldValue)
                  @Decat_Field("@@am19")  @dtw_assign(V_CKD19, fieldValue)
                  @Decat_Field("@@am20")  @dtw_assign(V_CKD20, fieldValue)

                  @Decat_Field("@@de1")  @dtw_assign(V_CKSC01, fieldValue)
                  @Decat_Field("@@de2")  @dtw_assign(V_CKSC02, fieldValue)
                  @Decat_Field("@@de3")  @dtw_assign(V_CKSC03, fieldValue)
                  @Decat_Field("@@de4")  @dtw_assign(V_CKSC04, fieldValue)
                  @Decat_Field("@@de5")  @dtw_assign(V_CKSC05, fieldValue)

                  @Decat_Field("@@de6")  @dtw_assign(V_CKSC06, fieldValue)
                  @Decat_Field("@@de7")  @dtw_assign(V_CKSC07, fieldValue)
                  @Decat_Field("@@de8")  @dtw_assign(V_CKSC08, fieldValue)
                  @Decat_Field("@@de9")  @dtw_assign(V_CKSC09, fieldValue)
                  @Decat_Field("@@de10")  @dtw_assign(V_CKSC10, fieldValue)

                  @Decat_Field("@@de11")  @dtw_assign(V_CKSC11, fieldValue)
                  @Decat_Field("@@de12")  @dtw_assign(V_CKSC12, fieldValue)
                  @Decat_Field("@@de13")  @dtw_assign(V_CKSC13, fieldValue)
                  @Decat_Field("@@de14")  @dtw_assign(V_CKSC14, fieldValue)
                  @Decat_Field("@@de15")  @dtw_assign(V_CKSC15, fieldValue)

                  @Decat_Field("@@de16")  @dtw_assign(V_CKSC16, fieldValue)
                  @Decat_Field("@@de17")  @dtw_assign(V_CKSC17, fieldValue)
                  @Decat_Field("@@de18")  @dtw_assign(V_CKSC18, fieldValue)
                  @Decat_Field("@@de19")  @dtw_assign(V_CKSC19, fieldValue)
                  @Decat_Field("@@de20")  @dtw_assign(V_CKSC20, fieldValue)
                  
                  @Decat_Field("@@tstp")  @dtw_assign(V_CKTSTP, fieldValue)

                  @dtw_assign(errFound, "")
              %else
                  @dtw_assign(focusField, "am1")

              %endif

              <table $(contentTable)>
                  %if (V_CKRCCD != "H")
                      <tr><td class="dsphdr">Check Number</td>
                          <td class="dspalph">$(V_CKCKNO)</td>
                      </tr>
                      @DateFromCYMD(V_CKCKDT)
                      <tr><td class="dsphdr">Check Date</td>
                          <td class="dspalph">$(V_CKCKDT)</td>
                      </tr>
                  %endif

                  %if (V_CKRCCD == "H")
                      @dtw_assign(checkType, "Regular")
                  %elif (V_CKRCCD == "V")
                      @dtw_assign(checkType, "Void")
                  %elif (V_CKRCCD == "M")
                      @dtw_assign(checkType, "Manual/History Adjustment")
                  %elif (V_CKRCCD == "4")
                      @dtw_assign(checkType, "Non Elective Contribution")
                  %endif

                  @SetTextOvr(Err_checktype)
                 <tr><td class="dsphdr"><span $(textOvr)>Check Type</span></td>
                     <td class="dspalph">$(checkType)</td>
                 </tr>
                 @DspErrMsg(Err_checktype)

                  %if (V_CKSEPC != "")
                      <tr><td class="dsphdr">Separate Check Code</td>
                          <td class="dspalph">$(V_CKSEPC)</td>
                      </tr>
                  %endif
                  
                  @SetTextOvr(Err_TSTP)
                 <tr><td class="dsphdr"><span $(textOvr)>.</span></td>
                     <td><input name="timeStamp" type="hidden" value="$(V_CKTSTP)"></td>
                 </tr>
                 @DspErrMsg(Err_TSTP)
                                   
              </table>

          <a name="deductions"></a>
          <fieldset class="legendBody">
          <legend class="legendTitle">Voluntary Deductions</legend>
          <table $(contentTable)>
               <tr>
		    <th class="colhdr">Deduction<br>Number</th>
		    <th class="colhdr">Description</th>
                   <th class="colhdr">Amount</th>
                   <th class="colhdr">Process</th>
   	        </tr>

               %if (V_CKDN01 != "0")
                  @SetTextOvr(Err_CKDN01)
                  @RtvFldDesc("HVDDNO=$(V_CKDN01)", "HRDEDM", "HVLDSC", HVLDSC)
                  %INCLUDE "SetRowClass.icl"
	   	   <tr class="$(rowClass)">
                      <td class="colnmbr"><input name="dn1" type="hidden" value=$(V_CKDN01) size="3" maxlength="3"><span $(textOvr)>$(V_CKDN01)</span></td>
	   	       <td class="colalph">$(HVLDSC)</td>
	   	       <td class="inputnmbr"><input name="am1" type="text" value="$(V_CKD01)" size=9 maxlength="8"></td>
                          @dtw_tb_rows(yn01Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_CKSC01) && (x < maxRows))
                           {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "de1", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_CKDN01)
               %else
                  <tr><td> <input name="am1" type="hidden" value="$(V_CKD01)"> </td></tr>
               %endif

               %if (V_CKDN02 != "0")
                  @SetTextOvr(Err_CKDN02)
                  @RtvFldDesc("HVDDNO=$(V_CKDN02)", "HRDEDM", "HVLDSC", HVLDSC)
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colnmbr"><input name="dn2" type="hidden" value=$(V_CKDN02) size="3" maxlength="3"><span $(textOvr)>$(V_CKDN02)</span></td>
	               <td class="colalph">$(HVLDSC)</td>
                      <td class="inputnmbr"><input name="am2" type="text" value="$(V_CKD02)" size=9 maxlength="8"></td>
                          @dtw_tb_rows(yn01Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_CKSC02) && (x < maxRows))
                           {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "de2", "2", "1", "N", "", x, "1")</td>
