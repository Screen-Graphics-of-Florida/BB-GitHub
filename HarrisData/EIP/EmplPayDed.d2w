               %else
                  <tr><td> <input name="am3" type="hidden" value="$(V_CKD03)"> </td></tr>
               %endif

               %if (V_CKDN04 != "0")
                  @SetTextOvr(Err_CKDN04)
                  @RtvFldDesc("HVDDNO=$(V_CKDN04)", "HRDEDM", "HVLDSC", HVLDSC)
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colnmbr"><input name="dn4" type="hidden" value=$(V_CKDN04) size="3" maxlength="3"><span $(textOvr)>$(V_CKDN04)</span></td>
	   	       <td class="colalph">$(HVLDSC)</td>
                      <td class="inputnmbr"><input name="am4" type="text" value="$(V_CKD04)" size=9 maxlength="8"></td>
                          @dtw_tb_rows(yn01Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_CKSC04) && (x < maxRows))
                           {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "de4", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_CKDN04)
               %else
                  <tr><td> <input name="am4" type="hidden" value="$(V_CKD04)"> </td></tr>
               %endif

               %if (V_CKDN05 != "0")
                  @SetTextOvr(Err_CKDN05)
                  @RtvFldDesc("HVDDNO=$(V_CKDN05)", "HRDEDM", "HVLDSC", HVLDSC)
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colnmbr"><input name="dn5" type="hidden" value=$(V_CKDN05) size="3" maxlength="3"><span $(textOvr)>$(V_CKDN05)</span></td>
	               <td class="colalph">$(HVLDSC)</td>
                      <td class="inputnmbr"><input name="am5" type="text" value="$(V_CKD05)" size=9 maxlength="8"></td>
                          @dtw_tb_rows(yn01Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_CKSC05) && (x < maxRows))
                           {@dtw_add(x, "1", x)%}
