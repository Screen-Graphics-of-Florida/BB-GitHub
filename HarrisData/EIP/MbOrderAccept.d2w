%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Mobile Order Accept"
  d2wName                 = "MbOrderAccept.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;customerCity=@dtw_rurlescseq(customerCity)&amp;customerState=@dtw_rurlescseq(customerState)&amp;customerWhs=@dtw_rurlescseq(customerWhs)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
  RPT_MAX_ROWS            = "1000"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "MbHead.icl"
          <script TYPE="text/javascript">
              function confirmCancel() {return confirm("Confirm Cancel Of Order")}
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "MbBanner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "SELECT OEHDWK.*,  ", stmtSQL)
                      @dtw_concat(stmtSQL, " (H1OTOT-H1FRT-H1STTA-H1CNTA-H1CTTA-H1LC1A-H1LC2A-H1LC3A-H1CHRG) as subTotal ", stmtSQL)
                      @dtw_concat(fileSQL, " OEHDWK ", fileSQL)
                      @dtw_concat(selectSQL, "H1OCTL=$(orderControlNumber) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By H1OCTL ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Mobile_Order_Accept(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "MbTrailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Mobile_Order_Accept (IN CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <tr>
              <td class="hdrdata"><h2>$(customerName)</h2>$(customerCity), $(customerState)</td>
              <td class="hdrdata">$(mbLogo)</td>
          </tr>
      </table>

      <table $(contentTable)>
          %ROW {

              <form class="formClass" NAME="Chg" METHOD=POST ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                  <table $(contentTable)>
            	   <tr><td class="dsphdr">PO:</td>
                          <td class="inputalph"><input name="refNumber" type="text" size="15" maxlength="22"></td>
                      </tr>

                      %if (V_subTotal != V_H1OTOT)
                          @Format_Nbr(V_subTotal, F_subTotal, "2", $(amtEditCode), "Y", "", "")
                          <tr class="$(rowClass)">
                              <td class="colnmbr">Subtotal</td>
                              <td class="colnmbr">$(F_subTotal)</td>
                          </tr>
                      %endif

                      %if (V_H1FRT>".00")
                          @Format_Nbr(V_H1FRT,  F_H1FRT,  "2", $(amtEditCode), "", "", "")
                          <tr class="$(rowClass)">
                              <td class="colnmbr">Freight Charge</td>
                              <td class="colnmbr">$(F_H1FRT)</td>
                          </tr>
                      %endif

                      %if (V_H1STTA>".00")
                          @Format_Nbr(V_H1STTA, F_H1STTA, "2", $(amtEditCode), "", "", "")
                          <tr class="$(rowClass)">
                              <td class="colnmbr">State Tax</td>
                              <td class="colnmbr">$(F_H1STTA)</td>
                          </tr>
                      %endif

                      %if (V_H1CNTA>".00")
                          @Format_Nbr(V_H1CNTA, F_H1CNTA, "2", $(amtEditCode), "", "", "")
                          <tr class="$(rowClass)">
                              <td class="colnmbr">County Tax</td>
                              <td class="colnmbr">$(F_H1CNTA)</td>
                          </tr>
                      %endif

                      %if (V_H1CTTA>".00")
                          @Format_Nbr(V_H1CTTA, F_H1CTTA, "2", $(amtEditCode), "", "", "")
                          <tr class="$(rowClass)">
                              <td class="colnmbr">City Tax</td>
                              <td class="colnmbr">$(F_H1CTTA)</td>
                          </tr>
                      %endif

                      %if (V_H1LC1A>".00")
                          @Format_Nbr(V_H1LC1A, F_H1LC1A, "2", $(amtEditCode), "", "", "")
                          <tr class="$(rowClass)">
                              <td class="colnmbr">Local 1 Tax</td>
                              <td class="colnmbr">$(F_H1LC1A)</td>
                          </tr>
                      %endif

                      %if (V_H1LC2A>".00")
                          @Format_Nbr(V_H1LC2A, F_H1LC2A, "2", $(amtEditCode), "", "", "")
                          <tr class="$(rowClass)">
                              <td class="colnmbr">Local 2 Tax</td>
                              <td class="colnmbr">$(F_H1LC2A)</td>
                          </tr>
                      %endif

                      %if (V_H1LC3A>".00")
                          @Format_Nbr(V_H1LC3A, F_H1LC3A, "2", $(amtEditCode), "", "", "")
                          <tr class="$(rowClass)">
                              <td class="colnmbr">Local 3 Tax</td>
                              <td class="colnmbr">$(F_H1LC3A)</td>
                          </tr>
                      %endif

                      %if (V_H1CHRG>".00")
                          @Format_Nbr(V_H1CHRG, F_H1CHRG, "2", $(amtEditCode), "", "", "")
                          <tr class="$(rowClass)">
                              <td class="colnmbr">Special Charge</td>
                              <td class="colnmbr">$(F_H1CHRG)</td>
                          </tr>
                      %endif

                      @Format_Nbr(V_H1OTOT, F_H1OTOT, "2", $(amtEditCode), "", "", "")
                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          <td class="colnmbr">Order Total</td>
                          <td class="colnmbr">$(F_H1OTOT)</td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Chg.refNumber.focus();
                  </script>
              </form>
          %}
      </table>
  <a href="$(homeURL)$(cGIPath)MbOrderReview.d2w/REPORT$(d2wVarBase)">$(mbOrderBack)</a>
  <a href="javascript:check(document.Chg)">$(mbOrderAccept)</a>
  <a onClick="return confirmCancel()" href="$(homeURL)$(cGIPath)$(d2wName)/CANCEL$(d2wVarBase)">$(mbOrderCancel)</a>
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HOEATO_M.PGM %}
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(maintenanceCode, "R")

  @dtw_assign(edtVar, "")
  @Concat_Field("@@octl", orderControlNumber)
  @Concat_Field("@@orrf", refNumber)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)">
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(maintenanceCode, "")
  @Process_Order (profileHandle, dataBaseID, orderControlNumber, orderNumber, maintenanceCode)
  @DTW_ASSIGN(confMessage, "Order Number $(orderNumber)")
  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)MbCustomer.d2w/REPORT$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
%}

%HTML(CANCEL) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(maintenanceCode, "D")
  @DTW_ASSIGN(confMessage, "Order Cancelled")
  @Process_Order (profileHandle, dataBaseID, orderControlNumber, orderNumber, maintenanceCode)
  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)MbCustomer.d2w/REPORT$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
%}
