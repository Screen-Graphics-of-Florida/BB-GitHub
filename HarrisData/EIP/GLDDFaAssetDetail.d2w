%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "G/L Drill Down Asset Detail"
  d2wName                 = "GLDDFaAssetDetail.d2w"
  d2wVarBase              = "$(genericVarBase)$(glDDVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;siteNumber=@dtw_rurlescseq(siteNumber)&amp;assetNumber=@dtw_rurlescseq(assetNumber)&amp;scheduleNumber=@dtw_rurlescseq(scheduleNumber)&amp;ddRptRef=@dtw_rurlescseq(ddRptRef)&amp;deprPeriod=@dtw_rurlescseq(deprPeriod)&amp;glJrnl=@dtw_rurlescseq(glJrnl)&amp;glPer=@dtw_rurlescseq(glPer)&amp;glDate=@dtw_rurlescseq(glDate)&amp;glJrnlSeq=@dtw_rurlescseq(glJrnlSeq)&amp;glJrnlRec=@dtw_rurlescseq(glJrnlRec)&amp;glDDSeq=@dtw_rurlescseq(glDDSeq)&amp;glDDAp=@dtw_rurlescseq(glDDAp)&amp;glDDFile=@dtw_rurlescseq(glDDFile)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "99"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(prtMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  backHome                = "glDDReport.d2w/REPORT"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @AssetUserView(profileHandle, dataBaseID, userPass, siteNumber, assetNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              %if (showMenu != "Y")
                  <link rel=stylesheet type="text/css" href="$(homeURL)$(homePath)$(GLDDStyleSheet)">
              %endif
              <script TYPE="text/javascript">
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "" && showMenu == "Y")
                          @dtw_assign(pageID, "GLDDFAASSETDETAIL")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          %{Asset %}
                              @dtw_assign(uv_SiteName, "GFSITE")
                              @dtw_assign(uv_PropertyTypeName, "GFPROP")
                              @dtw_assign(uv_FamilyCodeName, "GFFMCD")
                              %INCLUDE "UserView.icl"

                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_assign(appendUserView, "")
                              @dtw_assign(appendWildCard, "N")
                              @dtw_concat(stmtSQL, "SELECT GFSITE,GFASST,GFSCHD,Max(GFDESC) as GFDESC,Max(GFAQDT) as GFAQDT,Max(GFPROP) as GFPROP", stmtSQL)
                              @dtw_concat(fileSQL, " FAGLDD ", fileSQL)
                              @dtw_concat(selectSQL, " GFSITE=$(siteNumber) and GFASST=$(assetNumber) and GFSCHD=$(scheduleNumber) ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              @dtw_concat(stmtSQL, " GROUP BY GFSITE,GFASST,GFSCHD ", stmtSQL)
                              @dtw_concat(stmtSQL, " ORDER BY GFSITE,GFASST,GFSCHD ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              @AssetMaster_Query(profileHandle, dataBaseID, stmtSQL)

                          %{Drill Down Rows %}
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_assign(appendUserView, "")
                              @dtw_assign(appendWildCard, "")
                              @dtw_concat(stmtSQL, "SELECT FAGLDD.*, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(CHCHDS,' ') as CHCHDS, coalesce(CHCHDSU,' ') as CHCHDSU,", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(SMDESC,' ') as SMDESC ", stmtSQL)
                              @dtw_concat(fileSQL, " FAGLDD ", fileSQL)
                              @dtw_concat(fileSQL, " left join HDCHRT on CHACCT=GFACCT and CHSUB=GFSUB ", fileSQL)
                              @dtw_concat(fileSQL, " left join FASCHD on SMSCHD=GFSCHD ", fileSQL)
                              @dtw_concat(selectSQL, " GFSITE=$(siteNumber) and GFASST=$(assetNumber) ", selectSQL)
                              %if (ddRptRef != "")
                                  @dtw_concat(selectSQL, "  and  GFRPTS='$(ddRptRef)' ", selectSQL)
                              %endif
                              %if (deprPeriod != "")
                                  @dtw_concat(selectSQL, "  and  GFPER#=$(deprPeriod) ", selectSQL)
                              %endif
                              %INCLUDE "stmtSQLSelect.icl"
                              @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              @DrillDown_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) AssetMaster_Query (IN  CHAR(64) profileHandle,
                                          CHAR(2)   dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %if (backHome != "cofac.d2w/report" && backHome != "")
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(genericVarBase)$(glDDVarBase)&amp;backHome=@dtw_rurlescseq(backHome)" title="Back Home">$(portalHome)</a>
                      %endif
                      <a href="$(homeURL)$(cGIPath)$(d2wName)/ENTRY$(d2wVarBase)&amp;formatToPrint=Y" target=_blank>$(formatPrintDesc)</a>
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
	
      $(hrTagAttr)

      <table $(contentTable)>
          <tr>
              <th class="colhdr">Site</th>
              <th class="colhdr">Asset<br>Number</th>
              <th class="colhdr">Description</th>
              <th class="colhdr">Acquisition<br>Date</th>
              <th class="colhdr">Property<br>Type</th>
              <th class="colhdr">Begin<br>Depr<br>Date</th>
              <th class="colhdr">Life</th>
              <th class="colhdr">Schedule</th>
          </tr>

          %ROW{
              @RtvFldDesc("ASSITE=$(siteNumber) and ASASST=$(assetNumber) and ASSCHD=$(scheduleNumber)", "FAMSCH", "CHAR(ASBDDT)", V_ASBDDT)
              @RtvFldDesc("ASSITE=$(siteNumber) and ASASST=$(assetNumber) and ASSCHD=$(scheduleNumber)", "FAMSCH", "CHAR(ASLFYY)", V_ASLFYY)
              @RtvFldDesc("ASSITE=$(siteNumber) and ASASST=$(assetNumber) and ASSCHD=$(scheduleNumber)", "FAMSCH", "CHAR(ASLFMM)", V_ASLFMM)
              @RtvFldDesc("ACLOCN=$(siteNumber) ", "FASITE", "ACLONM", V_ACLONM)
              @RtvFldDesc("PTTYPE='$(V_GFPROP)' ", "FAPROP", "PTDESC", V_PTDESC)
              @RtvFldDesc("SMSCHD=$(scheduleNumber) ", "FASCHD", "SMDESC", V_SMDESC)
              @Format_Date(V_GFAQDT, "D", F_GFAQDT)
              @Format_Date(V_ASBDDT, "D", F_ASBDDT)

              <tr>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)FASiteInquiry.d2w/DISPLAY$(genericVarBase)&amp;siteNumber=@dtw_rurlescseq(V_GFSITE)" onclick="$(inquiryWinVar)" title="Site Quickview">$(V_ACLONM)</a></td>
                  <td class="colnmbr">$(V_GFASST)</td>
                  @RtvFldDesc("AMSITE=$(V_GFSITE) and AMASST=$(V_GFASST)", "FAMSTR", "Char(Count(*))", recordCount)
                  %if (recordCount>"0")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)FAAssetSelect.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;siteNumber=@dtw_rurlescseq(V_GFSITE)&amp;assetNumber=@dtw_rurlescseq(V_GFASST)&amp;scheduleNumber=@dtw_rurlescseq(V_GFSCHD)&amp;glJrnl=@dtw_rurlescseq(V_GFJRNL)&amp;glDDSeq=@dtw_rurlescseq(glDDSeq)" title="View Asset">$(V_GFDESC)</a></td>
                  %else
                      <td class="colnmbr">$(V_GFDESC)</td>
                  %endif
                  <td class="coldate">$(F_GFAQDT)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)FAPropertyInquiry.d2w/DISPLAY$(genericVarBase)&amp;propertyType=@dtw_rurlescseq(V_GFPROP)" onclick="$(inquiryWinVar)" title="Property Type Quickview">$(V_PTDESC)</a></td>
                  <td class="coldate">$(F_ASBDDT)</td>
                  <td class="colnmbr">$(V_ASLFYY)/$(V_ASLFMM)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)FAScheduleInquiry.d2w/DISPLAY$(genericVarBase)&amp;scheduleNumber=@dtw_rurlescseq(V_GFSCHD)" onclick="$(inquiryWinVar)" title="Schedule Quickview">$(V_SMDESC)</a></td>
              </tr>
          %}
      </table>
  %}
%}

%FUNCTION(dtw_sql) DrillDown_Query (IN  CHAR(64) profileHandle,
                                        CHAR(2)   dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              @OrderBy_Sort("GFAMT", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Amount" title="Sequence By Amount, Account, Depreciation Period, Transaction Type"> Amount</a></th>
              @OrderBy_Sort("GFCO", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Account" title="Sequence By Account, Depreciation Period, Transaction Type"> Account</a></th>
              @OrderBy_Sort("CHCHDSU", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=AcctDescr" title="Sequence By Description, Account, Depreciation Period, Transaction Type"> Description</a></th>
              @OrderBy_Sort("GFRPTS", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TransType" title="Sequence By Transaction Type, Account, Depreciation Period"> Trans<br>Type</a></th>
              @OrderBy_Sort("GFDPCD", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DeprMeth" title="Sequence By Depreciation Method, Account, Depreciation Period, Transaction Type"> Depr<br>Meth</a></th>
              @OrderBy_Sort("GFPER#", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DeprPeriod" title="Sequence By Depreciation Period, Account, Transaction Type">Depr<br>Period</a></th>
              @OrderBy_Sort("SMDESC", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Schedule" title="Sequence By Schedule, Account, Depreciation Period, Transaction Type">Schedule</a></th>
              @OrderBy_Sort("GFFPCD", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RetireCode" title="Sequence By Ret/Trf Code, Account, Depreciation Period, Transaction Type"> Ret/<br>Trf<br>Code</a></th>
              @OrderBy_Sort("GFRTPD", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TrfPeriod" title="Sequence By Ret/Trf Period, Account, Depreciation Period, Transaction Type"> Ret/<br>Trf<br>Period</a></th>
              @OrderBy_Sort("GFRRES", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RetireReason" title="Sequence By Retirement Reason, Account, Depreciation Period, Transaction Type"> Retirement<br>Reason</a></th>
              @OrderBy_Sort("GFTSIT", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TrfAsset" title="Sequence By Transfer From/To Asset, Account, Depreciation Period, Transaction Type">To/<br>From<br>Asset</a></th>
          </tr>

          %if (ddRptRef == "" && deprPeriod == "")
              @dtw_assign(svCo, "")
              @dtw_assign(svFac, "")
              @dtw_assign(svAcct, "")
              @dtw_assign(svSub, "")
              @dtw_assign(subTotal, "0")
          %endif

          %ROW {
              %INCLUDE "SetRowClass.icl"
              @Format_CoFac("$(V_GFCO)", "$(V_GFFAC)", "", F_CoFac)
              @Format_Acct("$(V_GFACCT)", "$(V_GFSUB)", "", F_AcctSub)
              @PeriodFromCYP(V_GFPER#)
              @PeriodFromCYP(V_GFRTPD)
              @Format_Nbr($(V_GFAMT), F_GFAMT, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr($(subTotal), F_subTotal, "2", $(amtEditCode), "Y", "", "")

              %if (ddRptRef == "" && deprPeriod == "")
                  %if (svCo=="" && svFac == "" && svAcct=="" && svSub == "")
                      @dtw_assign(svCo, V_GFCO)
                      @dtw_assign(svFac, V_GFFAC)
                      @dtw_assign(svAcct, V_GFACCT)
                      @dtw_assign(svSub, V_GFSUB)
                  %elif (V_GFACCT != svAcct || V_GFSUB != svSub)
                      @dtw_assign(svCo, V_GFCO)
                      @dtw_assign(svFac, V_GFFAC)
                      @dtw_assign(svAcct, V_GFACCT)
                      @dtw_assign(svSub, V_GFSUB)
                      <tr class="$(rowClass)">
                          <td class="colnmbr">$(F_subTotal)</td>
                          <td class="colalph">Account Total</td>
                          <td class="colnmbr"></td>
                          <td class="colalph"></td>
                          <td class="colalph"></td>
                          <td class="colalph"></td>
                          <td class="colalph"></td>
                          <td class="colalph"></td>
                          <td class="colalph"></td>
                          <td class="colalph"></td>
                          <td class="colalph"></td>
                      </tr>
                      @dtw_assign(subTotal, "0")
                      %INCLUDE "SetRowClass.icl"
                  %endif

                  @dtw_assign(subTotal, @dtw_radd(subTotal, $(V_GFAMT)))
              %endif
              	
              <tr class="$(rowClass)">
                  <td class="colnmbr">$(F_GFAMT)</td>
                  <td class="colnmbr">$(F_CoFac) $(F_AcctSub)</td>
                  <td class="colalph">$(V_CHCHDS)</td>
                  <td class="colcode">$(V_GFRPTS)</td>
                  <td class="colcode"><a href="$(homeURL)$(cGIPath)FADeprMethodInquiry.d2w/DISPLAY$(genericVarBase)&amp;deprMethod=@dtw_rurlescseq(V_GFDPCD)" onclick="$(inquiryWinVar)" title="Depreciation Method Quickview">$(V_GFDPCD)</a></td>
                  <td class="colnmbr">$(V_GFPER#)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)FAScheduleInquiry.d2w/DISPLAY$(genericVarBase)&amp;scheduleNumber=@dtw_rurlescseq(V_GFSCHD)" onclick="$(inquiryWinVar)" title="Schedule Quickview">$(V_SMDESC)</a></td>
                  %if (V_GFRPTS == "RET" || V_GFRPTS == "TRF" && V_GFTRFG == "F")
                      <td class="colcode">$(V_GFFPCD)</td>
                  %else
                      <td class="colcode"></td>
                  %endif

                  %if (V_GFRPTS == "RET" || V_GFRPTS == "TRF")
                      <td class="colnmbr">$(V_GFRTPD)</td>
                  %else
                      <td class="colcode"></td>
                  %endif

                  %if (V_GFRPTS == "RET")
                      <td class="colalph">$(V_GFRRES)</td>
                  %else
                      <td class="colcode"></td>
                  %endif

                  %if (V_GFRPTS == "TRF" && V_GFTRFG == "F")
                      <td class="colalph">To $(V_GFTSIT)-$(V_GFTAST)</td>
                  %elif (V_GFRPTS == "TRF" && V_GFTRFG == "T")
                      <td class="colalph">From $(V_GFTSIT)-$(V_GFTAST)</td>
                  %else
                      <td class="colcode"></td>
                  %endif
              </tr>
          %}
          %if (ddRptRef == "" && deprPeriod == "")
              %INCLUDE "SetRowClass.icl"
              @Format_Nbr($(subTotal), F_subTotal, "2", $(amtEditCode), "Y", "", "")
              <tr class="$(rowClass)">
                  <td class="colnmbr">$(F_subTotal)</td>
                  <td class="colalph">Account Total</td>
                  <td class="colnmbr"></td>
                  <td class="colalph"></td>
                  <td class="colalph"></td>
                  <td class="colalph"></td>
                  <td class="colalph"></td>
                  <td class="colalph"></td>
                  <td class="colalph"></td>
                  <td class="colalph"></td>
                  <td class="colalph"></td>
              </tr>
          %endif
      </table>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderByDisplay, "Account, Depreciation Period, Depreciation Method")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Amount")
      %if (orderBy == "GFAMT,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderBy, "GFAMT DESC,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderByDisplay, "Amount (descending), Account, Depreciation Period, Transaction Type")
      %else
          @DTW_ASSIGN(orderBy, "GFAMT,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderByDisplay, "Amount, Account, Depreciation Period, Transaction Type")
      %endif
  %elif (sequence == "Account")
      %if (orderBy == "GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderBy, "GFCO DESC,GFFAC DESC,GFACCT DESC,GFSUB DESC,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderByDisplay, "Account (descending), Depreciation Period, Transaction Type")
      %else
          @DTW_ASSIGN(orderBy, "GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderByDisplay, "Account, Depreciation Period, Transaction Type")
      %endif
  %elif (sequence == "AcctDescr")
      %if (orderBy == "CHCHDSU,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderBy, "CHCHDSU DESC,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Account, Depreciation Period, Transaction Type")
      %else
          @DTW_ASSIGN(orderBy, "CHCHDSU,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderByDisplay, "Description, Account, Depreciation Period, Transaction Type")
      %endif
  %elif (sequence == "TransType")
      %if (orderBy == "GFRPTS,GFCO,GFFAC,GFACCT,GFSUB,GFPER#")
          @DTW_ASSIGN(orderBy, "GFRPTS DESC,GFCO,GFFAC,GFACCT,GFSUB,GFPER#")
          @DTW_ASSIGN(orderByDisplay, "Transaction Type (descending), Account, Depreciation Period")
      %else
          @DTW_ASSIGN(orderBy, "GFRPTS,GFCO,GFFAC,GFACCT,GFSUB,GFPER#")
          @DTW_ASSIGN(orderByDisplay, "Transaction Type, Account, Depreciation Period")
      %endif
  %elif (sequence == "DeprMeth")
      %if (orderBy == "GFDPCD,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderBy, "GFDPCD DESC,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderByDisplay, "Depreciation Method (descending), Account, Depreciation Period, Transaction Type")
      %else
          @DTW_ASSIGN(orderBy, "GFDPCD,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderByDisplay, "Depreciation Method, Account, Depreciation Period, Transaction Type")
      %endif
  %elif (sequence == "DeprPeriod")
      %if (orderBy == "GFPER#,GFCO,GFFAC,GFACCT,GFSUB,GFRPTS")
          @DTW_ASSIGN(orderBy, "GFPER# DESC,GFCO,GFFAC,GFACCT,GFSUB,GFRPTS")
          @DTW_ASSIGN(orderByDisplay, "Depreciation Period (descending), Account, Transaction Type")
      %else
          @DTW_ASSIGN(orderBy, "GFPER#,GFCO,GFFAC,GFACCT,GFSUB,GFRPTS")
          @DTW_ASSIGN(orderByDisplay, "Depreciation Period, Account, Transaction Type")
      %endif
  %elif (sequence == "Schedule")
      %if (orderBy == "SMDESC,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderBy, "SMDESC DESC,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderByDisplay, "Schedule (descending), Account, Depreciation Period, Transaction Type")
      %else
          @DTW_ASSIGN(orderBy, "SMDESC,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderByDisplay, "Schedule, Account, Depreciation Period, Transaction Type")
      %endif
  %elif (sequence == "RetireCode")
      %if (orderBy == "GFFPCD Desc,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderBy, "GFFPCD,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderByDisplay, "Ret/Trf Code, Account, Depreciation Period, Transaction Type")
      %else
          @DTW_ASSIGN(orderBy, "GFFPCD Desc,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderByDisplay, "Ret/Trf Code (descending), Account, Depreciation Period, Transaction Type")
      %endif
  %elif (sequence == "TrfPeriod")
      %if (orderBy == "GFRTPD Desc,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderBy, "GFRTPD,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderByDisplay, "Ret/Trf Period, Account, Depreciation Period, Transaction Type")
      %else
          @DTW_ASSIGN(orderBy, "GFRTPD Desc,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderByDisplay, "Ret/Trf Period (descending), Account, Depreciation Period, Transaction Type")
      %endif
  %elif (sequence == "RetireReason")
      %if (orderBy == "GFRRES Desc,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderBy, "GFRRES,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderByDisplay, "Retirement Reason, Account, Depreciation Period, Transaction Type")
      %else
          @DTW_ASSIGN(orderBy, "GFRRES Desc,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderByDisplay, "Retirement Reason (descending), Account, Depreciation Period, Transaction Type")
      %endif
  %elif (sequence == "TrfAsset")
      %if (orderBy == "GFTSIT Desc,GFTAST Desc,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderBy, "GFTSIT,GFTAST,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderByDisplay, "Transfer From/To Asset, Account, Depreciation Period, Transaction Type")
      %else
          @DTW_ASSIGN(orderBy, "GFTSIT Desc,GFTAST Desc,GFCO,GFFAC,GFACCT,GFSUB,GFPER#,GFRPTS")
          @DTW_ASSIGN(orderByDisplay, "Transfer From/To Asset (descending), Account, Depreciation Period, Transaction Type")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
