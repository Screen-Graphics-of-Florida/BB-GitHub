%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "User"
  d2wName                 = "UserMaster.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HSYUSM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "USERMASTER")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "SELECT SYUSER.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(USEMAL) as USEMALU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(USNEWS) as USNEWSU ", stmtSQL)
                      @dtw_concat(fileSQL, " SYUSER ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, " USUSER<>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @User_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) User_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="20%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)UserMasterMaintain.d2w/MAINTAIN$(genericVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">User Profile</th>
                      <th class="colhdr">Role</th>
                      <th class="colhdr">Description</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchUser" size="10" maxlength="10">
                          <input type="hidden" name="operUser" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchRole" size="10" maxlength="10">
                          <input type="hidden" name="operRole" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchDesc" size="20" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchUser.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("USUSER", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=UserProfile" title="Sequence By User Profile"> User Profile</a></th>
              @OrderBy_Sort("USROLE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Role" title="Sequence By Role, User Profile"> Role</a></th>
              @OrderBy_Sort("USDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description, User Profile"> Description</a></th>
              @OrderBy_Sort("USEMALU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Email" title="Sequence By E-Mail Address, User Profile"> E-Mail Address</a></th>
              @OrderBy_Sort("USNEWSU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=News" title="Sequence By News Category URL, User Profile"> News Category URL</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(genericVarBase)&amp;user=@dtw_rurlescseq(V_USUSER)&amp;userDesc=@dtw_rurlescseq(V_USDESC)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_USDESC), $(V_USUSER), "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)UserMasterMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_04 == "Y")
                              <a href="$(homeURL)$(cGIPath)UserMasterMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)UserMasterMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_USUSER)</td>
                  <td class="colalph">$(V_USROLE)</td>
                  <td class="colalph">$(V_USDESC)</td>
                  <td class="colalph">$(V_USEMAL)</td>
                  <td class="colalph">$(V_USNEWS)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "SELECT SYUSER.*, ", stmtSQL)
  @dtw_concat(stmtSQL, " upper(USEMAL) as USEMALU, ", stmtSQL)
  @dtw_concat(stmtSQL, " upper(USNEWS) as USNEWSU ", stmtSQL)
  @dtw_concat(fileSQL, " SYUSER ", fileSQL)
  %if (wildCardSearch!="")
      @dtw_concat(selectSQL, " USUSER<>' ' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_Export_Query(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_Export_Query (IN CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("UserList")
          %ROW{
	       @XMLIDTag(V_USUSER, "User ID")
                  @XMLTag(V_USUSER, "UserProfile")
                  @XMLTag(V_USROLE, "Role")
                  @XMLTag(V_USDESC, "Description")
                  @XMLTag(V_USCUST, "Customer")
                  @XMLTag(V_USVEND, "Vendor")
                  @XMLTag(V_USSLSM, "Salesman")
                  @XMLTag(V_USCLCK, "Badge")
                  @XMLTag(V_USCATN, "Catalog")
                  @XMLTag(V_USNEWS, "NewsCategoryURL")
                  @XMLTag(V_USEMAL, "E-MailAddress")
                  @XMLTag(V_USFAX,  "Fax")
                  @XMLTag(V_USAASI, "AllowAccessToSecurityInquiry")
                  @XMLTag(V_USADOC, "AllowAccessToDocumentation")
                  @XMLTag(V_USMEDM, "Medium")
                  @XMLTag(V_USDPLT, "DefaultPlant")
              @XMLEndTag("User")
	   %}
      @XMLEndTag("UserList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "USDESCU")
          @DTW_ASSIGN(orderByDisplay, "Description")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit ()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "UserProfile")
      %if (orderBy == "USUSER")
          @DTW_ASSIGN(orderBy, "USUSER DESC")
          @DTW_ASSIGN(orderByDisplay, "User Profile (descending)")
      %else
          @DTW_ASSIGN(orderBy, "USUSER")
          @DTW_ASSIGN(orderByDisplay, "User Profile")
      %endif
  %elseif (sequence == "Role")
      %if (orderBy == "USROLE,USUSER")
          @DTW_ASSIGN(orderBy, "USROLE DESC,USUSER")
          @DTW_ASSIGN(orderByDisplay, "Role (descending), User Profile")
      %else
          @DTW_ASSIGN(orderBy, "USROLE,USUSER")
          @DTW_ASSIGN(orderByDisplay, "Role, User Profile")
      %endif
  %elseif (sequence == "Desc")
      %if (orderBy == "USDESCU,USUSER")
          @DTW_ASSIGN(orderBy, "USDESCU DESC,USUSER")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), User Profile")
      %else
          @DTW_ASSIGN(orderBy, "USDESCU,USUSER")
          @DTW_ASSIGN(orderByDisplay, "Description, User Profile")
      %endif
  %elseif (sequence == "News")
      %if (orderBy == "USNEWSU,USUSER")
          @DTW_ASSIGN(orderBy, "USNEWSU DESC,USUSER")
          @DTW_ASSIGN(orderByDisplay, "New Category URL (descending), User Profile")
      %else
          @DTW_ASSIGN(orderBy, "USNEWSU,USUSER")
          @DTW_ASSIGN(orderByDisplay, "New Category URL, User Profile")
      %endif
  %elseif (sequence == "Email")
      %if (orderBy == "USEMALU,USUSER")
          @DTW_ASSIGN(orderBy, "USEMALU DESC,USUSER")
          @DTW_ASSIGN(orderByDisplay, "E-Mail Address (descending), User Profile")
      %else
          @DTW_ASSIGN(orderBy, "USEMALU,USUSER")
          @DTW_ASSIGN(orderByDisplay, "E-Mail Address, User Profile")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchCust, 7, 0) &&
                      editNum(document.Search.srchVend, 7, 0) &&
                      editNum(document.Search.srchSlsm, 3, 0) &&
                      editNum(document.Search.srchPlant, 3, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "USERMASTERSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">User Profile</td>
                              @dtw_assign(operNbr, "operUser")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchUser" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Role</td>
                              @dtw_assign(operNbr, "operRole")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchRole" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchDesc" size="20" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Customer</td>
                              @dtw_assign(operNbr, "operCust")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchCust" size="7" maxlength="7"></td>
                          </tr>

                          <tr><td class="dsphdr">Vendor</td>
                              @dtw_assign(operNbr, "operVend")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchVend" size="7" maxlength="7"></td>
                          </tr>

                          <tr><td class="dsphdr">Salesman</td>
                              @dtw_assign(operNbr, "operSlsm")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchSlsm" size="3" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Default Plant</td>
                              @dtw_assign(operNbr, "operPlant")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchPlant" size="3" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Badge</td>
                              @dtw_assign(operNbr, "operBadge")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchBadge" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Catalog</td>
                              @dtw_assign(operNbr, "operCatalog")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchCatalog" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">News Category URL</td>
                              @dtw_assign(operNbr, "operNews")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchNews" size="30" maxlength="256"></td>
                          </tr>

                          <tr><td class="dsphdr">E-Mail Address</td>
                              @dtw_assign(operNbr, "operEmail")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchEmail" size="30" maxlength="256"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchUser.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("USUSER", "User Profile", $(srchUser), "U", operUser, "A")
  @Build_WildCard ("USROLE", "Role", $(srchRole), "U", operRole, "A")
  @Build_WildCard ("USDESCU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("USCUST", "Customer", $(srchCust), "", operCust, "N")
  @Build_WildCard ("USVEND", "Vendor", $(srchVend), "", operVend, "N")
  @Build_WildCard ("USSLSM", "Salesman", $(srchSlsm), "", operSlsm, "N")
  @Build_WildCard ("USDPLT", "Default Plant", $(srchPlant), "", operPlant, "N")
  @Build_WildCard ("USCLCK", "Badge", $(srchBadge), "U", operBadge, "A")
  @Build_WildCard ("USCATN", "Catalog", $(srchCatalog), "U", operCatalog, "A")
  @Build_WildCard ("upper(USNEWS)", "News Category URL", $(srchNews), "U", operNews, "A")
  @Build_WildCard ("upper(USEMAL)", "E-Mail Address", $(srchEmail), "U", operEmail, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
