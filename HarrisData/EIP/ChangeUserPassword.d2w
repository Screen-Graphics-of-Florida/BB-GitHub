%INCLUDE "$(baseVar)"
%INCLUDE "Menu.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Change User Password"
  d2wName                 = "ChangeUserPassword.d2w"
  d2wVarBase              = "$(genericVarBase)"
  DATABASE                = "*LOCAL"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%FUNCTION(dtw_directcall) Validate_New_Password(INOUT CHAR(10)  userProfile,
						       CHAR(10)  password,
				                       CHAR(2)   dataBaseID,
                                                      CHAR(64)  profileHandle,
                                                 OUT  CHAR(7)   messageData)
{%EXEC {HSYCUP_W.PGM %}  	
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"
  <html>
      <head>
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
               function editChg() {
                   if (document.signon.newPassword.value != document.signon.confirmPassword.value)
                       {alert("New Password and Confirm New Password must be the same value.");
                       return false;}
               }
          </script>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CHGUSRPASSWORD")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "PageTitle.icl"
                      %INCLUDE "ConfMessageDisplay.icl"

                      $(hrTagAttr)

                      <table>
                          <form class="formClass" NAME="signon" METHOD=POST ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Password$(d2wVarBase)">
                              <tr>
                                  <td class="dsphdr">User Profile: </td>
                                  <td class="inputalph"><input type="text"  name="userProfile" size="10" maxlength="10"></td>
                              </tr>

                              <tr>
                                  <td class="dsphdr">Password: </td>
                                  <td class="inputalph"><input type="password"  name="password" size="10" maxlength="10"></td>
                              </tr>

                                  <td>&nbsp;</td>
                                  <td><input TYPE=SUBMIT VALUE=" Submit "></td>
                          </form>
                      </table>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Password) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->

          @dtw_mUPPERCASE(userProfile, password, messageData)
          @Validate_New_Password(userProfile, password, dataBaseID, profileHandle, messageData)
          			
          %if (messageData != "")
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "CHGPASSWORD")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="error"> Errors occured in attempting to change password.</td>
                      <td class="error"> $(messageData)
                          %if (messageData == "CPF22E2")
                              Password not correct for user profile $(userProfile).
                          %elif (messageData == "CPF22E3")
                              Profile $(userProfile) disabled.
                          %elif (messageData == "CPF22E5")
                              Value for new password not allowed.
                          %elif (messageData == "CPD2356")
                              New password cannot be same as current.
                          %else
                              No Descripiton Found.
                          %endif
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->

          %else
              @retrieveUserRole(profileHandle, dataBaseID, userProfile, userCustomer, userVendor, userSalesman, userBadge, userCatalog, newsLink, profileName)
              %if (baseVar == "")
                   @dtw_assign(baseVar, "BaseConfiguration.icl")
              %endif
              <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)Welcome.d2w/WELCOME?newsLink=@dtw_rurlescseq(newsLink)&amp;profileName=@dtw_rurlescseq(profileName)&amp;baseVar=@dtw_rurlescseq(baseVar)&amp;eID=@dtw_rurlescseq(eID)">
          %endif
      </body>
  </html>
%}