%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Configuration Type"
  d2wName                 = "ConfigurationType.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;plantName=@dtw_rurlescseq(plantName)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPD022"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  plantNumber             = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @dtw_assign(userPass, "")
  %if (plantNumber > "0")
      @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %endif
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script type="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
                  %INCLUDE "CheckEnterSearch.icl"
                  %INCLUDE "NoFormValidate.icl"
               </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                          @dtw_assign(pageID, "CONFIGURATIONTYPE")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          @dtw_assign(uv_PlantName, "CYPLT")
                          %INCLUDE "userview.icl"

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, "Select CYPLT, CYCFGT, CYLDSC, ", stmtSQL)
                          @dtw_concat(stmtSQL, "upper(CYLDSC) as CYLDSCU " , stmtSQL)
                          %if (plantNumber == "")
                              @dtw_concat(stmtSQL, " , coalesce(PLNAME,' ') as PLNAME, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(upper(PLNAME),' ') as PLNAMEU ", stmtSQL)
                          %endif
                          @dtw_concat(fileSQL, " HDCFGT ", fileSQL)
                          %if (plantNumber == "")
                              @dtw_concat(fileSQL, " left join HDPLNT on CYPLT=PLPLNT ", fileSQL)
                          %endif
                          %if (wildCardSearch!="" || plantNumber>"0" || uv_Sql!="")
                              @dtw_concat(selectSQL, "CYCFGT>' ' ", selectSQL)
                          %endif
                          %if (plantNumber > "0")
                              @dtw_concat(selectSQL, " and CYPLT=$(plantNumber) ", selectSQL)
                          %endif
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order BY $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @ConfigurationType_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) ConfigurationType_Query (IN  CHAR(64)    profileHandle,
                                                CHAR(2)     dataBaseID,
                                                CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (plantNumber > "0")
          @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      %endif
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)ConfigurationTypeMaintain.d2w/MAINTAIN$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(plantNumber)&amp;fromName=@dtw_rurlescseq(plantName)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      %if (plantNumber > "0")
          <table $(contentTable)>
              @Format_Header_URL("Plant", $(plantName), $(plantNumber), "$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(d2wVarBase)")
          </table>
      %endif
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Configuration<br>Type</th>
                      <th class="colhdr">Description</th>
                      %if (plantNumber == "")
                          <th class="colhdr">Plant</th>
                      %endif
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchType" size="10" maxlength="5">
                          <input type="hidden" name="operType" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchDescription" size="15" maxlength="30">
                          <input type="hidden" name="operDescription" value="LIKE">
                      </td>
                      %if (plantNumber == "")
                          <td><input type="text" class="inputnmbr" name="srchPlant" size="5" maxlength="3">
                              <input type="hidden" name="operPlant" value="=">
                          </td>
                      %endif
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchType.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("CYCFGT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Type" title="Sequence By Configuration Type"> Configuration<br>Type</a></th>
              @OrderBy_Sort("CYLDSCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Description, Configuration Type"> Description</a></th>
              %if (plantNumber == "")
                  @OrderBy_Sort("CYPLT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlantNumber" title="Sequence By Plant">Plant</a></th>
                  @OrderBy_Sort("PLNAMEU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlantName" title="Sequence By Plant Name">Plant Name</a></th>
              %endif
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(plantNumber)&amp;fromName=@dtw_rurlescseq(plantName)&amp;plantNumber=@dtw_rurlescseq(V_CYPLT)&amp;configurationType=@dtw_rurlescseq(V_CYCFGT)&amp;longDescription=@dtw_rurlescseq(V_CYLDSC)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_CYLDSC), $(V_CYCFGT), "", "", "", "", confirmDesc)
              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)ConfigurationTypeMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_04 == "Y")
                              <a href="$(homeURL)$(cGIPath)ConfigurationTypeMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)ConfigurationTypeMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_CYCFGT)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ConfigurationTypeSelect.d2w/REPORT$(maintainVar)" title="View Configuration Type">$(V_CYLDSC)</a></td>
                  %if (plantNumber == "")
                      <td class="colnmbr">$(V_CYPLT)</td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(V_CYPLT)&amp;plantName=@dtw_rurlescseq(V_PLNAME)" title="View Plant">$(V_PLNAME)</a></td>
                  %endif
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "Select HDCFGT.* , ", stmtSQL)
  @dtw_concat(stmtSQL, "upper(CYLDSC) as CYLDSCU " , stmtSQL)
  %if (plantNumber == "")
      @dtw_concat(stmtSQL, " , coalesce(PLNAME,' ') as PLNAME, ", stmtSQL)
      @dtw_concat(stmtSQL, " coalesce(upper(PLNAME),' ') as PLNAMEU ", stmtSQL)
  %endif
  @dtw_concat(fileSQL, " HDCFGT ", fileSQL)
  %if (plantNumber == "")
      @dtw_concat(fileSQL, " left join HDPLNT on CYPLT=PLPLNT ", fileSQL)
  %endif
  %if (wildCardSearch!="" || plantNumber>"0" || uv_Sql!="")
      @dtw_concat(selectSQL, "CYCFGT>' ' ", selectSQL)
  %endif
  %if (plantNumber > "0")
      @dtw_concat(selectSQL, " and CYPLT=$(plantNumber) ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @ConfigurationType_XMLQuery(profileHandle, dataBaseID, stmtSQL)

%}

%FUNCTION(dtw_sql) ConfigurationType_XMLQuery (IN  CHAR(64)    profileHandle,
			                            CHAR(2)     dataBaseID,
                                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("ConfigurationTypeList")
      %if (plantNumber > "0")
	   @XMLIDTag(plantNumber, "Plant ID")
              @XMLTag(plantNumber, "PlantNumber")
              @XMLTag(plantName, "PlantName")
      %endif		

      %ROW{
          @XMLIDTag("$(V_CYCFGT)", "Configuration Type")
              @XMLTag(V_CYCFGT, "ConfigurationType")
              @XMLTag(V_CYSDSC, "ShortDescription")
              @XMLTag(V_CYLDSC, "LongDescription")
              @XMLTag(V_CYAS11, "UserDefinedAlpha1Desc")
              @XMLTag(V_CYAH11, "UserDefinedAlpha1Hdg1")
              @XMLTag(V_CYAH12, "UserDefinedAlpha1Hdg2")
              @XMLTag(V_CYAS21, "UserDefinedAlpha2Desc")
              @XMLTag(V_CYAH21, "UserDefinedAlpha2Hdg1")
              @XMLTag(V_CYAH22, "UserDefinedAlpha2Hdg2")
              @XMLTag(V_CYAS31, "UserDefinedAlpha3Desc")
              @XMLTag(V_CYAH31, "UserDefinedAlpha3Hdg1")
              @XMLTag(V_CYAH32, "UserDefinedAlpha3Hdg2")
              @XMLTag(V_CYNS11, "UserDefinedNumeric1Desc")
              @XMLTag(V_CYNH11, "UserDefinedNumeric1Hdg1")
              @XMLTag(V_CYNH12, "UserDefinedNumeric1Hdg2")
              @XMLTag(V_CYNS21, "UserDefinedNumeric2Desc")
              @XMLTag(V_CYNH21, "UserDefinedNumeric2Hdg1")
              @XMLTag(V_CYNH22, "UserDefinedNumeric2Hdg2")
              @XMLTag(V_CYNS31, "UserDefinedNumeric3Desc")
              @XMLTag(V_CYNH31, "UserDefinedNumeric3Hdg1")
              @XMLTag(V_CYNH32, "UserDefinedNumeric3Hdg2")
              @XMLTag(V_CYDS11, "UserDefinedDate1Desc")
              @XMLTag(V_CYDH11, "UserDefinedDate1Hdg1")
              @XMLTag(V_CYDH12, "UserDefinedDate1Hdg2")
              @XMLTag(V_CYDS21, "UserDefinedDate2Desc")
              @XMLTag(V_CYDH21, "UserDefinedDate2Hdg1")
              @XMLTag(V_CYDH22, "UserDefinedDate2Hdg2")
              @XMLTag(V_CYDS31, "UserDefinedDate3Desc")
              @XMLTag(V_CYDH31, "UserDefinedDate3Hdg1")
              @XMLTag(V_CYDH32, "UserDefinedDate3Hdg2")
              %if (plantNumber == "")
                  @XMLTag(V_CYPLT, "PlantNumber")
                  @XMLTag(V_PLNAME, "PlantName")
              %endif
          @XMLEndTag("Configuration")
      %}
      %if (plantNumber > "0")
          @XMLEndTag("Plant")
      %endif
      @XMLEndTag("ConfigurationTypeList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (plantNumber > "0" && orderBy == "PLNAMEU,CYCFGT")
          @dtw_assign(orderBy, "")
      %endif
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "CYLDSCU")
          @DTW_ASSIGN(orderByDisplay, "Description")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Type")
      %if (orderBy == "CYCFGT")
          @DTW_ASSIGN(orderBy, "CYCFGT DESC")
          @DTW_ASSIGN(orderByDisplay, "Type (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CYCFGT")
          @DTW_ASSIGN(orderByDisplay, "Type")
      %endif
  %elseif (sequence == "Description")
      %if (orderBy == "CYLDSCU,CYCFGT")
          @DTW_ASSIGN(orderBy, "CYLDSCU DESC,CYCFGT")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Type")
      %else
          @DTW_ASSIGN(orderBy, "CYLDSCU,CYCFGT")
          @DTW_ASSIGN(orderByDisplay, "Description, Type")
      %endif
  %elseif (sequence == "PlantNumber")
      %if (orderBy == "CYPLT,CYCFGT")
          @DTW_ASSIGN(orderBy, "CYPLT DESC,CYCFGT")
          @DTW_ASSIGN(orderByDisplay, "Plant Number (descending), Type")
      %else
          @DTW_ASSIGN(orderBy, "CYPLT,CYCFGT")
          @DTW_ASSIGN(orderByDisplay, "Plant Number, Type")
      %endif
  %elseif (sequence == "PlantName")
      %if (orderBy == "PLNAMEU,CYCFGT")
          @DTW_ASSIGN(orderBy, "PLNAMEU DESC,CYCFGT")
          @DTW_ASSIGN(orderByDisplay, "Plant Name (descending), Type")
      %else
          @DTW_ASSIGN(orderBy, "PLNAMEU,CYCFGT")
          @DTW_ASSIGN(orderByDisplay, "Plant Name, Type")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
	       %INCLUDE "numedit.icl"
              %if (plantNumber == "")
                  function validate(searchForm) {
                      if (editNum(document.Search.srchPlant, 3, 0))
                          return true;
                  }
              %else
                  %INCLUDE "NoFormValidate.icl"
              %endif
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CONFIGURATIONTYPESEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Configuration Type</td>
                              @dtw_assign(operNbr, "operType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchType" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDescription")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDescription" size="30" maxlength="30"></td>
                          </tr>

                          %if (plantNumber == "")
                              <tr><td class="dsphdr">Plant Number</td>
                                  @dtw_assign(operNbr, "operPlant")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchPlant" size="5" maxlength="3"></td>
                              </tr>

                              <tr><td class="dsphdr">Plant Name</td>
                                  @dtw_assign(operNbr, "operName")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"> <input type="text" name="srchName" size="30" maxlength="26"></td>
                              </tr>
                          %endif

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchType.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("CYCFGT", "Configuration Type", $(srchType), "U", operType, "A")
  @Build_WildCard ("upper(CYLDSC)", "Description", $(srchDescription), "U", operDescription, "A")
  %if (plantNumber == "")
      @Build_WildCard ("CYPLT", "Plant Number", $(srchPlant), "", operPlant, "N")
      @Build_WildCard ("upper(PLNAME)", "Plant Name", $(srchName), "U", operName, "A")
  %endif

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
