%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title 		= "Miscellaneous Data"
  d2wName              = "HRMiscellaneous.d2w"
  d2wVarBase           = "$(genericVarBase)$(employeeVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(d2wName)"
  nextPrevVar          = "$(d2wVarBase)"
  programName          = "HPEMDU"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  DTW_PAD_PGM_PARMS    = "YES"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext		= "1"
  totalPages		= "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
  @dtw_replace(workURL, "@@fromD2w", "@dtw_rurlescseq(fromD2w)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                       @dtw_assign(pageID, "MISCELLANEOUSDATA")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "UserViewEmpl.icl"
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select MISEQ, MICODE, MITYPE, MIEFDT, MIPREM, MIAMT, MIBENF, EMCOMP, EMFACL, EMEMPL, EMPECP, EMPEMP, EMDEPT, EMLOC, EMTYPE, ODDESC, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(MITYPE) as MITYPEU", stmtSQL)
                      @dtw_concat(fileSQL, " PEMISC inner join HREMPL on MICOMP=EMPECP and MIEMPL=EMPEMP ", fileSQL)
                      @dtw_concat(fileSQL, "        inner join PECODE on MICOMP=ODCOMP and MICODE=ODCODE and ODTYPE='K' ", fileSQL)
                      @dtw_concat(selectSQL, " MICOMP=$(hrCompany) and MIEMPL=$(hrEmployee)", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Misc_Data_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Misc_Data_Query (IN CHAR(64)    profileHandle,
				        CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/report") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Return To Employee">$(portalHome)</a>
                          %endif
                          %if (sec_01 == "Y")
                              <a href="$(homeURL)$(cGIPath)HRMiscellaneousMaintain.d2w/REPORT$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                          %endif
                          <a href="$(homeURL)$(cGIPath)EmployeeMaintainSelect.d2w/REPORT$(d2wVarBase)">$(emplMaintImage)</a>
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>

              @Ret_Format_EmplName("00", "0000", "00000", hrCompany, hrEmployee, "H", F_EmpName)
              <tr><td><h2>$(F_EmpName)</h2></td></tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"	
          $(hrTagAttr)	

              %if (formatToPrint != "Y")
                  <table $(contentTable)>
                      <tr><td> %INCLUDE "AssignPageValue.icl" </td></tr>
                  </table>
              %endif

          <table $(contentTable)>
              <tr>
    	       %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("MITYPEU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MiscName" title="Sequence By Miscellaneous Name">Miscellaneous<br>Name</a></th>
                  @OrderBy_Sort("MIEFDT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=EffectiveDate" title="Sequence By Effective Date, Miscellaneous Name">Effective<br>Date</a></th>
                  @OrderBy_Sort("MIPREM", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PremiumAmount" title="Sequence By Premium Amount">Premium<br>Amount</a></th>
                  @OrderBy_Sort("MIAMT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Amount" title="Sequence By Amount">Amount</a></th>
                  @OrderBy_Sort("MIBENF", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Beneficiary" title="Sequence By Beneficiary">Beneficiary</a></th>
                  @OrderBy_Sort("MICODE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MiscCode" title="Sequence By Miscellaneous Code">Miscellaneous<br>Code</a></th>
                  @OrderBy_Sort("ODDESC", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CodeDesc" title="Sequence By Code Description">Code<br>Description</a></th>
              </tr>		

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;sequenceNumber=@dtw_rurlescseq(V_MISEQ)&amp;miscellaneousCode=@dtw_rurlescseq(V_MICODE)&amp;miscellaneousCodeDesc=@dtw_rurlescseq(V_ODDESC)&amp;miscellaneousName=@dtw_rurlescseq(V_MITYPE)")
              @Format_Date(V_MIEFDT, "D", F_MIEFDT)
              @Format_Confirm_Desc($(V_MITYPE), "", $(V_ODDESC), $(V_MICODE), "", "", confirmDesc)
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
		   %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)HRMiscellaneousMaintain.d2w/REPORT$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)HRMiscellaneousMaintain.d2w/REPORT$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href=$(homeURL)$(cGIPath)HRMiscellaneousMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)HRMiscellaneousSelect.d2w/REPORT$(maintainVar)" title="View Miscellaneous Row">$(V_MITYPE)</a></td>
                  <td class="coldate">$(F_MIEFDT)</td>
                  @Format_Nbr($(V_MIPREM), F_MIPREM, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_MIPREM)</td>
                  @Format_Nbr($(V_MIAMT), F_MIAMT, "0", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_MIAMT)</td>
                  <td class="colalph">$(V_MIBENF)</td>
                  <td class="colcode">$(V_MICODE)</td>
                  <td class="colalph">$(V_ODDESC)</td>
	       </tr>
	   %}
      </table>
      %INCLUDE "PageBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "MIEFDT,MICODE,MITYPEU")
              @DTW_ASSIGN(orderByDisplay, "Effective Date, Miscellaneous Code, Miscellaneous Name")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "MiscName")
      %if (orderBy == "MITYPEU")
          @DTW_ASSIGN(orderBy, "MITYPEU DESC")
          @DTW_ASSIGN(orderByDisplay, "Miscellaneous Name (descending)")
      %else
          @DTW_ASSIGN(orderBy, "MITYPEU")
          @DTW_ASSIGN(orderByDisplay, "Miscellaneous Name")
      %endif
  %elif (sequence == "EffectiveDate")
      %if (orderBy == "MIEFDT,MITYPEU")
          @DTW_ASSIGN(orderBy, "MIEFDT DESC,MITYPEU")
          @DTW_ASSIGN(orderByDisplay, "Effective Date (descending), Miscellaneous Name")
      %else
          @DTW_ASSIGN(orderBy, "MIEFDT,MITYPEU")
          @DTW_ASSIGN(orderByDisplay, "Effective Date, Miscellaneous Name")
      %endif
  %elif (sequence == "PremiumAmount")
      %if (orderBy == "MIPREM")
          @DTW_ASSIGN(orderBy, "MIPREM DESC")
          @DTW_ASSIGN(orderByDisplay, "Premium Amount (descending)")
      %else
          @DTW_ASSIGN(orderBy, "MIPREM")
          @DTW_ASSIGN(orderByDisplay, "Premium Amount")
      %endif
  %elif (sequence == "Amount")
      %if (orderBy == "MIAMT")
          @DTW_ASSIGN(orderBy, "MIAMT DESC")
          @DTW_ASSIGN(orderByDisplay, "Amount (descending)")
      %else
          @DTW_ASSIGN(orderBy, "MIAMT")
          @DTW_ASSIGN(orderByDisplay, "Amount")
      %endif
  %elif (sequence == "Beneficiary")
      %if (orderBy == "MIBENF")
          @DTW_ASSIGN(orderBy, "MIBENF DESC")
          @DTW_ASSIGN(orderByDisplay, "Beneficiary (descending)")
      %else
          @DTW_ASSIGN(orderBy, "MIBENF")
          @DTW_ASSIGN(orderByDisplay, "Beneficiary")
      %endif
  %elif (sequence == "MiscCode")
      %if (orderBy == "MICODE")
          @DTW_ASSIGN(orderBy, "MICODE DESC")
          @DTW_ASSIGN(orderByDisplay, "Miscellaneous Code (descending)")
      %else
          @DTW_ASSIGN(orderBy, "MICODE")
          @DTW_ASSIGN(orderByDisplay, "Miscellaneous Code")
      %endif
  %elif (sequence == "CodeDesc")
      %if (orderBy == "ODDESC")
          @DTW_ASSIGN(orderBy, "ODDESC DESC")
          @DTW_ASSIGN(orderByDisplay, "Code Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "ODDESC")
          @DTW_ASSIGN(orderByDisplay, "Code Description")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}