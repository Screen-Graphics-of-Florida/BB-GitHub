%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Part Class"
  d2wName                 = "PartClass.d2w"
  d2wVarBase              = "$(genericVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPD044"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "PARTCLASS")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      @dtw_assign(uv_PartClassName, "ICCLAS")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select ICCLAS, ICDESC, ICFDTF, ICFSPR, ICTFND, ICPFCT, ICCFCT, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(ICDESC) as ICDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " HDMICM ", fileSQL)
                      %if (wildCardSearch!="" || uv_Sql != "")
                          @dtw_concat(selectSQL, "ICDESC>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @PartClass_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) PartClass_Query (IN CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)PartClassMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr"> Description</th></tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="20" maxlength="20">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("ICCLAS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PartClass" title="Sequence By Part Class"> Part<br>Class</a></th>
              @OrderBy_Sort("ICDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description, Part Class"> Description</a></th>
              @OrderBy_Sort("ICFDTF", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DateFormat" title="Sequence By Forecast Date Format, Part Class"> Forecast<br>Date Format</a></th>
              @OrderBy_Sort("ICFSPR", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Spreaders" title="Sequence By Forecast Spreaders, Part Class"> Forecast<br>Spreaders</a></th>
              @OrderBy_Sort("ICTFND", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TimeFence" title="Sequence By Time Fence Definition, Part Class"> Time Fence<br>Definition</a></th>
              @OrderBy_Sort("ICPFCT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Retain" title="Sequence By Periods To Retain Forecast, Part Class"> Periods To<br>Retain Forecast</a></th>
              @OrderBy_Sort("ICCFCT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Consume" title="Sequence By Periods To Consume Forecast, Part Class"> Periods To<br>Consume Forecast</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;partClass=@dtw_rurlescseq(V_ICCLAS)&amp;partClassDesc=@dtw_rurlescseq(V_ICDESC)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_ICDESC), $(V_ICCLAS), "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)PartClassMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_04 == "Y")
                              <a href="$(homeURL)$(cGIPath)PartClassMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)PartClassMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colcode">$(V_ICCLAS)</td>
                  <td class="colalph">$(V_ICDESC)</td>
                  @RtvFldDesc("FLTYPE='FORECASTDF' AND FLVALU='$(V_ICFDTF)'", "SYFLAG", "FLDESC", dateFormatDesc)
                  <td class="colcode" $(helpCursor)><span title="$(dateFormatDesc)">$(V_ICFDTF)</span></td>
                  @RtvFldDesc("FLTYPE='FORECASTSP' AND FLVALU='$(V_ICFSPR)'", "SYFLAG", "FLDESC", spreaderDesc)
                  <td class="colcode" $(helpCursor)><span title="$(spreaderDesc)">$(V_ICFSPR)</span></td>
                  @RtvFldDesc("TFDEF='$(V_ICTFND)'", "HDMTFM", "TFDESC", fenceDesc)
                  <td class="colalph" $(helpCursor)><span title="$(fenceDesc)">$(V_ICTFND)</span></td>
                  <td class="colcode">$(V_ICPFCT)</td>
                  <td class="colcode">$(V_ICCFCT)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  @dtw_assign(uv_PartClassName, "ICCLAS")
  %INCLUDE "userview.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select ICCLAS, ICDESC, ICFDTF, ICFSPR, ICTFND, ICPFCT, ICCFCT, ", stmtSQL)
  @dtw_concat(stmtSQL, " upper(ICDESC) as ICDESCU ", stmtSQL)
  @dtw_concat(fileSQL, " HDMICM ", fileSQL)
  %if (wildCardSearch!="" || uv_Sql != "")
      @dtw_concat(selectSQL, "ICDESC>' ' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @PartClass_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) PartClass_XMLQuery (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("PartClassList")
          %ROW{
              @XMLIDTag(V_ICCLAS, "PartClass ID")
                  @XMLTag(V_ICCLAS, "PartClass")
                  @XMLTag(V_ICDESC, "Description")
                  @XMLTag(V_ICFDTF, "ForecastDateFormat")
                  @XMLTag(V_ICFSPR, "ForecastSpreaders")
                  @XMLTag(V_ICTFND, "TimeFenceDefinition")
                  @XMLTag(V_ICPFCT, "PeriodsToRetainForecast")
                  @XMLTag(V_ICCFCT, "PeriodsToConsumeForecast")
              @XMLEndTag("PartClass")
          %}
      @XMLEndTag("PartClassList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "ICDESCU,ICCLAS")
          @DTW_ASSIGN(orderByDisplay, "Description, Part Class")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "PartClass")
      %if (orderBy == "ICCLAS")
          @DTW_ASSIGN(orderBy, "ICCLAS DESC")
          @DTW_ASSIGN(orderByDisplay, "Part Class (descending)")
      %else
          @DTW_ASSIGN(orderBy, "ICCLAS")
          @DTW_ASSIGN(orderByDisplay, "Part Class")
      %endif
  %elseif (sequence == "Desc")
      %if (orderBy == "ICDESCU,ICCLAS")
          @DTW_ASSIGN(orderBy, "ICDESCU DESC,ICCLAS")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Part Class")
      %else
          @DTW_ASSIGN(orderBy, "ICDESCU,ICCLAS")
          @DTW_ASSIGN(orderByDisplay, "Description, Part Class")
      %endif
  %elseif (sequence == "DateFormat")
      %if (orderBy == "ICFDTF,ICCLAS")
          @DTW_ASSIGN(orderBy, "ICFDTF DESC,ICCLAS")
          @DTW_ASSIGN(orderByDisplay, "Forecast Date Format (descending), Part Class")
      %else
          @DTW_ASSIGN(orderBy, "ICFDTF,ICCLAS")
          @DTW_ASSIGN(orderByDisplay, "Forecast Date Format, Part Class")
      %endif
  %elseif (sequence == "Spreaders")
      %if (orderBy == "ICFSPR,ICCLAS")
          @DTW_ASSIGN(orderBy, "ICFSPR DESC,ICCLAS")
          @DTW_ASSIGN(orderByDisplay, "Forecast Spreaders (descending), Part Class")
      %else
          @DTW_ASSIGN(orderBy, "ICFSPR,ICCLAS")
          @DTW_ASSIGN(orderByDisplay, "Forecast Spreaders, Part Class")
      %endif
  %elseif (sequence == "TimeFence")
      %if (orderBy == "ICTFND,ICCLAS")
          @DTW_ASSIGN(orderBy, "ICTFND DESC,ICCLAS")
          @DTW_ASSIGN(orderByDisplay, "Time Fence Definition (descending), Part Class")
      %else
          @DTW_ASSIGN(orderBy, "ICTFND,ICCLAS")
          @DTW_ASSIGN(orderByDisplay, "Time Fence Definition, Part Class")
      %endif
  %elseif (sequence == "Retain")
      %if (orderBy == "ICPFCT,ICCLAS")
          @DTW_ASSIGN(orderBy, "ICPFCT DESC,ICCLAS")
          @DTW_ASSIGN(orderByDisplay, "Periods To Retain Forecast (descending), Part Class")
      %else
          @DTW_ASSIGN(orderBy, "ICPFCT,ICCLAS")
          @DTW_ASSIGN(orderByDisplay, "Periods To Retain Forecast, Part Class")
      %endif
  %elseif (sequence == "Consume")
      %if (orderBy == "ICCFCT,ICCLAS")
          @DTW_ASSIGN(orderBy, "ICCFCT DESC,ICCLAS")
          @DTW_ASSIGN(orderByDisplay, "Periods To Consume Forecast (descending), Part Class")
      %else
          @DTW_ASSIGN(orderBy, "ICCFCT,ICCLAS")
          @DTW_ASSIGN(orderByDisplay, "Periods To Consume Forecast, Part Class")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchPfct, 1, 0) &&
                      editNum(document.Search.srchCfct, 1, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PARTCLASSSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Part Class</td>
                              @dtw_assign(operNbr, "operClas")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchClas" size="5" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchDesc" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Forecast Date Format</td>
                              @dtw_assign(operNbr, "operFdtf")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchFdtf" size="5" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Forecast Spreaders</td>
                              @dtw_assign(operNbr, "operFspr")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchFspr" size="5" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Time Fence Definition</td>
                              @dtw_assign(operNbr, "operTfnd")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchTfnd" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">Periods To Retain Forecast</td>
                              @dtw_assign(operNbr, "operPfct")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchPfct" size="5" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Periods To Consume Forecast</td>
                              @dtw_assign(operNbr, "operCfct")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchCfct" size="5" maxlength="1"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchClas.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("ICCLAS", "Part Class", $(srchClas), "U", operClas, "A")
  @Build_WildCard ("upper(ICDESC)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("ICFDTF", "Forecast Date Format", $(srchFdtf), "U", operFdtf, "A")
  @Build_WildCard ("ICFSPR", "Forecast Spreaders", $(srchFspr), "U", operFspr, "A")
  @Build_WildCard ("ICTFND", "Time Fence Definition", $(srchTfnd), "U", operTfnd, "A")
  @Build_WildCard ("ICPFCT", "Periods To Retain Forecast", $(srchPfct), "", operPfct, "N")
  @Build_WildCard ("ICCFCT", "Periods To Consume Forecast", $(srchCfct), "", operCfct, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}