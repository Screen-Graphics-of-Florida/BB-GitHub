%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Tax Definition"
  d2wName                 = "TaxDefinition.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HOETDU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "TAXDEFINITION")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select TDSTCD, TDCNYC, TDCTYC, TDLOC1, TDLOC2, TDLOC3, TDTAX1, TDFRTX, ", stmtSQL)
                      @dtw_concat(stmtSQL, " TDTDSC, upper(TDTDSC) as TDTDSCU ", stmtSQL)
                      @dtw_concat(fileSQL, " HDTAXD ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, "TDSTCD>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @TaxDefinition_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) TaxDefinition_Query (IN CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)TaxDefinitionMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">State</th>
                      <th class="colhdr">Description</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchState" size="2" maxlength="2">
                          <input type="hidden" name="operState" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchDesc" size="20" maxlength="20">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchState.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("TDSTCD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=State" title="Sequence By State, County, City, Local 1, Local 2, Local 3">State</a></th>
              @OrderBy_Sort("TDCNYC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=County" title="Sequence By County, State">County</a></th>
              @OrderBy_Sort("TDCTYC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=City" title="Sequence By City, State">City</a></th>
              @OrderBy_Sort("TDLOC1", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Loc1" title="Sequence By Local 1, State">Local<br>1</a></th>
              @OrderBy_Sort("TDLOC2", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Loc2" title="Sequence By Local 2, State">Local<br>2</a></th>
              @OrderBy_Sort("TDLOC3", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Loc3" title="Sequence By Local 3, State">Local<br>3</a></th>
              @OrderBy_Sort("TDTDSCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description, State, County, City, Local 1, Local 2, Local 3"> Description</a></th>
              @OrderBy_Sort("TDTAX1", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Rate" title="Sequence By Tax Rate Percent, State, County, City, Local 1, Local 2, Local 3">Tax Rate<br>Percent</a></th>
              <th class="colhdr">Total<br>Tax Rate<br>Percent</th>
              @OrderBy_Sort("TDFRTX", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Freight" title="Sequence By Freight Taxable, State">Freight<br>Taxable</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;state=@dtw_rurlescseq(V_TDSTCD)&amp;county=@dtw_rurlescseq(V_TDCNYC)&amp;city=@dtw_rurlescseq(V_TDCTYC)&amp;local1=@dtw_rurlescseq(V_TDLOC1)&amp;local2=@dtw_rurlescseq(V_TDLOC2)&amp;local3=@dtw_rurlescseq(V_TDLOC3)&amp;taxDefDesc=@dtw_rurlescseq(V_TDTDSC)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_TDTDSC), "$(V_TDSTCD)/$(V_TDCNYC)/$(V_TDCTYC)/$(V_TDLOC1)/$(V_TDLOC2)/$(V_TDLOC3)", "", "", "", "", confirmDesc)
              @Format_Nbr(@dtw_rformat(@dtw_rmultiply(V_TDTAX1, "100"),"","4"), F_TDTAX1, "4", $(pctEditCode), "", "", "")
              @dtw_assign(totalRate, "0")
              %if (V_TDLOC3>"0")
                  @RtvFldDesc("TDSTCD='$(V_TDSTCD)' and TDCNYC=$(V_TDCNYC) and TDCTYC=$(V_TDCTYC) and TDLOC1=$(V_TDLOC1) and TDLOC2=$(V_TDLOC2) and TDLOC3=$(V_TDLOC3)", "HDTAXD", "char(TDTAX1)", rate)
                  @dtw_add(totalRate, rate, totalRate)
              %endif
              %if (V_TDLOC2>"0")
                  @RtvFldDesc("TDSTCD='$(V_TDSTCD)' and TDCNYC=$(V_TDCNYC) and TDCTYC=$(V_TDCTYC) and TDLOC1=$(V_TDLOC1) and TDLOC2=$(V_TDLOC2)", "HDTAXD", "char(TDTAX1)", rate)
                  @dtw_add(totalRate, rate, totalRate)
              %endif
              %if (V_TDLOC1>"0")
                  @RtvFldDesc("TDSTCD='$(V_TDSTCD)' and TDCNYC=$(V_TDCNYC) and TDCTYC=$(V_TDCTYC) and TDLOC1=$(V_TDLOC1)", "HDTAXD", "char(TDTAX1)", rate)
                  @dtw_add(totalRate, rate, totalRate)
              %endif
              %if (V_TDCTYC>"0")
                  @RtvFldDesc("TDSTCD='$(V_TDSTCD)' and TDCNYC=$(V_TDCNYC) and TDCTYC=$(V_TDCTYC)", "HDTAXD", "char(TDTAX1)", rate)
                  @dtw_add(totalRate, rate, totalRate)
              %endif
              %if (V_TDCNYC>"0")
                  @RtvFldDesc("TDSTCD='$(V_TDSTCD)' and TDCNYC=$(V_TDCNYC)", "HDTAXD", "char(TDTAX1)", rate)
                  @dtw_add(totalRate, rate, totalRate)
              %endif
              @RtvFldDesc("TDSTCD='$(V_TDSTCD)'", "HDTAXD", "char(TDTAX1)", rate)
              @dtw_add(totalRate, rate, totalRate)
              @Format_Nbr(@dtw_rformat(@dtw_rmultiply(totalRate, "100"),"","4"), F_totalRate, "4", $(pctEditCode), "", "", "")

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)TaxDefinitionMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_04 == "Y")
                              <a href="$(homeURL)$(cGIPath)TaxDefinitionMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)TaxDefinitionMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colcode">$(V_TDSTCD)</td>
                  <td class="colnmbr">$(V_TDCNYC)</td>
                  <td class="colnmbr">$(V_TDCTYC)</td>
                  <td class="colnmbr">$(V_TDLOC1)</td>
                  <td class="colnmbr">$(V_TDLOC2)</td>
                  <td class="colnmbr">$(V_TDLOC3)</td>
                  <td class="colalph">$(V_TDTDSC)</td>
                  <td class="colnmbr">$(F_TDTAX1)</td>
                  <td class="colnmbr">$(F_totalRate)</td>
                  <td class="colcode">$(V_TDFRTX)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select TDSTCD, TDCNYC, TDCTYC, TDLOC1, TDLOC2, TDLOC3, TDTAX1, TDFRTX, ", stmtSQL)
  @dtw_concat(stmtSQL, " TDTDSC, upper(TDTDSC) as TDTDSCU ", stmtSQL)
  @dtw_concat(fileSQL, " HDTAXD ", fileSQL)
  %if (wildCardSearch!="")
      @dtw_concat(selectSQL, "TDSTCD>' ' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @TaxDefinition_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) TaxDefinition_XMLQuery (IN CHAR(64)    profileHandle,
                                              CHAR(2)     dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("TaxDefinitionList")
          %ROW{
              @XMLIDTag("$(V_TDSTCD)/$(V_TDCNYC)/$(V_TDCTYC)/$(V_TDLOC1)/$(V_TDLOC2)/$(V_TDLOC3)", "TaxDefinition ID")
                  @XMLTag(V_TDSTCD, "State")
                  @XMLTag(V_TDCNYC, "County")
                  @XMLTag(V_TDCTYC, "City")
                  @XMLTag(V_TDLOC1, "Local1")
                  @XMLTag(V_TDLOC2, "Local2")
                  @XMLTag(V_TDLOC3, "Local3")
                  @XMLTag(V_TDTDSC, "Description")
                  @XMLTag(@dtw_rformat(@dtw_rmultiply(V_TDTAX1, "100"),"","4"), "TaxRatePercent")
                  %if (V_TDFRTX != "")
                      @XMLTag(V_TDFRTX, "FreightTaxable")
                  %endif
              @XMLEndTag("TaxDefinition")
          %}
      @XMLEndTag("TaxDefinitionList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "TDTDSCU,TDSTCD")
          @DTW_ASSIGN(orderByDisplay, "Description, Tax Definition")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "State")
      %if (orderBy == "TDSTCD,TDCNYC,TDCTYC,TDLOC1,TDLOC2,TDLOC3")
          @DTW_ASSIGN(orderBy, "TDSTCD DESC,TDCNYC,TDCTYC,TDLOC1,TDLOC2,TDLOC3")
          @DTW_ASSIGN(orderByDisplay, "State (descending), County, City, Local 1, Local 2, Local 3")
      %else
          @DTW_ASSIGN(orderBy, "TDSTCD,TDCNYC,TDCTYC,TDLOC1,TDLOC2,TDLOC3")
          @DTW_ASSIGN(orderByDisplay, "State, County, City, Local 1, Local 2, Local 3")
      %endif
  %elseif (sequence == "County")
      %if (orderBy == "TDCNYC,TDSTCD")
          @DTW_ASSIGN(orderBy, "TDCNYC DESC,TDSTCD")
          @DTW_ASSIGN(orderByDisplay, "County (descending), State")
      %else
          @DTW_ASSIGN(orderBy, "TDCNYC,TDSTCD")
          @DTW_ASSIGN(orderByDisplay, "County, State")
      %endif
  %elseif (sequence == "City")
      %if (orderBy == "TDCTYC,TDSTCD")
          @DTW_ASSIGN(orderBy, "TDCTYC DESC,TDSTCD")
          @DTW_ASSIGN(orderByDisplay, "City (descending), State")
      %else
          @DTW_ASSIGN(orderBy, "TDCTYC,TDSTCD")
          @DTW_ASSIGN(orderByDisplay, "City, State")
      %endif
  %elseif (sequence == "Loc1")
      %if (orderBy == "TDLOC1,TDSTCD")
          @DTW_ASSIGN(orderBy, "TDLOC1 DESC,TDSTCD")
          @DTW_ASSIGN(orderByDisplay, "Local 1 (descending), State")
      %else
          @DTW_ASSIGN(orderBy, "TDLOC1,TDSTCD")
          @DTW_ASSIGN(orderByDisplay, "Local 1, State")
      %endif
  %elseif (sequence == "Loc2")
      %if (orderBy == "TDLOC2,TDSTCD")
          @DTW_ASSIGN(orderBy, "TDLOC2 DESC,TDSTCD")
          @DTW_ASSIGN(orderByDisplay, "Local 2 (descending), State")
      %else
          @DTW_ASSIGN(orderBy, "TDLOC2,TDSTCD")
          @DTW_ASSIGN(orderByDisplay, "Local 2, State")
      %endif
  %elseif (sequence == "Loc3")
      %if (orderBy == "TDLOC3,TDSTCD")
          @DTW_ASSIGN(orderBy, "TDLOC3 DESC,TDSTCD")
          @DTW_ASSIGN(orderByDisplay, "Local 3 (descending), State")
      %else
          @DTW_ASSIGN(orderBy, "TDLOC3,TDSTCD")
          @DTW_ASSIGN(orderByDisplay, "Local 3, State")
      %endif
  %elseif (sequence == "Desc")
      %if (orderBy == "TDTDSCU,TDSTCD,TDCNYC,TDCTYC,TDLOC1,TDLOC2,TDLOC3")
          @DTW_ASSIGN(orderBy, "TDTDSCU DESC,TDSTCD,TDCNYC,TDCTYC,TDLOC1,TDLOC2,TDLOC3")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), State, County, City, Local 1, Local 2, Local 3")
      %else
          @DTW_ASSIGN(orderBy, "TDTDSCU,TDSTCD,TDCNYC,TDCTYC,TDLOC1,TDLOC2,TDLOC3")
          @DTW_ASSIGN(orderByDisplay, "Description, State, County, City, Local 1, Local 2, Local 3")
      %endif
  %elseif (sequence == "Rate")
      %if (orderBy == "TDTAX1,TDSTCD,TDCNYC,TDCTYC,TDLOC1,TDLOC2,TDLOC3")
          @DTW_ASSIGN(orderBy, "TDTAX1 DESC,TDSTCD,TDCNYC,TDCTYC,TDLOC1,TDLOC2,TDLOC3")
          @DTW_ASSIGN(orderByDisplay, "Tax Rate (descending), State, County, City, Local 1, Local 2, Local 3")
      %else
          @DTW_ASSIGN(orderBy, "TDTAX1,TDSTCD,TDCNYC,TDCTYC,TDLOC1,TDLOC2,TDLOC3")
          @DTW_ASSIGN(orderByDisplay, "Tax Rate, State, County, City, Local 1, Local 2, Local 3")
      %endif
  %elseif (sequence == "Freight")
      %if (orderBy == "TDFRTX,TDSTCD")
          @DTW_ASSIGN(orderBy, "TDFRTX DESC,TDSTCD")
          @DTW_ASSIGN(orderByDisplay, "Freight Taxable (descending), State")
      %else
          @DTW_ASSIGN(orderBy, "TDFRTX,TDSTCD")
          @DTW_ASSIGN(orderByDisplay, "Freight Taxable, State")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchCounty, 3, 0) &&
                      editNum(document.Search.srchCity, 5, 0) &&
                      editNum(document.Search.srchLoc1, 4, 0) &&
                      editNum(document.Search.srchLoc2, 4, 0) &&
                      editNum(document.Search.srchLoc3, 4, 0) &&
                      editNum(document.Search.srchRate, 3, 4))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "TAXDEFINITIONSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">State</td>
                              @dtw_assign(operNbr, "operState")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchState" size="5" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">County</td>
                              @dtw_assign(operNbr, "operCounty")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchCounty" size="5" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">City</td>
                              @dtw_assign(operNbr, "operCity")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchCity" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">Local 1</td>
                              @dtw_assign(operNbr, "operLoc1")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchLoc1" size="5" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Local 2</td>
                              @dtw_assign(operNbr, "operLoc2")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchLoc2" size="5" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Local 3</td>
                              @dtw_assign(operNbr, "operLoc3")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchLoc3" size="5" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Tax Rate Percent</td>
                              @dtw_assign(operNbr, "operRate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchRate" size="10" maxlength="7"></td>
                          </tr>

                          <tr><td class="dsphdr">Freight Taxable</td>
                              @dtw_assign(operNbr, "operFrt")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchFrt" size="5" maxlength="1"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchState.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("TDSTCD", "State", $(srchState), "U", operState, "A")
  @Build_WildCard ("upper(TDTDSC)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("TDCNYC", "County", $(srchCounty), "", operCounty, "N")
  @Build_WildCard ("TDCTYC", "City", $(srchCity), "", operCity, "N")
  @Build_WildCard ("TDLOC1", "Local 1", $(srchLoc1), "", operLoc1, "N")
  @Build_WildCard ("TDLOC2", "Local 2", $(srchLoc2), "", operLoc2, "N")
  @Build_WildCard ("TDLOC3", "Local 3", $(srchLoc3), "", operLoc3, "N")
  @Build_WildCard ("TDTAX1*100", "Tax Rate Percent", $(srchRate), "", operRate, "N")
  @Build_WildCard ("TDFRTX", "Freight Taxable", $(srchFrt), "U", operFrt, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}