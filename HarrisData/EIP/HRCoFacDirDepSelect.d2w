%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title 	        = "Direct Deposits"
  d2wName              = "HRCoFacDirDepSelect.d2w"
  d2wVarBase           = "$(genericVarBase)$(employeeVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName          = "HHREMU"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  RPT_MAX_ROWS         = "99"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext	        = "1"
  totalPages	        = "0"	
  EMU_06                  = ""
  EMU_07                  = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @dtw_assign(applicationID, "PR")
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "DIRDEPSELECT")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          @dtw_concat(stmtSQL, "Select * From PREACH INNER JOIN PREMPL ON ACCOMP=ERCOMP AND ACFACL=ERFACL AND ACEMPL=EREMPL", stmtSQL)
                          @dtw_concat(stmtSQL, " Where ACCOMP=$(prCompany) and ACFACL=$(prFacility) and ACEMPL=$(prEmployee)", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @DirDep_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) DirDep_Query (IN CHAR(64)    profileHandle,
				     CHAR(2)     dataBaseID,
                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(programName, "HHREMU")
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @dtw_assign(EMU_06, sec_06)
      @dtw_assign(EMU_07, sec_07)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Return To Employee">$(portalHome)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
          @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(hrEmployee)", "HREMPL", "EMTYPE", EMTYPE)
          @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
          <tr><td><h2>$(F_EmpName)</h2></td></tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      %ROW {
          <table $(contentTable)>
              <tr><td class="colhdr">Deposit</td>
                  <td class="colhdr">Type</td>
                  <td class="colhdr">Account<br>Number</td>
                  <td class="colhdr">Transit<br>Routing #</td>
                  <td class="colhdr">Pre-Note</td>
                  %if ((EMTYPE == "H" && EMU_06 == "Y") || (EMTYPE != "H" && EMU_07 == "Y"))
                      <td class="colhdr">Amount</td>
                  %endif
                  <td class="colhdr">Percent</td>
                  <td class="colhdr">Net Deposit</td>
                  %if ((EMTYPE == "H" && EMU_06 == "Y") || (EMTYPE != "H" && EMU_07 == "Y"))
                      <td class="colhdr">Year To Date<br>Deposits</td>
                  %endif
              </tr>

              %if (V_ACTYP1 != "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colcode">1</td>
                      %if (V_ACTYP1 == "C")
                          <td class="colalph">Checking</td>
                      %else
                      <td class="colalph">Savings</td>
                      %endif
                      <td class="colalph">$(V_ACACT1)</td>
                      <td class="colalph">$(V_ACTRN1)</td>
                      @RtvYNDesc($(V_ACPRE1), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>

                      %if ((EMTYPE == "H" && EMU_06 == "Y") || (EMTYPE != "H" && EMU_07 == "Y"))
                          %if (V_ACAMT1 == ".00")
                              @dtw_assign(V_ACAMT1, "")
                              <td class="colnmbr">$(V_ACAMT1)</td>
                          %else
                              @Format_Nbr($(V_ACAMT1), F_ACAMT1, "2", $(amtEditCode), "", "", "")
                              <td class="colnmbr">$(F_ACAMT1)</td>
                          %endif
                      %endif

                      %if (V_ACPCT1 == ".000")
                          @dtw_assign(V_ACPCT1, "")
                          <td class="colnmbr">$(V_ACPCT1)</td>
                      %else
                          @Format_Nbr(@dtw_rmultiply(V_ACPCT1, "100"), F_ACPCT1, "1", $(pctEditCode), "", "", "")
                          <td class="colnmbr">$(F_ACPCT1)</td>
                      %endif
                      <td class="colalph"></td>

                      %if ((EMTYPE == "H" && sec_06 == "Y") || (EMTYPE != "H" && sec_07 == "Y"))
                          @Format_Nbr($(V_ERDD01), F_ERDD01, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ERDD01)</td>
                      %endif
                  </tr>
              %endif

              %if (V_ACTYP2 != "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colcode">2</td>
                      %if (V_ACTYP2 == "C")
                          <td class="colalph">Checking</td>
                      %else
                      <td class="colalph">Savings</td>
                      %endif
                      <td class="colalph">$(V_ACACT2)</td>
                      <td class="colalph">$(V_ACTRN2)</td>
                      @RtvYNDesc($(V_ACPRE2), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                      %if ((EMTYPE == "H" && sec_06 == "Y") || (EMTYPE != "H" && sec_07 == "Y"))
                        %if (V_ACAMT2 == ".00")
                              @dtw_assign(V_ACAMT2, "")
                              <td class="colnmbr">$(V_ACAMT2)</td>
                          %else
                              @Format_Nbr($(V_ACAMT2), F_ACAMT2, "2", $(amtEditCode), "", "", "")
                              <td class="colnmbr">$(F_ACAMT2)</td>
                          %endif
                      %endif
                      %if (V_ACPCT2 == ".000")
                          @dtw_assign(V_ACPCT2, "")
                          <td class="colnmbr">$(V_ACPCT2)</td>
                      %else
                          @Format_Nbr(@dtw_rmultiply(V_ACPCT2, "100"), F_ACPCT2, "1", $(pctEditCode), "", "", "")
                          <td class="colnmbr">$(F_ACPCT2)</td>
                      %endif
                      <td class="colalph"></td>
                      %if ((EMTYPE == "H" && sec_06 == "Y") || (EMTYPE != "H" && sec_07 == "Y"))
                          @Format_Nbr($(V_ERDD02), F_ERDD02, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ERDD02)</td>
                      %endif
                  </tr>
              %endif

              %if (V_ACTYP3 != "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colcode">3</td>
                      %if (V_ACTYP3 == "C")
                          <td class="colalph">Checking</td>
                      %else
                          <td class="colalph">Savings</td>
                      %endif
                      <td class="colalph">$(V_ACACT3)</td>
                      <td class="colalph">$(V_ACTRN3)</td>
                      @RtvYNDesc($(V_ACPRE3), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                      %if ((EMTYPE == "H" && sec_06 == "Y") || (EMTYPE != "H" && sec_07 == "Y"))
                        %if (V_ACAMT3 == ".00")
                              @dtw_assign(V_ACAMT3, "")
                              <td class="colnmbr">$(V_ACAMT3)</td>
                          %else
                              @Format_Nbr($(V_ACAMT3), F_ACAMT3, "2", $(amtEditCode), "", "", "")
                              <td class="colnmbr">$(F_ACAMT3)</td>
                          %endif
                      %endif
                      %if (V_ACPCT3 == ".000")
                          @dtw_assign(V_ACPCT3, "")
                          <td class="colnmbr">$(V_ACPCT3)</td>
                      %else
                          @Format_Nbr(@dtw_rmultiply(V_ACPCT3, "100"), F_ACPCT3, "1", $(pctEditCode), "", "", "")
                          <td class="colnmbr">$(F_ACPCT3)</td>
                      %endif
                      <td class="colalph"></td>
                      %if ((EMTYPE == "H" && sec_06 == "Y") || (EMTYPE != "H" && sec_07 == "Y"))
                          @Format_Nbr($(V_ERDD03), F_ERDD03, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ERDD03)</td>
                      %endif
                  </tr>
              %endif

              %if (V_ACTYP4 != "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colcode">4</td>
                      %if (V_ACTYP4 == "C")
                          <td class="colalph">Checking</td>
                      %else
                          <td class="colalph">Savings</td>
                      %endif
                      <td class="colalph">$(V_ACACT4)</td>
                      <td class="colalph">$(V_ACTRN4)</td>
                      @RtvYNDesc($(V_ACPRE4), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                      %if ((EMTYPE == "H" && sec_06 == "Y") || (EMTYPE != "H" && sec_07 == "Y"))
                        %if (V_ACAMT4 == ".00")
                              @dtw_assign(V_ACAMT4, "")
                              <td class="colnmbr">$(V_ACAMT4)</td>
                          %else
                              @Format_Nbr($(V_ACAMT4), F_ACAMT4, "2", $(amtEditCode), "", "", "")
                              <td class="colnmbr">$(F_ACAMT4)</td>
                          %endif
                      %endif
                      %if (V_ACPCT4 == ".000")
                          @dtw_assign(V_ACPCT4, "")
                          <td class="colnmbr">$(V_ACPCT4)</td>
                      %else
                          @Format_Nbr(@dtw_rmultiply(V_ACPCT4, "100"), F_ACPCT4, "1", $(pctEditCode), "", "", "")
                          <td class="colnmbr">$(F_ACPCT4)</td>
                      %endif
                      <td class="colalph"></td>
                      %if ((EMTYPE == "H" && sec_06 == "Y") || (EMTYPE != "H" && sec_07 == "Y"))
                          @Format_Nbr($(V_ERDD04), F_ERDD04, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ERDD04)</td>
                      %endif
                  </tr>
              %endif

              %if (V_ACTYP5 != "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colcode">5</td>
                      %if (V_ACTYP5 == "C")
                          <td class="colalph">Checking</td>
                      %else
                          <td class="colalph">Savings</td>
                      %endif
                      <td class="colalph">$(V_ACACT5)</td>
                      <td class="colalph">$(V_ACTRN5)</td>
                      @RtvYNDesc($(V_ACPRE5), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                      %if ((EMTYPE == "H" && sec_06 == "Y") || (EMTYPE != "H" && sec_07 == "Y"))
                          %if (V_ACAMT5 == ".00")
                              @dtw_assign(V_ACAMT5, "")
                              <td class="colnmbr">$(V_ACAMT5)</td>
                          %else
                              @Format_Nbr($(V_ACAMT5), F_ACAMT5, "2", $(amtEditCode), "", "", "")
                              <td class="colnmbr">$(F_ACAMT5)</td>
                          %endif
                      %endif
                      %if (V_ACPCT5 == ".000")
                          @dtw_assign(V_ACPCT5, "")
                          <td class="colnmbr">$(V_ACPCT5)</td>
                      %else
                          @Format_Nbr(@dtw_rmultiply(V_ACPCT5, "100"), F_ACPCT5, "1", $(pctEditCode), "", "", "")
                          <td class="colnmbr">$(F_ACPCT5)</td>
                      %endif
                      <td class="colalph"></td>
                      %if ((EMTYPE == "H" && sec_06 == "Y") || (EMTYPE != "H" && sec_07 == "Y"))
                          @Format_Nbr($(V_ERDD05), F_ERDD05, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ERDD05)</td>
                      %endif
                  </tr>
              %endif
              %if (V_ACTYP6 != "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colcode">6</td>
                      %if (V_ACTYP6 == "C")
                          <td class="colalph">Checking</td>
                      %else
                          <td class="colalph">Savings</td>
                      %endif
                      <td class="colalph">$(V_ACACT6)</td>
                      <td class="colalph">$(V_ACTRN6)</td>
                      @RtvYNDesc($(V_ACPRE6), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                      %if ((EMTYPE == "H" && sec_06 == "Y") || (EMTYPE != "H" && sec_07 == "Y"))
                          %if (V_ACAMT6 == ".00")
                              @dtw_assign(V_ACAMT6, "")
                              <td class="colnmbr">$(V_ACAMT6)</td>
                          %else
                              @Format_Nbr($(V_ACAMT6), F_ACAMT6, "2", $(amtEditCode), "", "", "")
                              <td class="colnmbr">$(F_ACAMT6)</td>
                          %endif
                      %endif
                      %if (V_ACPCT6 == ".000")
                          @dtw_assign(V_ACPCT6, "")
                          <td class="colnmbr">$(V_ACPCT6)</td>
                      %else
                          @Format_Nbr(@dtw_rmultiply(V_ACPCT6, "100"), F_ACPCT6, "1", $(pctEditCode), "", "", "")
                          <td class="colnmbr">$(F_ACPCT6)</td>
                      %endif
                      <td class="colalph"></td>
                      %if ((EMTYPE == "H" && sec_06 == "Y") || (EMTYPE != "H" && sec_07 == "Y"))
                          @Format_Nbr($(V_ERDD06), F_ERDD06, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ERDD06)</td>
                      %endif
                  </tr>
              %endif

              %if (V_ACTYP7 != "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colcode">7</td>
                      %if (V_ACTYP7 == "C")
                          <td class="colalph">Checking</td>
                      %else
                          <td class="colalph">Savings</td>
                      %endif
                      <td class="colalph">$(V_ACACT7)</td>
                      <td class="colalph">$(V_ACTRN7)</td>
                      @RtvYNDesc($(V_ACPRE7), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                      %if ((EMTYPE == "H" && sec_06 == "Y") || (EMTYPE != "H" && sec_07 == "Y"))
                          %if (V_ACAMT7 == ".00")
                              @dtw_assign(V_ACAMT7, "")
                              <td class="colnmbr">$(V_ACAMT7)</td>
                          %else
                              @Format_Nbr($(V_ACAMT7), F_ACAMT7, "2", $(amtEditCode), "", "", "")
                              <td class="colnmbr">$(F_ACAMT7)</td>
                          %endif
                      %endif
                      %if (V_ACPCT7 == ".000")
                          @dtw_assign(V_ACPCT7, "")
                          <td class="colnmbr">$(V_ACPCT7)</td>
                      %else
                          @Format_Nbr(@dtw_rmultiply(V_ACPCT7, "100"), F_ACPCT7, "1", $(pctEditCode), "", "", "")
                          <td class="colnmbr">$(F_ACPCT7)</td>
                      %endif
                      @RtvYNDesc($(V_ACNET), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                      %if ((EMTYPE == "H" && sec_06 == "Y") || (EMTYPE != "H" && sec_07 == "Y"))
                          @Format_Nbr($(V_ERDD07), F_ERDD07, "2", $(amtEditCode), "", "", "")
