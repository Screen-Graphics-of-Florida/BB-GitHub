%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Work Center Maintenance"
  d2wName                 = "WorkCenterMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(fromPlant)&amp;fromName=@dtw_rurlescseq(fromName)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;fromSel=@dtw_rurlescseq(fromSel)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;department=@dtw_rurlescseq(department)&amp;workCenter=@dtw_rurlescseq(workCenter)&amp;description=@dtw_rurlescseq(description)&amp;maintenanceCode=D"
  programName             = "HPD016"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  fromPlant               = ""
  fromName                = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (maintenanceCode == "A")
      @dtw_assign(userPass, "Y")
  %else
      @WorkCenterUserView(profileHandle, dataBaseID, userPass, plantNumber, department, workCenter)
  %endif
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  %INCLUDE "NumEdit.icl"
                  function confirmDelete() {return confirm("$(delRecordConf)")}
                  function validate(chgForm) {
                      if (document.Chg.plantNumber.value =="" ||
                          document.Chg.department.value =="" ||
                          document.Chg.workCenter.value =="" ||
                          document.Chg.description.value =="" ||
                          document.Chg.companyNumber.value =="" ||
                          document.Chg.facilityNumber.value =="" ||
                          document.Chg.checkCapAvail.value =="")
                         {alert("$(reqFieldError)"); return false;}
                      if (editNum(document.Chg.plantNumber, 3, 0) &&
                          editNum(document.Chg.laborUtilization, 3, 0) &&
                          editNum(document.Chg.laborEfficiency, 3, 0) &&
                          editNum(document.Chg.laborHours, 5, 0) &&
                          editNum(document.Chg.machineUtilization, 3, 0) &&
                          editNum(document.Chg.machineHours, 5, 0) &&
                          editNum(document.Chg.setupHours, 5, 0) &&
                          editNum(document.Chg.transitDays, 3, 1) &&
                          editNum(document.Chg.companyNumber, 2, 0) &&
                          editNum(document.Chg.facilityNumber, 4, 0) &&
                          editNum(document.Chg.schedule, 3, 0) &&
                          editNum(document.Chg.weeksDailyPeriod, 2, 0) &&
                          editNum(document.Chg.weeksWeeklyPeriod, 2, 0))
                          return true;
                  }
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "WORKCENTERMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "SELECT HDMWCM.*, ", stmtSQL)
                              @dtw_concat(stmtSQL, "coalesce(WXAVLC,'N') as WXAVLC, ", stmtSQL)
                              @dtw_concat(stmtSQL, "coalesce(WXWDPD,0) as WXWDPD, ", stmtSQL)
                              @dtw_concat(stmtSQL, "coalesce(WXWWPD,0) as WXWWPD ", stmtSQL)
                              @dtw_concat(fileSQL, " HDMWCM left join HDMWCX on WCPLT=WXPLT and WCDEPT=WXDEPT and WCWC=WXWC ", fileSQL)
                              @dtw_concat(selectSQL, "WCPLT = $(plantNumber) and WCDEPT = '$(department)' and WCWC = '$(workCenter)' ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (fromSel == "Y")
          @dtw_assign(backURL, "$(homeURL)$(cGIPath)WorkCenterSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;plantName=@dtw_rurlescseq(plantName)&amp;department=@dtw_rurlescseq(department)&amp;workCenter=@dtw_rurlescseq(workCenter)&amp;description=@dtw_rurlescseq(description)")
      %else
          @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
          %if (backURL == "")
              @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=218")
          %endif
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "department")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@plt@", "plantNumber")         @dtw_assign(Err_WCPLT,  fieldValue)
                          @DecatErr_Field("@@dept", "department")          @dtw_assign(Err_WCDEPT, fieldValue)
                          @DecatErr_Field("@@wc@@", "workCenter")          @dtw_assign(Err_WCWC,   fieldValue)
                          @DecatErr_Field("@@desc", "description")         @dtw_assign(Err_WCDESC, fieldValue)
                          @DecatErr_Field("@@laut", "laborUtilization")    @dtw_assign(Err_WCLAUT, fieldValue)
                          @DecatErr_Field("@@laef", "laborEfficiency")     @dtw_assign(Err_WCLAEF, fieldValue)
                          @DecatErr_Field("@@lhrd", "laborHours")          @dtw_assign(Err_WCLHRD, fieldValue)
                          @DecatErr_Field("@@maut", "machineUtilization")  @dtw_assign(Err_WCMAUT, fieldValue)
                          @DecatErr_Field("@@mhrd", "machineHours")        @dtw_assign(Err_WCMHRD, fieldValue)
                          @DecatErr_Field("@@shrd", "setupHours")          @dtw_assign(Err_WCSHRD, fieldValue)
                          @DecatErr_Field("@@mtd@", "transitDays")         @dtw_assign(Err_WCMTD,  fieldValue)
                          @DecatErr_Field("@@klcd", "keyLoadCode")         @dtw_assign(Err_WCKLCD, fieldValue)
                          @DecatErr_Field("@@co@@", "companyNumber")       @dtw_assign(Err_WCCO,   fieldValue)
                          @DecatErr_Field("@@fac@", "facilityNumber")      @dtw_assign(Err_WCFAC,  fieldValue)
                          @DecatErr_Field("@@schd", "schedule")            @dtw_assign(Err_WCSCHD, fieldValue)
                          @DecatErr_Field("@@avlc", "checkCapAvail")       @dtw_assign(Err_WXAVLC, fieldValue)
                          @DecatErr_Field("@@wdpd", "weeksDailyPeriod")    @dtw_assign(Err_WXWDPD, fieldValue)
                          @DecatErr_Field("@@wwpd", "weeksWeeklyPeriod")   @dtw_assign(Err_WXWWPD, fieldValue)
                          
                      %endif

                      @Decat_Field("@@plt@")   @dtw_assign(V_WCPLT,  fieldValue)
                      @Decat_Field("@@dept")   @dtw_assign(V_WCDEPT, fieldValue)
                      @Decat_Field("@@wc@@")   @dtw_assign(V_WCWC,   fieldValue)
                      @Decat_Field("@@desc")   @dtw_assign(V_WCDESC, fieldValue)
                      @Decat_Field("@@laut")   @dtw_assign(V_WCLAUT, fieldValue)
                      @Decat_Field("@@laef")   @dtw_assign(V_WCLAEF, fieldValue)
                      @Decat_Field("@@lhrd")   @dtw_assign(V_WCLHRD, fieldValue)
                      @Decat_Field("@@maut")   @dtw_assign(V_WCMAUT, fieldValue)
                      @Decat_Field("@@mhrd")   @dtw_assign(V_WCMHRD, fieldValue)
                      @Decat_Field("@@shrd")   @dtw_assign(V_WCSHRD, fieldValue)
                      @Decat_Field("@@mtd@")   @dtw_assign(V_WCMTD,  fieldValue)
                      @Decat_Field("@@klcd")   @dtw_assign(V_WCKLCD, fieldValue)
                      @Decat_Field("@@co@@")   @dtw_assign(V_WCCO,   fieldValue)
                      @Decat_Field("@@fac@")   @dtw_assign(V_WCFAC,  fieldValue)
                      @Decat_Field("@@schd")   @dtw_assign(V_WCSCHD, fieldValue)
                      @Decat_Field("@@avlc")   @dtw_assign(V_WXAVLC, fieldValue)
                      @Decat_Field("@@wdpd")   @dtw_assign(V_WXWDPD, fieldValue)
                      @Decat_Field("@@wwpd")   @dtw_assign(V_WXWWPD, fieldValue)
                      

                      %if (errFound == "" && maintenanceCode == "A")
                          %if (fromPlant > "0")
                              @dtw_assign(V_WCPLT, fromPlant)
                          %else
                              @RtvDftPlant(V_WCPLT, plantName)
                          %endif
                          %if (V_WCPLT > "0")
                              @RtvFldDesc("PLPLNT=$(V_WCPLT)", "HDPLNT", "PLCO#", V_WCCO)
                              @RtvFldDesc("PLPLNT=$(V_WCPLT)", "HDPLNT", "PLFAC#", V_WCFAC)
                              @dtw_assign(focusField, "department")
                          %else
                              @dtw_assign(focusField, "plantNumber")
                          %endif
                          @dtw_assign(V_WCDEPT, "")
                          @dtw_assign(V_WCWC,   "")
                          @dtw_assign(V_WCKLCD, "N")
                          @dtw_assign(V_WCSCHD, "0")
                          @dtw_assign(V_WXAVLC, "N")
                      %endif

                      @dtw_assign(errFound, "")

                  %elseif (maintenanceCode == "Z")
                      @dtw_assign(V_WCDEPT, "")
                      @dtw_assign(V_WCWC,   "")
                      @dtw_assign(focusField, "department")
                  %else
                      @dtw_assign(focusField, "description")
                  %endif

                  @Default_Zero(V_WCPLT)
                  @RtvFldDesc("PLPLNT=$(V_WCPLT)", "HDPLNT", "PLNAME", plantName)
                  @SetTextOvr(Err_WCPLT)
                  <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="plantNumber" type="text" value="$(V_WCPLT)" size="5" maxlength="3"> $(reqFieldChar) <a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=plantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="plantName" value="$(plantName)" type="text" size="30"></td>
                      %else
                          <td class="inputnmbr"><input name="plantNumber" type="hidden" value="$(V_WCPLT)">$(V_WCPLT) &nbsp; $(plantName)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_WCPLT)

                  @SetTextOvr(Err_WCDEPT)
                  <tr><td class="dsphdr"><span $(textOvr)>Department</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="department" type="text" value="$(V_WCDEPT)" size="5" maxlength="5"> $(reqFieldChar) </td>
                      %else
                          <td class="inputalph"><input name="department" type="hidden" value="$(V_WCDEPT)" size="5" maxlength="5">$(V_WCDEPT)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_WCDEPT)

                  @SetTextOvr(Err_WCWC)
                  <tr><td class="dsphdr"><span $(textOvr)>Work Center</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="workCenter" type="text" value="$(V_WCWC)" size="5" maxlength="5"> $(reqFieldChar) </td>
                      %else
                          <td class="inputalph"><input name="workCenter" type="hidden" value="$(V_WCWC)" size="5" maxlength="5">$(V_WCWC)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_WCWC)

                  @SetTextOvr(Err_WCDESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="description" type="text" value="$(V_WCDESC)" size="30" maxlength="30"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_WCDESC)
    	
                  @SetTextOvr(Err_WCLAUT)
                  <tr><td class="dsphdr"><span $(textOvr)>Labor Utilization Percent</span></td>
                      <td class="inputnmbr"><input name="laborUtilization" type="text" value="@dtw_rformat(@dtw_rMultiply(V_WCLAUT, "100"),"","0")" size="5" maxlength="3"></td>
                  </tr>
                  @DspErrMsg(Err_WCLAUT)
    	
                  @SetTextOvr(Err_WCLAEF)
                  <tr><td class="dsphdr"><span $(textOvr)>Labor Efficiency Percent</span></td>
                      <td class="inputnmbr"><input name="laborEfficiency" type="text" value="@dtw_rformat(@dtw_rMultiply(V_WCLAEF, "100"),"","0")" size="5" maxlength="3"></td>
                  </tr>
                  @DspErrMsg(Err_WCLAEF)

                  @SetTextOvr(Err_WCLHRD)
                  <tr><td class="dsphdr"><span $(textOvr)>Direct Labor Hours Per Day</span></td>
                      <td class="inputnmbr"><input name="laborHours" type="text" value="$(V_WCLHRD)" size="5" maxlength="5"></td>
                  </tr>
                  @DspErrMsg(Err_WCLHRD)
    	
                  @SetTextOvr(Err_WCMAUT)
                  <tr><td class="dsphdr"><span $(textOvr)>Machine Utilization Percent</span></td>
                      <td class="inputnmbr"><input name="machineUtilization" type="text" value="@dtw_rformat(@dtw_rMultiply(V_WCMAUT, "100"),"","0")" size="5" maxlength="3"></td>
                  </tr>
                  @DspErrMsg(Err_WCMAUT)

                  @SetTextOvr(Err_WCMHRD)
                  <tr><td class="dsphdr"><span $(textOvr)>Machine Hours Per Day</span></td>
                      <td class="inputnmbr"><input name="machineHours" type="text" value="$(V_WCMHRD)" size="5" maxlength="5"></td>
                  </tr>
                  @DspErrMsg(Err_WCMHRD)

                  @SetTextOvr(Err_WCSHRD)
                  <tr><td class="dsphdr"><span $(textOvr)>Setup Hours Per Day</span></td>
                      <td class="inputnmbr"><input name="setupHours" type="text" value="$(V_WCSHRD)" size="5" maxlength="5"></td>
                  </tr>
                  @DspErrMsg(Err_WCSHRD)

                  @SetTextOvr(Err_WCMTD)
                  <tr><td class="dsphdr"><span $(textOvr)>Transit Days</span></td>
                      <td class="inputnmbr"><input type="text" name="transitDays" value="$(V_WCMTD)" size="5" maxlength="5"></td>
                  </tr>
                  @DspErrMsg(Err_WCMTD)

                  @SetTextOvr(Err_WCKLCD)
                  <tr><td class="dsphdr"><span $(textOvr)>Key Load Code</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_WCKLCD) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "keyLoadCode", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_WCKLCD)
   	   		
                  @Default_Zero(V_WCCO)
                  @Default_Zero(V_WCFAC)
                  @RtvFldDesc("CFCO#=$(V_WCCO) and CFFAC#=$(V_WCFAC)", "HDCFAC", "CFCFNM", coFacDesc)
                  @SetTextOvr(Err_WCCO)
                  <tr><td class="dsphdr"><span $(textOvr)>Company/Facility</span></td>
                      <td class="inputnmbr"><input name="companyNumber" value="$(V_WCCO)" type="text" size="2" maxlength="2"> / <input name="facilityNumber" value="$(V_WCFAC)" type="text" size="2" maxlength="4"> <a href="$(homeURL)$(phpPath)CoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=companyNumber&amp;fldFac=facilityNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="coFacDesc" value="$(coFacDesc)"  type="text" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_WCCO)

                  @RtvFldDesc("SMSCHD=$(V_WCSCHD)", "HDSCHM", "SMDESC", scheduleDesc)
                  @SetTextOvr(Err_WCSCHD)
                  <tr><td class="dsphdr"><span $(textOvr)>Schedule</span></td>
                      <td class="inputnmbr"><input name="schedule" value="$(V_WCSCHD)" type="text" size="5" maxlength="3"><a href="$(homeURL)$(phpPath)ScheduleSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=schedule&amp;fldDesc=scheduleDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="scheduleDesc" value="$(scheduleDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_WCSCHD)
                  
                  @SetTextOvr(Err_WXAVLC)
                  <tr><td class="dsphdr"><span $(textOvr)>Check Capacity Availability</span></td>
                      @dtw_tb_rows(yn02Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn02Table, x, "1") != V_WXAVLC) && (x < maxRows))
                            {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn02Table, "checkCapAvail", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_WXAVLC)

                  @SetTextOvr(Err_WXWDPD)
                  <tr><td class="dsphdr"><span $(textOvr)># Weeks Of Daily Periods</span></td>
                      <td class="inputnmbr"><input type="text" name="weeksDailyPeriod" value="$(V_WXWDPD)" size="2" maxlength="2"></td>
                  </tr>
                  @DspErrMsg(Err_WXWDPD)

                  @SetTextOvr(Err_WXWWPD)
                  <tr><td class="dsphdr"><span $(textOvr)># Weeks Of Weekly Periods</span></td>
                      <td class="inputnmbr"><input type="text" name="weeksWeeklyPeriod" value="$(V_WXWWPD)" size="2" maxlength="2"></td>
                  </tr>
                  @DspErrMsg(Err_WXWWPD)
                  
              %}	
          </table>
        <script TYPE="text/javascript">
          document.Chg.$(focusField).focus();
        </script>
      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HPD016_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if ((sec_02 == "N" && sec_03 == "N" && maintenanceCode != "A") || (sec_01 == "N" && maintenanceCode == "A") || (sec_04 == "N" && maintenanceCode == "Z"))
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)ProgOptSecError.d2w/DISPLAY$(genericVarBase)&amp;page_title=@dtw_rurlescseq(page_title)">
  %else
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @yn02_Table_Query(profileHandle, dataBaseID, "YORN      ", yn02Table)
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(department)
  @dtw_mUPPERCASE(workCenter)
  @dtw_mUPPERCASE(checkCapAvail)

  @dtw_assign(plantNumber,       @dtw_rstrip(plantNumber))
  @dtw_assign(laborUtilization,  @dtw_rstrip(laborUtilization))
  @dtw_assign(laborEfficiency,   @dtw_rstrip(laborEfficiency))
  @dtw_assign(laborHours,        @dtw_rstrip(laborHours))
  @dtw_assign(machineUtilization,@dtw_rstrip(machineUtilization))
  @dtw_assign(machineHours,      @dtw_rstrip(machineHours))
  @dtw_assign(setupHours,        @dtw_rstrip(setupHours))
  @dtw_assign(transitDays,       @dtw_rstrip(transitDays))
  @dtw_assign(companyNumber,     @dtw_rstrip(companyNumber))
  @dtw_assign(facilityNumber,    @dtw_rstrip(facilityNumber))
  @dtw_assign(schedule,          @dtw_rstrip(schedule))
  @dtw_assign(weeksDailyPeriod,  @dtw_rstrip(weeksDailyPeriod))
  @dtw_assign(weeksWeeklyPeriod, @dtw_rstrip(weeksWeeklyPeriod))
  

  %if (laborUtilization != "0" && laborUtilization != "")
      @dtw_Divide(laborUtilization, "100", laborUtilization)
  %endif
  %if (laborEfficiency != "0" && laborEfficiency != "")
      @dtw_Divide(laborEfficiency, "100", laborEfficiency)
  %endif
  %if (machineUtilization != "0" && machineUtilization != "")
      @dtw_Divide(machineUtilization, "100", machineUtilization)
  %endif

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@dept", department)
  @Concat_Field("@@wc@@", workCenter)
  @Concat_Field("@@desc", description)
  @Concat_Field("@@laut", laborUtilization)
  @Concat_Field("@@laef", laborEfficiency)
  @Concat_Field("@@lhrd", laborHours)
  @Concat_Field("@@maut", machineUtilization)
  @Concat_Field("@@mhrd", machineHours)
  @Concat_Field("@@shrd", setupHours)
  @Concat_Field("@@mtd@", transitDays)
  @Concat_Field("@@klcd", keyLoadCode)
  @Concat_Field("@@co@@", companyNumber)
  @Concat_Field("@@fac@", facilityNumber)
  @Concat_Field("@@schd", schedule)
  @Concat_Field("@@avlc", checkCapAvail)
  @Concat_Field("@@wdpd", weeksDailyPeriod)
  @Concat_Field("@@wwpd", weeksWeeklyPeriod)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(description), "$(department) - $(workCenter)", "in $(plantName)", $(plantNumber), "", "", confMessage)
      %else
          @DecatErr_Field("@@dept", "department")
          @Format_ConfMsg_Desc("", $(description), "$(department) - $(workCenter)", "in $(plantName)", $(plantNumber), "<br>$(fieldValue)", "", confMessage)
      %endif
      %if (fromSel == "Y" && maintenanceCode != "D")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)WorkCenterSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;plantName=@dtw_rurlescseq(plantName)&amp;department=@dtw_rurlescseq(department)&amp;workCenter=@dtw_rurlescseq(workCenter)&amp;description=@dtw_rurlescseq(description)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
          %if (backURL == "")
              <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=218&amp;fKey1=WCPLT&amp;fVal1=@dtw_rurlescseq(fromPlant)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %else
              <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %endif
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;department=@dtw_rurlescseq(department)&amp;workCenter=@dtw_rurlescseq(workCenter)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
