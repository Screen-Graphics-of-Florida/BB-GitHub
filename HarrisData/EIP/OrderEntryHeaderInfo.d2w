*********************************************************************
%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Order Entry - Header Information"
  d2wName                 = "OrderEntryHeaderInfo.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
  userHeaderTable         = %table
  userHeaderCount         = ""
  userHeaderFields        = ""
  V_CMRREF                = ""
  V_CEACOM                = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@customerName", "@dtw_rurlescseq(customerName)", "1", "a", workURL)
  @dtw_replace(workURL, "@@customerNumber", "@dtw_rurlescseq(customerNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@orderBy", "@dtw_rurlescseq(orderBy)", "1", "a", workURL)
  @dtw_replace(workURL, "@@orderControlNumber", "@dtw_rurlescseq(orderControlNumber)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          @RtvFldDesc("CEACOM<>' '", "OECTRL", "CEACOM", V_CEACOM)
          @RtvFldDesc("H1OCTL=$(orderControlNumber)", "OEHDWK", "H1ORTY", orderType)
          @User_Header_Query(profileHandle, dataBaseID, orderControlNumber, userHeaderTable)
          @dtw_tb_rows(userHeaderTable, userHeaderCount)
          @dtw_assign(recCnt, "1")
          @dtw_assign(userHeaderFields, "")
          %while(recCnt <= userHeaderCount) {
              @dtw_tb_getv(userHeaderTable, recCnt, "1", V_UMFSEQ)
              @dtw_concat(userHeaderFields, "@@$(V_UMFSEQ)", userHeaderFields)
              @dtw_add(recCnt, "1", recCnt)
          %}
          @RtvFldDesc("CMCUST=$(customerNumber)", "HDCUST", "CMRREF", V_CMRREF)
	   %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (
                      %if (@dtw_rpos("@@60", userHeaderFields) > "0")
                          document.Chg.termsCode.value =="" ||
                      %endif
                      %if (@dtw_rpos("@@90", userHeaderFields) > "0")
                          document.Chg.shipVia.value =="" ||
                      %endif
                      %if (@dtw_rpos("@@100", userHeaderFields) > "0" && V_CEACOM == "Y")
                          document.Chg.salesmanNumber.value =="" ||
                      %endif
                      %if (@dtw_rpos("@@140", userHeaderFields) > "0")
                          document.Chg.taxCode.value =="" ||
                      %endif
                      %if (@dtw_rpos("@@260", userHeaderFields) > "0")
                          document.Chg.fobCode.value =="" ||
                      %endif
                      %if (V_CMRREF == "Y" && @dtw_rpos("@@50", userHeaderFields) > "0")
                          document.Chg.referenceNumber.value =="" ||
                      %endif
                      document.Chg.octl.value ==""
                      )
                     {alert("$(reqFieldError)"); return false;}
                  if (
                      editNum(document.Chg.octl, 8, 0)
                      %if (orderType == "R")
                          && editZero(document.Chg.recurDays, 3, 0)
                          && editdate(document.Chg.startDate)
                          && editdate(document.Chg.endDate)
                      %endif
                      %if (@dtw_rpos("@@40", userHeaderFields) > "0")
                          && editdate(document.Chg.reqDate)
                      %endif
                      %if (@dtw_rpos("@@360", userHeaderFields) > "0")
                          && editdate(document.Chg.orderDate)
                      %endif
                      %if (@dtw_rpos("@@80", userHeaderFields) > "0")
                          && editNum(document.Chg.discountPercent, 3, 4)
                      %endif
                      %if (@dtw_rpos("@@100", userHeaderFields) > "0" && V_CEACOM == "Y")
                          && editNum(document.Chg.salesmanNumber, 7, 0)
                      %endif
                      %if (@dtw_rpos("@@110", userHeaderFields) > "0" && V_CEACOM == "Y")
                          && editNum(document.Chg.commissionPercent, 3, 4)
                      %endif
                      %if (@dtw_rpos("@@120", userHeaderFields) > "0" && V_CEACOM == "Y")
                          && editNum(document.Chg.splitSalesmanNumber, 7, 0)
                      %endif
                      %if (@dtw_rpos("@@130", userHeaderFields) > "0" && V_CEACOM == "Y")
                          && editNum(document.Chg.splitCommissionPercent, 3, 4)
                      %endif
                      %if (@dtw_rpos("@@270", userHeaderFields) > "0")
                          && editdate(document.Chg.userDate2)
                      %endif
                      %if (@dtw_rpos("@@280", userHeaderFields) > "0")
                          && editdate(document.Chg.userDate3)
                      %endif
                      %if (@dtw_rpos("@@290", userHeaderFields) > "0")
                          && editdate(document.Chg.userDate4)
                      %endif
                      )
                      return true;
              }
              %INCLUDE "NumZero.icl"
              %INCLUDE "numedit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "NewWindowOpen.icl"
              function confirmCancel() { return confirm("Confirm Cancel Of Order")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ORDERHEADER")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "Select * From OEHDWK Where H1OCTL=$(orderControlNumber)")
                      %INCLUDE "stmtSQLEnd.icl"
                      @Order_Header_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Order_Header_Query (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  <a href="javascript:check(document.Chg)">$(orderContinueImage)</a>
                  <a href="$(homeURL)$(cGIPath)OrderEntryComments.d2w/COMMENTS$(d2wVarBase)&amp;lineNumber=000">$(commentHdrImageLrg)</a>
                  <a href="$(homeURL)$(cGIPath)OrderEntryComments.d2w/COMMENTS$(d2wVarBase)&amp;lineNumber=999">$(commentTrlImageLrg)</a>
                  <a onClick="return confirmCancel()" href="$(homeURL)$(cGIPath)OrderEntryOrderReview.d2w/CANCEL$(d2wVarBase)">$(orderCancelImage)</a>
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>

      %INCLUDE "OrderEntryHeader.icl"

      $(hrTagAttr)

      %ROW {
          %INCLUDE "OrderEntryRetInfo.icl"

          %INCLUDE "OrderEntryNameAddress.icl"
          %INCLUDE "RequiredField.icl"
          %INCLUDE "ErrorDisplay.icl"

          %if (errFound != "")
              @dtw_assign(focusField, "")
              @EdtVarErr(profileHandle, typeValue, edtVar)
              @ErrVarErr(profileHandle, typeError, errVar)
          %endif

      <form class="formClass" METHOD=POST name="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintCode=@dtw_rurlescseq(V_H1MNCD)&amp;userHeaderFields=@dtw_rurlescseq(userHeaderFields)&amp;orderType=@dtw_rurlescseq(V_H1ORTY)">
          <table $(contentTable)>
              %if (V_H1ORD#>"0")
                  <tr>
                      <td class="dsphdr">Order Number</td>
                      <td class="dspalph">$(V_H1ORD#)</td>
                  </tr>
              %endif

              %if (V_H1ORTY == "R")
                  %if (errFound != "")
                      @DecatErr_Field("@@orry", "recurDays")  @dtw_assign(Err_H1ORRY, fieldValue)
                      @Decat_Field("@@orry")                  @dtw_assign(V_H1ORRY, fieldValue)
                  %endif
                  @SetTextOvr(Err_H1ORRY)
                  <tr><td class="dsphdr"><span $(textOvr)>Recurring Days</span></td>
                      <td class="inputnmbr"><input name="recurDays" type="text" value="$(V_H1ORRY)" size="3" maxlength="3">$(reqFieldChar)</td>
                      @DspErrMsg(Err_H1ORRY)
                  </tr>

                  %if (errFound != "")
                      @DecatErr_Field("@@rsdt", "startDate")  @dtw_assign(Err_H1RSDT, fieldValue)
                      @Decat_Field("@@rsdt")                  @dtw_assign(V_H1RSDT, fieldValue)
                  %else
                      @DateInputFromCYMD(V_H1RSDT)
                  %endif
                  @SetTextOvr(Err_H1RSDT)
                  <tr><td class="dsphdr"><span $(textOvr)>Start Date</span></td>
                      <td class="inputalph"><input name="startDate" type="text" value="$(V_H1RSDT)" size="6" maxlength="6">
                          <a href="javascript:calWindow('startDate');"> $(calendarImage) </a>
                      </td>
                      @DspErrMsg(Err_H1RSDT)
                  </tr>

                  %if (errFound != "")
                      @DecatErr_Field("@@redt", "endDate")  @dtw_assign(Err_H1REDT, fieldValue)
                      @Decat_Field("@@redt")                @dtw_assign(V_H1REDT, fieldValue)
                  %else
                      @DateInputFromCYMD(V_H1REDT)
                  %endif
                  @SetTextOvr(Err_H1REDT)
                  <tr><td class="dsphdr"><span $(textOvr)>End Date</span></td>
                      <td class="inputalph"><input name="endDate" type="text" value="$(V_H1REDT)" size="6" maxlength="6">
                          <a href="javascript:calWindow('endDate');"> $(calendarImage) </a>
                      </td>
                      @DspErrMsg(Err_H1REDT)
                  </tr>
              %endif

              @dtw_assign(recCnt, "1")
              %while(recCnt <= userHeaderCount) {
                  @dtw_tb_getv(userHeaderTable, recCnt, "1", V_UMFSEQ)

                  %if (V_UMFSEQ == "40")
                      %if (errFound != "")
                          @DecatErr_Field("@@rqdt", "reqDate")    @dtw_assign(Err_H1RQDT, fieldValue)
                          @Decat_Field("@@rqdt")                  @dtw_assign(V_H1RQDT, fieldValue)
                      %else
                          @DateInputFromCYMD(V_H1RQDT)
                      %endif
                      @SetTextOvr(Err_H1RQDT)
                      <tr>
                          <td class="dsphdr"><span $(textOvr)>Required Date</span></td>
                          <td class="inputnmbr"><input type="text" name="reqDate" value="$(V_H1RQDT)" size="6" maxlength="6">
                              <a href="javascript:calWindow('reqDate');"> $(reqFieldChar) $(calendarImage) </a>
                          </td>
                          @DspErrMsg(Err_H1RQDT)
                      </tr>

                  %elseif (V_UMFSEQ == "360")
                      %if (errFound != "")
                          @DecatErr_Field("@@ordt", "orderDate")  @dtw_assign(Err_H1BDTE, fieldValue)
                          @Decat_Field("@@ordt")                  @dtw_assign(V_H1BDTE, fieldValue)
                      %else
                          @DateInputFromCYMD(V_H1BDTE)
                      %endif
                      @SetTextOvr(Err_H1BDTE)
                      <tr>
                          <td class="dsphdr"><span $(textOvr)>Order Date</span></td>
                          <td class="inputnmbr"><input type="text" name="orderDate" value="$(V_H1BDTE)" size="6" maxlength="6">
                              <a href="javascript:calWindow('orderDate');"> $(reqFieldChar) $(calendarImage) </a>
                          </td>
                          @DspErrMsg(Err_H1BDTE)
                      </tr>

                  %elseif (V_UMFSEQ == "50")
                      %if (V_CMRREF == "Y")
                          @dtw_assign(refReq,  "$(reqFieldChar)")
                      %else
                          @dtw_assign(refReq,  "")
                      %endif
                      %if (errFound != "")
                          @DecatErr_Field("@@orrf", "referenceNumber")  @dtw_assign(Err_H1ORRF, fieldValue)
                          @Decat_Field("@@orrf")                        @dtw_assign(V_H1ORRF, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1ORRF)
                      <tr>
    	   	           <td class="dsphdr"><span $(textOvr)>Reference Number</span></td>
                          <td class="inputalph"><input type="text" name="referenceNumber" value="$(V_H1ORRF)" size="31" maxlength="22"> $(refReq)</td>
                          @DspErrMsg(Err_H1ORRF)
                      </tr>
	   		     		
                  %elseif (V_UMFSEQ == "60")
                      %if (errFound != "")
                          @DecatErr_Field("@@ctrm", "termsCode")  @dtw_assign(Err_H1CTRM, fieldValue)
                          @Decat_Field("@@ctrm")                  @dtw_assign(V_H1CTRM, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1CTRM)
                      <tr>
                          @RtvFldDesc("TMCTRM='$(V_H1CTRM)'", "HDTRMS", "TMCTDS", fieldDesc)
                          <td class="dsphdr"><span $(textOvr)>Terms Code</span></td>
                          <td class="inputnmbr"><input name="termsCode" type="text" value="$(V_H1CTRM)" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)TermsCodeSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=termsCode&amp;fldDesc=termsCodeDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input name="termsCodeDesc" value="$(fieldDesc)" type="text" size="20" disabled></td>
                          @DspErrMsg(Err_H1CTRM)
                      </tr>

                  %elseif (V_UMFSEQ == "70")
                      %if (errFound != "")
                          @DecatErr_Field("@@boal", "allowBackorders")  @dtw_assign(Err_H1BOAL, fieldValue)
                          @Decat_Field("@@boal")                        @dtw_assign(V_H1BOAL, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1BOAL)
                      <tr>
                          <td class="dsphdr"><span $(textOvr)>Allow Backorders</span></td>
                          @dtw_tb_rows(yn01Table, maxRows)
 	                   @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_H1BOAL) && (x < maxRows)) {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(yn01Table, "allowBackorders", "2", "1", "N", "", x, "1")</td>
                          @DspErrMsg(Err_H1BOAL)
                      </tr>

                  %elseif (V_UMFSEQ == "80")
                      %if (errFound != "")
                          @DecatErr_Field("@@dspc", "discountPercent")  @dtw_assign(Err_H1DSPC, fieldValue)
                          @Decat_Field("@@dspc")                        @dtw_assign(V_H1DSPC, fieldValue)
                      %else
                          @dtw_assign(V_H1DSPC, @dtw_rformat(@dtw_rmultiply(V_H1DSPC, "100"),"","4"))
                      %endif
                      @SetTextOvr(Err_H1DSPC)
                      <tr>
                          <td class="dsphdr"><span $(textOvr)>Discount Percent</span></td>
                          <td class="inputnmbr"><input type="text" name="discountPercent" value="$(V_H1DSPC)" size="9" maxlength="9"></td>
                          @DspErrMsg(Err_H1DSPC)
                      </tr>

                  %elseif (V_UMFSEQ == "90")
                      %if (errFound != "")
                          @DecatErr_Field("@@svsv", "shipVia")  @dtw_assign(Err_H1SVSV, fieldValue)
                          @Decat_Field("@@svsv")                @dtw_assign(V_H1SVSV, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1SVSV)
                      <tr>
                          @RtvFldDesc("SVSVSV='$(V_H1SVSV)'", "HDSHPV", "SVSVDS", fieldDesc)
                          <td class="dsphdr"><span $(textOvr)>Ship Via</span></td>
                          <td class="inputnmbr"><input name="shipVia" type="text" value="$(V_H1SVSV)" size="3" maxlength="2"><a href="$(homeURL)$(cGIPath)ShipViaSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=shipVia&amp;fldDesc=shipViaDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input name="shipViaDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                          @DspErrMsg(Err_H1SVSV)
                      </tr>

                  %elseif (V_UMFSEQ == "100" && V_CEACOM == "Y")
                      %if (errFound != "")
                          @DecatErr_Field("@@slsm", "salesmanNumber")  @dtw_assign(Err_H1SLSM, fieldValue)
                          @Decat_Field("@@slsm")                       @dtw_assign(V_H1SLSM, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1SLSM)
                      <tr>
                          @Default_Zero(V_H1SLSM)
                          @RtvFldDesc("SMSLSM=$(V_H1SLSM)", "HDSLSM", "SMSNA1", fieldDesc)
                          <td class="dsphdr"><span $(textOvr)>Salesman</span></td>
                          <td class="inputnmbr"><input name="salesmanNumber" type="text" value="$(V_H1SLSM)" size="3" maxlength="3"><a href="$(homeURL)$(cGIPath)salesmansearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=salesmanNumber&amp;fldDesc=salesmanName" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input name="salesmanName" value="$(fieldDesc)" type="text" size="35" disabled></td>
                          @DspErrMsg(Err_H1SLSM)
                      </tr>

                  %elseif (V_UMFSEQ == "110" && V_CEACOM == "Y")
                      %if (errFound != "")
                          @DecatErr_Field("@@smpc", "commissionPercent")  @dtw_assign(Err_H1SMPC, fieldValue)
                          @Decat_Field("@@smpc")                          @dtw_assign(V_H1SMPC, fieldValue)
                      %else
                          @dtw_assign(V_H1SMPC, @dtw_rformat(@dtw_rmultiply(V_H1SMPC, "100"),"","4"))
                      %endif
                      @SetTextOvr(Err_H1SMPC)
                      <tr>
                          <td class="dsphdr"><span $(textOvr)>Commission Percent</span></td>
                          <td class="inputnmbr"><input type="text" name="commissionPercent" value="$(V_H1SMPC)" size="9" maxlength="9"></td>
                          @DspErrMsg(Err_H1SMPC)
                      </tr>

                  %elseif (V_UMFSEQ == "120" && V_CEACOM == "Y")
                      %if (errFound != "")
                          @DecatErr_Field("@@sls1", "splitSalesmanNumber")  @dtw_assign(Err_H1SLS1, fieldValue)
                          @Decat_Field("@@sls1")                            @dtw_assign(V_H1SLS1, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1SLS1)
                      <tr>
                          @Default_Zero(V_H1SLS1)
                          @RtvFldDesc("SMSLSM=$(V_H1SLS1)", "HDSLSM", "SMSNA1", fieldDesc)
                          <td class="dsphdr"><span $(textOvr)>Split Salesman</span></td>
                          <td class="inputnmbr"><input name="splitSalesmanNumber" type="text" value="$(V_H1SLS1)" size="3" maxlength="3"><a href="$(homeURL)$(cGIPath)salesmansearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=splitSalesmanNumber&amp;fldDesc=splitSalesmanName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="splitSalesmanName" value="$(fieldDesc)" type="text" size="35" disabled></td>
                          @DspErrMsg(Err_H1SLS1)
                      </tr>

                  %elseif (V_UMFSEQ == "130" && V_CEACOM == "Y")
                      %if (errFound != "")
                          @DecatErr_Field("@@sspc", "splitCommissionPercent")  @dtw_assign(Err_H1SSPC, fieldValue)
                          @Decat_Field("@@sspc")                               @dtw_assign(V_H1SSPC, fieldValue)
                      %else
                          @dtw_assign(V_H1SSPC, @dtw_rformat(@dtw_rmultiply(V_H1SSPC, "100"),"","4"))
                      %endif
                      @SetTextOvr(Err_H1SSPC)
                      <tr>
                          <td class="dsphdr"><span $(textOvr)>Split Commission Percent</span></td>
                          <td class="inputnmbr"><input type="text" name="splitCommissionPercent" value="$(V_H1SSPC)" size="9" maxlength="9"></td>
                          @DspErrMsg(Err_H1SSPC)
                      </tr>

                  %elseif (V_UMFSEQ == "140")
                      %if (errFound != "")
                          @DecatErr_Field("@@ctxc", "taxCode")  @dtw_assign(Err_H1CTXC, fieldValue)
                          @Decat_Field("@@ctxc")                @dtw_assign(V_H1CTXC, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1CTXC)
                      <tr>
                          @RtvFldDesc("TCCODE='$(V_H1CTXC)'", "HDTAXC", "TCDESC", fieldDesc)
                          <td class="dsphdr"><span $(textOvr)>Tax Code</span></td>
                          <td class="inputalph"><input name="taxCode" type="text" value="$(V_H1CTXC)" size="2" maxlength="1"><a href="$(homeURL)$(cGIPath)TaxCodeSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=taxCode&amp;fldDesc=taxCodeDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input name="taxCodeDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                          @DspErrMsg(Err_H1CTXC)
                      </tr>
	   		
                  %elseif (V_UMFSEQ == "150")
                      %if (errFound != "")
                          @DecatErr_Field("@@cntx", "taxDefDesc")  @dtw_assign(Err_H1CNTX, fieldValue)
                          @Decat_Field("@@cntx")                   @dtw_assign(V_H1CNTX, fieldValue)
                          @Decat_Field("@@cttx")                   @dtw_assign(V_H1CTTX, fieldValue)
                          @Decat_Field("@@loc1")                   @dtw_assign(V_H1LOC1, fieldValue)
                          @Decat_Field("@@loc2")                   @dtw_assign(V_H1LOC2, fieldValue)
                          @Decat_Field("@@loc3")                   @dtw_assign(V_H1LOC3, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1CNTX)
                      <tr>
                          @Default_Zero(V_H1CNTX)
                          @Default_Zero(V_H1CTTX)
                          @Default_Zero(V_H1LOC1)
                          @Default_Zero(V_H1LOC2)
                          @Default_Zero(V_H1LOC3)
                          @RtvFldDesc("TDSTCD='$(V_H1STTX)' and TDCNYC=$(V_H1CNTX) and TDCTYC=$(V_H1CTTX) and TDLOC1=$(V_H1LOC1) and TDLOC2=$(V_H1LOC2) and TDLOC3=$(V_H1LOC3)", "HDTAXD", "TDTDSC", fieldDesc)
                          <td class="dsphdr"><span $(textOvr)>Tax Definition</span></td>
                          <td class="inputnmbr"><input name="taxDefDesc" value="$(fieldDesc)" type="text" size="35" disabled><input name="stateCode" type="hidden" value="$(V_H1STTX)" size="2" maxlength="2"><input name="countyTaxCode" type="hidden" value="$(V_H1CNTX)" size="3" maxlength="3"><input name="cityTaxCode" type="hidden" value="$(V_H1CTTX)" size="5" maxlength="5"><input name="loc1Code" type="hidden" value="$(V_H1LOC1)" size="4" maxlength="4"><input name="loc2Code" type="hidden" value="$(V_H1LOC2)" size="4" maxlength="4"><input name="loc3Code" type="hidden" value="$(V_H1LOC3)" size="4" maxlength="4"><a href="$(homeURL)$(cGIPath)TaxDefinitionSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;forState=@dtw_rurlescseq(V_H1STTX)&amp;fldState=stateCode&amp;fldCnty=countyTaxCode&amp;fldCity=cityTaxCode&amp;fldLoc1=loc1Code&amp;fldLoc2=loc2Code&amp;fldLoc3=loc3Code&amp;fldDesc=taxDefDesc" onclick="$(searchWinVar)"> $(searchImage) </a></td>
                          @DspErrMsg(Err_H1CNTX)
                      </tr>

                  %elseif (V_UMFSEQ == "210")
                      %if (errFound != "")
                          @DecatErr_Field("@@mail", "mailingCode")  @dtw_assign(Err_H1MAIL, fieldValue)
                          @Decat_Field("@@mail")                    @dtw_assign(V_H1MAIL, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1MAIL)
                      <tr>
                          <td class="dsphdr"><span $(textOvr)>Mailing Code</span></td>
                          <td class="inputalph"><input type="text" name="mailingCode" value="$(V_H1MAIL)" size="5" maxlength="5"></td>
                          @DspErrMsg(Err_H1MAIL)
                      </tr>

                  %elseif (V_UMFSEQ == "220")
                      %if (errFound != "")
                          @DecatErr_Field("@@cctp", "creditCardType")  @dtw_assign(Err_H1CCTP, fieldValue)
                          @Decat_Field("@@cctp")                       @dtw_assign(V_H1CCTP, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1CCTP)
                      <tr>
                          @RtvFldDesc("OECCTP='$(V_H1CCTP)'", "OECCTM", "OECCDS", fieldDesc)
  	                   <td class="dsphdr">Credit Card Type</td>
                          <td class="inputalph"><input name="creditCardType" type="text" value="$(V_H1CCTP)" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)CreditCardTypeSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=creditCardType&amp;fldDesc=creditCardTypeDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="creditCardTypeDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                          @DspErrMsg(Err_H1CCTP)
                      </tr>

                  %elseif (V_UMFSEQ == "230")
                      %if (errFound != "")
                          @DecatErr_Field("@@ccno", "creditCardNumber")  @dtw_assign(Err_H1CCNO, fieldValue)
                          @Decat_Field("@@ccno")                         @dtw_assign(V_H1CCNO, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1CCNO)
                      <tr>
                          <td class="dsphdr"><span $(textOvr)>Credit Card Number</span></td>
                          <td class="inputalph"><input type="text" name="creditCardNumber" value="$(V_H1CCNO)" size="16" maxlength="16"></td>
                          @DspErrMsg(Err_H1CCNO)
                      </tr>

                  %elseif (V_UMFSEQ == "240")
                      %if (errFound != "")
                          @DecatErr_Field("@@cced", "creditCardExpMonth")  @dtw_assign(Err_H1CCED, fieldValue)
                          @Decat_Field("@@cced")                           @dtw_assign(V_H1CCED, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1CCED)
                      <tr>
                          @dtw_assign(ccmm, @dtw_rsubstr(V_H1CCED, "4", "2"))
                          @dtw_assign(ccyy, @dtw_rsubstr(V_H1CCED, "2", "2"))

                          <td class="dsphdr"><span $(textOvr)>Expiration Month/Year</span></td>
                          @dtw_assign(x, "0")
                          @dtw_assign(y, "0")
                          <td class="inputnmbr">
                              <SELECT NAME="creditCardExpMonth" SIZE=1>
                                  %while(x <= "12"){
                                      %if (@dtw_rlength(x) == "1")
                                          @dtw_insert("0", x, x)
                                      %endif
                                      %if (x == "$(ccmm)")
                                          @dtw_assign(sel, "SELECTED")
                                      %else
                                          @dtw_assign(sel, "")
                                      %endif
                                      <OPTION VALUE="$(x)" $(sel)>$(x)
                                      @dtw_add(x, "1", x)
                                  %}
                              </SELECT>
                              /
                              <SELECT NAME="creditCardExpYear" SIZE=1>
                                  %while(y <= "10"){
                                      %if (@dtw_rlength(y) == "1")
                                          @dtw_insert("0", y, y)
                                      %endif
                                      %if (y == "$(ccyy)")
                                          @dtw_assign(sel, "SELECTED")
                                      %else
                                          @dtw_assign(sel, "")
                                      %endif
                                      <OPTION VALUE="$(y)" $(sel)>$(y)
                                      %if (y=="0")
                                          @dtw_assign(y, @dtw_rsubstr(@dtw_rdate("O"), "1", "2"))
                                      %else
                                          @dtw_add(y, "1", y)
                                      %endif
                                  %}
                              </SELECT>
                          </td>
                          @DspErrMsg(Err_H1CCED)
                      </tr>

                  %elseif (V_UMFSEQ == "250")
                      %if (errFound != "")
                          @DecatErr_Field("@@ccac", "creditCardAuth")  @dtw_assign(Err_H1CCAC, fieldValue)
                          @Decat_Field("@@ccac")                       @dtw_assign(V_H1CCAC, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1CCAC)
                      <tr>
                          <td class="dsphdr"><span $(textOvr)>Authorization Code</span></td>
                          <td class="inputalph"><input type="text" name="creditCardAuth" value="$(V_H1CCAC)" size="8" maxlength="8"></td>
                          @DspErrMsg(Err_H1CCAC)
                      </tr>

                  %elseif (V_UMFSEQ == "260")
                      %if (errFound != "")
                          @DecatErr_Field("@@fbcd", "fobCode")  @dtw_assign(Err_H1FBCD, fieldValue)
                          @Decat_Field("@@fbcd")                @dtw_assign(V_H1FBCD, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1FBCD)
                      <tr>
                          @RtvFldDesc("FBFBCD='$(V_H1FBCD)'", "HDFOBM", "FBFBDS", fieldDesc)
                          <td class="dsphdr"><span $(textOvr)>FOB Code</span></td>
                          <td class="inputalph"><input name="fobCode" type="text" value="$(V_H1FBCD)" size="3" maxlength="2"><a href="$(homeURL)$(cGIPath)FOBCodeSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fobCode&amp;fldDesc=fobCodeDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input name="fobCodeDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                          @DspErrMsg(Err_H1FBCD)
                      </tr>

                  %elseif (V_UMFSEQ == "270")
                      %if (errFound != "")
                          @DecatErr_Field("@@dte2", "userDate2")  @dtw_assign(Err_H1DTE2, fieldValue)
                          @Decat_Field("@@dte2")                  @dtw_assign(V_H1DTE2, fieldValue)
                      %else
                          @DateInputFromCYMD(V_H1DTE2)
                      %endif
                      @SetTextOvr(Err_H1DTE2)
                      <tr>
                          <td class="dsphdr"><span $(textOvr)>$(userDateDesc1)</span></td>
                          <td class="inputnmbr"><input type="text" name="userDate2" value="$(V_H1DTE2)" size="6" maxlength="6">
                              <a href="javascript:calWindow('userDate2');">$(calendarImage)</a>
                          </td>
                          @DspErrMsg(Err_H1DTE2)
                      </tr>

                  %elseif (V_UMFSEQ == "280")
                      %if (errFound != "")
                          @DecatErr_Field("@@dte3", "userDate3")  @dtw_assign(Err_H1DTE3, fieldValue)
                          @Decat_Field("@@dte3")                  @dtw_assign(V_H1DTE3, fieldValue)
                      %else
                          @DateInputFromCYMD(V_H1DTE3)
                      %endif
                      @SetTextOvr(Err_H1DTE3)
                      <tr>
                          <td class="dsphdr"><span $(textOvr)>$(userDateDesc2)</span></td>
                          <td class="inputnmbr"><input type="text" name="userDate3" value="$(V_H1DTE3)" size="6" maxlength="6">
                              <a href="javascript:calWindow('userDate3');">$(calendarImage)</a>
                          </td>
                          @DspErrMsg(Err_H1DTE3)
                      </tr>

                  %elseif (V_UMFSEQ == "290")
                      %if (errFound != "")
                          @DecatErr_Field("@@dte4", "userDate4")  @dtw_assign(Err_H1DTE4, fieldValue)
                          @Decat_Field("@@dte4")                  @dtw_assign(V_H1DTE4, fieldValue)
                      %else
                          @DateInputFromCYMD(V_H1DTE4)
                      %endif
                      @SetTextOvr(Err_H1DTE4)
                      <tr>
                          <td class="dsphdr"><span $(textOvr)>$(userDateDesc3)</span></td>
                          <td class="inputnmbr"><input type="text" name="userDate4" value="$(V_H1DTE4)" size="6" maxlength="6">
                              <a href="javascript:calWindow('userDate4');">$(calendarImage)</a>
                          </td>
                          @DspErrMsg(Err_H1DTE4)
                      </tr>

                  %elseif (V_UMFSEQ == "300" && userAlphaDesc1 != "")
                      %if (errFound != "")
                          @DecatErr_Field("@@udf1", "userAlpha1")  @dtw_assign(Err_H1UDF1, fieldValue)
                          @Decat_Field("@@udf1")                   @dtw_assign(V_H1UDF1, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1UDF1)
                      <tr>
    	   	           <td class="dsphdr"><span $(textOvr)>$(userAlphaDesc1)</span></td>
                          <td class="inputalph"><input type="text" name="userAlpha1" value="$(V_H1UDF1)" size="22" maxlength="15"></td>
                          @DspErrMsg(Err_H1UDF1)
                      </tr>

                  %elseif (V_UMFSEQ == "310" && userAlphaDesc2 != "")
                      %if (errFound != "")
                          @DecatErr_Field("@@udf2", "userAlpha2")  @dtw_assign(Err_H1UDF2, fieldValue)
                          @Decat_Field("@@udf2")                   @dtw_assign(V_H1UDF2, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1UDF2)
                      <tr>
    	   	           <td class="dsphdr"><span $(textOvr)>$(userAlphaDesc2)</span></td>
                          <td class="inputalph"><input type="text" name="userAlpha2" value="$(V_H1UDF2)" size="22" maxlength="15"></td>
                          @DspErrMsg(Err_H1UDF2)
                      </tr>

                  %elseif (V_UMFSEQ == "320" && userAlphaDesc3 != "")
                      %if (errFound != "")
                          @DecatErr_Field("@@udf3", "userAlpha3")  @dtw_assign(Err_H1UDF3, fieldValue)
                          @Decat_Field("@@udf3")                   @dtw_assign(V_H1UDF3, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1UDF3)
                      <tr>
    	   	           <td class="dsphdr"><span $(textOvr)>$(userAlphaDesc3)</span></td>
                          <td class="inputalph"><input type="text" name="userAlpha3" value="$(V_H1UDF3)" size="22" maxlength="15"></td>
                          @DspErrMsg(Err_H1UDF3)
                      </tr>

                  %elseif (V_UMFSEQ == "330" && userAlphaDesc4 != "")
                      %if (errFound != "")
                          @DecatErr_Field("@@udf4", "userAlpha4")  @dtw_assign(Err_H1UDF4, fieldValue)
                          @Decat_Field("@@udf4")                   @dtw_assign(V_H1UDF4, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1UDF4)
                      <tr>
    	   	           <td class="dsphdr">$(userAlphaDesc4)</td>
                          <td class="inputalph"><input type="text" name="userAlpha4" value="$(V_H1UDF4)" size="22" maxlength="15"></td>
                          @DspErrMsg(Err_H1UDF4)
                      </tr>

                  %elseif (V_UMFSEQ == "340" && userAlphaDesc5 != "")
                      %if (errFound != "")
                          @DecatErr_Field("@@udf5", "userAlpha5")  @dtw_assign(Err_H1UDF5, fieldValue)
                          @Decat_Field("@@udf5")                   @dtw_assign(V_H1UDF5, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1UDF5)
                      <tr>
    	   	           <td class="dsphdr"><span $(textOvr)>$(userAlphaDesc5)</span></td>
                          <td class="inputalph"><input type="text" name="userAlpha5" value="$(V_H1UDF5)" size="22" maxlength="15"></td>
                          @DspErrMsg(Err_H1UDF5)
                      </tr>

                  %elseif (V_UMFSEQ == "350")
                      %if (errFound != "")
                          @DecatErr_Field("@@hold", "holdCode")  @dtw_assign(Err_H1HOLD, fieldValue)
                          @Decat_Field("@@hold")                 @dtw_assign(V_H1HOLD, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1HOLD)
                      <tr>
                          <td class="dsphdr"><span $(textOvr)>Hold Code</span></td>
                          <td class="inputalph"><input type="text" name="holdCode" value="$(V_H1HOLD)" size="1" maxlength="1"></td>
                          @DspErrMsg(Err_H1HOLD)
                      </tr>
                  %endif
                  @dtw_add(recCnt, "1", recCnt)
              %}
              <tr><td class="inputalph"><input type="hidden" name="octl" value="$(orderControlNumber)"></td></tr>
      %}
      </table>
      %if (focusField != "")
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      %endif
      </form>
      @dtw_assign(errFound, "")
      <table $(contentTable)>
          <tr>
              <td class="toolbar">
                  <a href="javascript:check(document.Chg)">$(orderContinueImage)</a>
                  <a href="$(homeURL)$(cGIPath)OrderEntryComments.d2w/COMMENTS$(d2wVarBase)&amp;lineNumber=000">$(commentHdrImageLrg)</a>
                  <a href="$(homeURL)$(cGIPath)OrderEntryComments.d2w/COMMENTS$(d2wVarBase)&amp;lineNumber=999">$(commentTrlImageLrg)</a>
                  <a onClick="return confirmCancel()" href="$(homeURL)$(cGIPath)OrderEntryOrderReview.d2w/CANCEL$(d2wVarBase)">$(orderCancelImage)</a>
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(DTW_SQL) User_Header_Query(IN  CHAR(64)     profileHandle,
				          CHAR(2)      dataBaseID,
				          DECIMAL(8,0) orderControlNumber,	
				      OUT              userHeaderTable)

  {call $(pgmLibrary)HOEUHR_W
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HOEUHW_W.PGM %}
%}

%HTML(HEADER) {
      %INCLUDE "setLibraryList.icl"
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)">
  %}

%HTML(DISPLAY) {
      %INCLUDE "setLibraryList.icl"
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @yn02_Table_Query(profileHandle, dataBaseID, "YORN      ", yn02Table)
      @yn03_Table_Query(profileHandle, dataBaseID, "YORN      ", yn03Table)
      @yn04_Table_Query(profileHandle, dataBaseID, "YORN      ", yn04Table)
      @yn05_Table_Query(profileHandle, dataBaseID, "YORN      ", yn05Table)

      @Set_SQL(stmtSQL)
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(referenceNumber)
  @dtw_mUPPERCASE(termsCode)
  @dtw_mUPPERCASE(mailingCode)
  @dtw_mUPPERCASE(shipVia)
  @dtw_mUPPERCASE(fobCode)
  @dtw_mUPPERCASE(taxCode)
  @dtw_mUPPERCASE(creditCardType)
  @dtw_mUPPERCASE(creditCardAuth)
  @dtw_mUPPERCASE(userAlpha1)
  @dtw_mUPPERCASE(userAlpha2)
  @dtw_mUPPERCASE(userAlpha3)
  @dtw_mUPPERCASE(userAlpha4)
  @dtw_mUPPERCASE(userAlpha5)
  @dtw_mUPPERCASE(holdCode)

  @dtw_assign(reqDate,@dtw_rstrip(reqDate))
  @dtw_assign(orderDate,@dtw_rstrip(orderDate))
  @dtw_assign(discountPercent,@dtw_rstrip(discountPercent))
  @dtw_assign(salesmanNumber,@dtw_rstrip(salesmanNumber))
  @dtw_assign(commissionPercent,@dtw_rstrip(commissionPercent))
  @dtw_assign(splitSalesmanNumber,@dtw_rstrip(splitSalesmanNumber))
  @dtw_assign(splitCommissionPercent,@dtw_rstrip(splitCommissionPercent))
  @dtw_assign(creditCardExpMonth,@dtw_rstrip(creditCardExpMonth))
  @dtw_assign(creditCardExpYear,@dtw_rstrip(creditCardExpYear))
  @dtw_assign(userDate2,@dtw_rstrip(userDate2))
  @dtw_assign(userDate3,@dtw_rstrip(userDate3))
  @dtw_assign(userDate4,@dtw_rstrip(userDate4))

  @RtvFldDesc("CEACOM<>' '", "OECTRL", "CEACOM", V_CEACOM)
  @dtw_assign(edtVar, "")
  @Concat_Field("@@octl", orderControlNumber)
  @Concat_Field("@@shto", customerNumber)
  %if (orderType == "R")
      @Concat_Field("@@orry", recurDays)
      @Concat_Field("@@rsdt", startDate)
      @Concat_Field("@@redt", endDate)
  %endif
  %if (@dtw_rpos("@@40", userHeaderFields) > "0")
      @Concat_Field("@@rqdt", reqDate)
  %endif
  %if (@dtw_rpos("@@360", userHeaderFields) > "0")
      @Concat_Field("@@ordt", orderDate)
  %endif
  %if (@dtw_rpos("@@50", userHeaderFields) > "0")
      @Concat_Field("@@orrf", referenceNumber)
  %endif
  %if (@dtw_rpos("@@60", userHeaderFields) > "0")
      @Concat_Field("@@ctrm", termsCode)
  %endif
  %if (@dtw_rpos("@@70", userHeaderFields) > "0")
      @Concat_Field("@@boal", allowBackorders)
  %endif
  %if (@dtw_rpos("@@80", userHeaderFields) > "0")
      @Concat_Field("@@dspc", discountPercent)
  %endif
  %if (@dtw_rpos("@@90", userHeaderFields) > "0")
      @Concat_Field("@@svsv", shipVia)
  %endif
  %if (@dtw_rpos("@@100", userHeaderFields) > "0" && V_CEACOM == "Y")
      @Concat_Field("@@slsm", salesmanNumber)
  %endif
  %if (@dtw_rpos("@@110", userHeaderFields) > "0" && V_CEACOM == "Y")
      @Concat_Field("@@smpc", commissionPercent)
  %endif
  %if (@dtw_rpos("@@120", userHeaderFields) > "0" && V_CEACOM == "Y")
      @Concat_Field("@@sls1", splitSalesmanNumber)
  %endif
  %if (@dtw_rpos("@@130", userHeaderFields) > "0" && V_CEACOM == "Y")
      @Concat_Field("@@sspc", splitCommissionPercent)
  %endif
  %if (@dtw_rpos("@@140", userHeaderFields) > "0")
      @Concat_Field("@@ctxc", taxCode)
  %endif
  %if (@dtw_rpos("@@150", userHeaderFields) > "0")
      @Concat_Field("@@sttx", stateCode)
      @Concat_Field("@@cntx", countyTaxCode)
      @Concat_Field("@@cttx", cityTaxCode)
      @Concat_Field("@@loc1", loc1Code)
      @Concat_Field("@@loc2", loc2Code)
      @Concat_Field("@@loc3", loc3Code)
  %endif
  %if (@dtw_rpos("@@210", userHeaderFields) > "0")
      @Concat_Field("@@mail", mailingCode)
  %endif
  %if (@dtw_rpos("@@220", userHeaderFields) > "0")
      @Concat_Field("@@cctp", creditCardType)
  %endif
  %if (@dtw_rpos("@@230", userHeaderFields) > "0")
      @Concat_Field("@@ccno", creditCardNumber)
  %endif
  %if (@dtw_rpos("@@240", userHeaderFields) > "0")
      @Concat_Field("@@ccmm", creditCardExpMonth)
      @Concat_Field("@@ccyy", creditCardExpYear)
  %endif
  %if (@dtw_rpos("@@250", userHeaderFields) > "0")
      @Concat_Field("@@ccac", creditCardAuth)
  %endif
  %if (@dtw_rpos("@@260", userHeaderFields) > "0")
      @Concat_Field("@@fbcd", fobCode)
  %endif
  %if (@dtw_rpos("@@270", userHeaderFields) > "0")
      @Concat_Field("@@dte2", userDate2)
  %endif
  %if (@dtw_rpos("@@280", userHeaderFields) > "0")
      @Concat_Field("@@dte3", userDate3)
  %endif
  %if (@dtw_rpos("@@290", userHeaderFields) > "0")
      @Concat_Field("@@dte4", userDate4)
  %endif
  %if (@dtw_rpos("@@300", userHeaderFields) > "0")
      @Concat_Field("@@udf1", userAlpha1)
  %endif
  %if (@dtw_rpos("@@310", userHeaderFields) > "0")
      @Concat_Field("@@udf2", userAlpha2)
  %endif
  %if (@dtw_rpos("@@320", userHeaderFields) > "0")
      @Concat_Field("@@udf3", userAlpha3)
  %endif
  %if (@dtw_rpos("@@330", userHeaderFields) > "0")
      @Concat_Field("@@udf4", userAlpha4)
  %endif
  %if (@dtw_rpos("@@340", userHeaderFields) > "0")
      @Concat_Field("@@udf5", userAlpha5)
  %endif
  %if (@dtw_rpos("@@350", userHeaderFields) > "0")
      @Concat_Field("@@hold", holdCode)
  %endif
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, errFound, edtVar, errVar)

  %if (errFound == "")
      @DTW_ASSIGN(updateTotal, "Y")
      @Update_Misc_Charges (profileHandle, dataBaseID, orderControlNumber, freightCharge, specialCharge, updateTotal)

      %if (maintCode == "S")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ordershippingreview.d2w/DISPLAY$(d2wVarBase)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)orderentryorderreview.d2w/DISPLAY$(d2wVarBase)&amp;useH1OTOT=Y">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}