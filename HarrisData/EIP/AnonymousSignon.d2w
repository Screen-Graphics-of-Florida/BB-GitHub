%if (baseVar == "")
    %if (@dtw_ruppercase(EnvBaseVar) == "SELECT")
        @dtw_assign(baseVar, "BaseConfiguration.icl")
    %elseif (EnvBaseVar != "")
        @dtw_assign(baseVar, EnvBaseVar)
    %else
        @dtw_assign(baseVar, "BaseConfigurationanonymous.icl")
    %endif
%endif

%INCLUDE "$(baseVar)"

%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"

%Define {
  page_title              = "Sign On"
  d2wName                 = "AnonymousSignon.d2w"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "999"
  menuTable               = %table
  browser                 = ""
%}

%FUNCTION(dtw_directcall) Validate_User_Profile(INOUT CHAR(10) userProfile,
						       CHAR(10) password,
				                       CHAR(2)  dataBaseID,
                                                      CHAR(64) profileHandle)
{%EXEC {HSYHND_W.PGM %}  	
%}

%HTML(REPORT){
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)anonymousWelcomePage.icl/WELCOME?baseVar=@dtw_rurlescseq(baseVar)&amp;newsLink=@dtw_rurlescseq(newsLink)&amp;profileName=@dtw_rurlescseq(profileName)">
}%HTML(REPORTa) {


  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr)>
          @dtw_assign(userProfile, AnonymousUser)
          @dtw_assign(password, "*NOPWDCHK ")
          @dtw_mUPPERCASE(userProfile, password)
          @Validate_User_Profile(userProfile, password, dataBaseID, profileHandle)
         	
          %if (profileHandle == "")
              Invalid User Profile or Password, press back to try again.
          %else
              @retrieveUserRole(profileHandle, dataBaseID, userProfile, userCustomer, userVendor, userSalesman, userBadge, userCatalog, newsLink, profileName)
              @dtw_assign(baseVar, "BaseConfiguration.php")
              <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)AnonymousWelcome.d2w/WELCOME?baseVar=@dtw_rurlescseq(baseVar)&amp;newsLink=@dtw_rurlescseq(newsLink)&amp;profileName=@dtw_rurlescseq(profileName)">
          %endif
      </body>
  </html>
%}

%HTML(returnsignon) {
  @deleteUserHandle(profileHandle, dataBaseID)
  <meta http-equiv="refresh" content="$(accessErrorTime); URL=$(AnonymousSignonURL)">
%}
