%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Salesman Search"
  d2wName                 = "SalesmanSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  novcf                   = ""
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectSalesman(salesman, desc){
                  window.opener.document.$(docName).$(fldName).value = salesman;
                  window.opener.document.$(docName).$(fldDesc).value = desc;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchSlsm, 3, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(uv_SalesmanName, "SMSLSM")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      %if (moreInfo == "Y")
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      %else
                          @dtw_concat(stmtSQL, " Select SMSLSM, SMSNA1, SMSCTY, SMST, SMZIP, ", stmtSQL)
                          @dtw_concat(stmtSQL, " upper(SMSNA1) as SMSNA1U, upper(SMSCTY) as SMSCTYU", stmtSQL)
                      %endif
                      @dtw_concat(fileSQL, " HDSLSM ", fileSQL)
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, "SMSLSM=$(salesmanNumber)", selectSQL)
                      %elseif (wildCardSearch!="" || uv_Sql!="")
                          @dtw_concat(selectSQL, " SMSLSM>0 ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Salesman_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Salesman_Search (IN  CHAR(64)    profileHandle,
     	                                 CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"

      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr"> Name</th>
                      <th class="colhdr"> Number</th>
                  </tr>
                  <tr>
                      <td class="inputalph">
                          <input type="text" name="srchName" size="15" maxlength="30">
                          <input type="hidden" name="operName" value="LIKE">
                      </td>
                      <td class="inputnmbr">
                          <input type="text" name="srchSlsm" size="4" maxlength="3">
                          <input type="hidden" name="operSlsm" value="=">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchName.focus();
              </script>
          </form>
	
          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("SMSLSM", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Number" title="Sequence By Number"> Number</a></th>
                  @OrderBy_Sort("SMSNA1U", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Name"  title="Sequence By Name, Number"> Name</a></th>
                  @OrderBy_Sort("SMSCTYU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=City" title="Sequence By City, Name, Number"> City</a></th>
                  @OrderBy_Sort("SMST", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=State" title="Sequence By State, Name, Number"> State</a></th>
                  @OrderBy_Sort("SMZIP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Zip" title="Sequence By Zip, Name, Number"> Zip</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %else
          <table $(contentTable)>
      %endif		

              %ROW{
                  @Format_Quote(V_SMSNA1, F_SMSNA1)

                  %if (moreInfo != "Y")	
                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          <td class="colnmbr">$(V_SMSLSM)</td>                                      	
                          <td class="colalph"><a href="javascript:selectSalesman($(V_SMSLSM), '$(F_SMSNA1)')" title="Select Salesman">$(V_SMSNA1)</a></td>

                          <td class="colalph">$(V_SMSCTY)</td>
                          <td class="colcode">$(V_SMST)</td>
                          <td class="colalph">$(V_SMZIP)</td>
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)$(wildCardVarBase)&amp;orderBy=SMSLSM&amp;salesmanNumber=@dtw_rurlescseq(V_SMSLSM)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                      </tr>

                  %else
                      %{ More Information Screen %}

                      @EditPhoneNumber(V_SMPHON)

                      <tr><td><a href="javascript:selectSalesman($(V_SMSLSM),'$(F_SMSNA1)')" title="Select Salesman">$(selectImageLrg)</a>
                          </td>
                      </tr>

                      <tr><td class="dsphdr">Salesman Number</td>
                          <td class="dspalph">$(V_SMSLSM)</td>
                      </tr>
    	   		
                      <tr><td class="dsphdr">Salesman Name</td>
                          <td class="dspalph">$(V_SMSNA1)</td>
                      </tr>

                      %if (V_SMSNA2!="")		
                          <tr><td class="dsphdr">Address Line One</td>
                              <td class="dspalph">$(V_SMSNA2)</td></tr>
                      %endif

                      %if (V_SMSNA3!="")		
                          <tr><td class="dsphdr">Address Line Two</td>
                              <td class="dspalph">$(V_SMSNA3)</td></tr>
                      %endif

                      %if (V_SMSNA4!="")		
                          <tr><td class="dsphdr">Address Line Three</td>
                              <td class="dspalph">$(V_SMSNA4)</td></tr>
                      %endif
    	   			
                      %if (V_SMSCTY!="")		
                          <tr><td class="dsphdr">City</td>
                              <td class="dspalph">$(V_SMSCTY)</td></tr>
                      %endif

                      %if (V_SMST!="")		
                          @RtvFldDesc("STID='$(V_SMST)'", "HDSTID", "STDESC", fieldDesc)
                          <tr><td class="dsphdr">State</td>
                              <td class="dspalph">$(fieldDesc)</td></tr>
                      %endif

                      %if (V_SMZIP!="")		
                          <tr><td class="dsphdr">Zip</td>
                              <td class="dspalph">$(V_SMZIP)</td></tr>
                      %endif

                      %if (V_SMPHON!="")		
                          <tr><td class="dsphdr">Phone Number</td>
                              <td class="dspnmbr">$(V_SMPHON)</td></tr>
                      %endif

                      %if (V_SMREGN!="")		
                          @RtvFldDesc("RGCRGN='$(V_SMREGN)'", "HDCRGN", "RGCRDS", fieldDesc)
                          <tr><td class="dsphdr">Region</td>
                              <td class="dspalph">$(fieldDesc)</td></tr>			
                      %endif

                      %if (V_SMCTRY!="")		
                          @RtvFldDesc("CNCTCD='$(V_SMCTRY)'", "HDCTRY", "CNCDES", fieldDesc)
                          <tr><td class="dsphdr">Country</td>
                              <td class="dspalph">$(fieldDesc)</td></tr>			
                      %endif

                      %if (V_SMSCPT!="")
    		           @RtvFldDesc("FLTYPE='COMMTYPE' and FLVALU='$(V_SMSCPT)'", "SYFLAG", "FLDESC", fieldDesc)
                          <tr><td class="dsphdr">Commission Type</td>
                              <td class="dspalph">$(fieldDesc)</td></tr>			
                      %endif
        	   		
                      %if (V_SMSCPT=="S")		
                          @Format_Nbr("@dtw_rMultiply(V_SMSCPC, "100")", F_SMSCPC, "4", $(pctEditCode), "Y", "", "")
                          <tr><td class="dsphdr">Commission Percent</td>
                              <td class="dspnmbr">$(F_SMSCPC)</td></tr>
                      %endif

                  %endif
              %}
          </table>
          %if (moreInfo != "Y")	
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
          %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "SMSNA1U,SMSLSM")
      @DTW_ASSIGN(orderByDisplay, "Name, Number")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(orderBy, "SMSLSM")
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
		
  %if (sequence == "Number")
      %if (orderBy == "SMSLSM")
          @DTW_ASSIGN(orderBy, "SMSLSM DESC")
          @DTW_ASSIGN(orderByDisplay, "Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SMSLSM")
          @DTW_ASSIGN(orderByDisplay, "Number")
      %endif
  %elseif (sequence == "Name")
      %if (orderBy == "SMSNA1U,SMSLSM")
          @DTW_ASSIGN(orderBy, "SMSNA1U DESC,SMSLSM")
          @DTW_ASSIGN(orderByDisplay, "Name (descending), Number")
      %else
          @DTW_ASSIGN(orderBy, "SMSNA1U,SMSLSM")
          @DTW_ASSIGN(orderByDisplay, "Name, Number")
      %endif
  %elseif (sequence == "City")
      %if (orderBy == "SMSCTYU,SMSNA1U,SMSLSM")
          @DTW_ASSIGN(orderBy, "SMSCTYU DESC,SMSNA1U,SMSLSM")
          @DTW_ASSIGN(orderByDisplay, "City (descending), Name, Number")
      %else
          @DTW_ASSIGN(orderBy, "SMSCTYU,SMSNA1U,SMSLSM")
          @DTW_ASSIGN(orderByDisplay, "City, Name, Number")
      %endif
  %elseif (sequence == "State")
      %if (orderBy == "SMST,SMSNA1U,SMSLSM")
          @DTW_ASSIGN(orderBy, "SMST DESC,SMSNA1U,SMSLSM")
          @DTW_ASSIGN(orderByDisplay, "State (descending), Name, Number")
      %else
          @DTW_ASSIGN(orderBy, "SMST,SMSNA1U,SMSLSM")
          @DTW_ASSIGN(orderByDisplay, "State, Name, Number")
      %endif
  %elseif (sequence == "Zip")
      %if (orderBy == "SMZIP,SMSNA1U,SMSLSM")
          @DTW_ASSIGN(orderBy, "SMZIP DESC,SMSNA1U,SMSLSM")
          @DTW_ASSIGN(orderByDisplay, "Zip (descending), Name, Number")
      %else
          @DTW_ASSIGN(orderBy, "SMZIP,SMSNA1U,SMSLSM")
          @DTW_ASSIGN(orderByDisplay, "Zip, Name, Number")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "SALESMANSEARCH")
                  <td>
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Name</td>
                              @dtw_assign(operNbr, "operName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchName" size="26" maxlength="26"></td>
                          </tr>

                          <tr><td class="dsphdr">Address</td>
                              <td>&nbsp;</td>
                              <td class="inputalph"><input type="text" name="srchAddress" size="26" maxlength="26"></td>	
                          </tr>

                          <tr><td class="dsphdr">State</td>
                              @dtw_assign(operNbr, "operState")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchState" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Zip</td>
                              @dtw_assign(operNbr, "operZip")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchZip" size="14" maxlength="14"></td>
                          </tr>

                          <tr><td class="dsphdr">Country</td>
                              @dtw_assign(operNbr, "operCountry")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCountry" size="3" maxlength="3"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchName.focus();
                          </script>
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("SMSLSM", "Number", $(srchSlsm), "", operSlsm, "N")
  @Build_WildCard ("upper(SMSNA1)", "Name", $(srchName), "U", operName, "A")

  @dtw_assign(srchAddress,@dtw_rstrip(srchAddress))
  %if (srchAddress != "")
      @Build_WildCard ("SMSNA2", "Address", $(srchAddress), "U", "LIKE", "V")
      @dtw_mUPPERCASE(srchAddress)
      @dtw_replace(srchAddress, "?", "_", "1", "a", srchAddress)
      @dtw_replace(srchAddress, "*", "%", "1", "a", srchAddress)
      @dtw_concat(wildCardTemp, " (trim(upper(SMSNA2)) LIKE '$(srchAddress)'", wildCardTemp)
      @dtw_concat(wildCardTemp, " OR   trim(upper(SMSNA3)) LIKE '$(srchAddress)'", wildCardTemp)
      @dtw_concat(wildCardTemp, " OR   trim(upper(SMSCTY)) LIKE '$(srchAddress)')", wildCardTemp)
  %endif
		
  @Build_WildCard ("SMST", "State", $(srchState), "U", operState, "A")
  @Build_WildCard ("SMZIP", "Zip", $(srchZip), "U", operZip, "A")
  @Build_WildCard ("SMCTRY", "Country", $(srchCountry), "U", operCountry, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}