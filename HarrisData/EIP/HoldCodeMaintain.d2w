%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Hold Code Maintenance"
  d2wName                 = "HoldCodeMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;holdCode=@dtw_rurlescseq(holdCode)&amp;type=@dtw_rurlescseq(type)&amp;holdCodeDesc=@dtw_rurlescseq(holdCodeDesc)&amp;maintenanceCode=D"
  programName             = "HHDHCM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.holdCode.value =="" ||
                      document.Chg.holdCodeDesc.value =="")
                         {alert("$(reqFieldError)"); return false;}
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "HOLDCODEMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From HDHLCD Where HCHLCD='$(holdCode)' and HCTYPE='$(type)'", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=157")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "holdCode")
                      %else
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @dtw_assign(focusField, "")
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@hlcd", "holdCode")       @dtw_assign(Err_HCHLCD, fieldValue)
                          @DecatErr_Field("@@desc", "holdCodeDesc")   @dtw_assign(Err_HCDESC, fieldValue)
                          @DecatErr_Field("@@icon", "iconName")       @dtw_assign(Err_HCICON, fieldValue)
                          @DecatErr_Field("@@mhld", "mfgHoldCode")    @dtw_assign(Err_HCMHLD, fieldValue)
                          @DecatErr_Field("@@prto", "printOrder")     @dtw_assign(Err_HCPRTO, fieldValue)
                          @DecatErr_Field("@@issc", "issueComp")      @dtw_assign(Err_HCISSC, fieldValue)
                          @DecatErr_Field("@@rptl", "reportLabor")    @dtw_assign(Err_HCRPTL, fieldValue)
                          @DecatErr_Field("@@ordr", "orderReceipt")   @dtw_assign(Err_HCORDR, fieldValue)
                          @DecatErr_Field("@@ordc", "orderClose")     @dtw_assign(Err_HCORDC, fieldValue)
                          @DecatErr_Field("@@pmat", "planMaterial")   @dtw_assign(Err_HCPMAT, fieldValue)
                          @DecatErr_Field("@@pcap", "planCapacity")   @dtw_assign(Err_HCPCAP, fieldValue)
                          @DecatErr_Field("@@schl", "schedLabor")     @dtw_assign(Err_HCSCHL, fieldValue)
                          @DecatErr_Field("@@haeo", "holdAutoExp")    @dtw_assign(Err_HCHAEO, fieldValue)
                      %endif

                      @Decat_Field("@@hlcd")   @dtw_assign(V_HCHLCD, fieldValue)
                      @Decat_Field("@@desc")   @dtw_assign(V_HCDESC, fieldValue)
                      @Decat_Field("@@icon")   @dtw_assign(V_HCICON, fieldValue)
                      @Decat_Field("@@mhld")   @dtw_assign(V_HCMHLD, fieldValue)
                      @Decat_Field("@@prto")   @dtw_assign(V_HCPRTO, fieldValue)
                      @Decat_Field("@@issc")   @dtw_assign(V_HCISSC, fieldValue)
                      @Decat_Field("@@rptl")   @dtw_assign(V_HCRPTL, fieldValue)
                      @Decat_Field("@@ordr")   @dtw_assign(V_HCORDR, fieldValue)
                      @Decat_Field("@@ordc")   @dtw_assign(V_HCORDC, fieldValue)
                      @Decat_Field("@@pmat")   @dtw_assign(V_HCPMAT, fieldValue)
                      @Decat_Field("@@pcap")   @dtw_assign(V_HCPCAP, fieldValue)
                      @Decat_Field("@@schl")   @dtw_assign(V_HCSCHL, fieldValue)
                      @Decat_Field("@@haeo")   @dtw_assign(V_HCHAEO, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(V_HCPRTO, "N")
                          @dtw_assign(V_HCISSC, "N")
                          @dtw_assign(V_HCRPTL, "N")
                          @dtw_assign(V_HCORDR, "N")
                          @dtw_assign(V_HCORDC, "N")
                          @dtw_assign(V_HCPMAT, "N")
                          @dtw_assign(V_HCPCAP, "N")
                          @dtw_assign(V_HCSCHL, "N")
                          @dtw_assign(V_HCHAEO, "Y")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "holdCode")
                      @dtw_assign(V_HCHLCD, "")
                  %else
                      @dtw_assign(focusField, "holdCodeDesc")
                  %endif

                  %if (type=="M")
                      @dtw_assign(typeDesc, "Manufacturing")
                  %else
                      @dtw_assign(typeDesc, "Order Management")
                  %endif
	           <tr><td class="dsphdr"><span $(textOvr)>Type</span></td>
                      <td class="inputalph"><input name="type" type="hidden" value="$(type)">$(typeDesc)</td>
                  </tr>

                  @SetTextOvr(Err_HCHLCD)
	           <tr><td class="dsphdr"><span $(textOvr)>Hold Code</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="holdCode" type="text" value="$(V_HCHLCD)" size="4" maxlength="4">$(reqFieldChar)</td>
                      %else
                          <td class="inputalph"><input name="holdCode" type="hidden" value="$(V_HCHLCD)" size="4" maxlength="4">$(V_HCHLCD)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_HCHLCD)

                  @SetTextOvr(Err_HCDESC)
	   	       <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="holdCodeDesc" type="text" value="$(V_HCDESC)" size="30" maxlength="30">$(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_HCDESC)

                  @SetTextOvr(Err_HCICON)
	   	       <tr><td class="dsphdr"><span $(textOvr)>Icon Name</span></td>
                      <td class="inputalph"><input name="iconName" type="text" value="$(V_HCICON)" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_HCICON)

                  %if (V_HDPDRL>"0" && type=="O")
                      @RtvFldDesc("HCTYPE='M' and HCHLCD='$(V_HCMHLD)'", "HDHLCD", "HCDESC", fieldDesc)
                      @SetTextOvr(Err_HCMHLD)
    	   	       <tr><td class="dsphdr"><span $(textOvr)>Mfg Hold Code</span></td>
                          <td class="inputalph"><input name="mfgHoldCode" type="text" value="$(V_HCMHLD)" size="4" maxlength="4"><a href="$(homeURL)$(phpPath)HoldCodeSearch.php$(altVarBase)&amp;fldType=M&amp;docName=Chg&amp;fldName=mfgHoldCode&amp;fldDesc=mfgHoldCodeDesc" onclick="$(searchWinVar)">$(searchImage) </a><input name="mfgHoldCodeDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                      </tr>
                      @DspErrMsg(Err_HCMHLD)
                  %endif

                  %if (type=="M")
                      @SetTextOvr(Err_HCPRTO)
                      <tr><td class="dsphdr"><span $(textOvr)>Print Order</span></td>
                          @dtw_tb_rows(yn01Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_HCPRTO) && (x < maxRows)) {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(yn01Table, "printOrder", "2", "1", "N", "", x, "1")</td>
                      </tr>
                      @DspErrMsg(Err_HCPRTO)

                      @SetTextOvr(Err_HCISSC)
                      <tr><td class="dsphdr"><span $(textOvr)>Issue Components</span></td>
                          @dtw_tb_rows(yn02Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn02Table, x, "1") != V_HCISSC) && (x < maxRows)) {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(yn02Table, "issueComp", "2", "1", "N", "", x, "1")</td>
                      </tr>
                      @DspErrMsg(Err_HCISSC)

                      @SetTextOvr(Err_HCRPTL)
                      <tr><td class="dsphdr"><span $(textOvr)>Report Labor</span></td>
                          @dtw_tb_rows(yn03Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn03Table, x, "1") != V_HCRPTL) && (x < maxRows)) {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(yn03Table, "reportLabor", "2", "1", "N", "", x, "1")</td>
                      </tr>
                      @DspErrMsg(Err_HCRPTL)

                      @SetTextOvr(Err_HCORDR)
                      <tr><td class="dsphdr"><span $(textOvr)>Order Receipt</span></td>
                          @dtw_tb_rows(yn04Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn04Table, x, "1") != V_HCORDR) && (x < maxRows)) {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(yn04Table, "orderReceipt", "2", "1", "N", "", x, "1")</td>
                      </tr>
                      @DspErrMsg(Err_HCORDR)

                      @SetTextOvr(Err_HCORDC)
                      <tr><td class="dsphdr"><span $(textOvr)>Order Close</span></td>
                          @dtw_tb_rows(yn05Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn05Table, x, "1") != V_HCORDC) && (x < maxRows)) {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(yn05Table, "orderClose", "2", "1", "N", "", x, "1")</td>
                      </tr>
                      @DspErrMsg(Err_HCORDC)

                      @SetTextOvr(Err_HCPMAT)
                      <tr><td class="dsphdr"><span $(textOvr)>Plan Material</span></td>
                          @dtw_tb_rows(yn06Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn06Table, x, "1") != V_HCPMAT) && (x < maxRows)) {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(yn06Table, "planMaterial", "2", "1", "N", "", x, "1")</td>
                      </tr>
                      @DspErrMsg(Err_HCPMAT)

                      @SetTextOvr(Err_HCPCAP)
                      <tr><td class="dsphdr"><span $(textOvr)>Plan Capacity</span></td>
                          @dtw_tb_rows(yn07Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn07Table, x, "1") != V_HCPCAP) && (x < maxRows)) {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(yn07Table, "planCapacity", "2", "1", "N", "", x, "1")</td>
                      </tr>
                      @DspErrMsg(Err_HCPCAP)

                      @SetTextOvr(Err_HCSCHL)
                      <tr><td class="dsphdr"><span $(textOvr)>Schedule Labor</span></td>
                          @dtw_tb_rows(yn08Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn08Table, x, "1") != V_HCSCHL) && (x < maxRows)) {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(yn08Table, "schedLabor", "2", "1", "N", "", x, "1")</td>
                      </tr>
                      @DspErrMsg(Err_HCSCHL)

                      @SetTextOvr(Err_HCHAEO)
                      <tr><td class="dsphdr"><span $(textOvr)>Hold Auto-Explode Orders</span></td>
                          @dtw_tb_rows(yn09able, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn09Table, x, "1") != V_HCHAEO) && (x < maxRows)) {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(yn09Table, "holdAutoExp", "2", "1", "N", "", x, "1")</td>
                      </tr>
                      @DspErrMsg(Err_HCHAEO)
                  %endif
              %}
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDHCM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %if (type=="M")
          @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
          @yn02_Table_Query(profileHandle, dataBaseID, "YORN      ", yn02Table)
          @yn03_Table_Query(profileHandle, dataBaseID, "YORN      ", yn03Table)
          @yn04_Table_Query(profileHandle, dataBaseID, "YORN      ", yn04Table)
          @yn05_Table_Query(profileHandle, dataBaseID, "YORN      ", yn05Table)
          @yn06_Table_Query(profileHandle, dataBaseID, "YORN      ", yn06Table)
          @yn07_Table_Query(profileHandle, dataBaseID, "YORN      ", yn07Table)
          @yn08_Table_Query(profileHandle, dataBaseID, "YORN      ", yn08Table)
          @yn09_Table_Query(profileHandle, dataBaseID, "YORN      ", yn09Table)
      %endif
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(ADD) {
  %if (V_HDPDRL <= "00000" || V_HDOERL <= "00000")
      %if (V_HDOERL > "00000")
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;type=O&amp;maintenanceCode=A&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
      %else
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;type=M&amp;maintenanceCode=A&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
      %endif
  %else

      %INCLUDE "setLibraryList.icl"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "Menu.js"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "HOLDCODEMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          <table $(contentTable)>
                              <colgroup>
                                  <col width="80%">
                                  <col width="15%">
                              <tr><td><h1>Add Hold Code</h1></td>
                                  <td class="toolbar">
                                      <a href="javascript:history.back()">$(cancelImageMed)</a>
                                      @dtw_assign(medIcon, "Y")
                                      %INCLUDE "HelpPage.icl"
                                  </td>
                              </tr>
                          </table>

                          $(hrTagAttr)
                          <form class="formClass" METHOD=POST name=Add ACTION="$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
                              <table $(contentTable)>
                                  <tr><td class="dsphdr">Select Type</td>
                                      <td class="inputcode"><input onClick="javascript:document.Add.submit()" name="type" type="radio" VALUE='M'>Manufacturing &nbsp; <input onClick="javascript:document.Add.submit()" name="type" type="radio" VALUE='O'>Order Management</td>
                                  </tr>
                              </table>
                          </form>
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(holdCode)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@type", type)
  @Concat_Field("@@hlcd", holdCode)
  @Concat_Field("@@desc", holdCodeDesc)
  @Concat_Field("@@icon", iconName)
  %if (type=="M")
      @Concat_Field("@@prto", printOrder)
      @Concat_Field("@@issc", issueComp)
      @Concat_Field("@@rptl", reportLabor)
      @Concat_Field("@@ordr", orderReceipt)
      @Concat_Field("@@ordc", orderClose)
      @Concat_Field("@@pmat", planMaterial)
      @Concat_Field("@@pcap", planCapacity)
      @Concat_Field("@@schl", schedLabor)
      @Concat_Field("@@haeo", holdAutoExp)
  %elif (type=="O")
      @dtw_mUPPERCASE(mfgHoldCode)
      @Concat_Field("@@mhld", mfgHoldCode)
  %endif
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(holdCodeDesc), $(holdCode), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@hlcd", "holdCode")
          @Format_ConfMsg_Desc("", $(holdCodeDesc), $(holdCode), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=157&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;holdCode=@dtw_rurlescseq(holdCode)&amp;type=@dtw_rurlescseq(type)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}