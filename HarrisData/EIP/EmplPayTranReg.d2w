      %if ((sec_02 == "Y" || sec_03 == "Y") && (V_CKDN01 != "0" || V_CKDN02 != "0" || V_CKDN03 != "0" || V_CKDN04 != "0" || V_CKDN05 != "0" || V_CKDN06 != "0" || V_CKDN07 != "0" || V_CKDN08 != "0" || V_CKDN09 != "0" || V_CKDN10 != "0" || V_CKDN11 != "0" || V_CKDN12 != "0" || V_CKDN13 != "0" || V_CKDN14 != "0" || V_CKDN15 != "0" || V_CKDN16 != "0" || V_CKDN17 != "0" || V_CKDN18 != "0" || V_CKDN19 != "0" || V_CKDN20 != "0"))
          @dtw_assign(moreURL, "$(homeURL)$(cGIPath)emplpayded.d2w/DEDUCTIONS$(d2wVarBase)&amp;maintenanceCode=C")
