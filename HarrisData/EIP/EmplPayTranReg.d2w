%INCLUDE "$(baseVar)"
%INCLUDE "EdtVar.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "Employee.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "QuickLink.icl"

%Define {
  page_title 	        = "Employee Pay Transaction"
  d2wName              = "EmplPayTranReg.d2w"
  d2wVarBase           = "$(genericVarBase)$(employeeVarBase)&amp;prCKTYPE=@dtw_rurlescseq(prCKTYPE)&amp;prCKSEPC=@dtw_rurlescseq(prCKSEPC)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName          = "HPRSBE"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  dspMaxRows           = "999"
  RPT_MAX_ROWS         = "99"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  caller               = "PayTranReg"
  dltmsg               = ""
  dspMaxRows           = "$(dspMaxRowsDft)"
  JBCL                 = ""
  PAYTYPECODE          = ""
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext	        = "1"
  showError            = "N"
  totalPages	        = "0"	
  TIPPAYROLL           = ""
  quickLinkByUser      = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
  @dtw_replace(workURL, "@@prCKTYPE", "@dtw_rurlescseq(prCKTYPE)", "1", "a", workURL)
  @dtw_replace(workURL, "@@prCKSEPC", "@dtw_rurlescseq(prCKSEPC)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @dtw_assign(applicationID, "PR")
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script type="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                          @dtw_assign(pageID, "EMPLPAYTRANREG")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      @RtvFldDesc("CFCOMP=$(prCompany) and CFFACL=$(prFacility)", "HRCOFC", "PCTIP", TIPPAYROLL)

                      <td class="content">

%{ QuickLink Table %}     %INCLUDE "QuickLinkTable.icl"

%{ QuickLink By User %}   %INCLUDE "QuickLinkByUser.icl"

%{ Pay Transaction Heading %}
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                          @dtw_concat(fileSQL, " PRCHCK ", fileSQL)
                          @dtw_concat(selectSQL, " CKCOMP=$(prCompany) and CKFACL=$(prFacility) and CKEMPL=$(prEmployee) and CKTYPE='$(prCKTYPE)' and CKSEPC='$(prCKSEPC)'", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Pay_Transaction_Header(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Begin %}     %INCLUDE "QuickLinkBegLoop.icl"

%{ paytransdetail %}
                              %if (quicklinkRef == "paytransdetail")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                                  @dtw_concat(fileSQL, "  PRTIME inner join PRCODE on SBCOMP=C2COMP and SBFACL=C2FACL and SBCODE=C2CODE ", fileSQL)
                                  @dtw_concat(selectSQL, " SBCOMP=$(prCompany) and SBFACL=$(prFacility) and SBEMPL=$(prEmployee) and SBTYPE='$(prCKTYPE)' and SBSEPC='$(prCKSEPC)'", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Pay_Transaction_Detail(profileHandle, dataBaseID, stmtSQL)

%{ paytranssummary %}
                              %elif (quicklinkRef == "paytranssummary")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                                  @dtw_concat(fileSQL, " PRCHCK ", fileSQL)
                                  @dtw_concat(selectSQL, " CKCOMP=$(prCompany) and CKFACL=$(prFacility) and CKEMPL=$(prEmployee) and CKTYPE='$(prCKTYPE)' and CKSEPC='$(prCKSEPC)'", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Pay_Transaction_Summary(profileHandle, dataBaseID, stmtSQL)

%{ paytransdeductions %}
                              %elif (quicklinkRef == "paytransdeductions")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                                  @dtw_concat(fileSQL, " PRCHCK ", fileSQL)
                                  @dtw_concat(selectSQL, " CKCOMP=$(prCompany) and CKFACL=$(prFacility) and CKEMPL=$(prEmployee) and CKTYPE='$(prCKTYPE)' and CKSEPC='$(prCKSEPC)'", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Pay_Transaction_Deductions(profileHandle, dataBaseID, stmtSQL)

%{ paytransoverrides %}
                              %elif (quicklinkRef == "paytransoverrides")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                                  @dtw_concat(fileSQL, " PRCHCK ", fileSQL)
                                  @dtw_concat(selectSQL, " CKCOMP=$(prCompany) and CKFACL=$(prFacility) and CKEMPL=$(prEmployee) and CKTYPE='$(prCKTYPE)' and CKSEPC='$(prCKSEPC)'", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Pay_Transaction_Overrides(profileHandle, dataBaseID, stmtSQL)

%{ paytransdeposits %}
                              %elif (quicklinkRef == "paytransdeposits")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                                  @dtw_concat(fileSQL, " PRCHCK left outer join PREACH on CKCOMP=ACCOMP and CKFACL=ACFACL and CKEMPL=ACEMPL ", fileSQL)
                                  @dtw_concat(selectSQL, " CKCOMP=$(prCompany) and CKFACL=$(prFacility) and CKEMPL=$(prEmployee) and CKTYPE='$(prCKTYPE)' and CKSEPC='$(prCKSEPC)'", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Pay_Transaction_Deposits(profileHandle, dataBaseID, stmtSQL)
                              %endif

%{ Quicklink End %}       %INCLUDE "QuickLinkEndLoop.icl"

                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Pay_Transaction_Header (IN CHAR(64)    profileHandle,
				               CHAR(2)     dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMTYPE", PAYTYPECODE)
      @dtw_assign(checkType, "Regular")
      %INCLUDE "ProgSecurityTestView.icl"
      %if (pgmOptAuth=="F")
          %INCLUDE "ProgSecurityError.icl"
      %endif
      %ROW{
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      @Format_Confirm_Desc($(checkType), $(prCKSEPC), "", "", "", "", confirmDesc)
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="BackHome">$(portalHome)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)$(d2wName)/DELETE$(d2wVarBase)&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                          %endif
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
              @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
              <tr><td><h2>$(F_EmpName)</h2></td></tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"

          $(hrTagAttr)
          <table $(contentTable)>
              <tr><td class="dsphdr">Check Type</td>
                  <td class="dspalph">$(checkType)</td>
                      %if (deleteError != "")
                          <td class="dspalph">$(deleteError)</td>
                          @dtw_assign(deleteError, "")
                      %endif
              </tr>
              %if (prCKSEPC != "")
                  <tr><td class="dsphdr">Separate Check</td>
                      <td class="dspalph">$(prCKSEPC)</td></tr>
              %endif

          </table>
          $(hrTagAttr)
          %INCLUDE "QuickLinkDisplay.icl"
      %}
  %}
%}

%FUNCTION(dtw_sql) Pay_Transaction_Detail (IN  CHAR(64)    profileHandle,
				                CHAR(2)     dataBaseID,
                                               CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="paytransdetail"></a>
      @dtw_assign(displayMaxRowsMsg, "Y")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
        	   <th class="colhdr">Date<br>Worked</th>
                  <th class="colhdr">Pay<br>Code</th>
        	   <th class="colhdr">Description</th>
        	   <th class="colhdr">Hours</th>
          	   <th class="colhdr">Units</th>
      	           %if ((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                      <th class="colhdr">Earnings</th>
                      <th class="colhdr">Pay<br>Rate</th>
                  %endif
                  <th class="colhdr">Shift</th>
                  <th class="colhdr">Dept</th>
                  <th class="colhdr">G/L Account</th>
                  <th class="colhdr">Job<br>Number</th>
              </tr>
              @dtw_assign(workedHours, "0")
              @dtw_assign(notWorked, "0")
              @dtw_assign(totalUnits, "0")
              @dtw_assign(totalEarnings, "0")
          %endif

          %ROW{

              %INCLUDE "SetRowClass.icl"
              @Format_Date(V_SBDTWK, "D", F_SBDTWK)
	       <tr class="$(rowClass)">
                  <td class="coldate">$(F_SBDTWK)</td>
	           <td class="colcode">$(V_SBCODE)</td>
                  @RetPayCodeDesc(profileHandle, dataBaseID, prCompany, prFacility, V_SBCODE, payCodeDesc)
    	           <td class="colalph"><a href="$(homeURL)$(cGIPath)emplPayTranDetailSelect.d2w/report$(d2wVarBase)&amp;detailSequence=@dtw_rurlescseq(V_SBSEQ)" title="View Pay Transaction Detail">$(payCodeDesc)</a></td>	
    	           %if(V_SBHRUN == "H")
                      @Format_Nbr($(V_SBHOUR), F_SBHOUR, "2", $(hrsEditCode), "", "", "")
    	               <td class="colnmbr">$(F_SBHOUR)</td>
                      <td class="colnmbr"></td>
                      %if(V_C2RPHR == "Y")
                          @dtw_add(V_SBHOUR, workedHours, workedHours)
                      %else
                          @dtw_add(V_SBHOUR, notWorked, notWorked)
                      %endif
    	           %elif(V_SBHRUN == "U")
                      @Format_Nbr($(V_SBHOUR), F_SBHOUR, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr"></td>
                      <td class="colnmbr">$(F_SBHOUR)</td>
    	               @dtw_add(V_SBHOUR, totalUnits, totalUnits)
    	           %else
                      <td class="colnmbr"></td>
                      <td class="colnmbr"></td>
    	           %endif
    	           @dtw_add(V_SBEARN, totalEarnings, totalEarnings)
    	           %if((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                      @Format_Nbr($(V_SBEARN), F_SBEARN, "2", $(amtEditCode), "", "", "")
    	               <td class="colnmbr">$(F_SBEARN)</td>
                      %if(V_SBOVRT == ".000")
                          @dtw_assign(V_SBOVRT, "")
                          <td class="colnmbr">$(V_SBOVRT)</td>
                      %else
                          @Format_Nbr($(V_SBOVRT), F_SBOVRT, $(rteNbrDec), $(rteEditCode), "", "", "")
                          <td class="colnmbr">$(F_SBOVRT)</td>
                      %endif
                  %endif
                  <td class="colcode">$(V_SBSHFW)</td>
    	           <td class="colcode">$(V_SBDEPT)</td>
    	           <td class="colalph">$(V_SBACCT)-$(V_SBSACT)</td>
    	           <td class="colalph">$(V_SBJOB)</td>
    	       </tr>	
          %}

          <tr><td class="colnmbr"> </td>
              <td class="colnmbr"> </td>
              <td class="colalph">Total Worked</td>
              @Format_Nbr($(workedHours), F_workedHours, "2", $(hrsEditCode), "", "", "")
              <td class="colnmbr"> $(F_workedHours)</td>
	           %if(totalUnits == "0")
	               @dtw_assign(totalUnits, "")
                      <td class="colnmbr"> $(totalUnits)</td>
                  %else
                      @Format_Nbr($(totalUnits), F_totalUnits, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr"> $(F_totalUnits)</td>
	      	   %endif
	           %if((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                      @Format_Nbr($(totalEarnings), F_totalEarnings, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_totalEarnings)</td>
                  %endif
              <td class="colnmbr"> </td>
              <td class="colnmbr"> </td>
          </tr>
          %if (notWorked != "0")
              <tr><td class="colalph"> </td>
                  <td class="colnmbr"></td>
                  <td class="colalph">Not Worked</td>
                  @Format_Nbr($(notWorked), F_notWorked, "2", $(hrsEditCode), "", "", "")
                  <td class="colnmbr">$(F_notWorked)</td>
                  <td class="colnmbr"></td>
               </tr>
          %endif
          <tr><td><input name="timeStamp" type="hidden" value="$(V_CKTSTP)"></td></tr>
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Pay_Transaction_Summary (IN  CHAR(64)    profileHandle,
				                 CHAR(2)     dataBaseID,
                                                CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="paytranssummary"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMTYPE", PAYTYPECODE)
      @RtvFldDesc("CKCOMP=$(prCompany) and CKFACL=$(prFacility) and CKEMPL=$(prEmployee) and CKTYPE='3' and CKSEPC='$(prCKSEPC)' ", "PRCHCK", "CHAR(CKMode)", checkMode)
      %if ((sec_02 == "Y" || sec_03 == "Y") && (checkMode == "S"))
          @dtw_assign(moreURL, "$(homeURL)$(cGIPath)emplpaysummary.d2w/REPORT$(d2wVarBase)&amp;maintenanceCode=C")
      %else
          @dtw_assign(moreURL, "")
      %endif
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %ROW{
              <tr><td class="colhdr">Description</td>
                  <td class="colhdr">Hours/Units</td>
	   	   %if((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                      <td class="colhdr">Earnings</td>
                  %endif
              </tr>

              @dtw_assign(totalHours, "0")
              @dtw_assign(totalEarnings, "0")

              %if(V_CKREGH != ".00" || V_CKREGE != ".00")
                  <tr><td class="dsphdr">Regular</td>
                      @Format_Nbr($(V_CKREGH), F_CKREGH, "2", $(hrsEditCode), "", "", "")
                      @Format_Nbr($(V_CKREGE), F_CKREGE, "2", $(amtEditCode), "", "", "")
                      @dtw_add(V_CKREGH, totalHours, totalHours)
                      @dtw_add(V_CKREGE, totalEarnings, totalEarnings)
                      <td class="colnmbr">$(F_CKREGH)</td>
	   	       %if((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                          <td class="colnmbr">$(F_CKREGE)</td>
                      %endif
                  </tr>
              %endif

              %if(V_CKOVTH != ".00" || V_CKOVTE != ".00")
                  <tr><td class="dsphdr">Overtime</td>
                      @Format_Nbr($(V_CKOVTH), F_CKOVTH, "2", $(hrsEditCode), "", "", "")
                      @Format_Nbr($(V_CKOVTE), F_CKOVTE, "2", $(amtEditCode), "", "", "")
                      @dtw_add(V_CKOVTH, totalHours, totalHours)
                      @dtw_add(V_CKOVTE, totalEarnings, totalEarnings)
                      <td class="colnmbr">$(F_CKOVTH)</td>
	   	       %if((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                          <td class="colnmbr">$(F_CKOVTE)</td>
                      %endif
                  </tr>
              %endif

              %if(V_CKDBLH != ".00" || V_CKDBLE != ".00")
                  <tr><td class="dsphdr">Double Time</td>
                      @Format_Nbr($(V_CKDBLH), F_CKDBLH, "2", $(hrsEditCode), "", "", "")
                      @Format_Nbr($(V_CKDBLE), F_CKDBLE, "2", $(amtEditCode), "", "", "")
                      @dtw_add(V_CKDBLH, totalHours, totalHours)
                      @dtw_add(V_CKDBLE, totalEarnings, totalEarnings)
                      <td class="colnmbr">$(F_CKDBLH)</td>
	   	       %if((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                          <td class="colnmbr">$(F_CKDBLE)</td>
                      %endif
                  </tr>
              %endif

              %if(V_CKVACH != ".00" || V_CKVACE != ".00")
                  <tr><td class="dsphdr">Vacation</td>
                      @Format_Nbr($(V_CKVACH), F_CKVACH, "2", $(hrsEditCode), "", "", "")
                      @Format_Nbr($(V_CKVACE), F_CKVACE, "2", $(amtEditCode), "", "", "")
                      @dtw_add(V_CKVACH, totalHours, totalHours)
                      @dtw_add(V_CKVACE, totalEarnings, totalEarnings)
                      <td class="colnmbr">$(F_CKVACH)</td>
	   	       %if((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                          <td class="colnmbr">$(F_CKVACE)</td>
                      %endif
                  </tr>
              %endif

              %if(V_CKHOLH != ".00" || V_CKHOLE != ".00")
                  <tr><td class="dsphdr">Holiday</td>
                      @Format_Nbr($(V_CKHOLH), F_CKHOLH, "2", $(hrsEditCode), "", "", "")
                      @Format_Nbr($(V_CKHOLE), F_CKHOLE, "2", $(amtEditCode), "", "", "")
                      @dtw_add(V_CKHOLH, totalHours, totalHours)
                      @dtw_add(V_CKHOLE, totalEarnings, totalEarnings)
                      <td class="colnmbr">$(F_CKHOLH)</td>
	   	       %if((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                          <td class="colnmbr">$(F_CKHOLE)</td>
                      %endif
                  </tr>
              %endif

              %if(V_CKSICH != ".00" || V_CKSICE != ".00")
                  <tr><td class="dsphdr">Sick</td>
                      @Format_Nbr($(V_CKSICH), F_CKSICH, "2", $(hrsEditCode), "", "", "")
                      @Format_Nbr($(V_CKSICE), F_CKSICE, "2", $(amtEditCode), "", "", "")
                      @dtw_add(V_CKSICH, totalHours, totalHours)
                      @dtw_add(V_CKSICE, totalEarnings, totalEarnings)
                      <td class="colnmbr">$(F_CKSICH)</td>
	   	       %if((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                          <td class="colnmbr">$(F_CKSICE)</td>
                      %endif
                  </tr>
              %endif

              %if(V_CKOTHH != ".00" || V_CKOTPT != ".00")
                  <tr><td class="dsphdr">Other Taxable</td>
                      @Format_Nbr($(V_CKOTHH), F_CKOTHH, "2", $(hrsEditCode), "", "", "")
                      @Format_Nbr($(V_CKOTPT), F_CKOTPT, "2", $(amtEditCode), "", "", "")
                      @dtw_add(V_CKOTHH, totalHours, totalHours)
                      @dtw_add(V_CKOTPT, totalEarnings, totalEarnings)
                      <td class="colnmbr">$(F_CKOTHH)</td>
	   	       %if((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                          <td class="colnmbr">$(F_CKOTPT)</td>
                      %endif
                  </tr>
              %endif

              %if((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                  %if(V_CKOPNT != ".00")
                      <tr><td class="dsphdr">Nontaxable</td>
                          @Format_Nbr($(V_CKOPNT), F_CKOPNT, "2", $(amtEditCode), "", "", "")
                          @dtw_add(V_CKOPNT, totalEarnings, totalEarnings)
                          <td class="colnmbr"></td>
                          <td class="colnmbr">$(F_CKOPNT)</td>
                      </tr>
                  %endif
              %endif

              %if((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                  %if(V_CKFRIN != ".00")
                      <tr><td class="dsphdr">Fringe Benefits</td>
                          @Format_Nbr($(V_CKFRIN), F_CKFRIN, "2", $(amtEditCode), "", "", "")
                          @dtw_add(V_CKFRIN, totalEarnings, totalEarnings)
                          <td class="colnmbr"></td>
                          <td class="colnmbr">$(F_CKFRIN)</td>
                      </tr>
                  %endif
              %endif

              %if((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                  %if(V_CKCOME != ".00")
                      <tr><td class="dsphdr">Commission</td>
                          @Format_Nbr($(V_CKCOME), F_CKCOME, "2", $(amtEditCode), "", "", "")
                          @dtw_add(V_CKCOME, totalEarnings, totalEarnings)
                          <td class="colnmbr"></td>
                          <td class="colnmbr">$(F_CKCOME)</td>
                      </tr>
                  %endif
              %endif

              %if((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                  %if(V_CKBNSE != ".00")
                      <tr><td class="dsphdr">Bonus</td>
                          @Format_Nbr($(V_CKBNSE), F_CKBNSE, "2", $(amtEditCode), "", "", "")
                          @dtw_add(V_CKBNSE, totalEarnings, totalEarnings)
                          <td class="colnmbr"></td>
                          <td class="colnmbr">$(F_CKBNSE)</td>
                      </tr>
                  %endif
              %endif

              %if((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                  %if(V_CKCSTP != ".00")
                      <tr><td class="dsphdr">Cash Tips</td>
                      @Format_Nbr($(V_CKCSTP), F_CKCSTP, "2", $(amtEditCode), "", "", "")
                          @dtw_add(V_CKCSTP, totalEarnings, totalEarnings)
                          <td class="colnmbr"></td>
                          <td class="colnmbr">$(F_CKCSTP)</td>
                      </tr>
                  %endif
              %endif

              %if((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                  %if(V_CKCHTP != ".00")
                      <tr><td class="dsphdr">Charge Tips</td>
                      @Format_Nbr($(V_CKCHTP), F_CKCHTP, "2", $(amtEditCode), "", "", "")
                          @dtw_add(V_CKCHTP, totalEarnings, totalEarnings)
                          <td class="colnmbr"></td>
                          <td class="colnmbr">$(F_CKCHTP)</td>
                      </tr>
                  %endif
              %endif

              %if((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                  %if(V_CKMEAL != ".00")
                      <tr><td class="dsphdr">Meal Allowance</td>
                      @Format_Nbr($(V_CKMEAL), F_CKMEAL, "2", $(amtEditCode), "", "", "")
    	      	       @dtw_add(V_CKMEAL, totalEarnings, totalEarnings)
                          <td class="colnmbr"></td>
                          <td class="colnmbr">$(F_CKMEAL)</td>
                      </tr>
                  %endif
              %endif

              <tr><td class="dsphdr">Total</td>
                  @Format_Nbr($(totalHours), F_totalHours, "2", $(hrsEditCode), "", "", "")
                  @Format_Nbr($(totalEarnings), F_totalEarnings, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_totalHours)</td>
        	   %if((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                      <td class="colnmbr">$(F_totalEarnings)</td>
                  %endif
              </tr>

              %if((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                  %if(V_CKGRRC != ".00")
                      <tr><td class="dsphdr">Gross Receipts</td>
                      @Format_Nbr($(V_CKGRRC), F_CKGRRC, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr"></td>
                          <td class="colnmbr">$(F_CKGRRC)</td>
                      </tr>
                  %endif
              %endif

              <tr><td class="colhdr">Description</td></tr>

              %if ((TIPPAYROLL == "Y") && ((PAYTYPECODE == "S") || (PAYTYPECODE == "H")))
                  <tr><td class="dsphdr">Tip Type</td>
                      <td class="colalph">$(V_CKTHTY)</td>
                  </tr>
              %endif
              <tr><td class="colnmbr"></td></tr>

              %if(V_CKWKSW != "")
                  <tr><td class="dsphdr">Override Shift Worked</td>
                      <td class="colalph">$(V_CKWKSW)</td>
                  </tr>
              %endif

              %if(V_CKCRWK != ".0")
                  <tr><td class="dsphdr"> Credit Service Weeks</td>
                      @Format_Nbr($(V_CKCRWK), F_CKCRWK, "0", $(amtEditCode), "", "", "")
                      <td class="colalph">$(F_CKCRWK)</td></tr>
              %endif

              %if(V_CKEQDY != "0")
                  <tr><td class="dsphdr">Equiv. Days Worked</td>
                      @Format_Nbr($(V_CKEQDY), F_CKEQDY, "0", $(amtEditCode), "", "", "")
                      <td class="colalph">$(F_CKEQDY)</td></tr>
              %endif

              %if(V_CKWKDP != "")
                  <tr><td class="dsphdr">Override Department</td>
                      @RtvFldDesc("EADEPT='$(V_CKWKDP)' ", "PREXAC", "EANAME", deptName)
                      @Format_Code(V_CKWKDP, F_CKWKDP)
                      <td class="dspalph">$(deptName)</td>
                      <td class="dspalph">$(F_CKWKDP)</td>
                  </tr>
              %endif

              %if(V_CKWKAC != "0" || V_CKWKSB != "0")
                  <tr><td class="dsphdr">Override Expense Account</td>
                      @dtw_assign(expacct,"")
                      @dtw_concat(expacct,"$(V_CKWKCO)",expacct)
                      @dtw_concat(expacct,"/",expacct)
                      @dtw_concat(expacct,"$(V_CKWKFA)",expacct)
                      @dtw_concat(expacct,"  $(V_CKWKAC)",expacct)
                      @dtw_concat(expacct,"-",expacct)
                      @dtw_concat(expacct,"$(V_CKWKSB)",expacct)
                      <td class="colalph">$(expacct)</td></tr>
              %endif

              %if((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                  <tr><td class="dsphdr">Override Rate</td>
                      @Format_Nbr($(V_CKWKRT), F_CKWKRT, $(rteNbrDec), $(rteEditCode), "", "", "")
                      <td class="colalph">$(F_CKWKRT)</td></tr>
              %endif

              %if(V_CKWKDT != "0")
                  <tr><td class="dsphdr">Override Date Worked</td>
                      @Format_Date(V_CKWKDT, "D", F_CKWKDT)
                      <td class="colalph">$(F_CKWKDT)</td></tr>
              %endif
              <tr><td><input name="timeStamp" type="hidden" value="$(V_CKTSTP)"></td></tr>
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Pay_Transaction_Deductions (IN  CHAR(64)    profileHandle,
				                 CHAR(2)     dataBaseID,
                                                CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

