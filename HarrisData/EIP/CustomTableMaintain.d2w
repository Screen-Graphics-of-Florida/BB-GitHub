%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Custom Table Maintenance"
  d2wName                 = "CustomTableMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;tblID=@dtw_rurlescseq(tblID)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;tableName=@dtw_rurlescseq(tableName)&amp;tableDesc=@dtw_rurlescseq(tableDesc)&amp;maintenanceCode=D"
  programName             = "HSYTBN_E"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.tableName.value =="")
                         {alert("$(reqFieldError)"); return false;}
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "TABLENAME")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, " Select * From SYTBLN Where TNTBLN = '$(tableName)'", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "tableName")
                      %else
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @dtw_assign(focusField, "")
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@tbln", "tableName")       @dtw_assign(Err_TNTBLN,  fieldValue)
                          @DecatErr_Field("@@desc", "tableDesc")       @dtw_assign(Err_TNDESC,  fieldValue)
                          @DecatErr_Field("@@pgos", "progName")        @dtw_assign(Err_TNPGOS,  fieldValue)
                          @DecatErr_Field("@@xmlc", "xmlContainer")    @dtw_assign(Err_TNXMLC,  fieldValue)
                      %endif

                      @Decat_Field("@@tbln")   @dtw_assign(V_TNTBLN,  fieldValue)
                      @Decat_Field("@@desc")   @dtw_assign(V_TNDESC,  fieldValue)
                      @Decat_Field("@@d2wn")   @dtw_assign(V_TND2WN,  fieldValue)
                      @Decat_Field("@@pgos")   @dtw_assign(V_TNPGOS,  fieldValue)
                      @Decat_Field("@@xmlc")   @dtw_assign(V_TNXMLC,  fieldValue)
                      @dtw_assign(errFound, "")
                  %else
                      @dtw_assign(focusField, "tableDesc")
                  %endif

                  @SetTextOvr(Err_TNTBLN)
                  <tr><td class="dsphdr"><span $(textOvr)>Table Name</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="tableName" type="text" value="$(V_TNTBLN)" size="30" maxlength="130"> $(reqFieldChar) </td>
                      %else
                          <td class="inputnmbr"><input name="tableName" type="hidden" value="$(V_TNTBLN)">$(V_TNTBLN)</td>
	      	       %endif  		
                  </tr>
                  @DspErrMsg(Err_TNTBLN)

                  @SetTextOvr(Err_TNDESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="tableDesc" type="text" value="$(V_TNDESC)" size="100" maxlength="100"></td>
                  </tr>
                  @DspErrMsg(Err_TNDESC)

                  @RtvFldDesc("PTPGID='$(V_TNPGOS)'", "SYILET", "PTDESC", progDesc)
                  @SetTextOvr(Err_TNPGOS)
                  <tr><td class="dsphdr"><span $(textOvr)>Security Program</span></td>
                      <td class="inputalph"><input name="progName" type="text" value="$(V_TNPGOS)" size="10" maxlength="10"><a href="$(homeURL)$(cGIPath)ProgSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=progName&amp;fldDesc=progDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="progDesc" value="$(progDesc)" type="text" size="50" disabled></td>
                  </tr>
                  @DspErrMsg(Err_TNPGOS)

                  @SetTextOvr(Err_TNXMLC)
                  <tr><td class="dsphdr"><span $(textOvr)>XML Container</span></td>
                      <td class="inputalph"><input name="xmlContainer" type="text" value="$(V_TNXMLC)" size="50" maxlength="50"></td>
                  </tr>
                  @DspErrMsg(Err_TNXMLC)
              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)	
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                              CHAR(2)     dataBaseID,
                                              CHAR(1)     maintenanceCode,
                                              CHAR(1)     errFound,
                                              CHAR(32000) edtVar,                             	
                                              CHAR(32000) errVar)
{%EXEC {HSYTBN_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(tableName)
  @dtw_mUPPERCASE(progName)
  @RtvFileLib(tableName, tableLibrary)
  %if (tableDesc == "")
      @RtvFldDesc("TABLE_NAME='$(tableName)' and SYSTEM_TABLE_SCHEMA='$(tableLibrary)' ", "QSYS2/SYSTABLES", "TABLE_TEXT", tableDesc)	
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@tbln", tableName)
  @Concat_Field("@@tlib", tableLibrary)
  @Concat_Field("@@desc", tableDesc)
  @Concat_Field("@@pgos", progName)
  @Concat_Field("@@xmlc", xmlContainer)
  @Concat_Field("@@styp", "P")
  @Concat_Field("@@ctbl", "Y")
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      %if (maintenanceCode == "A")
          @RtvFldDesc("TNTBLN='$(tableName)'", "SYTBLN", "TNTBID", tblID)
          @dtw_concat("CUSTOM/HDLIST/", @DTW_rUPPERCASE($(tableName)), urlID)
          @DTW_REPLACE(urlID, " ", "", urlID)
          @DTW_SUBSTR(tableDesc, "1", "20", urlDesc)
          @dtw_uppercase(urlDesc, FUDESCU)
          %INCLUDE "stmtSQLClear.icl"
          @dtw_concat(stmtSQL, " Insert Into SYURLM (FUID,FUDESC,FUDESCU,FUTITL,FUURL,FURESV,FUTSTP,FUTSUS,FUTSWS) ", stmtSQL)
          @dtw_concat(stmtSQL, " Values ('$(urlID)','$(urlDesc)','$(FUDESCU)','Display a list of $(urlDesc)','@@homeURL@@phpPathhdList.php?tblID=$(tblID)','',CURRENT_TIMESTAMP,'$(userProfile)','BROWSER')", stmtSQL)
          @dtw_concat(stmtSQL, "  @@endsql ", stmtSQL)
          @SQL_Update(stmtSQL, status)
      %endif

      @Format_ConfMsg_Desc(maintenanceCode, $(tableDesc), $(tableName), "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)CustomTable.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@tbln", "tableName")
      @Format_ConfMsg_Desc("", "$(fieldValue)", "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)CustomTable.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;tableName=@dtw_rurlescseq(tableName)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}