              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              @dtw_assign(previousDocType,"")
              @dtw_assign(previousCommentType,"")
          %endif

          %ROW{
              %if (V_CXDOCT == previousDocType && V_CXHT == previousCommentType )
