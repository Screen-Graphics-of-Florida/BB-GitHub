                  @Format_Column_Header("PIPOL#", "Line")
                  @Format_Column_Header("PIPORL", "Rel")
                  @Format_Column_Header("PIITEM", "Item Number")
                  @Format_Column_Header("PIOVWH", "Whs")
                  @Format_Column_Header("PIIMDS", "Item Description")
                  @Format_Column_Header("PIPCLS", "Product<br>Class")
                  @Format_Column_Header("PIDLRC", "Date<br>Received")
                  @Format_Column_Header("PIQTOR", "Quantity<br>Ordered")
                  @Format_Column_Header("QTYOPEN", "Quantity<br>Open")
                  @Format_Column_Header("PITRQT", "Transaction<br>Quantity")
                  @Format_Column_Header("PITRXN", "Trans<br>Code")
                  @Format_Column_Header("PIDSCC", "Purchase<br>Cost")
                  @Format_Column_Header("PIBUOM", "Pur<br>UOM")
                  @Format_Column_Header("EXTCOST", "Extended<br>Cost")
                  @Format_Column_Header("BMBNA1", "Buyer")
              </tr>
          %endif
      			
          %ROW{
              %INCLUDE "SetRowClass.icl"
			  @Format_Nbr(V_PIQTOR, F_PIQTOR, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
			  @Format_Nbr(V_QTYOPEN, F_QTYOPEN, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
			  @Format_Nbr(V_PITRQT, F_PITRQT, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
			  @Format_Nbr(V_PIDSCC, F_PIDSCC, $(cstNbrDec), $(cstEditCode), "Y", "", "")
			  @Format_Nbr(V_EXTCOST, F_EXTCOST, $(cstNbrDec), $(cstEditCode), "Y", "", "")
              @Format_Date(V_PIDLRC, "D", F_PIDLRC)
              @RtvFldDesc("PCPCLS='$(V_PIPCLS)'", "HDPCLS", "PCPCDS", prodClassDesc)
              @RtvFldDesc("TTTYPE='$(V_PITRXN)'", "HDTTYP", "TTDESC", transCodeDesc)
              @RtvFldDesc("UMUOM='$(V_PIBUOM)'", "HDUOM", "UMUMLD", uomDesc)
              <tr class="$(rowClass)">
              	  <td class="colnmbr"><a href="$(homeURL)$(phpPath)SelectPO.php$(altVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_PHVEND)&amp;vendorName=@dtw_rurlescseq(V_VMVNA1)&amp;purchaseOrderNumber=@dtw_rurlescseq(V_PHPO)" title="View Purchase Order">$(V_PHPO)</a></td>
                  <td class="colnmbr">$(V_PISEQ#)</td>
                  <td class="colnmbr">$(V_PIPOL#)</td>
                  <td class="colnmbr">$(V_PIPORL)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_PIITEM)&amp;itemDescription=@dtw_rurlescseq(V_PIIMDS)" title="View Item">$(V_PIITEM)</a></td>
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)WarehouseSelect.d2w/REPORT$(genericVarBase)&amp;warehouseNumber=@dtw_rurlescseq(V_PIOVWH)" title="View Warehouse"> $(V_PIOVWH)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemWarehouseSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq($(V_PIITEM))&amp;warehouseNumber=@dtw_rurlescseq(V_PIOVWH)" title="View Item/Warehouse"> $(V_PIIMDS)</a></td>
                  <td class="colalph" $(helpCursor)><span title="$(prodClassDesc)">$(V_PIPCLS)</span></td>
                  <td class="coldate">$(F_PIDLRC)</td>
                  <td class="colnmbr">$(F_PIQTOR)</td>
                  <td class="colnmbr">$(F_QTYOPEN)</td>
                  <td class="colnmbr">$(F_PITRQT)</td>
                  <td class="colcode" $(helpCursor)><span title="$(transCodeDesc)">$(V_PITRXN)</span></td>
                  <td class="colnmbr">$(F_PIDSCC)</td>
                  <td class="colcode" $(helpCursor)><span title="$(uomDesc)">$(V_PIBUOM)</span></td>
                  <td class="colnmbr">$(F_EXTCOST)</td>
                  <td class="colalph"><a href="$(homeURL)$(phpPath)BuyerSelect.php$(altVarBase)&amp;buyer=@dtw_rurlescseq(V_PHBUYR)" title="View Buyer">$(V_BMBNA1)</a></td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

