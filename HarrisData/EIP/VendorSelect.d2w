%FUNCTION(dtw_sql) Vendor_Select_Top_Items (IN CHAR(64)    profileHandle,
				                CHAR(2)     dataBaseID,
                                               CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (quicklinkRef == "ytdtopitems" )
          <a name="ytdtopitems"></a>
      %else
          <a name="lastyeartopitems"></a>
      %endif
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

          %if (sql_Record_Count == "0")
              <table $(contentTable)>
                  %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              @Format_Nbr(purchasesTotal, F_purchasesTotal, "2", $(amtEditCode), "", "$", "")
              <div class="page">
                   Total Purchases: $(F_purchasesTotal)
              </div>

              <table $(contentTable)>
                  <tr>
                      @Format_Column_Header("PIITEM", "Item Number")
                      @Format_Column_Header("xxx", "Item Description")
                      @Format_Column_Header("PURCHASES", "Purchases")
                      @Format_Column_Header("xxx", "Percent<br>of Total")
                      @Format_Column_Header("RECEIVED", "Quantity")
                  </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              %if (purchasesTotal > "0")
                  @dtw_multiply(V_PURCHASES, "100", percentOfTotal)
                  @dtw_divide(percentOfTotal, purchasesTotal, percentOfTotal)
                  @Format_Nbr($(percentOfTotal), F_percentOfTotal, "2", $(pctEditCode), "Y", "", "%")
              %else
                  @dtw_assign(F_percentOfTotal, "")
              %endif
              @Format_Nbr(V_RECEIVED, F_RECEIVED, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_PURCHASES), F_PURCHASES, "2", $(amtEditCode), "", "", "")
              @RtvFldDesc("IMITEM='$(V_PIITEM)'", "HDIMST", "IMIMDS", fieldDesc)
              <tr class="$(rowClass)">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemInquiry.d2w/DISPLAY$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq($(V_PIITEM))" onclick="$(inquiryWinVar)" title="Item Quickview">$(V_PIITEM)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_PIITEM)&amp;itemDescription=@dtw_rurlescseq(fieldDesc)" title="View Item">$(fieldDesc)</a></td>
                  <td class="colnmbr">$(F_PURCHASES)</td>
                  <td class="colnmbr">$(F_percentOfTotal)</td>
                  <td class="colnmbr">$(F_RECEIVED)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Vendor_Select_Order_Actions (IN CHAR(64)    profileHandle,
				                                   CHAR(2)     dataBaseID,
                                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="orderactions"></a>
      @dtw_assign(moreURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=461&amp;fKey1=POVEND&amp;fVal1=@dtw_rurlescseq(vendorNumber)&amp;fDsc1=@dtw_rurlescseq(vendorName)&amp;tag=QSEARCH")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("OWPLT", "Plant")
                  @Format_Column_Header("OWPN", "Item Number")
                  @Format_Column_Header("IMIMDS", "Item Description")
                  @Format_Column_Header("OWORD", "Order Number")
                  @Format_Column_Header("OWCQT2", "Current<br>Order Quantity")
                  @Format_Column_Header("OWOACT", "Order<br>Action Code")
                  @Format_Column_Header("OWADAT", "Order<br>Action Date")
                  @Format_Column_Header("OWDAT", "Due<br>Date")
              </tr>
          %endif
      			
          %ROW{
              %INCLUDE "SetRowClass.icl"
              @DTW_STRIP(V_OWORD, V_OWORD)
              %if (V_OWORD > "0")
                  @RtvFldDesc("POPO=$(V_OWORD) and POVEND=$(V_POVEND)", "POPOMS", "coalesce(POPO,'')", poNumber)
              %else
				  @dtw_assign(poNumber, "")
				  @dtw_assign(V_OWORD, "")
			  %endif
			  @Format_Nbr(V_OWCQT2, F_OWCQT2, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Date_ISO(V_OWADAT, "D", F_OWADAT)
              @Format_Date_ISO(V_OWDAT, "D", F_OWDAT)
              @RtvFldDesc("FLTYPE='ORDACTION' AND FLVALU='$(V_OWOACT)'", "SYFLAG", "FLDESC", orderActionDesc)
              @RtvFldDesc("FLTYPE='PARTTYPE' AND FLVALU='$(V_OWID)'", "SYFLAG", "FLDESC", partTypeDesc)
              
              <tr class="$(rowClass)">
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(V_OWPLT)" title="View Plant"> $(V_OWPLT)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_OWPN)&amp;itemDescription=@dtw_rurlescseq(V_IMIMDS)" title="View Item">$(V_OWPN)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemPlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(V_OWPLT)&amp;itemNumber=@dtw_rurlescseq(V_OWPN)" title="View Item/Plant"> $(V_IMIMDS)</a></td>
                  %if (poNumber > "0")
                  	  <td class="colnmbr"><a href="$(homeURL)$(phpPath)SelectPO.php$(altVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_POVEND)&amp;vendorName=@dtw_rurlescseq(V_VMVNA1)&amp;purchaseOrderNumber=@dtw_rurlescseq(V_OWORD)" title="View Purchase Order">$(V_OWORD)</a></td>
				  %else
				      <td class="colnmbr">$(V_OWORD)</td>
				  %endif
                  <td class="colnmbr">$(F_OWCQT2)</td>
                  <td class="colcode" $(helpCursor)><span title="$(orderActionDesc)">$(V_OWOACT)</span></td>
                  <td class="coldate">$(F_OWADAT)</td>
                  <td class="coldate">$(F_OWDAT)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Vendor_Select_Planned_Order (IN CHAR(64)    profileHandle,
				                                   CHAR(2)     dataBaseID,
                                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="plannedorders"></a>
      @dtw_assign(moreURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=460&amp;fKey1=PLVEND&amp;fVal1=@dtw_rurlescseq(vendorNumber)&amp;fDsc1=@dtw_rurlescseq(vendorName)&amp;tag=QSEARCH")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("PLPLT", "Plant")
                  @Format_Column_Header("PLPN", "Item Number")
                  @Format_Column_Header("IMIMDS", "Item Description")
                  @Format_Column_Header("PLPTYP", "Part Type")
                  @Format_Column_Header("BMBNA1", "Buyer")
                  @Format_Column_Header("PLPQTY", "Planned<br>Order Quantity")
                  @Format_Column_Header("PLDAT", "Due<br>Date")
                  @Format_Column_Header("PLSDAT", "Start<br>Date")
                  @Format_Column_Header("PLCPNS", "Component<br>Shortage")
              </tr>
          %endif
      			
          %ROW{
              %INCLUDE "SetRowClass.icl"
			  @Format_Nbr(V_PLPQTY, F_PLPQTY, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Date_ISO(V_PLDAT, "D", F_PLDAT)
              @Format_Date_ISO(V_PLSDAT, "D", F_PLSDAT)
              @RtvFldDesc("FLTYPE='BY' AND FLVALU='$(V_PLCPNS)'", "SYFLAG", "FLDESC", compShortDesc)
              @RtvFldDesc("FLTYPE='PARTTYPE' AND FLVALU='$(V_PLPTYP)'", "SYFLAG", "FLDESC", partTypeDesc)
              <tr class="$(rowClass)">
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(V_PLPLT)" title="View Plant"> $(V_PLPLT)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_PLPN)&amp;itemDescription=@dtw_rurlescseq(V_IMIMDS)" title="View Item">$(V_PLPN)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemPlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(V_PLPLT)&amp;itemNumber=@dtw_rurlescseq(V_PLPN)" title="View Item/Plant"> $(V_IMIMDS)</a></td>
                  <td class="colcode" $(helpCursor)><span title="$(partTypeDesc)">$(V_PLPTYP)</span></td>
                  <td class="colalph"><a href="$(homeURL)$(phpPath)BuyerSelect.php$(altVarBase)&amp;buyer=@dtw_rurlescseq(V_PLBAC)" title="View Buyer">$(V_BMBNA1)</a></td>
                  <td class="colnmbr">$(F_PLPQTY)</td>
                  <td class="coldate">$(F_PLDAT)</td>
                  <td class="coldate">$(F_PLSDAT)</td>
                  %if (V_PLCPNS == "Y")
                      <td class="colcode"><a href="$(homeURL)$(cGIPath)ProductStructureIndentedStockStatusInquiry.d2w/DISPLAY$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(V_PLPLT)&amp;itemNumber=@dtw_rurlescseq(V_PLPN)" onclick="$(inquiryWinVar)" title="Product Structure Idented Stock Status">$(V_PLCPNS)</a></td>
                  %else
                      <td class="colcode" $(helpCursor)><span title="$(compShortDesc)">$(V_PLCPNS)</span></td>
                  %endif
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Vendor_Select_Suggested_PO (IN CHAR(64)    profileHandle,
				                                  CHAR(2)     dataBaseID,
                                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{ 
      <a name="suggestedpo"></a>
      @dtw_assign(moreURL, "$(homeURL)$(phpPath)CreatePOItems.php$(altVarBase)&amp;fromVendor=$(vendorNumber)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("PSTYPE", "Type")
                  @Format_Column_Header("PSREQN", "Requisition<br>Number")
                  @Format_Column_Header("PSITEM", "Item Number")
                  @Format_Column_Header("PSWHS",  "Whs")
                  @Format_Column_Header("PSIMDS", "Item Description")
                  @Format_Column_Header("PSBUOM", "Pur<br>UOM")
                  @Format_Column_Header("PSSQOR", "Suggested<br>Order Quantity")
                  @Format_Column_Header("PSCOST", "Cost")
                  @Format_Column_Header("PSRQDT", "Required<br>Date")
                  @Format_Column_Header("PSBNA1", "Buyer")
              </tr>
          %endif
      			
          %ROW{
              %INCLUDE "SetRowClass.icl"
              %if (V_PSCOST == ".00000")
                @Get_PO_Cost(profileHandle, dataBaseID, $(V_PSVEND), $(V_PSITEM), $(V_PSWHS), $(V_PSSQOR), V_PSCOST)
              %endif
			  @Format_Nbr(V_PSSQOR, F_PSSQOR, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
			  @Format_Nbr(V_PSCOST, F_PSCOST, $(cstNbrDec), $(cstEditCode), "Y", "", "")
              @Format_Date(V_PSRQDT, "D", F_PSRQDT)
              @RtvFldDesc("IMITEM='$(V_PSITEM)'", "HDIMST", "char(count(*))", itemCnt)
              @RtvFldDesc("WHWHS=$(V_PSWHS)", "HDWHSM", "char(count(*))", whsCnt)
              @RtvFldDesc("IWITEM='$(V_PSITEM)' AND IWWHS=$(V_PSWHS)", "HDIWHS", "IWUOMB", purUOM)
              <tr class="$(rowClass)">
                  <td class="colcode">$(V_PSTYPE)</td>
                  <td class="colalph">$(V_PSREQN)</td>
                  %if ($(itemCnt) > "0")
                    <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_PSITEM)&amp;itemDescription=@dtw_rurlescseq(V_IMIMDS)" title="View Item">$(V_PSITEM)</a></td>
                  %else
                    <td class="colalph">$(V_PSITEM)</td>
                  %endif
                  %if ($(whsCnt) > "0")
                    <td class="colnmbr"><a href="$(homeURL)$(cGIPath)WarehouseSelect.d2w/REPORT$(genericVarBase)&amp;warehouseNumber=@dtw_rurlescseq(V_PSWHS)" title="View Warehouse"> $(V_PSWHS)</a></td>
                  %else
                    <td class="colalph">$(V_PSWHS)</td>
                  %endif
                  %if ($(purUOM) != "")
                    <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemWarehouseSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq($(V_PSITEM))&amp;warehouseNumber=@dtw_rurlescseq(V_PSWHS)" title="View Item/Warehouse"> $(V_IMIMDS)</a></td>
                    <td class="colcode">$(purUOM)</td>
                  %else
                    <td class="colalph">$(V_PSIMDS)</td>
                    <td class="colcode">$(V_PSBUOM)</td>
                  %endif
                  <td class="colnmbr">$(F_PSSQOR)</td>
                  <td class="colnmbr">$(F_PSCOST)</td>
                  <td class="coldate">$(F_PSRQDT)</td>
                  <td class="colalph"><a href="$(homeURL)$(phpPath)BuyerSelect.php$(altVarBase)&amp;buyer=@dtw_rurlescseq(V_PSBUYR)" title="View Buyer">$(V_PSBNA1)</a></td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Vendor_Select_Receipt_History (IN CHAR(64)    profileHandle,
				                                     CHAR(2)     dataBaseID,
