                      @Format_Nbr(V_FMCONT, F_FMCONT, "0", "Z", "", "", "")
                      <td class="colnmbr">$(F_FMCONT)</td>
                      <td class="colalph">$(F_Name)</td>
                  %endif
                  <td class="colalph">$(V_FMFAX)</td>
                  <td class="colalph">$(V_FMEMAL)</td>
                  <td class="colcode">$(bccImage)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

