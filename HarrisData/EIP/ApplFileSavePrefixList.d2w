%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Application Table Save Prefix List"
  d2wName                 = "ApplFileSavePrefixList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "2"
  helpExt                 = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (editFromToAll(document.Chg.frmPrefix, document.Chg.toPrefix, document.Chg.allPrefix, "A") &&
                      editFromToAll(document.Chg.frmApplID, document.Chg.toApplID, document.Chg.allApplID, "A"))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "APPLFILEPREFIXLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          @dtw_assign(focusField, "frmPrefix")
                          %if (errFound != "" || scheduleJobSwitch == "Y")
                              @dtw_assign(scheduleJobSwitch, "")
                              @EdtVarErr(profileHandle, typeValue, edtVar)
                              @dtw_assign(focusField, "")
                              @ErrVarErr(profileHandle, typeError, errVar)
                              @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule, fieldValue)
                              @DecatErr_Field("@@fpre", "frmPrefix")         @dtw_assign(Err_N1FPRE, fieldValue)
                              @DecatErr_Field("@@tpre", "toPrefix")          @dtw_assign(Err_N1TPRE, fieldValue)
                              @DecatErr_Field("@@apre", "allPrefix")         @dtw_assign(Err_N1APRE, fieldValue)
                              @DecatErr_Field("@@spre", "srtPrefix")         @dtw_assign(Err_N1SPRE, fieldValue)
                              @DecatErr_Field("@@ppre", "totPrefix")         @dtw_assign(Err_N1PPRE, fieldValue)
                              @DecatErr_Field("@@fapd", "frmApplID")         @dtw_assign(Err_N1FAPD, fieldValue)
                              @DecatErr_Field("@@tapd", "toApplID")          @dtw_assign(Err_N1TAPD, fieldValue)
                              @DecatErr_Field("@@aapd", "allApplID")         @dtw_assign(Err_N1AAPD, fieldValue)
                              @DecatErr_Field("@@sapd", "srtApplID")         @dtw_assign(Err_N1SAPD, fieldValue)
                              @DecatErr_Field("@@papd", "totApplID")         @dtw_assign(Err_N1PAPD, fieldValue)
                              %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                              @Decat_Field("@@fpre")  @dtw_assign(V_N1FPRE, fieldValue)
                              @Decat_Field("@@tpre")  @dtw_assign(V_N1TPRE, fieldValue)
                              @Decat_Field("@@apre")  @dtw_assign(V_N1APRE, fieldValue)
                              @Decat_Field("@@spre")  @dtw_assign(V_N1SPRE, fieldValue)
                              @Decat_Field("@@ppre")  @dtw_assign(V_N1PPRE, fieldValue)
                              @Decat_Field("@@fapd")  @dtw_assign(V_N1FAPD, fieldValue)
                              @Decat_Field("@@tapd")  @dtw_assign(V_N1TAPD, fieldValue)
                              @Decat_Field("@@aapd")  @dtw_assign(V_N1AAPD, fieldValue)
                              @Decat_Field("@@sapd")  @dtw_assign(V_N1SAPD, fieldValue)
                              @Decat_Field("@@papd")  @dtw_assign(V_N1PAPD, fieldValue)
                              %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                          %else
                              @dtw_assign(V_N1APRE, "ALL")
                              @dtw_assign(V_N1AAPD, "ALL")

                              @dtw_assign(V_N1PPRE, "N")
                              @dtw_assign(V_N1PAPD, "N")
                          %endif

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                                  <td class="colhdr">Print<br>Totals</td>
                              </tr>

                              @Field_Checked(V_N1APRE, "ALL", allChecked)
                              @Field_Checked(V_N1PPRE, "Y", totChecked)
                              @SetTextOvr(Err_N1FPRE)
                              %if (textOvr == "") @SetTextOvr(Err_N1TPRE) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1APRE) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SPRE) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PPRE) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Table Save Prefix</span></td>
                                  <td class="inputalph"><input type="text" name="frmPrefix" value="$(V_N1FPRE)" size="4" maxlength="4"></td>
                                  <td class="inputalph"><input type="text" name="toPrefix" value="$(V_N1TPRE)" size="4" maxlength="4"></td>
                                  <td class="inputalph"><input type="checkbox" name="allPrefix" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmPrefix.value='', this.form.toPrefix.value='';"></td>
                                  @Build_Sort_Select("srtPrefix", "$(V_N1SPRE)")
                                  <td align=center><input type="checkbox" name="totPrefix" $(totChecked) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N1FPRE)
                              @DspErrMsg(Err_N1TPRE)
                              @DspErrMsg(Err_N1APRE)
                              @DspErrMsg(Err_N1SPRE)
                              @DspErrMsg(Err_N1PPRE)

                              @Field_Checked(V_N1AAPD, "ALL", allChecked)
                              @Field_Checked(V_N1PAPD, "Y", totChecked)
                              @SetTextOvr(Err_N1FAPD)
                              %if (textOvr == "") @SetTextOvr(Err_N1TAPD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AAPD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SAPD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PAPD) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Application ID</span></td>
                                  <td class="inputalph"><input type="text" name="frmApplID" value="$(V_N1FAPD)" size="4" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)ApIdSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=frmApplID&amp;fldDesc=none" onclick="$(searchWinVar)">$(searchImage)</a></td>
                                  <td class="inputalph"><input type="text" name="toApplID" value="$(V_N1TAPD)" size="4" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)ApIdSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toApplID&amp;fldDesc=none" onclick="$(searchWinVar)">$(searchImage)</a></td>
                                  <td class="inputalph"><input type="checkbox" name="allApplID" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmApplID.value='', this.form.toApplID.value='';"></td>
                                  @Build_Sort_Select("srtApplID", "$(V_N1SAPD)")
                                  <td align=center><input type="checkbox" name="totApplID" $(totChecked) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N1FAPD)
                              @DspErrMsg(Err_N1TAPD)
                              @DspErrMsg(Err_N1AAPD)
                              @DspErrMsg(Err_N1SAPD)
                              @DspErrMsg(Err_N1PAPD)
                          </table>

                          @dtw_assign(envProgram, "HSYPRL")
                          @dtw_assign(envPrinter, "HSYPRLPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSYPRS1_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"

  @dtw_assign(edtVar, "")
  @dtw_mUPPERCASE(frmPrefix)                                                             @Concat_Field("@@fpre", frmPrefix)
  @dtw_mUPPERCASE(toPrefix)                                                              @Concat_Field("@@tpre", toPrefix)
  @dtw_mUPPERCASE(allPrefix) %if (allPrefix != "ALL") @dtw_assign(allPrefix, "") %endif  @Concat_Field("@@apre", allPrefix)
                                                                                         @Concat_Field("@@spre", @dtw_rstrip(srtPrefix))
  %if (totPrefix != "Y") @dtw_assign(totPrefix, "N") %endif                              @Concat_Field("@@ppre", totPrefix)
  @dtw_mUPPERCASE(frmApplID)                                                             @Concat_Field("@@fapd", frmApplID)
  @dtw_mUPPERCASE(toApplID)                                                              @Concat_Field("@@tapd", toApplID)
  @dtw_mUPPERCASE(allApplID) %if (allApplID != "ALL") @dtw_assign(allApplID, "") %endif  @Concat_Field("@@aapd", allApplID)
                                                                                         @Concat_Field("@@sapd", @dtw_rstrip(srtApplID))
  %if (totApplID != "Y") @dtw_assign(totApplID, "N") %endif                              @Concat_Field("@@papd", totApplID)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}