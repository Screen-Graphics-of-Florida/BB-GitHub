%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Environment Override List"
  d2wName                 = "EnvOvrList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "9"
  helpExt                 = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.JobFilled.checked == false &&
                      document.Chg.PrtFilled.checked == false &&
                      document.Chg.NoPFilled.checked == false)
                      {alert("Must make at least one 'Rows To Print' selection");
                      return false;}

                  if (editFromToAll(document.Chg.frmApplID, document.Chg.toApplID, document.Chg.allApplID, "A") &&
                      editFromToAll(document.Chg.frmUser, document.Chg.toUser, document.Chg.allUser, "A") &&
                      editFromToAll(document.Chg.frmWS, document.Chg.toWS, document.Chg.allWS, "A") &&
                      editFromToAll(document.Chg.frmProgram, document.Chg.toProgram, document.Chg.allProgram, "A") &&
                      editFromToAll(document.Chg.frmPrinter, document.Chg.toPrinter, document.Chg.allPrinter, "A") &&
                      editFromToAll(document.Chg.frmJobName, document.Chg.toJobName, document.Chg.allJobName, "A") &&
                      editFromToAll(document.Chg.frmJobDesc, document.Chg.toJobDesc, document.Chg.allJobDesc, "A") &&
                      editFromToAll(document.Chg.frmJobq, document.Chg.toJobq, document.Chg.allJobq, "A") &&
                      editFromToAll(document.Chg.frmOutq, document.Chg.toOutq, document.Chg.allOutq, "A")
                      )
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ENVOVRLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          @dtw_assign(focusField, "frmApplID")
                          %if (errFound != "" || scheduleJobSwitch == "Y")
                              @dtw_assign(scheduleJobSwitch, "")
                              @EdtVarErr(profileHandle, typeValue, edtVar)
                              @dtw_assign(focusField, "")
                              @ErrVarErr(profileHandle, typeError, errVar)
                              @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                              @DecatErr_Field("@@fapd", "frmApplID")       @dtw_assign(Err_N1FAPD, fieldValue)
                              @DecatErr_Field("@@tapd", "toApplID")        @dtw_assign(Err_N1TAPD, fieldValue)
                              @DecatErr_Field("@@aapd", "allApplID")       @dtw_assign(Err_N1AAPD, fieldValue)
                              @DecatErr_Field("@@sapd", "srtApplID")       @dtw_assign(Err_N1SAPD, fieldValue)
                              @DecatErr_Field("@@papd", "totApplID")       @dtw_assign(Err_N1PAPD, fieldValue)
                              @DecatErr_Field("@@fusr", "frmUser")         @dtw_assign(Err_N1FUSR, fieldValue)
                              @DecatErr_Field("@@tusr", "toUser")          @dtw_assign(Err_N1TUSR, fieldValue)
                              @DecatErr_Field("@@ausr", "allUser")         @dtw_assign(Err_N1AUSR, fieldValue)
                              @DecatErr_Field("@@susr", "srtUser")         @dtw_assign(Err_N1SUSR, fieldValue)
                              @DecatErr_Field("@@pusr", "totUser")         @dtw_assign(Err_N1PUSR, fieldValue)
                              @DecatErr_Field("@@fwsd", "frmWS")           @dtw_assign(Err_N1FWSD, fieldValue)
                              @DecatErr_Field("@@twsd", "toWS")            @dtw_assign(Err_N1TWSD, fieldValue)
                              @DecatErr_Field("@@awsd", "allWS")           @dtw_assign(Err_N1AWSD, fieldValue)
                              @DecatErr_Field("@@swsd", "srtWS")           @dtw_assign(Err_N1SWSD, fieldValue)
                              @DecatErr_Field("@@pwsd", "totWS")           @dtw_assign(Err_N1PWSD, fieldValue)
                              @DecatErr_Field("@@fpgn", "frmProgram")      @dtw_assign(Err_N1FPGN, fieldValue)
                              @DecatErr_Field("@@tpgn", "toProgram")       @dtw_assign(Err_N1TPGN, fieldValue)
                              @DecatErr_Field("@@apgn", "allProgram")      @dtw_assign(Err_N1APGN, fieldValue)
                              @DecatErr_Field("@@spgn", "srtProgram")      @dtw_assign(Err_N1SPGN, fieldValue)
                              @DecatErr_Field("@@ppgn", "totProgram")      @dtw_assign(Err_N1PPGN, fieldValue)
                              @DecatErr_Field("@@fpfn", "frmPrinter")      @dtw_assign(Err_N1FPFN, fieldValue)
                              @DecatErr_Field("@@tpfn", "toPrinter")       @dtw_assign(Err_N1TPFN, fieldValue)
                              @DecatErr_Field("@@apfn", "allPrinter")      @dtw_assign(Err_N1APFN, fieldValue)
                              @DecatErr_Field("@@spfn", "srtPrinter")      @dtw_assign(Err_N1SPFN, fieldValue)
                              @DecatErr_Field("@@ppfn", "totPrinter")      @dtw_assign(Err_N1PPFN, fieldValue)
                              @DecatErr_Field("@@fjbn", "frmJobName")      @dtw_assign(Err_N1FJBN, fieldValue)
                              @DecatErr_Field("@@tjbn", "toJobName")       @dtw_assign(Err_N1TJBN, fieldValue)
                              @DecatErr_Field("@@ajbn", "allJobName")      @dtw_assign(Err_N1AJBN, fieldValue)
                              @DecatErr_Field("@@sjbn", "srtJobName")      @dtw_assign(Err_N1SJBN, fieldValue)
                              @DecatErr_Field("@@pjbn", "totJobName")      @dtw_assign(Err_N1PJBN, fieldValue)
                              @DecatErr_Field("@@fjbd", "frmJobDesc")      @dtw_assign(Err_N1FJBD, fieldValue)
                              @DecatErr_Field("@@tjbd", "toJobDesc")       @dtw_assign(Err_N1TJBD, fieldValue)
                              @DecatErr_Field("@@ajbd", "allJobDesc")      @dtw_assign(Err_N1AJBD, fieldValue)
                              @DecatErr_Field("@@sjbd", "srtJobDesc")      @dtw_assign(Err_N1SJBD, fieldValue)
                              @DecatErr_Field("@@pjbd", "totJobDesc")      @dtw_assign(Err_N1PJBD, fieldValue)
                              @DecatErr_Field("@@fjbq", "frmJobq")         @dtw_assign(Err_N1FJBQ, fieldValue)
                              @DecatErr_Field("@@tjbq", "toJobq")          @dtw_assign(Err_N1TJBQ, fieldValue)
                              @DecatErr_Field("@@ajbq", "allJobq")         @dtw_assign(Err_N1AJBQ, fieldValue)
                              @DecatErr_Field("@@sjbq", "srtJobq")         @dtw_assign(Err_N1SJBQ, fieldValue)
                              @DecatErr_Field("@@pjbq", "totJobq")         @dtw_assign(Err_N1PJBQ, fieldValue)
                              @DecatErr_Field("@@fotq", "frmOutq")         @dtw_assign(Err_N1FOTQ, fieldValue)
                              @DecatErr_Field("@@totq", "toOutq")          @dtw_assign(Err_N1TOTQ, fieldValue)
                              @DecatErr_Field("@@aotq", "allOutq")         @dtw_assign(Err_N1AOTQ, fieldValue)
                              @DecatErr_Field("@@sotq", "srtOutq")         @dtw_assign(Err_N1SOTQ, fieldValue)
                              @DecatErr_Field("@@potq", "totOutq")         @dtw_assign(Err_N1POTQ, fieldValue)
                              %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                              @Decat_Field("@@job@")  @dtw_assign(V_N1JOB ,  fieldValue)
                              @Decat_Field("@@prt@")  @dtw_assign(V_N1PRT ,  fieldValue)
                              @Decat_Field("@@nop@")  @dtw_assign(V_N1NOP ,  fieldValue)
                              @Decat_Field("@@fapd")  @dtw_assign(V_N1FAPD, fieldValue)
                              @Decat_Field("@@tapd")  @dtw_assign(V_N1TAPD, fieldValue)
                              @Decat_Field("@@aapd")  @dtw_assign(V_N1AAPD, fieldValue)
                              @Decat_Field("@@sapd")  @dtw_assign(V_N1SAPD, fieldValue)
                              @Decat_Field("@@papd")  @dtw_assign(V_N1PAPD, fieldValue)
                              @Decat_Field("@@fusr")  @dtw_assign(V_N1FUSR, fieldValue)
                              @Decat_Field("@@tusr")  @dtw_assign(V_N1TUSR, fieldValue)
                              @Decat_Field("@@ausr")  @dtw_assign(V_N1AUSR, fieldValue)
                              @Decat_Field("@@susr")  @dtw_assign(V_N1SUSR, fieldValue)
                              @Decat_Field("@@pusr")  @dtw_assign(V_N1PUSR, fieldValue)
                              @Decat_Field("@@fwsd")  @dtw_assign(V_N1FWSD, fieldValue)
                              @Decat_Field("@@twsd")  @dtw_assign(V_N1TWSD, fieldValue)
                              @Decat_Field("@@awsd")  @dtw_assign(V_N1AWSD, fieldValue)
                              @Decat_Field("@@swsd")  @dtw_assign(V_N1SWSD, fieldValue)
                              @Decat_Field("@@pwsd")  @dtw_assign(V_N1PWSD, fieldValue)
                              @Decat_Field("@@fpgn")  @dtw_assign(V_N1FPGN, fieldValue)
                              @Decat_Field("@@tpgn")  @dtw_assign(V_N1TPGN, fieldValue)
                              @Decat_Field("@@apgn")  @dtw_assign(V_N1APGN, fieldValue)
                              @Decat_Field("@@spgn")  @dtw_assign(V_N1SPGN, fieldValue)
                              @Decat_Field("@@ppgn")  @dtw_assign(V_N1PPGN, fieldValue)
                              @Decat_Field("@@fpfn")  @dtw_assign(V_N1FPFN, fieldValue)
                              @Decat_Field("@@tpfn")  @dtw_assign(V_N1TPFN, fieldValue)
                              @Decat_Field("@@apfn")  @dtw_assign(V_N1APFN, fieldValue)
                              @Decat_Field("@@spfn")  @dtw_assign(V_N1SPFN, fieldValue)
                              @Decat_Field("@@ppfn")  @dtw_assign(V_N1PPFN, fieldValue)
                              @Decat_Field("@@fjbn")  @dtw_assign(V_N1FJBN, fieldValue)
                              @Decat_Field("@@tjbn")  @dtw_assign(V_N1TJBN, fieldValue)
                              @Decat_Field("@@ajbn")  @dtw_assign(V_N1AJBN, fieldValue)
                              @Decat_Field("@@sjbn")  @dtw_assign(V_N1SJBN, fieldValue)
                              @Decat_Field("@@pjbn")  @dtw_assign(V_N1PJBN, fieldValue)
                              @Decat_Field("@@fjbd")  @dtw_assign(V_N1FJBD, fieldValue)
                              @Decat_Field("@@tjbd")  @dtw_assign(V_N1TJBD, fieldValue)
                              @Decat_Field("@@ajbd")  @dtw_assign(V_N1AJBD, fieldValue)
                              @Decat_Field("@@sjbd")  @dtw_assign(V_N1SJBD, fieldValue)
                              @Decat_Field("@@pjbd")  @dtw_assign(V_N1PJBD, fieldValue)
                              @Decat_Field("@@fjbq")  @dtw_assign(V_N1FJBQ, fieldValue)
                              @Decat_Field("@@tjbq")  @dtw_assign(V_N1TJBQ, fieldValue)
                              @Decat_Field("@@ajbq")  @dtw_assign(V_N1AJBQ, fieldValue)
                              @Decat_Field("@@sjbq")  @dtw_assign(V_N1SJBQ, fieldValue)
                              @Decat_Field("@@pjbq")  @dtw_assign(V_N1PJBQ, fieldValue)
                              @Decat_Field("@@fotq")  @dtw_assign(V_N1FOTQ, fieldValue)
                              @Decat_Field("@@totq")  @dtw_assign(V_N1TOTQ, fieldValue)
                              @Decat_Field("@@aotq")  @dtw_assign(V_N1AOTQ, fieldValue)
                              @Decat_Field("@@sotq")  @dtw_assign(V_N1SOTQ, fieldValue)
                              @Decat_Field("@@potq")  @dtw_assign(V_N1POTQ, fieldValue)
                              %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                          %else
                              @dtw_assign(V_N1JOB, "01")
                              @dtw_assign(V_N1PRT, "01")
                              @dtw_assign(V_N1NOP, "01")

                              @dtw_assign(V_N1AAPD, "ALL")
                              @dtw_assign(V_N1AUSR, "ALL")
                              @dtw_assign(V_N1AWSD, "ALL")
                              @dtw_assign(V_N1APGN, "ALL")
                              @dtw_assign(V_N1APFN, "ALL")
                              @dtw_assign(V_N1AJBN, "ALL")
                              @dtw_assign(V_N1AJBD, "ALL")
                              @dtw_assign(V_N1AJBQ, "ALL")
                              @dtw_assign(V_N1AOTQ, "ALL")

                              @dtw_assign(V_N1PAPD, "N")
                              @dtw_assign(V_N1PUSR, "N")
                              @dtw_assign(V_N1PWSD, "N")
                              @dtw_assign(V_N1PPGN, "N")
                              @dtw_assign(V_N1PPFN, "N")
                              @dtw_assign(V_N1PJBN, "N")
                              @dtw_assign(V_N1PJBD, "N")
                              @dtw_assign(V_N1PJBQ, "N")
                              @dtw_assign(V_N1POTQ, "N")
                          %endif

                          <table $(contentTable)>
                              @Field_Checked(V_N1JOB, "01", checkedJobFilled)
                              @Field_Checked(V_N1PRT, "01", checkedPrtFilled)
                              @Field_Checked(V_N1NOP, "01", checkedNoPFilled)
                              @SetTextOvr(Err_N1JOB)
                              <tr><td class="dsphdr"><span $(textOvr)>Rows To Print</span></td>
                                  <td class="inputnmbr"><input name="JobFilled" type="checkbox" VALUE='01' $(checkedJobFilled)>Job Parameters Columns Filled</td>
                              </tr>
                              @DspErrMsg(Err_N1JOB)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="PrtFilled" type="checkbox" VALUE='01' $(checkedPrtFilled)>Printer Parameter Columns Filled</td>
                              </tr>

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="NoPFilled" type="checkbox" VALUE='01' $(checkedNoPFilled)>No Parameters Filled</td>
                              </tr>
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                                  <td class="colhdr">Print<br>Totals</td>
                              </tr>

                              @Field_Checked(V_N1AAPD, "ALL", allChecked)
                              @Field_Checked(V_N1PAPD, "Y", totChecked)
                              @SetTextOvr(Err_N1FAPD)
                              %if (textOvr == "") @SetTextOvr(Err_N1TAPD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AAPD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SAPD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PAPD) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Application ID</span></td>
                                  <td class="inputalph"><input type="text" name="frmApplID" value="$(V_N1FAPD)" size="10" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)ApIdSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=frmApplID&amp;fldDesc=none" onclick="$(searchWinVar)">$(searchImage)</a></td>
                                  <td class="inputalph"><input type="text" name="toApplID" value="$(V_N1TAPD)" size="10" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)ApIdSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toApplID&amp;fldDesc=none" onclick="$(searchWinVar)">$(searchImage)</a></td>
                                  <td class="inputalph"><input type="checkbox" name="allApplID" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmApplID.value='', this.form.toApplID.value='';"></td>
                                  @Build_Sort_Select("srtApplID", "$(V_N1SAPD)")
                                  <td align=center><input type="checkbox" name="totApplID" $(totChecked) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N1FAPD)
                              @DspErrMsg(Err_N1TAPD)
                              @DspErrMsg(Err_N1AAPD)
                              @DspErrMsg(Err_N1SAPD)
                              @DspErrMsg(Err_N1PAPD)

                              @Field_Checked(V_N1AUSR, "ALL", allChecked)
                              @Field_Checked(V_N1PUSR, "Y", totChecked)
                              @SetTextOvr(Err_N1FUSR)
                              %if (textOvr == "") @SetTextOvr(Err_N1TUSR) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AUSR) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SUSR) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PUSR) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>User Profile</span></td>
                                  <td class="inputalph"><input type="text" name="frmUser" value="$(V_N1FUSR)" size="10" maxlength="10">
                                                        <a href="$(homeURL)$(phpPath)UserSearch.php$(altVarBase)&amp;docName=Chg&amp;userFld=frmUser&amp;descFld=none" onclick="$(searchWinVar)">$(searchImage)</a></td>
                                  <td class="inputalph"><input type="text" name="toUser" value="$(V_N1TUSR)" size="10" maxlength="10">
                                                        <a href="$(homeURL)$(phpPath)UserSearch.php$(altVarBase)&amp;docName=Chg&amp;userFld=toUser&amp;descFld=none" onclick="$(searchWinVar)">$(searchImage)</a></td>
                                  <td class="inputalph"><input type="checkbox" name="allUser" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmUser.value='', this.form.toUser.value='';"></td>
                                  @Build_Sort_Select("srtUser", "$(V_N1SUSR)")
                                  <td align=center><input type="checkbox" name="totUser" $(totChecked) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N1FUSR)
                              @DspErrMsg(Err_N1TUSR)
                              @DspErrMsg(Err_N1AUSR)
                              @DspErrMsg(Err_N1SUSR)
                              @DspErrMsg(Err_N1PUSR)

                              @Field_Checked(V_N1AWSD, "ALL", allChecked)
                              @Field_Checked(V_N1PWSD, "Y", totChecked)
                              @SetTextOvr(Err_N1FWSD)
                              %if (textOvr == "") @SetTextOvr(Err_N1TWSD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AWSD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SWSD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PWSD) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Workstation</span></td>
                                  <td class="inputalph"><input type="text" name="frmWS" value="$(V_N1FWSD)" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input type="text" name="toWS" value="$(V_N1TWSD)" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input type="checkbox" name="allWS" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmWS.value='', this.form.toWS.value='';"></td>
                                  @Build_Sort_Select("srtWS", "$(V_N1SWSD)")
                                  <td align=center><input type="checkbox" name="totWS" $(totChecked) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N1FWSD)
                              @DspErrMsg(Err_N1TWSD)
                              @DspErrMsg(Err_N1AWSD)
                              @DspErrMsg(Err_N1SWSD)
                              @DspErrMsg(Err_N1PWSD)

                              @Field_Checked(V_N1APGN, "ALL", allChecked)
                              @Field_Checked(V_N1PPGN, "Y", totChecked)
                              @SetTextOvr(Err_N1FPGN)
                              %if (textOvr == "") @SetTextOvr(Err_N1TPGN) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1APGN) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SPGN) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PPGN) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Program Name</span></td>
                                  <td class="inputalph"><input type="text" name="frmProgram" value="$(V_N1FPGN)" size="10" maxlength="10">
                                                        <a href="$(homeURL)$(cGIPath)OverridePgmSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;pgmFld=frmProgram&amp;prtfFld=frmPrinter&amp;descFld=frmProgramDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="frmProgramDesc"></td>
                                  <td class="inputalph"><input type="text" name="toProgram" value="$(V_N1TPGN)" size="10" maxlength="10">
                                                        <a href="$(homeURL)$(cGIPath)OverridePgmSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;pgmFld=toProgram&amp;prtfFld=toPrinter&amp;descFld=toProgramDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="toProgramDesc"></td>
                                  <td class="inputalph"><input type="checkbox" name="allProgram" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmProgram.value='', this.form.toProgram.value='';"></td>
                                  @Build_Sort_Select("srtProgram", "$(V_N1SPGN)")
                                  <td align=center><input type="checkbox" name="totProgram" $(totChecked) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N1FPGN)
                              @DspErrMsg(Err_N1TPGN)
                              @DspErrMsg(Err_N1APGN)
                              @DspErrMsg(Err_N1SPGN)
                              @DspErrMsg(Err_N1PPGN)

                              @Field_Checked(V_N1APFN, "ALL", allChecked)
                              @Field_Checked(V_N1PPFN, "Y", totChecked)
                              @SetTextOvr(Err_N1FPFN)
                              %if (textOvr == "") @SetTextOvr(Err_N1TPFN) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1APFN) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SPFN) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PPFN) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Printer File</span></td>
                                  <td class="inputalph"><input type="text" name="frmPrinter" value="$(V_N1FPFN)" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input type="text" name="toPrinter" value="$(V_N1TPFN)" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input type="checkbox" name="allPrinter" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmPrinter.value='', this.form.toPrinter.value='';"></td>
                                  @Build_Sort_Select("srtPrinter", "$(V_N1SPFN)")
                                  <td align=center><input type="checkbox" name="totPrinter" $(totChecked) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N1FPFN)
                              @DspErrMsg(Err_N1TPFN)
                              @DspErrMsg(Err_N1APFN)
                              @DspErrMsg(Err_N1SPFN)
                              @DspErrMsg(Err_N1PPFN)

                              @Field_Checked(V_N1AJBN, "ALL", allChecked)
                              @Field_Checked(V_N1PJBN, "Y", totChecked)
                              @SetTextOvr(Err_N1FJBN)
                              %if (textOvr == "") @SetTextOvr(Err_N1TJBN) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AJBN) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SJBN) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PJBN) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Job Name</span></td>
                                  <td class="inputalph"><input type="text" name="frmJobName" value="$(V_N1FJBN)" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input type="text" name="toJobName" value="$(V_N1TJBN)" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input type="checkbox" name="allJobName" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmJobName.value='', this.form.toJobName.value='';"></td>
                                  @Build_Sort_Select("srtJobName", "$(V_N1SJBN)")
                                  <td align=center><input type="checkbox" name="totJobName" $(totChecked) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N1FJBN)
                              @DspErrMsg(Err_N1TJBN)
                              @DspErrMsg(Err_N1AJBN)
                              @DspErrMsg(Err_N1SJBN)
                              @DspErrMsg(Err_N1PJBN)

                              @Field_Checked(V_N1AJBD, "ALL", allChecked)
                              @Field_Checked(V_N1PJBD, "Y", totChecked)
                              @SetTextOvr(Err_N1FJBD)
                              %if (textOvr == "") @SetTextOvr(Err_N1TJBD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AJBD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SJBD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PJBD) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Job Description</span></td>
                                  <td class="inputalph"><input type="text" name="frmJobDesc" value="$(V_N1FJBD)" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input type="text" name="toJobDesc" value="$(V_N1TJBD)" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input type="checkbox" name="allJobDesc" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmJobDesc.value='', this.form.toJobDesc.value='';"></td>
                                  @Build_Sort_Select("srtJobDesc", "$(V_N1SJBD)")
                                  <td align=center><input type="checkbox" name="totJobDesc" $(totChecked) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N1FJBD)
                              @DspErrMsg(Err_N1TJBD)
                              @DspErrMsg(Err_N1AJBD)
                              @DspErrMsg(Err_N1SJBD)
                              @DspErrMsg(Err_N1PJBD)

                              @Field_Checked(V_N1AJBQ, "ALL", allChecked)
                              @Field_Checked(V_N1PJBQ, "Y", totChecked)
                              @SetTextOvr(Err_N1FJBQ)
                              %if (textOvr == "") @SetTextOvr(Err_N1TJBQ) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AJBQ) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SJBQ) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PJBQ) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Job Queue</span></td>
                                  <td class="inputalph"><input type="text" name="frmJobq" value="$(V_N1FJBQ)" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input type="text" name="toJobq" value="$(V_N1TJBQ)" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input type="checkbox" name="allJobq" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmJobq.value='', this.form.toJobq.value='';"></td>
                                  @Build_Sort_Select("srtJobq", "$(V_N1SJBQ)")
                                  <td align=center><input type="checkbox" name="totJobq" $(totChecked) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N1FJBQ)
                              @DspErrMsg(Err_N1TJBQ)
                              @DspErrMsg(Err_N1AJBQ)
                              @DspErrMsg(Err_N1SJBQ)
                              @DspErrMsg(Err_N1PJBQ)

                              @Field_Checked(V_N1AOTQ, "ALL", allChecked)
                              @Field_Checked(V_N1POTQ, "Y", totChecked)
                              @SetTextOvr(Err_N1FOTQ)
                              %if (textOvr == "") @SetTextOvr(Err_N1TOTQ) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AOTQ) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SOTQ) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1POTQ) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Output Queue</span></td>
                                  <td class="inputalph"><input type="text" name="frmOutq" value="$(V_N1FOTQ)" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input type="text" name="toOutq" value="$(V_N1TOTQ)" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input type="checkbox" name="allOutq" value='ALL' $(allChecked) onClick="if (this.checked) this.form.frmOutq.value='', this.form.toOutq.value='';"></td>
                                  @Build_Sort_Select("srtOutq", "$(V_N1SOTQ)")
                                  <td align=center><input type="checkbox" name="totOutq" $(totChecked) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N1FOTQ)
                              @DspErrMsg(Err_N1TOTQ)
                              @DspErrMsg(Err_N1AOTQ)
                              @DspErrMsg(Err_N1SOTQ)
                              @DspErrMsg(Err_N1POTQ)
                          </table>

                          @dtw_assign(envProgram, "HSYEOL")
                          @dtw_assign(envPrinter, "HSYEOLPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField != "")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSYEOS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"

  @dtw_assign(edtVar, "")
  @Concat_Field("@@job@", JobFilled)
  @Concat_Field("@@prt@", PrtFilled)
  @Concat_Field("@@nop@", NoPFilled)

  @dtw_mUPPERCASE(frmApplID)                                                             @Concat_Field("@@fapd", frmApplID)
  @dtw_mUPPERCASE(toApplID)                                                              @Concat_Field("@@tapd", toApplID)
  @dtw_mUPPERCASE(allApplID) %if (allApplID != "ALL") @dtw_assign(allApplID, "") %endif  @Concat_Field("@@aapd", allApplID)
                                                                                         @Concat_Field("@@sapd", @dtw_rstrip(srtApplID))
  %if (totApplID != "Y") @dtw_assign(totApplID, "N") %endif                              @Concat_Field("@@papd", totApplID)

  @dtw_mUPPERCASE(frmUser)                                                         @Concat_Field("@@fusr", frmUser)
  @dtw_mUPPERCASE(toUser)                                                          @Concat_Field("@@tusr", toUser)
  @dtw_mUPPERCASE(allUser) %if (allUser != "ALL") @dtw_assign(allUser, "") %endif  @Concat_Field("@@ausr", allUser)
                                                                                   @Concat_Field("@@susr", @dtw_rstrip(srtUser))
  %if (totUser != "Y") @dtw_assign(totUser, "N") %endif                            @Concat_Field("@@pusr", totUser)

  @dtw_mUPPERCASE(frmWS)                                                     @Concat_Field("@@fwsd", frmWS)
  @dtw_mUPPERCASE(toWS)                                                      @Concat_Field("@@twsd", toWS)
  @dtw_mUPPERCASE(allWS) %if (allWS != "ALL") @dtw_assign(allWS, "") %endif  @Concat_Field("@@awsd", allWS)
                                                                             @Concat_Field("@@swsd", @dtw_rstrip(srtWS))
  %if (totWS != "Y") @dtw_assign(totWS, "N") %endif                          @Concat_Field("@@pwsd", totWS)

  @dtw_mUPPERCASE(frmProgram)                                                               @Concat_Field("@@fpgn", frmProgram)
  @dtw_mUPPERCASE(toProgram)                                                                @Concat_Field("@@tpgn", toProgram)
  @dtw_mUPPERCASE(allProgram) %if (allProgram != "ALL") @dtw_assign(allProgram, "") %endif  @Concat_Field("@@apgn", allProgram)
                                                                                            @Concat_Field("@@spgn", @dtw_rstrip(srtProgram))
  %if (totProgram != "Y") @dtw_assign(totProgram, "N") %endif                               @Concat_Field("@@ppgn", totProgram)

  @dtw_mUPPERCASE(frmPrinter)                                                               @Concat_Field("@@fpfn", frmPrinter)
  @dtw_mUPPERCASE(toPrinter)                                                                @Concat_Field("@@tpfn", toPrinter)
  @dtw_mUPPERCASE(allPrinter) %if (allPrinter != "ALL") @dtw_assign(allPrinter, "") %endif  @Concat_Field("@@apfn", allPrinter)
                                                                                            @Concat_Field("@@spfn", @dtw_rstrip(srtPrinter))
  %if (totPrinter != "Y") @dtw_assign(totPrinter, "N") %endif                               @Concat_Field("@@ppfn", totPrinter)

  @dtw_mUPPERCASE(frmJobName)                                                               @Concat_Field("@@fjbn", frmJobName)
  @dtw_mUPPERCASE(toJobName)                                                                @Concat_Field("@@tjbn", toJobName)
  @dtw_mUPPERCASE(allJobName) %if (allJobName != "ALL") @dtw_assign(allJobName, "") %endif  @Concat_Field("@@ajbn", allJobName)
                                                                                            @Concat_Field("@@sjbn", @dtw_rstrip(srtJobName))
  %if (totJobName != "Y") @dtw_assign(totJobName, "N") %endif                               @Concat_Field("@@pjbn", totJobName)

  @dtw_mUPPERCASE(frmJobDesc)                                                               @Concat_Field("@@fjbd", frmJobDesc)
  @dtw_mUPPERCASE(toJobDesc)                                                                @Concat_Field("@@tjbd", toJobDesc)
  @dtw_mUPPERCASE(allJobDesc) %if (allJobDesc != "ALL") @dtw_assign(allJobDesc, "") %endif  @Concat_Field("@@ajbd", allJobDesc)
                                                                                            @Concat_Field("@@sjbd", @dtw_rstrip(srtJobDesc))
  %if (totJobDesc != "Y") @dtw_assign(totJobDesc, "N") %endif                               @Concat_Field("@@pjbd", totJobDesc)

  @dtw_mUPPERCASE(frmJobq)                                                         @Concat_Field("@@fjbq", frmJobq)
  @dtw_mUPPERCASE(toJobq)                                                          @Concat_Field("@@tjbq", toJobq)
  @dtw_mUPPERCASE(allJobq) %if (allJobq != "ALL") @dtw_assign(allJobq, "") %endif  @Concat_Field("@@ajbq", allJobq)
                                                                                   @Concat_Field("@@sjbq", @dtw_rstrip(srtJobq))
  %if (totJobq != "Y") @dtw_assign(totJobq, "N") %endif                            @Concat_Field("@@pjbq", totJobq)

  @dtw_mUPPERCASE(frmOutq)                                                         @Concat_Field("@@fotq", frmOutq)
  @dtw_mUPPERCASE(toOutq)                                                          @Concat_Field("@@totq", toOutq)
  @dtw_mUPPERCASE(allOutq) %if (allOutq != "ALL") @dtw_assign(allOutq, "") %endif  @Concat_Field("@@aotq", allOutq)
                                                                                   @Concat_Field("@@sotq", @dtw_rstrip(srtOutq))
  %if (totOutq != "Y") @dtw_assign(totOutq, "N") %endif                            @Concat_Field("@@potq", totOutq)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}