%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Item Comments"
  d2wName                 = "VendCustItemComments.d2w"
  d2wVarBase              = "$(genericVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  DTW_PAD_PGM_PARMS       = "YES"
%}

%FUNCTION(dtw_sql) ITEM_COMMENTS (IN  CHAR(64)  profileHandle,
				       CHAR(2)   dataBaseID,
                                      CHAR(1)   vendCustFlag,
                                      DEC(7,0)  vendCustNumber,
                                      CHAR(15)  item)
{CALL $(pgmLibrary)HHDVCP_W

  %REPORT{
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "headcmt.icl"
          </head>
      	
          <body $(bodyTagAttr)>
              %INCLUDE "$(cmtBanner)"
              <table $(contentTable)>
                  %if (vendCustFlag == "C")
                      @Format_Header("Customer Item", $(itemDesc), $(vendCustItemNumber))
                  %else
                      @Format_Header("Vendor Item", $(itemDesc), $(vendCustItemNumber))
                  %endif
              </table>
              $(hrTagAttr)

              <table $(contentTable)>
                  %ROW{
                      <tr><td class="colalph"> $(V_ICCMNT)</td></tr>
                  %}
              </table>
              $(hrTagAttr)
    	       <table $(contentTable)>
                  <tr>
                      <td valign="top">
                          %INCLUDE "CloseWindow.icl"
                      </td>
                  </tr>
              </table>
              %INCLUDE "$(cmtTrailer)"
          </body>
      </html>
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_concat(itemNumber, "               ", item)
  @ITEM_COMMENTS(profileHandle, dataBaseID, vendCustFlag, vendCustNumber, item)
%}