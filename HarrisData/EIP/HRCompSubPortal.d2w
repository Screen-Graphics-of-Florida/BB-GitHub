%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"

%Define {
  page_title		= "Company"
  d2wName              = "HRCompSubPortal.d2w"
  d2wVarBase           = "$(genericVarBase)&amp;hrCompany=@dtw_rurlescseq(hrCompany)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  RPT_MAX_ROWS 	= "10"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  facilityZero        = "0000"
  rowIndexNext		= "1"
  totalPages		= "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@hrCompany", "@dtw_rurlescseq(hrCompany)", "1", "a", workURL)
  @dtw_replace(workURL, "@@subPortal", "@dtw_rurlescseq(subPortal)", "1", "a", workURL)
  @dtw_replace(workURL, "@@subPortalID", "@dtw_rurlescseq(subPortalID)", "1", "a", workURL)
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @HrCoFacUserView(profileHandle, dataBaseID, userPass, hrCompany, facilityNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
                  <!-- Start Of Trailer Code -->
                  %INCLUDE "banner.icl"
                  <!-- End Of Trailer Code -->
                  <table $(baseTable)>
                      <tr valign="top">
                          @dtw_assign(pageID, $(subPortalID))
                          @dtw_assign(page_title, $(subPortal))
                          %if (formatToPrint == "")
                              <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                          %endif
                          <td class="content">
                              @dtw_assign(stmtSQL, "")
                              @dtw_concat(stmtSQL, "Select * From HRCOFC ", stmtSQL)
                              @dtw_concat(stmtSQL, " Where CFCOMP = $(hrCompany) and CFFACL = 0", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              @CompSelect_Query(profileHandle, dataBaseID, stmtSQL)
                          </td>
                      </tr>
                  </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) CompSelect_Query (IN CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)&amp;backHome=@dtw_rurlescseq(backHome)" title="Return To Company">$(portalHome)</a>
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif

          </tr>

          @RetHrCompNam(profileHandle, dataBaseID, hrCompany, facilityZero, coFacName)
          <tr><td><h2>$(coFacName)</h2></td></tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"
      $(hrTagAttr)

      <table $(contentTable)>
          <colgroup>
              <col width="60%">
	       <col width="20%">
	   		
          %ROW {
              @EditPhoneNumber(V_CFPHON)
              <tr><td class="dspalph">$(V_CFADR1)</td>
                  <td class="dsphdr">Phone Number: </td>
                  <td class="dspnmbr">$(V_CFPHON)</td>
              </tr>

              <tr><td class="dspalph">$(V_CFADR2)</td>
              </tr>
	   			
              <tr><td class="dspalph">$(V_CFCITY), $(V_CFSTID) $(V_CFZIP)</td>
              </tr>
          %}
      </table>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}