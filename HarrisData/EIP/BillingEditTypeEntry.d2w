%INCLUDE "$(baseVar)"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Edit List &nbsp; "
  d2wName                 = "BillingEditTypeEntry.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;oneBillCode=@dtw_rurlescseq(oneBillCode)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "10"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmNoUpdate() {return confirm("Confirm Cancel Of Edit List Selection")}
              function confirmSelectAll() {return confirm("Confirm Selection Of All Order Types For Edit")}
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "BILLINGEDITTYPEENTRY")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " OEBIPTW ", fileSQL)
                      @dtw_concat(selectSQL, "WTXHND='$(profileHandle)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " ORDER BY WTXHND,WTOTYP ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Billing_Edit_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Billing_Edit_Query (IN  CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
  {CALL $(pgmLibrary)HSYSQL_W

      %REPORT{
          %if (sql_Record_Count != "1")
              <table $(contentTable)>
                  <colgroup>
                      <col width="50%">
                      <col width="45%">
                  <tr><td><h1>$(page_title)</h1></td>
                      <td class="toolbar">
                          %if (errFound == "")
                              <a href="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)&amp;oneBillCode=@dtw_rurlescseq(oneBillCode)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">$(selectContinueImage)</a>
                          %endif
                          <a onClick="return confirmSelectAll()" href="$(homeURL)$(cGIPath)$(d2wName)/SELECTALL$(d2wVarBase)&amp;oneBillCode=@dtw_rurlescseq(oneBillCode)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">$(selectAllImage)</a>
                          <a onClick="return confirmNoUpdate()" href="$(homeURL)$(cGIPath)$(d2wName)/NOUPDATE$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">$(selectCancelImage)</a>
                          %if (oneBillCode == "")
                              <a href="$(homeURL)$(cGIPath)BillingEditCodeEntry.d2w/INPUT$(genericVarBase)&amp;oneBillCode=@dtw_rurlescseq(oneBillCode)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">$(selectBackImage)</a>
                          %endif
                          @dtw_assign(medIcon, "Y")
                          %INCLUDE "HelpPage.icl"
                      </td>
                  </tr>
              </table>

              $(hrTagAttr)

              %INCLUDE "AssignPageValue.icl"
    			
              <form class="formClass" name="Chg" METHOD=POST ACTION="$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(d2wVarBase)&amp;oneBillCode=@dtw_rurlescseq(oneBillCode)&amp;updateRowNum=@dtw_rurlescseq($(START_ROW_NUM))&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
                  <table $(contentTable)>

                      <tr>
                          <td class="colhdr">Sel</td>
                          <td class="colhdr">Order<br>Type</td>
                          <td class="colhdr">Description</td>
                      </tr>
                      %if (errFound != "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@selc", " ")          @dtw_assign(Err_N2SELC, fieldValue)
                          @DspErrMsg(Err_N2SELC)
                          @dtw_assign(errFound, "")
                      %endif
	   %endif

                      %ROW{
                          %if (sql_Record_Count == "1")
                              <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/SELECTALL$(d2wVarBase)&amp;oneBillCode=Y&amp;oneOrderType=@dtw_rurlescseq(oneOrderType)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
                          %else
                              %INCLUDE "SetRowClass.icl"
                      	
                              %if (V_WTSELC == "S")
                                  @dtw_assign(selected, "CHECKED")
                              %else
                                  @dtw_assign(selected, "")
                              %endif

                              <tr class="$(rowClass)">
                                  <td class="colcode"><input name="sel$(ROW_NUM)" type="checkbox" VALUE='S' $(selected) onClick="javascript:check(document.Chg)"></td>
                                  <td class="colcode">$(V_WTOTYP)</td>
                                  <td class="colalph">$(V_WTDESC)<input type="hidden" name="typ$(ROW_NUM)" value=$(V_WTOTYP)></td>
                              </tr>
                          %endif
                      %}
    	           </table>
              </form>
              %if (sql_Record_Count != "1")
                  %INCLUDE "PageBottom.icl"
                  $(hrTagAttr)
                  %INCLUDE "Copyright.icl"
    	       %endif
      %}
  %}

%FUNCTION(dtw_directcall) Update_Billing_Edit (IN    CHAR(64)    profileHandle,
                                                     CHAR(2)     dataBaseID,
                                                     CHAR(2)     updCode,
                                               INOUT CHAR(1)     errFound,
                                               INOUT CHAR(32000) edtVar,                             	
                                               INOUT CHAR(32000) errVar)
  {%EXEC {HOEESL_W.PGM %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @dtw_assign(updCode, "ET")
  @Update_Billing_Edit (profileHandle, dataBaseID, updCode, errFound, edtVar, errVar)
  @Set_SQL(stmtSQL)
%}

%HTML(UPDATE) {
  %INCLUDE "setLibraryList.icl"

  @dtw_assign(edtVar, "")
  @Concat_Field("@@sl01", sel1)
  @Concat_Field("@@sl02", sel2)
  @Concat_Field("@@sl03", sel3)
  @Concat_Field("@@sl04", sel4)
  @Concat_Field("@@sl05", sel5)
  @Concat_Field("@@sl06", sel6)
  @Concat_Field("@@sl07", sel7)
  @Concat_Field("@@sl08", sel8)
  @Concat_Field("@@sl09", sel9)
  @Concat_Field("@@sl10", sel10)
  @Concat_Field("@@ty01", typ1)
  @Concat_Field("@@ty02", typ2)
  @Concat_Field("@@ty03", typ3)
  @Concat_Field("@@ty04", typ4)
  @Concat_Field("@@ty05", typ5)
  @Concat_Field("@@ty06", typ6)
  @Concat_Field("@@ty07", typ7)
  @Concat_Field("@@ty08", typ8)
  @Concat_Field("@@ty09", typ9)
  @Concat_Field("@@ty10", typ10)
  @dtw_concat(edtVar, "}{", edtVar)

  @dtw_assign(updCode, "UT")
  @Update_Billing_Edit (profileHandle, dataBaseID, updCode, errFound, edtVar, errVar)

  @dtw_assign(START_ROW_NUM,  "$(updateRowNum)")
  @Set_SQL(stmtSQL)
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)BillingEditListEntry.d2w/ENTRY$(genericVarBase)&amp;oneBillCode=@dtw_rurlescseq(oneBillCode)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(SELECTALL) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @dtw_assign(updCode, "AT")
  @Update_Billing_Edit (profileHandle, dataBaseID, updCode, errFound, edtVar, errVar)
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)BillingEditListEntry.d2w/ENTRY$(genericVarBase)&amp;oneBillCode=@dtw_rurlescseq(oneBillCode)&amp;oneOrderType=@dtw_rurlescseq(oneOrderType)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(NOUPDATE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @dtw_assign(updCode, "D ")
  @Update_Billing_Edit (profileHandle, dataBaseID, updCode, errFound, edtVar, errVar)

  @DTW_ASSIGN(confMessage, "Confirm Cancel Of Edit List Selection")
  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)billing.d2w/REPORT$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @dtw_assign(updCode, "ET")
  @Update_Billing_Edit (profileHandle, dataBaseID, updCode, errFound, edtVar, errVar)
  @Set_SQL(stmtSQL)
%}