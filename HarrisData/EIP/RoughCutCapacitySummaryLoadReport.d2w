%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Rough Cut Capacity Summary Load Report"
  d2wName                 = "RoughCutCapacitySummaryLoadReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;apid=@dtw_rurlescseq(apid)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                      if  (editNum(document.Chg.fromPlantNumber, 3, 0) &&
                           editNum(document.Chg.toPlantNumber, 3, 0) &&
                           editFromToAll(document.Chg.fromPlantNumber, document.Chg.toPlantNumber, document.Chg.allPlantNumber, 3)
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ROUGHCUTCAPACITYSUMMARYLOADREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromPlantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@fplt", "fromPlantNumber")        @dtw_assign(Err_N1FPLT,  fieldValue)
                                  @DecatErr_Field("@@tplt", "toPlantNumber")        @dtw_assign(Err_N1TPLT,  fieldValue)
                                  @DecatErr_Field("@@aplt", "allPlantNumber")        @dtw_assign(Err_N1APLT,  fieldValue)
                                  @DecatErr_Field("@@type", "reportType")        @dtw_assign(Err_N1TYPE,  fieldValue)
                                  @DecatErr_Field("@@povr", "percentOver")        @dtw_assign(Err_N1POVR,  fieldValue)
                                  @DecatErr_Field("@@pund", "percentUnder")        @dtw_assign(Err_N1PUND,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@fplt")  @dtw_assign(V_N1FPLT, fieldValue)
                                  @Decat_Field("@@tplt")  @dtw_assign(V_N1TPLT, fieldValue)
                                  @Decat_Field("@@aplt")  @dtw_assign(V_N1APLT, fieldValue)
                                  @Decat_Field("@@type")  @dtw_assign(V_N1TYPE, fieldValue)
                                  @Decat_Field("@@povr")  @dtw_assign(V_N1POVR, fieldValue)
                                  @Decat_Field("@@pund")  @dtw_assign(V_N1PUND, fieldValue)

                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}

                                  %if (V_N1APLT == "ALL")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPlantNumber, "")
                                  %endif

                              %else

                                  @RtvDftPlant(plantNumber, plantName)
                                  %if (plantNumber == "0")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(V_N1FPLT, plantNumber)
                                      @dtw_assign(V_N1TPLT, plantNumber)
                                      @dtw_assign(checkedallPlantNumber, "")
                                  %endif
                              %endif
                              %if (V_N1TYPE == "02")
                                  @dtw_assign(prd, "")
                                  @dtw_assign(sch, "CHECKED")
                              %else
                                  @dtw_assign(prd, "CHECKED")
                                  @dtw_assign(sch, "")
                              %endif

                          </table>

                          <table $(contentTable)>

                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_N1FPLT)
                              %if (textOvr == "") @SetTextOvr(Err_N1TPLT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1APLT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                  <td class="inputnmbr"><input name="fromPlantNumber" value="$(V_N1FPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromPlantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toPlantNumber" value="$(V_N1TPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toPlantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName" type="hidden"></td>
                                  <td class="inputalph"><input name="allPlantNumber" value='ALL' $(checkedallPlantNumber) type="checkbox" onClick="if (this.checked) this.form.fromPlantNumber.value='', this.form.toPlantNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FPLT)
                              @DspErrMsg(Err_N1TPLT)
                              @DspErrMsg(Err_N1APLT)
                              <tr><td  class="dsphdr">Quantity Selection</td>
                                  <td class="inputnmbr"><input name="reportType" type="radio" VALUE='01' $(prd)>Use Production Plan Quantities</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="reportType" type="radio" VALUE='02' $(sch)>Use Master Schedule Quantities </td>
                              </tr>
                              <tr><td class="dsphdr">Include Work Centers With % Of Capacity Over</td>
                                  <td class="inputnmbr"><input name="percentOver" type="text" value="$(V_N1POVR)" size="3" maxlength="3"></a></td>
                              </tr>
                              <tr><td class="dsphdr">Include Work Centers With % Of Capacity Under</td>
                                  <td class="inputnmbr"><input name="percentUnder" type="text" value="$(V_N1PUND)" size="3" maxlength="3"></a></td>
                              </tr>


                          </table>

                          @dtw_assign(envProgram, "HMS503")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HMSRSS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allPlantNumber)

  @dtw_assign(fromPlantNumber,@dtw_rstrip(fromPlantNumber))
  @dtw_assign(toPlantNumber,@dtw_rstrip(toPlantNumber))

  %if (allPlantNumber != "ALL")
      @dtw_assign(allPlantNumber, "")
  %endif

  @dtw_assign(percentOver,@dtw_rstrip(percentOver))
  @dtw_assign(percentUnder,@dtw_rstrip(percentUnder))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@fplt", fromPlantNumber)
  @Concat_Field("@@tplt", toPlantNumber)
  @Concat_Field("@@aplt", allPlantNumber)
  @Concat_Field("@@type", reportType)
  @Concat_Field("@@povr", percentOver)
  @Concat_Field("@@pund", percentUnder)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}