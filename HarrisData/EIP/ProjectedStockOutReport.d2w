%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Projected Stock Out Report"
  d2wName                 = "ProjectedStockOutReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "4"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.stockOutDate.value =="" ||
                      document.Chg.numberOfPeriods.value =="")
                     {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.numberOfPeriods, 2, 0) &&
                      editNum(document.Chg.workingDaysExpired, 2, 0) &&
                      editNum(document.Chg.fromWarehouse, 3, 0) &&
                      editNum(document.Chg.toWarehouse, 3, 0) &&
                      editNum(document.Chg.fromVendorNumber, 7, 0) &&
                      editNum(document.Chg.toVendorNumber, 7, 0) &&
                      editdate(document.Chg.stockOutDate) &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromWarehouse, document.Chg.toWarehouse, document.Chg.allWarehouse, 3) &&
                      editFromToAll(document.Chg.fromProductClass, document.Chg.toProductClass, document.Chg.allProductClass, "A") &&
                      editFromToAll(document.Chg.fromVendorNumber, document.Chg.toVendorNumber, document.Chg.allVendorNumber, 7))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PROJECTEDSTOCKOUTREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
                      %INCLUDE "RequiredField.icl"
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "stockOutDate")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@popo", "printOpenPO")     @dtw_assign(Err_N1POPO,  fieldValue)
                                  @DecatErr_Field("@@sodt", "stockOutDate")     @dtw_assign(Err_N2SODT,  fieldValue)
                                  @DecatErr_Field("@@nper", "numberOfPeriods")     @dtw_assign(Err_N2NPER,  fieldValue)
                                  @DecatErr_Field("@@expd", "workingDaysExpired")     @dtw_assign(Err_N2EXPD,  fieldValue)
                                  @DecatErr_Field("@@sale", "sales")   @dtw_assign(Err_N2SALE,  fieldValue)
                                  @DecatErr_Field("@@issu", "issues") @dtw_assign(Err_N2ISSU,  fieldValue)
                                  @DecatErr_Field("@@frit", "fromItemNumber")        @dtw_assign(Err_N2FRIT,  fieldValue)
                                  @DecatErr_Field("@@toit", "toItemNumber")        @dtw_assign(Err_N2TOIT,  fieldValue)
                                  @DecatErr_Field("@@alit", "allItemNumber")        @dtw_assign(Err_N2ALIT,  fieldValue)
                                  @DecatErr_Field("@@sqit", "sortItemNumber")        @dtw_assign(Err_N2SQIT,  fieldValue)
                                  @DecatErr_Field("@@frwh", "fromWarehouse")        @dtw_assign(Err_N2FRWH,  fieldValue)
                                  @DecatErr_Field("@@towh", "toWarehouse")        @dtw_assign(Err_N2TOWH,  fieldValue)
                                  @DecatErr_Field("@@alwh", "allWarehouse")        @dtw_assign(Err_N2ALWH,  fieldValue)
                                  @DecatErr_Field("@@sqwh", "sortWarehouse")        @dtw_assign(Err_N2SQWH,  fieldValue)
                                  @DecatErr_Field("@@frpc", "fromProductClass")        @dtw_assign(Err_N2FRPC,  fieldValue)
                                  @DecatErr_Field("@@topc", "toProductClass")        @dtw_assign(Err_N2TOPC,  fieldValue)
                                  @DecatErr_Field("@@alpc", "allProductClass")        @dtw_assign(Err_N2ALPC,  fieldvalue)
                                  @DecatErr_Field("@@sqpc", "sortProductClass")        @dtw_assign(Err_N2SQPC,  fieldValue)
                                  @DecatErr_Field("@@frvn", "fromVendorNumber")          @dtw_assign(Err_N2FRVN,  fieldValue)
                                  @DecatErr_Field("@@tovn", "toVendorNumber")          @dtw_assign(Err_N2TOVN,  fieldValue)
                                  @DecatErr_Field("@@alvn", "allVendorNumber")          @dtw_assign(Err_N2ALVN,  fieldValue)
                                  @DecatErr_Field("@@sqvn", "sortVendorNumber")          @dtw_assign(Err_N2SQVN,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@popo")  @dtw_assign(V_N1POPO,  fieldValue)
                                  @Decat_Field("@@sodt")  @dtw_assign(V_N2SODT,  fieldValue)
                                  @Decat_Field("@@nper")  @dtw_assign(V_N2NPER,  fieldValue)
                                  @Decat_Field("@@expd")  @dtw_assign(V_N2EXPD,  fieldValue)
                                  @Decat_Field("@@sale")  @dtw_assign(V_N2SALE,  fieldValue)
                                  @Decat_Field("@@issu")  @dtw_assign(V_N2ISSU,  fieldValue)
                                  @Decat_Field("@@frit")  @dtw_assign(V_N2FRIT,  fieldValue)
                                  @Decat_Field("@@toit")  @dtw_assign(V_N2TOIT,  fieldValue)
                                  @Decat_Field("@@alit")  @dtw_assign(V_N2ALIT,  fieldValue)
                                  @Decat_Field("@@sqit")  @dtw_assign(V_N2SQIT,  fieldValue)
                                  @Decat_Field("@@frwh")  @dtw_assign(V_N2FRWH,  fieldValue)
                                  @Decat_Field("@@towh")  @dtw_assign(V_N2TOWH,  fieldValue)
                                  @Decat_Field("@@alwh")  @dtw_assign(V_N2ALWH,  fieldValue)
                                  @Decat_Field("@@sqwh")  @dtw_assign(V_N2SQWH,  fieldValue)
                                  @Decat_Field("@@frpc")  @dtw_assign(V_N2FRPC,  fieldValue)
                                  @Decat_Field("@@topc")  @dtw_assign(V_N2TOPC,  fieldValue)
                                  @Decat_Field("@@alpc")  @dtw_assign(V_N2ALPC,  fieldValue)
                                  @Decat_Field("@@sqpc")  @dtw_assign(V_N2SQPC,  fieldValue)
                                  @Decat_Field("@@frvn")  @dtw_assign(V_N2FRVN,  fieldValue)
                                  @Decat_Field("@@tovn")  @dtw_assign(V_N2TOVN,  fieldValue)
                                  @Decat_Field("@@alvn")  @dtw_assign(V_N2ALVN,  fieldValue)
                                  @Decat_Field("@@sqvn")  @dtw_assign(V_N2SQVN,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1POPO == "02")
                                      @dtw_assign(no, "")
                                      @dtw_assign(yes, "CHECKED")
                                  %else
                                      @dtw_assign(no, "CHECKED")
                                      @dtw_assign(yes, "")
                                  %endif
                                  %if (V_N2SALE == "1")
                                      @dtw_assign(checkedSales, "CHECKED")
                                  %else
                                      @dtw_assign(checkedSales, "")
                                  %endif
                                  %if (V_N2ISSU == "1")
                                      @dtw_assign(checkedIssues, "CHECKED")
                                  %else
                                      @dtw_assign(checkedIssues, "")
                                  %endif
                                  %if (V_N2ALIT == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_N2ALWH == "ALL")
                                      @dtw_assign(checkedallWarehouse, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallWarehouse, "")
                                  %endif
                                  %if (V_N2ALPC == "ALL")
                                      @dtw_assign(checkedallProductClass, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallProductClass, "")
                                  %endif
                                  %if (V_N2ALVN == "ALL")
                                      @dtw_assign(checkedallVendorNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallVendorNumber, "")
                                  %endif
                              %else
                                  @dtw_assign(no, "CHECKED")
                                  @dtw_assign(yes, "")
                                  @dtw_assign(checkedSales, "CHECKED")
                                  @dtw_assign(checkedIssues, "CHECKED")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallWarehouse, "CHECKED")
                                  @dtw_assign(checkedallProductClass, "CHECKED")
                                  @dtw_assign(checkedallVendorNumber, "CHECKED")
                              %endif

                              @SetTextOvr(Err_N1POPO)
                              <tr><td class="dsphdr"><span $(textOvr)>Print Open Purchase Orders On Report</span></td>
                                  <td class="inputnmbr"><input name="printOpenPO" type="radio" VALUE='01' $(no)>No</td>
                              </tr>
                              @DspErrMsg(Err_N1POPO)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="printOpenPO" type="radio" VALUE='02' $(yes)>Yes</td>
                              </tr>

                              @SetTextOvr(Err_N2SODT)
                              <tr><td class="dsphdr"><span $(textOvr)>Inventory Stock Out Date</span></td>
                                  <td class="inputnmbr"><input name="stockOutDate" value="$(V_N2SODT)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('stockOutDate');">$(reqFieldChar) $(calendarImage)</a></td>
                              </tr>
                              @DspErrMsg(Err_N2SODT)

                              @SetTextOvr(Err_N2NPER)
                              <tr><td class="dsphdr"><span $(textOvr)>Number Of Periods Of Usage To Include</span></td>
                                  <td class="inputnmbr"><input name="numberOfPeriods" value="$(V_N2NPER)" type="text" size="2" maxlength="2">$(reqFieldChar)</td>
                              </tr>
                              @DspErrMsg(Err_N2NPER)

                              @SetTextOvr(Err_N2EXPD)
                              <tr><td class="dsphdr"><span $(textOvr)>Number Of Working Days Expired This Period</span></td>
                                  <td class="inputnmbr"><input name="workingDaysExpired" value="$(V_N2EXPD)" type="text" size="2" maxlength="2"></td>
                              </tr>
                              @DspErrMsg(Err_N2EXPD)

                              @SetTextOvr(Err_N2SALE)
                              <tr><td class="dsphdr"><span $(textOvr)>Include Type</span></td>
                                  <td class="inputnmbr"><input name="sales" type="checkbox" VALUE='1' $(checkedSales)>Sales</td>
                              </tr>
                              @DspErrMsg(Err_N2SALE)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="issues" type="checkbox" VALUE='1' $(checkedIssues)>Issues</td>
                              </tr>

                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                              </tr>

                              @SetTextOvr(Err_N2FRIT)
                              %if (textOvr == "") @SetTextOvr(Err_N2TOIT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2ALIT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SQIT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N2FRIT)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N2TOIT)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                                  @Build_Sort_Select("sortItemNumber", "$(V_N2SQIT)")
                              </tr>
                              @DspErrMsg(Err_N2FRIT)
                              @DspErrMsg(Err_N2TOIT)
                              @DspErrMsg(Err_N2ALIT)
                              @DspErrMsg(Err_N2SQIT)

                              @SetTextOvr(Err_N2FRWH)
                              %if (textOvr == "") @SetTextOvr(Err_N2TOWH) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2ALWH) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SQWH) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Warehouse</span></td>
                                  <td class="inputnmbr"><input name="fromWarehouse" value="$(V_N2FRWH)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromWarehouse&amp;fldDesc=fwarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fwarehouseName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toWarehouse" value="$(V_N2TOWH)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toWarehouse&amp;fldDesc=twarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="twarehouseName" type="hidden"></td>
                                  <td class="inputalph"><input name="allWarehouse" value='ALL' $(checkedallWarehouse) type="checkbox" onClick="if (this.checked) this.form.fromWarehouse.value='', this.form.toWarehouse.value='';"></td>
                                  @Build_Sort_Select("sortWarehouse", "$(V_N2SQWH)")
                              </tr>
                              @DspErrMsg(Err_N2FRWH)
                              @DspErrMsg(Err_N2TOWH)
                              @DspErrMsg(Err_N2ALWH)
                              @DspErrMsg(Err_N2SQWH)

                              @SetTextOvr(Err_N2FRPC)
                              %if (textOvr == "") @SetTextOvr(Err_N2TOPC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2ALPC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SQPC) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Product Class</span></td>
                                  <td class="inputalph"><input name="fromProductClass" value="$(V_N2FRPC)" type="text" size="8" maxlength="4"><a href="$(homeURL)$(cGIPath)ProdClassSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromProductClass&amp;fldDesc=fproductClassDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="fproductClassDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="toProductClass" value="$(V_N2TOPC)" type="text" size="8" maxlength="4"><a href="$(homeURL)$(cGIPath)ProdClassSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toProductClass&amp;fldDesc=tproductClassDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="tproductClassDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allProductClass" value='ALL' $(checkedallProductClass) type="checkbox" onClick="if (this.checked) this.form.fromProductClass.value='', this.form.toProductClass.value='';"></td>
                                  @Build_Sort_Select("sortProductClass", "$(V_N2SQPC)")
                              </tr>
                              @DspErrMsg(Err_N2FRPC)
                              @DspErrMsg(Err_N2TOPC)
                              @DspErrMsg(Err_N2ALPC)
                              @DspErrMsg(Err_N2SQPC)

                              @SetTextOvr(Err_N2FRVN)
                              %if (textOvr == "") @SetTextOvr(Err_N2TOVN) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2ALVN) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SQVN) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Vendor Number</span></td>
                                  <td class="inputnmbr"><input name="fromVendorNumber" value="$(V_N2FRVN)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="vendorName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toVendorNumber" value="$(V_N2TOVN)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="vendorName" type="hidden"></td>
                                  <td class="inputalph"><input name="allVendorNumber" value='ALL' $(checkedallVendorNumber) type="checkbox" onClick="if (this.checked) this.form.fromVendorNumber.value='', this.form.toVendorNumber.value='';"></td>
                                  @Build_Sort_Select("sortVendorNumber", "$(V_N2SQVN)")
                              </tr>
                              @DspErrMsg(Err_N2FRVN)
                              @DspErrMsg(Err_N2TOVN)
                              @DspErrMsg(Err_N2ALVN)
                              @DspErrMsg(Err_N2SQVN)

                          </table>

                          @dtw_assign(envProgram, "HPOIAR")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HPOIAS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(allWarehouse)
  @dtw_mUPPERCASE(fromProductClass)
  @dtw_mUPPERCASE(toProductClass)
  @dtw_mUPPERCASE(allProductClass)
  @dtw_mUPPERCASE(allVendorNumber)

  @dtw_assign(stockOutDate,@dtw_rstrip(stockOutDate))
  @dtw_assign(numberOfPeriods,@dtw_rstrip(numberOfPeriods))
  @dtw_assign(workingDaysExpired,@dtw_rstrip(workingDaysExpired))
  @dtw_assign(sortItemNumber,@dtw_rstrip(sortItemNumber))
  @dtw_assign(fromWarehouse,@dtw_rstrip(fromWarehouse))
  @dtw_assign(toWarehouse,@dtw_rstrip(toWarehouse))
  @dtw_assign(sortWarehouse,@dtw_rstrip(sortWarehouse))
  @dtw_assign(sortProductClass,@dtw_rstrip(sortProductClass))
  @dtw_assign(fromVendorNumber,@dtw_rstrip(fromVendorNumber))
  @dtw_assign(toVendorNumber,@dtw_rstrip(toVendorNumber))
  @dtw_assign(sortVendorNumber,@dtw_rstrip(sortVendorNumber))

  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allWarehouse != "ALL")
      @dtw_assign(allWarehouse, "")
  %endif
  %if (allProductClass != "ALL")
      @dtw_assign(allProductClass, "")
  %endif
  %if (allVendorNumber != "ALL")
      @dtw_assign(allVendorNumber, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@popo", printOpenPO)
  @Concat_Field("@@sodt", stockOutDate)
  @Concat_Field("@@nper", numberOfPeriods)
  @Concat_Field("@@expd", workingDaysExpired)
  @Concat_Field("@@sale", sales)
  @Concat_Field("@@issu", issues)
  @Concat_Field("@@frit", fromItemNumber)
  @Concat_Field("@@toit", toItemNumber)
  @Concat_Field("@@alit", allItemNumber)
  @Concat_Field("@@sqit", sortItemNumber)
  @Concat_Field("@@frwh", fromWarehouse)
  @Concat_Field("@@towh", toWarehouse)
  @Concat_Field("@@alwh", allWarehouse)
  @Concat_Field("@@sqwh", sortWarehouse)
  @Concat_Field("@@frpc", fromProductClass)
  @Concat_Field("@@topc", toProductClass)
  @Concat_Field("@@alpc", allProductClass)
  @Concat_Field("@@sqpc", sortProductClass)
  @Concat_Field("@@frvn", fromVendorNumber)
  @Concat_Field("@@tovn", toVendorNumber)
  @Concat_Field("@@alvn", allVendorNumber)
  @Concat_Field("@@sqvn", sortVendorNumber)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}