%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Employee Entry Approval"
  d2wName                 = "EmployeeEntryApprove.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfInstance=@dtw_rurlescseq(wfInstance)&amp;wfInstanceDate=@dtw_rurlescseq(wfInstanceDate)&amp;wfWorkItem=@dtw_rurlescseq(wfWorkItem)&amp;wfWorkItemSequence=@dtw_rurlescseq(wfWorkItemSequence)&amp;wfParticipantId=@dtw_rurlescseq(wfParticipantId)&amp;wfProcess=@dtw_rurlescseq(wfProcess)&amp;wfPoint=@dtw_rurlescseq(wfPoint)&amp;wfSequence=@dtw_rurlescseq(wfSequence)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  maintainVar             = ""
  showIconPassWith        = ""
  showIconPassWithout     = ""
  recordCount             = ""
  V_IEWITM                = ""
  V_IEWISQ                = ""
  dataType                = "SSNO"
  modeD                   = "D"
  modeI                   = "I"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @RtvFldDesc("WIINST=$(wfInstance) and WIINDT=$(wfInstanceDate) and WIWITM=$(wfWorkItem) and WIWISQ=$(wfWorkItemSequence) and WIMODE='M' and WPPTID=$(wfParticipantId) and WPPART='$(userProfile)' and (WPRVWS='Y' or WPRVWS=' ') ", "WFWITM inner join WFWIPT on WPINST=WIINST and WPINDT=WIINDT and WPWITM=WIWITM and WPWISQ=WIWISQ ", "char(count(*))", recCount)	
  %if (recCount<="0")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
     	   %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
                  function submitForm(action) {document.Chg.action = action; return true;}
                  function confirmFail(text) {return confirm("$(wfFailConf)" + "\n" + "\n" + text);}
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "EMPLOYEEENTRYAPPROVE")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, "Select HRIMEM.* ", stmtSQL)
                          @dtw_concat(stmtSQL, " From HRIMEM ", stmtSQL)
                          @dtw_concat(stmtSQL, " Where IEINST=$(wfInstance) and IEINDT=$(wfInstanceDate) and IECLOS=' ' ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Header(profileHandle, dataBaseID, stmtSQL)

                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Header (IN CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(hrTagAttr)

      @dtw_assign(errorMessage, "")
      @dtw_assign(showIconPassWith, "Y")
      @dtw_assign(showIconPassWithout, "")

      @dtw_assign(maintainVar, "$(d2wVarBase)")
      %INCLUDE "WFWorkListOptions.icl"

      %ROW {
          <fieldset class="legendBody">
              <legend class="legendTitle">Employee</legend>
              <table $(contentTable)>

                  <tr><td class="dsphdr">Type Of Import</td>
                      <td class="dspalph">$(V_IECODE)</td>
                  </tr>

                  @RtvFldDesc("FLTYPE='HRACTIVE' and FLVALU='$(V_IEPRAC)'", "SYFLAG", "FLDESC", fieldDesc)
                  @Format_Code(V_IEPRAC, F_IEPRAC)
                  <tr><td class="dsphdr">P/R Activity Code</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_IEPRAC)</td>
                  </tr>

                  @RtvFldDesc("CFCOMP=$(V_IECOMP) and CFFACL=$(V_IEFACL)", "HRCOFC", "CFNAME", fieldDesc)
                  @Format_CoFac("$(V_IECOMP)", "$(V_IEFACL)", "", F_CoFac) @Format_Code(F_CoFac, F_CoFac)
                  <tr><td class="dsphdr">Company/Facility</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspnmbr">$(F_CoFac)</td>
                  </tr>

                  <tr><td class="dsphdr">Employee Number</td>
                      <td class="dspnmbr">$(V_IEEMPL)</td>
                  </tr>

                  <tr><td class="dsphdr">H/R Company Number</td>
                      <td class="dspnmbr">$(V_IEPECP)</td>
                  </tr>

                  <tr><td class="dsphdr">H/R Employee Number</td>
                      <td class="dspnmbr">$(V_IEPEMP)</td>
                  </tr>

                  @RtvFldDesc("APCOMP=$(V_IEPECP) and APAPDT=$(V_IEAPDT) and APAPSQ=$(V_IEAPSQ) ", "PEAPPL", "APRNAM", fieldDesc)
                  @Format_Date(V_IEAPDT, "H", F_IEAPDT)
                  @Format_Code("$(F_IEAPDT)/$(V_IEAPSQ)", F_IEAPSQ)
                  <tr><td class="dsphdr">Applicant Date/Sequence</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspnmbr">$(F_IEAPSQ)</td>
                  </tr>

                  @RtvFldDesc("ORCOMP=$(V_IEPECP) and ORLEVL=$(V_IELEVL) and ORSEQ=$(V_IEOSEQ) ", "PEORG", "ORTITL", fieldDesc)
                  @Format_Code("$(V_IELEVL)/$(V_IEOSEQ)", F_IELEVL)
                  <tr><td class="dsphdr">Company Position Level/Sequence</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspnmbr">$(F_IELEVL)</td>
                  </tr>
              </table>
          </fieldset>

          <fieldset class="legendBody">
              <legend class="legendTitle">Demographics 1</legend>
              <table $(contentTable)>

                  <tr><td class="dsphdr">Employee Report Name</td>
                      <td class="dspalph">$(V_IERNAM)</td>
                  </tr>
                  			
                  <tr><td class="dsphdr">Last Name</td>
                      <td class="dspalph">$(V_IELNAM)</td>
                  </tr>

                  <tr><td class="dsphdr">First Name</td>
                      <td class="dspalph">$(V_IEFNAM)</td>
                  </tr>

                  <tr><td class="dsphdr">Middle Initial</td>
                      <td class="dspalph">$(V_IEMIDI)</td>
                  </tr>

                  <tr><td class="dsphdr">Address 1</td>
                      <td class="dspalph">$(V_IEADR1)</td>
                  </tr>

                  <tr><td class="dsphdr">Address 2</td>
                      <td class="dspalph">$(V_IEADR2)</td>
                  </tr>

                  <tr><td class="dsphdr">City</td>
                      <td class="dspalph">$(V_IECITY)</td>
                  </tr>

                  @RtvFldDesc("STID='$(V_IEST)'", "PRSTID", "CHAR(STDESC)", fieldDesc)
                  @Format_Code(V_IEST, F_IEST)
                  <tr><td class="dsphdr">State</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_IEST)</td>
                  </tr>

                  <tr><td class="dsphdr">Canadian Province</td>
                      <td class="dspalph">$(V_IEPROV)</td>
                  </tr>

                  <tr><td class="dsphdr">Zip Code</td>
                      <td class="dspalph">$(V_IEZIP)</td>
                  </tr>

                  <tr><td class="dsphdr">Country</td>
                      <td class="dspalph">$(V_IECNTR)</td>
                  </tr>

              </table>
          </fieldset>

          <fieldset class="legendBody">
              <legend class="legendTitle">Demographics 2</legend>
              <table $(contentTable)>

                  <tr><td class="dsphdr">Home Phone Number</td>
                      <td class="dspnmbr">$(V_IEPHON)</td>
                  </tr>

                  @RtvFldDesc("ODCOMP=$(V_IEPECP) and ODTYPE='O' and ODCODE='$(V_IELOC)' ", "PECODE", "CHAR(ODDESC)", fieldDesc)
                  @Format_Code(V_IELOC, F_IELOC)
                  <tr><td class="dsphdr">Location</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_IELOC)</td>
                  </tr>

                  @RtvFldDesc("EADEPT='$(V_IEDEPT)' ", "PREXAC", "EANAME", fieldDesc)
                  @Format_Code(V_IEDEPT, F_IEDEPT)
                  <tr><td class="dsphdr">Department</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_IEDEPT)</td>
                  </tr>

                  @Format_Date(V_IEDOB, "H", F_IEDOB)
                  <tr><td class="dsphdr">Date Of Birth</td>
                      <td class="dspnmbr">$(F_IEDOB)</td>
                  </tr>

                   @Format_SSN(V_IESSNO, V_IESSNO)
                  <tr><td class="dsphdr">Social Security Number</td>
                      <td class="dspalph">$(V_IESSNO)</td>
                  </tr>

                  <tr><td class="dsphdr">Social Security Suffix</td>
                      <td class="dspalph">$(V_IESSSF)</td>
                  </tr>

                  @RtvFldDesc("FLTYPE='GENDER' and FLVALU='$(V_IEGNDR)'", "SYFLAG", "FLDESC", fieldDesc)
                  @Format_Code(V_IEGNDR, F_IEGNDR)
                  <tr><td class="dsphdr">Gender</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_IEGNDR)</td>
                  </tr>

                  @RtvFldDesc("FLTYPE='MARITALSTS' and FLVALU='$(V_IEMSTA)'", "SYFLAG", "FLDESC", fieldDesc)
                  @Format_Code(V_IEMSTA, F_IEMSTA)
                  <tr><td class="dsphdr">Marital Status</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_IEMSTA)</td>
                  </tr>

                  <tr><td class="dsphdr">Number Of Dependents</td>
                      <td class="dspnmbr">$(V_IENODP)</td>
                  </tr>

                  @Format_Date(V_IEHIRE, "H", F_IEHIRE)
                  <tr><td class="dsphdr">Hire Date</td>
                      <td class="dspnmbr">$(F_IEHIRE)</td> 		
                  </tr>

                  @Format_Date(V_IESTRT, "H", F_IESTRT)
                  <tr><td class="dsphdr">Start Date</td>
                      <td class="dspnmbr">$(F_IESTRT)</td> 		
                  </tr>

                  @Format_Date(V_IESENR, "H", F_IESENR)
                  <tr><td class="dsphdr">Seniority Date</td>
                      <td class="dspnmbr">$(F_IESENR)</td>		
                  </tr>

                  @RtvFldDesc("FLTYPE='CITIZENSHP' and FLVALU='$(V_IECTZN)'", "SYFLAG", "FLDESC", fieldDesc)
                  @Format_Code(V_IECTZN, F_IECTZN)
                  <tr><td class="dsphdr">Citizenship</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_IECTZN)</td>
                  </tr>

                  <tr><td class="dsphdr">Alien Registration Number</td>
                      <td class="dspalph">$(V_IEALRG)</td>
                  </tr>

              </table>
          </fieldset>

          <fieldset class="legendBody">
              <legend class="legendTitle">Demographics 3</legend>
              <table $(contentTable)>

                  @RtvFldDesc("ODCOMP=$(V_IEPECP) and ODTYPE='J' and ODCODE='$(V_IEJOB)' ", "PECODE", "CHAR(ODDESC)", fieldDesc)
                  @Format_Code(V_IEJOB, F_IEJOB)
                  <tr><td class="dsphdr">Job Code</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_IEJOB)</td>
                  </tr>

                  @dtw_assign(T_EEO, "")
                  @CvtEEO(V_IEEEO, T_EEO)
                  @RtvFldDesc("ODCOMP=$(V_IEPECP) and ODTYPE='Y' and ODCODE='$(T_EEO)' ", "PECODE", "CHAR(ODDESC)", fieldDesc)
                  @Format_Code(V_IEEEO, F_IEEEO)
                  <tr><td class="dsphdr">EEO-1 Job Category</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspnmbr">$(F_IEEEO)</td>
                  </tr>

                  @RtvFldDesc("ODCOMP=$(V_IEPECP) and ODTYPE='U' and ODCODE='$(V_IEUNCD)' ", "PECODE", "CHAR(ODDESC)", fieldDesc)
                  @Format_Code(V_IEUNCD, F_IEUNCD)
                  <tr><td class="dsphdr">Union</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_IEUNCD)</td>
                  </tr>

                  <tr><td class="dsphdr">Union Membership Number</td>
                      <td class="dspalph">$(V_IEUNMN)</td>
                  </tr>

                  @RtvFldDesc("PPCOMP=$(V_IECOMP) and PPFACL=$(V_IEFACL) and PPDEPT='$(V_IEDEPT)' and PPSHFT='$(V_IESHFT)' ", "PRPREM", "PPDESC", fieldDesc)
                  %if (shiftDesc =="")
                      @RtvFldDesc("PPCOMP=$(V_IECOMP) and PPFACL=$(V_IEFACL) and PPDEPT=' ' and PPSHFT='$(V_IESHFT)' ", "PRPREM", "PPDESC", fieldDesc)
                  %endif
                  @Format_Code(V_IESHFT, F_IESHFT)
                  <tr><td class="dsphdr">Shift</td>
                      %if (fieldDesc == "")
                          <td class="dspalph">$(V_IESHFT)</td>
                      %else
                          <td class="dspalph">$(fieldDesc)</td>
                          <td class="dspalph">$(F_IESHFT)</td>
                      %endif
                  </tr>

                  <tr><td class="dsphdr">Standard Annual Hours</td>
                      <td class="dspnmbr">$(V_IEANHR)</td>
                  </tr>

                  @RtvFldDesc("SMSCHD=$(V_IESCHD)", "HDSCHM", "SMDESC", fieldDesc)
                  @Format_Code(V_IESCHD, F_IESCHD)
                  <tr><td class="dsphdr">Schedule</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspnmbr">$(F_IESCHD)</td>
                  </tr>

                  @Format_Date(V_IETRDT, "H", F_IETRDT)
                  <tr><td class="dsphdr">Termination Date</td>
                      <td class="dspnmbr">$(F_IETRDT)</td> 		
                  </tr>

                  @RtvFldDesc("ODCOMP=$(V_IEPECP) and ODTYPE='T' and ODCODE='$(V_IETRCD)' ", "PECODE", "CHAR(ODDESC)", fieldDesc)
                  @Format_Code(V_IETRCD, F_IETRCD)
                  <tr><td class="dsphdr">Termination Code</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_IETRCD)</td>
                  </tr>

                  @RtvFldDesc("PLPLNT=$(V_IEPLNT)", "HDPLNT", "PLNAME", fieldDesc)
                  @Format_Code(V_IEPLNT, F_IEPLNT)
                  <tr><td class="dsphdr">Home Plant Number</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspnmbr">$(F_IEPLNT)</td>
                  </tr>

                  @RtvFldDesc("WCPLT=$(V_IEPLNT) and WCDEPT='$(V_IEMDPT)' and WCWC='$(V_IEWC)'", "HDMWCM", "WCDESC", fieldDesc)
                  @Format_Code("$(V_IEMDPT)/$(V_IEWC)", F_IEMDPT)
                  <tr><td class="dsphdr">Manufacturing Department / Work Center</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_IEMDPT)</td>
                  </tr>

                  @RtvFldDesc("BBGRP#=$(V_IEHGRP) ", "HDGRPM", "BBDESC", fieldDesc)
                  @Format_Code(V_IEHGRP, F_IEHGRP)
                  <tr><td class="dsphdr">Home Group Number</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspnmbr">$(F_IEHGRP)</td>
                  </tr>

                  @RtvFldDesc("PRU1DS<>' '", "PRCTRL", "PRU1DS", UDF1)
                  @RtvFldDesc("PRU2DS<>' '", "PRCTRL", "PRU2DS", UDF2)
                  @RtvFldDesc("PRU3DS<>' '", "PRCTRL", "PRU3DS", UDF3)
                  @RtvFldDesc("PRU4DS<>' '", "PRCTRL", "PRU4DS", UDF4)
                  @RtvFldDesc("PRU5DS<>' '", "PRCTRL", "PRU5DS", UDF5)
                  @RtvFldDesc("PRU6DS<>' '", "PRCTRL", "PRU6DS", UDF6)
                  %if($(UDF1) != "")
                      <tr><td class="dsphdr">$(UDF1)</td>
                          <td class="dspnmbr">$(V_IEUSR1)</td>
                      </tr>
                  %endif
                  %if($(UDF2) != "")
                      <tr><td class="dsphdr">$(UDF2)</td>
                          <td class="dspnmbr">$(V_IEUSR2)</td>
                      </tr>
                  %endif
                  %if($(UDF3) != "")
                      <tr><td class="dsphdr">$(UDF3)</td>
                          <td class="dspnmbr">$(V_IEUSR3)</td>
                      </tr>
                  %endif
                  %if($(UDF4) != "")
                      <tr><td class="dsphdr">$(UDF4)</td>
                          <td class="dspnmbr">$(V_IEUSR4)</td>
                      </tr>
                  %endif
                  %if($(UDF5) != "")
                      <tr><td class="dsphdr">$(UDF5)</td>
                          <td class="dspnmbr">$(V_IEUSR5)</td>
                      </tr>
                  %endif
                  %if($(UDF6) != "")
                      <tr><td class="dsphdr">$(UDF6)</td>
                          <td class="dspnmbr">$(V_IEUSR6)</td>
                      </tr>
                  %endif
              </table>
          </fieldset>

          <fieldset class="legendBody">
              <legend class="legendTitle">Pay Information</legend>
              <table $(contentTable)>

                  @RtvFldDesc("FLTYPE='PAYTYPE' and FLVALU='$(V_IETYPE)'", "SYFLAG", "FLDESC", fieldDesc)
                  @Format_Code(V_IETYPE, F_IETYPE)
                  <tr><td class="dsphdr">Pay Type Code</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_IETYPE)</td>
                  </tr>

                  @RtvFldDesc("FLTYPE='EXEMPT' and FLVALU='$(V_IEEXMT)'", "SYFLAG", "FLDESC", fieldDesc)
                  @Format_Code(V_IEEXMT, F_IEEXMT)
                  <tr><td class="dsphdr">Exempt/Nonexempt</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_IEEXMT)</td>
                  </tr>

                  @RtvFldDesc("FLTYPE='EMPLFREQ' and FLVALU='$(V_IEFREQ)'", "SYFLAG", "FLDESC", fieldDesc)
                  @Format_Code(V_IEFREQ, F_IEFREQ)
                  <tr><td class="dsphdr">Payroll Frequency</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspnmbr">$(F_IEFREQ)</td>
                  </tr>

                  <tr><td class="dsphdr">Pay Rate/Salary Amount</td>
                      <td class="dspnmbr">$(V_IEAMT)</td>
                  </tr>

                  @RtvFldDesc("FLTYPE='PAYROLLFRQ' and FLVALU='$(V_IESRCD)'", "SYFLAG", "FLDESC", fieldDesc)
                  @Format_Code(V_IESRCD, F_IESRCD)
                  <tr><td class="dsphdr">Salary Amount Code</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspnmbr">$(F_IESRCD)</td>
                  </tr>

                  @RtvFldDesc("FLTYPE='OVERTIME' and FLVALU='$(V_IEOVTM)'", "SYFLAG", "FLDESC", fieldDesc)
                  @Format_Code(V_IEOVTM, F_IEOVTM)
                  <tr><td class="dsphdr">Overtime Calculation Method</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_IEOVTM)</td>
                  </tr>

                  @RtvYNDesc($(V_IEHCE), fieldDesc)
                  @Format_Code(V_IEHCE, F_IEHCE)
                  <tr><td class="dsphdr">Highly Compensated Employee</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_IEHCE)</td>
                  </tr>

                  @RtvYNDesc($(V_IEOFCR), fieldDesc)
                  @Format_Code(V_IEOFCR, F_IEOFCR)
                  <tr><td class="dsphdr">Corporate Officer</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_IEOFCR)</td>
                  </tr>

                  @RtvYNDesc($(V_IEKEYE), fieldDesc)
                  @Format_Code(V_IEKEYE, F_IEKEYE)
                  <tr><td class="dsphdr">Key Employee</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_IEKEYE)</td>
                  </tr>

                  @RtvFldDesc("BHCOMP=$(V_IECOMP) and BHFACL=$(V_IEFACL) and BHBGRP='$(V_IEBGRP)' ", "HRBGRH", "CHAR(BHNAME)", fieldDesc)
                  @Format_Code(V_IEBGRP, F_IEBGRP)
                  <tr><td class="dsphdr">Benefit Group</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_IEBGRP)</td>
                  </tr>

                  @RtvFldDesc("ODCOMP=$(V_IEPECP) and ODTYPE='I' and ODCODE='$(V_IESCRS)' ", "PECODE", "CHAR(ODDESC)", fieldDesc)
                  @Format_Code(V_IESCRS, F_IESCRS)
                  <tr><td class="dsphdr">Salary Change Reason</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_IESCRS)</td>
                  </tr>

                  @Format_Date(V_IEDLIN, "H", F_IEDLIN)
                  <tr><td class="dsphdr">Salary Change Date</td>
                      <td class="dspnmbr">$(F_IEDLIN)</td>	
                  </tr>

              </table>
          </fieldset>

          <fieldset class="legendBody">
              <legend class="legendTitle">Accruals</legend>
              <table $(contentTable)>
                  <tr>
                      <td>
                          <fieldset class="legendBody">
                              <legend class="legendTitle">Accrual Codes and Date</legend>
                              <table $(contentTable)>

                                  <tr><td class="dsphdr">Vacation/Sick Accrual Code</td>
                                      <td class="dspalph">$(V_IEVASC)</td>
                                  </tr>
                                  	
                                  <tr><td class="dsphdr">Miscellaneous Accrual Code</td>
                                      <td class="dspalph">$(V_IEMSAC)</td>
                                  </tr>

                                  @Format_Date(V_IEACDT, "H", F_IEACDT)
                                  <tr><td class="dsphdr">Accrual Date</td>
                                      <td class="dspnmbr">$(F_IEACDT)</td>		
                                  </tr>

                              </table>
                          </fieldset>
                      </td>
                  </tr>
                  <tr>
                      <td>
                          <fieldset class="legendBody">
                              <legend class="legendTitle">Vacation</legend>
                              <table $(contentTable)>
                                  <tr><td class="colhdr">&nbsp;</td>
                                      <td class="colhdr">Hours</td>
                                      <td class="colhdr">Dollars</td>
                                  </tr>

                                  <tr><td class="dsphdr">YTD Accrued</td>
                                      <td class="dspnmbr">$(V_IEACVH)</td>
                                      <td class="dspnmbr">$(V_IEACVD)</td>
                                  </tr>

                                  <tr><td class="dsphdr">YTD Available</td>
                                      <td class="dspnmbr">$(V_IEVHA)</td>
                                      <td class="dspnmbr">$(V_IEVDA)</td>
                                  </tr>
                              </table>
                          </fieldset>
                      </td>
                  </tr>
                  <tr>
                      <td>
                          <fieldset class="legendBody">
                              <legend class="legendTitle">Sick</legend>
