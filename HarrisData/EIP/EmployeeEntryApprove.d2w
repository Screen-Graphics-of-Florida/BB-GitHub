                                      <td class="dspnmbr">$(V_IESTAA)</td>
                                  </tr>

                                  <tr><td class="dsphdr">Commission Withholding Percent</td>
                                      <td class="dspnmbr">$(V_IECSTP)</td>
                                  </tr>

                                  <tr><td class="dsphdr">Bonus Withholding Percent</td>
                                      <td class="dspnmbr">$(V_IEBSTP)</td>
                                  </tr>
                              </table>
                          </fieldset>
                      </td>
                  </tr>
                  <tr>
                      <td>
                          <fieldset class="legendBody">
                              <legend class="legendTitle">State Unemployment Insurance</legend>
                              <table $(contentTable)>

                                  @RtvFldDesc("STID='$(V_IESUID)'", "PRSTID", "CHAR(STDESC)", fieldDesc)
                                  @Format_Code(V_IESUID, F_IESUID)
                                  <tr><td class="dsphdr">State Unemployment Insurance ID</td>
                                      <td class="dspalph">$(fieldDesc)</td>
                                      <td class="dspalph">$(F_IESUID)</td>
                                  </tr>

                              </table>
                          </fieldset>
                      </td>
                  </tr>
                  <tr>
                      <td>
                          <fieldset class="legendBody">
                              <legend class="legendTitle">State Workers' Compensation</legend>
                              <table $(contentTable)>

                                  @RtvYNDesc($(V_IEEXWC), fieldDesc)
                                  @Format_Code(V_IEEXWC, F_IEEXWC)
                                  <tr><td class="dsphdr">Exempt From SWC</td>
                                      <td class="dspalph">$(fieldDesc)</td>
                                      <td class="dspalph">$(F_IEEXWC)</td>
                                  </tr>

                                  @RtvFldDesc("STID='$(V_IESWID)'", "PRSTID", "CHAR(STDESC)", fieldDesc)
                                  @Format_Code(V_IESWID, F_IESWID)
                                  <tr><td class="dsphdr">State Workers' Compensation ID</td>
                                      <td class="dspalph">$(fieldDesc)</td>
                                      <td class="dspalph">$(F_IESWID)</td>
                                  </tr>

                                  @RtvFldDesc("JBCLAS='$(V_IEJBCL)'", "PRJBCL", "CHAR(JBDESC)", fieldDesc)
                                  @Format_Code(V_IEJBCL, F_IEJBCL)
                                  <tr><td class="dsphdr">Job Class</td>
                                      <td class="dspalph">$(fieldDesc)</td>
                                      <td class="dspnmbr">$(F_IEJBCL)</td>
                                  </tr>

                               </table>
                          </fieldset>
                      </td>
                  </tr>
                  <tr>
                      <td>
                          <fieldset class="legendBody">
                              <legend class="legendTitle">State Disability Insurance</legend>
                              <table $(contentTable)>

                                  @RtvFldDesc("STID='$(V_IESDID)'", "PRSTID", "CHAR(STDESC)", fieldDesc)
                                  @Format_Code(V_IESDID, F_IESDID)
                                  <tr><td class="dsphdr">State Disability Insurance ID</td>
                                      <td class="dspalph">$(fieldDesc)</td>
                                      <td class="dspalph">$(F_IESDID)</td>
                                  </tr>
                              </table>
                          </fieldset>
                      </td>
                  </tr>
                  <tr>
                      <td>
                          <fieldset class="legendBody">
                              <legend class="legendTitle">Local Tax</legend>
                              <table $(contentTable)>

                                  @RtvFldDesc("TLID='$(V_IELTX1)'", "PRLTAX", "CHAR(TLLCNM)", fieldDesc)
                                  @Format_Code(V_IELTX1, F_IELTX1)
                                  <tr><td class="dsphdr">Local Tax 1 ID</td>
                                      <td class="dspalph">$(fieldDesc)</td>
                                      <td class="dspalph">$(F_IELTX1)</td>
                                  </tr>

                                  <tr><td class="dsphdr">Local Tax 1 Dependents</td>
                                      <td class="dspnmbr">$(V_IELDP1)</td>
                                  </tr>

                                  <tr><td class="dsphdr">Local Tax 1 Personal Exemptions</td>
                                      <td class="dspnmbr">$(V_IELPE1)</td>
                                  </tr>                                  

                                  @RtvFldDesc("TLID='$(V_IELTX2)'", "PRLTAX", "CHAR(TLLCNM)", fieldDesc)
                                  @Format_Code(V_IELTX2, F_IELTX2)
                                  <tr><td class="dsphdr">Local Tax 2 ID</td>
                                      <td class="dspalph">$(fieldDesc)</td>
                                      <td class="dspalph">$(F_IELTX2)</td>
                                  </tr>

                                  <tr><td class="dsphdr">Local Tax 2 Dependents</td>
                                      <td class="dspnmbr">$(V_IELDP2)</td>
                                  </tr>
                                  
                                  <tr><td class="dsphdr">Local Tax 2 Personal Exemptions</td>
                                      <td class="dspnmbr">$(V_IELPE2)</td>
                                  </tr>  
                                  @RtvFldDesc("TLID='$(V_IEERES)'", "PRLTAX", "CHAR(TLLCNM)", fieldDesc)
                                  @Format_Code(V_IEERES, F_IEERES)
                                  <tr><td class="dsphdr">Employee Resident Local Tax ID</td>
                                      <td class="dspalph">$(fieldDesc)</td>
                                      <td class="dspalph">$(F_IEERES)</td>
                                  </tr>
                              </table>
                          </fieldset>
                      </td>
                  </tr>
                  <tr>
                      <td>
                          <fieldset class="legendBody">
                              <legend class="legendTitle">Tax Reporting</legend>
                              <table $(contentTable)>

                                  @RtvYNDesc($(V_IEPEN), fieldDesc)
                                  @Format_Code(V_IEPEN, F_IEPEN)
                                  <tr><td class="dsphdr">Covered By Qualified Pension</td>
                                      <td class="dspalph">$(fieldDesc)</td>
                                      <td class="dspalph">$(F_IEPEN)</td>
                                  </tr>

                                  @RtvFldDesc("FLTYPE='EMPLOYMENT' and FLVALU='$(V_IEETYP)'", "SYFLAG", "FLDESC", fieldDesc)
                                  @Format_Code(V_IEETYP, F_IEETYP)
                                  <tr><td class="dsphdr">Employment Type</td>
                                      <td class="dspalph">$(fieldDesc)</td>
                                      <td class="dspalph">$(F_IEETYP)</td>
                                  </tr>

                                  <tr><td class="dsphdr">Occupation/Industry Code</td>
                                      <td class="dspnmbr">$(V_IEINDS)</td>
                                  </tr>

                                  <tr><td class="dsphdr">Area Classifications</td>
                                      <td class="dspalph">$(V_IEOPCD)</td>
                                  </tr>

                                  <tr><td class="dsphdr">Nonqualified Plan Code</td>
                                      <td class="dspalph">$(V_IENQPC)</td>
                                  </tr>

                                  @RtvFldDesc("FLTYPE='STATUTORY' and FLVALU='$(V_IESTEM)'", "SYFLAG", "FLDESC", fieldDesc)
                                  @Format_Code(V_IESTEM, F_IESTEM)
                                  <tr><td class="dsphdr">Statutory Employee</td>
                                      <td class="dspalph">$(fieldDesc)</td>
                                      <td class="dspalph">$(F_IESTEM)</td>
                                  </tr>

                                  @RtvYNDesc($(V_IELGRP), fieldDesc)
                                  @Format_Code(V_IELGRP, F_IELGRP)
                                  <tr><td class="dsphdr">Legal Representative</td>
                                      <td class="dspalph">$(fieldDesc)</td>
                                      <td class="dspalph">$(F_IELGRP)</td>
                                  </tr>

                                  <tr><td class="dsphdr">Probationary Code</td>
                                      <td class="dspalph">$(V_IEPBCD)</td>
                                  </tr>

                                  @Format_Date(V_IEPBDT, "H", F_IEPBDT)
                	               <tr><td class="dsphdr">Probationary Date</td>
                                      <td class="dspnmbr">$(F_IEPBDT)</td> 		
                                  </tr>

                                  <tr><td class="dsphdr">County Code</td>
                                      <td class="dspnmbr">$(V_IECNTY)</td>
                                  </tr>

                                  <tr><td class="dsphdr">Employee Health Insurance Code</td>
                                      <td class="dspnmbr">$(V_IEEHLT)</td>
                                  </tr>

                                  <tr><td class="dsphdr">Employer Health Insurance Code</td>
                                      <td class="dspnmbr">$(V_IERHLT)</td>
                                  </tr>

                                  <tr><td class="dsphdr">Wage Plan Code</td>
                                      <td class="dspalph">$(V_IEWGPC)</td>
                                  </tr>

                                  <tr><td class="dsphdr">Seasonal Indicator</td>
                                      <td class="dspalph">$(V_IESEAS)</td>
                                  </tr>

                                  <tr><td class="dsphdr">Unit/Div/Loc/Plant</td>
                                      <td class="dspalph">$(V_IEUNIT)</td>
                                  </tr>

                                  @Format_Date(V_IEDCDT, "H", F_IEDCDT)
                	               <tr><td class="dsphdr">Date Deceased</td>
                                      <td class="dspnmbr">$(F_IEDCDT)</td>		
                                  </tr>
                              </table>
                          </fieldset>
                      </td>
                  </tr>
              </table>
          </fieldset>

      %}
  %}
%}

%FUNCTION(dtw_directcall) SetApprove_Data(IN    CHAR(64)    profileHandle,
                                                CHAR(2)     dataBaseID,
                                                CHAR(1)     approveCode,
                                                CHAR(32000) edtVar)
{%EXEC {HWFWIA_S.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(setFlag, "Y")
  @dtw_assign(edtVar, "")
  @Concat_Field("@@inst", wfInstance)
  @Concat_Field("@@indt", wfInstanceDate)
  @Concat_Field("@@witm", wfWorkItem)
  @Concat_Field("@@wisq", wfWorkItemSequence)
  @Concat_Field("@@ptid", wfParticipantId)
  @dtw_concat(edtVar, "}{", edtVar)
  @SetApprove_Data(profileHandle, dataBaseID, setFlag, edtVar)
  @Set_SQL(stmtSQL)
%}
