%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"

%Define {
  page_title              = "G/L Drill Down Report Comments"
  d2wName                 = "GLDrillDownComments.d2w"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  DTW_PAD_PGM_PARMS       = "YES"
  dspMaxRows              = "$(dspMaxRowsDft)"
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64) profileHandle,
                                   CHAR(2)   dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "headcmt.icl"
          </head>

          <body $(bodyTagAttr) onLoad="window.focus()" onBlur="window.close()">
              <!-- Start Of Banner Code -->
              %INCLUDE "$(cmtBanner)"
              <!-- End Of Banner Code -->
              <table $(contentTable)>
                  @Format_Header("Report", $(ddDescr), $(ddReport))
              </table>
              $(inquiryhrTagAttr)

              <table $(contentTable)>
                  %ROW{
                      %if (V_DMCMNT == "")
                          <tr><td class="colalph">&nbsp;</td></tr>
                      %else
                          <tr><td class="colalph">$(V_DMCMNT)</td></tr>
                      %endif
                  %}
              </table>
              $(inquiryhrTagAttr)
              <!-- Start Of Trailer Code -->
              %INCLUDE "$(cmtTrailer)"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "SELECT * ", stmtSQL)
  @dtw_concat(fileSQL, " GLDDCM ", fileSQL)
  @dtw_concat(selectSQL, " DMGRSN='$(ddReport)' ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " order by DMGRSN, DMSEQ#  ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @dtw_concat(ddReport, "               ", drillDownReport)
  @List_Query(profileHandle, dataBaseID, stmtSQL)
%}