%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Item/Warehouse List"
  d2wName                 = "ItemWarehouseList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)&amp;apid=@dtw_rurlescseq(apid)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "5"
  userdef                 = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          @dtw_assign(userdef, "")
          %if (V_HDINRL > "0")
              %if (V_CIWAS1 != "")
                  @dtw_assign(userdef, "Y")
              %elif (V_CIWAS2 != "")
                  @dtw_assign(userdef, "Y")
              %elif (V_CIWAS3 != "")
                  @dtw_assign(userdef, "Y")
              %elif (V_CIWNS1 != "")
                  @dtw_assign(userdef, "Y")
              %elif (V_CIWNS2 != "")
                  @dtw_assign(userdef, "Y")
              %elif (V_CIWNS3 != "")
                  @dtw_assign(userdef, "Y")
              %endif
          %endif

          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromWarehouseNumber, 3, 0) &&
                      editNum(document.Chg.toWarehouseNumber, 3, 0) &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromWarehouseNumber, document.Chg.toWarehouseNumber, document.Chg.allWarehouseNumber, 3) &&
                      editFromToAll(document.Chg.fromProductClass, document.Chg.toProductClass, document.Chg.allProductClass, "A") &&
                      editFromToAll(document.Chg.fromPhyInvCountGroup, document.Chg.toPhyInvCountGroup, document.Chg.allPhyInvCountGroup, "A") &&
                      editFromToAll(document.Chg.fromABCClassCode, document.Chg.toABCClassCode, document.Chg.allABCClassCode, "A")
                      %if (V_HDPDRL > "0")
                          && editFromToAll(document.Chg.fromPartType, document.Chg.toPartType, document.Chg.allPartType, "A")
                      %endif
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ITEMLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromItemNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@cont", "reportContent")     @dtw_assign(Err_N1SEL,  fieldValue)
                                  @DecatErr_Field("@@gndt", "generalData")
 @dtw_assign(Err_N2GNDT,  fieldValue)
                                  @DecatErr_Field("@@csdt", "costData") @dtw_assign(Err_N2CSDT,  fieldValue)
                                  @DecatErr_Field("@@usdt", "userDefinedData")     @dtw_assign(Err_N2USDT,  fieldValue)
                                  @DecatErr_Field("@@sitm", "sortItemNumber")        @dtw_assign(Err_N2SITM,  fieldValue)
                                  @DecatErr_Field("@@swhs", "sortWarehouseNumber")        @dtw_assign(Err_N2SWHS,  fieldValue)
                                  @DecatErr_Field("@@spcl", "sortProductClass")        @dtw_assign(Err_N2SPCL,  fieldValue)
                                  @DecatErr_Field("@@scyc", "sortPhyInvCountGroup")        @dtw_assign(Err_N2SCYC,  fieldValue)
                                  @DecatErr_Field("@@sabc", "sortABCClassCode")        @dtw_assign(Err_N2SABC,  fieldValue)
                                  @DecatErr_Field("@@sptp", "sortPartType")          @dtw_assign(Err_N2SPTP,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@cont")  @dtw_assign(V_N1SEL,  fieldValue)
                                  @Decat_Field("@@gndt")  @dtw_assign(V_N2GNDT,  fieldValue)
                                  @Decat_Field("@@csdt")  @dtw_assign(V_N2CSDT,  fieldValue)
                                  @Decat_Field("@@usdt")  @dtw_assign(V_N2USDT,  fieldValue)
                                  @Decat_Field("@@fitm")  @dtw_assign(V_N2FITM,  fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N2TITM,  fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N2AITM,  fieldValue)
                                  @Decat_Field("@@sitm")  @dtw_assign(V_N2SITM,  fieldValue)
                                  @Decat_Field("@@fwhs")  @dtw_assign(V_N2FWHS,  fieldValue)
                                  @Decat_Field("@@twhs")  @dtw_assign(V_N2TWHS,  fieldValue)
                                  @Decat_Field("@@awhs")  @dtw_assign(V_N2AWHS,  fieldValue)
                                  @Decat_Field("@@swhs")  @dtw_assign(V_N2SWHS,  fieldValue)
                                  @Decat_Field("@@fpcl")  @dtw_assign(V_N2FPCL,  fieldValue)
                                  @Decat_Field("@@tpcl")  @dtw_assign(V_N2TPCL,  fieldValue)
                                  @Decat_Field("@@apcl")  @dtw_assign(V_N2APCL,  fieldValue)
                                  @Decat_Field("@@spcl")  @dtw_assign(V_N2SPCL,  fieldValue)
                                  @Decat_Field("@@fcyc")  @dtw_assign(V_N2FCYC,  fieldValue)
                                  @Decat_Field("@@tcyc")  @dtw_assign(V_N2TCYC,  fieldValue)
                                  @Decat_Field("@@acyc")  @dtw_assign(V_N2ACYC,  fieldValue)
                                  @Decat_Field("@@scyc")  @dtw_assign(V_N2SCYC,  fieldValue)
                                  @Decat_Field("@@fabc")  @dtw_assign(V_N2FABC,  fieldValue)
                                  @Decat_Field("@@tabc")  @dtw_assign(V_N2TABC,  fieldValue)
                                  @Decat_Field("@@aabc")  @dtw_assign(V_N2AABC,  fieldValue)
                                  @Decat_Field("@@sabc")  @dtw_assign(V_N2SABC,  fieldValue)
                                  @Decat_Field("@@fptp")  @dtw_assign(V_N2FPTP,  fieldValue)
                                  @Decat_Field("@@tptp")  @dtw_assign(V_N2TPTP,  fieldValue)
                                  @Decat_Field("@@aptp")  @dtw_assign(V_N2APTP,  fieldValue)
                                  @Decat_Field("@@sptp")  @dtw_assign(V_N2SPTP,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1SEL == "02")
                                      @dtw_assign(detail, "")
                                      @dtw_assign(summary, "CHECKED")
                                  %else
                                      @dtw_assign(detail, "CHECKED")
                                      @dtw_assign(summary, "")
                                  %endif
                                  %if (V_N2GNDT == "1")
                                      @dtw_assign(checkedGeneralData, "CHECKED")
                                  %else
                                      @dtw_assign(checkedGeneralData, "")
                                  %endif
                                  %if (V_N2CSDT == "1")
                                      @dtw_assign(checkedCostData, "CHECKED")
                                  %else
                                      @dtw_assign(checkedCostData, "")
                                  %endif
                                  %if (V_N2USDT == "1")
                                      @dtw_assign(checkedUserDefinedData, "CHECKED")
                                  %else
                                      @dtw_assign(checkedUserDefinedData, "")
                                  %endif
                                  %if (V_N2AITM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_N2AWHS == "ALL")
                                      @dtw_assign(checkedallWarehouseNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallWarehouseNumber, "")
                                  %endif
                                  %if (V_N2APCL == "ALL")
                                      @dtw_assign(checkedallProductClass, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallProductClass, "")
                                  %endif
                                  %if (V_N2ACYC == "ALL")
                                      @dtw_assign(checkedallPhyInvCountGroup, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPhyInvCountGroup, "")
                                  %endif
                                  %if (V_N2AABC == "ALL")
                                      @dtw_assign(checkedallABCClassCode, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallABCClassCode, "")
                                  %endif
                                  %if (V_N2APTP == "ALL")
                                      @dtw_assign(checkedallPartType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPartType, "")
                                  %endif
                              %else
                                  @dtw_assign(detail, "CHECKED")
                                  @dtw_assign(summary, "")
                                  @dtw_assign(checkedGeneralData, "CHECKED")
                                  @dtw_assign(checkedCostData, "CHECKED")
                                  @dtw_assign(checkedUserDefinedData, "CHECKED")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallWarehouseNumber, "CHECKED")
                                  @dtw_assign(checkedallProductClass, "CHECKED")
                                  @dtw_assign(checkedallPhyInvCountGroup, "CHECKED")
                                  @dtw_assign(checkedallABCClassCode, "CHECKED")
                                  @dtw_assign(checkedallPartType, "CHECKED")
                              %endif

                              <tr><td><input type="hidden" name="dspPartType" value="$(V_HDPDRL)"></td></tr>

                              @SetTextOvr(Err_N1SEL)
                              <tr><td  class="dsphdr"><span $(textOvr)>Report Content Selection</span></td>
                                  <td class="inputnmbr"><input name="reportContent" type="radio" VALUE='01' $(detail)>Detail</td>
                              </tr>
                              @DspErrMsg(Err_N1SEL)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="reportContent" type="radio" VALUE='02' $(summary)>Summary</td>
                              </tr>

                              @SetTextOvr(Err_N2GNDT)
                              <tr><td class="dsphdr"><span $(textOvr)>Options For Detail Selection</span></td>
                                  <td class="inputnmbr"><input name="generalData" type="checkbox" VALUE='1' $(checkedGeneralData)>General Data</td>
                              </tr>
                              @DspErrMsg(Err_N2GNDT)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="costData" type="checkbox" VALUE='1' $(checkedCostData)>Cost Data</td>
                              </tr>

                              %if (userdef == "Y")
                                  <tr><td>&nbsp;</td>
                                      <td class="inputnmbr"><input name="userDefinedData" type="checkbox" VALUE='1' $(checkedUserDefinedData)>User-Defined Data</td>
                                  </tr>
                              %endif

                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                              </tr>

                              @SetTextOvr(Err_N2FITM)
                              %if (textOvr == "") @SetTextOvr(Err_N2SITM) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N2FITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N2TITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                                  @Build_Sort_Select("sortItemNumber", "$(V_N2SITM)")
                              </tr>
                              @DspErrMsg(Err_N2SITM)

                              @SetTextOvr(Err_N2FWHS)
                              %if (textOvr == "") @SetTextOvr(Err_N2SWHS) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Warehouse Number</span></td>
                                  <td class="inputnmbr"><input name="fromWarehouseNumber" value="$(V_N2FWHS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromWarehouseNumber&amp;fldDesc=fwarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fwarehouseName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toWarehouseNumber" value="$(V_N2TWHS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toWarehouseNumber&amp;fldDesc=twarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="twarehouseName" type="hidden"></td>
                                  <td class="inputalph"><input name="allWarehouseNumber" value='ALL' $(checkedallWarehouseNumber) type="checkbox" onClick="if (this.checked) this.form.fromWarehouseNumber.value='', this.form.toWarehouseNumber.value='';"></td>
                                  @Build_Sort_Select("sortWarehouseNumber", "$(V_N2SWHS)")
                              </tr>
                              @DspErrMsg(Err_N2SWHS)

                              @SetTextOvr(Err_N2FPCL)
                              %if (textOvr == "") @SetTextOvr(Err_N2SPCL) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Product Class</span></td>
                                  <td class="inputalph"><input name="fromProductClass" value="$(V_N2FPCL)" type="text" size="8" maxlength="4"><a href="$(homeURL)$(cGIPath)ProdClassSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromProductClass&amp;fldDesc=fproductClassDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="fproductClassDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="toProductClass" value="$(V_N2TPCL)" type="text" size="8" maxlength="4"><a href="$(homeURL)$(cGIPath)ProdClassSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toProductClass&amp;fldDesc=tproductClassDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="tproductClassDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allProductClass" value='ALL' $(checkedallProductClass) type="checkbox" onClick="if (this.checked) this.form.fromProductClass.value='', this.form.toProductClass.value='';"></td>
                                  @Build_Sort_Select("sortProductClass", "$(V_N2SPCL)")
                              </tr>
                              @DspErrMsg(Err_N2SPCL)

                              @SetTextOvr(Err_N2FCYC)
                              %if (textOvr == "") @SetTextOvr(Err_N2SCYC) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Phy Inv Count Group</span></td>
                                  <td class="inputalph"><input   name="fromPhyInvCountGroup" type="text" value="$(V_N2FCYC)" size="4" maxlength="4"><a href="$(homeURL)$(cGIPath)PhyInvCountGroupSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromPhyInvCountGroup&amp;fldDesc=countGroupDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="countGroupDesc" type="hidden"></td>
                                  <td class="inputalph"><input   name="toPhyInvCountGroup" type="text" value="$(V_N2TCYC)" size="4" maxlength="4"><a href="$(homeURL)$(cGIPath)PhyInvCountGroupSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toPhyInvCountGroup&amp;fldDesc=countGroupDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="countGroupDesc" type="hidden"></td>

                                  <td class="inputalph"><input name="allPhyInvCountGroup" value='ALL' $(checkedallPhyInvCountGroup) type="checkbox" onClick="if (this.checked) this.form.fromPhyInvCountGroup.value='', this.form.toPhyInvCountGroup.value='';"></td>
                                  @Build_Sort_Select("sortPhyInvCountGroup", "$(V_N2SCYC)")
                              </tr>
                              @DspErrMsg(Err_N2SCYC)

                              @SetTextOvr(Err_N2FABC)
                              %if (textOvr == "") @SetTextOvr(Err_N2SABC) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>ABC Class Code</span></td>
                                  <td class="inputnmbr"><input name="fromABCClassCode" value="$(V_N2FABC)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputnmbr"><input name="toABCClassCode" value="$(V_N2TABC)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="allABCClassCode" value='ALL' $(checkedallABCClassCode) type="checkbox" onClick="if (this.checked) this.form.fromABCClassCode.value='', this.form.toABCClassCode.value='';"></td>
                                  @Build_Sort_Select("sortABCClassCode", "$(V_N2SABC)")
                              </tr>
                              @DspErrMsg(Err_N2SABC)

                              %if (V_HDPDRL > "0")
                                  <tr><td  class="dsphdr">Part Type</td>
                                      <td class="inputnmbr"><input name="fromPartType" value="$(V_N2FPTP)" type="text" size="1" maxlength="1"></td>
                                      <td class="inputnmbr"><input name="toPartType" value="$(V_N2TPTP)" type="text" size="1" maxlength="1"></td>
                                      <td class="inputalph"><input name="allPartType" value='ALL' $(checkedallPartType) type="checkbox" onClick="if (this.checked) this.form.fromPartType.value='', this.form.toPartType.value='';"></td>
                                  </tr>
                              %endif

                          </table>

                          @dtw_assign(envProgram, "HHDIVL")
                          @dtw_assign(envPrinter, "HHDIVLPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HHDIVX_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(allWarehouseNumber)
  @dtw_mUPPERCASE(fromProductClass)
  @dtw_mUPPERCASE(toProductClass)
  @dtw_mUPPERCASE(allProductClass)
  @dtw_mUPPERCASE(fromPhyInvCountGroup)
  @dtw_mUPPERCASE(toPhyInvCountGroup)
  @dtw_mUPPERCASE(allPhyInvCountGroup)
  @dtw_mUPPERCASE(fromABCClassCode)
  @dtw_mUPPERCASE(toABCClassCode)
  @dtw_mUPPERCASE(allABCClassCode)
  @dtw_mUPPERCASE(fromPartType)
  @dtw_mUPPERCASE(toPartType)
  @dtw_mUPPERCASE(allPartType)

  @dtw_assign(sortItemNumber,@dtw_rstrip(sortItemNumber))
  @dtw_assign(fromWarehouseNumber,@dtw_rstrip(fromWarehouseNumber))
  @dtw_assign(toWarehouseNumber,@dtw_rstrip(toWarehouseNumber))
  @dtw_assign(allWarehouseNumber,@dtw_rstrip(allWarehouseNumber))
  @dtw_assign(sortWarehouseNumber,@dtw_rstrip(sortWarehouseNumber))
  @dtw_assign(sortProductClass,@dtw_rstrip(sortProductClass))
  @dtw_assign(sortPhyInvCountGroup,@dtw_rstrip(sortPhyInvCountGroup))
  @dtw_assign(sortABCClassCode,@dtw_rstrip(sortABCClassCode))
  @dtw_assign(sortPartType,@dtw_rstrip(sortPartType))

  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allWarehouseNumber != "ALL")
      @dtw_assign(allWarehouseNumber, "")
  %endif
  %if (allProductClass != "ALL")
      @dtw_assign(allProductClass, "")
  %endif
  %if (allPhyInvCountGroup != "ALL")
      @dtw_assign(allPhyInvCountGroup, "")
  %endif
  %if (allABCClassCode != "ALL")
      @dtw_assign(allABCClassCode, "")
  %endif
  %if (allPartType != "ALL")
      @dtw_assign(allPartType, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@cont", reportContent)
  @Concat_Field("@@apid", apid)
  %if (reportContent == "01")
      @Concat_Field("@@gndt", generalData)
      @Concat_Field("@@csdt", costData)
      @Concat_Field("@@usdt", userDefinedData)
  %endif
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@sitm", sortItemNumber)
  @Concat_Field("@@fwhs", fromWarehouseNumber)
  @Concat_Field("@@twhs", toWarehouseNumber)
  @Concat_Field("@@awhs", allWarehouseNumber)
  @Concat_Field("@@swhs", sortWarehouseNumber)
  @Concat_Field("@@fpcl", fromProductClass)
  @Concat_Field("@@tpcl", toProductClass)
  @Concat_Field("@@apcl", allProductClass)
  @Concat_Field("@@spcl", sortProductClass)
  @Concat_Field("@@fcyc", fromPhyInvCountGroup)
  @Concat_Field("@@tcyc", toPhyInvCountGroup)
  @Concat_Field("@@acyc", allPhyInvCountGroup)
  @Concat_Field("@@scyc", sortPhyInvCountGroup)
  @Concat_Field("@@fabc", fromABCClassCode)
  @Concat_Field("@@tabc", toABCClassCode)
  @Concat_Field("@@aabc", allABCClassCode)
  @Concat_Field("@@sabc", sortABCClassCode)
  %if (dspPartType != "")
      @Concat_Field("@@fptp", fromPartType)
      @Concat_Field("@@tptp", toPartType)
      @Concat_Field("@@aptp", allPartType)
  %endif

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}