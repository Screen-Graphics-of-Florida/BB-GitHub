%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Production Plan/Customer Order Report"
  d2wName                 = "ProductionPlanCustomerOrderReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;apid=@dtw_rurlescseq(apid)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  Ptype                   = "P"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {

                      if  (editNum(document.Chg.fromPlantNumber, 3, 0) &&
                           editNum(document.Chg.toPlantNumber, 3, 0) &&
                           editdate(document.Chg.fromScheduleDate) &&
                           editdate(document.Chg.toScheduleDate) &&
                           editFromToAll(document.Chg.fromPlantNumber, document.Chg.toPlantNumber, document.Chg.allPlantNumber, 3) &&
                           editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                           editFromToAll(document.Chg.fromItemType, document.Chg.toItemType, document.Chg.allItemType, "A") &&
                           editFromToAll(document.Chg.fromDemandCode, document.Chg.toDemandCode, document.Chg.allDemandCode, "A") &&
                           editFromToAll(document.Chg.fromScheduleDate, document.Chg.toScheduleDate, document.Chg.allScheduleDate, "D")
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PRODUCTIONPLANCUSTOMERORDERREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromPlantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@fplt", "fromPlantNumber")        @dtw_assign(Err_N1FPLT,  fieldValue)
                                  @DecatErr_Field("@@tplt", "toPlantNumber")        @dtw_assign(Err_N1TPLT,  fieldValue)
                                  @DecatErr_Field("@@aplt", "allPlantNumber")        @dtw_assign(Err_N1APLT,  fieldValue)
                                  @DecatErr_Field("@@fitm", "fromItemNumber")        @dtw_assign(Err_N1FITM,  fieldValue)
                                  @DecatErr_Field("@@titm", "toItemNumber")        @dtw_assign(Err_N1TITM,  fieldValue)
                                  @DecatErr_Field("@@aitm", "allItemNumber")        @dtw_assign(Err_N1AITM,  fieldValue)
                                  @DecatErr_Field("@@ftyp", "fromItemType")        @dtw_assign(Err_N1FTYP,  fieldValue)
                                  @DecatErr_Field("@@ttyp", "toItemType")        @dtw_assign(Err_N1TTYP,  fieldValue)
                                  @DecatErr_Field("@@atyp", "allItemType")        @dtw_assign(Err_N1ATYP,  fieldValue)
                                  @DecatErr_Field("@@fmdc", "fromDemandCode")        @dtw_assign(Err_N1FMDC,  fieldValue)
                                  @DecatErr_Field("@@tmdc", "toDemandCode")        @dtw_assign(Err_N1TMDC,  fieldValue)
                                  @DecatErr_Field("@@amdc", "allDemandCode")        @dtw_assign(Err_N1AMDC,  fieldValue)
                                  @DecatErr_Field("@@fqdn", "fromScheduleDate")        @dtw_assign(Err_N1FQDN,  fieldValue)
                                  @DecatErr_Field("@@tqdn", "toScheduleDate")        @dtw_assign(Err_N1TQDN,  fieldValue)
                                  @DecatErr_Field("@@aqdn", "allScheduleDate")        @dtw_assign(Err_N1AQDN,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@fplt")  @dtw_assign(V_N1FPLT, fieldValue)
                                  @Decat_Field("@@tplt")  @dtw_assign(V_N1TPLT, fieldValue)
                                  @Decat_Field("@@aplt")  @dtw_assign(V_N1APLT, fieldValue)

                                  @Decat_Field("@@fitm")  @dtw_assign(V_N1FITM, fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N1TITM, fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N1AITM, fieldValue)

                                  @Decat_Field("@@ftyp")  @dtw_assign(V_N1FTYP, fieldValue)
                                  @Decat_Field("@@ttyp")  @dtw_assign(V_N1TTYP, fieldValue)
                                  @Decat_Field("@@atyp")  @dtw_assign(V_N1ATYP, fieldValue)

                                  @Decat_Field("@@fmdc")  @dtw_assign(V_N1FMDC, fieldValue)
                                  @Decat_Field("@@tmdc")  @dtw_assign(V_N1TMDC, fieldValue)
                                  @Decat_Field("@@amdc")  @dtw_assign(V_N1AMDC, fieldValue)

                                  @Decat_Field("@@fqdn")  @dtw_assign(V_N1FQDN, fieldValue)
                                  @Decat_Field("@@tqdn")  @dtw_assign(V_N1TQDN, fieldValue)
                                  @Decat_Field("@@aqdn")  @dtw_assign(V_N1AQDN, fieldValue)

                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}

                                  %if (V_N1APLT == "ALL")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPlantNumber, "")
                                  %endif
                                  %if (V_N1AITM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_N1ATYP == "ALL")
                                      @dtw_assign(checkedallItemType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemType, "")
                                  %endif
                                  %if (V_N1AMDC == "ALL")
                                      @dtw_assign(checkedallDemandCode, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallDemandCode, "")
                                  %endif
                                  %if (V_N1AQDN == "ALL")
                                      @dtw_assign(checkedallScheduleDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallScheduleDate, "")
                                  %endif

                              %else

                                  @RtvDftPlant(plantNumber, plantName)
                                  %if (plantNumber == "0")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(V_N1FPLT, plantNumber)
                                      @dtw_assign(V_N1TPLT, plantNumber)
                                      @dtw_assign(checkedallPlantNumber, "")
                                  %endif
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallItemType, "CHECKED")
                                  @dtw_assign(checkedallDemandCode, "CHECKED")
                                  @dtw_assign(checkedallScheduleDate, "CHECKED")
                              %endif

                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_N1FPLT)
                              %if (textOvr == "") @SetTextOvr(Err_N1TPLT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1APLT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                  <td class="inputnmbr"><input name="fromPlantNumber" value="$(V_N1FPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromPlantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toPlantNumber" value="$(V_N1TPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toPlantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName" type="hidden"></td>
                                  <td class="inputalph"><input name="allPlantNumber" value='ALL' $(checkedallPlantNumber) type="checkbox" onClick="if (this.checked) this.form.fromPlantNumber.value='', this.form.toPlantNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FPLT)
                              @DspErrMsg(Err_N1TPLT)
                              @DspErrMsg(Err_N1APLT)

                              @SetTextOvr(Err_N1FITM)
                              %if (textOvr == "") @SetTextOvr(Err_N1TITM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AITM) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N1FITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N1TITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FITM)
                              @DspErrMsg(Err_N1TITM)
                              @DspErrMsg(Err_N1AITM)

                              @SetTextOvr(Err_N1FTYP)
                              %if (textOvr == "") @SetTextOvr(Err_N1TTYP) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ATYP) %endif
                              <tr><td class="dsphdr">Item Type</td>
                                  <td class="inputalph"><input name="fromItemType" value="$(V_N1FTYP)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="toItemType" value="$(V_N1TTYP)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="allItemType" value='ALL' $(checkedallItemType) type="checkbox" onClick="if (this.checked) this.form.fromItemType.value='', this.form.toItemType.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FTYP)
                              @DspErrMsg(Err_N1TTYP)
                              @DspErrMsg(Err_N1ATYP)

                              @SetTextOvr(Err_N1FMDC)
                              %if (textOvr == "") @SetTextOvr(Err_N1TMDC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AMDC) %endif
                              <tr><td class="dsphdr">Demand Code</td>
                                  <td class="inputalph"><input name="fromDemandCode" value="$(V_N1FMDC)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="toDemandCode" value="$(V_N1TMDC)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="allDemandCode" value='ALL' $(checkedallDemandCode) type="checkbox" onClick="if (this.checked) this.form.fromDemandCode.value='', this.form.toDemandCode.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FMDC)
                              @DspErrMsg(Err_N1TMDC)
                              @DspErrMsg(Err_N1AMDC)

                              @SetTextOvr(Err_N1FQDN)
                              %if (textOvr == "") @SetTextOvr(Err_N1TQDN) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AQDN) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Schedule Date</span></td>
                                  <td class="inputnmbr"><input  name="fromScheduleDate" type="text" value="$(V_N1FQDN)" size="6" maxlength="6"><a href="javascript:calWindow('fromScheduleDate');"> $(calendarImage)</a></td>
                                  <td class="inputnmbr"><input  name="toScheduleDate" type="text" value="$(V_N1TQDN)" size="6" maxlength="6"><a href="javascript:calWindow('toScheduleDate');"> $(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allScheduleDate" value='ALL' $(checkedallScheduleDate) type="checkbox" onClick="if (this.checked) this.form.fromScheduleDate.value='', this.form.toScheduleDate.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FQDN)
                              @DspErrMsg(Err_N1TQDN)
                              @DspErrMsg(Err_N1AQDN)
                          </table>

                          @dtw_assign(envProgram, "HMR405")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(1)     Ptype,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HMRCOL_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allPlantNumber)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(fromItemType)
  @dtw_mUPPERCASE(toItemType)
  @dtw_mUPPERCASE(allItemType)
  @dtw_mUPPERCASE(fromDemandCode)
  @dtw_mUPPERCASE(toDemandCode)
  @dtw_mUPPERCASE(allDemandCode)
  @dtw_mUPPERCASE(allScheduleDate)

  @dtw_assign(fromPlantNumber,@dtw_rstrip(fromPlantNumber))
  @dtw_assign(toPlantNumber,@dtw_rstrip(toPlantNumber))
  @dtw_assign(fromScheduleDate,@dtw_rstrip(fromScheduleDate))
  @dtw_assign(toScheduleDate,@dtw_rstrip(toScheduleDate))

  %if (allPlantNumber != "ALL")
      @dtw_assign(allPlantNumber, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allItemType != "ALL")
      @dtw_assign(allItemType, "")
  %endif
  %if (allDemandCode != "ALL")
      @dtw_assign(allDemandCode, "")
  %endif
  %if (allScheduleDate != "ALL")
      @dtw_assign(allScheduleDate, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@fplt", fromPlantNumber)
  @Concat_Field("@@tplt", toPlantNumber)
  @Concat_Field("@@aplt", allPlantNumber)
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@ftyp", fromItemType)
  @Concat_Field("@@ttyp", toItemType)
  @Concat_Field("@@atyp", allItemType)
  @Concat_Field("@@fmdc", fromDemandCode)
  @Concat_Field("@@tmdc", toDemandCode)
  @Concat_Field("@@amdc", allDemandCode)
  @Concat_Field("@@fqdn", fromScheduleDate)
  @Concat_Field("@@tqdn", toScheduleDate)
  @Concat_Field("@@aqdn", allScheduleDate)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, Ptype, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}