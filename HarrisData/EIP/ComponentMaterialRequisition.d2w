%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Component Material Requisition"
  d2wName                 = "ComponentMaterialRequisition.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;touchScreen=Y&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;mfgOrder=@dtw_rurlescseq(mfgOrder)&amp;parentItem=@dtw_rurlescseq(parentItem)"
  currentURL              = "$(d2wName)/REPORT$(d2wVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  programName             = "HSI221"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  dspMaxRows              = "$(dspMaxRowsDft)"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterSearch.icl"
                  %INCLUDE "NoFormValidate.icl"
                  %INCLUDE "KeyboardFunctionsTS.icl"
                  %INCLUDE "ShowHideSelCriteria.icl"
                  function switchColor(el) {
                    var rows=document.getElementsByTagName("tr");
                    var setClass = "oddrow";
                    for(i=0;i<rows.length;i++) {
                       if(el==rows[i]) {var curClass = rows[i].className;}

                       if (rows[i].className != "") {
                           rows[i].className=setClass;
                           if (setClass == "oddrow") {setClass = "evenrow";} else {setClass = "oddrow";}
                       }
                    }
                    if (curClass != "selrow") {el.className="selrow";}
                 }
                 function updateSel(comp,seqn,qtyi,lot) {
                    if (document.Chg.compItem.value == comp && document.Chg.routingSeq.value == seqn) {
                        document.Chg.compItem.value='';
                        document.Chg.routingSeq.value='';
                        document.Chg.qtyIssued.value='';
                        document.Chg.lotControl.value='';
                    } else {
                        document.Chg.compItem.value=comp;
                        document.Chg.routingSeq.value=seqn;
                        document.Chg.qtyIssued.value=qtyi;
                        document.Chg.lotControl.value=lot;
                    }
                 }
                 function submit_Chg() {
                   if (document.Chg.transType.value!='FI' && document.Chg.compItem.value == "") {alert ("Component Item has not been selected"); return;}
                   if (document.Chg.transType.value=='FI' && document.Chg.compItem.value != "") {alert ("Component Item selection not allowed for Fill"); return;}
                   if (document.Chg.transType.value=='SH' && document.Chg.qtyIssued.value <=0) {alert ("Component Item has no quantity issued"); return;}
                   %if (V_CILTUS == "Y")
                       if (document.Chg.transType.value=='SH' && document.Chg.lotControl.value != 'N') {alert ("Shortage transaction cannot be processed for a lot control item"); return;}
                   %endif
                   document.Chg.submit();
                 }
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "COMPONENTMATERIALREQ")
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, "Select HDMCRM.*,IMLOT,IMIMDS", stmtSQL)
                          @dtw_concat(fileSQL, " HDMCRM", fileSQL)
                          @dtw_concat(fileSQL, " Inner Join HDIMST on CRCPN=IMITEM", fileSQL)
                          @dtw_concat(selectSQL, " CRPPLT=$(plantNumber)", selectSQL)
                          @dtw_concat(selectSQL, " and CRORD='$(mfgOrder)'", selectSQL)
                          @dtw_concat(selectSQL, " and CRPPN='$(parentItem)'", selectSQL)
                          @dtw_concat(selectSQL, " and CRFSTK<>'F' and CRREAS<>'D'", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By CRCPN ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Component_Material_Req(profileHandle, dataBaseID, stmtSQL)
                      </td>
                      <td>
                          <ul class="toolbarTS">
                              <li class="optionTS"><a href="$(homeURL)$(cGIPath)$(d2wName)/NOUPDATE$(d2wVarBase)">&nbsp;<br>Back</a></li>                          
                              %if (sec_04 == "Y")
                                  <li class="optionTS"><a href="javascript: document.Chg.transType.value='FI'; submit_Chg();">&nbsp;<br>Fill</a></li>
                              %endif
                              %if (sec_01 == "Y")
                                  <li class="optionTS"><a href="javascript: document.Chg.transType.value='IS'; submit_Chg();">&nbsp;<br>Issue</a></li>
                              %endif
                              %if (sec_02 == "Y")
                                  <li class="optionTS"><a href="javascript: document.Chg.transType.value='SC'; submit_Chg();">&nbsp;<br>Scrap</a></li>
                              %endif
                              %if (sec_03 == "Y")
                                  <li class="optionTS"><a href="javascript: document.Chg.transType.value='SH'; submit_Chg();">&nbsp;<br>Short</a></li>
                              %endif
                          </ul>
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}
%FUNCTION(dtw_sql) Component_Material_Req (IN CHAR(64)    profileHandle,
                                              CHAR(2)     dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <tr><td><h1>$(page_title)</h1></td></tr>
      </table>

      <table $(contentTable)>
          <colgroup>
              <col width="20%">
              <col width="60%">
              <col width="15%">
          @Format_Header("Order Number", $(mfgOrder), "")
          @RtvFldDesc("OHPLT=$(plantNumber) and OHORD='$(mfgOrder)' ", "HDMOHM", "OHCQTY", OHCQTY)
          @Format_Nbr($(OHCQTY), F_OHCQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
          @Format_Header("Order Quantity", $(F_OHCQTY), "")
          @RtvFldDesc("IMITEM='$(parentItem)'", "HDIMST", "IMIMDS", itemDescription)
          @Format_Code($(parentItem), F_parentItem)
          <tr><td class="hdrtitl">Item Number:</td>
              <td class="hdrdata">$(itemDescription) &nbsp; $(F_parentItem)</td>
              <td><a href="javascript:void+0" onClick="showSel('selData')" onBlur="hideSel('selData')">$(smMoreInfoImage)</a></td>
          </tr>
      </table>
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      @Format_Code($(plantNumber), F_plantNumber)

      @dtw_assign(moreInfo, "")
      @Build_More_Info("Plant", plantName, F_plantNumber, moreInfo)
      @RtvFldDesc("OHPLT=$(plantNumber) and OHORD='$(mfgOrder)' ", "HDMOHM", "OHRORD", OHRORD)
      @Build_More_Info("Reference Number", OHRORD, "", moreInfo)
      %INCLUDE "MoreInfo.icl"
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr">Component Item</th>
                  <th class="colhdr">Seq</th>
              </tr>
              <tr>
                  <td class="inputalph">
                      <input class="input" id="srchItem" onfocus="kbActive(this, 'keyboard');" name="srchItem" type="text" size="15" maxlength="15">
                      <input type="hidden" id="submitSearch">
                      <input type="hidden" name="operItem" value="LIKE">
                  </td>
                  <td class="inputnmbr">
                      <input class="input" id="srchSeq" onfocus="kbActive(this, 'numericKeyboard');" name="srchSeq" type="text" size="3" maxlength="3">
                      <input type="hidden" name="operSeq" value="=">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
      </form>

      @dtw_assign(pageSelectList, "N")
      @dtw_assign(wildCardDefault, "N")
      @dtw_assign(advanceSearch, "N")
      %INCLUDE "WildCardPage.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/PROCESS$(d2wVarBase)">
          <input type="hidden" name="transType">
          <input type="hidden" name="compItem">
          <input type="hidden" name="routingSeq">
          <input type="hidden" name="qtyIssued">
          <input type="hidden" name="lotControl">
          <table $(contentTable)>
              <tr><th class="colhdr">Component<br>Item</th>
                  <th class="colhdr">Description</th>
                  <th class="colhdr">Rtg<br>Seq</th>
                  <th class="colhdr">Required<br>Quantity</th>
                  <th class="colhdr">Quantity<br>Issued</th>
                  <th class="colhdr">Quantity<br>Scrapped</th>
                  <th class="colhdr">S<br>T</th>
                  <th class="colhdr">R<br>C</th>
                  <th class="colhdr">B<br>C</th>
                  %if (V_CILTUS == "Y")
                      <th class="colhdr">L<br>C</th>
                  %endif
              </tr>
              %INCLUDE "NoRecordsFound.icl"
              @dtw_assign(focusField, "orderFill")

              %ROW {
                  %INCLUDE "SetRowClass.icl"
                  @Format_Nbr($(V_CRRQTY), F_CRRQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @Format_Nbr($(V_CRQTYI), F_CRQTYI, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @Format_Nbr($(V_CRQTYS), F_CRQTYS, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  %while(@dtw_rlength(recNbr) != "2") {@dtw_insert("0", recNbr, recNbr)%}
                  <tr class="$(rowClass)" onclick="switchColor(this); updateSel('$(V_CRCPN)', $(V_CRSEQN), $(V_CRQTYI), '$(V_IMLOT)');">
                      <td class="colalph">$(V_CRCPN)</td>
                      <td class="colalph">$(V_IMIMDS)</td>
                      <td class="colnmbr">$(V_CRSEQN)</td>
                      <td class="colnmbr">$(F_CRRQTY)</td>
                      <td class="colnmbr">$(F_CRQTYI)</td>
                      <td class="colnmbr">$(F_CRQTYS)</td>
                      <td class="colcode">$(V_CRSTC)</td>
                      <td class="colcode">$(V_CRREAS)</td>
                      <td class="colcode">$(V_CRFSTK)</td>
                      %if (V_CILTUS == "Y")
                          <td class="colcode">$(V_IMLOT)</td>
                      %endif
                  </tr>
              %}
          </table>
      </form>
      %INCLUDE "KeyboardTS.icl"

      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("CRCPN", "Component Item", $(srchItem), "U", operItem, "A")
  @Build_WildCard ("CRSEQN", "Routing Sequence", $(srchSeq), "", operSeq, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}

%HTML(NOUPDATE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(confMessage, "")
  @dtw_assign(returnURL, "ShopFloorDispatch.d2w/REPORT$(genericVarBase)")
  %INCLUDE "ReturnTS.icl"
%}

%HTML(PROCESS) {
  %if (transType == "SH")
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ComponentMaterialRequisitionEntry.d2w/Edit_Data$(d2wVarBase)&amp;transType=@dtw_rurlescseq(transType)&amp;compItem=@dtw_rurlescseq(compItem)&amp;routingSeq=@dtw_rurlescseq(routingSeq)">
  %else
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ComponentMaterialRequisitionEntry.d2w/ENTRY$(d2wVarBase)&amp;transType=@dtw_rurlescseq(transType)&amp;compItem=@dtw_rurlescseq(compItem)&amp;routingSeq=@dtw_rurlescseq(routingSeq)">
  %endif
%}