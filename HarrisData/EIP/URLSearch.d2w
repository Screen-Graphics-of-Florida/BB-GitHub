%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "URL ID Search"
  d2wName                 = "URLSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  novcf                   = ""
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function selectURL(urlID, desc){
                      window.opener.document.$(docName).$(fldName).value = urlID;
                      window.opener.document.$(docName).$(fldDesc).value = desc;
                      window.opener.document.$(docName).$(fldName).focus();
                      window.close();
                  }
                  %INCLUDE "CheckEnterSearch.icl"
                  %INCLUDE "NoFormValidate.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "$(searchBanner)"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select FUID, FUDESC, FUDESCU, ", stmtSQL)
                          @dtw_concat(stmtSQL, " FUTITL, upper(FUTITL) as FUTITLU, FUURL ", stmtSQL)
                          @dtw_concat(fileSQL, " SYURLM ", fileSQL)
                          %if (moreInfo == "Y")
                              @dtw_concat(selectSQL, " FUID='$(urlIDNumber)'", selectSQL)
                          %elif (wildCardSearch!="")
                              @dtw_concat(selectSQL, " FUID<>' '", selectSQL)
                          %endif
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @List_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "$(searchTrailer)"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}
%FUNCTION(dtw_sql) List_Query (IN CHAR(64)    profileHandle,
     	                           CHAR(2)     dataBaseID,
                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Description</th>
                      <th class="colhdr">URL ID</th>
                  </tr>
                  <tr>
                      <td class="inputalph">
                          <input type="text" name="srchDesc" size="20" maxlength="20">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td class="inputalph">
                          <input type="text" name="srchURLID" size="20" maxlength="50">
                          <input type="hidden" name="operURLID" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>
	
          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("FUDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=urlDesc" title="Sequence By Description, URL ID"> Description</a></th>
                  @OrderBy_Sort("FUID", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=urlID" title="Sequence By URL ID"> URL ID</a></th>
                  @OrderBy_Sort("FUTITLU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=urlTitle" title="Sequence By Title, URL ID"> Title</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %else
          <table $(contentTable)>
      %endif		

              %ROW{
                  %INCLUDE "SetRowClass.icl"
                  @Format_Quote(V_FUID, F_FUID)
                  @Format_Quote(V_FUDESC, F_FUDESC)
                  @EditPhoneNumber(V_LOPHON)

    	           %if (moreInfo != "Y")	
                      <tr class="$(rowClass)">                                     	
                          <td class="colalph"><a href="javascript:selectURL('$(F_FUID)','$(F_FUDESC)')" title="Select URL">$(V_FUDESC)</a></td>
                          <td class="colalph">$(V_FUID)</td>
                          <td class="colalph">$(V_FUTITL)</td>
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;urlIDNumber=@dtw_rurlescseq(V_FUID)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                      </tr>

                  %else
                      %{ More Information Page %}

                      <tr><td><a href="javascript:selectURL('$(F_FUID)','$(F_FUDESC)')" title="Select URL">$(selectImageLrg)</a>
                      </td></tr>
    	   		
                      <tr><td class="dsphdr">URL ID</td>
                          <td class="dspalph">$(V_FUID)</td>
                      </tr>

                      <tr><td class="dsphdr">Description</td>
                          <td class="dspalph">$(V_FUDESC)</td>
                      </tr>
    	   		
                      <tr><td class="dsphdr">Title</td>
                          <td class="dspalph">$(V_FUTITL)</td>
                      </tr>
    	   		
                      <tr><td class="dsphdr">Target</td>
                          <td class="dspalph">$(V_FUTRGT)</td>
                      </tr>
    	   		
                      <tr><td class="dsphdr">URL</td>
                          <td class="dspalph"><textarea ROWS=5 COLS=60 DISABLED>$(V_FUURL)</textarea></td>
                      </tr>
    	   		
                      <tr><td class="dsphdr">Image</td>
                          <td class="dspalph"><textarea ROWS=5 COLS=60 DISABLED>$(V_FUIMG)</textarea></td>
                      </tr>

                  %endif
              %}
          </table>
	   %if (moreInfo != "Y")	
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
	   %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "FUDESCU,FUID")
      @DTW_ASSIGN(orderByDisplay, "Description, URL ID")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}
%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(orderBy, "FUID")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "urlID")
      %if (orderBy == "FUID")
          @DTW_ASSIGN(orderBy, "FUID DESC")
          @DTW_ASSIGN(orderByDisplay, "URL ID (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FUID")
          @DTW_ASSIGN(orderByDisplay, "URL ID")
      %endif
  %elif (sequence == "urlDesc")
      %if (orderBy == "FUDESCU,FUID")
          @DTW_ASSIGN(orderBy, "FUDESCU DESC,FUID")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), URL ID")
      %else
          @DTW_ASSIGN(orderBy, "FUDESCU,FUID")
          @DTW_ASSIGN(orderByDisplay, "Description, URL ID")
      %endif
  %elif (sequence == "urlTitle")
      %if (orderBy == "FUTITLU,FUID")
          @DTW_ASSIGN(orderBy, "FUTITLU DESC,FUID")
          @DTW_ASSIGN(orderByDisplay, "Title (descending), URL ID")
      %else
          @DTW_ASSIGN(orderBy, "FUTITLU,FUID")
          @DTW_ASSIGN(orderByDisplay, "Title, URL ID")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">URL ID</td>
                              @dtw_assign(operNbr, "operURLID")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchURLID" size="20" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchDesc" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Title</td>
                              @dtw_assign(operNbr, "operTitle")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchTitle" size="20" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">URL</td>
                              @dtw_assign(operNbr, "operURL")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchURL" size="20" maxlength="50"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchURLID.focus();
                          </script>
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("FUID", "URL ID", $(srchURLID), "U", operURLID, "A")
  @Build_WildCard ("FUDESCU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("upper(FUTITL)", "Title", $(srchTitle), "U", operTitle, "A")
  @Build_WildCard ("upper(FUURL)", "URL", $(srchURL), "U", operURL, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}