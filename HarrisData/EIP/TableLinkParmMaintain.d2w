%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Table Link Parameter Maintain"
  d2wName                 = "TableLinkParmMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;tblID=@dtw_rurlescseq(tblID)&amp;linkID=@dtw_rurlescseq(linkID)&amp;detailLink=@dtw_rurlescseq(detailLink)&amp;urlID=@dtw_rurlescseq(urlID)&amp;urlDesc=@dtw_rurlescseq(urlDesc)&amp;tableName=@dtw_rurlescseq(tableName)&amp;tableDesc=@dtw_rurlescseq(tableDesc)&amp;dftD2WName=@dtw_rurlescseq(dftD2WName)&amp;progOptName=@dtw_rurlescseq(progOptName)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  editVariables           = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %if (linkID > "0" && detailLink == "Y")
      @dtw_assign(rtvSelect, "TQXHND='$(profileHandle)' and TQTBID=$(tblID) and (TQLKID=$(linkID) or TQLKID=0) ")
  %else
       @dtw_assign(rtvSelect, "TQXHND='$(profileHandle)' and TQTBID=$(tblID) and TQLKID=$(linkID) ")
  %endif
  @RtvFldDesc("$(rtvSelect)", "SYTBLQ", "char(count(*))", recCount)	
  %if (recCount <= "0")
      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Insert Into SYTBLQ (TQXHND,TQTBID,TQLKID,TQPARM,TQCOLN,TQVALU) ", stmtSQL)
      @dtw_concat(stmtSQL, " Select  '$(profileHandle)',$(tblID),TPLKID,TPPARM,TPCOLN,TPVALU ", stmtSQL)
      @dtw_concat(stmtSQL, " From SYTBLP ", stmtSQL)
      @dtw_concat(stmtSQL, " Where TPTBID=$(tblID) and TPLKID=$(linkID) ", stmtSQL)
      %if (linkID > "0" && detailLink == "Y")
          @dtw_concat(stmtSQL, " or TPTBID=$(tblID) and TPLKID=0 ", stmtSQL)
      %endif
      @dtw_concat(stmtSQL, "  @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)
  %endif
  @RtvFldDesc("TQXHND='$(profileHandle)' and TQTBID=$(tblID) and TQLKID=$(linkID) and TQPARM=' ' and TQCOLN=' '", "SYTBLQ", "char(count(*))", recCount)	
  %if (recCount <= "0")
      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Insert Into SYTBLQ (TQXHND,TQTBID,TQLKID,TQPARM,TQCOLN,TQVALU) ", stmtSQL)
      @dtw_concat(stmtSQL, " Values ('$(profileHandle)',$(tblID),$(linkID),' ',' ',' ') @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
 	   %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              function confirmRefresh() { return confirm("Confirm refresh of parameters")}
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "TABLEOPTIONPARMMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select SYTBLQ.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, "       case when TQPARM=' ' and TQCOLN=' ' and TQVALU=' ' THEN 'C' ", stmtSQL)
                      %if (linkID > "0" && detailLink == "Y")
                          @dtw_concat(stmtSQL, "        when TQLKID=0 THEN 'A' ", stmtSQL)
                      %endif
                      @dtw_concat(stmtSQL, "            ELSE 'B' END as DSPSEQ", stmtSQL)
                      @dtw_concat(stmtSQL, " From SYTBLQ ", stmtSQL)
                      @dtw_concat(stmtSQL, "Where TQXHND='$(profileHandle)' ", stmtSQL)
                      @dtw_concat(stmtSQL, " Order By DSPSEQ,TQPARM ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  <a href="javascript:document.Chg.updateLink.value='U'; check(document.Chg)">$(acceptImageMed)</a>
                  <a onClick="return confirmRefresh()" href="$(homeURL)$(cGIPath)$(d2wName)/REFRESH$(d2wVarBase)">$(selectResetImage)</a>
                  <a href="javascript:history.back()">$(cancelImageMed)</a>
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>
      <table $(contentTable)>
          @Format_Header("Table", $(tableDesc), $(tableName))
          %if (linkID > "0")
             @Format_Header("URL", $(urlDesc), $(urlID))
          %endif
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
		
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              <tr>
                  <td class="colhdr">Parameter Name</td>
                  <td class="colhdr">Column Name</td>
                  <td class="colhdr">Value</td>
              </tr>
              <tr><td><input type="hidden" name="updateLink"></td></tr>
              @dtw_assign(focusField, "")
              @dtw_assign(recNbr, "0")
          %ROW {
             @Rtv_Error_Desc("$(V_TQMSG#)", errorMessage)
             <tr>
                 %if (linkID > "0"  && detailLink == "Y" && V_TQLKID == "0")
                     <td class="inputalph">$(V_TQPARM)</td>
                     <td class="inputalph">$(V_TQCOLN)</td>
                     <td class="inputalph">$(V_TQVALU)</td>
                 %else
                     @dtw_add(recNbr, "1", recNbr)
                     %while(@dtw_rlength(recNbr) != "4") {@dtw_insert("0", recNbr, recNbr)%}
                     %if (focusField == "" && V_TQMSG# != "")
                         @dtw_assign(focusField, "cn$(recNbr)")
                     %endif
                     <td class="inputnmbr"><input type="text"   name="pn$(recNbr)" value="$(V_TQPARM)" size="30" maxlength="100"></td>
                     <td class="inputalph"><input type="text"   name="cn$(recNbr)" value="$(V_TQCOLN)" size="30" maxlength="130"><a href="$(homeURL)$(cGIPath)TableColumnSearch.d2w/REPORT$(d2wVarBase)&amp;docName=Chg&amp;fldName=cn$(recNbr)&amp;fldDesc=cn$(recNbr)Desc" onclick="$(searchWinVar)"> $(searchImage) &nbsp; </a> <input name="cn$(recNbr)Desc" value="$(fieldDesc)" type="hidden"></td>
                     <td class="inputalph"><input type="text"   name="vl$(recNbr)" value="$(V_TQVALU)" size="30" maxlength="130"></td>
                     <td class="inputalph"><input type="hidden" name="fp$(recNbr)" value="$(V_TQPARM)"></td>
                 %endif
             </tr>
             @DspErrMsg(errorMessage)
          %}
          </table>
          %if (focusField == "")
              @dtw_assign(focusField, "pn$(recNbr)")
          %endif
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      <table $(contentTable)>
          <tr>
              <td class="toolbar">
                  <a href="javascript:document.Chg.updateLink.value='U'; check(document.Chg)">$(acceptImageMed)</a>
                  <a onClick="return confirmRefresh()" href="$(homeURL)$(cGIPath)$(d2wName)/REFRESH$(d2wVarBase)">$(selectResetImage)</a>
                  <a href="javascript:history.back()">$(cancelImageMed)</a>
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSYTBQ_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(REFRESH) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Delete From SYTBLQ Where TQXHND='$(profileHandle)'  @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)
  @Set_SQL(stmtSQL)
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @RtvFldDesc("TQXHND='$(profileHandle)' and TQTBID=$(tblID) and TQLKID=$(linkID) ", "SYTBLQ", "char(count(*))", recCount)	
  @dtw_assign(ux, "1")
  %while(ux <= recCount){
      @dtw_assign(recNbr, ux)
      %while(@dtw_rlength(recNbr) != "4") {@dtw_insert("0", recNbr, recNbr)%}
      @dtw_assign(fprm, $(fp$(recNbr)))
      @dtw_assign(parm, $(pn$(recNbr)))
      @dtw_assign(coln, $(cn$(recNbr)))   @dtw_mUPPERCASE(coln)
      @dtw_assign(valu, $(vl$(recNbr)))

      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Update SYTBLQ Set TQPARM='$(parm)', TQCOLN='$(coln)', TQVALU='$(valu)' ", stmtSQL)
      @dtw_concat(stmtSQL, " Where TQXHND='$(profileHandle)' and TQTBID=$(tblID) and TQLKID=$(linkID) and TQPARM='$(fprm)' @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)
      @dtw_add(ux, "1", ux)
  %}

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Delete From SYTBLQ Where TQXHND='$(profileHandle)' and TQPARM=' ' and TQCOLN=' ' and TQVALU=' '  @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)

  @dtw_assign(maintenanceCode, updateLink)
  @dtw_assign(edtVar, "")
  @Concat_Field("@@tbln", tableName)
  @Concat_Field("@@tbid", tblID)
  @Concat_Field("@@lkid", linkID)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" && updateLink=="U")
      @Format_ConfMsg_Desc("C", $(tableDesc), "$(tableName)", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)TableLink.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif

%}
