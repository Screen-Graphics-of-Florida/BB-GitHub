%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Component Material Fill"
  d2wName                 = "ComponentMaterialFill.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;turnaroundNumber=@dtw_rurlescseq(turnaroundNumber)&amp;touchScreen=Y"
  nextPrevVar             = "$(d2wVarBase)"
  programName             = ""
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "8"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "8"
  F_OQTY                  = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")	
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  var rows = (chgForm.displayedRows.value ? chgForm.displayedRows.value : 0);
                  var ok = true;
                  for (var rx = 1; rx <= rows; rx++) {
                      var suffix = rx.toString();
                      while (suffix.length < 4) {
                          suffix = "0" + suffix;
                      }
                      var elemName = "FQ" + suffix;
                      chgForm[elemName].value = numberWithoutCommas(chgForm[elemName].value);
                      ok = (editNum(chgForm[elemName], 9, 4));
                      chgForm[elemName].value = numberWithCommas(chgForm[elemName].value);
                      if (!ok) {break;}
                  }
                  return ok;
              }
              function validateOrderFill(chgForm) {
                  var ok = true;
                  chgForm.orderFill.value = numberWithoutCommas(chgForm.orderFill.value);
                  ok = editNum(chgForm.orderFill, 9, 4);
                  chgForm.orderFill.value = numberWithCommas(chgForm.orderFill.value);
                  if (ok) {
                      chgForm.updateFill.value='Y';
                      chgForm.submit();
                  }
              }
              function nextPage(chgForm,startRow) {
                  chgForm.rowIndexNext.value=startRow;
                  chgForm.submit();
              }
              function prevPage(chgForm,startRow) {
                  chgForm.rowIndexPrev.value=startRow;
                  chgForm.submit();
              }
              %INCLUDE "NumEdit.icl"
              %INCLUDE "KeyboardFunctionsTS.icl"
              %INCLUDE "ShowHideSelCriteria.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(wildCardSearch, "")
                      @dtw_assign(uv_Sql, "")
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " SITFIW inner join HDTRNM on WRPLT=DCPLT and WRORD=DCMORD and WRSEQN=DCSEQN and WRXHND='$(profileHandle)' ", fileSQL)
                      @dtw_concat(selectSQL, "DCTURN = $(turnaroundNumber) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By WRCPN ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Fill_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
                  <td>
                      <ul class="toolbarTS">
                          <li class="optionTS"><a href="$(homeURL)$(cGIPath)$(d2wName)/NOUPDATE$(d2wVarBase)">&nbsp;<br>Back</a></li>                      
                          <li class="optionTS"><a href="javascript:check(document.Chg)">&nbsp;<br>Accept</a></li>
                          <li class="optionTS"><a href="$(homeURL)$(cGIPath)$(d2wName)/BUILD$(d2wVarBase)">&nbsp;<br>Refresh</a></li>
                      </ul>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Fill_Query (IN CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <tr><td><h1>$(page_title)</h1></td></tr>
      </table>

      <table $(contentTable)>
          <colgroup>
              <col width="20%">
              <col width="60%">
              <col width="15%">
          @RtvFldDesc("DCTURN=$(turnaroundNumber)", "HDTRNM", "DCMORD", mfgOrder)

          <tr><td class="hdrtitl">Order:</td>
              <td class="hdrdata">$(mfgOrder)</td>
          </tr>
          @RtvFldDesc("DCTURN=$(turnaroundNumber)", "HDTRNM", "DCSEQN", rtgSequence)
          <tr><td class="hdrtitl">Routing Sequence:</td>
              <td class="hdrdata">$(rtgSequence)</td>
              <td><a href="javascript:void+0" onClick="showSel('selData')" onBlur="hideSel('selData')">$(smMoreInfoImage)</a></td>
          </tr>
      </table>
      @RtvFldDesc("DCTURN=$(turnaroundNumber)", "HDTRNM", "DCPLT", plantNumber)
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      @Format_Code($(plantNumber), F_plantNumber)

      @dtw_assign(moreInfo, "")
      @Build_More_Info("Plant", plantName, F_plantNumber, moreInfo)
      @Build_More_Info("Turnaround", turnaroundNumber, "", moreInfo)
      %INCLUDE "MoreInfo.icl"

      $(hrTagAttr)

      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" method="post" name="Chg" action="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
          <table $(contentTable)>
              <tr>
                  <td class="page" nowrap>
                      %if (sql_Record_Count > RPT_MAX_ROWS)  %{Assign Paging Values %}
                          @DTW_ASSIGN(totalPages, @DTW_RINTDIV(sql_Record_Count, RPT_MAX_ROWS))
                          %if (@DTW_RDIVREM(sql_Record_Count, RPT_MAX_ROWS) > "0")
                              @DTW_ADD(totalPages, "1", totalPages)
                          %endif
                      %else
                          @DTW_ASSIGN(totalPages, "1")
                      %endif

                      @dtw_assign(page, @dtw_radd(@dtw_rdivide(@dtw_rsubtract(START_ROW_NUM, "1"), RPT_MAX_ROWS), "1"))
                      @dtw_add(START_ROW_NUM, RPT_MAX_ROWS, rowIndexNext)
                      @dtw_subtract(START_ROW_NUM, RPT_MAX_ROWS, rowIndexPrev)

                      Page: $(page) of $(totalPages)
                          %if (nextPrevPos != "2" && nextPrevVar != "")
                              %if (START_ROW_NUM > RPT_MAX_ROWS)
                                  <a href="javascript:prevPage(document.Chg,$(rowIndexPrev))">$(previousImage)</a>
                              %else
                                  %if (sql_Record_Count > RPT_MAX_ROWS)
                                      $(nextPrevBlank)
                                  %endif
                              %endif

                              %if (sql_Record_Count >= rowIndexNext)
                                  <a href="javascript:nextPage(document.Chg,$(rowIndexNext))">$(nextImage)</a>
                              %else
                                  %if (sql_Record_Count > RPT_MAX_ROWS)
                                      $(nextPrevBlank)
                                  %endif
                              %endif
                          %endif
                  </td>
                  <td class="dsphdr"><span $(textOvr)>&nbsp; &nbsp; Order Fill Quantity</span></td>
                  <td class="input"><input class="input" id="orderFill" onfocus="kbActive(this, 'numericKeyboard', true);" onkeyup="formatInput(this.id);" name="orderFill" type="text" value="$(F_OQTY)" size="15" maxlength="15"></td>
                  <td class="input"><a href="javascript:validateOrderFill(document.Chg)">&nbsp; $(selectAcceptImage)</a></td>
                  <td><input type="hidden" name="updateFill" value="N"></td>
              </tr>
          </table>


          <table $(contentTable)>
              <tr><th class="colhdr">Component Item</th>
                  <th class="colhdr">Required<br>Quantity</th>
                  <th class="colhdr">Quantity<br>Issued</th>
                  <th class="colhdr">Quantity<br>Scrapped</th>
                  <th class="colhdr">Fill<br>Quantity</th>
                  <th class="colhdr" colspan="3">Stock Location</th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
              @dtw_assign(focusField, "orderFill")

              %ROW {
                  %INCLUDE "SetRowClass.icl"
                  @Format_Nbr($(V_WRRQTY), F_WRRQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @Format_Nbr($(V_WRIQTY), F_WRIQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @Format_Nbr($(V_WRSQTY), F_WRSQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @dtw_assign(recNbr, $(ROW_NUM))
                  %while(@dtw_rlength(recNbr) != "4") {@dtw_insert("0", recNbr, recNbr)%}
                  <tr class="$(rowClass)">
                      <td class="colalph"><input type="hidden" name="CI$(recNbr)" value="$(V_WRCPN)">$(V_WRCPN)</td>
                      <td class="colnmbr">$(F_WRRQTY)</td>
                      <td class="colnmbr">$(F_WRIQTY)</td>
                      <td class="colnmbr">$(F_WRSQTY)</td>
                      
                      @dtw_assign(creditCodeOvr, "N")
                      @Format_Nbr($(V_WRFQTY), F_WRFQTY, "4", "K", "", "", "")
                      %if (@dtw_rpos("-", F_WRFQTY) > "0")
                          @dtw_concat("-", @dtw_rreplace("$(F_WRFQTY)", "-", ""), F_WRFQTY)
                      %endif
                      <td class="input"><input class="input" id="FQ$(recNbr)" onfocus="kbActive(this, 'numericKeyboard', true);" onkeyup="formatInput(this.id);" name="FQ$(recNbr)" type="text" value="$(F_WRFQTY)" size="12" maxlength="17"></td>
                      <td class="input" colspan="3"><input class="input" id="SR$(recNbr)" onfocus="kbActive(this, 'keyboard');" name="SR$(recNbr)" type="text" value="$(V_WRSTKR)" size="2" maxlength="3"> - <input class="input" id="SA$(recNbr)" onfocus="kbActive(this, 'keyboard');" name="SA$(recNbr)" type="text" value="$(V_WRAILE)" size="3" maxlength="4"> - <input class="input" id="SL$(recNbr)" onfocus="kbActive(this, 'keyboard');" name="SL$(recNbr)" type="text" value="$(V_WRSLOC)" size="5" maxlength="8">
                                                    <a href="$(homeURL)$(phpPath)StockLocSearch.php$(altVarBase)&amp;docName=Chg&amp;fldStkr=SR$(recNbr)&amp;fldAisle=SA$(recNbr)&amp;fldLoc=SL$(recNbr)&amp;fldStkID=SI$(recNbr)&amp;touchScreen=Y" onclick="$(searchWinVar)"> $(searchDesc)</a>
                                                    <input name="SI$(recNbr)" type="hidden" size="9" maxlength="9">
                      </td>
                  </tr>
                  %if (V_WRESTK != "")
                      @Ret_Error_Msg(profileHandle, dataBaseID, $(V_WRER#), errorMessage)
                      %if (errorMessage != "")
                          <tr class="$(rowClass)">
                              <td colspan="4">&nbsp;</td>
                              <td class="error" colspan="5">$(errorMessage)</td>
                          </tr>
                      %endif
                  %endif
              %}
              <tr><td><input type="hidden" name="displayedRows" value="$(ROW_NUM)"></td></tr>	
              <tr><td><input type="hidden" name="rowIndexCurr" value="$(START_ROW_NUM)"></td></tr>	
              <tr><td><input type="hidden" name="rowIndexNext" value=""></td></tr>	
              <tr><td><input type="hidden" name="rowIndexPrev" value=""></td></tr>	
          </table>
          %INCLUDE "KeyboardTS.icl"
      </form>

      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSITFI_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(NOUPDATE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(confMessage, "Confirm No Update")
  @dtw_assign(returnURL, "DataCollection.d2w/REPORT$(genericVarBase)")
  %INCLUDE "ReturnTS.icl"
%}

%HTML(BUILD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @Concat_Field("@@turn", turnaroundNumber)
  @Concat_Field("@@subr", "SRWORK")
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, errFound, edtVar, errVar)
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  %if (updateFill == "Y")
      @dtw_assign(orderFill,  @dtw_rstrip(orderFill))
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@turn", turnaroundNumber)
  %if (updateFill == "Y")
      @Concat_Field("@@subr", "SRUPDF")
      @dtw_replace("$(orderFill)", ",", "", orderFill)
      @Concat_Field("@@oqty", orderFill)
  %else
      %if (rowIndexNext != "" || rowIndexPrev != "")
          @Concat_Field("@@subr", "SRUPDW")
      %else
          @Concat_Field("@@subr", "ACCEPT")
      %endif
      @Concat_Field("@@rows", displayedRows)
      @dtw_assign(y, "1")
      %while(y <= displayedRows) {
          @dtw_assign(x, "$(y)")
          %while(@dtw_rlength(x) != "4") {@dtw_insert("0", x, x)%}
          @dtw_assign(CI, "CI$(x)")
          @dtw_assign(FQ, "FQ$(x)")
          @dtw_assign(SR, "SR$(x)")
          @dtw_assign(SA, "SA$(x)")
          @dtw_assign(SL, "SL$(x)")
          @dtw_add(y, "1", y)
          @Concat_Field("$(CI)", "$($(CI))")
          @dtw_replace("$($(FQ))", ",", "", F_FQ)
          @Concat_Field("$(FQ)", "$(F_FQ)")
          @Concat_Field("$(SR)", "$($(SR))")
          @Concat_Field("$(SA)", "$($(SA))")
          @Concat_Field("$(SL)", "$($(SL))")
      %}
  %endif
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, errFound, edtVar, errVar)

  %if (errFound == "")
      @dtw_assign(confMessage, "Confirm Component Material Fill")
      @dtw_assign(returnURL, "DataCollection.d2w/REPORT$(genericVarBase)")
      %INCLUDE "ReturnTS.icl"
  %elif (errFound == "R")
      %if (rowIndexNext != "")
          @dtw_assign(START_ROW_NUM,rowIndexNext)
      %elif (rowIndexPrev != "")
          @dtw_assign(START_ROW_NUM,rowIndexPrev)
      %else
          @dtw_assign(START_ROW_NUM,rowIndexCurr)
      %endif
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;START_ROW_NUM=$(START_ROW_NUM)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;START_ROW_NUM=$(rowIndexCurr)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}