%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Delegated Participant Maintenance"
  d2wName                 = "WFDelegateMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;passedWfParticipant=@dtw_rurlescseq(passedWfParticipant)&amp;backHome=@dtw_rurlescseq(backHome)&amp;updRecNbr=@dtw_rurlescseq(updRecNbr)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;wfParticipant=@dtw_rurlescseq(wfParticipant)&amp;wfDelegationId=@dtw_rurlescseq(wfDelegationId)&amp;maintenanceCode=D"
  programName             = "HWFDLM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "TimeEdit.icl"
              function confirmDelete() {return confirm("$(delRecordConf)")}
              function validate(chgForm) {
                  if (document.Chg.wfParticipant.value =="" ||
                      document.Chg.delegator.value =="" ||
                      document.Chg.fromDate.value =="" ||
                      document.Chg.toDate.value =="")
                         {alert("$(reqFieldError)"); return false;}
                  if (editdate(document.Chg.fromDate) &&
                      editTimeHM(document.Chg.fromTime) &&
                      editdate(document.Chg.toDate) &&
                      editTimeHM(document.Chg.toTime) &&
                      editNum(document.Chg.wfPoint, 4, 3) &&
                      editNum(document.Chg.wfSequence, 4, 3)
                      )
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFDELEGATEMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " WFDELG ", fileSQL)
                          @dtw_concat(selectSQL, " DLPART='$(wfParticipant)' and DLDLID=$(wfDelegationId) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (fromD2w == "WFParticipantInquiryList.d2w")
          @dtw_assign(backURL, "$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;wfParticipant=@dtw_rurlescseq(passedWfParticipant)")
      %else
          @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
          %if (backURL == "")
              @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=214")
          %endif
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          %ROW {
              %if (errFound != "" || maintenanceCode == "A")
                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(edtVar, "")
                  %else
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@part", "wfParticipant")       @dtw_assign(Err_DLPART, fieldValue)
                      @DecatErr_Field("@@dprt", "delegator")           @dtw_assign(Err_DLDPRT, fieldValue)
                      @DecatErr_Field("@@erpt", "effectiveRepeat")     @dtw_assign(Err_DLERPT, fieldValue)
                      @DecatErr_Field("@@fdat", "fromDate")            @dtw_assign(Err_DLFDAT, fieldValue)
                      @DecatErr_Field("@@ftim", "fromTime")            @dtw_assign(Err_DLFTIM, fieldValue)
                      @DecatErr_Field("@@tdat", "toDate")              @dtw_assign(Err_DLTDAT, fieldValue)
                      @DecatErr_Field("@@ttim", "toTime")              @dtw_assign(Err_DLTTIM, fieldValue)
                      @DecatErr_Field("@@proc", "wfProcess")           @dtw_assign(Err_DLPROC, fieldValue)
                      @DecatErr_Field("@@pont", "wfPoint")             @dtw_assign(Err_DLPONT, fieldValue)
                      @DecatErr_Field("@@seq@", "wfSequence")          @dtw_assign(Err_DLSEQ, fieldValue)
                  %endif

                  @Decat_Field("@@part")   @dtw_assign(V_DLPART, fieldValue)
                  @Decat_Field("@@dlid")   @dtw_assign(V_DLDLID, fieldValue)
                  @Decat_Field("@@dprt")   @dtw_assign(V_DLDPRT, fieldValue)
                  @Decat_Field("@@erpt")   @dtw_assign(V_DLERPT, fieldValue)
                  @Decat_Field("@@fdat")   @dtw_assign(V_DLFDAT, fieldValue)
                  @Decat_Field("@@ftim")   @dtw_assign(V_DLFTIM, fieldValue)
                  @Decat_Field("@@tdat")   @dtw_assign(V_DLTDAT, fieldValue)
                  @Decat_Field("@@ttim")   @dtw_assign(V_DLTTIM, fieldValue)
                  @Decat_Field("@@proc")   @dtw_assign(V_DLPROC, fieldValue)
                  @Decat_Field("@@pont")   @dtw_assign(V_DLPONT, fieldValue)
                  @Decat_Field("@@seq@")   @dtw_assign(V_DLSEQ, fieldValue)

                  %if (errFound == "" && maintenanceCode == "A")
                      %if (frmWfParticipant != "")
                          @dtw_assign(V_DLPART, frmWfParticipant)
                          @dtw_assign(V_DLPROC, wfProcess)
                          @dtw_assign(V_DLPONT, wfPoint)
                          @dtw_assign(V_DLSEQ,  wfSequence)
                          @dtw_assign(focusField, "delegator")
                      %else
                          @dtw_assign(focusField, "wfParticipant")
                          @dtw_assign(V_DLPONT, "0")
                          @dtw_assign(V_DLSEQ, "0")
                      %endif
                      @dtw_assign(V_DLDLID, "0")
                  %endif

                  @dtw_assign(errFound, "")

              %elif (maintenanceCode == "Z")
                  @DateInputFromCYMD(V_DLFDAT)
                  @DateInputFromCYMD(V_DLTDAT)
                  @dtw_assign(focusField, "wfParticipant")
                  @dtw_assign(V_DLDLID, "0")
              %else
                  @DateInputFromCYMD(V_DLFDAT)
                  @DateInputFromCYMD(V_DLTDAT)
                  @dtw_assign(focusField, "delegator")
              %endif

              <table $(contentTable)>
                  <tr><td><input type="hidden" name="wfDelegationId" value="$(V_DLDLID)"></td></tr>

                  @SetTextOvr(Err_DLPART)
                  @RtvFldDesc("USUSER='$(V_DLPART)' ", "SYUSER", "USDESC", fieldDesc)
                  <tr><td class="dsphdr"><span $(textOvr)>Participant</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input type="text" name="wfParticipant" value="$(V_DLPART)" size="10" maxlength="10">
                                                <a href="$(homeURL)$(phpPath)UserSearch.php$(altVarBase)&amp;docName=Chg&amp;userFld=wfParticipant&amp;descFld=wfParticipantName" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage)</a>
                                                <input type="text" disabled name="wfParticipantName" value="$(fieldDesc)" size="30"></td>
                      %else
                          <td class="inputalph"><input type="hidden" name="wfParticipant" value="$(V_DLPART)">$(V_DLPART) $(fieldDesc)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_DLPART)

                  @SetTextOvr(Err_DLDPRT)
                  @RtvFldDesc("USUSER='$(V_DLDPRT)' ", "SYUSER", "USDESC", fieldDesc)
                  <tr><td class="dsphdr"><span $(textOvr)>Delegated Participant</span></td>
                      <td class="inputalph"><input type="text" name="delegator" value="$(V_DLDPRT)" size="10" maxlength="10">
                                            <a href="$(homeURL)$(phpPath)UserSearch.php$(altVarBase)&amp;docName=Chg&amp;userFld=delegator&amp;descFld=delegatorName" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage)</a>
                                            <input type="text" disabled name="delegatorName" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_DLDPRT)

                  @RtvFldDesc("FLTYPE='BY' and FLVALU='$(V_DLERPT)'", "SYFLAG", "FLDESC", fieldDesc)
                  @SetTextOvr(Err_DLERPT)
                  <tr><td class="dsphdr"><span $(textOvr)>Repeat Every Day</span></td>
                      <td class="inputalph"><input type="text" name="effectiveRepeat" value="$(V_DLERPT)" size="10" maxlength="1">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=BY&amp;flagSrchHdr=@dtw_rurlescseq("Repeat Every Day")&amp;docName=Chg&amp;fldName=effectiveRepeat&amp;fldDesc=effectiveRepeatDesc" onclick="$(searchWinVar)">&nbsp; $(searchImage)</a>
                                            <input type="text" disabled name="effectiveRepeatDesc" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_DLERPT)
              </table>

              <table $(contentTable)>
                  <tr><td class="dsphdr">&nbsp;</td>
                      <td class="colhdr">Date</td>
                      <td class="colhdr">Time</td>
                  </tr>

                  @SetTextOvr(Err_DLFDAT)
	           <tr><td class="dsphdr"><span $(textOvr)>Effective From</span></td>
                      <td class="inputnmbr"><input type="text" name="fromDate" value="$(V_DLFDAT)" size="6" maxlength="6"> $(reqFieldChar) 		
                                            <a href="javascript:calWindow('fromDate');">$(calendarImage)</a></td>
                      <td class="inputnmbr"><input type="text" name="fromTime" value="$(V_DLFTIM)" size="4" maxlength="4"> 		
                  </tr>
                  @DspErrMsg(Err_DLFDAT)

                  @SetTextOvr(Err_DLTDAT)
	           <tr><td class="dsphdr"><span $(textOvr)>Effective To</span></td>
                      <td class="inputnmbr"><input type="text" name="toDate" value="$(V_DLTDAT)" size="6" maxlength="6"> $(reqFieldChar) 		
                                            <a href="javascript:calWindow('toDate');">$(calendarImage)</a></td>
                      <td class="inputnmbr"><input type="text" name="toTime" value="$(V_DLTTIM)" size="4" maxlength="4"> 		
                  </tr>
                  @DspErrMsg(Err_DLTDAT)
              </table>

              <fieldset class="legendBody">
                  <legend class="legendTitle">Specific Entries</legend>
                  <table $(contentTable)>
                      @SetTextOvr(Err_DLPROC)
                      @RtvFldDesc("PRPROC='$(V_DLPROC)'", "WFPRHD", "PRDESC", fieldDesc)
                      <tr><td class="dsphdr"><span $(textOvr)>Process</span></td>
                          <td class="inputalph"><input type="text" name="wfProcess" value="$(V_DLPROC)" size="30" maxlength="30">
                                                <input type="text" disabled name="wfProcessDesc" value="$(fieldDesc)" size="50"></td>
                      </tr>
                      @DspErrMsg(Err_DLPROC)

                      @SetTextOvr(Err_DLPONT)
                      @RtvFldDesc("PDPROC='$(V_DLPROC)' and PDPONT=$(V_DLPONT) and PDSEQ=$(V_DLSEQ) ", "WFPRDT", "PDDESC", fieldDesc)
                      <tr><td class="dsphdr"><span $(textOvr)>Detail Point</span></td>
                          <td class="inputnmbr"><input type="text" name="wfPoint" value="$(V_DLPONT)" size="10" maxlength="8">
                                                <input type="text" name="wfSequence" value="$(V_DLSEQ)" size="9" maxlength="8">
                                                <a href="$(homeURL)$(cGIPath)WFDetailSearch.d2w/REPORT$(genericVarBase)&amp;specificDelegateFlag=Y&amp;docName=Chg&amp;fldProc=wfProcess&amp;fldProcDesc=wfProcessDesc&amp;fldPoint=wfPoint&amp;fldSequence=wfSequence&amp;fldDesc=wfSequenceDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                <input type="text" disabled name="wfSequenceDesc" value="$(fieldDesc)" size="30"></td>
                      </tr>
                      @DspErrMsg(Err_DLPONT)
                  </table>
              </fieldset>
          %}

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HWFDLM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @dtw_mUPPERCASE(wfParticipant)
  @dtw_mUPPERCASE(delegator)
  @dtw_mUPPERCASE(wfProcess)
  @dtw_mUPPERCASE(effectiveRepeat)

  %if (delegator == "")
      @RtvFldDesc("DLPART='$(wfParticipant)' and DLDLID=$(wfDelegationId)", "WFDELG", "DLDPRT", delegator)
  %endif
  @RtvFldDesc("USUSER='$(wfParticipant)'", "SYUSER", "USDESC", wfParticipantName)
  @RtvFldDesc("USUSER='$(delegator)'", "SYUSER", "USDESC", delegatorName)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@part", wfParticipant)
  @Concat_Field("@@dlid", wfDelegationId)
  @Concat_Field("@@dprt", delegator)
  @Concat_Field("@@erpt", effectiveRepeat)
  @Concat_Field("@@fdat", fromDate)
  @Concat_Field("@@ftim", fromTime)
  @Concat_Field("@@tdat", toDate)
  @Concat_Field("@@ttim", toTime)
  @Concat_Field("@@proc", wfProcess)
  @Concat_Field("@@pont", wfPoint)
  @Concat_Field("@@seq@", wfSequence)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, "$(wfParticipantName) to $(delegatorName)", "", "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@part", "wfParticipant")
          @Format_ConfMsg_Desc("", "$(wfParticipantName) to $(delegatorName)", "", "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      %if (fromD2w == "WFParticipantInquiryList.d2w")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;wfParticipant=@dtw_rurlescseq(passedWfParticipant)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
          %if (backURL == "")
              <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=214&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %else
              <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %endif
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;wfParticipant=@dtw_rurlescseq(wfParticipant)&amp;wfDelegationId=@dtw_rurlescseq(wfDelegationId)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
