%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Order Entry User Defined"
  d2wName                 = "OrderEntryUserDefined.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
  tabID                   = "USERDEFINED"
  fileName                = "OEOUHD"
%}

%INCLUDE "userdefined_number.icl"

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@customerName", "@dtw_rurlescseq(customerName)", "1", "a", workURL)
  @dtw_replace(workURL, "@@customerNumber", "@dtw_rurlescseq(customerNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@orderBy", "@dtw_rurlescseq(orderBy)", "1", "a", workURL)
  @dtw_replace(workURL, "@@orderControlNumber", "@dtw_rurlescseq(orderControlNumber)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @dtw_assign(editVariables, "")
  @dtw_tb_rows(orderUserDefinedTable, userMaxRows)
  @dtw_assign(ux, "1")
  %while(ux <= userMaxRows){
      @dtw_tb_getv(orderUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderUserDefinedTable, "UFFLDN"), V_UFFLDN)
      @dtw_tb_getv(orderUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderUserDefinedTable, "UFDESC"), V_UFDESC)
      @dtw_tb_getv(orderUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderUserDefinedTable, "UFTYPE"), V_UFTYPE)
      @dtw_tb_getv(orderUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderUserDefinedTable, "UFSIZE"), V_UFSIZE)
      @dtw_tb_getv(orderUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderUserDefinedTable, "UFDECM"), V_UFDECM)
      @dtw_tb_getv(orderUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderUserDefinedTable, "UFREQF"), V_UFREQF)

      %if (V_UFTYPE == "N")
          @dtw_concat(editVariables, " editNum(document.Chg.", editVariables)
          @dtw_concat(editVariables, $(V_UFFLDN), editVariables)
          @dtw_concat(editVariables, ", ", editVariables)
          @dtw_concat(editVariables, $(V_UFSIZE), editVariables)
          @dtw_concat(editVariables, ", ", editVariables)
          @dtw_concat(editVariables, $(V_UFDECM), editVariables)
          @dtw_concat(editVariables, ") &&", editVariables)
      %elif (V_UFTYPE == "D")
          @dtw_concat(editVariables, " editdate(document.Chg.", editVariables)
          @dtw_concat(editVariables, $(V_UFFLDN), editVariables)
          @dtw_concat(editVariables, ") &&", editVariables)
      %endif
      %if (V_UFREQF == "Y")
          @dtw_concat(editVariables, " checkReqField(document.Chg.", editVariables)
          @dtw_concat(editVariables, $(V_UFFLDN), editVariables)
          @dtw_concat(editVariables, ") &&", editVariables)
      %endif
      @dtw_add(ux, "1", ux)
  %}
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "OrderEntryProgOpt.icl"
          %INCLUDE "OrderEntryRetInfo.icl"
          @RtvFldDesc("H1OCTL=$(orderControlNumber)", "OEHDWK", "H1ORTY", orderType)
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "ShowHideSelCriteria.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "OrderEntryConfirm.icl"
              function validate(chgForm) {
                  if ($(editVariables) document.Chg.octl.value != "")
                  return true;
              }
              %INCLUDE "checkReqField.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumZero.icl"
              %INCLUDE "numedit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ORDERHEADER")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "Select * From OEHDWK Where H1OCTL=$(orderControlNumber)")
                      %INCLUDE "stmtSQLEnd.icl"
                      @Order_Header_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Order_Header_Query (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "OrderEntryTabs.icl"
      %INCLUDE "RequiredField.icl"
      <div class="quickLinksTop">
          <a href="javascript:check(document.Chg)">$(acceptImageLrg)</a>
          <a href="$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)">$(selectResetImage)</a>
      </div>

      %ROW {
      <form class="formClass" METHOD=POST name="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintCode=@dtw_rurlescseq(V_H1MNCD)&amp;userHeaderFields=@dtw_rurlescseq(userHeaderFields)&amp;orderType=@dtw_rurlescseq(V_H1ORTY)&amp;oe_sec_09=@dtw_rurlescseq(oe_sec_09)">
          <table $(contentTable)>
              %if (confUpdate == "Y")
                  <tr><td>&nbsp;</td>
                      <td class="dspalph"><span class="error">Confirm Update Of User-Defined</span></td>
                  </tr>
              %endif

              <tr><td class="inputalph"><input type="hidden" name="octl" value="$(orderControlNumber)"></td></tr>
      %}

              @dtw_tb_rows(orderUserDefinedTable, userMaxRows)
              @dtw_assign(ux, "1")
              %while(ux <= userMaxRows){
                  @dtw_tb_getv(orderUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderUserDefinedTable, "UFFLDN"), V_UFFLDN)
                  @dtw_tb_getv(orderUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderUserDefinedTable, "UFDESC"), V_UFDESC)
                  @dtw_tb_getv(orderUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderUserDefinedTable, "UFTYPE"), V_UFTYPE)
                  @dtw_tb_getv(orderUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderUserDefinedTable, "UFSIZE"), V_UFSIZE)
                  @dtw_tb_getv(orderUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderUserDefinedTable, "UFDECM"), V_UFDECM)
                  @dtw_tb_getv(orderUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderUserDefinedTable, "UFVALU"), V_UFVALU)
                  @dtw_tb_getv(orderUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderUserDefinedTable, "UFBOXS"), V_UFBOXS)
                  @dtw_tb_getv(orderUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderUserDefinedTable, "UFREQF"), V_UFREQF)
                  @dtw_tb_getv(orderUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderUserDefinedTable, "UFVLDV"), V_UFVLDV)

                  @dtw_assign(V_WUFLDD, "")
                  @dtw_assign(V_WUFLDV, "")
                  @dtw_assign(V_WUFLDR, "")
                  @dtw_tb_rows(orderWorkUserDefinedTable, maxRows)
                  @dtw_assign(x, "1")
                  %while((@dtw_tb_rgetv(orderWorkUserDefinedTable, x, @dtw_tb_rQuerycolnonj(orderWorkUserDefinedTable, "WUFLDN")) != V_UFFLDN) && (x <= maxRows))
                      {@dtw_add(x, "1", x)%}
                  %if (x <=maxRows)
                      @dtw_tb_getv(orderWorkUserDefinedTable, x, @dtw_tb_rQuerycolnonj(orderWorkUserDefinedTable, "WUFLDD"), V_WUFLDD)
                      @dtw_tb_getv(orderWorkUserDefinedTable, x, @dtw_tb_rQuerycolnonj(orderWorkUserDefinedTable, "WUFLDV"), V_WUFLDV)
                      @dtw_tb_getv(orderWorkUserDefinedTable, x, @dtw_tb_rQuerycolnonj(orderWorkUserDefinedTable, "WUFLDR"), V_WUFLDR)
                  %else
                      @dtw_assign(V_WUFLDD, "")
                      @dtw_assign(V_WUFLDV, "")
                      @dtw_assign(V_WUFLDR, "")
                  %endif

                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(userEdtVar, "")
                      %else
                          %if (ux == "1")
                              @EdtVarErr(profileHandle, typeValue, edtVar)
                              @ErrVarErr(profileHandle, typeError, errVar)
                          %endif
                          @dtw_assign(catFld, V_UFFLDN)
                          %while(@dtw_rlength(catFld) != "6")
                              {@dtw_insert("@", catFld, @dtw_rlength(catFld), catFld) %}
                          @DecatErr_Field("$(catFld)", "$(V_UFFLDN)")
                          @dtw_concat("Err_", "$(V_UFFLDN)", errFldName)
                          @dtw_assign(errFldName, fieldValue)
                      %endif

                      @Decat_Field("$(catFld)")
                      %if (V_UFTYPE == "A" || V_UFTYPE == "C")
                          @dtw_assign(V_WUFLDV, fieldValue)
                      %elif (V_UFTYPE == "N")
                          @dtw_assign(V_WUFLDN, fieldValue)
                          @dtw_multiply(V_WUFLDN, "1", "21", V_WUFLDN)
                      %elif (V_UFTYPE == "D")
                          @dtw_assign(V_WUFLDD, fieldValue)
                      %endif
                  %else
                      %if (V_UFTYPE == "N")
                          @dtw_assign(Precision, @dtw_radd(V_UFSIZE, V_UFDECM))
                          @dtw_assign(V_WUFLDN, @dtw_rformat(V_WUFLDR, V_UFSIZE, V_UFDECM, "", "", Precision))
                          @dtw_assign(V_WUFLDN, @dtw_rstrip(V_WUFLDN))
                      %elif (V_UFTYPE == "D")
                          @DateInputFromISO("$(V_WUFLDD)", V_WUFLDD)
                      %endif
                  %endif

                  @SetTextOvr(errFldName)
       	          <tr><td class="dsphdr"><span $(textOvr)>$(V_UFDESC)</span></td>
                          %if (V_UFTYPE == "A")
                              <td class="inputalph"><input type="text" name="$(V_UFFLDN)" value="$(V_WUFLDV)" size="$(V_UFSIZE)" maxlength="$(V_UFSIZE)">
                          %elif (V_UFTYPE == "C")
                              <td>%if ("$(V_WUFLDV)" != "")
                                      <textarea name="$(V_UFFLDN)" ROWS=$(V_UFBOXS) COLS=60 onkeyup="checkCmtLength(this.value)" onkeypress="checkCmtLength(this.value)">$(V_WUFLDV)</textarea>
                                  %else
            	                       <textarea name="$(V_UFFLDN)" ROWS=$(V_UFBOXS) COLS=60 onkeyup="checkCmtLength(this.value)" onkeypress="checkCmtLength(this.value)"></textarea>
                                  %endif
                          %elif (V_UFTYPE == "N")
                              @dtw_add(V_UFSIZE, V_UFDECM, V_UFSIZE)
                              %if (V_UFDECM != "0")
                                  @dtw_add(V_UFSIZE, "2", V_UFSIZE)
                              %endif
                              <td class="inputnmbr"><input type="text" name="$(V_UFFLDN)" value="$(V_WUFLDN)" size="$(V_UFSIZE)" maxlength="$(V_UFSIZE)">
                          %elif (V_UFTYPE == "D")
                              <td class="inputnmbr"><input type="text" name="$(V_UFFLDN)" value="$(V_WUFLDD)" size="6" maxlength="6">
                                   %if (V_UFVLDV != "Y")
                                       <a href="javascript:calWindow('$(V_UFFLDN)');">$(calendarImage)</a>
                                   %endif
                          %endif
                          %if (V_UFVALU == "Y" || V_UFVLDV == "Y")
                              <a href="$(homeURL)$(phpPath)UserDefinedSearch.php$(altVarBase)&amp;docName=Chg&amp;fileName=$(fileName)&amp;fldName=$(V_UFFLDN)&amp;fldType=$(V_UFTYPE)&amp;fldDesc=$(V_UFDESC)" onclick="$(searchWinVar)"> $(searchImage) </a>
                          %endif
                          %if (V_UFREQF == "Y")
                              $(reqFieldChar)
                          %endif
                      </td>
                  </tr>
                  @DspErrMsg(errFldName)
                  @dtw_add(ux, "1", ux)
              %}
      </table>
      %if (focusField != "")
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      %endif
      </form>
      @dtw_assign(errFound, "")
      <div>
          <a href="javascript:check(document.Chg)">$(acceptImageLrg)</a>
          <a href="$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)">$(selectResetImage)</a>
      </div>
      %INCLUDE "EndTabs.icl"
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(10)    userProfile,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HOEUHU_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "OrderEntryRetInfo.icl"
  @OrderUserDefined_Query(fileName, orderControlNumber, orderUserDefinedTable)	
  @OrderWorkUserDefined_Query(orderControlNumber, orderWorkUserDefinedTable)	
  @Set_SQL(stmtSQL)
  %}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "OrderEntryRetInfo.icl"
  @OrderUserDefined_Query(fileName, orderControlNumber, orderUserDefinedTable)	
  @OrderWorkUserDefined_Query(orderControlNumber, orderWorkUserDefinedTable)	
  @Set_SQL(stmtSQL)
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @dtw_assign(edtVar, "")
  @Concat_Field("@@octl", orderControlNumber)

  @OrderUserDefined_Query(fileName, orderControlNumber, orderUserDefinedTable)	

  @dtw_tb_rows(orderUserDefinedTable, userMaxRows)
  @dtw_assign(ux, "1")
  %while(ux <= userMaxRows){
      @dtw_tb_getv(orderUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderUserDefinedTable, "UFFLDN"), V_UFFLDN)
      @dtw_tb_getv(orderUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderUserDefinedTable, "UFTYPE"), V_UFTYPE)
      @dtw_assign(UFFLDN, $(V_UFFLDN))
      @dtw_assign(outField, $($(UFFLDN)))
      %if (V_UFTYPE == "A" || V_UFTYPE == "C")
          @dtw_tb_getv(orderUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderUserDefinedTable, "UFUPPR"), V_UFUPPR)
          %if (V_UFUPPR == "Y")
              @dtw_mUPPERCASE(outField)
          %endif
      %elif (V_UFTYPE == "N")
          @dtw_tb_getv(orderUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderUserDefinedTable, "UFSIZE"), V_UFSIZE)
          @dtw_tb_getv(orderUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderUserDefinedTable, "UFDECM"), V_UFDECM)
          @Build_User_Number(outField, V_UFSIZE, V_UFDECM, outField)
      %endif
      %while(@dtw_rlength(V_UFFLDN) != "6")
          {@dtw_insert("@", V_UFFLDN, @dtw_rlength(V_UFFLDN), V_UFFLDN) %}
      @dtw_concat(edtVar, @dtw_rconcat("}{$(V_UFFLDN)", $(outField)), edtVar)
      @dtw_add(ux, "1", ux)
  %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(userProfile, errFound, edtVar, errVar)

  %if (errFound == "")
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)&amp;confUpdate=Y">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}