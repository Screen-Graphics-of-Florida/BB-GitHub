%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Specification Search"
  d2wName                 = "SpecificationSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;lineNumber=@dtw_rurlescseq(lineNumber)&amp;headerTrailer=@dtw_rurlescseq(headerTrailer)&amp;commentType=@dtw_rurlescseq(commentType)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;purchaseOrder=@dtw_rurlescseq(purchaseOrder)&amp;orderControl=@dtw_rurlescseq(orderControl)&amp;vendorNumber=@dtw_rurlescseq(vendorNumber)&amp;vendorName=@dtw_rurlescseq(vendorName)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;itemDescription=@dtw_rurlescseq(itemDescription)&amp;documentType=@dtw_rurlescseq(documentType)&amp;docDescription=@dtw_rurlescseq(docDescription)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
  customerIDNumber        = ""
  medIcon                 = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select SHSPEC, SHDESC, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(SHDESC) as SHDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " HDSPCH ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, " SHSPEC<>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Spec_Search_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
     </body>
  </html>
%}

%FUNCTION(dtw_sql) Spec_Search_Query (IN CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(displayCloseIcon, "Y")
      %INCLUDE "PageTitle.icl"

      <table $(contentTable)>
          %if (vendorNumber > "0")
              @Format_Header("Vendor", $(vendorName), $(vendorNumber))
          %else
              @Format_Header("Customer", $(customerName), $(customerNumber))
          %endif
          @Format_Header("Document", $(docDescription), $(documentType))
          %if (itemNumber != "")
              @Format_Header("Item", $(itemDescription), $(itemNumber))
          %endif
      </table>

      $(searchhrTagAttr)

      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr"> Specification </th>
                  <th class="colhdr"> Description </th>
              </tr>
              <tr><td align=center><input type="text" class="inputalph" name="srchSpec" size="15" maxlength="15">
                      <input type="hidden" name="operSpec" value="LIKE">
                  </td>
                  <td><input type="text" class="inputalph" name="srchDesc" size="30" maxlength="30">
                      <input type="hidden" name="operDesc" value="LIKE">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
          <script TYPE="text/javascript">
              document.Search.srchSpec.focus();
          </script>
      </form>

      %INCLUDE "WildCardPage.icl"

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              @OrderBy_Sort("SHSPEC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=document" title="Sequence By Specification"> Specification</a></th>
              @OrderBy_Sort("SHDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=description" title="Sequence By Description, Specification"> Description</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)$(d2wName)/SELECT$(d2wVarBase)&amp;fromSpecification=@dtw_rurlescseq(V_SHSPEC)&amp;commentFile=HDSPCD" title="Select Specifications">$(V_SHSPEC)</a></td>
                  <td class="colalph">$(V_SHDESC)</td>
                  <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/VIEW$(d2wVarBase)&amp;fromSpecification=@dtw_rurlescseq(V_SHSPEC)&amp;fromSpecDesc=@dtw_rurlescseq(V_SHDESC)&amp;commentFile=HDSPCD" title="View Specifications">$(moreInfoImage)</a></td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}
%MACRO_FUNCTION Display_Specifications () {	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(contentTable)>
              <tr valign="top">
                  <td>
                      @Get_Specifications(profileHandle, dataBaseID, fromSpecification, comment)
                      <table $(contentTable)>
                          <tr><td><h1>$(page_title)</h1></td>
                              <td class="toolbar">
                                  <a href="$(homeURL)$(cGIPath)$(d2wName)/SELECT$(d2wVarBase)&amp;fromSpecification=@dtw_rurlescseq(fromSpecification)&amp;commentFile=@dtw_rurlescseq(commentFile)" title="Select Specifications">$(copyImageLrg)</a>
                                  %INCLUDE "CloseWindow.icl"
                              </td>
                          </tr>
                      </table>
                      <table $(contentTable)>
                          @Format_Header("Customer", $(customerName), $(customerNumber))
                          @Format_Header("Document", $(docDescription), $(documentType))
                          %if (itemNumber != "")
                              @Format_Header("Item", $(itemDescription), $(itemNumber))
                          %endif
                      </table>

                      <table $(contentTable)>
                          <tr align="center"><td><h2>$(fromSpecDesc)</h2></td></tr>
                          <tr><td><textarea ROWS=20 COLS=60 WRAP="hard">$(comment)</textarea></td></tr>
                      </table>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(DTW_directcall) Get_Specifications (INOUT CHAR(64)    profileHandle,
				   		     CHAR(2)     dataBaseID,
    				                     CHAR(15)    fromSpecification,
    				                     char(32000) comment)

{%EXEC {HHDSPC_P.PGM %}
%}

%FUNCTION(DTW_directcall) Select_Comments (INOUT   CHAR(64)    profileHandle,
				      		    CHAR(2)     dataBaseID,
				                    CHAR(10)    commentFile,
				                    CHAR(3)     fromDocument,
				                    CHAR(3)     documentType,
				      		    DEC(7,0)    customerNumber,
				      		    DEC(8,0)    orderControlNumber,
				      		    CHAR(15)    fromSpecification,
				      		    DEC(3,0)    lineNumber)

{%EXEC {HOECMS_W.PGM %}
%}

%HTML(VIEW) {
  %INCLUDE "setLibraryList.icl"
  @Display_Specifications ()
%}

%HTML(SELECT){
  %INCLUDE "setLibraryList.icl"
  %if (vendorNumber > "0")
      <script TYPE="text/javascript">
          opener.location.href='$(homeURL)$(phpPath)POCommentMaintain.php$(altVarBase)&tag=MAINTAIN&fromTable=HDSPCD&cmtLine=@dtw_rurlescseq(lineNumber)&specification=@dtw_rurlescseq(fromSpecification)&purchaseOrder=@dtw_rurlescseq(purchaseOrder)&orderControl=@dtw_rurlescseq(orderControl)&vendorNumber=@dtw_rurlescseq(vendorNumber)&vendorName=@dtw_rurlescseq(vendorName)&itemNumber=@dtw_rurlescseq(itemNumber)&itemDesc=@dtw_rurlescseq(itemDescription)&doct=@dtw_rurlescseq(documentType)';
          window.close()
      </script>
  %else
      @Select_Comments(profileHandle, dataBaseID, commentFile, fromDocument, documentType, customerNumber, orderControlNumber, fromSpecification, lineNumber)
      <script TYPE="text/javascript">
          opener.location.href=opener.location.href;
          window.close()
      </script>
  %endif

%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "SHDESCU,SHSPEC")
      @DTW_ASSIGN(orderByDisplay, "Description, Specification")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "document")
      %if (orderBy == "SHSPEC")
          @DTW_ASSIGN(orderBy, "SHSPEC DESC")
          @DTW_ASSIGN(orderByDisplay, "Specification (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SHSPEC")
          @DTW_ASSIGN(orderByDisplay, "Specification")
      %endif
  %elif (sequence == "description")
      %if (orderBy == "SHDESCU,SHSPEC")
          @DTW_ASSIGN(orderBy, "SHDESCU DESC,SHSPEC")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Specification")
      %else
          @DTW_ASSIGN(orderBy, "SHDESCU,SHSPEC")
          @DTW_ASSIGN(orderByDisplay, "Description, Specification")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("SHSPEC", "Specification", $(srchSpec), "U", operSpec, "A")
  @Build_WildCard ("upper(SHDESC)", "Description", $(srchDesc), "U", operDesc, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}