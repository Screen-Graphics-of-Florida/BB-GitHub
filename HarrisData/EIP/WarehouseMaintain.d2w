%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"

%Define {
  page_title 	           = "Warehouse Maintenance"
  d2wName                 = "WarehouseMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromSel=@dtw_rurlescseq(fromSel)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;warehouseName=@dtw_rurlescseq(warehouseName)&amp;maintenanceCode=D"
  programName             = "HHDWHU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  V_COUVGL                = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (maintenanceCode == "A")
      @dtw_assign(userPass, "Y")
  %else
      @WarehouseUserView(profileHandle, dataBaseID, userPass, warehouseNumber)
  %endif
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      @RtvFldDesc("COUVGL<>' '", "POCTRL", "COUVGL", V_COUVGL)
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  function validate(chgForm) {
                      if (document.Chg.warehouseNumber.value =="" ||
                          document.Chg.warehouseName.value =="" ||
                          document.Chg.addressLineOne.value =="" ||
                          document.Chg.city.value =="")
                             {alert("$(reqFieldError)"); return false;}
                      if (editNum(document.Chg.warehouseNumber, 3, 0) &&
                          editNum(document.Chg.schedule, 3, 0) &&
                          editNum(document.Chg.companyNumber, 2, 0) &&
                          editNum(document.Chg.facilityNumber, 4, 0) &&
                          editNum(document.Chg.transferCostVarAcctNbr, 4, 0) &&
                          editNum(document.Chg.transferCostVarSubNbr, 4, 0) &&
                          editNum(document.Chg.acceptancePctA, 2, 1) &&
                          editNum(document.Chg.acceptancePctB, 2, 1) &&
                          editNum(document.Chg.acceptancePctC, 2, 1) &&
                          editNum(document.Chg.cycleDaysA, 5, 0) &&
                          editNum(document.Chg.cycleDaysB, 5, 0) &&
                          editNum(document.Chg.cycleDaysC, 5, 0) &&
                          editNum(document.Chg.percentageA, 2, 0) &&
                          editNum(document.Chg.percentageB, 2, 0) 
                          %if (V_HDPORL > "0")
                          && editNum(document.Chg.unvReceiptsExpAcctNbr, 4, 0) &&
                          editNum(document.Chg.unvReceiptsExpSubNbr, 4, 0) &&
                          editNum(document.Chg.standardVarAcctNbr, 4, 0) &&
                          editNum(document.Chg.standardVarSubNbr, 4, 0) &&
                          editNum(document.Chg.freightExpenseAcctNbr, 4, 0) &&
                          editNum(document.Chg.freightExpenseSubNbr, 4, 0) &&
                          editNum(document.Chg.freightVarianceAcctNbr, 4, 0) &&
                          editNum(document.Chg.freightVarianceSubNbr, 4, 0) &&
                          editNum(document.Chg.taxExpenseAcctNbr, 4, 0) &&
                          editNum(document.Chg.taxExpenseSubNbr, 4, 0) &&
                          editNum(document.Chg.taxVarianceAcctNbr, 4, 0) &&
                          editNum(document.Chg.taxVarianceSubNbr, 4, 0) &&
                          editNum(document.Chg.specialChgExpAcctNbr, 4, 0) &&
                          editNum(document.Chg.specialChgExpSubNbr, 4, 0) &&
                          editNum(document.Chg.specialChgVarAcctNbr, 4, 0) &&
                          editNum(document.Chg.specialChgVarSubNbr, 4, 0) &&
                          editNum(document.Chg.misc1ExpenseAcctNbr, 4, 0) &&
                          editNum(document.Chg.misc1ExpenseSubNbr, 4, 0) &&
                          editNum(document.Chg.misc1VarianceAcctNbr, 4, 0) &&
                          editNum(document.Chg.misc1VarianceSubNbr, 4, 0) &&
                          editNum(document.Chg.misc2ExpenseAcctNbr, 4, 0) &&
                          editNum(document.Chg.misc2ExpenseSubNbr, 4, 0) &&
                          editNum(document.Chg.misc2VarianceAcctNbr, 4, 0) &&
                          editNum(document.Chg.misc2VarianceSubNbr, 4, 0) &&
                          editNum(document.Chg.misc3ExpenseAcctNbr, 4, 0) &&
                          editNum(document.Chg.misc3ExpenseSubNbr, 4, 0) &&
                          editNum(document.Chg.misc3VarianceAcctNbr, 4, 0) &&
                          editNum(document.Chg.misc3VarianceSubNbr, 4, 0) &&
                          editNum(document.Chg.misc4ExpenseAcctNbr, 4, 0) &&
                          editNum(document.Chg.misc4ExpenseSubNbr, 4, 0) &&
                          editNum(document.Chg.misc4VarianceAcctNbr, 4, 0) &&
                          editNum(document.Chg.misc4VarianceSubNbr, 4, 0) &&
                          editNum(document.Chg.misc5ExpenseAcctNbr, 4, 0) &&
                          editNum(document.Chg.misc5ExpenseSubNbr, 4, 0) &&
                          editNum(document.Chg.misc5VarianceAcctNbr, 4, 0) &&
                          editNum(document.Chg.misc5VarianceSubNbr, 4, 0) &&
                          editNum(document.Chg.misc6ExpenseAcctNbr, 4, 0) &&
                          editNum(document.Chg.misc6ExpenseSubNbr, 4, 0) &&
                          editNum(document.Chg.misc6VarianceAcctNbr, 4, 0) &&
                          editNum(document.Chg.misc6VarianceSubNbr, 4, 0)
                          %endif
                          )
                          return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
	           %INCLUDE "numedit.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "WAREHOUSEMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "Select * From HDWHSM Where WHWHS = $(warehouseNumber)", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
  %}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
		                       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (fromSel == "Y")
          @dtw_assign(backURL, "$(homeURL)$(cGIPath)WarehouseSelect.d2w/REPORT$(genericVarBase)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;warehouseName=@dtw_rurlescseq(warehouseName)")
      %else
          @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
          %if (backURL == "")
              @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=163")
          %endif
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>

              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "warehouseNumber")
                      %else
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @dtw_assign(focusField, "")
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@whs@", "warehouseNumber")        @dtw_assign(Err_WHWHS,  fieldValue)
                          @DecatErr_Field("@@co#@", "companyNumber")          @dtw_assign(Err_WHCO#,  fieldValue)
                          @DecatErr_Field("@@fac#", "facilityNumber")         @dtw_assign(Err_WHFAC#, fieldValue)
                          @DecatErr_Field("@@whnm", "warehouseName")          @dtw_assign(Err_WHWHNM, fieldValue)
                          @DecatErr_Field("@@alph", "alphaSequence")          @dtw_assign(Err_WHALPH, fieldValue)
                          @DecatErr_Field("@@whad", "addressLineOne")         @dtw_assign(Err_WHWHAD, fieldValue)
                          @DecatErr_Field("@@wha2", "addressLineTwo")         @dtw_assign(Err_WHWHA2, fieldValue)
                          @DecatErr_Field("@@whct", "city")                   @dtw_assign(Err_WHWHCT, fieldValue)
                          @DecatErr_Field("@@whst", "state")                  @dtw_assign(Err_WHWHST, fieldValue)
                          @DecatErr_Field("@@hwzp", "zip")                    @dtw_assign(Err_WHHWZP, fieldValue)
                          @DecatErr_Field("@@ctry", "country")                @dtw_assign(Err_WHCTRY, fieldValue)
                          @DecatErr_Field("@@pseg", "pageSegmentName")        @dtw_assign(Err_WHPSEG, fieldValue)
                          @DecatErr_Field("@@schd", "schedule")               @dtw_assign(Err_WHSCHD, fieldValue)
                          @DecatErr_Field("@@tcva", "transferCostVarAcctNbr") @dtw_assign(Err_WHTCVA, fieldValue)
                          @DecatErr_Field("@@tcvs", "transferCostVarSubNbr")  @dtw_assign(Err_WHTCVS, fieldValue)
                          @DecatErr_Field("@@stkl", "stockLocatorActive")     @dtw_assign(Err_WHSTKL, fieldValue)
                          @DecatErr_Field("@@acs@", "autoUpdateItemStock")    @dtw_assign(Err_WHACS,  fieldValue)
                          @DecatErr_Field("@@mrpn", "mrpNetableWarehouse")    @dtw_assign(Err_WHMRPN, fieldValue)
                          @DecatErr_Field("@@abci", "abcAnalysis")            @dtw_assign(Err_WHABCI, fieldValue)
                          @DecatErr_Field("@@vla@", "acceptancePctA")         @dtw_assign(Err_WHVLA,  fieldValue)
                          @DecatErr_Field("@@vlb@", "acceptancePctB")         @dtw_assign(Err_WHVLB,  fieldValue)
                          @DecatErr_Field("@@vlc@", "acceptancePctC")         @dtw_assign(Err_WHVLC,  fieldValue)
                          @DecatErr_Field("@@caw@", "cycleDaysA")             @dtw_assign(Err_WHCAW,  fieldValue)
                          @DecatErr_Field("@@cbw@", "cycleDaysB")             @dtw_assign(Err_WHCBW,  fieldValue)
                          @DecatErr_Field("@@ccw@", "cycleDaysC")             @dtw_assign(Err_WHCCW,  fieldValue)
                          @DecatErr_Field("@@pca@", "percentageA")            @dtw_assign(Err_WHPCA,  fieldValue)
                          @DecatErr_Field("@@pcb@", "percentageB")            @dtw_assign(Err_WHPCB,  fieldValue)
                          @DecatErr_Field("@@uvra", "unvReceiptsExpAcctNbr")  @dtw_assign(Err_WHUVRA, fieldValue)
                          @DecatErr_Field("@@uvrs", "unvReceiptsExpSubNbr")   @dtw_assign(Err_WHUVRS, fieldValue)
                          @DecatErr_Field("@@prva", "standardVarAcctNbr")     @dtw_assign(Err_WHPRVA, fieldValue)
                          @DecatErr_Field("@@prvs", "standardVarSubNbr")      @dtw_assign(Err_WHPRVS, fieldValue)
                          @DecatErr_Field("@@fgha", "freightExpenseAcctNbr")  @dtw_assign(Err_WHFGHA, fieldValue)
                          @DecatErr_Field("@@fghs", "freightExpenseSubNbr")   @dtw_assign(Err_WHFGHS, fieldValue)
                          @DecatErr_Field("@@fgva", "freightVarianceAcctNbr") @dtw_assign(Err_WHFGVA, fieldValue)
                          @DecatErr_Field("@@fgvs", "freightVarianceSubNbr")  @dtw_assign(Err_WHFGVS, fieldValue)
                          @DecatErr_Field("@@slta", "taxExpenseAcctNbr")      @dtw_assign(Err_WHSLTA, fieldValue)
                          @DecatErr_Field("@@slts", "taxExpenseSubNbr")       @dtw_assign(Err_WHSLTS, fieldValue)
                          @DecatErr_Field("@@stva", "taxVarianceAcctNbr")     @dtw_assign(Err_WHSTVA, fieldValue)
                          @DecatErr_Field("@@stvs", "taxVarianceSubNbr")      @dtw_assign(Err_WHSTVS, fieldValue)
                          @DecatErr_Field("@@spga", "specialChgExpAcctNbr")   @dtw_assign(Err_WHSPGA, fieldValue)
                          @DecatErr_Field("@@spcs", "specialChgExpSubNbr")    @dtw_assign(Err_WHSPCS, fieldValue)
                          @DecatErr_Field("@@scva", "specialChgVarAcctNbr")   @dtw_assign(Err_WHSCVA, fieldValue)
                          @DecatErr_Field("@@scvs", "specialChgVarSubNbr")    @dtw_assign(Err_WHSCVS, fieldValue)
                          @DecatErr_Field("@@mc1a", "misc1ExpenseAcctNbr")    @dtw_assign(Err_WHMC1A, fieldValue)
                          @DecatErr_Field("@@mc1s", "misc1ExpenseSubNbr")     @dtw_assign(Err_WHMC1S, fieldValue)
                          @DecatErr_Field("@@mv1a", "misc1VarianceAcctNbr")   @dtw_assign(Err_WHMV1A, fieldValue)
                          @DecatErr_Field("@@mv1s", "misc1VarianceSubNbr")    @dtw_assign(Err_WHMV1S, fieldValue)
                          @DecatErr_Field("@@mc2a", "misc2ExpenseAcctNbr")    @dtw_assign(Err_WHMC2A, fieldValue)
                          @DecatErr_Field("@@mc2s", "misc2ExpenseSubNbr")     @dtw_assign(Err_WHMC2S, fieldValue)
                          @DecatErr_Field("@@mv2a", "misc2VarianceAcctNbr")   @dtw_assign(Err_WHMV2A, fieldValue)
                          @DecatErr_Field("@@mv2s", "misc2VarianceSubNbr")    @dtw_assign(Err_WHMV2S, fieldValue)
                          @DecatErr_Field("@@mc3a", "misc3ExpenseAcctNbr")    @dtw_assign(Err_WHMC3A, fieldValue)
                          @DecatErr_Field("@@mc3s", "misc3ExpenseSubNbr")     @dtw_assign(Err_WHMC3S, fieldValue)
                          @DecatErr_Field("@@mv3a", "misc3VarianceAcctNbr")   @dtw_assign(Err_WHMV3A, fieldValue)
                          @DecatErr_Field("@@mv3s", "misc3VarianceSubNbr")    @dtw_assign(Err_WHMV3S, fieldValue)
                          @DecatErr_Field("@@mc4a", "misc4ExpenseAcctNbr")    @dtw_assign(Err_WHMC4A, fieldValue)
                          @DecatErr_Field("@@mc4s", "misc4ExpenseSubNbr")     @dtw_assign(Err_WHMC4S, fieldValue)
                          @DecatErr_Field("@@mv4a", "misc4VarianceAcctNbr")   @dtw_assign(Err_WHMV4A, fieldValue)
                          @DecatErr_Field("@@mv4s", "misc4VarianceSubNbr")    @dtw_assign(Err_WHMV4S, fieldValue)
                          @DecatErr_Field("@@mc5a", "misc5ExpenseAcctNbr")    @dtw_assign(Err_WHMC5A, fieldValue)
                          @DecatErr_Field("@@mc5s", "misc5ExpenseSubNbr")     @dtw_assign(Err_WHMC5S, fieldValue)
                          @DecatErr_Field("@@mv5a", "misc5VarianceAcctNbr")   @dtw_assign(Err_WHMV5A, fieldValue)
                          @DecatErr_Field("@@mv5s", "misc5VarianceSubNbr")    @dtw_assign(Err_WHMV5S, fieldValue)
                          @DecatErr_Field("@@mc6a", "misc6ExpenseAcctNbr")    @dtw_assign(Err_WHMC6A, fieldValue)
                          @DecatErr_Field("@@mc6s", "misc6ExpenseSubNbr")     @dtw_assign(Err_WHMC6S, fieldValue)
                          @DecatErr_Field("@@mv6a", "misc6VarianceAcctNbr")   @dtw_assign(Err_WHMV6A, fieldValue)
                          @DecatErr_Field("@@mv6s", "misc6VarianceSubNbr")    @dtw_assign(Err_WHMV6S, fieldValue)
                      %endif

                      @Decat_Field("@@whs@")   @dtw_assign(V_WHWHS,  fieldValue)
                      @Decat_Field("@@co#@")   @dtw_assign(V_WHCO#,  fieldValue)
                      @Decat_Field("@@fac#")   @dtw_assign(V_WHFAC#, fieldValue)
                      @Decat_Field("@@whnm")   @dtw_assign(V_WHWHNM, fieldValue)
                      @Decat_Field("@@alph")   @dtw_assign(V_WHALPH, fieldValue)
                      @Decat_Field("@@whad")   @dtw_assign(V_WHWHAD, fieldValue)
                      @Decat_Field("@@wha2")   @dtw_assign(V_WHWHA2, fieldValue)
                      @Decat_Field("@@whct")   @dtw_assign(V_WHWHCT, fieldValue)
                      @Decat_Field("@@whst")   @dtw_assign(V_WHWHST, fieldValue)
                      @Decat_Field("@@hwzp")   @dtw_assign(V_WHHWZP, fieldValue)
                      @Decat_Field("@@ctry")   @dtw_assign(V_WHCTRY, fieldValue)
                      @Decat_Field("@@pseg")   @dtw_assign(V_WHPSEG, fieldValue)
                      @Decat_Field("@@schd")   @dtw_assign(V_WHSCHD, fieldValue)
                      @Decat_Field("@@tcva")   @dtw_assign(V_WHTCVA, fieldValue)
                      @Decat_Field("@@tcvs")   @dtw_assign(V_WHTCVS, fieldValue)
                      @Decat_Field("@@stkl")   @dtw_assign(V_WHSTKL, fieldValue)
                      @Decat_Field("@@acs@")   @dtw_assign(V_WHACS,  fieldValue)
                      @Decat_Field("@@mrpn")   @dtw_assign(V_WHMRPN, fieldValue)
                      @Decat_Field("@@abci")   @dtw_assign(V_WHABCI, fieldValue)
                      @Decat_Field("@@vla@")   @dtw_assign(V_WHVLA,  fieldValue)
                      @Decat_Field("@@vlb@")   @dtw_assign(V_WHVLB,  fieldValue)
                      @Decat_Field("@@vlc@")   @dtw_assign(V_WHVLC,  fieldValue)
                      @Decat_Field("@@caw@")   @dtw_assign(V_WHCAW,  fieldValue)
                      @Decat_Field("@@cbw@")   @dtw_assign(V_WHCBW,  fieldValue)
                      @Decat_Field("@@ccw@")   @dtw_assign(V_WHCCW,  fieldValue)
                      @Decat_Field("@@pca@")   @dtw_assign(V_WHPCA,  fieldValue)
                      @Decat_Field("@@pcb@")   @dtw_assign(V_WHPCB,  fieldValue)
                      @Decat_Field("@@uvra")   @dtw_assign(V_WHUVRA, fieldValue)
                      @Decat_Field("@@uvrs")   @dtw_assign(V_WHUVRS, fieldValue)
                      @Decat_Field("@@prva")   @dtw_assign(V_WHPRVA, fieldValue)
                      @Decat_Field("@@prvs")   @dtw_assign(V_WHPRVS, fieldValue)
                      @Decat_Field("@@fgha")   @dtw_assign(V_WHFGHA, fieldValue)
                      @Decat_Field("@@fghs")   @dtw_assign(V_WHFGHS, fieldValue)
                      @Decat_Field("@@fgva")   @dtw_assign(V_WHFGVA, fieldValue)
                      @Decat_Field("@@fgvs")   @dtw_assign(V_WHFGVS, fieldValue)
                      @Decat_Field("@@slta")   @dtw_assign(V_WHSLTA, fieldValue)
                      @Decat_Field("@@slts")   @dtw_assign(V_WHSLTS, fieldValue)
                      @Decat_Field("@@stva")   @dtw_assign(V_WHSTVA, fieldValue)
                      @Decat_Field("@@stvs")   @dtw_assign(V_WHSTVS, fieldValue)
                      @Decat_Field("@@spga")   @dtw_assign(V_WHSPGA, fieldValue)
                      @Decat_Field("@@spcs")   @dtw_assign(V_WHSPCS, fieldValue)
                      @Decat_Field("@@scva")   @dtw_assign(V_WHSCVA, fieldValue)
                      @Decat_Field("@@scvs")   @dtw_assign(V_WHSCVS, fieldValue)
                      @Decat_Field("@@mc1a")   @dtw_assign(V_WHMC1A, fieldValue)
                      @Decat_Field("@@mc1s")   @dtw_assign(V_WHMC1S, fieldValue)
                      @Decat_Field("@@mv1a")   @dtw_assign(V_WHMV1A, fieldValue)
                      @Decat_Field("@@mv1s")   @dtw_assign(V_WHMV1S, fieldValue)
                      @Decat_Field("@@mc2a")   @dtw_assign(V_WHMC2A, fieldValue)
                      @Decat_Field("@@mc2s")   @dtw_assign(V_WHMC2S, fieldValue)
                      @Decat_Field("@@mv2a")   @dtw_assign(V_WHMV2A, fieldValue)
                      @Decat_Field("@@mv2s")   @dtw_assign(V_WHMV2S, fieldValue)
                      @Decat_Field("@@mc3a")   @dtw_assign(V_WHMC3A, fieldValue)
                      @Decat_Field("@@mc3s")   @dtw_assign(V_WHMC3S, fieldValue)
                      @Decat_Field("@@mv3a")   @dtw_assign(V_WHMV3A, fieldValue)
                      @Decat_Field("@@mv3s")   @dtw_assign(V_WHMV3S, fieldValue)
                      @Decat_Field("@@mc4a")   @dtw_assign(V_WHMC4A, fieldValue)
                      @Decat_Field("@@mc4s")   @dtw_assign(V_WHMC4S, fieldValue)
                      @Decat_Field("@@mv4a")   @dtw_assign(V_WHMV4A, fieldValue)
                      @Decat_Field("@@mv4s")   @dtw_assign(V_WHMV4S, fieldValue)
                      @Decat_Field("@@mc5a")   @dtw_assign(V_WHMC5A, fieldValue)
                      @Decat_Field("@@mc5s")   @dtw_assign(V_WHMC5S, fieldValue)
                      @Decat_Field("@@mv5a")   @dtw_assign(V_WHMV5A, fieldValue)
                      @Decat_Field("@@mv5s")   @dtw_assign(V_WHMV5S, fieldValue)
                      @Decat_Field("@@mc6a")   @dtw_assign(V_WHMC6A, fieldValue)
                      @Decat_Field("@@mc6s")   @dtw_assign(V_WHMC6S, fieldValue)
                      @Decat_Field("@@mv6a")   @dtw_assign(V_WHMV6A, fieldValue)
                      @Decat_Field("@@mv6s")   @dtw_assign(V_WHMV6S, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(V_WHCO#,  "00")
                          @dtw_assign(V_WHFAC#, "0000")
                          @dtw_assign(V_WHSCHD, "000")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "warehouseNumber")
                      @dtw_assign(V_WHWHS,  "")
                      @dtw_assign(V_WHVLA,  "@dtw_rformat(@dtw_rmultiply(V_WHVLA, "100"),"","1")")
                      @dtw_assign(V_WHVLB,  "@dtw_rformat(@dtw_rmultiply(V_WHVLB, "100"),"","1")")
                      @dtw_assign(V_WHVLC,  "@dtw_rformat(@dtw_rmultiply(V_WHVLC, "100"),"","1")")
                  %else
                      @dtw_assign(focusField, "companyNumber")
                      @dtw_assign(V_WHVLA,  "@dtw_rformat(@dtw_rmultiply(V_WHVLA, "100"),"","1")")
                      @dtw_assign(V_WHVLB,  "@dtw_rformat(@dtw_rmultiply(V_WHVLB, "100"),"","1")")
                      @dtw_assign(V_WHVLC,  "@dtw_rformat(@dtw_rmultiply(V_WHVLC, "100"),"","1")")
                  %endif

                  @SetTextOvr(Err_WHWHS)
