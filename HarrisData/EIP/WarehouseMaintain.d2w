                      @RtvFldDesc("CHACCT=$(V_WHMC3A) and CHSUB=$(V_WHMC3S) ", "HDCHRT", "CHCHDS", acctDesc)
                      @SetTextOvr(Err_WHMC3A)
                      <tr><td class="dsphdr"><span $(textOvr)>$(V_COSMC3) Expense Account</span></td>
                          <td class="inputnmbr"><input name="misc3ExpenseAcctNbr" value="$(V_WHMC3A)" type="text" size="4" maxlength="4">&nbsp;-&nbsp;<input name="misc3ExpenseSubNbr" value="$(V_WHMC3S)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=misc3ExpenseAcctNbr&amp;subFld=misc3ExpenseSubNbr&amp;descFld=misc3ExpenseAcctDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="misc3ExpenseAcctDesc" value="$(acctDesc)" type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_WHMC3A)
    			
                      @Default_Zero(V_WHMV3A)
                      @Default_Zero(V_WHMV3S)
                      @RtvFldDesc("CHACCT=$(V_WHMV3A) and CHSUB=$(V_WHMV3S) ", "HDCHRT", "CHCHDS", acctDesc)
                      @SetTextOvr(Err_WHMV3A)
                      <tr><td class="dsphdr"><span $(textOvr)>$(V_COSMC3) Variance Account</span></td>
                          <td class="inputnmbr"><input name="misc3VarianceAcctNbr" value="$(V_WHMV3A)" type="text" size="4" maxlength="4">&nbsp;-&nbsp;<input name="misc3VarianceSubNbr" value="$(V_WHMV3S)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=misc3VarianceAcctNbr&amp;subFld=misc3VarianceSubNbr&amp;descFld=misc3VarianceAcctDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="misc3VarianceAcctDesc" value="$(acctDesc)" type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_WHMV3A)
                  %endif	

                  %if (V_COSMC4 != "")	
                      @Default_Zero(V_WHMC4A)
                      @Default_Zero(V_WHMC4S)
                      @RtvFldDesc("CHACCT=$(V_WHMC4A) and CHSUB=$(V_WHMC4S) ", "HDCHRT", "CHCHDS", acctDesc)
                      @SetTextOvr(Err_WHMC4A)
                      <tr><td class="dsphdr"><span $(textOvr)>$(V_COSMC4) Expense Account</span></td>
                          <td class="inputnmbr"><input name="misc4ExpenseAcctNbr" value="$(V_WHMC4A)" type="text" size="4" maxlength="4">&nbsp;-&nbsp;<input name="misc4ExpenseSubNbr" value="$(V_WHMC4S)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=misc4ExpenseAcctNbr&amp;subFld=misc4ExpenseSubNbr&amp;descFld=misc4ExpenseAcctDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="misc4ExpenseAcctDesc" value="$(acctDesc)" type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_WHMC4A)
    			
                      @Default_Zero(V_WHMV4A)
                      @Default_Zero(V_WHMV4S)
                      @RtvFldDesc("CHACCT=$(V_WHMV4A) and CHSUB=$(V_WHMV4S) ", "HDCHRT", "CHCHDS", acctDesc)
                      @SetTextOvr(Err_WHMV4A)
                      <tr><td class="dsphdr"><span $(textOvr)>$(V_COSMC4) Variance Account</span></td>
                          <td class="inputnmbr"><input name="misc4VarianceAcctNbr" value="$(V_WHMV4A)" type="text" size="4" maxlength="4">&nbsp;-&nbsp;<input name="misc4VarianceSubNbr" value="$(V_WHMV4S)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=misc4VarianceAcctNbr&amp;subFld=misc4VarianceSubNbr&amp;descFld=misc4VarianceAcctDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="misc4VarianceAcctDesc" value="$(acctDesc)" type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_WHMV4A)
                  %endif	

                  %if (V_COSMC5 != "")	
                      @Default_Zero(V_WHMC5A)
                      @Default_Zero(V_WHMC5S)
                      @RtvFldDesc("CHACCT=$(V_WHMC5A) and CHSUB=$(V_WHMC5S) ", "HDCHRT", "CHCHDS", acctDesc)
                      @SetTextOvr(Err_WHMC5A)
                      <tr><td class="dsphdr"><span $(textOvr)>$(V_COSMC5) Expense Account</span></td>
                          <td class="inputnmbr"><input name="misc5ExpenseAcctNbr" value="$(V_WHMC5A)" type="text" size="4" maxlength="4">&nbsp;-&nbsp;<input name="misc5ExpenseSubNbr" value="$(V_WHMC5S)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=misc5ExpenseAcctNbr&amp;subFld=misc5ExpenseSubNbr&amp;descFld=misc5ExpenseAcctDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="misc5ExpenseAcctDesc" value="$(acctDesc)" type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_WHMC5A)
    			
                      @Default_Zero(V_WHMV5A)
                      @Default_Zero(V_WHMV5S)
                      @RtvFldDesc("CHACCT=$(V_WHMV5A) and CHSUB=$(V_WHMV5S) ", "HDCHRT", "CHCHDS", acctDesc)
                      @SetTextOvr(Err_WHMV5A)
                      <tr><td class="dsphdr"><span $(textOvr)>$(V_COSMC5) Variance Account</span></td>
                          <td class="inputnmbr"><input name="misc5VarianceAcctNbr" value="$(V_WHMV5A)" type="text" size="4" maxlength="4">&nbsp;-&nbsp;<input name="misc5VarianceSubNbr" value="$(V_WHMV5S)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=misc5VarianceAcctNbr&amp;subFld=misc5VarianceSubNbr&amp;descFld=misc5VarianceAcctDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="misc5VarianceAcctDesc" value="$(acctDesc)" type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_WHMV5A)
                  %endif	

                  %if (V_COSMC6 != "")	
                      @Default_Zero(V_WHMC6A)
                      @Default_Zero(V_WHMC6S)
                      @RtvFldDesc("CHACCT=$(V_WHMC6A) and CHSUB=$(V_WHMC6S) ", "HDCHRT", "CHCHDS", acctDesc)
                      @SetTextOvr(Err_WHMC6A)
                      <tr><td class="dsphdr"><span $(textOvr)>$(V_COSMC6) Expense Account</span></td>
                          <td class="inputnmbr"><input name="misc6ExpenseAcctNbr" value="$(V_WHMC6A)" type="text" size="4" maxlength="4">&nbsp;-&nbsp;<input name="misc6ExpenseSubNbr" value="$(V_WHMC6S)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=misc6ExpenseAcctNbr&amp;subFld=misc6ExpenseSubNbr&amp;descFld=misc6ExpenseAcctDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="misc6ExpenseAcctDesc" value="$(acctDesc)" type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_WHMC6A)
    			
                      @Default_Zero(V_WHMV6A)
                      @Default_Zero(V_WHMV6S)
                      @RtvFldDesc("CHACCT=$(V_WHMV6A) and CHSUB=$(V_WHMV6S) ", "HDCHRT", "CHCHDS", acctDesc)
                      @SetTextOvr(Err_WHMV6A)
                      <tr><td class="dsphdr"><span $(textOvr)>$(V_COSMC6) Variance Account</span></td>
                          <td class="inputnmbr"><input name="misc6VarianceAcctNbr" value="$(V_WHMV6A)" type="text" size="4" maxlength="4">&nbsp;-&nbsp;<input name="misc6VarianceSubNbr" value="$(V_WHMV6S)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=misc6VarianceAcctNbr&amp;subFld=misc6VarianceSubNbr&amp;descFld=misc6VarianceAcctDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="misc6VarianceAcctDesc" value="$(acctDesc)" type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_WHMV6A)
                  %endif
                  
               %endif
                  
	           %if (V_COSMC1=="" || V_COSMC2=="" || V_COSMC3=="" || V_COSMC4=="" || V_COSMC5=="" || V_COSMC6=="")	
                      <tr>
                  %endif
	           %if (V_COSMC1=="")	
                      <td><input name="misc1ExpenseAcctNbr"  type="hidden" value="$(V_WHMC1A)"><input name="misc1ExpenseSubNbr"  type="hidden" value="$(V_WHMC1S)"></td>
                      <td><input name="misc1VarianceAcctNbr" type="hidden" value="$(V_WHMV1A)"><input name="misc1VarianceSubNbr" type="hidden" value="$(V_WHMV1S)"></td>
                  %endif
	           %if (V_COSMC2=="")	
                      <td><input name="misc2ExpenseAcctNbr"  type="hidden" value="$(V_WHMC2A)"><input name="misc2ExpenseSubNbr"  type="hidden" value="$(V_WHMC2S)"></td>
                      <td><input name="misc2VarianceAcctNbr" type="hidden" value="$(V_WHMV2A)"><input name="misc2VarianceSubNbr" type="hidden" value="$(V_WHMV2S)"></td>
                  %endif
	           %if (V_COSMC3=="")	
                      <td><input name="misc3ExpenseAcctNbr"  type="hidden" value="$(V_WHMC3A)"><input name="misc3ExpenseSubNbr"  type="hidden" value="$(V_WHMC3S)"></td>
                      <td><input name="misc3VarianceAcctNbr" type="hidden" value="$(V_WHMV3A)"><input name="misc3VarianceSubNbr" type="hidden" value="$(V_WHMV3S)"></td>
                  %endif
	           %if (V_COSMC4=="")	
                      <td><input name="misc4ExpenseAcctNbr"  type="hidden" value="$(V_WHMC4A)"><input name="misc4ExpenseSubNbr"  type="hidden" value="$(V_WHMC4S)"></td>
                      <td><input name="misc4VarianceAcctNbr" type="hidden" value="$(V_WHMV4A)"><input name="misc4VarianceSubNbr" type="hidden" value="$(V_WHMV4S)"></td>
                  %endif
	           %if (V_COSMC5=="")	
                      <td><input name="misc5ExpenseAcctNbr"  type="hidden" value="$(V_WHMC5A)"><input name="misc5ExpenseSubNbr"  type="hidden" value="$(V_WHMC5S)"></td>
                      <td><input name="misc5VarianceAcctNbr" type="hidden" value="$(V_WHMV5A)"><input name="misc5VarianceSubNbr" type="hidden" value="$(V_WHMV5S)"></td>
                  %endif
	           %if (V_COSMC6=="")	
                      <td><input name="misc6ExpenseAcctNbr"  type="hidden" value="$(V_WHMC6A)"><input name="misc6ExpenseSubNbr"  type="hidden" value="$(V_WHMC6S)"></td>
                      <td><input name="misc6VarianceAcctNbr" type="hidden" value="$(V_WHMV6A)"><input name="misc6VarianceSubNbr" type="hidden" value="$(V_WHMV6S)"></td>
                  %endif
	           %if (V_COSMC1=="" || V_COSMC2=="" || V_COSMC3=="" || V_COSMC4=="" || V_COSMC5=="" || V_COSMC6=="")	
                      </tr>
                  %endif
              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDWHU_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @RtvFldDesc("COSMC1<>' '", "POCTRL", "COSMC1", V_COSMC1)
      @RtvFldDesc("COSMC2<>' '", "POCTRL", "COSMC2", V_COSMC2)
      @RtvFldDesc("COSMC3<>' '", "POCTRL", "COSMC3", V_COSMC3)
      @RtvFldDesc("COSMC4<>' '", "POCTRL", "COSMC4", V_COSMC4)
      @RtvFldDesc("COSMC5<>' '", "POCTRL", "COSMC5", V_COSMC5)
      @RtvFldDesc("COSMC6<>' '", "POCTRL", "COSMC6", V_COSMC6)

      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @yn02_Table_Query(profileHandle, dataBaseID, "YORN      ", yn02Table)
      @yn03_Table_Query(profileHandle, dataBaseID, "YORN      ", yn03Table)
      @yn04_Table_Query(profileHandle, dataBaseID, "YORN      ", yn04Table)

      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(alphaSequence)
  @dtw_mUPPERCASE(state)
  @dtw_mUPPERCASE(zip)
  @dtw_mUPPERCASE(country)
  @dtw_mUPPERCASE(pageSegmentName)

  @dtw_assign(warehouseNumber,@dtw_rstrip(warehouseNumber))
  @dtw_assign(companyNumber,@dtw_rstrip(companyNumber))
  @dtw_assign(facilityNumber,@dtw_rstrip(facilityNumber))
  @dtw_assign(transferCostVarAcctNbr,@dtw_rstrip(transferCostVarAcctNbr))
  @dtw_assign(transferCostVarSubNbr,@dtw_rstrip(transferCostVarSubNbr))
  @dtw_assign(acceptancePctA,@dtw_rstrip(acceptancePctA))
  @dtw_assign(acceptancePctB,@dtw_rstrip(acceptancePctB))
  @dtw_assign(acceptancePctC,@dtw_rstrip(acceptancePctC))
  @dtw_assign(cycleDaysA,@dtw_rstrip(cycleDaysA))
  @dtw_assign(cycleDaysB,@dtw_rstrip(cycleDaysB))
  @dtw_assign(cycleDaysC,@dtw_rstrip(cycleDaysC))
  @dtw_assign(percentageA,@dtw_rstrip(percentageA))
  @dtw_assign(percentageB,@dtw_rstrip(percentageB))
  @dtw_assign(unvReceiptsExpAcctNbr,@dtw_rstrip(unvReceiptsExpAcctNbr))
  @dtw_assign(unvReceiptsExpSubNbr,@dtw_rstrip(unvReceiptsExpSubNbr))
  @dtw_assign(standardVarAcctNbr,@dtw_rstrip(standardVarAcctNbr))
  @dtw_assign(standardVarSubNbr,@dtw_rstrip(standardVarSubNbr))
  @dtw_assign(freightExpenseAcctNbr,@dtw_rstrip(freightExpenseAcctNbr))
  @dtw_assign(freightExpenseSubNbr,@dtw_rstrip(freightExpenseSubNbr))
  @dtw_assign(freightVarianceAcctNbr,@dtw_rstrip(freightVarianceAcctNbr))
  @dtw_assign(freightVarianceSubNbr,@dtw_rstrip(freightVarianceSubNbr))
  @dtw_assign(taxExpenseAcctNbr,@dtw_rstrip(taxExpenseAcctNbr))
  @dtw_assign(taxExpenseSubNbr,@dtw_rstrip(taxExpenseSubNbr))
  @dtw_assign(taxVarianceAcctNbr,@dtw_rstrip(taxVarianceAcctNbr))
  @dtw_assign(taxVarianceSubNbr,@dtw_rstrip(taxVarianceSubNbr))
  @dtw_assign(specialChgExpAcctNbr,@dtw_rstrip(specialChgExpAcctNbr))
  @dtw_assign(specialChgExpSubNbr,@dtw_rstrip(specialChgExpSubNbr))
  @dtw_assign(specialChgVarAcctNbr,@dtw_rstrip(specialChgVarAcctNbr))
  @dtw_assign(specialChgVarSubNbr,@dtw_rstrip(specialChgVarSubNbr))
  @dtw_assign(misc1ExpenseAcctNbr,@dtw_rstrip(misc1ExpenseAcctNbr))
  @dtw_assign(misc1ExpenseSubNbr,@dtw_rstrip(misc1ExpenseSubNbr))
  @dtw_assign(misc1VarianceAcctNbr,@dtw_rstrip(misc1VarianceAcctNbr))
  @dtw_assign(misc1VarianceSubNbr,@dtw_rstrip(misc1VarianceSubNbr))
  @dtw_assign(misc2ExpenseAcctNbr,@dtw_rstrip(misc2ExpenseAcctNbr))
  @dtw_assign(misc2ExpenseSubNbr,@dtw_rstrip(misc2ExpenseSubNbr))
  @dtw_assign(misc2VarianceAcctNbr,@dtw_rstrip(misc2VarianceAcctNbr))
  @dtw_assign(misc2VarianceSubNbr,@dtw_rstrip(misc2VarianceSubNbr))
  @dtw_assign(misc3ExpenseAcctNbr,@dtw_rstrip(misc3ExpenseAcctNbr))
  @dtw_assign(misc3ExpenseSubNbr,@dtw_rstrip(misc3ExpenseSubNbr))
  @dtw_assign(misc3VarianceAcctNbr,@dtw_rstrip(misc3VarianceAcctNbr))
  @dtw_assign(misc3VarianceSubNbr,@dtw_rstrip(misc3VarianceSubNbr))
  @dtw_assign(misc4ExpenseAcctNbr,@dtw_rstrip(misc4ExpenseAcctNbr))
  @dtw_assign(misc4ExpenseSubNbr,@dtw_rstrip(misc4ExpenseSubNbr))
  @dtw_assign(misc4VarianceAcctNbr,@dtw_rstrip(misc4VarianceAcctNbr))
  @dtw_assign(misc4VarianceSubNbr,@dtw_rstrip(misc4VarianceSubNbr))
  @dtw_assign(misc5ExpenseAcctNbr,@dtw_rstrip(misc5ExpenseAcctNbr))
  @dtw_assign(misc5ExpenseSubNbr,@dtw_rstrip(misc5ExpenseSubNbr))
  @dtw_assign(misc5VarianceAcctNbr,@dtw_rstrip(misc5VarianceAcctNbr))
  @dtw_assign(misc5VarianceSubNbr,@dtw_rstrip(misc5VarianceSubNbr))
  @dtw_assign(misc6ExpenseAcctNbr,@dtw_rstrip(misc6ExpenseAcctNbr))
  @dtw_assign(misc6ExpenseSubNbr,@dtw_rstrip(misc6ExpenseSubNbr))
  @dtw_assign(misc6VarianceAcctNbr,@dtw_rstrip(misc6VarianceAcctNbr))
  @dtw_assign(misc6VarianceSubNbr,@dtw_rstrip(misc6VarianceSubNbr))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@whs@", warehouseNumber)
  @Concat_Field("@@co#@", companyNumber)
  @Concat_Field("@@fac#", facilityNumber)
  @Concat_Field("@@whnm", warehouseName)
  @Concat_Field("@@alph", alphaSequence)
  @Concat_Field("@@whad", addressLineOne)
  @Concat_Field("@@wha2", addressLineTwo)
  @Concat_Field("@@whct", city)
  @Concat_Field("@@whst", state)
  @Concat_Field("@@hwzp", zip)
  @Concat_Field("@@ctry", country)
  @Concat_Field("@@pseg", pageSegmentName)
  @Concat_Field("@@schd", schedule)
  @Concat_Field("@@tcva", transferCostVarAcctNbr)
  @Concat_Field("@@tcvs", transferCostVarSubNbr)
  @Concat_Field("@@stkl", stockLocatorActive)
  @Concat_Field("@@acs@", autoUpdateItemStock)
  @Concat_Field("@@mrpn", mrpNetableWarehouse)
  @Concat_Field("@@abci", abcAnalysis)
  @Concat_Field("@@vla@", acceptancePctA)
  @Concat_Field("@@vlb@", acceptancePctB)
  @Concat_Field("@@vlc@", acceptancePctC)
  @Concat_Field("@@caw@", cycleDaysA)
  @Concat_Field("@@cbw@", cycleDaysB)
  @Concat_Field("@@ccw@", cycleDaysC)
  @Concat_Field("@@pca@", percentageA)
  @Concat_Field("@@pcb@", percentageB)
  @Concat_Field("@@uvra", unvReceiptsExpAcctNbr)
  @Concat_Field("@@uvrs", unvReceiptsExpSubNbr)
  @Concat_Field("@@prva", standardVarAcctNbr)
  @Concat_Field("@@prvs", standardVarSubNbr)
  @Concat_Field("@@fgha", freightExpenseAcctNbr)
  @Concat_Field("@@fghs", freightExpenseSubNbr)
  @Concat_Field("@@fgva", freightVarianceAcctNbr)
  @Concat_Field("@@fgvs", freightVarianceSubNbr)
  @Concat_Field("@@slta", taxExpenseAcctNbr)
  @Concat_Field("@@slts", taxExpenseSubNbr)
  @Concat_Field("@@stva", taxVarianceAcctNbr)
  @Concat_Field("@@stvs", taxVarianceSubNbr)
  @Concat_Field("@@spga", specialChgExpAcctNbr)
  @Concat_Field("@@spcs", specialChgExpSubNbr)
  @Concat_Field("@@scva", specialChgVarAcctNbr)
  @Concat_Field("@@scvs", specialChgVarSubNbr)
  @Concat_Field("@@mc1a", misc1ExpenseAcctNbr)
  @Concat_Field("@@mc1s", misc1ExpenseSubNbr)
  @Concat_Field("@@mv1a", misc1VarianceAcctNbr)
  @Concat_Field("@@mv1s", misc1VarianceSubNbr)
  @Concat_Field("@@mc2a", misc2ExpenseAcctNbr)
  @Concat_Field("@@mc2s", misc2ExpenseSubNbr)
  @Concat_Field("@@mv2a", misc2VarianceAcctNbr)
  @Concat_Field("@@mv2s", misc2VarianceSubNbr)
  @Concat_Field("@@mc3a", misc3ExpenseAcctNbr)
  @Concat_Field("@@mc3s", misc3ExpenseSubNbr)
  @Concat_Field("@@mv3a", misc3VarianceAcctNbr)
  @Concat_Field("@@mv3s", misc3VarianceSubNbr)
  @Concat_Field("@@mc4a", misc4ExpenseAcctNbr)
  @Concat_Field("@@mc4s", misc4ExpenseSubNbr)
  @Concat_Field("@@mv4a", misc4VarianceAcctNbr)
  @Concat_Field("@@mv4s", misc4VarianceSubNbr)
  @Concat_Field("@@mc5a", misc5ExpenseAcctNbr)
  @Concat_Field("@@mc5s", misc5ExpenseSubNbr)
  @Concat_Field("@@mv5a", misc5VarianceAcctNbr)
  @Concat_Field("@@mv5s", misc5VarianceSubNbr)
  @Concat_Field("@@mc6a", misc6ExpenseAcctNbr)
  @Concat_Field("@@mc6s", misc6ExpenseSubNbr)
  @Concat_Field("@@mv6a", misc6VarianceAcctNbr)
  @Concat_Field("@@mv6s", misc6VarianceSubNbr)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(warehouseName), $(warehouseNumber), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@whs@", "warehouseNumber")
          @Format_ConfMsg_Desc("", $(warehouseName), $(warehouseNumber), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      %if (fromSel == "Y" && maintenanceCode != "D")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)WarehouseSelect.d2w/REPORT$(genericVarBase)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;warehouseName=@dtw_rurlescseq(warehouseName)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
          %if (backURL == "")
              <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=163&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %else
              <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %endif
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}