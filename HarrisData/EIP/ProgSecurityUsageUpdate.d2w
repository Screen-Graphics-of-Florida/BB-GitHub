%INCLUDE "$(baseVar)"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"

%Define {	
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  START_ROW_NUM           = "1"
  doubleQuote             = """"
  progType                = "SCRIPT"
  comments                = ""
%}

%MACRO_FUNCTION BuildUserViewFields (IN    field,
                                     INOUT userViewFields)
{
  @dtw_concat(userViewFields, "$(field) ", userViewFields)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  <html>
      <head>
      </head>
      <body $(bodyTagAttr)>
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " PIPRD2W ", fileSQL)
                      @dtw_concat(selectSQL, " PWTYPE IN ('D','P')", selectSQL)
                      @dtw_concat(selectSQL, " and PWD2WMU Not LIKE 'PROGSECURITYUSAGEUPDATE%'", selectSQL)
                      @dtw_concat(selectSQL, " and PWD2WMU Not LIKE 'DOCREFERENCEUPDATE%'", selectSQL)
                      @dtw_concat(selectSQL, " and PWRLS<>'O'", selectSQL)
                      @dtw_concat(selectSQL, " and not exists (Select * From SYPSUM Where PWD2WMU=PSPGNMU)", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      @D2WN_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
      </body>
  </html>
%}

%FUNCTION(dtw_sql) D2WN_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
              %ROW{
                  @dtw_assign(userViewFields, "")
                  @dtw_assign(progName, "")
                  @dtw_assign(progNameDesc, "")
                  @dtw_assign(progOptSec, "")
                  @dtw_assign(includeName, "")
                  @dtw_assign(progName, "$(V_PWD2WM)")
                  @dtwf_readfile(V_PWD2WM, text)
                  %if (text != "")
                      <table $(baseTable)>
                      <tr><td>$(V_PWD2WM)</td></tr>
                      </table>
                      @dtw_assign(progPos, @dtw_rpos("programName", text))
                      %if (progPos > "0")
                          @dtw_assign(x, "1")
                          %while(x < "50") {
                              %if (@dtw_rsubstr(text, progPos, "1") == doubleQuote)
                                  @dtw_add(progPos, "1", progPos)
                                  @dtw_assign(quotePos, @dtw_rpos(doubleQuote, text, progPos))
                                  @dtw_assign(progOptSec, @dtw_rsubstr(text, progPos, @dtw_rsubtract(quotePos, progPos)))
                                  @dtw_assign(x, "99")
                              %else
                                  @dtw_add(x, "1", x)
                                  @dtw_add(progPos, "1", progPos)
                              %endif
                          %}
                      %endif
                      @dtw_assign(progPos, @dtw_rpos("page_title", text))
                      %if (progPos > "0")
                          @dtw_assign(x, "1")
                          %while(x < "50") {
                              %if (@dtw_rsubstr(text, progPos, "1") == doubleQuote)
                                  @dtw_add(progPos, "1", progPos)
                                  @dtw_assign(quotePos, @dtw_rpos(doubleQuote, text, progPos))
                                  @dtw_assign(progNameDesc, @dtw_rsubstr(text, progPos, @dtw_rsubtract(quotePos, progPos)))
                                  @dtw_assign(x, "99")
                              %else
                                  @dtw_add(x, "1", x)
                                  @dtw_add(progPos, "1", progPos)
                              %endif
                          %}
                      %endif
                      %if (@dtw_rpos("uv_CompanyName", text) > "0")
                           @BuildUserViewFields("XPCO#",  userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_FacilityName", text) > "0")
                          @BuildUserViewFields("XPFAC#", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_PayerTinName", text) > "0")
                          @BuildUserViewFields("XPTIN#", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_BankName", text) > "0")
                          @BuildUserViewFields("XPBNK#", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_AccountName", text) > "0")
                          @BuildUserViewFields("XPACCT", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_BuyerName", text) > "0")
                          @BuildUserViewFields("XPBUYR", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_VendorTypeName", text) > "0")
                          @BuildUserViewFields("XPVTYP", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_VendorName", text) > "0")
                          @BuildUserViewFields("XPVEND", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_SalesmanName", text) > "0")
                          @BuildUserViewFields("XPSLSM", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_CustomerClassName", text) > "0")
                          @BuildUserViewFields("XPCCLS", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_RegionName", text) > "0")
                          @BuildUserViewFields("XPCRGN", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_BillingLocationName", text) > "0")
                          @BuildUserViewFields("XPBLLC", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_CustomerName", text) > "0")
                          @BuildUserViewFields("XPCUST", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_PayerName", text) > "0")
                          @BuildUserViewFields("XPPAYR", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_FederalEINName", text) > "0")
                          @BuildUserViewFields("XPEIN", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_HRCompanyName", text) > "0")
                          @BuildUserViewFields("XPPECO", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_HRLocationName", text) > "0")
                          @BuildUserViewFields("XPPELC", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_PRBankName", text) > "0")
                          @BuildUserViewFields("XPBANK", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_HomeDepartmentName", text) > "0")
                          @BuildUserViewFields("XPDEPT", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_PayTypeName", text) > "0")
                          @BuildUserViewFields("XPPAYT", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_SalaryControlName", text) > "0")
                          @BuildUserViewFields("XPPAYD", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_PREmployeeName", text) > "0")
                          @BuildUserViewFields("XPPREM", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_HREmployeeName", text) > "0")
                          @BuildUserViewFields("XPPEEM", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_ScheduleName", text) > "0")
                          @BuildUserViewFields("XPSCHD", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_GroupName", text) > "0")
                          @BuildUserViewFields("XPGRP",  userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_DataCollectionName", text) > "0")
                          @BuildUserViewFields("XPCODE", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_LaborCodeName", text) > "0")
                          @BuildUserViewFields("XPLCOD", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_IndirectDowntimeName", text) > "0")
                          @BuildUserViewFields("XPINCD", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_PlantName", text) > "0")
                          @BuildUserViewFields("XPPLT",  userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_MfgDepartmentName", text) > "0")
                          @BuildUserViewFields("XPMFDP", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_WorkCenterName", text) > "0")
                          @BuildUserViewFields("XPWC",   userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_PltInventoryTypeName", text) > "0")
                          @BuildUserViewFields("XPITC",  userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_PltPartTypeName", text) > "0")
                          @BuildUserViewFields("XPPTYP", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_ProductGroupName", text) > "0")
                          @BuildUserViewFields("XPPGRP", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_PartClassName", text) > "0")
                          @BuildUserViewFields("XPCLAS", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_ProductClassName", text) > "0")
                          @BuildUserViewFields("XPPCLS", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_WarehouseName", text) > "0")
                          @BuildUserViewFields("XPWHS",  userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_ProdInventoryTypeName", text) > "0")
                          @BuildUserViewFields("XPPITC",  userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_ProdPartTypeName", text) > "0")
                          @BuildUserViewFields("XPPPTY", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_CountGroupName", text) > "0")
                          @BuildUserViewFields("XPCYCL", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_StockroomName", text) > "0")
                          @BuildUserViewFields("XPSTKR", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_AileName", text) > "0")
                          @BuildUserViewFields("XPAILE", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_StockLocationName", text) > "0")
                          @BuildUserViewFields("XPSLOC", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_OEOrderTypeName", text) > "0")
                          @BuildUserViewFields("XPOOCD", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_POOrderTypeName", text) > "0")
                          @BuildUserViewFields("XPPOCD", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_TransactionTypeName", text) > "0")
                          @BuildUserViewFields("XPTTYP", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_SiteName", text) > "0")
                          @BuildUserViewFields("XPSITE", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_PropertyTypeName", text) > "0")
                          @BuildUserViewFields("XPPROP", userViewFields)
                      %endif
                      %if (@dtw_rpos("uv_FamilyCodeName", text) > "0")
                          @BuildUserViewFields("XPFMCD", userViewFields)
                      %endif

                      %if (@dtw_rpos("AssetUserView", text) > "0")
                          @dtw_assign(includeName, "AssetUserView")
                          @BuildUserViewFields("XPSITE", userViewFields)
                          @BuildUserViewFields("XPPROP", userViewFields)
                          @BuildUserViewFields("XPFMCD", userViewFields)
                      %endif

                      %if (@dtw_rpos("EmplUV.icl", text) > "0")
                          @dtw_assign(includeName, "EmplUV")
                          @BuildUserViewFields("XPCO#",  userViewFields)
                          @BuildUserViewFields("XPFAC#", userViewFields)
                          @BuildUserViewFields("XPPREM", userViewFields)
                          @BuildUserViewFields("XPPECO", userViewFields)
                          @BuildUserViewFields("XPPEEM", userViewFields)
                          @BuildUserViewFields("XPDEPT", userViewFields)
                          @BuildUserViewFields("XPPELC", userViewFields)
                          @BuildUserViewFields("XPPAYT", userViewFields)
                      %endif

                      %if (@dtw_rpos("UserViewEmpl.icl", text) > "0")
                          @dtw_assign(includeName, "UserViewEmpl")
                          @BuildUserViewFields("XPCO#",  userViewFields)
                          @BuildUserViewFields("XPFAC#", userViewFields)
                          @BuildUserViewFields("XPPREM", userViewFields)
                          @BuildUserViewFields("XPPECO", userViewFields)
                          @BuildUserViewFields("XPPEEM", userViewFields)
                          @BuildUserViewFields("XPDEPT", userViewFields)
                          @BuildUserViewFields("XPPELC", userViewFields)
                          @BuildUserViewFields("XPPAYT", userViewFields)
                      %endif

                      %if (@dtw_rpos("BankUserView", text) > "0")
                          @dtw_assign(includeName, "BankUserView")
                          @BuildUserViewFields("XPBNK#", userViewFields)
                      %endif

                      %if (@dtw_rpos("PrBankUserView", text) > "0")
                          @dtw_assign(includeName, "PrBankUserView")
                          @BuildUserViewFields("XPBANK", userViewFields)
                      %endif

                      %if (@dtw_rpos("CoFacUserView", text) > "0")
                          @dtw_assign(includeName, "CoFacUserView")
                          @BuildUserViewFields("XPCO#",  userViewFields)
                          @BuildUserViewFields("XPFAC#", userViewFields)
                      %endif

                      %if (@dtw_rpos("CustomerUserView", text) > "0")
                          @dtw_assign(includeName, "CustomerUserView")
                          @BuildUserViewFields("XPWHS",  userViewFields)
                          @BuildUserViewFields("XPBLLC", userViewFields)
                          @BuildUserViewFields("XPCUST", userViewFields)
                      %endif

                      %if (@dtw_rpos("HrCoFacUserView", text) > "0")
                          @dtw_assign(includeName, "HrCoFacUserView")
                          @BuildUserViewFields("XPCO#",  userViewFields)
                          @BuildUserViewFields("XPFAC#", userViewFields)
                      %endif

                      %if (@dtw_rpos("ItemUserView", text) > "0")
                          @dtw_assign(includeName, "ItemUserView")
                          @BuildUserViewFields("XPPCLS", userViewFields)
                          @BuildUserViewFields("XPITC",  userViewFields)
                          @BuildUserViewFields("XPPTYP", userViewFields)
                      %endif

                      %if (@dtw_rpos("ItemPlantUserView", text) > "0")
                          @dtw_assign(includeName, "ItemPlantUserView")
                          @BuildUserViewFields("XPPLT",  userViewFields)
                          @BuildUserViewFields("XPITC",  userViewFields)
                          @BuildUserViewFields("XPPTYP", userViewFields)
                          @BuildUserViewFields("XPCLAS", userViewFields)
                      %endif

                      %if (@dtw_rpos("ItemWarehouseUserView", text) > "0")
                          @dtw_assign(includeName, "ItemWarehouseUserView")
                          @BuildUserViewFields("XPWHS",  userViewFields)
                          @BuildUserViewFields("XPPGRP", userViewFields)
                          @BuildUserViewFields("XPCYCL", userViewFields)
                      %endif

                      %if (@dtw_rpos("LocationUserView", text) > "0")
                          @dtw_assign(includeName, "LocationUserView")
                          @BuildUserViewFields("XPBLLC", userViewFields)
                      %endif

                      %if (@dtw_rpos("LotUserView", text) > "0")
                          @dtw_assign(includeName, "LocationUserView")
                          @BuildUserViewFields("XPWHS",  userViewFields)
                          @BuildUserViewFields("XPPCLS", userViewFields)
                          @BuildUserViewFields("XPPTYP", userViewFields)
                          @BuildUserViewFields("XPITC",  userViewFields)
                          @BuildUserViewFields("XPBUYR", userViewFields)
                          @BuildUserViewFields("XPVEND", userViewFields)
                      %endif

                      %if (@dtw_rpos("PlantUserView", text) > "0")
                          @dtw_assign(includeName, "PlantUserView")
                          @BuildUserViewFields("XPPLT", userViewFields)
                      %endif

                      %if (@dtw_rpos("VendorUserView", text) > "0")
                          @dtw_assign(includeName, "VendorUserView")
                          @BuildUserViewFields("XPVEND", userViewFields)
                      %endif

                      %if (@dtw_rpos("WarehouseUserView", text) > "0")
                          @dtw_assign(includeName, "WarehouseUserView")
                          @BuildUserViewFields("XPWHS", userViewFields)
                      %endif

                      %if (@dtw_rpos("WorkCenterUserView", text) > "0")
                          @dtw_assign(includeName, "WorkCenterUserView")
                          @BuildUserViewFields("XPPLT", userViewFields)
                          @BuildUserViewFields("XPMFDP", userViewFields)
                          @BuildUserViewFields("XPWC", userViewFields)
                          @BuildUserViewFields("XPCO#", userViewFields)
                          @BuildUserViewFields("XPFAC#", userViewFields)
                          @BuildUserViewFields("XPSCHD", userViewFields)
                      %endif

                      %if (@dtw_rpos("SalesmanUserView", text) > "0")
                          @dtw_assign(includeName, "SalesmanUserView")
                          @BuildUserViewFields("XPSLSM", userViewFields)
                      %endif

                      @dtw_mUPPERCASE(progOptSec)
                      @dtw_assign(maintenanceCode, "U")

                      @dtw_assign(edtVar, "")
                      @Concat_Field("@@pgtp", progType)
                      @Concat_Field("@@pgnm", progName)
                      @Concat_Field("@@desc", progNameDesc)
                      @Concat_Field("@@posp", progOptSec)
                      @Concat_Field("@@uvfn", userViewFields)
                      @Concat_Field("@@icln", includeName)
                      @dtw_concat(edtVar, "}{", edtVar)

                      @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar, comments)
                  %endif
              %}
      %}
  %}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                              CHAR(2)     dataBaseID,
                                              CHAR(1)     maintenanceCode,
                                              CHAR(1)     errFound,
                                              CHAR(32000) edtVar,                             	
                                              CHAR(32000) errVar,
                                              CHAR(32000) comments)
{%EXEC {HSYSUM_W.PGM %}
%}

%HTML(UPDATE) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}
