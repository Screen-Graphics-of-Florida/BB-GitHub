%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Parameter Maintenance"
  d2wName                 = "WFParameterMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromWfParm=@dtw_rurlescseq(fromWfParm)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;backHome=@dtw_rurlescseq(backHome)&amp;updRecNbr=@dtw_rurlescseq(updRecNbr)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;wfParm=@dtw_rurlescseq(wfParm)&amp;maintenanceCode=D"
  programName             = "HWFPMM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function confirmDelete() {return confirm("$(delRecordConf)")}
              function validate(chgForm) {
                  if (document.Chg.wfParm.value =="" ||
                      document.Chg.wfParmDescription.value =="" ||
                      document.Chg.fieldType.value =="" ||
                      document.Chg.wholePrecision.value =="")
                         {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.wholePrecision, 5, 0) &&
                      editNum(document.Chg.decimalPrecision, 2, 0)
                      )
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFPARAMETERMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " WFPARM ", fileSQL)
                          @dtw_concat(selectSQL, " PMPARM='$(wfParm)'", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=147")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "wfParm")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@parm", "wfParm")               @dtw_assign(Err_PMPARM, fieldValue)
                          @DecatErr_Field("@@prmd", "wfParmDescription")    @dtw_assign(Err_PMPRMD, fieldValue)
                          @DecatErr_Field("@@type", "fieldType")            @dtw_assign(Err_PMTYPE, fieldValue)
                          @DecatErr_Field("@@size", "wholePrecision")       @dtw_assign(Err_PMSIZE, fieldValue)
                          @DecatErr_Field("@@decm", "decimalPrecision")     @dtw_assign(Err_PMDECM, fieldValue)
                          @DecatErr_Field("@@uppr", "cvtUpper")             @dtw_assign(Err_PMUPPR, fieldValue)
                      %endif

                      @Decat_Field("@@parm")   @dtw_assign(V_PMPARM, fieldValue)
                      @Decat_Field("@@prmd")   @dtw_assign(V_PMPRMD, fieldValue)
                      @Decat_Field("@@type")   @dtw_assign(V_PMTYPE, fieldValue)
                      @Decat_Field("@@size")   @dtw_assign(V_PMSIZE, fieldValue)
                      @Decat_Field("@@decm")   @dtw_assign(V_PMDECM, fieldValue)
                      @Decat_Field("@@uppr")   @dtw_assign(V_PMUPPR, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "wfParm")
                          @dtw_assign(V_PMTYPE, "A")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "wfParm")
                  %else
                      @dtw_assign(focusField, "wfParmDescription")
                  %endif

                  @SetTextOvr(Err_PMPARM)
                  <tr><td class="dsphdr"><span $(textOvr)>Parameter</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input type="text" name="wfParm" value="$(V_PMPARM)" size="5" maxlength="4">$(reqFieldChar)</td>
                      %else
                          <td class="inputalph"><input type="hidden" name="wfParm" value="$(V_PMPARM)">$(V_PMPARM)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_PMPARM)

                  @SetTextOvr(Err_PMPRMD)
                  <tr><td class="dsphdr"><span $(textOvr)>Parameter Description</span></td>
                      <td class="inputalph"><input type="text" name="wfParmDescription" value="$(V_PMPRMD)" size="50" maxlength="50">$(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_PMPRMD)

                  @RtvFldDesc("FLTYPE='WFFLDTYPE' and FLVALU='$(V_PMTYPE)'", "SYFLAG", "FLDESC", fieldDesc)
                  @SetTextOvr(Err_PMTYPE)
                  <tr><td class="dsphdr"><span $(textOvr)>Column Type</span></td>
                      <td class="inputalph"><input type="text" name="fieldType" value="$(V_PMTYPE)" size="5" maxlength="1">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=WFFLDTYPE&amp;flagSrchHdr=@dtw_rurlescseq("Column Type")&amp;docName=Chg&amp;fldName=fieldType&amp;fldDesc=fieldTypeDesc" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage)</a>
                                            <input type="text" disabled name="fieldTypeDesc" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_PMTYPE)

                  @SetTextOvr(Err_PMSIZE)
                  <tr><td class="dsphdr"><span $(textOvr)>Whole Number Precision</span></td>
                      <td class="inputnmbr"><input type="text" name="wholePrecision" value="$(V_PMSIZE)" size="5" maxlength="5">$(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_PMSIZE)

                  @SetTextOvr(Err_PMDECM)
                  <tr><td class="dsphdr"><span $(textOvr)>Decimal Precision</span></td>
                      <td class="inputnmbr"><input type="text" name="decimalPrecision" value="$(V_PMDECM)" size="5" maxlength="2"></td>
                  </tr>
                  @DspErrMsg(Err_PMDECM)

                  @RtvFldDesc("FLTYPE='BY' and FLVALU='$(V_PMUPPR)'", "SYFLAG", "FLDESC", fieldDesc)
                  @SetTextOvr(Err_PMUPPR)
                  <tr><td class="dsphdr"><span $(textOvr)>Convert To Upper</span></td>
                      <td class="inputalph"><input type="text" name="cvtUpper" value="$(V_PMUPPR)" size="5" maxlength="1">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=BY&amp;flagSrchHdr=@dtw_rurlescseq("Convert To Upper")&amp;docName=Chg&amp;fldName=cvtUpper&amp;fldDesc=cvtUpperDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                            <input type="text" disabled name="cvtUpperDesc" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_PMUPPR)
              %}
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HWFPMM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  %if (wfParmDescription == "")
      @RtvFldDesc("PMPARM='$(wfParm)'", "WFPARM", "PMPRMD", wfParmDescription)
  %endif

  @dtw_mUPPERCASE(fieldType)
  @dtw_mUPPERCASE(cvtUpper)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@frm1", fromWfParm)
  @Concat_Field("@@parm", wfParm)
  @Concat_Field("@@prmd", wfParmDescription)
  @Concat_Field("@@type", fieldType)
  @Concat_Field("@@size", wholePrecision)
  @Concat_Field("@@decm", decimalPrecision)
  @Concat_Field("@@uppr", cvtUpper)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(wfParmDescription), $(wfParm), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@parm", "wfParm")
          @Format_ConfMsg_Desc("", $(wfParmDescription), $(wfParm), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=147&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;wfParm=@dtw_rurlescseq(wfParm)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
