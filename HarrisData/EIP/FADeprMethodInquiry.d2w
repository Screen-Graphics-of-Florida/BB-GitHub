%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"

%Define {	
  page_title              = "Depreciation Method Inquiry"
  d2wName                 = "FADeprMethodInquiry.d2w"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
%}
	
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL)
{	
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onLoad="window.focus()" onBlur="window.close()">
              <!-- Start Of Banner Code -->
              %INCLUDE "$(inquiryBanner)"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      <td>
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, "SELECT * ", stmtSQL)
                          @dtw_concat(fileSQL, " FADPCD ", fileSQL)
                          @dtw_concat(selectSQL, " DCDPCD='$(deprMethod)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                          @Display_Inquiry(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "$(inquiryTrailer)"
              <!-- End Of Trailer Code -->
          </body>
      </html>
%}
%FUNCTION(dtw_sql) Display_Inquiry (IN CHAR(64) profileHandle,
                                       CHAR(2)   dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(displayCloseIcon, "Y")
      %INCLUDE "PageTitle.icl"

      $(inquiryhrTagAttr)

      <table $(contentTable)>
          %ROW{
              <tr><td class="dsphdr">Depreciation Method</td>
                  <td class="dspalph">$(V_DCDPCD)</td></tr>

              <tr><td class="dsphdr">Abbreviated Description</td>
                  <td class="dspalph">$(V_DCABBR)</td></tr>

              <tr><td class="dsphdr">Long Description</td>
                  <td class="dspalph">$(V_DCLONG)</td></tr>
          %}
      </table>
      $(inquiryhrTagAttr)
      %INCLUDE "CloseWindow.icl"
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}