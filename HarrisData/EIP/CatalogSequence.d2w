%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Catalog Maintenance &nbsp;"
  d2wName                 = "CatalogSequence.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;catalog=@dtw_rurlescseq(catalog)&amp;catalogDesc=@dtw_rurlescseq(catalogDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "SELECT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@catalogDesc", "@dtw_rurlescseq(catalogDesc)", "1", "a", workURL)
  @dtw_replace(workURL, "@@catalog", "@dtw_rurlescseq(catalog)", "1", "a", workURL)
%}
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "CATALOGSEQUENCE")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select CSCATN, CSCSEQ, CSDESC, upper(CSDESC) as CSDESCU, CSOSEQ  ", stmtSQL)
                      @dtw_concat(fileSQL, " OECATS ", fileSQL)
                      @dtw_concat(selectSQL, "CSCATN='$(catalog)'  ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Catalog_Seq_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Catalog_Seq_Query (IN CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
          <col width="80%">
          <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      <a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=113" title="Return To Catalogs">$(portalHome)</a>
                      <a href="$(homeURL)$(cGIPath)catalogselect.d2w/SELECT$(d2wVarBase)&amp;recordSequence=0&amp;orderSequence=0&amp;maintenanceCode=A&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">$(addImageLrg)</a>
                      <a href="$(homeURL)$(cGIPath)$(d2wName)/SELECT$(d2wVarBase)&amp;formatToPrint=Y" target=_blank>$(formatPrintDesc)</a>
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      <table $(contentTable)>
          @Format_Header("Catalog", $(catalogDesc), $(catalog))
      </table>

      %INCLUDE "ConfMessageDisplay.icl"
      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Description</th>
                  </tr>
                  <tr>
                      <td><input type="text" class="inputalph" name="srchDesc" size="20" maxlength="50">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y")
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("CSOSEQ", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Sequence" title="Sequence By Sequence, Description"> Sequence</a></th>
              @OrderBy_Sort("CSDESCU", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description, Sequence"> Description</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{

              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;recordSequence=@dtw_rurlescseq(V_CSCSEQ)&amp;orderSequence=@dtw_rurlescseq(V_CSOSEQ)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_CSDESC), $(V_CSOSEQ), "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y")
                      <td class="opticon">
                          <a href="$(homeURL)$(cGIPath)catalogselect.d2w/SELECT$(maintainVar)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">$(changeImageSml)</a>
                          <a href="$(homeURL)$(cGIPath)catalogselect.d2w/SELECT$(maintainVar)&amp;maintenanceCode=Z&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">$(copyImageSml)</a>
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)$(d2wName)/DELETE$(maintainVar)">$(deleteImageSml)</a>
                      </td>
                  %endif
                  <td class="colnmbr">$(V_CSOSEQ)</td>
                  <td class="colalph">$(V_CSDESC)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Update_Catalog_Sequence(INOUT CHAR(64) profileHandle,
                                                  INOUT CHAR(2)  dataBaseID,
                                                  INOUT CHAR(1)  maintCode,
                                                  INOUT CHAR(15) catalog,
                                                  INOUT DEC(7,0) recordSequence,
                                                  INOUT DEC(7,2) orderSequence,
                                                  INOUT CHAR(50) selectDesc,
                                                  INOUT CHAR(15) category,
                                                  INOUT CHAR(1)  newPage,
                                                  INOUT CHAR(500) selectGroupBy,
                                                  INOUT CHAR(3000) selectCriteria)
{%EXEC {HOECTS_W.PGM %}
%}

%HTML(SELECT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "CSOSEQ,CSDESCU")
          @DTW_ASSIGN(orderByDisplay, "Sequence, Description")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(DELETE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(maintCode, "D")
  @Update_Catalog_Sequence(profileHandle, dataBaseID, maintCode, catalog, recordSequence, orderSequence, selectDesc, category, newPage, selectGroupBy, selectCriteria)
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/SELECT$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Sequence")
      %if (orderBy == "CSOSEQ,CSDESCU")
          @DTW_ASSIGN(orderBy, "CSOSEQ DESC,CSDESCU")
          @DTW_ASSIGN(orderByDisplay, "Sequence (descending), Description")
      %else
          @DTW_ASSIGN(orderBy, "CSOSEQ,CSDESCU")
          @DTW_ASSIGN(orderByDisplay, "Sequence, Description")
      %endif
  %elif (sequence == "Desc")
      %if (orderBy == "CSDESCU,CSOSEQ")
          @DTW_ASSIGN(orderBy, "CSDESCU DESC,CSOSEQ")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Sequence")
      %else
          @DTW_ASSIGN(orderBy, "CSDESCU,CSOSEQ")
          @DTW_ASSIGN(orderByDisplay, "Description, Sequence")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
  @Build_WildCard ("upper(CSDESC)", "Description", $(srchDesc), "U", operDesc, "A")
  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
