%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Indented Explosion"
  d2wName                 = "ProductStructureIndentedExplosionInquiry.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  quantityRequired        = ""
%}
	
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script type="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.quantityRequired, 11, 0))
                      return true;
              }
           </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onLoad="window.focus()" onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " PDM099 ", fileSQL)
                      @dtw_concat(selectSQL, " PZXHND='$(profileHandle)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By PZXHND, PZRSEQ ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @ProdStr_Inquiry(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) ProdStr_Inquiry (IN CHAR(64)    profileHandle,
				        CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
      <table $(contentTable)>
          @Format_Header("Plant", $(plantName), $(plantNumber))
          @Format_Header("Item", $(itemDescription), $(itemNumber))
      </table>
      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return false;" ACTION="$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)">
          <table $(contentTable)>
              <tr><td class="dsphdr">Quantity Required</td>
                  <td class="inputnmbr"><input type="text" name="quantityRequired" value="$(quantityRequired)" size="11" maxlength="11"></td>
                  <td><a href="javascript:check(document.Search)">$(signOnImage)</a></td>
              </tr>
          </table>
      </form>

      $(inquiryhrTagAttr)
      <table $(contentTable)>
         <tr>
              <th class="colhdr">BOM<br>Level</th>
              <th class="colhdr">Rtg<br>Seq</th>
              <th class="colhdr">Component Item</th>
              <th class="colhdr">Description</th>
              <th class="colhdr">UM<br>ST</th>
              <th class="colhdr">T<br>Y</th>
              <th class="colhdr">Qty Per</th>
              <th class="colhdr">Extended<br>Quantity</th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                 <td class="colalph">$(V_PZLVL)</td>
                 <td class="colnmbr">$(V_PZSEQN)</td>
                 <td class="colalph">$(V_PZCPN)</td>
                 <td class="colalph">$(V_PZIMDS)</td>
                 <td class="colalph">$(V_PZUOMS)</td>
                 <td class="colcode">$(V_PZPTYP)</td>
                 <td class="colnmbr">$(V_PZQPER)</td>
                 <td class="colnmbr">$(V_PZXPER)</td>
              </tr>
          %}
      </table>
      $(inquiryhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Create_Work_File (IN    CHAR(64)    profileHandle,
                                                  CHAR(32000) edtVar)

{%EXEC {HPD099_W.PGM %}
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  %if (quantityRequired == "")
      @DTW_ASSIGN(quantityRequired, "1")
  %endif
  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@item", itemNumber)
  @Concat_Field("@@rqty", quantityRequired)
  @dtw_concat(edtVar, "}{", edtVar)
  @Create_Work_File (profileHandle, edtVar)
  @Set_SQL(stmtSQL)
%}