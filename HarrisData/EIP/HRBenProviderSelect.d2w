%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title		= "Benefit Provider"
  d2wName              = "HRBenProviderSelect.d2w"
  attachFolder         = "HRBenefitProvider"
  d2wVarBase           = "$(genericVarBase)&amp;providerCode=@dtw_rurlescseq(providerCode)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName          = "HPECRU"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  nextPrevVar          = "$(d2wVarBase)"
  RPT_MAX_ROWS 	= "10"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext		= "1"
  totalPages		= "0"	
  advanceSearch        = "N"
  attachVarKey         = ""
  attachForDesc        = ""
  quickLinksInUse      = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@providerCode", "@dtw_rurlescseq(providerCode)", "1", "a", workURL)
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @HrCoFacUserView(profileHandle, dataBaseID, userPass, hrCompany, facilityNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
                  function goToPage(selectedPage) {if (selectedPage != "") {self.location=selectedPage;}}
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Trailer Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Trailer Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "BENPROVIDER")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                      @dtw_assign(START_ROW_NUM, "1")
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " CBCARR ", fileSQL)
                          @dtw_concat(selectSQL, " CRCODE = '$(providerCode)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                          @Provider_Inquiry(profileHandle, dataBaseID, stmtSQL)
                          @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)

                          @dtw_assign(uv_CompanyName, "CVCOMP")
                          @dtw_assign(uv_FacilityName, "CVFACL")
	                   %INCLUDE "userview.icl"
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " CBCOVR inner join CBCODE on CVPLAN=CCCODE ", fileSQL)
                          @dtw_concat(selectSQL, " CVCARR = '$(providerCode)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By CVCOMP, CVFACL, CVDESC ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Provider_Inquiry2(profileHandle, dataBaseID, stmtSQL)
                          %INCLUDE "AttachmentSQL.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Provider_Inquiry (IN CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("CRCODE='$(providerCode)'", "CBCARR", "CRNAME", providerName)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              @dtw_assign(attachVarKey, "$(providerCode)")
              @dtw_assign(attachForDesc, providerName)
              @dtw_assign(attachPrg1, "CBCARR Where CRCODE = '$(providerCode)'")
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/report") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Return To Company/Facility Select">$(portalHome)</a>
                      %endif
                      %INCLUDE "Attachment.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>

      </table>
      %INCLUDE "ConfMessageDisplay.icl"
      $(hrTagAttr)

      <table $(contentTable)>
          <colgroup>
              <col width="60%">
	       <col width="20%">
	   		
          %ROW {
              @EditPhoneNumber(V_CRPHON)
              <tr><td rowspan="4" class="dspalph"> $(V_CRNAME) <br>
                      %if (V_CRADD1 != "")
                          $(V_CRADD1) <br>
                      %endif
                      %if (V_CRADD2 != "")
                          $(V_CRADD2) <br>
                      %endif
                      $(V_CRCITY), $(V_CRSTAT) $(V_CRZIP)
                  </td>

                  <td class="dsphdr">Provider Code:</td>
                  <td class="dspnmbr">$(V_CRCODE)</td>
              </tr>

              <tr>
                  <td class="dsphdr">Phone Number: </td>
                  <td class="dspnmbr">$(V_CRPHON)</td>
              </tr>
          %}
      </table>
      $(hrTagAttr)
  %}
%}

%FUNCTION(dtw_sql) Provider_Inquiry2 (IN CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(programName2, "HPECVU")
      @pgmOptSecurity(profileHandle, dataBaseID, programName2, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @dtw_assign(benefitView, sec_05)

      <h3>Benefits</h3>

      %if (formatToPrint == "")
          <table $(contentTable)>
              <tr><td> %INCLUDE "AssignPageValue.icl" </td>
              </tr>
          </table>
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y")
                  <th class="colhdr">Opt</th>
              %endif
              <th class="colhdr">Company/Facility</th>
              <th class="colhdr">Benefit</th>
              <th class="colhdr">Plan</th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(imageExists, "")
              %if (V_CVIMG != "")
                  @dtw_assign(fileImage, "$(V_CVIMG)")
                  @dtwf_exists(fileImage, imageExists)
              %endif

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y")
                      %if (V_CVURLI != "")
                          <td class="opticon">
                              <a href="$(V_CVURLI)">
                                  %if (imageExists == "Y")
                                      <img src="$(homeURL)$(fileImage)">
                                  %else
                                      $(planDocImage)
                                  %endif
                              </a>
                          </td>
                      %else
                          <td class="opticon">&nbsp;</td>
                      %endif
                  %endif
                  @Format_HRCoFac("$(V_CVCOMP)", "$(V_CVFACL)", "", F_CoFac)
                  <td class="colcode">$(F_CoFac)</td>

                  %if (benefitView == "Y")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)HRBenefitSelect.d2w/REPORT$(d2wVarBase)&amp;prCompany=@dtw_rurlescseq(V_CVCOMP)&amp;prFacility=@dtw_rurlescseq(V_CVFACL)&amp;benefitCode=@dtw_rurlescseq(V_CVCOVR)&amp;planCode=@dtw_rurlescseq(V_CVPLAN)" title="View Benefit">$(V_CVDESC)</a></td>
                  %else
                      <td class="colalph">$(V_CVDESC))</td>
                  %endif

                  <td class="colalph">$(V_CCDESC)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
  %}
%}

%INCLUDE "AttachmentSelect.icl"

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
      @Set_SQL(stmtSQL)
  %endif
%}