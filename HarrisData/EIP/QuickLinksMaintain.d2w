%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Quick Links Maintenance"
  d2wName                 = "QuickLinksMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;quickLinkD2W=@dtw_rurlescseq(quickLinkD2W)&amp;quickLink=@dtw_rurlescseq(quickLink)&amp;quickLinkDesc=@dtw_rurlescseq(quickLinkDesc)&amp;maintenanceCode=D"
  programName             = "HSYQLN_E"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "NumZero.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.quickLinkD2W.value =="" ||
                      document.Chg.quickLink.value =="" ||
                      document.Chg.quickLinkDesc.value =="")
                         {alert("$(reqFieldError)"); return false;}
                  if (editZero(document.Chg.quickLinkRows, 5, 0))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "DOCREFERENCEMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From SYQLND ", stmtSQL)
                          @dtw_concat(stmtSQL, "Where QDD2WN='$(quickLinkD2W)' ", stmtSQL)
                          @dtw_concat(stmtSQL, "and QDQLNK='$(quickLink)' ", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=161")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "quickLinkD2W")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)

                          @DecatErr_Field("@@d2wn", "quickLinkD2W")      @dtw_assign(Err_QDD2WN, fieldValue)
                          @DecatErr_Field("@@desc", "quickLinkDesc")     @dtw_assign(Err_QDDESC, fieldValue)
                          @DecatErr_Field("@@link", "quickLink")         @dtw_assign(Err_QDQLNK, fieldValue)
                          @DecatErr_Field("@@nrow", "quickLinkRows")     @dtw_assign(Err_QDNROW, fieldValue)
                          @DecatErr_Field("@@imgn", "imageName")         @dtw_assign(Err_QDIMGN, fieldValue)
                          @DecatErr_Field("@@clas", "class")             @dtw_assign(Err_QDCLAS, fieldValue)
                          @DecatErr_Field("@@urli", "urlID")             @dtw_assign(Err_QDURLID, fieldValue)
                          @DecatErr_Field("@@resv", "reserved")          @dtw_assign(Err_QDRESV, fieldValue)
                      %endif

                      @Decat_Field("@@d2wn")   @dtw_assign(V_QDD2WN, fieldValue)
                      @Decat_Field("@@desc")   @dtw_assign(V_QDDESC, fieldValue)
                      @Decat_Field("@@link")   @dtw_assign(V_QDQLNK, fieldValue)
                      @Decat_Field("@@nrow")   @dtw_assign(V_QDNROW, fieldValue)
                      @Decat_Field("@@imgn")   @dtw_assign(V_QDIMGN, fieldValue)
                      @Decat_Field("@@clas")   @dtw_assign(V_QDCLAS, fieldValue)
                      @Decat_Field("@@urli")   @dtw_assign(V_QDURLID, fieldValue)
                      @Decat_Field("@@resv")   @dtw_assign(V_QDRESV, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "quickLinkD2W")
                      %endif
                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "quickLinkD2W")
                  %else
                      @dtw_assign(focusField, "quickLinkDesc")
                  %endif

                  @SetTextOvr(Err_QDD2WN)
                  <tr><td class="dsphdr"><span $(textOvr)>Script Name</span></td>
                         %if (maintenanceCode == "A" || maintenanceCode == "Z")
                             <td class="inputalph"><input name="quickLinkD2W" type="text" value="$(V_QDD2WN)" size="50" maxlength="50"> $(reqFieldChar) </td>
                         %else
                             <td class="inputalph"><input name="quickLinkD2W" type="hidden" value="$(V_QDD2WN)" size="50" maxlength="50">$(V_QDD2WN)</td>
                         %endif
                  </tr>
                  @DspErrMsg(Err_QDD2WN)

                  @SetTextOvr(Err_QDQLNK)
                  <tr><td class="dsphdr"><span $(textOvr)>Quick Link</span></td>
                         %if (maintenanceCode == "A" || maintenanceCode == "Z")
                             <td class="inputalph"><input name="quickLink" type="text" value="$(V_QDQLNK)" size="50" maxlength="50"> $(reqFieldChar) </td>
                         %else
                             <td class="inputalph"><input name="quickLink" type="hidden" value="$(V_QDQLNK)" size="50" maxlength="50">$(V_QDQLNK)</td>
                         %endif
                  </tr>
                  @DspErrMsg(Err_QDQLNK)

                  @SetTextOvr(Err_QDDESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="quickLinkDesc" type="text" value="$(V_QDDESC)" size="50" maxlength="100"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_QDDESC)

                  @SetTextOvr(Err_QDNROW)
                  <tr><td class="dsphdr"><span $(textOvr)>Rows To Display</span></td>
                      <td class="inputnmbr"><input name="quickLinkRows" type="text" value="$(V_QDNROW)" size="5" maxlength="5"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_QDNROW)

                  @SetTextOvr(Err_QDIMGN)
                  <tr><td class="dsphdr"><span $(textOvr)>Image</span></td>
                      <td class="inputnmbr"><input name="imageName" type="text" value="$(V_QDIMGN)" size="50" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_QDIMGN)

                  @SetTextOvr(Err_QDCLAS)
                  <tr><td class="dsphdr"><span $(textOvr)>Class</span></td>
                      <td class="inputnmbr"><input name="class" type="text" value="$(V_QDCLAS)" size="50" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_QDCLAS)

                  @RtvFldDesc("FUID='$(V_QDURLID)'", "SYURLM", "FUDESC", fieldDesc)
                  @SetTextOvr(Err_QDURLID)
                  <tr><td class="dsphdr"><span $(textOvr)>URL ID</span></td>
                      <td class="inputalph"><input name="urlID" type="text" value="$(V_QDURLID)" size="50" maxlength="55"><a href="$(homeURL)$(cGIPath)URLSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=urlID&amp;fldDesc=urlIDDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="urlIDDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_QDURLID)

                  @dtw_assign(checked, "")
                  %if (V_QDRESV == "Y")
                      @dtw_assign(checked, "CHECKED")
                  %endif
                  @SetTextOvr(Err_QDRESV)
                  <tr><td class="dsphdr"><span $(textOvr)>Reserved Row On Update</span></td>
                      <td class="dspalph"><input type="checkbox" name="reserved"  value="Y"  $(checked)></td>
                  </tr>
                  @DspErrMsg(Err_QDRESV)
              </table>
    			
              %}

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                              CHAR(2)     dataBaseID,
                                              CHAR(1)     maintenanceCode,
                                              CHAR(1)     errFound,
                                              CHAR(32000) edtVar,                             	
                                              CHAR(32000) errVar)
{%EXEC {HSYQLN_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@d2wn", quickLinkD2W)
  @Concat_Field("@@link", quickLink)
  @Concat_Field("@@desc", quickLinkDesc)
  @Concat_Field("@@nrow", quickLinkRows)
  @Concat_Field("@@imgn", imageName)
  @Concat_Field("@@clas", class)
  @Concat_Field("@@urli", urlID)
  @Concat_Field("@@resv", reserved)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, "$(quickLinkD2W) - $(quickLink)", "", "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@d2wn", "quickLinkD2W")
          @Format_ConfMsg_Desc("", "$(quickLinkD2W) - $(quickLink)", "", "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=161&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;quickLinkD2W=@dtw_rurlescseq(quickLinkD2W)&amp;quickLink=@dtw_rurlescseq(quickLink)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
