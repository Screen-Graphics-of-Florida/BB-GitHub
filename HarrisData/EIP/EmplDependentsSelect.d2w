%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title           = "Spouse/Dependent"
  d2wName              = "EmplDependentsSelect.d2w"
  attachFolder         = "EmployeeDependents"
  d2wVarBase           = "$(genericVarBase)$(employeeVarBase)&amp;dependentNbr=@dtw_rurlescseq(dependentNbr)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(d2wName)"
  programName          = "HPESDU"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  applicationID        = "PE"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  UVPREmpl             = "00000"
  UVHRComp             = "00"
  attachVarKey         = ""
  attachForDesc        = ""
  quickLinksInUse      = "N"
  dataType             = "SSNO"
  modeD                = "D"
  modeI                = "I"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
  @dtw_replace(workURL, "@@dependentNbr", "@dtw_rurlescseq(dependentNbr)", "1", "a", workURL)
  @dtw_replace(workURL, "@@fromD2w", "@dtw_rurlescseq(fromD2w)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL_Display (INOUT stmtSQL) {	
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script type="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                          @dtw_assign(pageID, "EMPLDEPDISPLAY ")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          @dtw_concat(stmtSQL, "SELECT * FROM HRSPDP ", stmtSQL)
                          @dtw_concat(stmtSQL, " WHERE SDCOMP = $(prCompany) and SDFACL = $(prFacility) and SDEMPL = $(hrEmployee) and SDSPDP = $(dependentNbr)", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @Empl_Dependent_Display_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- Start Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Empl_Dependent_Display_Query(IN CHAR(64)    profileHandle,
                                                   CHAR(2)     dataBaseID,
                                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT {
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "ProgSecurityTestView.icl"
      %if (pgmOptAuth=="F")
          <table $(contentTable)>
              <tr><td><h1> $(page_title)</h1></td></tr>
              <tr><td><h1> Not Available </h1></td></tr>
          </table>
      %else
          @RetDepNam(profileHandle, dataBaseID, dependentNbr, depName)
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  @dtw_assign(dependentNbrFilled, "$(dependentNbr)")
                  %while(@dtw_rlength(dependentNbrFilled) != "7") {@dtw_insert("0", dependentNbrFilled, dependentNbrFilled)%}
                  @dtw_assign(attachVarKey, "$(dependentNbrFilled)")
                  @dtw_assign(attachForDesc, depName)
                  @dtw_assign(attachPrg1, "HRSPDP Where SDCOMP=$(prCompany) and SDFACL=$(prFacility) and SDEMPL=$(hrEmployee) and SDSPDP=$(dependentNbr)")
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if (backHome != "$(d2wName)/REPORT" && backHome != "")
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Return To Employee">$(portalHome)</a>
                          %endif
                          %INCLUDE "Attachment.icl"
                          %if (sec_01 == "Y")
                              <a href="$(homeURL)$(cGIPath)EmplDependentsMaintain.d2w/EMPLDEPENDENTS$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                          %endif
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)EmplDependentsMaintain.d2w/EMPLDEPENDENTS$(d2wVarBase)&amp;maintenanceCode=C">$(changeImageLrg)</a>
                          %endif
                          %if (sec_03 == "Y")
                              @RtvFldDesc("SDSPDP=$(dependentNbr)", "HRSPDP", "SDLNAM", lastName)
                              @RtvFldDesc("SDSPDP=$(dependentNbr)", "HRSPDP", "SDFNAM", firstName)
                              @RtvFldDesc("SDSPDP=$(dependentNbr)", "HRSPDP", "SDSSN", socialSecurityNo)
                              @Format_EmplName(firstName, lastName, "", "", "", "D", F_dependentName)
                              @Format_Confirm_Desc($(F_dependentName), "", "", "", "", "", confirmDesc)
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)EmplDependentsMaintain.d2w/Edit_Data$(d2wVarBase)&amp;firstName=@dtw_rurlescseq(firstName)&amp;lastName=@dtw_rurlescseq(lastName)&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                          %endif
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>

              @Ret_Format_EmplName(prCompany, prFacility, UVPREmpl, hrCompany, hrEmployee, "H", F_EmpName)
              <tr><td><h2>Dependent of $(F_EmpName)</h2></td></tr>

          </table>
          %INCLUDE "ConfMessageDisplay.icl"

          $(hrTagAttr)

      %endif

      <table $(contentTable)>
          %ROW{
              %if (sec_05 == "Y")
              	  @RtvColVal("SDCOMP = $(prCompany) and SDFACL = $(prFacility) and SDEMPL = $(hrEmployee) and SDSPDP = $(dependentNbr)", "HRSPDP", "(SDSSN)", "I", xsocsec) 
                  @dtw_assign(V_SDSSN, xsocsec)
                  
                  %if (V_SDSSN == "")
                      @dtw_assign(F_SDSSN, "         ")
                  %else
                      @Format_SSN(V_SDSSN, F_SDSSN)
                  %endif
                  
                  <tr><td class="dsphdr">Social Security Number</td>
                      <td class="dspnmbr">$(F_SDSSN)</td></tr>

                  <tr><td class="dsphdr">Social Security Suffix</td>
                      <td class="dspalph">$(V_SDSSSF)</td></tr>

                  <tr><td class="dsphdr">Last Name</td>
                      <td class="dspalph">$(V_SDLNAM)</td></tr>

                  <tr><td class="dsphdr">First Name</td>
                      <td class="dspalph">$(V_SDFNAM)</td></tr>

                  <tr><td class="dsphdr">Middle Initial</td>
                      <td class="dspalph">$(V_SDMIDI)</td></tr>

                  <tr><td class="dsphdr">Address Line 1</td>
                      <td class="dspalph">$(V_SDADR1)</td></tr>

                  <tr><td class="dsphdr">Address Line 2</td>
                      <td class="dspalph">$(V_SDADR2)</td></tr>

                  <tr><td class="dsphdr">City</td>
                      <td class="dspalph">$(V_SDCITY)</td></tr>

                  @RtvFldDesc("STID='$(V_SDSTAT)'", "PRSTID", "STDESC", stateDescription)
                  <tr><td class="dsphdr">State</td>
    		       <td class="dspalph">$(stateDescription)</td>
                  %if (V_SDPROV != "")
                      @RtvFldDesc("FLTYPE='PROVINCE' and FLVALU='$(V_SDPROV)'", "SYFLAG", "FLDESC", provinceDescription)
                      <tr><td class="dsphdr">Canadian Province</td>
    		           <td class="dspalph">$(provinceDescription)</td>
                  %endif
                  <tr><td class="dsphdr">Zip Code</td>
                      <td class="dspalph">$(V_SDZIP)</td></tr>

                  @RtvFldDesc("HRCNTR='$(V_SDCNTR)'", "HRCNTY", "HRCNNM", countryDescription)
                  <tr><td class="dsphdr">Country</td>
    		       <td class="dspalph">$(countryDescription)</td>

                  <tr><td class="dsphdr">Home Phone Number</td>
                      @EditPhoneNumber(V_SDPHON)
                      <td class="dspalph">$(V_SDPHON)</td></tr>

                  @Format_Date(V_SDDOB, "H", F_SDDOB)
                  <tr><td class="dsphdr">Date Of Birth</td>
                      <td class="dspdate">$(F_SDDOB)</td></tr>

                  @RtvFldDesc("FLTYPE='DEPCLASS' and FLVALU='$(V_SDCLAS)'", "SYFLAG", "FLDESC", classDescription)
                  <tr><td class="dsphdr">Classification</td>
    		       <td class="dspalph">$(classDescription)</td>

                  <tr><td class="dsphdr">Relationship</td>
                      <td class="dspalph">$(V_SDrel)</td></tr>

                  @RtvFldDesc("FLTYPE='GENDER' and FLVALU='$(V_SDGNDR)'", "SYFLAG", "FLDESC", genderDescription)
                  <tr><td class="dsphdr">Gender</td>
    		       <td class="dspalph">$(genderDescription)</td>
              %endif
          %}
      </table>
      %INCLUDE "AttachmentSQL.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%INCLUDE "AttachmentSelect.icl"

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL_Display(stmtSQL)
  %endif
%}