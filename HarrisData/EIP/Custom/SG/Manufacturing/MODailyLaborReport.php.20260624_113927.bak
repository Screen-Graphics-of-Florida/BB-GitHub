          display: flex; align-items: center;
          justify-content: space-between; }
.topbar h1 { font-size: 15px; font-weight: 700; }
.topbar-right { display: flex; align-items: center; gap: 10px;
                font-size: 11px; color: #b8cfee; flex-shrink: 0; }
