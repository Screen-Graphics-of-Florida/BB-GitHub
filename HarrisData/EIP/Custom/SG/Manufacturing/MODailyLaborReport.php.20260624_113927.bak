/* ── Standard refresh bar ── */
.refresh-bar { background: #fff; border-bottom: 1px solid #c8d0de;
               padding: 5px 16px; display: flex; align-items: center;
               gap: 12px; font-size: 12px; color: #1a2233; }
.refresh-dot { color: #22c55e; font-size: 16px; line-height: 1; flex-shrink: 0; }
.refresh-dot--off { color: #94a3b8; }
.refresh-lbl { white-space: nowrap; }
.refresh-prog-wrap { flex: 1; height: 6px; background: #dde3ee;
                     border-radius: 3px; overflow: hidden; min-width: 80px; }
.refresh-prog-fill { height: 100%; background: #1e40af;
                     border-radius: 3px; width: 100%; }
.refresh-next, .refresh-last { white-space: nowrap; }
.refresh-asof { background: #f59e0b; color: #7c2d12; font-weight: 700;
                padding: 2px 10px; border-radius: 10px;
                font-size: 11px; white-space: nowrap; flex-shrink: 0; }
</style>
</head>
