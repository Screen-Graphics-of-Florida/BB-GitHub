%{  Shareware version in which the back flush code, qty per, scrap percent and reason code
    has been added to the list of components.         Matt  4/2018
*********************************************************************
* Copr 1979 2003 An Unpublished Work By Harris Business Group, Inc. *
* All rights reserved. This work contains trade secrets.            *
*                  					             *
*  Job: Select Mfg Order                                            *
*********************************************************************
%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NoteComment.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title           = "Mfg Order*** $(mfgOrder)"
  d2wName              = "SelectMfgOrder.d2w"
  attachFolder         = "MfgOrder"
  d2wVarBase           = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;mfgOrder=@dtw_rurlescseq(mfgOrder)&amp;touchScreen=@dtw_rurlescseq(touchScreen)"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  RPT_MAX_ROWS	       = "1000"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  rowIndexNext	       = "1"
  totalPages	       = "0"	
  documentType	       = "RTG"	
  OHCQTY               = "0"	
  formatToPrint        = ""	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          %if (touchScreen == "Y")
              <link rel=stylesheet type="text/css" href="$(homeURL)$(homePath)HDSTouchScreen.css">
          %endif
          <script TYPE="text/javascript">
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
%{ quicklinkSeqTable %}
                          @QuicklinkSequence(profileHandle, dataBaseID, d2wName, quicklinkSeqTable)
                          @dtw_tb_rows(quicklinkSeqTable,quicklinkCount)
                          %if (quicklinkCount == "0" || quicklinkCount == "")
                              @dtw_assign(quicklinkCount, "0")
                          %endif
	
%{ Mfg Order Header %}
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " HDMOHM ", fileSQL)
                          @dtw_concat(selectSQL, "OHPLT=$(plantNumber) and OHORD='$(mfgOrder)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                          @Mfg_Order_Header(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Display Loop %}
                          @dtw_assign(x, "1")
                          %while(x <= quicklinkCount) {
                              @dtw_tb_getv(quicklinkSeqTable, x, "1", quicklinkRef)
                              @dtw_lowercase(quicklinkRef,quicklinkRef)
                              @dtw_tb_getv(quicklinkSeqTable, x, "2", quicklinkTitle)
                              @dtw_tb_getv(quicklinkSeqTable, x, "3", quicklinkMaxRows)
                              @dtw_assign(dspMaxRows, RPT_MAX_ROWS)

    %{ General %}
                              %if (quicklinkRef == "general")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDMOHM ", fileSQL)
                                  @dtw_concat(selectSQL, "OHPLT=$(plantNumber) and OHORD='$(mfgOrder)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Mfg_Order_General(profileHandle, dataBaseID, stmtSQL)
                              %endif
    %{ Quantities %}
                              %if (quicklinkRef == "quantities")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDMOHM ", fileSQL)
                                  @dtw_concat(selectSQL, "OHPLT=$(plantNumber) and OHORD='$(mfgOrder)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Mfg_Order_Quantities(profileHandle, dataBaseID, stmtSQL)
                              %endif
    %{ Transactions %}
                              %if (quicklinkRef == "transactions")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDMHDM ", fileSQL)
                                  @dtw_concat(selectSQL, "HDPLT=$(plantNumber) and HDORD='$(mfgOrder)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Mfg_Order_Trans(profileHandle, dataBaseID, stmtSQL)
                              %endif
    %{ Components %}
                              %if (quicklinkRef == "components")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDMCRM ", fileSQL)
                                  @dtw_concat(selectSQL, "CRPPLT=$(plantNumber) and CRORD='$(mfgOrder)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Mfg_Order_Comp(profileHandle, dataBaseID, stmtSQL)
                              %endif
    %{ Add On Costs %}
                              %if (quicklinkRef == "addoncosts")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " IVGLDD ", fileSQL)
                                  @dtw_concat(selectSQL, "IVPLT=$(plantNumber) and IVMORD='$(mfgOrder)' and IVIVTT='ADON' and IVAMT<0  ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Mfg_Order_AddOnCosts(profileHandle, dataBaseID, stmtSQL)
                              %endif
    %{ Order Variance %}
                              %if (quicklinkRef == "ordervariance")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDMOVM ", fileSQL)
                                  @dtw_concat(selectSQL, "OVPLT=$(plantNumber) and OVORD='$(mfgOrder)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Mfg_Order_Variance(profileHandle, dataBaseID, stmtSQL)
                              %endif
    %{ Labor Hours %}
                              %if (quicklinkRef == "laborhours")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDMLPM ", fileSQL)
                                  @dtw_concat(selectSQL, "LPPLT=$(plantNumber) and LPORD='$(mfgOrder)' and LPALTC<>'A' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Mfg_Order_Labor_Hours(profileHandle, dataBaseID, stmtSQL)
                              %endif
    %{ Labor Quantities %}
                              %if (quicklinkRef == "laborquantities")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDMLPM ", fileSQL)
                                  @dtw_concat(selectSQL, "LPPLT=$(plantNumber) and LPORD='$(mfgOrder)' and LPALTC<>'A' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Mfg_Order_Labor_Quantities(profileHandle, dataBaseID, stmtSQL)
                              %endif

    %{ Attachments %}         %INCLUDE "AttachmentSQL.icl"

                              @dtw_add(x, "1", x)
                          %}
%{ Quicklink Display Loop END %}

                      $(inquiryhrTagAttr)
                      %if (touchScreen == "Y")
                          @dtw_assign(formatToPrint, "Y")
                      %endif
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}


%FUNCTION(dtw_sql) Mfg_Order_Header (IN CHAR(64)    profileHandle,
			                 CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %ROW{
          %if (touchScreen == "Y")
              <div class="quickLinksTop">
                  <ul class="toolbarTS">
                      <li class="optionTS"><a href="javascript:window.close()">&nbsp;<br>Close</a></li>
                  </ul>
              </div>
          %endif
          @RtvFldDesc("PLPLNT=$(V_OHPLT)", "HDPLNT", "PLNAME", plantName)
          @RtvFldDesc("IMITEM='$(V_OHPN)'", "HDIMST", "IMIMDS", itemDescription)
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  @dtw_assign(attachPltKey, plantNumber)
                  %while(@dtw_rlength(attachPltKey) != "3") {@dtw_insert("0", attachPltKey, attachPltKey) %}
                  @dtw_assign(attachVarKey, "$(attachPltKey)$(mfgOrder)")
                  @dtw_assign(attachForDesc, "Plant $(plantNumber) $(plantName) <br>Mfg Order $(mfgOrder)")
                  @dtw_assign(attachPrg1, "HDMOHM Where OHPLT=$(plantNumber) and OHORD='$(mfgOrder)'")
                  %if (formatToPrint != "Y" && touchScreen != "Y")
                      <td class="toolbar">
                           <a href="javascript:opener.document.location='$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=445&amp;fKey1=OHORD&amp;fVal1=@dtw_rurlescseq(V_OHORD)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))';window.close();" title="Select Mfg Order">$(changeImageLrg)</a>
                          %INCLUDE "Attachment.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
          </table>

          <table $(contentTable)>
              @dtw_assign(OHCQTY, V_OHCQTY)
              @Format_Header("Plant", $(plantName), $(plantNumber))
              @Format_Header("Item", $(itemDescription), $(V_OHPN))
          </table>
      %}
      %INCLUDE "ConfMessageDisplay.icl"
      $(inquiryhrTagAttr)
      %INCLUDE "QuickLinkDisplay.icl"
  %}
%}

%FUNCTION(dtw_sql) Mfg_Order_General (IN CHAR(64)    profileHandle,
				          CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="general"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %ROW{
              @RtvFldDesc("PLPLNT=$(V_OHPLT)", "HDPLNT", "PLNAME", plantName)
              @Format_Code(V_OHPLT, F_OHPLT)
              <tr><td class="dsphdr">Plant Number</td>
                  <td class="dspnmbr">$(plantName)</td>
                  <td class="dspnmbr">$(F_OHPLT)</td>
              </tr>

              @RtvFldDesc("IMITEM='$(V_OHPN)'", "HDIMST", "IMIMDS", itemDescription)
              @Format_Code(V_OHPN, F_OHPN)
              <tr><td class="dsphdr">Item Number</td>
                  <td class="dspnmbr">$(itemDescription)</td>
                  <td class="dspnmbr">$(F_OHPN)</td>
              </tr>

              %if (V_OHRORD != "")
                  <tr><td class="dsphdr">Reference Number</td>
                      <td class="dspnmbr">$(V_OHRORD)</td>
                  </tr>
              %endif

              @RtvFldDesc("FLTYPE='MFGORDTYPE' and FLVALU='$(V_OHOTYP)'", "SYFLAG", "FLDESC", orderTypeDesc)
              @Format_Code(V_OHOTYP, F_OHOTYP)
              <tr><td class="dsphdr">Order Type</td>
                  <td class="dspnmbr">$(orderTypeDesc)</td>
                  <td class="dspnmbr">$(F_OHOTYP)</td>
              </tr>

              @RtvFldDesc("FLTYPE='MFGORDSTAT' and FLVALU='$(V_OHSTC)'", "SYFLAG", "FLDESC", orderStatusDesc)
              @Format_Code(V_OHSTC, F_OHSTC)
              <tr><td class="dsphdr">Status Code</td>
                  <td class="dspnmbr">$(orderStatusDesc)</td>
                  <td class="dspnmbr">$(F_OHSTC)</td>
              </tr>
            	   	
              @Format_Date_ISO(V_OHCSDT, "H", F_OHCSDT)
              <tr><td class="dsphdr">Start Date</td>
                  <td class="dspnmbr">$(F_OHCSDT)</td>
              </tr>
            	   	
              @Format_Date_ISO(V_OHCDDT, "H", F_OHCDDT)
              <tr><td class="dsphdr">Due Date</td>
                  <td class="dspnmbr">$(F_OHCDDT)</td>
              </tr>

              %if (V_OHORD# > "0")	   	
                  <tr><td class="dsphdr">Sales Order Number</td>
                      <td class="dspnmbr">$(V_OHORD#)</td>
                  </tr>
                	   	
                  @Format_Date_ISO(V_OHORDT, "H", F_OHORDT)
                  <tr><td class="dsphdr">Order Date</td>
                      <td class="dspnmbr">$(F_OHORDT)</td>
                  </tr>
              %endif
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Mfg_Order_Quantities (IN CHAR(64)    profileHandle,
				             CHAR(2)     dataBaseID,
                                            CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="quantities"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("OHCQTY", "Ordered")
                  @Format_Column_Header("OHQTYR", "Received")
                  @Format_Column_Header("OHRSCR", "Scrapped")
                  @Format_Column_Header("xxx", "Balance")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Nbr($(V_OHCQTY), F_OHCQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_OHQTYR), F_OHQTYR, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_OHRSCR), F_OHRSCR, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @dtw_assign(balanceQty, @dtw_rsubtract(V_OHCQTY, @dtw_radd(V_OHQTYR, V_OHRSCR)))
              @Format_Nbr($(balanceQty), F_balanceQty, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              <tr class="$(rowClass)">
                  <td class="colnmbr">$(F_OHCQTY)</td>
                  <td class="colnmbr">$(F_OHQTYR)</td>
                  <td class="colnmbr">$(F_OHRSCR)</td>
                  <td class="colnmbr">$(F_balanceQty)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Mfg_Order_Trans (IN CHAR(64)    profileHandle,
				        CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="transactions"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("HDDATE", "Trans<br>Date")
                  @Format_Column_Header("HDXN", "Trans<br>Code")
                  @Format_Column_Header("HDREC", "Receipt<br>Quantity")
                  @Format_Column_Header("HDRSCR", "Scrapped<br>Quantity")
                  @Format_Column_Header("HDCODE", "Hold<br>Code")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Date_ISO(V_HDDATE, "D", F_HDDATE)
              @Format_Nbr($(V_HDREC), F_HDREC, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_HDRSCR), F_HDRSCR, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              <tr class="$(rowClass)">
        	   <td class="coldate">$(F_HDDATE)</td>
        	   <td class="colalph">$(V_HDXN)</td>
        	   <td class="colnmbr">$(F_HDREC)</td>
        	   <td class="colnmbr">$(F_HDRSCR)</td>
        	   <td class="colcode">$(V_HDCODE)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Mfg_Order_Comp (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="components"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("CRCPN", "Component<br>Item")
                  @Format_Column_Header("xxx", "Description")
                  @Format_Column_Header("CRSEQN", "Rtg<br>Seq")

%{EXT-BEG - add backflush, qty per, scrap percent & reasons code section 1 of 2  4/2018    %}
                  @Format_Column_Header("CRFSTK", "Backflush<br>Code")
		  @Format_Column_Header("CRREAS", "Reason<br>Code")
		  @Format_Column_Header("CRQPER", "Qty<br>Per")
		  @Format_Column_Header("CRSCPP", "Scrap<br>Percent")
                  @Format_Column_Header("CRRQTY", "Required<br>Quantity")
                  @Format_Column_Header("CRQTYI", "Issued<br>Quantity")
                  @Format_Column_Header("CRQTYS", "Scrapped<br>Quantity")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Nbr($(V_CRQPER), F_CRQPER, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_CRSCPP), F_CRSCPP, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_CRRQTY), F_CRRQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_CRQTYI), F_CRQTYI, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_CRQTYS), F_CRQTYS, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @RtvFldDesc("IMITEM='$(V_CRCPN)'", "HDIMST", "IMIMDS", itemDescription)
              <tr class="$(rowClass)">
    	           <td class="colalph">$(V_CRCPN)</td>
    	           <td class="colalph"><a href="$(homeURL)$(cGIPath)ComponentDetailInquiry.d2w/REPORT$(d2wVarBase)&amp;compItem=@dtw_rurlescseq(V_CRCPN)&amp;rtgSeqn=@dtw_rurlescseq(V_CRSEQN)" onclick="$(inquiryDetailWinVar)" title="Component Detail Quickview">$(itemDescription)</a></td>
    	           <td class="colnmbr">$(V_CRSEQN)</td>

%{EXT-BEG - add backflush, qty per, scrap percent & reason code section 2 of 2   %}
                   <td class="colalph">$(V_CRFSTK)</td>
                   <td class="colalph">$(V_CRREAS)</td>
    	           <td class="colnmbr">$(F_CRQPER)</td>
    	           <td class="colnmbr">$(F_CRSCPP)</td>
    	           <td class="colnmbr">$(F_CRRQTY)</td>
    	           <td class="colnmbr">$(F_CRQTYI)</td>
    	           <td class="colnmbr">$(F_CRQTYS)</td>
    	       </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Mfg_Order_AddOnCosts (IN CHAR(64)    profileHandle,
				             CHAR(2)     dataBaseID,
                                            CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="addoncosts"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("IVTRDT", "Trans<br>Date")
                  @Format_Column_Header("IVQTY", "Quantity")
                  @Format_Column_Header("IVAMT", "Amount")
                  @Format_Column_Header("xxx", "G/L Account")
                  @Format_Column_Header("xxx", "Account Description")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Date(V_IVTRDT, "D", F_IVTRDT)
              @Format_Nbr($(V_IVQTY), F_IVQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_IVAMT), F_IVAMT, "2", "2", "", "", "")
              @Format_Acct("$(V_IVACCT)", "$(V_IVSUB)", "", F_AcctSub)
              @Format_CoFac("$(V_IVCO)", "$(V_IVFAC)", "", F_CoFac)
              @RtvFldDesc("CHACCT=$(V_IVACCT) and CHSUB=$(V_IVSUB)", "HDCHRT", "CHCHDS", acctDesc)
              <tr class="$(rowClass)">
       	   <td class="colalph">$(F_IVTRDT)</td>
        	   <td class="colalph">$(F_IVQTY)</td>
        	   <td class="colnmbr">$(F_IVAMT)</td>
        	   <td class="colnmbr">$(F_CoFac) $(F_AcctSub)</td>
        	   <td class="colnmbr">$(acctDesc)</td>
    	       </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Mfg_Order_Variance (IN CHAR(64)    profileHandle,
				           CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="ordervariance"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLCC1D", cat1Desc)
              @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLCC2D", cat2Desc)
              @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLCC3D", cat3Desc)
              @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLCC4D", cat4Desc)
              @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLCC5D", cat5Desc)
              <tr>
                  @Format_Column_Header("xxx", "$(cat1Desc)")
                  @Format_Column_Header("xxx", "$(cat2Desc)")
                  @Format_Column_Header("xxx", "$(cat3Desc)")
                  @Format_Column_Header("xxx", "$(cat4Desc)")
                  @Format_Column_Header("xxx", "$(cat5Desc)")
                  @Format_Column_Header("xxx", "Total")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Nbr($(V_OVC1DV), F_OVC1DV, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_OVC2DV), F_OVC2DV, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_OVC3DV), F_OVC3DV, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_OVC4DV), F_OVC4DV, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_OVC5DV), F_OVC5DV, "2", $(amtEditCode), "", "", "")
              @dtw_assign(totalVar, @dtw_radd(V_OVC1DV, @dtw_radd(V_OVC2DV, @dtw_radd(V_OVC3DV, @dtw_radd(V_OVC4DV, V_OVC5DV)))))
              @Format_Nbr(totalVar, F_totalVar, "2", $(amtEditCode), "Y", "", "")
              <tr class="$(rowClass)">
    	           <td class="colnmbr">$(F_OVC1DV)</td>
    	           <td class="colnmbr">$(F_OVC2DV)</td>
    	           <td class="colnmbr">$(F_OVC3DV)</td>
    	           <td class="colnmbr">$(F_OVC4DV)</td>
    	           <td class="colnmbr">$(F_OVC5DV)</td>
    	           <td class="colnmbr">$(F_totalVar)</td>
    	       </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Mfg_Order_Labor_Hours (IN CHAR(64)    profileHandle,
				              CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="laborhours"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("xxx", "Rtg<br>Seq")
                  @Format_Column_Header("xxx", "Dept")
                  @Format_Column_Header("xxx", "Work<br>Center")
                  @Format_Column_Header("xxx", "Description")
                  @Format_Column_Header("xxx", "Rtg<br>Type")
                  @Format_Column_Header("xxx", "Alt<br>Oper")
                  @Format_Column_Header("xxx", "Measured<br>Hours")
                  @Format_Column_Header("xxx", "Ref<br>Code")
                  @Format_Column_Header("xxx", "Std<br>Setup<br>Hours")
                  @Format_Column_Header("xxx", "Actual<br>Setup<br>Hours")
                  @Format_Column_Header("xxx", "Std<br>Labor<br>Hours")
                  @Format_Column_Header("xxx", "Actual<br>Labor<br>Hours")
                  @Format_Column_Header("xxx", "Actual<br>Indirect<br>Hours")
                  @Format_Column_Header("xxx", "Actual<br>Rework<br>Hours")
                  @Format_Column_Header("xxx", "Transit<br>Days")
                  @Format_Column_Header("xxx", "Crew<br>Size")
                  @Format_Column_Header("xxx", "Oper")
                  @Format_Column_Header("xxx", "Description")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Get_Labor_Notes(profileHandle, dataBaseID, plantNumber, mfgOrder, V_LPSEQN, documentType, comment)
              @Format_Nbr($(V_LPMHRS), F_LPMHRS, $(hrsNbrDec), $(hrsEditCode), "", "", "")
              @Format_Nbr($(V_LPSUHR), F_LPSUHR, $(hrsNbrDec), $(hrsEditCode), "", "", "")
              @Format_Nbr($(V_LPACTD), F_LPACTD, $(hrsNbrDec), $(hrsEditCode), "", "", "")
              @Format_Nbr($(V_LPACTI), F_LPACTI, $(hrsNbrDec), $(hrsEditCode), "", "", "")
              @Format_Nbr($(V_LPACTS), F_LPACTS, $(hrsNbrDec), $(hrsEditCode), "", "", "")
              @Format_Nbr($(V_LPACTR), F_LPACTR, $(hrsNbrDec), $(hrsEditCode), "", "", "")
              @Format_Nbr($(V_LPMPON), F_LPMPON, "2", $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_LPMTD), F_LPMTD, "1", $(qtyEditCode), "", "", "")
              @RtvFldDesc("WCPLT=$(V_LPPLT) and WCDEPT='$(V_LPDEPT)' and WCWC='$(V_LPWC)'", "HDMWCM", "WCDESC", workCenterDesc)
              @RtvFldDesc("SDSON='$(V_LPSON)'", "HDMSDM", "SDDESC", operDesc)

              %if (V_LPMHRC == "M")
                  @dtw_assign(refCode, "1000")
              %elif (V_LPMHRC == "H")
                  @dtw_assign(refCode, "100")
              %else
                  @dtw_assign(refCode, "1")
              %endif
              @dtw_assign(stdHrs, @dtw_rformat(@dtw_rdivide(@dtw_rmultiply(OHCQTY, V_LPMHRS), refCode), "21", "2", "0", "", "23"))
              @Format_Nbr(stdHrs, F_stdHrs, $(hrsNbrDec), $(hrsEditCode), "Y", "", "")
              @RtvFldDesc("FLTYPE='RTGTYPE' AND FLVALU='$(V_LPRTYP)'", "SYFLAG", "FLDESC", rtgTypeDesc)
              @RtvFldDesc("FLTYPE='RTMHRC' AND FLVALU='$(V_LPMHRC)'", "SYFLAG", "FLDESC", refCodeDesc)
              @RtvFldDesc("FLTYPE='ALTOPER' AND FLVALU='$(V_LPALTC)'", "SYFLAG", "FLDESC", altOperDesc)

              <tr class="$(rowClass)">
    	           <td class="colnmbr">$(V_LPSEQN)</td>
    	           <td class="colalph">$(V_LPDEPT)</td>
    	           <td class="colalph">$(V_LPWC)</td>
    	           <td class="colalph"><a href="$(homeURL)$(cGIPath)LaborDetailInquiry.d2w/REPORT$(d2wVarBase)&amp;rtgSeqn=@dtw_rurlescseq(V_LPSEQN)" onclick="$(inquiryDetailWinVar)" title="Labor Detail Quickview">$(workCenterDesc)</a></td>
                  <td class="colcode" $(helpCursor)><span title="$(rtgTypeDesc)">$(V_LPRTYP)</span></td>
                  <td class="colcode" $(helpCursor)><span title="$(altOperDesc)">$(V_LPALTC)</span></td>
    	           <td class="colnmbr">$(F_LPMHRS)</td>
                  <td class="colcode" $(helpCursor)><span title="$(refCodeDesc)">$(V_LPMHRC)</span></td>
    	           <td class="colnmbr">$(F_LPSUHR)</td>
    	           <td class="colnmbr">$(F_LPACTS)</td>
    	           <td class="colnmbr">$(F_stdHrs)</td>
    	           <td class="colnmbr">$(F_LPACTD)</td>
    	           <td class="colnmbr">$(F_LPACTI)</td>
    	           <td class="colnmbr">$(F_LPACTR)</td>
    	           <td class="colnmbr">$(F_LPMTD)</td>
    	           <td class="colnmbr">$(F_LPMPON)</td>
    	           <td class="colalph">$(V_LPSON)</td>
    	           <td class="colalph">$(operDesc)</td>
    	       </tr>
              %if (comment != "")
                  <tr class="$(rowClass)">
                      <td colspan="3">&nbsp;</td>
                          @dtw_chartohex(comment, hexValue)
                          @dtw_length(hexValue, fldLength)
                          @dtw_assign(printRows, "0")
                          @dtw_assign(x, "1")
                          %while(x <= fldLength){
                              @dtw_pos("0D", hexValue, x, y)
                              %if (y > "0")
                                  @dtw_add(printRows, "1", printRows)
                                  @dtw_add(y, "4", x)
                              %else
                                  @dtw_add(fldLength, "1", x)
                              %endif
                          %}
                      <td class="colalph" colspan="11"><textarea style="overflow:hidden" readonly ROWS=$(printRows) COLS=60 WRAP="hard">$(comment)</textarea></td>
    	           </tr>
              %endif
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Mfg_Order_Labor_Quantities (IN CHAR(64)    profileHandle,
				                   CHAR(2)     dataBaseID,
                                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="laborquantities"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("xxx", "Rtg<br>Seq")
                  @Format_Column_Header("xxx", "Dept")
                  @Format_Column_Header("xxx", "Work<br>Center")
                  @Format_Column_Header("xxx", "Description")
                  @Format_Column_Header("xxx", "Received")
                  @Format_Column_Header("xxx", "Completed")
                  @Format_Column_Header("xxx", "Rework")
                  @Format_Column_Header("xxx", "Scrapped")
                  @Format_Column_Header("xxx", "To<br>Vendor")
                  @Format_Column_Header("xxx", "From<br>Vendor")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @RtvFldDesc("WCPLT=$(V_LPPLT) and WCDEPT='$(V_LPDEPT)' and WCWC='$(V_LPWC)'", "HDMWCM", "WCDESC", workCenterDesc)
              @Format_Nbr($(V_LPQTYR), F_LPQTYR, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_LPQTYC), F_LPQTYC, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_LPRWQY), F_LPRWQY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_LPRSCR), F_LPRSCR, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_LPTVQT), F_LPTVQT, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_LPFVQT), F_LPFVQT, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              <tr class="$(rowClass)">
    	           <td class="colnmbr">$(V_LPSEQN)</td>
    	           <td class="colalph">$(V_LPDEPT)</td>
    	           <td class="colalph">$(V_LPWC)</td>
    	           <td class="colalph"><a href="$(homeURL)$(cGIPath)LaborDetailInquiry.d2w/REPORT$(d2wVarBase)&amp;rtgSeqn=@dtw_rurlescseq(V_LPSEQN)" onclick="$(inquiryDetailWinVar)" title="Labor Detail Quickview">$(workCenterDesc)</a></td>
    	           <td class="colnmbr">$(F_LPQTYR)</td>
    	           <td class="colnmbr">$(F_LPQTYC)</td>
    	           <td class="colnmbr">$(F_LPRWQY)</td>
    	           <td class="colnmbr">$(F_LPRSCR)</td>
    	           <td class="colnmbr">$(F_LPTVQT)</td>
    	           <td class="colnmbr">$(F_LPFVQT)</td>
    	       </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%INCLUDE "AttachmentSelect.icl"

