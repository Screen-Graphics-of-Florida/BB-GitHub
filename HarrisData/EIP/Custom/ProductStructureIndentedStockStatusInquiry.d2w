%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Indented Stock Status **"
  d2wName                 = "ProductStructureIndentedStockStatusInquiry.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;touchScreen=@dtw_rurlescseq(touchScreen)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "25"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  quantityRequired        = ""
%}
	
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %if (touchScreen == "Y")
              <link rel=stylesheet type="text/css" href="$(homeURL)$(homePath)HDSTouchScreen.css">
          %endif
          <script type="text/javascript">
              function confirmPrint() {return confirm("Confirm Print of Stock Status");}
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
                  function validate(searchForm) {
                      if (editNum(document.Search.quantityRequired, 11, 0))
                          return true;
              }
              %if (touchScreen == "Y")
                  %INCLUDE "KeyboardFunctionsTS.icl"
              %endif
           </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onLoad="window.focus()" onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " PDM099", fileSQL)
                      @dtw_concat(selectSQL, " PZXHND='$(profileHandle)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By PZXHND, PZRSEQ ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @ProdStr_Inquiry(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) ProdStr_Inquiry (IN CHAR(64)    profileHandle,
				        CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (touchScreen == "Y")
          @dtw_assign(formatToPrint, "Y")
          <div class="quickLinksTop">
              <ul class="toolbarTS">
                  <li class="optionTS"><a href="javascript:window.close()">&nbsp;<br>Close</a></li>
              </ul>
          </div>
      %endif
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
      <table $(contentTable)>
          @Format_Header("Plant", $(plantName), $(plantNumber))
          @Format_Header("Item", $(itemDescription), $(itemNumber))
      </table>
      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return false;" ACTION="$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)">
          <table $(contentTable)>
              <tr><td class="dsphdr">Quantity Required</td>
                  <td class="inputnmbr">
                      %if (touchScreen == "Y")
                          <input class="input" id="quantityRequired" onfocus="kbActive(this, 'numericKeyboard');" name="quantityRequired" value="$(quantityRequired)" type="text" size="11" maxlength="11">
                          <input type="hidden" id="submitSearch">
                      %else
                          <input type="text" name="quantityRequired" value="$(quantityRequired)" size="11" maxlength="11">
                      %endif
                  </td>
                  <td><a href="javascript:check(document.Search)">$(signOnImage)</a></td>
              </tr>
          </table>
      </form>

      $(inquiryhrTagAttr)
      <table $(contentTable)>
         <tr>


              <th class="colhdr">Item Number</th>
              <th class="colhdr">Description</th>
              <th class="colhdr">P<br>T</th>
              <th class="colhdr">St<br>UM</th>
              <th class="colhdr">BOM<br>Level</th>
              <th class="colhdr">Required<br>Quantity</th>
              <th class="colhdr">On Hand<br>Quantity</th>
              <th class="colhdr">Available<br>Quantity</th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">

 %{ EXT-BEG  Turn item into a link to Available to Promise
             and item description into a link to Item/Plant page.
             Replacing these lines
                 <td class="colalph">$(V_PZCPN)</td>
                 <td class="colalph">$(V_PZIMDS)</td>

             with the next two lines below this commented section.

Both target pages need both plant and plant name and item number and item description.
We must pass them therefore these four piecees of data or it will fail.
Here's the syntax for that:
"plantNumber=@dtw_rurlescseq(plantNumber)"
              and
"plantName=@dtw_rurlescseq(plantName)"
              and
"itemNumber=@dtw_rurlescseq(V_PZCPN)"
              and
"itemDescription=@dtw_rurlescseq(V_PZIMDS)"


Note that "plantNumber" and "plantName" variables had already been defined further up in the page.
That's why we can reference those terms instead of the field name as we do for part number(V_PZCPN)
where PZCPN is literally the component part number in the file PDM099.

Also note, to signify that another parameter is coming, each parameter [except the last]
must be followed by this:
&amp;

End Notes  %}


<td class="colalph"><a href="$(homeURL)$(cGIPath)AvailableToPromise.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_PZCPN)&amp;itemDescription=@dtw_rurlescseq(V_PZCPN)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;plantName=@dtw_rurlescseq(plantName)" title="View Available to Promise">$(V_PZCPN)</a></td>
<td class="colalph"><a href="$(homeURL)$(cGIPath)ItemPlantSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_PZIMDS)&amp;itemDescription=@dtw_rurlescseq(V_PZIMDS)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;plantName=@dtw_rurlescseq(plantName)" title="View Item/Plant">$(V_PZIMDS)</a></td>

%{ EXT-END   %}


                 <td class="colcode">$(V_PZPTYP)</td>
                 <td class="colalph">$(V_PZUOMS)</td>
                 <td class="colalph">$(V_PZLVL)</td>
                 <td class="colnmbr">$(V_PZXPER)</td>
                 <td class="colnmbr">$(V_PZOHQT)</td>
                 <td class="colnmbr">$(V_PZAVQT)</td>
              </tr>
          %}
      </table>
      $(inquiryhrTagAttr)
      %INCLUDE "Copyright.icl"
      %if (touchScreen == "Y")
         %INCLUDE "KeyboardTS.icl"
      %endif
  %}
%}

%FUNCTION(dtw_directcall) Create_Work_File (IN    CHAR(64)    profileHandle,
                                                  CHAR(32000) edtVar)

{%EXEC {HSI255_W.PGM %}
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  %if (quantityRequired == "")
      @DTW_ASSIGN(quantityRequired, "1")
  %endif
  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@item", itemNumber)
  @Concat_Field("@@rqty", quantityRequired)
  @Concat_Field("@print", printReport)
  @dtw_concat(edtVar, "}{", edtVar)
  @Create_Work_File (profileHandle, edtVar)
  @Set_SQL(stmtSQL)
%}