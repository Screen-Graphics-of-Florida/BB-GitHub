%{ Pop up windows like the image display can be handled in different
ways using Net.Data.  

As an unsupported, undocumented contribution tothe customer zone, 
here  is an example where we've changed the display to
support browser interactions which might allow the user to email the
image directly from the Portals page.          
*********************************************************************
* Copr 1979 2003 An Unpublished Work By Harris Business Group, Inc. *
* All rights reserved. This work contains trade secrets.            *
*                  					             *
*  Job: Image Display                                               *
*********************************************************************
%}

%INCLUDE "$(baseVar)"

%Define {
  page_title              = "Image Display"
  DATABASE                = "*LOCAL"
%}

%HTML(DISPLAY) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
      </head>

%{ EXT-BEG   Trying to make emailing images of items easier   Matt %}

%{ removed the onBlur entry from the original line to keep the window from closing too soon %}
%{      <body $(bodyTagAttr) onLoad="window.focus()" onBlur="window.close()">   %}

%{ Heres the new line %}
        <body $(bodyTagAttr) onLoad="window.focus()">

%{ EXT-END   Trying to make emailing images of items easier   Matt %}
          <!-- Start Of Banner Code -->
          %INCLUDE "$(imageBanner)"
          <!-- End Of Banner Code -->

          %if (imageDesc !="")
              <h2 align="center">$(imageDesc)</h2>
          %endif

          $(hrTagAttr)

          <table $(contentTable)>
              <tr><td><img src="$(imageDisplayPath)" hspace="25%" alt="No Picture Found"></td></tr>
	   </table>

          $(hrTagAttr)

	   <table $(contentTable)>
              <tr><td>%INCLUDE "CloseWindow.icl"</td></tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(imageTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}