                              <a href="javascript:calWindow('xdate03');">$(calendarImage)</a></td>
                      </tr>
                      @DspErrMsg(Err_IXUXD3)
                  %endif

                  %if (itemExtDate4 != "")		
                      @SetTextOvr(Err_IXUXD4)
                      <tr><td class="dsphdr"><span $(textOvr)>$(itemExtDate4)</span></td>
                          <td class="inputnmbr"><input type="text" name="xdate04" value="$(V_IXUXD4)" size="6" maxlength="6"> 		
                              <a href="javascript:calWindow('xdate04');">$(calendarImage)</a></td>
                      </tr>
                      @DspErrMsg(Err_IXUXD4)
                  %endif

                  %if (itemExtDate5 != "")		
                      @SetTextOvr(Err_IXUXD5)
                      <tr><td class="dsphdr"><span $(textOvr)>$(itemExtDate5)</span></td>
                          <td class="inputnmbr"><input type="text" name="xdate05" value="$(V_IXUXD5)" size="6" maxlength="6"> 		
                              <a href="javascript:calWindow('xdate05');">$(calendarImage)</a></td>
                      </tr>
                      @DspErrMsg(Err_IXUXD5)
                  %endif
              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Retrieve_Category(INOUT CHAR(64) profileHandle,
                                            INOUT CHAR(2) dataBaseID,
                                            INOUT CHAR(15) category,
                                            INOUT CHAR(50) categoryDesc,
                                            INOUT CHAR(50) catalogHeaderPage,
                                            INOUT CHAR(256) categoryImage,
                                            INOUT CHAR(75) error)
  {%EXEC {HOECTR_W.PGM %}
  %}

%FUNCTION(dtw_directcall) Validate_Data(IN    CHAR(64)    profileHandle,
                                        IN    CHAR(2)     dataBaseID,
                                        IN    CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HHDIMU_W.PGM %}
  %}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Kit_Query(profileHandle, dataBaseID, "KIT       ", kitTable)
      @Lot_Query(profileHandle, dataBaseID, "LOT       ", lotTable)
      @UPCBar_Query(profileHandle, dataBaseID, "UPCBAR    ", upcBarTable)
      @Quality_Query(profileHandle, dataBaseID, "QUALCONTRL", qualityTable)
      @PartType_Query(profileHandle, dataBaseID, "PARTTYPE  ", partTypeTable)
          @dtw_tb_insertrow(partTypeTable, "0", "1")

      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @yn02_Table_Query(profileHandle, dataBaseID, "YORN      ", yn02Table)
      @yn03_Table_Query(profileHandle, dataBaseID, "YORN      ", yn03Table)

      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(itemNumber)
  @dtw_mUPPERCASE(alphaSequence)
  @dtw_mUPPERCASE(productClass)
  @dtw_mUPPERCASE(stockUOM)
  @dtw_mUPPERCASE(inventoryType)
  @dtw_mUPPERCASE(weightUOM)
  @dtw_mUPPERCASE(cubicUOM)
  @dtw_mUPPERCASE(catalog)
  @dtw_mUPPERCASE(alpha01)
  @dtw_mUPPERCASE(alpha02)
  @dtw_mUPPERCASE(alpha03)
  @dtw_mUPPERCASE(alpha04)
  @dtw_mUPPERCASE(alpha05)
  @dtw_assign(numeric01,@dtw_rstrip(numeric01))
  @dtw_assign(numeric02,@dtw_rstrip(numeric02))
  @dtw_assign(numeric03,@dtw_rstrip(numeric03))
  @dtw_assign(numeric04,@dtw_rstrip(numeric04))
  @dtw_assign(numeric05,@dtw_rstrip(numeric05))
  @dtw_assign(xnumeric01,@dtw_rstrip(xnumeric01))
  @dtw_assign(xnumeric02,@dtw_rstrip(xnumeric02))
  @dtw_assign(xnumeric03,@dtw_rstrip(xnumeric03))
  @dtw_assign(xnumeric04,@dtw_rstrip(xnumeric04))
  @dtw_assign(xnumeric05,@dtw_rstrip(xnumeric05))
  @dtw_assign(xdate01,@dtw_rstrip(xdate01))
  @dtw_assign(xdate02,@dtw_rstrip(xdate02))
  @dtw_assign(xdate03,@dtw_rstrip(xdate03))
  @dtw_assign(xdate04,@dtw_rstrip(xdate04))
  @dtw_assign(xdate05,@dtw_rstrip(xdate05))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  %if (lotItem == "")
      @dtw_assign(lotItem, "N")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@imac", status)
  @Concat_Field("@@item", itemNumber)
  @Concat_Field("@@fitm", fromItem)
  @Concat_Field("@@imds", itemDescription)
  @Concat_Field("@@pcls", productClass)
  @Concat_Field("@@uoms", stockUOM)
  @Concat_Field("@@imwg", weight)
  @Concat_Field("@@uomw", weightUOM)
  @Concat_Field("@@alph", alphaSequence)
  @Concat_Field("@@kit@", kitItem)
  @Concat_Field("@@dshp", dropShipItem)
  @Concat_Field("@@lot@", lotItem)
  @Concat_Field("@@uda1", alpha01)
  @Concat_Field("@@uda2", alpha02)
  @Concat_Field("@@uda3", alpha03)
  @Concat_Field("@@uda4", alpha04)
  @Concat_Field("@@uda5", alpha05)
  @Concat_Field("@@udn1", numeric01)
  @Concat_Field("@@udn2", numeric02)
  @Concat_Field("@@udn3", numeric03)
  @Concat_Field("@@udn4", numeric04)
  @Concat_Field("@@udn5", numeric05)
  @Concat_Field("@@cszs", cubicSize)
  @Concat_Field("@@cuum", cubicUOM)
  @Concat_Field("@@ptyp", partType)
  @Concat_Field("@@catn", catalog)
  @Concat_Field("@@itc@", inventoryType)
  @Concat_Field("@@qual", qualityControl)
  @Concat_Field("@@hazm", hazMaterial)
  @Concat_Field("@@upc@", upcNumber)
  @Concat_Field("@@upct", upcBar)
  @Concat_Field("@@ctds", catalogDesc)
  @Concat_Field("@@cdyn", displayInCat)
  @Concat_Field("@@imgn", image)
  @Concat_Field("@@ctg1", category1)
  @Concat_Field("@@ctg2", category2)
  @Concat_Field("@@ctg3", category3)
  @Concat_Field("@@ctg4", category4)
  @Concat_Field("@@ctg5", category5)
  @Concat_Field("@@uxa1", xalpha01)
  @Concat_Field("@@uxa2", xalpha02)
  @Concat_Field("@@uxa3", xalpha03)
  @Concat_Field("@@uxa4", xalpha04)
  @Concat_Field("@@uxa5", xalpha05)
  @Concat_Field("@@uxn1", xnumeric01)
  @Concat_Field("@@uxn2", xnumeric02)
  @Concat_Field("@@uxn3", xnumeric03)
  @Concat_Field("@@uxn4", xnumeric04)
  @Concat_Field("@@uxn5", xnumeric05)
  @Concat_Field("@@uxd1", xdate01)
  @Concat_Field("@@uxd2", xdate02)
  @Concat_Field("@@uxd3", xdate03)
  @Concat_Field("@@uxd4", xdate04)
  @Concat_Field("@@uxd5", xdate05)
  @Concat_Field("@@uhtm", userHTMLPage)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(itemDescription), $(itemNumber), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@item", "itemNumber")
          @Format_ConfMsg_Desc("", $(itemDescription), $(itemNumber), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      %if (fromSel == "Y" && maintenanceCode != "D")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ItemSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;itemDescription=@dtw_rurlescseq(itemDescription)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
          %if (backURL == "")
              <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=224&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %else
              <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %endif
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
