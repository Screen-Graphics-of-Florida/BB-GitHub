%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "ItemMaintain.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Item Maintenance"
  d2wName                 = "ItemMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromSel=@dtw_rurlescseq(fromSel)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;itemDescription=@dtw_rurlescseq(itemDescription)&amp;maintenanceCode=D"
  programName             = "HHDIMU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (maintenanceCode == "A")
      @dtw_assign(userPass, "Y")
  %else
      @ItemUserView(profileHandle, dataBaseID, userPass, itemNumber)
  %endif
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              %if (V_HDPDRL == "0")
                  @dtw_assign(z, "1")
                  @dtw_tb_rows(kitTable, kitTableCount)
                  %while(z <= kitTableCount) {
                      %if (@dtw_tb_rgetv(kitTable, z, "1") == "F" || @dtw_tb_rgetv(kitTable, z, "1") == "C")
                          @dtw_tb_deleterow(kitTable, z, "1")
                          @dtw_subtract(kitTableCount, "1", kitTableCount)
                      %else
                          @dtw_add(z, "1", z)
                      %endif
                  %}
              %endif

              @dtw_assign(editFields, "")
              %if (V_CIINS1 != "")		
                  @dtw_concat(editFields, " editNum(document.Chg.numeric01, 8, 5) && ", editFields)
              %endif
              %if (V_CIINS2 != "")		
                  @dtw_concat(editFields, " editNum(document.Chg.numeric02, 8, 5) && ", editFields)
              %endif
              %if (V_CIINS3 != "")		
                  @dtw_concat(editFields, " editNum(document.Chg.numeric03, 8, 5) && ", editFields)
              %endif
              %if (V_CIINS4 != "")		
                  @dtw_concat(editFields, " editNum(document.Chg.numeric04, 8, 5) && ", editFields)
              %endif
              %if (V_CIINS5 != "")		
                  @dtw_concat(editFields, " editNum(document.Chg.numeric05, 8, 5) && ", editFields)
              %endif
              %if (itemExtNum1 != "")		
                  @dtw_concat(editFields, " editNum(document.Chg.xnumeric01, 8, 5) && ", editFields)
              %endif
              %if (itemExtNum2 != "")		
                  @dtw_concat(editFields, " editNum(document.Chg.xnumeric02, 8, 5) && ", editFields)
              %endif
              %if (itemExtNum3 != "")		
                  @dtw_concat(editFields, " editNum(document.Chg.xnumeric03, 8, 5) && ", editFields)
              %endif
              %if (itemExtNum4 != "")		
                  @dtw_concat(editFields, " editNum(document.Chg.xnumeric04, 8, 5) && ", editFields)
              %endif
              %if (itemExtNum5 != "")		
                  @dtw_concat(editFields, " editNum(document.Chg.xnumeric05, 8, 5) && ", editFields)
              %endif
              %if (itemExtDate1 != "")		
                  @dtw_concat(editFields, " editdate(document.Chg.xdate01) && ", editFields)
              %endif
              %if (itemExtDate2 != "")		
                  @dtw_concat(editFields, " editdate(document.Chg.xdate02) && ", editFields)
              %endif
              %if (itemExtDate3 != "")		
                  @dtw_concat(editFields, " editdate(document.Chg.xdate03) && ", editFields)
              %endif
              %if (itemExtDate4 != "")		
                  @dtw_concat(editFields, " editdate(document.Chg.xdate04) && ", editFields)
              %endif
              %if (itemExtDate5 != "")		
                  @dtw_concat(editFields, " editdate(document.Chg.xdate05) && ", editFields)
              %endif

              <script TYPE="text/javascript">
                  %INCLUDE "calendar.icl"
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "dateedit.icl"
                  %INCLUDE "Menu.js"
                  %INCLUDE "numedit.icl"
                  function confirmDelete() {return confirm("$(delRecordConf)")}
                  function confirmInactive(text) {alert("Warning - All Item/Warehouse rows for Item $(itemNumber) will be set to inactive");}
                  function validate(chgForm) {
                      if (document.Chg.itemNumber.value =="" ||
                          document.Chg.itemDescription.value =="" )
                         {alert("$(reqFieldError)"); return false;}
                      if ($(editFields)
                          editNum(document.Chg.upcNumber, 14, 0) &&
                          editNum(document.Chg.weight, 4, 3) &&
                          editNum(document.Chg.cubicSize, 5, 4))
                          return true;
                  }
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "ITEMMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, " Select HDIMST.*, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(IXCTDS,' ') as IXCTDS, coalesce(IXUXA5,' ') as IXUXA5, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(IXCDYN,' ') as IXCDYN, coalesce(IXUXN1,0)   as IXUXN1, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(IXIMGN,' ') as IXIMGN, coalesce(IXUXN2,0)   as IXUXN2, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(IXCTG1,' ') as IXCTG1, coalesce(IXUXN3,0)   as IXUXN3, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(IXCTG2,' ') as IXCTG2, coalesce(IXUXN4,0)   as IXUXN4, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(IXCTG3,' ') as IXCTG3, coalesce(IXUXN5,0)   as IXUXN5, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(IXCTG4,' ') as IXCTG4, coalesce(IXUXD1,'0001-01-01')   as IXUXD1, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(IXCTG5,' ') as IXCTG5, coalesce(IXUXD2,'0001-01-01')   as IXUXD2, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(IXUXA1,' ') as IXUXA1, coalesce(IXUXD3,'0001-01-01')   as IXUXD3, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(IXUXA2,' ') as IXUXA2, coalesce(IXUXD4,'0001-01-01')   as IXUXD4, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(IXUXA3,' ') as IXUXA3, coalesce(IXUXD5,'0001-01-01')   as IXUXD5, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(IXUXA4,' ') as IXUXA4, coalesce(IXUHTM,' ') as IXUHTM  ", stmtSQL)
                              @dtw_concat(fileSQL, " HDIMST left join HDIMSX on IMITEM=IXITEM ", fileSQL)
                              @dtw_concat(selectSQL, "IMITEM='$(itemNumber)' ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN  CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=224")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "itemNumber")
                      %else
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @dtw_assign(focusField, "")
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@imac", "status")          @dtw_assign(Err_IMIMAC, fieldValue)
                          @DecatErr_Field("@@item", "itemNumber")      @dtw_assign(Err_IMITEM, fieldValue)
                          @DecatErr_Field("@@imds", "itemDescription") @dtw_assign(Err_IMIMDS, fieldValue)
                          @DecatErr_Field("@@pcls", "productClass")    @dtw_assign(Err_IMPCLS, fieldValue)
                          @DecatErr_Field("@@uoms", "stockUOM")        @dtw_assign(Err_IMUOMS, fieldValue)
                          @DecatErr_Field("@@imwg", "weight")          @dtw_assign(Err_IMIMWG, fieldValue)
                          @DecatErr_Field("@@uomw", "weightUOM")       @dtw_assign(Err_IMUOMW, fieldValue)
                          @DecatErr_Field("@@alph", "alphaSequence")   @dtw_assign(Err_IMALPH, fieldValue)
                          @DecatErr_Field("@@kit@", "kitItem")         @dtw_assign(Err_IMKIT,  fieldValue)
                          @DecatErr_Field("@@dshp", "dropShipItem")    @dtw_assign(Err_IMDSHP, fieldValue)
                          @DecatErr_Field("@@lot@", "lotItem")         @dtw_assign(Err_IMLOT,  fieldValue)
                          @DecatErr_Field("@@uda1", "alpha01")         @dtw_assign(Err_IMUDA1, fieldValue)
                          @DecatErr_Field("@@uda2", "alpha02")         @dtw_assign(Err_IMUDA2, fieldValue)
                          @DecatErr_Field("@@uda3", "alpha03")         @dtw_assign(Err_IMUDA3, fieldValue)
                          @DecatErr_Field("@@uda4", "alpha04")         @dtw_assign(Err_IMUDA4, fieldValue)
                          @DecatErr_Field("@@uda5", "alpha05")         @dtw_assign(Err_IMUDA5, fieldValue)
                          @DecatErr_Field("@@udn1", "numeric01")       @dtw_assign(Err_IMUDN1, fieldValue)
                          @DecatErr_Field("@@udn2", "numeric02")       @dtw_assign(Err_IMUDN2, fieldValue)
                          @DecatErr_Field("@@udn3", "numeric03")       @dtw_assign(Err_IMUDN3, fieldValue)
                          @DecatErr_Field("@@udn4", "numeric04")       @dtw_assign(Err_IMUDN4, fieldValue)
                          @DecatErr_Field("@@udn5", "numeric05")       @dtw_assign(Err_IMUDN5, fieldValue)
                          @DecatErr_Field("@@cszs", "cubicSize")       @dtw_assign(Err_IMCSZS, fieldValue)
                          @DecatErr_Field("@@cuum", "cubicUOM")        @dtw_assign(Err_IMCUUM, fieldValue)
                          @DecatErr_Field("@@ptyp", "partType")        @dtw_assign(Err_IMPTYP, fieldValue)
                          @DecatErr_Field("@@catn", "catalog")         @dtw_assign(Err_IMCATN, fieldValue)
                          @DecatErr_Field("@@itc@", "inventoryType")   @dtw_assign(Err_IMITC,  fieldValue)
                          @DecatErr_Field("@@qual", "qualityControl")  @dtw_assign(Err_IMQUAL, fieldValue)
                          @DecatErr_Field("@@hazm", "hazMaterial")     @dtw_assign(Err_IMHAZM, fieldValue)
                          @DecatErr_Field("@@upc@", "upcNumber")       @dtw_assign(Err_IMUPC,  fieldValue)
                          @DecatErr_Field("@@upct", "upcBar")          @dtw_assign(Err_IMUPCT, fieldValue)

                          @DecatErr_Field("@@ctds", "catalogDesc")     @dtw_assign(Err_IXCTDS, fieldValue)
                          @DecatErr_Field("@@cdyn", "displayInCat")    @dtw_assign(Err_IXCDYN, fieldValue)
                          @DecatErr_Field("@@imgn", "image")           @dtw_assign(Err_IXIMGN, fieldValue)
                          @DecatErr_Field("@@ctg1", "category1")       @dtw_assign(Err_IXCTG1, fieldValue)
                          @DecatErr_Field("@@ctg2", "category2")       @dtw_assign(Err_IXCTG2, fieldValue)
                          @DecatErr_Field("@@ctg3", "category3")       @dtw_assign(Err_IXCTG3, fieldValue)
                          @DecatErr_Field("@@ctg4", "category4")       @dtw_assign(Err_IXCTG4, fieldValue)
                          @DecatErr_Field("@@ctg5", "category5")       @dtw_assign(Err_IXCTG5, fieldValue)
                          @DecatErr_Field("@@uxa1", "xalpha01")        @dtw_assign(Err_IXUXA1, fieldValue)
                          @DecatErr_Field("@@uxa2", "xalpha02")        @dtw_assign(Err_IXUXA2, fieldValue)
                          @DecatErr_Field("@@uxa3", "xalpha03")        @dtw_assign(Err_IXUXA3, fieldValue)
                          @DecatErr_Field("@@uxa4", "xalpha04")        @dtw_assign(Err_IXUXA4, fieldValue)
                          @DecatErr_Field("@@uxa5", "xalpha05")        @dtw_assign(Err_IXUXA5, fieldValue)
                          @DecatErr_Field("@@uxn1", "xnumeric01")      @dtw_assign(Err_IXUXN1, fieldValue)
                          @DecatErr_Field("@@uxn2", "xnumeric02")      @dtw_assign(Err_IXUXN2, fieldValue)
                          @DecatErr_Field("@@uxn3", "xnumeric03")      @dtw_assign(Err_IXUXN3, fieldValue)
                          @DecatErr_Field("@@uxn4", "xnumeric04")      @dtw_assign(Err_IXUXN4, fieldValue)
                          @DecatErr_Field("@@uxn5", "xnumeric05")      @dtw_assign(Err_IXUXN5, fieldValue)
                          @DecatErr_Field("@@uxd1", "xdate01")         @dtw_assign(Err_IXUXD1, fieldValue)
                          @DecatErr_Field("@@uxd2", "xdate02")         @dtw_assign(Err_IXUXD2, fieldValue)
                          @DecatErr_Field("@@uxd3", "xdate03")         @dtw_assign(Err_IXUXD3, fieldValue)
                          @DecatErr_Field("@@uxd4", "xdate04")         @dtw_assign(Err_IXUXD4, fieldValue)
                          @DecatErr_Field("@@uxd5", "xdate05")         @dtw_assign(Err_IXUXD5, fieldValue)
                          @DecatErr_Field("@@uhtm", "userHTMLPage")    @dtw_assign(Err_IXUHTM, fieldValue)
                      %endif

                      @Decat_Field("@@imac")   @dtw_assign(V_IMIMAC, fieldValue)
                      @Decat_Field("@@item")   @dtw_assign(V_IMITEM, fieldValue)
                      @Decat_Field("@@fitm")   @dtw_assign(V_IMFITM, fieldValue)
                      @Decat_Field("@@imds")   @dtw_assign(V_IMIMDS, fieldValue)
                      @Decat_Field("@@pcls")   @dtw_assign(V_IMPCLS, fieldValue)
                      @Decat_Field("@@uoms")   @dtw_assign(V_IMUOMS, fieldValue)
                      @Decat_Field("@@imwg")   @dtw_assign(V_IMIMWG, fieldValue)
                      @Decat_Field("@@uomw")   @dtw_assign(V_IMUOMW, fieldValue)
                      @Decat_Field("@@alph")   @dtw_assign(V_IMALPH, fieldValue)
                      @Decat_Field("@@kit@")   @dtw_assign(V_IMKIT,  fieldValue)
                      @Decat_Field("@@dshp")   @dtw_assign(V_IMDSHP, fieldValue)
                      @Decat_Field("@@lot@")   @dtw_assign(V_IMLOT,  fieldValue)
                      @Decat_Field("@@uda1")   @dtw_assign(V_IMUDA1, fieldValue)
                      @Decat_Field("@@uda2")   @dtw_assign(V_IMUDA2, fieldValue)
                      @Decat_Field("@@uda3")   @dtw_assign(V_IMUDA3, fieldValue)
                      @Decat_Field("@@uda4")   @dtw_assign(V_IMUDA4, fieldValue)
                      @Decat_Field("@@uda5")   @dtw_assign(V_IMUDA5, fieldValue)
                      @Decat_Field("@@udn1")   @dtw_assign(V_IMUDN1, fieldValue)
                      @Decat_Field("@@udn2")   @dtw_assign(V_IMUDN2, fieldValue)
                      @Decat_Field("@@udn3")   @dtw_assign(V_IMUDN3, fieldValue)
                      @Decat_Field("@@udn4")   @dtw_assign(V_IMUDN4, fieldValue)
                      @Decat_Field("@@udn5")   @dtw_assign(V_IMUDN5, fieldValue)
                      @Decat_Field("@@cszs")   @dtw_assign(V_IMCSZS, fieldValue)
                      @Decat_Field("@@cuum")   @dtw_assign(V_IMCUUM, fieldValue)
                      @Decat_Field("@@ptyp")   @dtw_assign(V_IMPTYP, fieldValue)
                      @Decat_Field("@@catn")   @dtw_assign(V_IMCATN, fieldValue)
                      @Decat_Field("@@itc@")   @dtw_assign(V_IMITC,  fieldValue)
                      @Decat_Field("@@qual")   @dtw_assign(V_IMQUAL, fieldValue)
                      @Decat_Field("@@hazm")   @dtw_assign(V_IMHAZM, fieldValue)
                      @Decat_Field("@@upc@")   @dtw_assign(V_IMUPC,  fieldValue)
                      @Decat_Field("@@upct")   @dtw_assign(V_IMUPCT, fieldValue)

                      @Decat_Field("@@ctds")   @dtw_assign(V_IXCTDS, fieldValue)
                      @Decat_Field("@@cdyn")   @dtw_assign(V_IXCDYN, fieldValue)
                      @Decat_Field("@@imgn")   @dtw_assign(V_IXIMGN, fieldValue)
                      @Decat_Field("@@ctg1")   @dtw_assign(V_IXCTG1, fieldValue)
                      @Decat_Field("@@ctg2")   @dtw_assign(V_IXCTG2, fieldValue)
                      @Decat_Field("@@ctg3")   @dtw_assign(V_IXCTG3, fieldValue)
                      @Decat_Field("@@ctg4")   @dtw_assign(V_IXCTG4, fieldValue)
                      @Decat_Field("@@ctg5")   @dtw_assign(V_IXCTG5, fieldValue)
                      @Decat_Field("@@uxa1")   @dtw_assign(V_IXUXA1, fieldValue)
                      @Decat_Field("@@uxa2")   @dtw_assign(V_IXUXA2, fieldValue)
                      @Decat_Field("@@uxa3")   @dtw_assign(V_IXUXA3, fieldValue)
                      @Decat_Field("@@uxa4")   @dtw_assign(V_IXUXA4, fieldValue)
                      @Decat_Field("@@uxa5")   @dtw_assign(V_IXUXA5, fieldValue)
                      @Decat_Field("@@uxn1")   @dtw_assign(V_IXUXN1, fieldValue)
                      @Decat_Field("@@uxn2")   @dtw_assign(V_IXUXN2, fieldValue)
                      @Decat_Field("@@uxn3")   @dtw_assign(V_IXUXN3, fieldValue)
                      @Decat_Field("@@uxn4")   @dtw_assign(V_IXUXN4, fieldValue)
                      @Decat_Field("@@uxn5")   @dtw_assign(V_IXUXN5, fieldValue)
                      @Decat_Field("@@uxd1")   @dtw_assign(V_IXUXD1, fieldValue)
                      @Decat_Field("@@uxd2")   @dtw_assign(V_IXUXD2, fieldValue)
                      @Decat_Field("@@uxd3")   @dtw_assign(V_IXUXD3, fieldValue)
                      @Decat_Field("@@uxd4")   @dtw_assign(V_IXUXD4, fieldValue)
                      @Decat_Field("@@uxd5")   @dtw_assign(V_IXUXD5, fieldValue)
                      @Decat_Field("@@uhtm")   @dtw_assign(V_IXUHTM, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(V_IMDSHP,  "N")
                          @dtw_assign(V_IMHAZM, "N")
                          @dtw_assign(V_IMLOT, "N")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "itemNumber")
                      @dtw_assign(V_IMFITM, V_IMITEM)
                      @dtw_assign(V_IMITEM, "")
                      @DateInputFromISO("$(V_IXUXD1)", V_IXUXD1)
                      @DateInputFromISO("$(V_IXUXD2)", V_IXUXD2)
                      @DateInputFromISO("$(V_IXUXD3)", V_IXUXD3)
                      @DateInputFromISO("$(V_IXUXD4)", V_IXUXD4)
                      @DateInputFromISO("$(V_IXUXD5)", V_IXUXD5)

                  %elif (maintenanceCode != "A")
                      @dtw_assign(V_IMFITM, "")
                      @dtw_assign(focusField, "itemDescription")
                      @DateInputFromISO("$(V_IXUXD1)", V_IXUXD1)
                      @DateInputFromISO("$(V_IXUXD2)", V_IXUXD2)
                      @DateInputFromISO("$(V_IXUXD3)", V_IXUXD3)
                      @DateInputFromISO("$(V_IXUXD4)", V_IXUXD4)
                      @DateInputFromISO("$(V_IXUXD5)", V_IXUXD5)
                      @DateInputFromCYMD(V_CFDTES)
                      @DateInputFromCYMD(V_CFDTDE)
                  %endif

                  %if (sec_05=="Y")
                      %if (V_IMIMAC=="I")
                          @dtw_assign(active, "")
                          @dtw_assign(inactive, "CHECKED")
                      %else
                          @dtw_assign(active, "CHECKED")
                          @dtw_assign(inactive, "")
                      %endif
                      %if (maintenanceCode!="A" && maintenanceCode!="Z")
                          <tr><td class="dsphdr">Status</td>
                              <td class="inputcode"><input name="status" type="radio" VALUE=' ' $(active)>Active &nbsp; <input onClick="return confirmInactive()" name="status" type="radio" VALUE='I' $(inactive)>Inactive</td>
                          </tr>
                      %endif
                  %else
                      <tr><td><input name="status" type="hidden" VALUE="$(V_IMIMAC)"></td></tr>
                  %endif

                  @SetTextOvr(Err_IMITEM)
                  <tr><td class="dsphdr"><span $(textOvr)>Item Number</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="itemNumber" type="text" value="$(V_IMITEM)" size="15" maxlength="15"> $(reqFieldChar)
                          %if (V_IMFITM != "")
                              <input name="fromItem" type="hidden" value="$(V_IMFITM)">
                          %endif
                          </td>
                      %else
                          <td class="inputalph"><input name="itemNumber" type="hidden" value="$(V_IMITEM)" size="15" maxlength="15">$(V_IMITEM)</td>
	   	       %endif
                  </tr>
                  @DspErrMsg(Err_IMITEM)

                  @SetTextOvr(Err_IMIMDS)
                  <tr><td class="dsphdr"><span $(textOvr)>Item Description</span></td>
                      <td class="inputalph"><input name="itemDescription" type="text" value="@dtw_rqhtmlencode($(V_IMIMDS))" size="30" maxlength="30"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_IMIMDS)

                  @SetTextOvr(Err_IMALPH)
                  <tr><td class="dsphdr"><span $(textOvr)>Alpha Sequence</span></td>
                      <td class="inputalph"><input type="text" name="alphaSequence" value="$(V_IMALPH)" size="4" maxlength="4"></td>
                  </tr>
                  @DspErrMsg(Err_IMALPH)
	   		
