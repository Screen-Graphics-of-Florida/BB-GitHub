%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Mfg Order $(mfgOrder) Component Detail"
  d2wName                 = "ComponentDetailInquiry.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;mfgOrder=@dtw_rurlescseq(mfgOrder)&amp;compItem=@dtw_rurlescseq(compItem)&amp;rtgSeqn=@dtw_rurlescseq(rtgSeqn)&amp;touchScreen=@dtw_rurlescseq(touchScreen)"
  nextPrevVar             = "$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  displayCloseIcon        = "Y"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
   %INCLUDE "$(docType)"
   <html>
       <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "dateedit.icl"
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
          </script>
          %INCLUDE "$(genericHead)"
       </head>

       <body $(bodyTagAttr) onLoad="window.focus()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select CDDATE,CDXN,CDQTYI,CDQTYS,DTQTY,Coalesce(DTLOT#,' ') as DTLOT#  ", stmtSQL)
                      @dtw_concat(fileSQL, " HDMCDM left join HDDTRN on CDDATE=DTTRDT and CDCPN=DTITEM and CDPPLT=DTPLT and CDORD=DTMORD and concat(CDXN,'IN')=DTIVTT ", fileSQL)
                      @dtw_concat(selectSQL, " CDPPLT=$(plantNumber) and CDORD='$(mfgOrder)' and CDCPN='$(compItem)' and CDSEQN=$(rtgSeqn) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @ComponentDetail_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
     </body>
  </html>
%}

%FUNCTION(dtw_sql) ComponentDetail_Query (IN CHAR(64)    profileHandle,
                                             CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (touchScreen == "Y")
          @dtw_assign(displayCloseIcon, "")
          @dtw_assign(formatToPrint, "Y")
          <div class="quickLinksTop">
              <ul class="toolbarTS">
                  <li class="optionTS"><a href="javascript:window.close()">&nbsp;<br>Close</a></li>
              </ul>
          </div>
      %else
          @dtw_assign(displayCloseIcon, "Y")
      %endif
      %INCLUDE "PageTitle.icl"

      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      @RtvFldDesc("IMITEM='$(compItem)'", "HDIMST", "IMIMDS", compDescription)
      @RtvFldDesc("OHPLT=$(plantNumber) and OHORD='$(mfgOrder)'", "HDMOHM", "OHPN", itemNumber)
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
      <table $(contentTable)>
          @Format_Header("Plant", $(plantName), $(plantNumber))
          @Format_Header("Component Item", $(compDescription), $(compItem))
          @Format_Header("Parent Item", $(itemDescription), $(itemNumber))
          @Format_Header("Routing Sequence", $(rtgSeqn), "")
      </table>

      $(inquiryhrTagAttr)

      <table $(contentTable)>
          <tr><td > %INCLUDE "AssignPageValue.icl" </td></tr>
      </table>

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              @OrderBy_Sort("CDDATE", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=trxnDate" title="Sequence By Transaction Date"> Transaction<br>Date</a></th>
              @OrderBy_Sort("CDXN", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=trxnCode" title="Sequence By Transaction Code"> Transaction<br>Code</a></th>
              @OrderBy_Sort("DTQTY", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=qtyIssue" title="Sequence By Issued Quantity"> Issued<br>Quantity</a></th>
              @OrderBy_Sort("CDQTYS", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=qtyScrap" title="Sequence By Scrapped Quantity"> Scrapped<br>Quantity</a></th>
              @OrderBy_Sort("DTLOT#", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=lotNumber" title="Sequence By Lot Number"> Lot<br>Number</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %if (V_DTQTY == "")
                @DTW_ASSIGN(V_DTQTY, $(V_CDQTYI))
              %endif
              %if (V_CDXN == "Is")
                @DTW_ASSIGN(V_CDXN, "IS")
              %endif
              @Format_Date(V_CDDATE, "D", F_CDDATE)
              @Format_Nbr($(V_DTQTY), F_DTQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_CDQTYS), F_CDQTYS, $(qtyNbrDec), $(qtyEditCode), "", "", "")

              %INCLUDE "SetRowClass.icl"

              <tr class="$(rowClass)">
                  <td class="coldate">$(F_CDDATE)</td>
                  <td class="colcode">$(V_CDXN)</td>
                  <td class="colnmbr">$(F_DTQTY)</td>
                  <td class="colnmbr">$(F_CDQTYS)</td>
                  <td class="colalph">$(V_DTLOT#)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      $(inquiryhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "CDDATE")
      @DTW_ASSIGN(orderByDisplay, "Transaction Date")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "CDDATE")
      @DTW_ASSIGN(orderByDisplay, "Transaction Date")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "trxnDate")
      %if (orderBy == "CDDATE")
          @DTW_ASSIGN(orderBy, "CDDATE DESC")
          @DTW_ASSIGN(orderByDisplay, "Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CDDATE")
          @DTW_ASSIGN(orderByDisplay, "Date")
      %endif
  %elif (sequence == "trxnCode")
      %if (orderBy == "CDXN,CDDATE")
          @DTW_ASSIGN(orderBy, "CDXN DESC,CDDATE")
          @DTW_ASSIGN(orderByDisplay, "Transaction Code (descending), Date")
      %else
          @DTW_ASSIGN(orderBy, "CDXN,CDDATE")
          @DTW_ASSIGN(orderByDisplay, "Transaction Code, Date")
      %endif
  %elif (sequence == "qtyIssue")
      %if (orderBy == "DTQTY,CDDATE")
          @DTW_ASSIGN(orderBy, "DTQTY DESC,CDDATE")
          @DTW_ASSIGN(orderByDisplay, "Issued Quantity (descending), Date")
      %else
          @DTW_ASSIGN(orderBy, "DTQTY,CDDATE")
          @DTW_ASSIGN(orderByDisplay, "Issued Quantity, Date")
      %endif
  %elif (sequence == "qtyScrap")
      %if (orderBy == "CDQTYS,CDDATE")
          @DTW_ASSIGN(orderBy, "CDQTYS DESC,CDDATE")
          @DTW_ASSIGN(orderByDisplay, "Scrapped Quantity (descending), Date")
      %else
          @DTW_ASSIGN(orderBy, "CDQTYS,CDDATE")
          @DTW_ASSIGN(orderByDisplay, "Scrapped Quantity, Date")
      %endif
  %elif (sequence == "lotNumber")
      %if (orderBy == "DTLOT#,CDDATE")
          @DTW_ASSIGN(orderBy, "DTLOT# DESC,CDDATE")
          @DTW_ASSIGN(orderByDisplay, "Lot Number (descending), Date")
      %else
          @DTW_ASSIGN(orderBy, "DTLOT#,CDDATE")
          @DTW_ASSIGN(orderByDisplay, "Lot Number, Date")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}