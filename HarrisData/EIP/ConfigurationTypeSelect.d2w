%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Configuration Type"
  d2wName                 = "ConfigurationTypeSelect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(fromPlant)&amp;fromName=@dtw_rurlescseq(fromName)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;configurationType=@dtw_rurlescseq(configurationType)&amp;longDescription=@dtw_rurlescseq(longDescription)&amp;fromSel=Y"
  programName             = "HPD022"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script type="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                          @dtw_assign(pageID, "CONFIGURATIONTYPESELECT")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " HDCFGT", fileSQL)
                          @dtw_concat(selectSQL, " CYPLT = $(plantNumber) and CYCFGT = '$(configurationType)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                          @ConfigurationType_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) ConfigurationType_Query (IN  CHAR(64)    profileHandle,
                                                CHAR(2)     dataBaseID,
                                                CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)ConfigurationTypeMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (sec_01=="Y" && sec_04=="Y")
                          <a href="$(homeURL)$(cGIPath)ConfigurationTypeMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=Z">$(copyImageLrg)</a>
                      %endif
                      %if (sec_02 == "Y" || sec_03 == "Y")
                          <a href="$(homeURL)$(cGIPath)ConfigurationTypeMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=C">$(changeImageLrg)</a>
                      %endif
                      %if (sec_03 == "Y")
                          @Format_Confirm_Desc($(longDescription), $(configurationType), "", "", "", "", confirmDesc)
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)ConfigurationTypeMaintain.d2w/Edit_Data$(d2wVarBase)&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      <table $(contentTable)>
          %ROW {
              @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
              <tr><td class="dsphdr">Plant</td>
                  <td class="dspnmbr">$(V_CYPLT)</td>
                  <td class="dspalph">$(plantName)</td>
              </tr>

              <tr><td class="dsphdr">Configuration Type</td>
                  <td class="dspalph">$(V_CYCFGT)</td>
              </tr>

              <tr><td class="dsphdr">Short Description</td>
                  <td class="dspalph">$(V_CYSDSC)</td>
              </tr>

              <tr><td class="dsphdr">Long Description</td>
                  <td class="dspalph" colspan="3">$(V_CYLDSC)</td>
              </tr>

              <tr><td>&nbsp;</td>
                  <td class="colhdr">Description</td>
                  <td class="colhdr" colspan="2">Report Headings</td>
              </tr>

              <tr><td class="dsphdr">User Defined Alpha 1</td>
                  <td class="dspalph">$(V_CYAS11)</td>
                  <td class="dspalph"> $(V_CYAH11)</td>
                  <td class="dspalph"> $(V_CYAH12)</td>
              </tr>

              <tr><td class="dsphdr">User Defined Alpha 2</td>
                  <td class="dspalph"> $(V_CYAS21)</td>
                  <td class="dspalph"> $(V_CYAH21)</td>
                  <td class="dspalph"> $(V_CYAH22)</td>
              </tr>

              <tr><td class="dsphdr">User Defined Alpha 3</td>
                  <td class="dspalph"> $(V_CYAS31)</td>
                  <td class="dspalph"> $(V_CYAH31)</td>
                  <td class="dspalph"> $(V_CYAH32)</td>
              </tr>

              <tr><td class="dsphdr">User Defined Numeric 1</td>
                  <td class="dspalph"> $(V_CYNS11)</td>
                  <td class="dspalph"> $(V_CYNH11)</td>
                  <td class="dspalph"> $(V_CYNH12)</td>
              </tr>

              <tr><td class="dsphdr">User Defined Numeric 2</td>
                  <td class="dspalph"> $(V_CYNS21)</td>
                  <td class="dspalph"> $(V_CYNH21)</td>
                  <td class="dspalph"> $(V_CYNH22)</td>
              </tr>

              <tr><td class="dsphdr">User Defined Numeric 3</td>
                  <td class="dspalph"> $(V_CYNS31)</td>
                  <td class="dspalph"> $(V_CYNH31)</td>
                  <td class="dspalph"> $(V_CYNH32)</td>
              </tr>

              <tr><td class="dsphdr">User Defined Date 1</td>
                  <td class="dspalph"> $(V_CYDS11)</td>
                  <td class="dspalph"> $(V_CYDH11)</td>
                  <td class="dspalph"> $(V_CYDH12)</td>
              </tr>

              <tr><td class="dsphdr">User Defined Date 2</td>
                  <td class="dspalph"> $(V_CYDS21)</td>
                  <td class="dspalph"> $(V_CYDH21)</td>
                  <td class="dspalph"> $(V_CYDH22)</td>
              </tr>

              <tr><td class="dsphdr">User Defined Date 3</td>
                  <td class="dspalph"> $(V_CYDS31)</td>
                  <td class="dspalph"> $(V_CYDH31)</td>
                  <td class="dspalph"> $(V_CYDH32)</td>
              </tr>
          %}
      </table>
      $(hrTagAttr)	
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}