%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Chart Usage"
  d2wName                 = "ChartUsage.d2w"
  programName             = "HHDCHU"
  d2wVarBase              = "$(genericVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchAcct, 4, 0) &&
                      editNum(document.Search.srchSub, 4, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "CHARTUSAGE")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      @dtw_assign(uv_AccountName, "CUACC")
                      @dtw_assign(uv_SubaccountName, "CUSUB")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select HDCUSE.*, ifnull(CHCHDS,' ') as CHCHDS, ifnull(CFCFNM,' ') as CFCFNM ", stmtSQL)
                      @dtw_concat(fileSQL, " HDCUSE ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDCHRT on CUACC=CHACCT and CUSUB=CHSUB ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDCFAC on CUCO#=digits(CFCO#) and CUFAC#=digits(CFFAC#) ", fileSQL)
                      @dtw_concat(selectSQL, "CUACC>0 ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Chart_Usage_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Chart_Usage_Query (IN CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                      <td class="toolbar">
                          %if (backHome != "$(d2wName)/report" && backHome != "")
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)&amp;backHome=@dtw_rurlescseq(backHome)" title="Back Home">$(portalHome)</a>
                          %endif
                          %if (sec_01 == "Y")
                              <a href="$(homeURL)$(cGIPath)ChartUsageMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"
	
          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Description</th>
                          <th class="colhdr">Account</th>
                          <th class="colhdr">Co/Fac</th>
                      </tr>
                      <tr><td class="inputalph"><input type="text" name="srchDesc" size="20" maxlength="30">
                              <input type="hidden" name="operDesc" value="LIKE">
                          </td>
                          <td class="inputnmbr"><input name="srchAcct" type="text" size="4" maxlength="4"><input name="srchSub" type="text" size="4" maxlength="4">
                              <input type="hidden" name="operAcct" value="=">
                              <input type="hidden" name="operSub" value="=">
                          </td>
                          <td class="inputalph"><input name="srchCo" type="text" size="4" maxlength="2"><input name="srchFac" type="text" size="4" maxlength="4">
                              <input type="hidden" name="operCo" value="LIKE">
                              <input type="hidden" name="operFac" value="LIKE">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchDesc.focus();
                  </script>
              </form>
              %INCLUDE "WildCardPage.icl"
          %endif
	   		
          <table $(contentTable)>
              <tr>
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("CUACC", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Account" title="Sequence By Account">Account</a></th>
                  @OrderBy_Sort("CHCHDSU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description, Account">Description</a></th>
                  @OrderBy_Sort("CUCO#", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CoFac" title="Sequence By Company/Facility, Account">Co/Fac</a></th>
                  @OrderBy_Sort("CFCFNMU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Name" title="Sequence By Company/Facility Name, Account">Name</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"

              %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;accountNumber=@dtw_rurlescseq(V_CUACC)&amp;subAccountNumber=@dtw_rurlescseq(V_CUSUB)&amp;accountDesc=@dtw_rurlescseq(V_CHCHDS)&amp;companyNumber=@dtw_rurlescseq(V_CUCO#)&amp;facilityNumber=@dtw_rurlescseq(V_CUFAC#)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
                  %INCLUDE "SetRowClass.icl"

                  @Format_Acct(V_CUACC, V_CUSUB, "", F_AcctSub)
                  @Format_CoFac(V_CUCO#, V_CUFAC#, "", F_CoFac)
                  @Format_Confirm_Desc($(V_CHCHDS), $(F_AcctSub), "$(V_CFCFNM)", "$(F_CoFac)", "", "", confirmDesc)
                  @dtw_pos("?", "$(V_CUCO#)", coQ)
                  @dtw_pos("?", "$(V_CUFAC#)", facQ)
                  %if (coQ>"0" || facQ>"0")
                      @dtw_assign(V_CFCFNM, "** Wildcard **")
                  %endif

                  <tr class="$(rowClass)">
                      %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                          <td class="opticon">
                              %if (sec_04 == "Y")
                                  <a href="$(homeURL)$(cGIPath)ChartUsageMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                              %endif
                              %if (sec_03 == "Y")
                                  <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)ChartUsageMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                              %endif
                          </td>
                      %endif
                      <td class="colnmbr">$(F_AcctSub)</td>
                      <td class="colalph">$(V_CHCHDS)</a></td>
                      <td class="colnmbr">$(F_CoFac)</td>
                      <td class="colalph">$(V_CFCFNM)</a></td>
                  </tr>
              %}
          </table>
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
          $(hrTagAttr)
          %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  @dtw_assign(uv_AccountName, "CUACC")
  @dtw_assign(uv_SubaccountName, "CUSUB")
  %INCLUDE "userview.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select HDCUSE.*, ifnull(CHCHDS,' ') as CHCHDS, ifnull(CFCFNM,' ') as CFCFNM ", stmtSQL)
  @dtw_concat(fileSQL, " HDCUSE ", fileSQL)
  @dtw_concat(fileSQL, " left join HDCHRT on CUACC=CHACCT and CUSUB=CHSUB ", fileSQL)
  @dtw_concat(fileSQL, " left join HDCFAC on CUCO#=digits(CFCO#) and CUFAC#=digits(CFFAC#) ", fileSQL)
  @dtw_concat(selectSQL, "CUACC>0 ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @Chart_Usage_Export_Query(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) Chart_Usage_Export_Query (IN CHAR(64)    profileHandle,
                                                CHAR(2)     dataBaseID,
                                                CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("ChartUsageList")
          %ROW{
              @dtw_pos("?", "$(V_CUCO#)", coQ)
              @dtw_pos("?", "$(V_CUFAC#)", facQ)
              %if (coQ>"0" || facQ>"0")
                  @dtw_assign(V_CFCFNM, "** Wildcard **")
              %endif
	       @XMLIDTag("$(V_CUACC)-$(V_CUSUB)", "Account ID")
                  @XMLTag(V_CUACC, "Account")
                  @XMLTag(V_CUSUB, "SubAccount")
                  @XMLTag(V_CHCHDS, "AccountDescription")
                  @XMLTag(V_CUCO#, "Company")
                  @XMLTag(V_CUFAC#, "Facility")
                  @XMLTag(V_CFCFNM, "CoFacName")
              @XMLEndTag("Account")
          %}
      @XMLEndTag("ChartUsageList")
  %}
%}

%HTML(REPORT)
{
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "CHCHDSU,CUACC,CUSUB")
          @DTW_ASSIGN(orderByDisplay, "Name, Co/Fac")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT)
{
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(EXPORT)
{
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit ()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(ORDERBY)
{
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Account")
      %if (orderBy == "CUACC,CUSUB")
          @DTW_ASSIGN(orderBy, "CUACC DESC,CUSUB")
          @DTW_ASSIGN(orderByDisplay, "Account (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CUACC,CUSUB")
          @DTW_ASSIGN(orderByDisplay, "Account")
      %endif
  %elseif (sequence == "Desc")
      %if (orderBy == "CHCHDSU,CUACC,CUSUB")
          @DTW_ASSIGN(orderBy, "CHCHDSU DESC,CUACC,CUSUB")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Account")
      %else
          @DTW_ASSIGN(orderBy, "CHCHDSU,CUACC,CUSUB")
          @DTW_ASSIGN(orderByDisplay, "Description, Account")
      %endif
  %elseif (sequence == "CoFac")
      %if (orderBy == "CUCO#,CUFAC#,CUACC,CUSUB")
          @DTW_ASSIGN(orderBy, "CUCO# DESC,CUFAC#,CUACC,CUSUB")
          @DTW_ASSIGN(orderByDisplay, "Co/Fac (descending), Account")
      %else
          @DTW_ASSIGN(orderBy, "CUCO#,CUFAC#,CUACC,CUSUB")
          @DTW_ASSIGN(orderByDisplay, "Co/Fac, Account")
      %endif
  %elseif (sequence == "Name")
      %if (orderBy == "CFCFNMU,CUACC,CUSUB")
          @DTW_ASSIGN(orderBy, "CFCFNMU DESC,CUACC,CUSUB")
          @DTW_ASSIGN(orderByDisplay, "Name (descending), Account")
      %else
          @DTW_ASSIGN(orderBy, "CFCFNMU,CUACC,CUSUB")
          @DTW_ASSIGN(orderByDisplay, "Name, Account")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH)
{
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchAcct, 4, 0) &&
                      editNum(document.Search.srchSub, 4, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CHARTUSAGESEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Account</td>
                              @dtw_assign(operNbr, "operAcct")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchAcct" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Subaccount</td>
                              @dtw_assign(operNbr, "operSub")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchSub" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Account (alpha)</td>
                              @dtw_assign(operNbr, "operAcctAlpha")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchAcctAlpha" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Subaccount (alpha)</td>
                              @dtw_assign(operNbr, "operSubAlpha")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchSubAlpha" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchDesc" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Company</td>
                              @dtw_assign(operNbr, "operCo")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchCo" size="4" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Facility</td>
                              @dtw_assign(operNbr, "operFac")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchFac" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Name</td>
                              @dtw_assign(operNbr, "operName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchName" size="30" maxlength="30"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchAcct.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD)
{
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  %if (srchCo!="")
      %while(@dtw_rlength(srchCo) != "2") {@dtw_insert("0", srchCo, srchCo)%}
  %endif
  %if (srchFac!="")
      %while(@dtw_rlength(srchFac) != "4") {@dtw_insert("0", srchFac, srchFac)%}
  %endif

  @Build_WildCard ("CUACC", "Account", $(srchAcct), "", operAcct, "N")
  @Build_WildCard ("CUSUB", "Subaccount", $(srchSub), "", operSub, "N")
  @Build_WildCard ("CUACC", "Account (Alpha)", $(srchAcctAlpha), "", operAcctAlpha, "DG")
  @Build_WildCard ("CUSUB", "Subaccount (Alpha)", $(srchSubAlpha), "", operSubAlpha, "DG")
  @Build_WildCard ("CHCHDSU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("CUCO#", "Company", $(srchCo), "U", operCo, "A")
  @Build_WildCard ("CUFAC#", "Facility", $(srchFac), "U", operFac, "A")
  @Build_WildCard ("CFCFNMU", "Name", $(srchName), "U", operName, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
