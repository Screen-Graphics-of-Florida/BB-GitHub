%INCLUDE "$(baseVar)"
%INCLUDE "BrowserType.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Work List Optional Options"
  d2wName                 = "WFWorkListOptionalOptions.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfProcess=@dtw_rurlescseq(wfProcess)&amp;wfPoint=@dtw_rurlescseq(wfPoint)&amp;wfSequence=@dtw_rurlescseq(wfSequence)&amp;wfPassFailFlag=@dtw_rurlescseq(wfPassFailFlag)&amp;wfPassFail=@dtw_rurlescseq(wfPassFail)&amp;wfPassFailLink=@dtw_rurlescseq(wfPassFailLink)&amp;wfInstance=@dtw_rurlescseq(wfInstance)&amp;wfInstanceDate=@dtw_rurlescseq(wfInstanceDate)&amp;wfWorkItem=@dtw_rurlescseq(wfWorkItem)&amp;wfWorkItemSequence=@dtw_rurlescseq(wfWorkItemSequence)&amp;wfParticipantId=@dtw_rurlescseq(wfParticipantId)&amp;refreshD2W=@dtw_rurlescseq(refreshD2W)&amp;expireDate=@dtw_rurlescseq(expireDate)&amp;specWfInstance=@dtw_rurlescseq(specWfInstance)&amp;specWfInstanceDate=@dtw_rurlescseq(specWfInstanceDate)&amp;specWfWorkItem=@dtw_rurlescseq(specWfWorkItem)&amp;specWfWorkItemSequence=@dtw_rurlescseq(specWfWorkItemSequence)"
  DATABASE                = "*LOCAL"
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "NewWindowOpen.icl"
          </script>
      </head>
      <body $(bodyTagAttr) onLoad="window.focus();">
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @DateTodayCYMD(systemDate)

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " With TRANSITION ", stmtSQL)
                      @dtw_concat(stmtSQL, " (TRPROC,TRTPNT,TRTSEQ,TRTRID) ", stmtSQL)
                      @dtw_concat(stmtSQL, " as ( ", stmtSQL)
                      @dtw_concat(stmtSQL, " Select TRPROC,TRTPNT,TRTSEQ,TRTRID ", stmtSQL)
                      @dtw_concat(stmtSQL, " From WFPRTR ", stmtSQL)
                      @dtw_concat(stmtSQL, " inner join WFPRDT on PDPROC=TRPROC and PDPONT=TRTPNT and PDSEQ=TRTSEQ ", stmtSQL)
                      @dtw_concat(stmtSQL, " Where TRPROC='$(wfProcess)' and TRFPNT=$(wfPoint) and TRFSEQ=$(wfSequence) and TRFAIL='$(wfPassFailFlag)' and TROPT='O' and TRTPNT>0 and (TREFDT=0 or TREFDT<=$(systemDate)) and (TRETDT=0 or TRETDT>=$(systemDate)) ", stmtSQL)
                      @RtvFldDesc("TRPROC='$(wfProcess)' and TRFPNT=$(wfPoint) and TRFSEQ=$(wfSequence) and TRFAIL='$(wfPassFailFlag)' and TROPT='O' and TRTPNT=0 ", "WFPRTR", "Char(coalesce(Max(TRTRID),0))", RecCount)
                      %if (RecCount>"0")
                          @dtw_concat(stmtSQL, " UNION  ", stmtSQL)
                          @dtw_concat(stmtSQL, " Select WDPROC as TRPROC,WDTPNT as TRTPNT,WDTSEQ as TRTSEQ,$(RecCount) as TRTRID  ", stmtSQL)
                          @dtw_concat(stmtSQL, " From WFWIDP ", stmtSQL)
                          @dtw_concat(stmtSQL, " inner join WFPRDT on PDPROC=WDPROC and PDPONT=WDTPNT and PDSEQ=WDTSEQ ", stmtSQL)
                          @dtw_concat(stmtSQL, " Where WDINST=$(wfInstance) and WDINDT=$(wfInstanceDate) and WDWITM=$(wfWorkItem) and WDWISQ=$(wfWorkItemSequence) and (WDTPNT<$(wfPoint) or WDTPNT=$(wfPoint) and WDTSEQ<$(wfSequence)) ", stmtSQL)
                      %endif
                      @dtw_concat(stmtSQL, " ) ", stmtSQL)
                      @dtw_concat(stmtSQL, " Select TRPROC,TRTPNT,TRTSEQ,max(TRTRID) as TRTRID,  ", stmtSQL)
                      @dtw_concat(stmtSQL, " max(coalesce(PDDESC,' ')) as PDDESC, max(coalesce(PDPPRC,' ')) as PDPPRC,max(coalesce(PDPACT,' ')) as PDPACT, ", stmtSQL)
                      @dtw_concat(stmtSQL, " max(coalesce(PRDESC,' ')) as PRDESC, ", stmtSQL)
                      @dtw_concat(stmtSQL, " max(coalesce(ATDESC,' ')) as ATDESC ", stmtSQL)
                      @dtw_concat(stmtSQL, " From TRANSITION ", stmtSQL)
                      @dtw_concat(stmtSQL, " inner join WFPRDT on PDPROC=TRPROC and PDPONT=TRTPNT and PDSEQ=TRTSEQ ", stmtSQL)
                      @dtw_concat(stmtSQL, " left join WFPRHD on PRPROC=PDPPRC ", stmtSQL)
                      @dtw_concat(stmtSQL, " left join WFPRAC on ATPROC=PDPPRC and ATACTV=PDPACT ", stmtSQL)
                      @dtw_concat(stmtSQL, " Group By TRPROC,TRTPNT,TRTSEQ  ", stmtSQL)
                      @dtw_concat(stmtSQL, " Order By TRTPNT,TRTSEQ ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl" 

                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          %INCLUDE "Copyright.icl"
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td align="justify">&nbsp;</td>
              <td class="toolbar">
                  %INCLUDE "CloseWindow.icl"
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>
      <fieldset class="legendBody">
          <legend class="legendTitle">$(page_title) for $(wfPassFail)</legend>
          <table $(contentTable)>
              <tr>
                  <th class="colhdr$(sortVar)">Detail Point</th>
                  <th class="colhdr$(sortVar)">Process</th>
                  <th class="colhdr$(sortVar)">Activity</th>
              </tr>

              %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;wfToPoint=@dtw_rurlescseq(V_TRTPNT)&amp;wfToSequence=@dtw_rurlescseq(V_TRTSEQ)&amp;wfToTransId=@dtw_rurlescseq(V_TRTRID)")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)WFWorkListOptions.d2w/$(wfPassFailLink)$(maintainVar)" title="Select this as your transition">$(V_PDDESC)</a></td>
                      <td class="colalph" $(helpCursor)><span title="$(V_PDPPRC)">$(V_PRDESC)</span></td>                                      	
                      <td class="colalph" $(helpCursor)><span title="$(V_PDPACT)">$(V_ATDESC)</span></td>                                      	
                  </tr>
              %}
          </table>
      </fieldset>
      <br>
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("WIINST=$(wfInstance) and WIINDT=$(wfInstanceDate) and WIWITM=$(wfWorkItem) and WIWISQ=$(wfWorkItemSequence)", "WFWITM", "Char(Count(*))", RecCount)
  %if (RecCount >"0")
      @Set_SQL(stmtSQL)
  %else
      %if (refreshD2W!="N")
          <script TYPE="text/javascript">
              opener.location.href=opener.location.href;
              opener.focus();
              window.close();
          </script>
      %else
          @BrowserType(browserCode)
          %if (browserCode == "IE")
              <script TYPE="text/javascript">
                  opener.location.href='$(homeURL)$(cGIPath)WFWorkList.d2w/REPORT$(d2wVarBase)';
                  window.close();
              </script>
          %else
              <meta http-equiv="refresh" content="0; URL=javascript:opener.document.location='$(homeURL)$(cGIPath)WFWorkList.d2w/REPORT$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))';self.close();">
          %endif
      %endif
  %endif
%}