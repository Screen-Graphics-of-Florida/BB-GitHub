%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Object Usage List"
  d2wName                 = "ObjectUsageList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;compSelection=@dtw_rurlescseq(compSelection)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "9999"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  compSelection           = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function confirmDeselectAll() {return confirm("Confirm deselect all for current selection");}
              function confirmSelectAll()   {return confirm("Confirm select all for current selection");}
              function validate(chgForm) {
                  if (document.Chg.PgmFilled.checked == false &&
                      document.Chg.PflFilled.checked == false &&
                      document.Chg.LflFilled.checked == false &&
                      document.Chg.DspFilled.checked == false &&
                      document.Chg.PrtFilled.checked == false &&
                      document.Chg.MscFilled.checked == false &&
                      document.Chg.ModFilled.checked == false &&
                      document.Chg.BndFilled.checked == false)
                      {alert("Must make at least one 'Include Rows' selection"); return false;}
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "OBJECTUSAGELIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select SYCPID.*, CFFLD1, CFFLD2, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(CWCPID,' ') as CWCPID ", stmtSQL)
                      @dtw_concat(fileSQL, " SYCPID  ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYCPIW on CWXHND='$(profileHandle)' and CWCPID=CICPID ", fileSQL)
                      @dtw_concat(fileSQL, " inner join SYCPFD on CFFILE='HDFLUS' and CFCPID=CICPID ", fileSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By CIGRP, CIDESCU ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Process_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Process_Query (IN  CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "SubmitScheduleTop.icl"
      %INCLUDE "ConfMessageDisplayNoTable.icl"
      $(hrTagAttr)

      @dtw_assign(focusField, "PgmFilled")
      %if (errFound != "" || scheduleJobSwitch == "Y" || compSelection=="Y")
          @dtw_assign(scheduleJobSwitch, "")
          @EdtVarErr(profileHandle, typeValue, edtVar)
          @dtw_assign(focusField, "")
          @ErrVarErr(profileHandle, typeError, errVar)
          @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
          %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
          @Decat_Field("@@pgm@")  @dtw_assign(V_N1PGM ,  fieldValue)
          @Decat_Field("@@pfl@")  @dtw_assign(V_N1PFL ,  fieldValue)
          @Decat_Field("@@lfl@")  @dtw_assign(V_N1LFL ,  fieldValue)
          @Decat_Field("@@dsp@")  @dtw_assign(V_N1DSP ,  fieldValue)
          @Decat_Field("@@prt@")  @dtw_assign(V_N1PRT ,  fieldValue)
          @Decat_Field("@@msc@")  @dtw_assign(V_N1MSC ,  fieldValue)
          @Decat_Field("@@mod@")  @dtw_assign(V_N1MOD ,  fieldValue)
          @Decat_Field("@@bnd@")  @dtw_assign(V_N1BND ,  fieldValue)
          %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
      %else
          @dtw_assign(V_N1PGM, "01")
          @dtw_assign(V_N1PFL, "01")
          @dtw_assign(V_N1LFL, "01")
          @dtw_assign(V_N1DSP, "01")
          @dtw_assign(V_N1PRT, "01")
          @dtw_assign(V_N1MSC, "01")
          @dtw_assign(V_N1MOD, "01")
          @dtw_assign(V_N1BND, "01")
      %endif

      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;compID=@dtw_rurlescseq(V_CICPID)&amp;selected=@dtw_rurlescseq(selected)">
          <table $(contentTable)>
              @Field_Checked(V_N1PGM, "01", checkedPgmFilled)
              @Field_Checked(V_N1PFL, "01", checkedPflFilled)
              @Field_Checked(V_N1LFL, "01", checkedLflFilled)
              @Field_Checked(V_N1DSP, "01", checkedDspFilled)
              @Field_Checked(V_N1PRT, "01", checkedPrtFilled)
              @Field_Checked(V_N1MSC, "01", checkedMscFilled)
              @Field_Checked(V_N1MOD, "01", checkedModFilled)
              @Field_Checked(V_N1BND, "01", checkedBndFilled)
              <tr><td><input name="updateAll" type="hidden"></td></tr>
              <tr><td><input name="compID"    type="hidden"></td></tr>
              <tr><td><input name="selected"  type="hidden"></td></tr>

              @SetTextOvr(Err_N1PGM)
              <tr><td class="dsphdr"><span $(textOvr)>Include Rows</span></td>
                  <td class="inputnmbr"><input name="PgmFilled" type="checkbox" VALUE='01' $(checkedPgmFilled)>Programs (*PGM/*SRVPGM)</td>
              </tr>
              @DspErrMsg(Err_N1PGM)

              <tr><td>&nbsp;</td>
                  <td class="inputnmbr"><input name="PflFilled" type="checkbox" VALUE='01' $(checkedPflFilled)>Tables (*PF)</td>
              </tr>

              <tr><td>&nbsp;</td>
                  <td class="inputnmbr"><input name="LflFilled" type="checkbox" VALUE='01' $(checkedLflFilled)>Indexes/Views (*LF)</td>
              </tr>

              <tr><td>&nbsp;</td>
                  <td class="inputnmbr"><input name="DspFilled" type="checkbox" VALUE='01' $(checkedDspFilled)>Display Files (*DSPF)</td>
              </tr>

              <tr><td>&nbsp;</td>
                  <td class="inputnmbr"><input name="PrtFilled" type="checkbox" VALUE='01' $(checkedPrtFilled)>Printer Objects (*PRTF/*OVL/*PAGSEG/*PAGDFN/*FNTRSC/*FORMDF)</td>
              </tr>

              <tr><td>&nbsp;</td>
                  <td class="inputnmbr"><input name="MscFilled" type="checkbox" VALUE='01' $(checkedMscFilled)>Miscellaneous (*CMD/*DTAARA/*DTAQ/*MSGF)</td>
              </tr>

              <tr><td>&nbsp;</td>
                  <td class="inputnmbr"><input name="ModFilled" type="checkbox" VALUE='01' $(checkedModFilled)>Modules (*MODULE)</td>
              </tr>

              <tr><td>&nbsp;</td>
                  <td class="inputnmbr"><input name="BndFilled" type="checkbox" VALUE='01' $(checkedBndFilled)>Bind Directories (*BNDDIR)</td>
              </tr>
          </table>

          <fieldset class="legendBody">
              <legend class="legendTitle">Components (for ALL Components, do not mark any)</legend>
              <div class="quickLinksTop">
                  <a onClick="return confirmSelectAll()"   href="javascript:document.Chg.updateAll.value='S'; document.Chg.submit()">$(selectAllImage)</a>
                  <a onClick="return confirmDeselectAll()" href="javascript:document.Chg.updateAll.value='C'; document.Chg.submit()">$(deselectAllImage)</a>
              </div>

              @dtw_assign(Tst_CIGRP, "")
              %ROW{
                  %if (Tst_CIGRP != V_CIGRP)
                      %if (Tst_CIGRP != "")
                          </table>
                          </fieldset>
                      %endif
                      @dtw_assign(Tst_CIGRP, V_CIGRP)

                      @RtvFldDesc("FLTYPE='CPIDGRP' and FLVALU='$(V_CIGRP)'", "SYFLAG", "FLDESC", fieldDesc)
                      <fieldset class="legendBody">
                          <legend class="legendTitle">$(fieldDesc)</legend>
                          <table $(contentTable)>
                              <tr>
                                  <td class="colhdr">Sel</td>
                                  <td class="colhdr">Component</td>
                              </tr>
        	   %endif	
                      @dtw_assign(maintainVar, "$(d2wVarBase)")
                      %INCLUDE "SetRowClass.icl"
                      %if (V_CWCPID == "")
                          @dtw_assign(selected, "")
                      %else
                          @dtw_assign(selected, "CHECKED")
                      %endif

                      <tr class="$(rowClass)">
                          <td class="colcode"><input type="checkbox" name="option" $(selected) onClick="javascript:document.Chg.compID.value='$(V_CICPID)'; javascript:document.Chg.selected.value='$(selected)'; javascript:document.Chg.updateAll.value='I'; document.Chg.submit()"></td>
                          <td class="colalph">$(V_CIDESC)</td>
                      </tr>
                  %}
              </table>
              </fieldset>
          </fieldset>
          %if (focusField != "")
              <script TYPE="text/javascript">
                  document.Chg.$(focusField).focus();
              </script>
          %endif
          @dtw_assign(envProgram, "HSYEOL")
          @dtw_assign(envPrinter, "HSYEOLPF")
          %INCLUDE "ScheduleJob.icl"
          %INCLUDE "SubmitScheduleBottom.icl"
      </form>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HDFUSS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"

  %if (resetSelectionFlag=="Y")
      @dtw_assign(compSelection, "")
  %endif
  %if (compSelection=="")
      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Delete From SYCPIW  ", stmtSQL)
      @dtw_concat(stmtSQL, " Where CWXHND='$(profileHandle)' ", stmtSQL)
      @dtw_concat(stmtSQL, " @@endsql", stmtSQL)
      @SQL_Update(stmtSQL, status)
  %endif
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"

  @dtw_assign(edtVar, "")
  @Concat_Field("@@pgm@", PgmFilled)
  @Concat_Field("@@pfl@", PflFilled)
  @Concat_Field("@@lfl@", LflFilled)
  @Concat_Field("@@dsp@", DspFilled)
  @Concat_Field("@@prt@", PrtFilled)
  @Concat_Field("@@msc@", MscFilled)
  @Concat_Field("@@mod@", ModFilled)
  @Concat_Field("@@bnd@", BndFilled)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)
  @dtw_assign(compSelection, "Y")

  %if (updateAll=="")
      @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)
      %INCLUDE "SubmitScheduleUpdate.icl"
  %else
      %INCLUDE "stmtSQLClear.icl"
      %if (updateAll=="I" && selected == "CHECKED")
          @dtw_concat(stmtSQL, " Delete From SYCPIW  ", stmtSQL)
          @dtw_concat(stmtSQL, " Where CWXHND='$(profileHandle)' and CWCPID='$(compID)' ", stmtSQL)
          @dtw_concat(stmtSQL, " @@endsql", stmtSQL)
      %elif (updateAll=="I")
          @dtw_concat(stmtSQL, " Insert into SYCPIW  ", stmtSQL)
          @dtw_concat(stmtSQL, " Values('$(profileHandle)', '$(compID)') ", stmtSQL)
          @dtw_concat(stmtSQL, " @@endsql", stmtSQL)
      %elif (updateAll=="C")
          @dtw_concat(stmtSQL, " Delete From SYCPIW  ", stmtSQL)
          @dtw_concat(stmtSQL, " Where CWXHND='$(profileHandle)' ", stmtSQL)
          @dtw_concat(stmtSQL, " @@endsql", stmtSQL)
      %elif (updateAll=="S")
          @dtw_concat(stmtSQL, " Delete From SYCPIW  ", stmtSQL)
          @dtw_concat(stmtSQL, " Where CWXHND='$(profileHandle)' ", stmtSQL)
          @dtw_concat(stmtSQL, " @@endsql", stmtSQL)
          @SQL_Update(stmtSQL, status)
          %INCLUDE "stmtSQLClear.icl"
          @dtw_concat(stmtSQL, " Insert into SYCPIW  ", stmtSQL)
          @dtw_concat(stmtSQL, " Select '$(profileHandle)', CICPID From SYCPID inner join SYCPFD on CFFILE='HDFLUS' and CFCPID=CICPID  ", stmtSQL)
          @dtw_concat(stmtSQL, " @@endsql", stmtSQL)
      %endif
      @SQL_Update(stmtSQL, status)
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;scheduleJobSwitch=Y&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif

%}