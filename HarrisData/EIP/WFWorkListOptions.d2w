%INCLUDE "$(baseVar)"
%INCLUDE "BrowserType.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "VarBase.icl"

%Define {	
  d2wName                 = "WFWorkListOptions.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfInstance=@dtw_rurlescseq(wfInstance)&amp;wfInstanceDate=@dtw_rurlescseq(wfInstanceDate)&amp;wfWorkItem=@dtw_rurlescseq(wfWorkItem)&amp;wfWorkItemSequence=@dtw_rurlescseq(wfWorkItemSequence)&amp;wfParticipantId=@dtw_rurlescseq(wfParticipantId)&amp;refreshD2W=@dtw_rurlescseq(refreshD2W)&amp;expireDate=@dtw_rurlescseq(expireDate)&amp;specWfInstance=@dtw_rurlescseq(specWfInstance)&amp;specWfInstanceDate=@dtw_rurlescseq(specWfInstanceDate)&amp;specWfWorkItem=@dtw_rurlescseq(specWfWorkItem)&amp;specWfWorkItemSequence=@dtw_rurlescseq(specWfWorkItemSequence)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%FUNCTION(dtw_directcall) Approve_Data(IN    CHAR(1)     approveCode,
                                             CHAR(32000) edtVar)
{%EXEC {HWFWIA_V.PGM %}
%}

%FUNCTION(dtw_directcall) SetApprove_Data(IN    CHAR(64)    profileHandle,
                                                CHAR(2)     dataBaseID,
                                                CHAR(1)     approveCode,
                                                CHAR(32000) edtVar)
{%EXEC {HWFWIA_S.PGM %}
%}

%FUNCTION(dtw_directcall) Revoke_Data(INOUT CHAR(64)    profileHandle,
                                      INOUT CHAR(2)     dataBaseID,
                                      INOUT CHAR(1)     errFound,
                                      INOUT CHAR(32000) edtVar,                             	
                                      INOUT CHAR(32000) errVar)
{%EXEC {HWFRVD_W.PGM %}
%}

%HTML(CANCEL) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("WIINST=$(wfInstance) and WIINDT=$(wfInstanceDate) and WIWITM=$(wfWorkItem) and WIWISQ=$(wfWorkItemSequence)", "WFWITM", "Char(Count(*))", RecCount)
  %if (RecCount >"0")
      @dtw_assign(setFlag, "")
      @dtw_assign(edtVar, "")
      @Concat_Field("@@inst", wfInstance)
      @Concat_Field("@@indt", wfInstanceDate)
      @Concat_Field("@@witm", wfWorkItem)
      @Concat_Field("@@wisq", wfWorkItemSequence)
      @Concat_Field("@@ptid", wfParticipantId)
      @dtw_concat(edtVar, "}{", edtVar)
      @SetApprove_Data(profileHandle, dataBaseID, setFlag, edtVar)
  %endif
  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)WFWorkList.d2w/REPORT$(d2wVarBase)">
%}

%HTML(PASS_WF) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("WIINST=$(wfInstance) and WIINDT=$(wfInstanceDate) and WIWITM=$(wfWorkItem) and WIWISQ=$(wfWorkItemSequence)", "WFWITM", "Char(Count(*))", RecCount)
  %if (RecCount >"0")
      @dtw_assign(edtVar, "")
      @Concat_Field("@@inst", wfInstance)
      @Concat_Field("@@indt", wfInstanceDate)
      @Concat_Field("@@witm", wfWorkItem)
      @Concat_Field("@@wisq", wfWorkItemSequence)
      @Concat_Field("@@ptid", wfParticipantId)
      %if (wfToPoint>"0")
         @Concat_Field("@@opnt", wfToPoint)
         @Concat_Field("@@oseq", wfToSequence)
         @Concat_Field("@@otid", wfToTransId)
      %endif
      @Concat_Field("@@wfcv", "Y")
      @dtw_concat(edtVar, "}{", edtVar)
      @Approve_Data("P", edtVar)
  %endif
  %if ((wfToPoint>"0") && (refreshD2W!="N"))
      <script TYPE="text/javascript">
          opener.location.href=opener.location.href;
          opener.focus();
          window.close();
      </script>
  %elseif (wfToPoint>"0")
      <script TYPE="text/javascript">
          opener.location.href='$(homeURL)$(cGIPath)WFWorkList.d2w/REPORT$(d2wVarBase)';
          window.close();
      </script>
  %else
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)WFWorkList.d2w/REPORT$(d2wVarBase)">
  %endif
%}

%HTML(PASSUNDO_WF) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("WIINST=$(wfInstance) and WIINDT=$(wfInstanceDate) and WIWITM=$(wfWorkItem) and WIWISQ=$(wfWorkItemSequence)", "WFWITM", "Char(Count(*))", RecCount)
  %if (RecCount >"0")
      @dtw_assign(edtVar, "")
      @Concat_Field("@@inst", wfInstance)
      @Concat_Field("@@indt", wfInstanceDate)
      @Concat_Field("@@witm", wfWorkItem)
      @Concat_Field("@@wisq", wfWorkItemSequence)
      @Concat_Field("@@ptid", wfParticipantId)
      %if (wfToPoint>"0")
         @Concat_Field("@@opnt", wfToPoint)
         @Concat_Field("@@oseq", wfToSequence)
         @Concat_Field("@@otid", wfToTransId)
      %endif
      @dtw_concat(edtVar, "}{", edtVar)
      @Approve_Data("P", edtVar)
  %endif
  %if ((wfToPoint>"0") && (refreshD2W!="N"))
      <script TYPE="text/javascript">
          opener.location.href=opener.location.href;
          opener.focus();
          window.close();
      </script>
  %elseif (wfToPoint>"0")
      @BrowserType(browserCode)
      %if (browserCode == "IE")
          <script TYPE="text/javascript">
              opener.location.href='$(homeURL)$(cGIPath)WFWorkList.d2w/REPORT$(d2wVarBase)';
              window.close();
          </script>
      %else
          <meta http-equiv="refresh" content="0; URL=javascript:opener.document.location='$(homeURL)$(cGIPath)WFWorkList.d2w/REPORT$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))';self.close();">
      %endif
  %else
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)WFWorkList.d2w/REPORT$(d2wVarBase)">
  %endif
%}

%HTML(FAIL_WF) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("WIINST=$(wfInstance) and WIINDT=$(wfInstanceDate) and WIWITM=$(wfWorkItem) and WIWISQ=$(wfWorkItemSequence)", "WFWITM", "Char(Count(*))", RecCount)
  %if (RecCount >"0")
      @dtw_assign(edtVar, "")
      @Concat_Field("@@inst", wfInstance)
      @Concat_Field("@@indt", wfInstanceDate)
      @Concat_Field("@@witm", wfWorkItem)
      @Concat_Field("@@wisq", wfWorkItemSequence)
      @Concat_Field("@@ptid", wfParticipantId)
      %if (wfToPoint>"0")
         @Concat_Field("@@opnt", wfToPoint)
         @Concat_Field("@@oseq", wfToSequence)
         @Concat_Field("@@otid", wfToTransId)
      %endif
      @dtw_concat(edtVar, "}{", edtVar)
      @Approve_Data("F", edtVar)
  %endif
  %if ((wfToPoint>"0") && (refreshD2W!="N"))
      <script TYPE="text/javascript">
          opener.location.href=opener.location.href;
          opener.focus();
          window.close();
      </script>
  %elseif (wfToPoint>"0")
      <script TYPE="text/javascript">
          opener.location.href='$(homeURL)$(cGIPath)WFWorkList.d2w/REPORT$(d2wVarBase)';
          window.close();
      </script>
  %else
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)WFWorkList.d2w/REPORT$(d2wVarBase)">
  %endif
%}

%HTML(REVOKE_WF) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("WIINST=$(wfInstance) and WIINDT=$(wfInstanceDate) and WIWITM=$(wfWorkItem) and WIWISQ=$(wfWorkItemSequence)", "WFWITM", "Char(Count(*))", RecCount)
  %if (RecCount >"0")
      @dtw_assign(edtVar, "")
      @Concat_Field("@@inst", wfInstance)
      @Concat_Field("@@indt", wfInstanceDate)
      @Concat_Field("@@witm", wfWorkItem)
      @Concat_Field("@@wisq", wfWorkItemSequence)
      @Concat_Field("@@ptid", wfParticipantId)
      @Concat_Field("@@part", wfParticipant)
      @Concat_Field("@@dprt", wfDelegatedFrom)
      @dtw_concat(edtVar, "}{", edtVar)
      @Revoke_Data(profileHandle, dataBaseID, errFound, edtVar, errVar)
  %endif
  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)WFWorkItemDelegate.d2w/REPORT$(d2wVarBase)">
%}