%DEFINE {
 DTW_HTML_TABLE="YES"
 SHOWSQL  = "NO"
 DTW_PRINT_HEADER = "NO"
 DTW_REMOVE_WS = "NO"
%}

%FUNCTION(DTW_SQL) GenerateExcel(){
  select * from eiodata/eioadv
  %REPORT {
   %ROW {
                 V1, V2, V3, V4, V5, V6, V7, V8, V9, V10, V11
   %}
  %}
%}

%FUNCTION(DTW_SQL) generateHtml() {select * from eiodata/eioadv %}

%HTML(Excel.csv) {
Content-type: application/msexcel-comma
Content-encoding: ebcdic
Content-Disposition: attachment; filename=file.csv

@GenerateExcel()
%}

%HTML(HTML.html) {
Content-type: text/html

@generateHtml()
%}
