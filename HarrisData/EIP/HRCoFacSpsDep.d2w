%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Spouse/Dependents"
  d2wName                 = "HRCoFacSpsDep.d2w"
  d2wVarBase              = "$(genericVarBase)$(hrCoFacVarBase)&amp;inclActive=@dtw_rurlescseq(inclActive)&amp;inclTerminated=@dtw_rurlescseq(inclTerminated)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(d2wName)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPESDU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  inclActive              = ""
  inclTerminated          = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "HrCoFacURL.icl"
  @dtw_replace(workURL, "@@fromD2w", "@dtw_rurlescseq(fromD2w)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              function validate(searchForm) {
                  if (editNum(document.Search.srchEmployee, 5, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "COFACSPSDEP")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "UserViewEmpl.icl"
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select EMCOMP, EMFACL, EMDEPT, EMLNAM, EMFNAM, EMRNAM, EMLNAMU, EMFNAMU, EMLOC, EMTYPE, EMEMPL, EMPECP, EMPEMP, EMMIDI, EMJOB, EMTRCD, SDLNAM, SDFNAM, SDMIDI, SDDOB, SDGNDR, SDREL, SDEMPL, SDSPDP, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(SDLNAM) as SDLNAMU,", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(SDFNAM) as SDFNAMU ", stmtSQL)
                      @dtw_concat(fileSQL, " HREMPL inner join HRSPDP on EMCOMP=SDCOMP and EMFACL=SDFACL and EMPEMP=SDEMPL ", fileSQL)
                      @dtw_concat(selectSQL, "EMCOMP=$(prCompany) and EMFACL=$(prFacility) ", selectSQL)
                      %INCLUDE "activeTerminatedEmplSQL.icl"
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @SpouseDependent_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) SpouseDependent_Query (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count != "1")
          @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>

              @RetHrCompNam(profileHandle, dataBaseID, prCompany, prFacility, coFacName)
              <tr><td><h2>$(coFacName)</h2></td></tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"
          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Last<br>Name</th>
                          <th class="colhdr">Employee<br>Number</th>
                      </tr>
                      <tr><td><input type="text" class="inputalph" name="srchLast" size="18" maxlength="18">
                              <input type="hidden" name="operLast" value="LIKE">
                          </td>
                          <td><input type="text" class="inputalph" name="srchEmployee" size="9" maxlength="9">
                              <input type="hidden" name="operEmployee" value="=">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchLast.focus();
                  </script>
              </form>

              %INCLUDE "ActiveTerminatedChecked.icl"
              @dtw_assign(viewCheckBox, "HR")
              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              <tr>
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y"))
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("EMEMPL", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=EmplNumber" title="Sequence By Employee Number, Spouse/Dependent First Name">Employee<br>Number</a></th>
                  @OrderBy_Sort("EMLNAMU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=LastName" title="Sequence By Enployee Last Name, First Name, Spouse/Dependent First Name">Employee Name</a></th>
                  @OrderBy_Sort("SDLNAMU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SpsDepLastName" title="Sequence By Spouse/Dependent Last Name, First Name">Spouse/Dependent<br>Name</a></th>
                  @OrderBy_Sort("SDDOB", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SpsDepDOB" title="Sequence By Spouse/Dependent Date Of Birth">Date Of Birth</a></th>
                  <th class="colhdr">Gender</a></th>
                  @OrderBy_Sort("SDREL", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Relationship" title="Sequence By Relationship">Relationship</a></th>
              </tr>
          %INCLUDE "NoRecordsFound.icl"
      %endif

              %ROW{
                  %if (sql_Record_Count == "1")
                      @Save_WebReg(webRegCurFile, profileHandle, d2wName, "", orderBy, orderByDisplay, "")
                      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)EmplDependentsSelect.d2w/REPORT$(d2wVarBase)&amp;prEmployee=@dtw_rurlescseq(V_EMEMPL)&amp;hrEmployee=@dtw_rurlescseq(V_EMPEMP)&amp;dependentNbr=@dtw_rurlescseq(V_SDSPDP)">
                  %else
                      @dtw_assign(maintainVar, "$(d2wVarBase)&amp;dependentNbr=@dtw_rurlescseq(V_SDSPDP)&amp;prEmployee=@dtw_rurlescseq(V_EMEMPL)&amp;hrEmployee=@dtw_rurlescseq(V_EMPEMP)")
                      %INCLUDE "SetRowClass.icl"
                      @Format_EmplName(V_EMFNAM, V_EMLNAM, V_EMMIDI, V_EMRNAM, V_EMTRCD, "D", F_EmpName)
                      @Format_EmplName(V_SDFNAM, V_SDLNAM, V_SDMIDI, "", "", "D", F_dependentName)
                      @Format_Confirm_Desc($(F_dependentName), "", "", "", "", "", confirmDesc)
                      <tr class="$(rowClass)">
                          %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y"))
                              <td class="opticon">
                                  %if (sec_02 == "Y" || sec_03 == "Y")
                                     <a href="$(homeURL)$(cGIPath)EmplDependentsMaintain.d2w/EMPLDEPENDENTS$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                                  %endif
                                  %if (sec_03 == "Y")
                                      <a onClick="return confirmDelete('$(confirmDesc)')" href=$(homeURL)$(cGIPath)EmplDependentsMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D&amp;firstName=@dtw_rurlescseq(V_SDFNAM)&amp;lastName=@dtw_rurlescseq(V_SDLNAM)>$(deleteImageSml)</a>
                                  %endif
                              </td>
                          %endif
                          <td class="colcode">$(V_EMEMPL)</td>
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)emplDependents.d2w/REPORT$(d2wVarBase)&amp;prEmployee=@dtw_rurlescseq(V_EMEMPL)&amp;hrEmployee=@dtw_rurlescseq(V_SDEMPL)" title="View All Dependents Of This Employee">$(F_EmpName)</a></td>
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)EmplDependentsSelect.d2w/REPORT$(d2wVarBase)&amp;prEmployee=@dtw_rurlescseq(V_EMEMPL)&amp;hrEmployee=@dtw_rurlescseq(V_SDEMPL)&amp;dependentNbr=@dtw_rurlescseq(V_SDSPDP)" title="View Dependent"> $(F_dependentName)</a></td>
                          @Format_Date(V_SDDOB, "D", F_SDDOB)
                          <td class="colcode"> $(F_SDDOB)</td>
                          <td class="colcode"> $(V_SDGNDR)</td>
                          <td class="colalph"> $(V_SDREL)</td>
                      </tr>
                  %endif
          %}
          </table>
          %if (sql_Record_Count != "1")
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "UserViewEmpl.icl"
  %INCLUDE "userview.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "Select EMCOMP, EMFACL, EMDEPT, EMLNAM, EMFNAM, EMRNAM, EMLNAMU, EMFNAMU, EMLOC, EMTYPE, EMEMPL, EMPECP, EMPEMP, EMMIDI, EMJOB, EMTRCD, SDLNAM, SDFNAM, SDMIDI, SDDOB, SDGNDR, SDREL, SDEMPL, SDSPDP, ", stmtSQL)
  @dtw_concat(stmtSQL, " upper(SDLNAM) as SDLNAMU,", stmtSQL)
  @dtw_concat(stmtSQL, " upper(SDFNAM) as SDFNAMU ", stmtSQL)
  @dtw_concat(fileSQL, " HREMPL inner join HRSPDP on EMCOMP=SDCOMP and EMFACL=SDFACL and EMPEMP=SDEMPL ", fileSQL)
  @dtw_concat(selectSQL, "EMCOMP=$(prCompany) and EMFACL=$(prFacility) ", selectSQL)
  %INCLUDE "activeTerminatedEmplSQL.icl"
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @SpouseDependent_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) SpouseDependent_XMLQuery (IN  CHAR(64)    profileHandle,
				              CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("spousedependentlist")
          %ROW{
              @DateFromCYMD(V_SDDOB)

              @Format_EmplName(V_SDFNAM, V_SDLNAM, V_SDMIDI, "", "", "D", F_dependentName)

              @XMLIDTag(@DTW_rCONCAT(V_EMCOMP, @DTW_rCONCAT("/", @DTW_rCONCAT(V_EMFACL, @DTW_rCONCAT("-", V_EMEMPL)))), "employee ID")
                  @XMLTag(V_EMCOMP, "CompanyNumber")
                  @XMLTag(V_EMFACL, "FacilityNumber")
                  @XMLTag(V_EMEMPL, "EmployeeNumber")

                  @XMLBeginTag("PersonName")
                      @XMLTag(V_EMRNAM, "FormattedName")
                      @XMLTag(V_EMFNAM, "GivenName")
                      @XMLTag(V_EMMIDI, "MiddleName")
                      @XMLTag(V_EMLNAM, "FamilyName")
                  @XMLEndTag("PersonName")

                  @XMLTag(V_EMDEPT, "Department")
                  @XMLTag(V_EMLOC, "Location")

                  @XMLBeginTag("DependentName")
                      @XMLTag(F_dependentName, "FormattedName")
                      @XMLTag(V_SDFNAM, "GivenName")
                      @XMLTag(V_SDMIDI, "MiddleName")
                      @XMLTag(V_SDLNAM, "FamilyName")
                  @XMLEndTag("DependentName")

                  @XMLTag(V_SDDOB, "DateOfBirth")
                  @XMLTag(V_SDGNDR, "Gender")
                  @XMLTag(V_SDREL, "Relationship")
              @XMLEndTag("employee")
	   %}
      @XMLEndTag("spousedependentlist")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "EMEMPL,SDLNAMU,SDFNAMU")
              @DTW_ASSIGN(orderByDisplay, "Employee Number, Spouse/Dependent Last Name, First Name")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %elif (chgActive == "Y" && inclActive == "Y")
              @dtw_assign(inclActive, "")
          %elif (chgActive == "Y")
              @dtw_assign(inclActive, "Y")
          %elif (chgTerminated == "Y" && inclTerminated == "Y")
              @dtw_assign(inclTerminated, "")
          %elif (chgTerminated == "Y")
              @dtw_assign(inclTerminated, "Y")
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      %if (inclActive == "" && inclTerminated == "" && chgActive != "Y" && chgTerminated != "Y")
          @dtw_assign(inclActive, activeEmpl)
          @dtw_assign(inclTerminated, terminatedEmpl)
      %endif
      %INCLUDE "SearchReturn.icl"
  %endif
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "EmplNumber")
      %if (orderBy == "EMEMPL,SDLNAMU,SDFNAMU")
          @DTW_ASSIGN(orderBy, "EMEMPL DESC,SDFNAMU")
          @DTW_ASSIGN(orderByDisplay, "Employee Number (descending), Spouse/Dependent First Name ")
      %else
          @DTW_ASSIGN(orderBy, "EMEMPL,SDFNAMU")
          @DTW_ASSIGN(orderByDisplay, "Employee Number, Spouse/Dependent First Name")
      %endif
  %elif (sequence == "LastName")
      %if (orderBy == "EMLNAMU,EMFNAMU,SDFNAMU")
          @DTW_ASSIGN(orderBy, "EMLNAMU DESC,EMFNAMU,SDLNAMU,SDFNAMU")
          @DTW_ASSIGN(orderByDisplay, "Employee Last Name (descending), First Name, Spouse/Dependent First Name")
      %else
          @DTW_ASSIGN(orderBy, "EMLNAMU,EMFNAMU,SDFNAMU")
          @DTW_ASSIGN(orderByDisplay, "Employee Last Name, First Name, Spouse/Dependent First Name")
      %endif
  %elif (sequence == "SpsDepLastName")
      %if (orderBy == "SDLNAMU,SDFNAMU")
          @DTW_ASSIGN(orderBy, "SDLNAMU DESC,SDFNAMU")
          @DTW_ASSIGN(orderByDisplay, "Spouse/Dependent Last Name (descending), First Name")
      %else
          @DTW_ASSIGN(orderBy, "SDLNAMU,SDFNAMU")
          @DTW_ASSIGN(orderByDisplay, "Spouse/Dependent Last Name, First Name")
      %endif
  %elif (sequence == "SpsDepDOB")
      %if (orderBy == "SDDOB")
          @DTW_ASSIGN(orderBy, "SDDOB DESC")
          @DTW_ASSIGN(orderByDisplay, "Spouse/Dependent Date Of Birth (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SDDOB")
          @DTW_ASSIGN(orderByDisplay, "Spouse/Dependent Date Of Birth ")
      %endif
  %elif (sequence == "Relationship")
      %if (orderBy == "SDREL")
          @DTW_ASSIGN(orderBy, "SDREL DESC")
          @DTW_ASSIGN(orderByDisplay, "Relationship (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SDREL")
          @DTW_ASSIGN(orderByDisplay, "Relationship")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              @dtw_assign(formName, "Search")
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchEmployee, 5, 0) &&
                      editdate(document.Search.srchSpsDepDOB))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "COFACSPSDEPSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      @RetHrCompNam(profileHandle, dataBaseID, prCompany, prFacility, coFacName)
                      <h2>$(coFacName)</h2>

                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Employee Number</td>
                              @dtw_assign(operNbr, "operEmployee")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchEmployee" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">Employee Last Name</td>
                              @dtw_assign(operNbr, "operLast")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchLast" size="18" maxlength="18"></td>
                          </tr>

                          <tr><td class="dsphdr">Employee First Name</td>
                              @dtw_assign(operNbr, "operFirst")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchFirst" size="18" maxlength="18"></td>
                          </tr>

                          <tr><td class="dsphdr">Spouse/Dependent Last Name</td>
                              @dtw_assign(operNbr, "operSpsDepLast")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchSpsDepLast" size="18" maxlength="18"></td>
                          </tr>

                          <tr><td class="dsphdr">Spouse/Dependent First Name</td>
                              @dtw_assign(operNbr, "operSpsDepFirst")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchSpsDepFirst" size="18" maxlength="18"></td>
                          </tr>

                          <tr><td class="dsphdr">Spouse/Dependent Date Of Birth</td>
                              @dtw_assign(operNbr, "operSpsDepDOB")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchSpsDepDOB" size="6" maxlength="6"> 		
                                  <a href="javascript:calWindow('srchSpsDepDOB');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Relationship</td>
                              @dtw_assign(operNbr, "operRel")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchRel" size="8" maxlength="8"> 		
                          </tr>

                          <tr><td class="dsphdr">Location</td>
                              @dtw_assign(operNbr, "operLoc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchLoc" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Search&amp;fldComp=@dtw_rurlescseq(hrCompany)&amp;fldType=O&amp;fldName=srchLoc&amp;fldDesc=locCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="locCodeDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Department</td>
                              @dtw_assign(operNbr, "operDept")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchDept" type="text" size="5" maxlength="5"> <a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Search&amp;fldName=srchDept&amp;fldDesc=deptDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="deptDesc" value="$(deptDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Job Code</td>
                              @dtw_assign(operNbr, "operJob")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchJob" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Search&amp;fldComp=@dtw_rurlescseq(hrCompany)&amp;fldType=J&amp;fldName=srchJob&amp;fldDesc=jobCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="jobCodeDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchEmployee.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("EMEMPL", "Employee Number", $(srchEmployee), "", operEmployee, "N")
  @Build_WildCard ("EMLNAMU", "Last Name", $(srchLast), "U", operLast, "A")
  @Build_WildCard ("EMFNAMU", "First Name", $(srchFirst), "U", operFirst, "A")
  @Build_WildCard ("upper(SDLNAM)", "Spouse/Dependent Last Name", $(srchSpsDepLast), "U", operSpsDepLast, "A")
  @Build_WildCard ("upper(SDFNAM)", "Spouse/Dependent First Name", $(srchSpsDepFirst), "U", operSpsDepFirst, "A")
  @Build_WildCard ("SDDOB", "Spouse/Dependent Date Of Birth", $(srchSpsDepDOB), "", operSpsDepDOB, "D")
  @Build_WildCard ("SDREL", "Relationship", $(srchRel), "U", operRel, "A")
  @Build_WildCard ("EMLOC", "Location", $(srchLoc), "U", operLoc, "A")
  @Build_WildCard ("EMDEPT", "Department", $(srchDept), "U", operDept, "A")
  @Build_WildCard ("EMJOB", "Job Code", $(srchJob), "U", operJob, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}