%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Supplier Contact Maintenance"
  d2wName                 = "SupplierContactMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;forVendor=@dtw_rurlescseq(forVendor)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;contactNumber=@dtw_rurlescseq(contactNumber)&amp;firstName=@dtw_rurlescseq(firstName)&amp;lastName=@dtw_rurlescseq(lastName)&amp;maintenanceCode=D"
  programName             = "HSRCNM_E"
  fileName                = "SRCNTU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  editVariables           = ""
%}

%INCLUDE "userdefined_number.icl"

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @VendorUserView(profileHandle, dataBaseID, userPass, vendorNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      @dtw_assign(editVariables, "")
      @dtw_tb_rows(userDefinedTable, userMaxRows)
      @dtw_assign(ux, "1")
      %while(ux <= userMaxRows){
          @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFFLDN"), V_UFFLDN)
          @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFDESC"), V_UFDESC)
          @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFTYPE"), V_UFTYPE)
          @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFSIZE"), V_UFSIZE)
          @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFDECM"), V_UFDECM)
          @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFREQF"), V_UFREQF)

          %if (V_UFTYPE == "N")
              @dtw_concat(editVariables, " editNum(document.Chg.", editVariables)
              @dtw_concat(editVariables, $(V_UFFLDN), editVariables)
              @dtw_concat(editVariables, ",", editVariables)
              @dtw_concat(editVariables, $(V_UFSIZE), editVariables)
              @dtw_concat(editVariables, ",", editVariables)
              @dtw_concat(editVariables, $(V_UFDECM), editVariables)
              @dtw_concat(editVariables, ") &&", editVariables)
          %elif (V_UFTYPE == "D")
              @dtw_concat(editVariables, " editdate(document.Chg.", editVariables)
              @dtw_concat(editVariables, $(V_UFFLDN), editVariables)
              @dtw_concat(editVariables, ") &&", editVariables)
          %endif
          %if (V_UFREQF == "Y")
              @dtw_concat(editVariables, " checkReqField(document.Chg.", editVariables)
              @dtw_concat(editVariables, $(V_UFFLDN), editVariables)
              @dtw_concat(editVariables, ") &&", editVariables)
          %endif
          @dtw_add(ux, "1", ux)
      %}
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.lastName.value =="" ||
                      document.Chg.firstName.value =="")
                     {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.contactNumber, 7, 0) &&
                      editNum(document.Chg.vendorNumber, 7, 0) &&
                      $(editVariables)
                      editdate(document.Chg.dateInactive))
                      return true;
                  }
                  function checkCmtLength(textField) {
                      if (textField.length > 1800) {
                          alert('Maximum field size has been reached.');
                          return false;
                      }
                      return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
                  %INCLUDE "dateedit.icl"
	           %INCLUDE "numedit.icl"
	           %INCLUDE "checkReqField.icl"
                  %INCLUDE "calendar.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- Start Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                       @dtw_assign(pageID, "SUPPCONTACTMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "Select * From SRCNTM Where SRCONT = $(contactNumber)", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
  %}

%FUNCTION(dtw_sql) Maintain_Query (IN  CHAR(64)    profileHandle,
				        CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "vendorNumber")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@cont", "contactNumber")     @dtw_assign(Err_SRCONT, fieldValue)
                          @DecatErr_Field("@@vend", "vendorNumber")      @dtw_assign(Err_SRVEND, fieldValue)
                          @DecatErr_Field("@@lnam", "lastName")          @dtw_assign(Err_SRLNAM, fieldValue)
                          @DecatErr_Field("@@fnam", "firstName")         @dtw_assign(Err_SRFNAM, fieldValue)
                          @DecatErr_Field("@@salu", "salutation")        @dtw_assign(Err_SRSALU, fieldValue)
                          @DecatErr_Field("@@cnam", "companyName")       @dtw_assign(Err_SRCNAM, fieldValue)
                          @DecatErr_Field("@@titl", "title")             @dtw_assign(Err_SRTITL, fieldValue)
                          @DecatErr_Field("@@adr1", "addressLineOne")    @dtw_assign(Err_SRADR1, fieldValue)
                          @DecatErr_Field("@@adr2", "addressLineTwo")    @dtw_assign(Err_SRADR2, fieldValue)
                          @DecatErr_Field("@@adr3", "addressLineThree")  @dtw_assign(Err_SRDAR3, fieldValue)
                          @DecatErr_Field("@@city", "city")              @dtw_assign(Err_SRCITY, fieldValue)
                          @DecatErr_Field("@@st@@", "state")             @dtw_assign(Err_SRST,   fieldValue)
                          @DecatErr_Field("@@zip@", "zip")               @dtw_assign(Err_SRZIP,  fieldValue)
                          @DecatErr_Field("@@dati", "dateInactive")      @dtw_assign(Err_SRDATI, fieldValue)
                      %endif

                      @Decat_Field("@@cont")   @dtw_assign(V_SRCONT, fieldValue)
                      @Decat_Field("@@vend")   @dtw_assign(V_SRVEND, fieldValue)
                      @Decat_Field("@@lnam")   @dtw_assign(V_SRLNAM, fieldValue)
                      @Decat_Field("@@fnam")   @dtw_assign(V_SRFNAM, fieldValue)
                      @Decat_Field("@@salu")   @dtw_assign(V_SRSALU, fieldValue)
                      @Decat_Field("@@cnam")   @dtw_assign(V_SRCNAM, fieldValue)
                      @Decat_Field("@@titl")   @dtw_assign(V_SRTITL, fieldValue)
                      @Decat_Field("@@adr1")   @dtw_assign(V_SRADR1, fieldValue)
                      @Decat_Field("@@adr2")   @dtw_assign(V_SRADR2, fieldValue)
                      @Decat_Field("@@adr3")   @dtw_assign(V_SRDAR3, fieldValue)
                      @Decat_Field("@@city")   @dtw_assign(V_SRCITY, fieldValue)
                      @Decat_Field("@@st@@")   @dtw_assign(V_SRST,   fieldValue)
                      @Decat_Field("@@zip@")   @dtw_assign(V_SRZIP,  fieldValue)
                      @Decat_Field("@@dati")   @dtw_assign(V_SRDATI, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(V_SRCONT, "0")
                          %if (forVendor > "0")
                              @dtw_assign(V_SRVEND, forVendor)
                          %else
                              @dtw_assign(V_SRVEND, "0")
                          %endif
                          @dtw_assign(focusField, "vendorNumber")
                      %endif

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_SRCONT, "0")
                      @DateInputFromISO("$(V_SRDATI)", V_SRDATI)
                      @dtw_assign(focusField, "contactNumber")
                  %else
                      @DateInputFromISO("$(V_SRDATI)", V_SRDATI)
                      @dtw_assign(focusField, "vendorNumber")
                  %endif

                  @SetTextOvr(Err_SRCONT)
                  <tr><td class="dsphdr"><span $(textOvr)>Contact Number</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="contactNumber" type="text" value=$(V_SRCONT) size="7" maxlength="7"></td>
                      %else
                          <td class="inputnmbr">$(V_SRCONT)</td>
                          <td><input type="hidden" name="contactNumber" value=$(V_SRCONT) size="7" maxlength="7"></td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_SRCONT)
               			
                  @RtvFldDesc("VMVEND=$(V_SRVEND)", "HDVEND", "VMVNA1", vendorName)
                  @SetTextOvr(Err_SRVEND)
                  <tr><td class="dsphdr"><span $(textOvr)>Vendor Number</span></td>
                      <td class="inputalph"><input name="vendorNumber" type="text" value="$(V_SRVEND)" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=vendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="vendorName" value="$(vendorName)" type="text" size="30" disabled></td>
                  </tr>
                  @DspErrMsg(Err_SRVEND)

                  @SetTextOvr(Err_SRSALU)
                  <tr><td class="dsphdr"><span $(textOvr)>Salutation</span></td>
                      @dtw_tb_rows(salutationTable, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(salutationTable, x, "1") != V_SRSALU) && (x < maxRows)) {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(salutationTable, "salutation", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_SRSALU)
        			
                  @SetTextOvr(Err_SRFNAM)
                  <tr><td class="dsphdr"><span $(textOvr)>First Name</span></td>
                      <td class="inputalph"><input name="firstName" type="text" value="$(V_SRFNAM)" size="30" maxlength="30"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_SRFNAM)
        			
                  @SetTextOvr(Err_SRLNAM)
                  <tr><td class="dsphdr"><span $(textOvr)>Last Name</span></td>
                      <td class="inputalph"><input name="lastName" type="text" value="$(V_SRLNAM)" size="30" maxlength="30"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_SRLNAM)
        			
                  @SetTextOvr(Err_SRCNAM)
                  <tr><td class="dsphdr"><span $(textOvr)>Company Name</span></td>
                      <td class="inputalph"><input name="companyName" type="text" value="$(V_SRCNAM)" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_SRCNAM)
        			
                  @SetTextOvr(Err_SRTITL)
                  <tr><td class="dsphdr"><span $(textOvr)>Title</span></td>
                      <td class="inputalph"><input name="title" type="text" value="$(V_SRTITL)" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_SRTITL)

                  @SetTextOvr(Err_SRADR1)
                  <tr><td class="dsphdr"><span $(textOvr)>Address Line One</span></td>
                      <td class="inputalph"><input name="addressLineOne" type="text" value="$(V_SRADR1)" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_SRADR1)

                  @SetTextOvr(Err_SRADR2)
                  <tr><td class="dsphdr"><span $(textOvr)>Address Line Two</span></td>
                      <td class="inputalph"><input type="text" name="addressLineTwo" value="$(V_SRADR2)" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_SRADR2)
        				
                  @SetTextOvr(Err_SRADR3)
        	       <tr><td class="dsphdr"><span $(textOvr)>Address Line Three</span></td>
                      <td class="inputalph"><input type="text" name="addressLineThree" value="$(V_SRADR3)" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_SRADR3)

                  @SetTextOvr(Err_SRCITY)
                  <tr><td class="dsphdr"><span $(textOvr)>City</span></td>
                      <td class="inputalph"><input type="text" name="city" value="$(V_SRCITY)" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_SRCITY)

                  @RtvFldDesc("STID='$(V_SRST)'", "HDSTID", "STDESC", fieldDesc)
                  @SetTextOvr(Err_SRST)
                  <tr><td class="dsphdr"><span $(textOvr)>State</span></td>
                      <td class="inputalph"><input name="state" type="text" value="$(V_SRST)" size="2" maxlength="2"><a href="$(homeURL)$(phpPath)StateSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=state&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stateDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_SRST)

                  @SetTextOvr(Err_SRZIP)
        	       <tr><td class="dsphdr"><span $(textOvr)>Zip</span></td>
                      <td class="inputalph"><input type="text" name="zip" value="$(V_SRZIP)" size="13" maxlength="13"></td>
                  </tr>
                  @DspErrMsg(Err_SRZIP)

                  @SetTextOvr(Err_SRDATI)
                  <tr><td class="dsphdr"><span $(textOvr)>Date Inactive</span></td>
                      <td class="inputnmbr"><input type="text" name="dateInactive" value="$(V_SRDATI)" size="6" maxlength="6">
                          <a href="javascript:calWindow('dateInactive');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_SRDATI)

                  <tr><td><input name="timeStamp" type="hidden" value="$(V_SRTSTP)"></td></tr>
              %}	

              @dtw_tb_rows(userDefinedTable, userMaxRows)
              @dtw_assign(ux, "1")
              %while(ux <= userMaxRows){
                  @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFFLDN"), V_UFFLDN)
                  @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFDESC"), V_UFDESC)
                  @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFTYPE"), V_UFTYPE)
                  @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFSIZE"), V_UFSIZE)
                  @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFDECM"), V_UFDECM)
                  @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFVALU"), V_UFVALU)
                  @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFBOXS"), V_UFBOXS)
                  @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFREQF"), V_UFREQF)
                  @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFVLDV"), V_UFVLDV)

                  @dtw_tb_rows(suppContactUserTable, maxRows)
                  @dtw_assign(x, "1")
                  %while((@dtw_tb_rgetv(suppContactUserTable, x, @dtw_tb_rQuerycolnonj(suppContactUserTable, "SUFLDN")) != V_UFFLDN) && (x <= maxRows)) {@dtw_add(x, "1", x)%}
                  %if (x <=maxRows)
                      @dtw_tb_getv(suppContactUserTable, x, @dtw_tb_rQuerycolnonj(suppContactUserTable, "SUFLDD"), V_SUFLDD)
                      @dtw_tb_getv(suppContactUserTable, x, @dtw_tb_rQuerycolnonj(suppContactUserTable, "SUFLDV"), V_SUFLDV)
                      @dtw_tb_getv(suppContactUserTable, x, @dtw_tb_rQuerycolnonj(suppContactUserTable, "SUFLDR"), V_SUFLDR)
                  %else
                      @dtw_assign(V_SUFLDD, "")
                      @dtw_assign(V_SUFLDV, "")
                      @dtw_assign(V_SUFLDR, "")
                  %endif

                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(userEdtVar, "")
                      %else
                          %if (ux == "1")
                              @UsrVarErr(profileHandle, typeUserDef, userEdtVar)
                          %endif
                          @dtw_assign(catFld, V_UFFLDN)
                          %while(@dtw_rlength(catFld) != "6") {@dtw_insert("@", catFld, @dtw_rlength(catFld), catFld) %}
                          @DecatErr_Field("$(catFld)", "$(V_UFFLDN)")
                          @dtw_concat("Err_", "$(V_UFFLDN)", errFldName)
                          @dtw_assign(errFldName, fieldValue)
                      %endif

                      @Decat_UserDef_Field("$(catFld)")
                      %if (V_UFTYPE == "A" || V_UFTYPE == "C")
                          @dtw_assign(V_SUFLDV, fieldValue)
                      %elif (V_UFTYPE == "N")
                          @dtw_assign(V_SUFLDN, fieldValue)
                          @dtw_multiply(V_SUFLDN, "1", "21", V_SUFLDN)
                      %elif (V_UFTYPE == "D")
                          @dtw_assign(V_SUFLDD, fieldValue)
                      %endif
                  %else
                      %if (V_UFTYPE == "N")
                          @dtw_assign(Precision, @dtw_radd(V_UFSIZE, V_UFDECM))
                          @dtw_assign(V_SUFLDN, @dtw_rformat(V_SUFLDR, V_UFSIZE, V_UFDECM, "", "", Precision))
                          @dtw_assign(V_SUFLDN, @dtw_rstrip(V_SUFLDN))
                      %elif (V_UFTYPE == "D")
                          @DateInputFromISO("$(V_SUFLDD)", V_SUFLDD)
                      %endif
                  %endif

                  @SetTextOvr(errFldName)
        	       <tr><td class="dsphdr"><span $(textOvr)>$(V_UFDESC)</span></td>
                      %if (V_UFTYPE == "A")
                          <td class="inputalph"><input type="text" name="$(V_UFFLDN)" value="$(V_SUFLDV)" size="$(V_UFSIZE)" maxlength="$(V_UFSIZE)">
                      %elif (V_UFTYPE == "C")
                          <td>%if ("$(V_SUFLDV)" != "")
                                  <textarea name="$(V_UFFLDN)" ROWS=$(V_UFBOXS) COLS=60 onkeyup="checkCmtLength(this.value)" onkeypress="checkCmtLength(this.value)">$(V_SUFLDV)</textarea>
                              %else
                                  <textarea name="$(V_UFFLDN)" ROWS=$(V_UFBOXS) COLS=60 onkeyup="checkCmtLength(this.value)" onkeypress="checkCmtLength(this.value)"></textarea>
                              %endif
                      %elif (V_UFTYPE == "N")
                          @dtw_add(V_UFSIZE, V_UFDECM, V_UFSIZE)
                          %if (V_UFDECM != "0")
                              @dtw_add(V_UFSIZE, "2", V_UFSIZE)
                          %endif
                          <td class="inputnmbr"><input type="text" name="$(V_UFFLDN)" value="$(V_SUFLDN)" size="$(V_UFSIZE)" maxlength="$(V_UFSIZE)">
                      %elif (V_UFTYPE == "D")
                          <td class="inputnmbr"><input type="text" name="$(V_UFFLDN)" value="$(V_SUFLDD)" size="6" maxlength="6">
                               %if (V_UFVLDV != "Y")
                                   <a href="javascript:calWindow('$(V_UFFLDN)');">$(calendarImage)</a>
                               %endif
                      %endif
                      %if (V_UFVALU == "Y" || V_UFVLDV == "Y")
                          <a href="$(homeURL)$(phpPath)UserDefinedSearch.php$(altVarBase)&amp;docName=Chg&amp;fileName=$(fileName)&amp;fldName=$(V_UFFLDN)&amp;fldType=$(V_UFTYPE)&amp;fldDesc=$(V_UFDESC)" onclick="$(searchWinVar)"> $(searchImage) </a>
                      %endif
                      %if (V_UFREQF == "Y")
                          $(reqFieldChar)
                      %endif
                      </td>
                  </tr>
                  @DspErrMsg(errFldName)
                  @dtw_add(ux, "1", ux)
              %}
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall)  Validate_Contact_Data(INOUT CHAR(64)    profileHandle,
                                                 INOUT CHAR(2)     dataBaseID,
                                                 INOUT CHAR(1)     maintenanceCode,
                                                 INOUT CHAR(1)     errFound,
                                                 INOUT CHAR(32000) edtVar,                             	
                                                 INOUT CHAR(32000) userEdtVar,                             	
                                                 INOUT CHAR(32000) errVar)
{%EXEC {HSRCNM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @UserDefined_Query(profileHandle, dataBaseID, "SRCNTU    ", "          ", userDefinedTable)	
          @dtw_tb_rows(userDefinedTable, userMaxRows)
      @SupplierContactUser_Query(profileHandle, dataBaseID, contactNumber, suppContactUserTable)	
      @Salutation_Query(profileHandle, dataBaseID, "SALUTATION", salutationTable)
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_mUPPERCASE(state)
  @dtw_mUPPERCASE(zip)
  @dtw_assign(vendorNumber,@dtw_rstrip(vendorNumber))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@cont", contactNumber)
  @Concat_Field("@@vend", vendorNumber)
  @Concat_Field("@@lnam", lastName)
  @Concat_Field("@@fnam", firstName)
  @Concat_Field("@@salu", salutation)
  @Concat_Field("@@cnam", companyName)
  @Concat_Field("@@titl", title)
  @Concat_Field("@@adr1", addressLineOne)
  @Concat_Field("@@adr2", addressLineTwo)
  @Concat_Field("@@adr3", addressLineThree)
  @Concat_Field("@@city", city)
  @Concat_Field("@@st@@", state)
  @Concat_Field("@@zip@", zip)
  @Concat_Field("@@dati", dateInactive)
  @Concat_Field("@@tstp", timeStamp)
  @Concat_Field("@@datu", dateUpdated)
  @dtw_concat(edtVar, "}{", edtVar)

  @UserDefined_Query(profileHandle, dataBaseID, "SRCNTU    ", "          ", userDefinedTable)	

  @dtw_tb_rows(userDefinedTable, userMaxRows)
  @dtw_assign(ux, "1")
  %while(ux <= userMaxRows){
      @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFFLDN"), V_UFFLDN)
      @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFTYPE"), V_UFTYPE)
      @dtw_assign(UFFLDN, $(V_UFFLDN))
      @dtw_assign(outField, $($(UFFLDN)))
      %if (V_UFTYPE == "A" || V_UFTYPE == "C")
          @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFUPPR"), V_UFUPPR)
          %if (V_UFUPPR == "Y")
              @dtw_mUPPERCASE(outField)
          %endif
      %elif (V_UFTYPE == "N")
          @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFSIZE"), V_UFSIZE)
          @dtw_tb_getv(userDefinedTable, ux, @dtw_tb_rQuerycolnonj(userDefinedTable, "UFDECM"), V_UFDECM)
          @Build_User_Number(outField, V_UFSIZE, V_UFDECM, outField)
      %endif
      %while(@dtw_rlength(V_UFFLDN) != "6")
          {@dtw_insert("@", V_UFFLDN, @dtw_rlength(V_UFFLDN), V_UFFLDN) %}
      @dtw_concat(userEdtVar, @dtw_rconcat("}{$(V_UFFLDN)", $(outField)), userEdtVar)
      @dtw_add(ux, "1", ux)
  %}
  @dtw_concat(userEdtVar, "}{", userEdtVar)

  @Validate_Contact_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, userEdtVar, errVar)

  @Format_EmplName(firstName, lastName, "", "", "", "D", F_Name)
  %if (errFound == "")
      %if (contactNumber == "0")
          @Decat_Field("&&cont")   @dtw_assign(contactNumber, fieldValue)
      %endif
      @Format_ConfMsg_Desc(maintenanceCode, $(F_Name), $(contactNumber), "", "", "", "", confMessage)
      @RtvFldDesc("VMVEND=$(vendorNumber)", "HDVEND", "VMVNA1", vendorName)
      %if (maintenanceCode == "D" || fromD2w != "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)supplierContact.d2w/REPORT$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)&amp;vendorNumber=@dtw_rurlescseq(vendorNumber)&amp;vendorName=@dtw_rurlescseq(vendorName)">
      %else
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)SupplierContactSelect.d2w/REPORT$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)&amp;vendorNumber=@dtw_rurlescseq(vendorNumber)&amp;vendorName=@dtw_rurlescseq(vendorName)&amp;contactNumber=@dtw_rurlescseq(contactNumber)">
      %endif
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@cont", "contactNumber")
      @Format_ConfMsg_Desc("", $(F_Name), $(contactNumber), "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)supplierContact.d2w/REPORT$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)&amp;vendorNumber=@dtw_rurlescseq(vendorNumber)&amp;vendorName=@dtw_rurlescseq(vendorName)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @UsrVarErr(profileHandle, typeUserDef, userEdtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;contactNumber=@dtw_rurlescseq(contactNumber)&amp;errFound=@dtw_rurlescseq(errFound)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}