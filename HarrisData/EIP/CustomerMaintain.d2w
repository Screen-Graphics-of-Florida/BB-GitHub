                          %while((@dtw_tb_rgetv(yn07Table, x, "1") != V_CMAOVS) && (x < maxRows))
                              {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(yn07Table, "allowOverShipments", "2", "1", "N", "", x, "1")</td>
                      </tr>
