%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Terms Code Maintenance"
  d2wName                 = "TermsCodeMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;termsCode=@dtw_rurlescseq(termsCode)&amp;termsDesc=@dtw_rurlescseq(termsDesc)&amp;maintenanceCode=D"
  programName             = "HHDTMM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function validate(chgForm) {
                  if (document.Chg.termsCode.value =="" ||
                      document.Chg.termsDesc.value =="")
                         {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.daysTillDue, 3, 0) &&
                      editNum(document.Chg.daysForDiscount, 3, 0) &&
                      editNum(document.Chg.discountPercent, 2, 1) &&
                      editdate(document.Chg.dueDate) &&
                      editNum(document.Chg.fromDay1, 2, 0) &&
                      editNum(document.Chg.toDay1, 2, 0) &&
                      editNum(document.Chg.dayDue1, 2, 0) &&
                      editNum(document.Chg.monthInc1, 1, 0) &&
                      editNum(document.Chg.fromDay2, 2, 0) &&
                      editNum(document.Chg.toDay2, 2, 0) &&
                      editNum(document.Chg.dayDue2, 2, 0) &&
                      editNum(document.Chg.monthInc2, 1, 0) &&
                      editNum(document.Chg.fromDay3, 2, 0) &&
                      editNum(document.Chg.toDay3, 2, 0) &&
                      editNum(document.Chg.dayDue3, 2, 0) &&
                      editNum(document.Chg.monthInc3, 1, 0) &&
                      editNum(document.Chg.fromDay4, 2, 0) &&
                      editNum(document.Chg.toDay4, 2, 0) &&
                      editNum(document.Chg.dayDue4, 2, 0) &&
                      editNum(document.Chg.monthInc4, 1, 0) &&
                      editNum(document.Chg.fromDay5, 2, 0) &&
                      editNum(document.Chg.toDay5, 2, 0) &&
                      editNum(document.Chg.dayDue5, 2, 0) &&
                      editNum(document.Chg.monthInc5, 1, 0))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "VENDORTERMSMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From HDTRMS Where TMCTRM = '$(termsCode)'", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=122")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          %ROW {
              %if (errFound != "" || maintenanceCode == "A")
                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(edtVar, "")
                      @dtw_assign(focusField, "termsCode")
                  %else
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@ctrm", "termsCode")        @dtw_assign(Err_TMCTRM, fieldValue)
                      @DecatErr_Field("@@ctds", "termsDesc")        @dtw_assign(Err_TMCTDS, fieldValue)
                      @DecatErr_Field("@@ctdt", "daysTillDue")      @dtw_assign(Err_TMCTDT, fieldValue)
                      @DecatErr_Field("@@ctdd", "daysForDiscount")  @dtw_assign(Err_TMCTDD, fieldValue)
                      @DecatErr_Field("@@ctdc", "discountPercent")  @dtw_assign(Err_TMCTDC, fieldValue)
                      @DecatErr_Field("@@dued", "dueDate")          @dtw_assign(Err_TMDUED, fieldValue)
                      @DecatErr_Field("@@fdy1", "fromDay1")         @dtw_assign(Err_TMFDY1, fieldValue)
                      @DecatErr_Field("@@tdy1", "toDay1")           @dtw_assign(Err_TMTDY1, fieldValue)
                      @DecatErr_Field("@@due1", "dayDue1")          @dtw_assign(Err_TMDUE1, fieldValue)
                      @DecatErr_Field("@@inc1", "monthInc1")        @dtw_assign(Err_TMINC1, fieldValue)
                      @DecatErr_Field("@@fdy2", "fromDay2")         @dtw_assign(Err_TMFDY2, fieldValue)
                      @DecatErr_Field("@@tdy2", "toDay2")           @dtw_assign(Err_TMTDY2, fieldValue)
                      @DecatErr_Field("@@due2", "dayDue2")          @dtw_assign(Err_TMDUE2, fieldValue)
                      @DecatErr_Field("@@inc2", "monthInc2")        @dtw_assign(Err_TMINC2, fieldValue)
                      @DecatErr_Field("@@fdy3", "fromDay3")         @dtw_assign(Err_TMFDY3, fieldValue)
                      @DecatErr_Field("@@tdy3", "toDay3")           @dtw_assign(Err_TMTDY3, fieldValue)
                      @DecatErr_Field("@@due3", "dayDue3")          @dtw_assign(Err_TMDUE3, fieldValue)
                      @DecatErr_Field("@@inc3", "monthInc3")        @dtw_assign(Err_TMINC3, fieldValue)
                      @DecatErr_Field("@@fdy4", "fromDay4")         @dtw_assign(Err_TMFDY4, fieldValue)
                      @DecatErr_Field("@@tdy4", "toDay4")           @dtw_assign(Err_TMTDY4, fieldValue)
                      @DecatErr_Field("@@due4", "dayDue4")          @dtw_assign(Err_TMDUE4, fieldValue)
                      @DecatErr_Field("@@inc4", "monthInc4")        @dtw_assign(Err_TMINC4, fieldValue)
                      @DecatErr_Field("@@fdy5", "fromDay5")         @dtw_assign(Err_TMFDY5, fieldValue)
                      @DecatErr_Field("@@tdy5", "toDay5")           @dtw_assign(Err_TMTDY5, fieldValue)
                      @DecatErr_Field("@@due5", "dayDue5")          @dtw_assign(Err_TMDUE5, fieldValue)
                      @DecatErr_Field("@@inc5", "monthInc5")        @dtw_assign(Err_TMINC5, fieldValue)
                  %endif

                  @Decat_Field("@@ctrm")   @dtw_assign(V_TMCTRM, fieldValue)
                  @Decat_Field("@@ctds")   @dtw_assign(V_TMCTDS, fieldValue)
                  @Decat_Field("@@ctdt")   @dtw_assign(V_TMCTDT, fieldValue)
                  @Decat_Field("@@ctdd")   @dtw_assign(V_TMCTDD, fieldValue)
                  @Decat_Field("@@ctdc")   @dtw_assign(V_TMCTDC, fieldValue)
                  @Decat_Field("@@dued")   @dtw_assign(V_TMDUED, fieldValue)
                  @Decat_Field("@@fdy1")   @dtw_assign(V_TMFDY1, fieldValue)
                  @Decat_Field("@@tdy1")   @dtw_assign(V_TMTDY1, fieldValue)
                  @Decat_Field("@@due1")   @dtw_assign(V_TMDUE1, fieldValue)
                  @Decat_Field("@@inc1")   @dtw_assign(V_TMINC1, fieldValue)
                  @Decat_Field("@@fdy2")   @dtw_assign(V_TMFDY2, fieldValue)
                  @Decat_Field("@@tdy2")   @dtw_assign(V_TMTDY2, fieldValue)
                  @Decat_Field("@@due2")   @dtw_assign(V_TMDUE2, fieldValue)
                  @Decat_Field("@@inc2")   @dtw_assign(V_TMINC2, fieldValue)
                  @Decat_Field("@@fdy3")   @dtw_assign(V_TMFDY3, fieldValue)
                  @Decat_Field("@@tdy3")   @dtw_assign(V_TMTDY3, fieldValue)
                  @Decat_Field("@@due3")   @dtw_assign(V_TMDUE3, fieldValue)
                  @Decat_Field("@@inc3")   @dtw_assign(V_TMINC3, fieldValue)
                  @Decat_Field("@@fdy4")   @dtw_assign(V_TMFDY4, fieldValue)
                  @Decat_Field("@@tdy4")   @dtw_assign(V_TMTDY4, fieldValue)
                  @Decat_Field("@@due4")   @dtw_assign(V_TMDUE4, fieldValue)
                  @Decat_Field("@@inc4")   @dtw_assign(V_TMINC4, fieldValue)
                  @Decat_Field("@@fdy5")   @dtw_assign(V_TMFDY5, fieldValue)
                  @Decat_Field("@@tdy5")   @dtw_assign(V_TMTDY5, fieldValue)
                  @Decat_Field("@@due5")   @dtw_assign(V_TMDUE5, fieldValue)
                  @Decat_Field("@@inc5")   @dtw_assign(V_TMINC5, fieldValue)

                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(focusField, "termsCode")
                  %endif
                  @dtw_assign(errFound, "")

              %elif (maintenanceCode == "Z")
                  @dtw_assign(V_TMCTRM,  "")
                  @dtw_assign(focusField, "termsCode")
                  @DateInputFromCYMD(V_TMDUED)
              %else
                  @dtw_assign(focusField, "termsDesc")
                  @DateInputFromCYMD(V_TMDUED)
              %endif

              <table $(contentTable)>
                  @SetTextOvr(Err_TMCTRM)
                  <tr><td class="dsphdr"><span $(textOvr)>Terms Code</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputcode"><input name="termsCode" type="text" value="$(V_TMCTRM)" size="2" maxlength="2"> $(reqFieldChar) </td>
                      %else
                          <td class="inputcode"><input name="termsCode" type="hidden" value="$(V_TMCTRM)" size="2" maxlength="2">$(V_TMCTRM)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_TMCTRM)

                  @SetTextOvr(Err_TMCTDS)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="termsDesc" type="text" value="$(V_TMCTDS)" size="30" maxlength="20"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_TMCTDS)
	   		
                  @SetTextOvr(Err_TMCTDT)
                  <tr><td class="dsphdr"><span $(textOvr)>Days Till Due</span></td>
                      <td class="inputnmbr"><input name="daysTillDue" type="text" value="$(V_TMCTDT)" size="3" maxlength="3"></td>
                  </tr>
                  @DspErrMsg(Err_TMCTDT)
	   		
                  @SetTextOvr(Err_TMCTDD)
                  <tr><td class="dsphdr"><span $(textOvr)>Days For Discount</span></td>
                      <td class="inputnmbr"><input name="daysForDiscount" type="text" value="$(V_TMCTDD)" size="3" maxlength="3"></td>
                  </tr>
                  @DspErrMsg(Err_TMCTDD)
	   		
                  @SetTextOvr(Err_TMCTDC)
                  <tr><td class="dsphdr"><span $(textOvr)>Discount Percent</span></td>
                      <td class="inputnmbr"><input name="discountPercent" type="text" value="$(V_TMCTDC)" size="3" maxlength="4"></td>
                  </tr>
                  @DspErrMsg(Err_TMCTDC)

                  @SetTextOvr(Err_TMDUED)
	           <tr><td class="dsphdr"><span $(textOvr)>Due Date</span></td>
                      <td class="inputnmbr"><input type="text" name="dueDate" value="$(V_TMDUED)" size="6" maxlength="6"> 		
                          <a href="javascript:calWindow('dueDate');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_TMDUED)
              </table>

              <table $(contentTable)>
                  <tr><td class="dsphdr">Day Of The Month:</td>
                      <td class="colhdr">From<br>Day</td>
                      <td class="colhdr">Through<br>Day</td>
                      <td class="colhdr">Day<br>Due</td>
                      <td class="colhdr">Month<br>Increment</td>
                      <td class="dsphdr">Due Date Month = (Invoice Month + Month Increment)</td>
                  </tr>
	   		
                  <tr><td>&nbsp;</td>
                      <td class="inputnmbr"><input name="fromDay1" type="text" value="$(V_TMFDY1)" size="3" maxlength="2"></td>
                      <td class="inputnmbr"><input name="toDay1" type="text" value="$(V_TMTDY1)" size="3" maxlength="2"></td>
                      <td class="inputnmbr"><input name="dayDue1" type="text" value="$(V_TMDUE1)" size="3" maxlength="2"></td>
                      <td class="inputnmbr"><input name="monthInc1" type="text" value="$(V_TMINC1)" size="3" maxlength="1"></td>
                  </tr>
                  @DspErrMsg(Err_TMFDY1)
	   		
                  <tr><td>&nbsp;</td>
                      <td class="inputnmbr"><input name="fromDay2" type="text" value="$(V_TMFDY2)" size="3" maxlength="2"></td>
                      <td class="inputnmbr"><input name="toDay2" type="text" value="$(V_TMTDY2)" size="3" maxlength="2"></td>
                      <td class="inputnmbr"><input name="dayDue2" type="text" value="$(V_TMDUE2)" size="3" maxlength="2"></td>
                      <td class="inputnmbr"><input name="monthInc2" type="text" value="$(V_TMINC2)" size="3" maxlength="1"></td>
                  </tr>
                  @DspErrMsg(Err_TMFDY2)
	   		
                  <tr><td>&nbsp;</td>
                      <td class="inputnmbr"><input name="fromDay3" type="text" value="$(V_TMFDY3)" size="3" maxlength="2"></td>
                      <td class="inputnmbr"><input name="toDay3" type="text" value="$(V_TMTDY3)" size="3" maxlength="2"></td>
                      <td class="inputnmbr"><input name="dayDue3" type="text" value="$(V_TMDUE3)" size="3" maxlength="2"></td>
                      <td class="inputnmbr"><input name="monthInc3" type="text" value="$(V_TMINC3)" size="3" maxlength="1"></td>
                  </tr>
                  @DspErrMsg(Err_TMFDY3)
	   		
                  <tr><td>&nbsp;</td>
                      <td class="inputnmbr"><input name="fromDay4" type="text" value="$(V_TMFDY4)" size="3" maxlength="2"></td>
                      <td class="inputnmbr"><input name="toDay4" type="text" value="$(V_TMTDY4)" size="3" maxlength="2"></td>
                      <td class="inputnmbr"><input name="dayDue4" type="text" value="$(V_TMDUE4)" size="3" maxlength="2"></td>
                      <td class="inputnmbr"><input name="monthInc4" type="text" value="$(V_TMINC4)" size="3" maxlength="1"></td>
                  </tr>
                  @DspErrMsg(Err_TMFDY4)
	   		
                  <tr><td>&nbsp;</td>
                      <td class="inputnmbr"><input name="fromDay5" type="text" value="$(V_TMFDY5)" size="3" maxlength="2"></td>
                      <td class="inputnmbr"><input name="toDay5" type="text" value="$(V_TMTDY5)" size="3" maxlength="2"></td>
                      <td class="inputnmbr"><input name="dayDue5" type="text" value="$(V_TMDUE5)" size="3" maxlength="2"></td>
                      <td class="inputnmbr"><input name="monthInc5" type="text" value="$(V_TMINC5)" size="3" maxlength="1"></td>
                  </tr>
                  @DspErrMsg(Err_TMFDY5)

                  <tr><td>&nbsp;</td>
                      <td class="dsphdr">(1-31)</td>
                      <td class="dsphdr">(1-31)</td>
                      <td class="dsphdr">(1-31)</td>
                      <td class="dsphdr">(0-9)</td>
                  </tr>
              </table>
          %}
	
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDTMM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(termsCode)
  @dtw_assign(daysTillDue,@dtw_rstrip(daysTillDue))
  @dtw_assign(daysForDiscount,@dtw_rstrip(daysForDiscount))
  @dtw_assign(discountPercent,@dtw_rstrip(discountPercent))
  @dtw_assign(dueDate,@dtw_rstrip(dueDate))
  @dtw_assign(fromDay1,@dtw_rstrip(fromDay1))
  @dtw_assign(toDay1,@dtw_rstrip(toDay1))
  @dtw_assign(dayDue1,@dtw_rstrip(dayDue1))
  @dtw_assign(monthInc1,@dtw_rstrip(monthInc1))
  @dtw_assign(fromDay2,@dtw_rstrip(fromDay2))
  @dtw_assign(toDay2,@dtw_rstrip(toDay2))
  @dtw_assign(dayDue2,@dtw_rstrip(dayDue2))
  @dtw_assign(monthInc2,@dtw_rstrip(monthInc2))
  @dtw_assign(fromDay3,@dtw_rstrip(fromDay3))
  @dtw_assign(toDay3,@dtw_rstrip(toDay3))
  @dtw_assign(dayDue3,@dtw_rstrip(dayDue3))
  @dtw_assign(monthInc3,@dtw_rstrip(monthInc3))
  @dtw_assign(fromDay4,@dtw_rstrip(fromDay4))
  @dtw_assign(toDay4,@dtw_rstrip(toDay4))
  @dtw_assign(dayDue4,@dtw_rstrip(dayDue4))
  @dtw_assign(monthInc4,@dtw_rstrip(monthInc4))
  @dtw_assign(fromDay5,@dtw_rstrip(fromDay5))
  @dtw_assign(toDay5,@dtw_rstrip(toDay5))
  @dtw_assign(dayDue5,@dtw_rstrip(dayDue5))
  @dtw_assign(monthInc5,@dtw_rstrip(monthInc5))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@ctrm", termsCode)
  @Concat_Field("@@ctds", termsDesc)
  @Concat_Field("@@ctdt", daysTillDue)
  @Concat_Field("@@ctdd", daysForDiscount)
  @Concat_Field("@@ctdc", discountPercent)
  @Concat_Field("@@dued", dueDate)
  @Concat_Field("@@fdy1", fromDay1)
  @Concat_Field("@@tdy1", toDay1)
  @Concat_Field("@@due1", dayDue1)
  @Concat_Field("@@inc1", monthInc1)
  @Concat_Field("@@fdy2", fromDay2)
  @Concat_Field("@@tdy2", toDay2)
  @Concat_Field("@@due2", dayDue2)
  @Concat_Field("@@inc2", monthInc2)
  @Concat_Field("@@fdy3", fromDay3)
  @Concat_Field("@@tdy3", toDay3)
  @Concat_Field("@@due3", dayDue3)
  @Concat_Field("@@inc3", monthInc3)
  @Concat_Field("@@fdy4", fromDay4)
  @Concat_Field("@@tdy4", toDay4)
  @Concat_Field("@@due4", dayDue4)
  @Concat_Field("@@inc4", monthInc4)
  @Concat_Field("@@fdy5", fromDay5)
  @Concat_Field("@@tdy5", toDay5)
  @Concat_Field("@@due5", dayDue5)
  @Concat_Field("@@inc5", monthInc5)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(termsDesc), $(termsCode), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@ctrm", "termsCode")
          @Format_ConfMsg_Desc("", $(termsDesc), $(termsCode), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=122&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;termsCode=@dtw_rurlescseq(termsCode)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}