%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Print Order Documents"
  d2wName                 = "PODocumentPrint.d2w"
  d2wVarBase              = "$(genericVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HPOODS_W.PGM %}
%}

%HTML (REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              function confirmSbmSched()  {return confirm("Confirm $(page_title)");}
              %INCLUDE "calendar.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.frVendor.value != "" || document.Chg.toVendor.value != "") {
                        document.Chg.alVendor.checked = false;
                  }
                  if (document.Chg.frUser.value != "" || document.Chg.toUser.value != "") {
                        document.Chg.alUser.checked = false;
                  }
                  if (document.Chg.frHeaderRequiredDate.value != "" || document.Chg.frHeaderRequiredDate.value != "") {
                        document.Chg.alHeaderRequiredDate.checked = false;
                  }
                  if (document.Chg.frOrderNumber.value != "" || document.Chg.toOrderNumber.value != "") {
                        document.Chg.alOrderNumber.checked = false;
                  }
                  if (document.Chg.frLine.value != "" || document.Chg.toLine.value != "") {
                        document.Chg.alLine.checked = false;
                  }
                  if (document.Chg.frWarehouse.value != "" || document.Chg.toWarehouse.value != "") {
                        document.Chg.alWarehouse.checked = false;
                  }
                  if (document.Chg.frItem.value != "" || document.Chg.toItem.value != "") {
                        document.Chg.alItem.checked = false;
                  }
                  if (editNum(document.Chg.frVendor, 7, 0) &&
                      editNum(document.Chg.toVendor, 7, 0) &&
                      editNum(document.Chg.srVendor, 1, 0) &&
                      editNum(document.Chg.srUser, 1, 0) &&
                      editdate(document.Chg.frHeaderRequiredDate) &&
                      editdate(document.Chg.toHeaderRequiredDate) &&
                      editNum(document.Chg.srHeaderRequiredDate, 1, 0) &&
                      editNum(document.Chg.frOrderNumber, 8, 0) &&
                      editNum(document.Chg.toOrderNumber, 8, 0) &&
                      editNum(document.Chg.srOrderNumber, 1, 0) &&
                      editNum(document.Chg.frLine, 3, 0) &&
                      editNum(document.Chg.toLine, 3, 0) &&
                      editNum(document.Chg.srLine, 1, 0) &&
                      editNum(document.Chg.frWarehouse, 3, 0) &&
                      editNum(document.Chg.toWarehouse, 3, 0) &&
                      editNum(document.Chg.srWarehouse, 1, 0) &&
                      editNum(document.Chg.srItem, 1, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      %if (printReportConfirm == "Y")
          <body $(bodyTagAttr)>
      %else
          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
      %endif
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ORDERDOCUMENTPRINT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %if (printReportConfirm == "Y")
                          @dtw_assign(sbmSchConfirm, "onClick=""return confirmSbmSched()""")
                      %endif
                      %INCLUDE "SubmitScheduleTop.icl"
                      $(hrTagAttr)

                      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;reprint=@dtw_rurlescseq(reprint)&amp;submitSchedule=@dtw_rurlescseq(submitSchedule)">
                          <table $(contentTable)>
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@1sel", "docType")                @dtw_assign(Err_N2SELC, fieldValue)
                                  @DecatErr_Field("@@rpnt", "reprint")                @dtw_assign(Err_N2RPNT, fieldValue)
                                  @DecatErr_Field("@@pgbk", "breakByWhs")             @dtw_assign(Err_N5PGBK, fieldValue)
                                  @DecatErr_Field("@@fvnd", "frVendor")               @dtw_assign(Err_N5FVND, fieldValue)
                                  @DecatErr_Field("@@tvnd", "toVendor")               @dtw_assign(Err_N5TVND, fieldValue)
                                  @DecatErr_Field("@@avnd", "alVendor")               @dtw_assign(Err_N5AVND, fieldValue)
                                  @DecatErr_Field("@@svnd", "srVendor")               @dtw_assign(Err_N5SVND, fieldValue)
                                  @DecatErr_Field("@@fusr", "frUser")                 @dtw_assign(Err_N5FUSR, fieldValue)
                                  @DecatErr_Field("@@tusr", "toUser")                 @dtw_assign(Err_N5TUSR, fieldValue)
                                  @DecatErr_Field("@@ausr", "alUser")                 @dtw_assign(Err_N5AUSR, fieldValue)
                                  @DecatErr_Field("@@susr", "srUser")                 @dtw_assign(Err_N5SUSR, fieldValue)
                                  @DecatErr_Field("@@fdat", "frHeaderRequiredDate")   @dtw_assign(Err_N5FDAT, fieldValue)
                                  @DecatErr_Field("@@tdat", "toHeaderRequiredDate")   @dtw_assign(Err_N5TDAT, fieldValue)
                                  @DecatErr_Field("@@adat", "alHeaderRequiredDate")   @dtw_assign(Err_N5ADAT, fieldValue)
                                  @DecatErr_Field("@@sdat", "srHeaderRequiredDate")   @dtw_assign(Err_N5SDAT, fieldValue)
                                  @DecatErr_Field("@@ford", "frOrderNumber")          @dtw_assign(Err_N5FORD, fieldValue)
                                  @DecatErr_Field("@@tord", "toOrderNumber")          @dtw_assign(Err_N5TORD, fieldValue)
                                  @DecatErr_Field("@@aord", "alOrderNumber")          @dtw_assign(Err_N5AORD, fieldValue)
                                  @DecatErr_Field("@@sord", "srOrderNumber")          @dtw_assign(Err_N5SORD, fieldValue)
                                  @DecatErr_Field("@@forl", "frLine")                 @dtw_assign(Err_N5FORL, fieldValue)
                                  @DecatErr_Field("@@torl", "toLine")                 @dtw_assign(Err_N5TORL, fieldValue)
                                  @DecatErr_Field("@@aorl", "alLine")                 @dtw_assign(Err_N5AORL, fieldValue)
                                  @DecatErr_Field("@@sorl", "srLine")                 @dtw_assign(Err_N5SORL, fieldValue)
                                  @DecatErr_Field("@@fwhs", "frWarehouse")            @dtw_assign(Err_N5FWHS, fieldValue)
                                  @DecatErr_Field("@@twhs", "toWarehouse")            @dtw_assign(Err_N5TWHS, fieldValue)
                                  @DecatErr_Field("@@awhs", "alWarehouse")            @dtw_assign(Err_N5AWHS, fieldValue)
                                  @DecatErr_Field("@@swhs", "srWarehouse")            @dtw_assign(Err_N5SWHS, fieldValue)
                                  @DecatErr_Field("@@fitm", "frItem")                 @dtw_assign(Err_N5FITM, fieldValue)
                                  @DecatErr_Field("@@titm", "toItem")                 @dtw_assign(Err_N5TITM, fieldValue)
                                  @DecatErr_Field("@@aitm", "alItem")                 @dtw_assign(Err_N5AITM, fieldValue)
                                  @DecatErr_Field("@@sitm", "srItem")                 @dtw_assign(Err_N5SITM, fieldValue)
                                  %INCLUDE "scheduleJobErr.icl"    %{ Schedule Entries Errors %}

                                  @Decat_Field("@@1sel")   @dtw_assign(V_N2SELC,  fieldValue)
                                  @Decat_Field("@@rpnt")   @dtw_assign(V_N2RPNT,  fieldValue)
                                  @Decat_Field("@@pgbk")   @dtw_assign(V_N5PGBK,  fieldValue)
                                  @Decat_Field("@@fvnd")   @dtw_assign(V_N5FVND,  fieldValue)
                                  @Decat_Field("@@tvnd")   @dtw_assign(V_N5TVND,  fieldValue)
                                  @Decat_Field("@@avnd")   @dtw_assign(V_N5AVND,  fieldValue)
                                  @Decat_Field("@@svnd")   @dtw_assign(V_N5SVND,  fieldValue)
                                  @Decat_Field("@@fusr")   @dtw_assign(V_N5FUSR,  fieldValue)
                                  @Decat_Field("@@tusr")   @dtw_assign(V_N5TUSR,  fieldValue)
                                  @Decat_Field("@@ausr")   @dtw_assign(V_N5AUSR,  fieldValue)
                                  @Decat_Field("@@susr")   @dtw_assign(V_N5SUSR,  fieldValue)
                                  @Decat_Field("@@fdat")   @dtw_assign(V_N5FDAT,  fieldValue)
                                  @Decat_Field("@@tdat")   @dtw_assign(V_N5TDAT,  fieldValue)
                                  @Decat_Field("@@adat")   @dtw_assign(V_N5ADAT,  fieldValue)
                                  @Decat_Field("@@sdat")   @dtw_assign(V_N5SDAT,  fieldValue)
                                  @Decat_Field("@@ford")   @dtw_assign(V_N5FORD,  fieldValue)
                                  @Decat_Field("@@tord")   @dtw_assign(V_N5TORD,  fieldValue)
                                  @Decat_Field("@@aord")   @dtw_assign(V_N5AORD,  fieldValue)
                                  @Decat_Field("@@sord")   @dtw_assign(V_N5SORD,  fieldValue)
                                  @Decat_Field("@@forl")   @dtw_assign(V_N5FORL,  fieldValue)
                                  @Decat_Field("@@torl")   @dtw_assign(V_N5TORL,  fieldValue)
                                  @Decat_Field("@@aorl")   @dtw_assign(V_N5AORL,  fieldValue)
                                  @Decat_Field("@@sorl")   @dtw_assign(V_N5SORL,  fieldValue)
                                  @Decat_Field("@@fwhs")   @dtw_assign(V_N5FWHS,  fieldValue)
                                  @Decat_Field("@@twhs")   @dtw_assign(V_N5TWHS,  fieldValue)
                                  @Decat_Field("@@awhs")   @dtw_assign(V_N5AWHS,  fieldValue)
                                  @Decat_Field("@@swhs")   @dtw_assign(V_N5SWHS,  fieldValue)
                                  @Decat_Field("@@fitm")   @dtw_assign(V_N5FITM,  fieldValue)
                                  @Decat_Field("@@titm")   @dtw_assign(V_N5TITM,  fieldValue)
                                  @Decat_Field("@@aitm")   @dtw_assign(V_N5AITM,  fieldValue)
                                  @Decat_Field("@@sitm")   @dtw_assign(V_N5SITM,  fieldValue)
                                  %INCLUDE "scheduleJobValue.icl"    %{ Schedule Entries Values %}

                              %else
                                  @dtw_assign(focusField, "frVendor")
                                  @dtw_assign(V_N2SELC, "3")
                                  @dtw_assign(V_N2RPNT, "N")
                                  @dtw_assign(V_N5PGBK, "N")
                                  @dtw_assign(V_N5AVND, "ALL")
                                  @dtw_assign(V_N5AUSR, "ALL")
                                  @dtw_assign(V_N5ADAT, "ALL")
                                  @dtw_assign(V_N5AORD, "ALL")
                                  @dtw_assign(V_N5AORL, "ALL")
                                  @dtw_assign(V_N5AWHS, "ALL")
                                  @dtw_assign(V_N5AITM, "ALL")
                                  %if (forPO != "")
                                    @dtw_assign(V_N5FORD, forPO)
                                    @dtw_assign(V_N5TORD, forPO)
                                    @dtw_assign(V_N5AORD, "")
                                    @RtvFldDesc("POPO=$(forPO)", "POPOMS", "POFL01", poFL01)
                                    %if (poFL01 == "2")
                                        @dtw_assign(V_N2RPNT, "Y")
                                    %endif
                                    @RtvFldDesc("POPO=$(forPO)", "POPOMS", "POTYPE", poType)
                                    %if (poType == "Q")
                                        @dtw_assign(V_N2SELC, "2")
                                    %endif
                                    @dtw_assign(forPO, "")
                                  %endif
                              %endif

                              @dtw_assign(chkPO, "")
                              @dtw_assign(chkQTE, "")
                              @dtw_assign(chkRCV, "")
                              %if (V_N2SELC == "3")
                                  @dtw_assign(chkPO, "CHECKED")
                              %elseif (V_N2SELC == "2")
                                  @dtw_assign(chkQTE, "CHECKED")
                              %else
                                  @dtw_assign(chkRCV, "CHECKED")
                              %endif
                              %if (V_N2RPNT == "Y")
                                  @dtw_assign(chkReprint, "CHECKED")
                              %else
                                  @dtw_assign(chkReprint, "")
                              %endif
                              %if (V_N5PGBK == "N")
                                  @dtw_assign(N5PGBKno, "CHECKED")
                                  @dtw_assign(N5PGBKyes, "")
                              %else
                                  @dtw_assign(N5PGBKno, "")
                                  @dtw_assign(N5PGBKyes, "CHECKED")
                              %endif

                              %if (V_N5ALOC == "ALL")
                                  @dtw_assign(N5ALOCchecked, "CHECKED")
                              %else
                                  @dtw_assign(N5ALOCchecked, "")
                              %endif
                              %if (V_N5AVND == "ALL")
                                  @dtw_assign(N5AVNDchecked, "CHECKED")
                              %else
                                  @dtw_assign(N5AVNDchecked, "")
                              %endif
                              %if (V_N5AUSR == "ALL")
                                  @dtw_assign(N5AUSRchecked, "CHECKED")
                              %else
                                  @dtw_assign(N5AUSRchecked, "")
                              %endif
                              %if (V_N5ADAT == "ALL")
                                  @dtw_assign(N5ADATchecked, "CHECKED")
                              %else
                                  @dtw_assign(N5ADATchecked, "")
                              %endif
                              %if (V_N5AORD == "ALL")
                                  @dtw_assign(N5AORDchecked, "CHECKED")
                              %else
                                  @dtw_assign(N5AORDchecked, "")
                              %endif
                              %if (V_N5ASV == "ALL")
                                  @dtw_assign(N5ASVchecked, "CHECKED")
                              %else
                                  @dtw_assign(N5ASVchecked, "")
                              %endif
                              %if (V_N5AORL == "ALL")
                                  @dtw_assign(N5AORLchecked, "CHECKED")
                              %else
                                  @dtw_assign(N5AORLchecked, "")
                              %endif
                              %if (V_N5AWHS == "ALL")
                                  @dtw_assign(N5AWHSchecked, "CHECKED")
                              %else
                                  @dtw_assign(N5AWHSchecked, "")
                              %endif
                              %if (V_N5AITM == "ALL")
                                  @dtw_assign(N5AITMchecked, "CHECKED")
                              %else
                                  @dtw_assign(N5AITMchecked, "")
                              %endif
                              %if (V_N5ARQD == "ALL")
                                  @dtw_assign(N5ARQDchecked, "CHECKED")
                              %else
                                  @dtw_assign(N5ARQDchecked, "")
                              %endif

                              @SetTextOvr(Err_N2SELC)
                              <tr><td class="dsphdr"><span $(textOvr)>Document</span></td>
                                  <td class="inputnmbr"><input name="docType" type="radio" VALUE='3' $(chkPO)>Purchase Order </td>
                              </tr>
                              <tr><td>&nbsp;</td><td class="inputnmbr"><input name="docType" type="radio" VALUE='1' $(chkQTE)>Quote</td></tr>
                              <tr><td>&nbsp;</td><td class="inputnmbr"><input name="docType" type="radio" VALUE='2' $(chkRCV)>Receiver</td></tr>
                              @DspErrMsg(Err_N2SELC)

                              @SetTextOvr(Err_N2RPNT)
                              <tr><td class="dsphdr"><span $(textOvr)>Reprint</span></td>
                                  <td class="inputnmbr"><input name="reprint" type="checkbox" VALUE='Y' $(chkReprint)></td>
                              </tr>
                              @DspErrMsg(Err_N2RPNT)
                          </table>

                          @dtw_assign(sortSeqMax, "4")
                          <fieldset class="legendBody">
                          <legend class="legendTitle">Header</legend>
                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Primary<br>Sequence</td>
                              </tr>

                              @SetTextOvr(Err_N5FVND)
                              %if (textOvr == "")  @SetTextOvr(Err_N5TVND)  %endif
                              %if (textOvr == "")  @SetTextOvr(Err_N5AVND)  %endif
                              %if (textOvr == "")  @SetTextOvr(Err_N5SVND)  %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Vendor Number</span></td>
                                  <td class="inputnmbr"><input name="frVendor" value="$(V_N5FVND)" type="text" size="10" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=frVendor&amp;fldDesc=fvndName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="fvndName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toVendor" value="$(V_N5TVND)" type="text" size="10" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toVendor&amp;fldDesc=tvndName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="tvndName" type="hidden"></td>
                                  <td class="inputalph"><input id="alVendor" name="alVendor" type="checkbox" VALUE='ALL' $(N5AVNDchecked) onClick="if (this.checked) this.form.frVendor.value='', this.form.toVendor.value='';"></td>
                                  @Build_Sort_Select("srVendor", "$(V_N5SVND)")
                              </tr>
                              @DspErrMsg(Err_N5FVND)
                              @DspErrMsg(Err_N5TVND)
                              @DspErrMsg(Err_N5AVND)
                              @DspErrMsg(Err_N5SVND)

                              @SetTextOvr(Err_N5FUSR)
                              %if (textOvr == "")  @SetTextOvr(Err_N5TUSR)  %endif
                              %if (textOvr == "")  @SetTextOvr(Err_N5AUSR)  %endif
                              %if (textOvr == "")  @SetTextOvr(Err_N5SUSR)  %endif
                              <tr><td class="dsphdr"><span $(textOvr)>User ID</span></td>
                                  <td class="inputalph"><input name="frUser" VALUE="$(V_N5FUSR)" type="text" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input name="toUser" VALUE="$(V_N5TUSR)" type="text" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input id="alUser" name="alUser" type="checkbox" VALUE='ALL' $(N5AUSRchecked) onClick="if (this.checked) this.form.frUser.value='', this.form.toUser.value='';"></td>
                                  @Build_Sort_Select("srUser", "$(V_N5SUSR)")
                              </tr>
                              @DspErrMsg(Err_N5FUSR)
                              @DspErrMsg(Err_N5TUSR)
                              @DspErrMsg(Err_N5AUSR)
                              @DspErrMsg(Err_N5SUSR)

                              @SetTextOvr(Err_N5FDAT)
                              %if (textOvr == "")  @SetTextOvr(Err_N5TDAT)  %endif
                              %if (textOvr == "")  @SetTextOvr(Err_N5ADAT)  %endif
                              %if (textOvr == "")  @SetTextOvr(Err_N5SDAT)  %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Required Date</span></td>
                                  <td class="inputnmbr"><input name="frHeaderRequiredDate" VALUE="$(V_N5FDAT)" type="text" size="10" maxlength="6">
                                      <a href="javascript:calWindow('frHeaderRequiredDate');">$(calendarImage)</a>&nbsp;</td>
                                  <td class="inputnmbr"><input name="toHeaderRequiredDate" VALUE="$(V_N5TDAT)" type="text" size="10" maxlength="6">
                                      <a href="javascript:calWindow('toHeaderRequiredDate');">$(calendarImage)</a>&nbsp;</td>
                                  <td class="inputalph"><input id="alHeaderRequiredDate" name="alHeaderRequiredDate" type="checkbox" VALUE='ALL' $(N5ADATchecked) onClick="if (this.checked) this.form.frHeaderRequiredDate.value='', this.form.toHeaderRequiredDate.value='';"></td>
                                  @Build_Sort_Select("srHeaderRequiredDate", "$(V_N5SDAT)")
                              </tr>
                              @DspErrMsg(Err_N5FDAT)
                              @DspErrMsg(Err_N5TDAT)
                              @DspErrMsg(Err_N5ADAT)
                              @DspErrMsg(Err_N5SDAT)

                              @SetTextOvr(Err_N5FORD)
                              %if (textOvr == "")  @SetTextOvr(Err_N5TORD)  %endif
                              %if (textOvr == "")  @SetTextOvr(Err_N5AORD)  %endif
                              %if (textOvr == "")  @SetTextOvr(Err_N5SORD)  %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Order Number</span></td>
                                  <td class="inputnmbr"><input name="frOrderNumber" VALUE="$(V_N5FORD)" type="text" size="10" maxlength="8"></td>
                                  <td class="inputnmbr"><input name="toOrderNumber" VALUE="$(V_N5TORD)" type="text" size="10" maxlength="8"></td>
                                  <td class="inputalph"><input id="alOrderNumber" name="alOrderNumber" type="checkbox" VALUE='ALL' $(N5AORDchecked) onClick="if (this.checked) this.form.frOrderNumber.value='', this.form.toOrderNumber.value='';"></td>
                                  @Build_Sort_Select("srOrderNumber", "$(V_N5SORD)")
                              </tr>
                              @DspErrMsg(Err_N5FORD)
                              @DspErrMsg(Err_N5TORD)
                              @DspErrMsg(Err_N5AORD)
                              @DspErrMsg(Err_N5SORD)
                          </table>
                          </fieldset>


                          <fieldset class="legendBody">
                          <legend class="legendTitle">Detail</legend>
                          <table $(contentTable)>
                              @dtw_assign(sortSeqMax, "3")
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Secondary<br>Sequence</td>
                              </tr>

                              @SetTextOvr(Err_N5FORL)
                              %if (textOvr == "")  @SetTextOvr(Err_N5TORL)  %endif
                              %if (textOvr == "")  @SetTextOvr(Err_N5AORL)  %endif
                              %if (textOvr == "")  @SetTextOvr(Err_N5SORL)  %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Line Number</span></td>
                                  <td class="inputnmbr"><input name="frLine" VALUE="$(V_N5FORL)" type="text" size="6" maxlength="3"></td>
                                  <td class="inputnmbr"><input name="toLine" VALUE="$(V_N5TORL)" type="text" size="6" maxlength="3"></td>
                                  <td class="inputalph"><input id="alLine" name="alLine" type="checkbox" VALUE='ALL' $(N5AORLchecked) onClick="if (this.checked) this.form.frLine.value='', this.form.toLine.value='';"></td>
                                  @Build_Sort_Select("srLine", "$(V_N5SORL)")
                              </tr>
                              @DspErrMsg(Err_N5FORL)
                              @DspErrMsg(Err_N5TORL)
                              @DspErrMsg(Err_N5AORL)
                              @DspErrMsg(Err_N5SORL)

                              @SetTextOvr(Err_N5FWHS)
                              %if (textOvr == "")  @SetTextOvr(Err_N5TWHS)  %endif
                              %if (textOvr == "")  @SetTextOvr(Err_N5AWHS)  %endif
                              %if (textOvr == "")  @SetTextOvr(Err_N5SWHS)  %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Warehouse Number</span></td>
                                  <td class="inputnmbr"><input name="frWarehouse" value="$(V_N5FWHS)" type="text" size="6" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=frWarehouse&amp;fldDesc=fwarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fwarehouseName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toWarehouse" value="$(V_N5TWHS)" type="text" size="6" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toWarehouse&amp;fldDesc=twarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="twarehouseName" type="hidden"></td>
                                  <td class="inputalph"><input id="alWarehouse" name="alWarehouse" type="checkbox" VALUE='ALL' $(N5AWHSchecked) onClick="if (this.checked) this.form.frWarehouse.value='', this.form.toWarehouse.value='';"></td>
                                  @Build_Sort_Select("srWarehouse", "$(V_N5SWHS)")
                              </tr>
                              @DspErrMsg(Err_N5FWHS)
                              @DspErrMsg(Err_N5TWHS)
                              @DspErrMsg(Err_N5AWHS)
                              @DspErrMsg(Err_N5SWHS)

                              @SetTextOvr(Err_N5FITM)
                              %if (textOvr == "")  @SetTextOvr(Err_N5TITM)  %endif
                              %if (textOvr == "")  @SetTextOvr(Err_N5AITM)  %endif
                              %if (textOvr == "")  @SetTextOvr(Err_N5SITM)  %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="frItem" value="$(V_N5FITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=frItem&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) &nbsp; </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItem" value="$(V_N5TITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItem&amp;fldDesc=titemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="titemDescription" type="hidden"></td>
                                  <td class="inputalph"><input id="alItem" name="alItem" type="checkbox" VALUE='ALL' $(N5AITMchecked) onClick="if (this.checked) this.form.frItem.value='', this.form.toItem.value='';"></td>
                                  @Build_Sort_Select("srItem", "$(V_N5SITM)")
                              </tr>
                              @DspErrMsg(Err_N5FITM)
                              @DspErrMsg(Err_N5TITM)
                              @DspErrMsg(Err_N5AITM)
                              @DspErrMsg(Err_N5SITM)
                          </table>
                          </fieldset>

                          <fieldset class="legendBody">
                             <legend class="legendTitle">Receiver Only</legend>
                                <table $(contentTable)>
                                @SetTextOvr(Err_N5PGBK)
                                <tr><td class="dsphdr"><span $(textOvr)>Page Break By Warehouse</span></td>
                                    <td class="inputnmbr"><input name="breakByWhs" type="radio" VALUE='Y' $(N5PGBKyes)>Yes</td></tr>
                                <tr><td>&nbsp;</td><td class="inputnmbr"><input name="breakByWhs" type="radio" VALUE='N' $(N5PGBKno)>No</td></tr>
                                @DspErrMsg(Err_N5PGBK)
                                </table>
                          </fieldset>

                          @dtw_assign(envProgram, "CPOODP")
                          @dtw_assign(envPrinter, "")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField != "")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @dtw_assign(frVendor,@dtw_rstrip(frVendor))
  @dtw_assign(toVendor,@dtw_rstrip(toVendor))
  @dtw_mUPPERCASE(alVendor)
  @dtw_assign(srVendor,@dtw_rstrip(srVendor))

  @dtw_mUPPERCASE(frUser)
  @dtw_mUPPERCASE(toUser)
  @dtw_mUPPERCASE(alUser)
  @dtw_assign(srUser,@dtw_rstrip(srUser))

  @dtw_assign(frHeaderRequiredDate,@dtw_rstrip(frHeaderRequiredDate))
  @dtw_assign(toHeaderRequiredDate,@dtw_rstrip(toHeaderRequiredDate))
  @dtw_mUPPERCASE(alHeaderRequiredDate)
  @dtw_assign(srHeaderRequiredDate,@dtw_rstrip(srHeaderRequiredDate))

  @dtw_assign(frOrderNumber,@dtw_rstrip(frOrderNumber))
  @dtw_assign(toOrderNumber,@dtw_rstrip(toOrderNumber))
  @dtw_mUPPERCASE(alOrderNumber)
  @dtw_assign(srOrderNumber,@dtw_rstrip(srOrderNumber))

  @dtw_assign(frLine,@dtw_rstrip(frLine))
  @dtw_assign(toLine,@dtw_rstrip(toLine))
  @dtw_mUPPERCASE(alLine)
  @dtw_assign(srLine,@dtw_rstrip(srLine))

  @dtw_assign(frWarehouse,@dtw_rstrip(frWarehouse))
  @dtw_assign(toWarehouse,@dtw_rstrip(toWarehouse))
  @dtw_mUPPERCASE(alWarehouse)
  @dtw_assign(srWarehouse,@dtw_rstrip(srWarehouse))

  @dtw_mUPPERCASE(frItem)
  @dtw_mUPPERCASE(toItem)
  @dtw_mUPPERCASE(alItem)
  @dtw_assign(srItem,@dtw_rstrip(srItem))

  %if (alVendor != "ALL")
      @dtw_assign(alVendor, "")
  %endif

  %if (alUser != "ALL")
      @dtw_assign(alUser, "")
  %endif

  %if (alHeaderRequiredDate != "ALL")
      @dtw_assign(alHeaderRequiredDate, "")
  %endif

  %if (alOrderNumber != "ALL")
      @dtw_assign(alOrderNumber, "")
  %endif

  %if (alLine != "ALL")
      @dtw_assign(alLine, "")
  %endif

  %if (alWarehouse != "ALL")
      @dtw_assign(alWarehouse, "")
  %endif

  %if (alItem != "ALL")
      @dtw_assign(alItem, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@1sel", docType)
  %if (docType != "2")
    @dtw_assign(breakByWhs, "N")
  %endif
  %if (reprint != "Y")
      @dtw_assign(reprint, "N")
  %endif
  @Concat_Field("@@rpnt", reprint)
  @Concat_Field("@@pgbk", breakByWhs)
  @Concat_Field("@@fvnd", frVendor)
  @Concat_Field("@@tvnd", toVendor)
  @Concat_Field("@@avnd", alVendor)
  @Concat_Field("@@svnd", srVendor)
  @Concat_Field("@@fusr", frUser)
  @Concat_Field("@@tusr", toUser)
  @Concat_Field("@@ausr", alUser)
  @Concat_Field("@@susr", srUser)
  @Concat_Field("@@fdat", frHeaderRequiredDate)
  @Concat_Field("@@tdat", toHeaderRequiredDate)
  @Concat_Field("@@adat", alHeaderRequiredDate)
  @Concat_Field("@@sdat", srHeaderRequiredDate)
  @Concat_Field("@@ford", frOrderNumber)
  @Concat_Field("@@tord", toOrderNumber)
  @Concat_Field("@@aord", alOrderNumber)
  @Concat_Field("@@sord", srOrderNumber)
  @Concat_Field("@@forl", frLine)
  @Concat_Field("@@torl", toLine)
  @Concat_Field("@@aorl", alLine)
  @Concat_Field("@@sorl", srLine)
  @Concat_Field("@@fwhs", frWarehouse)
  @Concat_Field("@@twhs", toWarehouse)
  @Concat_Field("@@awhs", alWarehouse)
  @Concat_Field("@@swhs", srWarehouse)
  @Concat_Field("@@fitm", frItem)
  @Concat_Field("@@titm", toItem)
  @Concat_Field("@@aitm", alItem)
  @Concat_Field("@@sitm", srItem)
  %INCLUDE "scheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)
  %INCLUDE "SubmitScheduleUpdate.icl"

%}