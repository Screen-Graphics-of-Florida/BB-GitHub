%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Ship Via"
  d2wName                 = "ShipVia.d2w"
  d2wVarBase              = "$(genericVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPOSVU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "SHIPVIA")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select SVSVSV, SVSVDS, SVSCAC, SVBOLR, upper(SVSVDS) as SVSVDSU, ", stmtSQL)
                      @dtw_concat(stmtSQL, "  ifnull(TVCASV,' ') as TVCASV, ifnull(TVTRBY,' ') as TVTRBY, ifnull(TVACRQ,'N') as TVACRQ ", stmtSQL)
                      @dtw_concat(fileSQL, " HDSHPV left join HDSVTR on TVSVSV=SVSVSV", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, "SVSVSV>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Shipvia_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Shipvia_Query (IN CHAR(64)    profileHandle,
                                     CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)ShipViaMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr"> Description</th></tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="15" maxlength="15">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("SVSVSV", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ShipVia" title="Sequence By Ship Via"> Ship<br>Via</a></th>
              @OrderBy_Sort("SVSVDSU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DESC" title="Sequence By Description, Ship Via"> Description</a></th>
              @OrderBy_Sort("TVCASV", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CarrierShipVia" title="Sequence By Carrier Ship Via, Ship Via">Carrier<br>Ship Via</a></th>
              @OrderBy_Sort("SVSCAC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SCAC" title="Sequence By Standard Carrier Alpha Code, Ship Via"> SCAC</a></th>
              @OrderBy_Sort("SVBOLR", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BOLR" title="Sequence By Bill Of Lading Required, Ship Via"> Bill Of Lading<br>Required</a></th>
              @OrderBy_Sort("TVACRQ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ACRQ" title="Sequence By Account Required, Ship Via">Account<br>Required</a></th>
              @OrderBy_Sort("TVTRBY", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TRBY" title="Sequence By Track By, Ship Via">Track<br>By</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{

              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;shipVia=@dtw_rurlescseq(V_SVSVSV)&amp;shipViaDesc=@dtw_rurlescseq(V_SVSVDS)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_SVSVDS), $(V_SVSVSV), "", "", "", "", confirmDesc)
              @RtvFldDesc("FLTYPE='TRACKBY' and FLVALU='$(V_TVTRBY)'", "SYFLAG", "FLDESC", trackByDesc)
              @dtw_assign(carShipViaDesc, "")
              %if (V_TVCASV != "")
                  @RtvFldDesc("SVSVSV='$(V_TVCASV)'", "HDSHPV", "SVSVDS", carShipViaDesc)
              %endif

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)ShipViaMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_04 == "Y")
                              <a href="$(homeURL)$(cGIPath)ShipViaMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)ShipViaMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_SVSVSV)</td>
                  <td class="colalph">$(V_SVSVDS)</td>
                  <td class="colalph" $(helpCursor)><span title="$(carShipViaDesc)">$(V_TVCASV)</span></td>
                  <td class="colalph">$(V_SVSCAC)</td>
                  <td class="colcode">$(V_SVBOLR)</td>
                  <td class="colcode">$(V_TVACRQ)</td>
                  <td class="colcode" $(helpCursor)><span title="$(trackByDesc)">$(V_TVTRBY)</span></td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select SVSVSV, SVSVDS, SVSCAC, SVBOLR, upper(SVSVDS) as SVSVDSU, ", stmtSQL)
  @dtw_concat(stmtSQL, "  ifnull(TVCASV,' ') as TVCASV, ifnull(TVTRBY,' ') as TVTRBY, ifnull(TVACRQ,'N') as TVACRQ ", stmtSQL)
  @dtw_concat(fileSQL, " HDSHPV left join HDSVTR on TVSVSV=SVSVSV", fileSQL)
  %if (wildCardSearch!="")
      @dtw_concat(selectSQL, "SVSVSV>' ' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @Shipvia_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) Shipvia_XMLQuery (IN  CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("ShipViaList")
          %ROW{
	       @XMLIDTag(V_SVSVSV, "ShipVia ID")
                  @XMLTag(V_SVSVSV, "ShipVia")
                  @XMLTag(V_SVSVDS, "Description")
                  @XMLTag(V_TVCASV, "CarrierShipVia")
                  @XMLTag(V_SVSCAC, "SCACCode")
                  @XMLTag(V_SVBOLR, "BOLRequired")
                  @XMLTag(V_TVACRQ, "AccountRequired")
                  @XMLTag(V_TVTRBY, "TrackBy")
              @XMLEndTag("ShipVia")
          %}
      @XMLEndTag("ShipViaList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "SVSVDSU,SVSVSV")
          @DTW_ASSIGN(orderByDisplay, "Description, Ship Via")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "ShipVia")
      %if (orderBy == "SVSVSV")
          @DTW_ASSIGN(orderBy, "SVSVSV DESC")
          @DTW_ASSIGN(orderByDisplay, "Ship Via (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SVSVSV")
          @DTW_ASSIGN(orderByDisplay, "Ship Via")
      %endif
  %elseif (sequence == "DESC")
      %if (orderBy == "SVSVDSU, SVSVSV")
          @DTW_ASSIGN(orderBy, "SVSVDSU DESC, SVSVSV")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Ship Via")
      %else
          @DTW_ASSIGN(orderBy, "SVSVDSU, SVSVSV")
          @DTW_ASSIGN(orderByDisplay, "Description, Ship Via")
      %endif
  %elseif (sequence == "CarrierShipVia")
      %if (orderBy == "TVCASV,SVSVSV")
          @DTW_ASSIGN(orderBy, "TVCASV DESC,SVSVSV")
          @DTW_ASSIGN(orderByDisplay, "Carrier Ship Via (descending), Ship Via")
      %else
          @DTW_ASSIGN(orderBy, "TVCASV,SVSVSV")
          @DTW_ASSIGN(orderByDisplay, "Carrier Ship Via, Ship Via")
      %endif
  %elseif (sequence == "SCAC")
      %if (orderBy == "SVSCAC, SVSVSV")
          @DTW_ASSIGN(orderBy, "SVSCAC DESC, SVSVSV")
          @DTW_ASSIGN(orderByDisplay, "Standard Carrier Alpha Code (descending), Ship Via")
      %else
          @DTW_ASSIGN(orderBy, "SVSCAC, SVSVSV")
          @DTW_ASSIGN(orderByDisplay, "Standard Carrier Alpha Code, Ship Via")
      %endif
  %elseif (sequence == "ACRQ")
      %if (orderBy == "TVACRQ, SVSVSV")
          @DTW_ASSIGN(orderBy, "TVACRQ DESC, SVSVSV")
          @DTW_ASSIGN(orderByDisplay, "Account Required (descending), Ship Via")
      %else
          @DTW_ASSIGN(orderBy, "TVACRQ, SVSVSV")
          @DTW_ASSIGN(orderByDisplay, "Account Required, Ship Via")
      %endif
  %elseif (sequence == "TRBY")
      %if (orderBy == "TVTRBY, SVSVSV")
          @DTW_ASSIGN(orderBy, "TVTRBY DESC, SVSVSV")
          @DTW_ASSIGN(orderByDisplay, "Track By (descending), Ship Via")
      %else
          @DTW_ASSIGN(orderBy, "TVTRBY, SVSVSV")
          @DTW_ASSIGN(orderByDisplay, "Track By, Ship Via")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("upper(SVSVDS)", "Description", $(srchDesc), "U", operDesc, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}