%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "Employee.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Pay Code Maintenance"
  d2wName                 = "PaycodeMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;coNumber=@dtw_rurlescseq(coNumber)&amp;facNumber=@dtw_rurlescseq(facNumber)&amp;payCode=@dtw_rurlescseq(payCode)&amp;maintenanceCode=D"
  programName             = "HPRPYM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  function validate(chgForm) {
                      if (document.Chg.coNumber.value =="" ||
                          document.Chg.facNumber.value =="" ||
                          document.Chg.payCode.value =="" ||
                          document.Chg.codeDesc.value =="" ||
                          document.Chg.reportHeading.value =="" ||
                          document.Chg.summaryPayType.value ==""
                                                       )
                         {alert("$(reqFieldError)"); return false;}
                      if (editNum(document.Chg.coNumber,             2, 0) &&
                          editNum(document.Chg.facNumber,            4, 0) &&
                          editNum(document.Chg.processingSeq,        3, 0) &&
                          editNum(document.Chg.glAcctNumber,         4, 0) &&
                          editNum(document.Chg.glSubAcctNumber,      4, 0) &&
                          editNum(document.Chg.hoursUnitsEarnings,   5, 2) &&
                          editNum(document.Chg.overrideRate,         6, 5) &&
                          editdate(document.Chg.startDate) &&
                          editdate(document.Chg.endDate) &&
                          editNum(document.Chg.maxYTDHoursUnits,     7, 2) &&
                          editNum(document.Chg.maxYTDEarnings,       7, 2))
                          return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
                  %INCLUDE "Menu.js"
                  %INCLUDE "numedit.icl"
                  %INCLUDE "dateedit.icl"
                  %INCLUDE "calendar.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "PAYCODEMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "SELECT * FROM PRCODE WHERE C2COMP=$(coNumber) and C2FACL=$(facNumber) and C2CODE='$(payCode)'", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=165")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;warningFlag=@dtw_rurlescseq(warningFlag)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "coNumber")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@comp", "coNumber")             @dtw_assign(Err_C2COMP, fieldValue)
                          @DecatErr_Field("@@facl", "facNumber")            @dtw_assign(Err_C2FACL, fieldValue)
                          @DecatErr_Field("@@code", "payCode")              @dtw_assign(Err_C2CODE, fieldValue)
                          @DecatErr_Field("@@desc", "codeDesc")             @dtw_assign(Err_C2DESC, fieldValue)
                          @DecatErr_Field("@@rphd", "reportHeading")        @dtw_assign(Err_C2RPHD, fieldValue)
                          @DecatErr_Field("@@smty", "summaryPayType")       @dtw_assign(Err_C2SMTY, fieldValue)
                          @DecatErr_Field("@@hrcd", "hoursOrUnits")         @dtw_assign(Err_C2HRCD, fieldValue)
                          @DecatErr_Field("@@prem", "applyShiftPremium")    @dtw_assign(Err_C2PREM, fieldValue)
                          @DecatErr_Field("@@ded@", "takeDeduction")        @dtw_assign(Err_C2DED,  fieldValue)
                          @DecatErr_Field("@@accr", "vacSickAccruals")      @dtw_assign(Err_C2ACCR, fieldValue)
                          @DecatErr_Field("@@iotc", "includeOT")            @dtw_assign(Err_C2IOTC, fieldValue)
                          @DecatErr_Field("@@wgds", "processDistTables")    @dtw_assign(Err_C2WGDS, fieldValue)
                          @DecatErr_Field("@@slds", "processSalDist")       @dtw_assign(Err_C2SLDS, fieldValue)
                          @DecatErr_Field("@@seq@", "processingSeq")        @dtw_assign(Err_C2SEQ,  fieldValue)
                          @DecatErr_Field("@@hrs@", "hoursUnitsEarnings")   @dtw_assign(Err_C2HRS,  fieldValue)
                          @DecatErr_Field("@@dept", "deptWorked")           @dtw_assign(Err_C2DEPT, fieldValue)
                          @DecatErr_Field("@@acct", "glAcctNumber")         @dtw_assign(Err_C2ACCT, fieldValue)
                          @DecatErr_Field("@@sub@", "glSubAcctNumber")      @dtw_assign(Err_C2SUB,  fieldValue)
                          @DecatErr_Field("@@ovrt", "overrideRate")         @dtw_assign(Err_C2OVRT, fieldValue)
                          @DecatErr_Field("@@shfw", "shiftWorked")          @dtw_assign(Err_C2SHFW, fieldValue)
                          @DecatErr_Field("@@job@", "jobNumber")            @dtw_assign(Err_C2JOB,  fieldValue)
                          @DecatErr_Field("@@strt", "startDate")            @dtw_assign(Err_C2STRT, fieldValue)
                          @DecatErr_Field("@@end@", "endDate")              @dtw_assign(Err_C2END,  fieldValue)
                          @DecatErr_Field("@@max1", "maxYTDHoursUnits")     @dtw_assign(Err_C2MAX1, fieldValue)
                          @DecatErr_Field("@@max2", "maxYTDEarnings")       @dtw_assign(Err_C2MAX2, fieldValue)
                          @DecatErr_Field("@@dflt", "defaultRecord")        @dtw_assign(Err_C2DFLT, fieldValue)
                          @DecatErr_Field("@@nopy", "unpaidHoursUnits")     @dtw_assign(Err_C2NOPY, fieldValue)
                          @DecatErr_Field("@@atcd", "attendanceExcept")     @dtw_assign(Err_C2ATCD, fieldValue)
                          @DecatErr_Field("@@rphr", "workedHours")          @dtw_assign(Err_C2RPHR, fieldValue)
                          @DecatErr_Field("@@tstp", "timeStamp")            @dtw_assign(Err_C2TSTP, fieldValue)

                      %endif

                      @Decat_Field("@@comp")   @dtw_assign(V_C2COMP, fieldValue)
                      @Decat_Field("@@facl")   @dtw_assign(V_C2FACL, fieldValue)
                      @Decat_Field("@@code")   @dtw_assign(V_C2CODE, fieldValue)
                      @Decat_Field("@@desc")   @dtw_assign(V_C2DESC, fieldValue)
                      @Decat_Field("@@rphd")   @dtw_assign(V_C2RPHD, fieldValue)
                      @Decat_Field("@@smty")   @dtw_assign(V_C2SMTY, fieldValue)
                      @Decat_Field("@@hrcd")   @dtw_assign(V_C2HRCD, fieldValue)
                      @Decat_Field("@@prem")   @dtw_assign(V_C2PREM, fieldValue)
                      @Decat_Field("@@ded@")   @dtw_assign(V_C2DED,  fieldValue)
                      @Decat_Field("@@accr")   @dtw_assign(V_C2ACCR, fieldValue)
                      @Decat_Field("@@iotc")   @dtw_assign(V_C2IOTC, fieldValue)
                      @Decat_Field("@@wgds")   @dtw_assign(V_C2WGDS, fieldValue)
                      @Decat_Field("@@slds")   @dtw_assign(V_C2SLDS, fieldValue)
                      @Decat_Field("@@seq@")   @dtw_assign(V_C2SEQ,  fieldValue)
                      @Decat_Field("@@hrs@")   @dtw_assign(V_C2HRS,  fieldValue)
                      @Decat_Field("@@dept")   @dtw_assign(V_C2DEPT, fieldValue)
                      @Decat_Field("@@acct")   @dtw_assign(V_C2ACCT, fieldValue)
                      @Decat_Field("@@sub@")   @dtw_assign(V_C2SUB,  fieldValue)
                      @Decat_Field("@@ovrt")   @dtw_assign(V_C2OVRT, fieldValue)
                      @Decat_Field("@@shfw")   @dtw_assign(V_C2SHFW, fieldValue)
                      @Decat_Field("@@job@")   @dtw_assign(V_C2JOB,  fieldValue)
                      @Decat_Field("@@strt")   @dtw_assign(V_C2STRT, fieldValue)
                      @Decat_Field("@@end@")   @dtw_assign(V_C2END,  fieldValue)
                      @Decat_Field("@@max1")   @dtw_assign(V_C2MAX1, fieldValue)
                      @Decat_Field("@@max2")   @dtw_assign(V_C2MAX2, fieldValue)
                      @Decat_Field("@@dflt")   @dtw_assign(V_C2DFLT, fieldValue)
                      @Decat_Field("@@nopy")   @dtw_assign(V_C2NOPY, fieldValue)
                      @Decat_Field("@@atcd")   @dtw_assign(V_C2ATCD, fieldValue)
                      @Decat_Field("@@rphr")   @dtw_assign(V_C2RPHR, fieldValue)
                      @Decat_Field("@@tstp")   @dtw_assign(V_C2TSTP, fieldValue)



                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(V_C2HRCD, "H")
                          @dtw_assign(V_C2PREM, "N")
                          @dtw_assign(V_C2DED,  "N")
                          @dtw_assign(V_C2ACCR, "N")
                          @dtw_assign(V_C2IOTC, "N")
                          @dtw_assign(V_C2WGDS, "N")
                          @dtw_assign(V_C2SLDS, "N")
                          @dtw_assign(V_C2NOPY, "N")
                          @dtw_assign(V_C2RPHR, "N")
                          @dtw_assign(V_C2DFLT, "N")
                          @dtw_assign(focusField, "coNumber")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "coNumber")
                      @DateInputFromCYMD(V_C2STRT)
                      @DateInputFromCYMD(V_C2END)
                  %else
                      @DateInputFromCYMD(V_C2STRT)
                      @DateInputFromCYMD(V_C2END)
                      @dtw_assign(focusField, "codeDesc")
                  %endif

                  @Default_Zero(V_C2COMP)
                  @Default_Zero(V_C2FACL)
                  @RtvFldDesc("CFCOMP=$(V_C2COMP) and CFFACL=$(V_C2FACL)", "HRCOFC", "CFNAME", fieldDesc)
              	  @SetTextOvr(Err_C2TSTP)
                  <tr><td class="dsphdr"><span $(textOvr)>.</span></td>
                  	  <td><input name="timeStamp" type="hidden" value="$(V_C2TSTP)"></td> 
                  </tr>
                  @DspErrMsg(Err_C2TSTP)

                  @SetTextOvr(Err_C2COMP)
                  <tr><td class="dsphdr"><span $(textOvr)>Company/Facility</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          %if (V_HDPERL > "0" || V_HDPRRL > "0") 
                              <td class="inputnmbr"><input name="coNumber" value="$(V_C2COMP)" type="text" size="4" maxlength="2"> / <input name="facNumber" value="$(V_C2FACL)" type="text" size="4" maxlength="4"> $(reqFieldChar) <a href="$(homeURL)$(phpPath)HRCoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=coNumber&amp;fldFac=facNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="coFacDesc" value="$(fieldDesc)"  type="text" size="30" maxlength="30"></td>
                          %else
                              <td class="inputnmbr"><input name="coNumber" value="$(V_C2COMP)" type="text" size="4" maxlength="2"> / <input name="facNumber" value="$(V_C2FACL)" type="text" size="4" maxlength="4"> $(reqFieldChar) <a href="$(homeURL)$(phpPath)CoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=coNumber&amp;fldFac=facNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="coFacDesc" value="$(fieldDesc)"  type="text" size="30" maxlength="30"></td>
                          %endif
                      %else
                          <td class="inputnmbr"><input name="coNumber" value="$(V_C2COMP)" type="hidden" size="4" maxlength="2"> <input name="facNumber" value="$(V_C2FACL)" type="hidden" size="4" maxlength="4">$(fieldDesc)</td>
                          @Format_HRCoFac("$(V_C2COMP)", "$(V_C2FACL)", "", F_CoFac)
                          @Format_Code(F_CoFac, F2_CoFac)
                          <td class="dspalph">$(F2_CoFac)</td>
                      %endif
                      </tr>
                  @DspErrMsg(Err_C2COMP)
                  @DspErrMsg(Err_C2FACL)

                  @SetTextOvr(Err_C2CODE)
                  <tr><td class="dsphdr"><span $(textOvr)>Pay Code</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="payCode" type="text" value="$(V_C2CODE)" size="3" maxlength="3"> $(reqFieldChar) </td>
                      %else
                          <td class="inputalph"><input name="payCode" type="hidden" value="$(V_C2CODE)" size="3" maxlength="3">$(V_C2CODE)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_C2CODE)

                  @SetTextOvr(Err_C2DESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Code Description</span></td>
                      <td class="inputalph"><input name="codeDesc" type="text" value="$(V_C2DESC)" size="20" maxlength="20"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_C2DESC)

                  @SetTextOvr(Err_C2RPHD)
                  <tr><td class="dsphdr"><span $(textOvr)>Report Heading</span></td>
                      <td class="inputalph"><input name="reportHeading" type="text" value="$(V_C2RPHD)" size="10" maxlength="10"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_C2RPHD)

                  @RtvFldDesc("SUMCOD='$(V_C2SMTY)' ", "PRSUMT", "SUMDSC", fieldDesc)
                  @SetTextOvr(Err_C2SMTY)
                  <tr><td class="dsphdr"><span $(textOvr)>Summary Pay Type Code</span></td>
                      <td class="inputalph"><input name="summaryPayType" type="text" value="$(V_C2SMTY)" size="1" maxlength="1"> $(reqFieldChar) <a href="$(homeURL)$(cGIPath)SummaryTypeSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=summaryPayType&amp;fldDesc=sumCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="sumCodeDesc" value="$(fieldDesc)"  type="text" size="14" maxlength="14">  </td>
                  </tr>
                  @DspErrMsg(Err_C2SMTY)


                  @SetTextOvr(Err_C2HRCD)
                  <tr><td class="dsphdr"><span $(textOvr)>Hours or Units Code</span></td>
                      @dtw_tb_rows(hourunitTable, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(hourunitTable, x, "1") != V_C2HRCD) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(hourunitTable, "hoursOrUnits", "2", "1", "N", "", x, "1") $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_C2HRCD)

                  @SetTextOvr(Err_C2PREM)
                  <tr><td class="dsphdr"><span $(textOvr)>Apply Shift Premium</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_C2PREM) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "applyShiftPremium", "2", "1", "N", "", x, "1") $(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_C2PREM)

                  @SetTextOvr(Err_C2DED)
                  <tr><td class="dsphdr"><span $(textOvr)>Take Deductions</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_C2DED) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "takeDeduction", "2", "1", "N", "", x, "1") $(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_C2DED)

                  @SetTextOvr(Err_C2ACCR)
                  <tr><td class="dsphdr"><span $(textOvr)>Include In Vac/Sick Accural</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_C2ACCR) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "vacSickAccruals", "2", "1", "N", "", x, "1") $(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_C2ACCR)

                  @SetTextOvr(Err_C2IOTC)
                  <tr><td class="dsphdr"><span $(textOvr)>Include In Overtime</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_C2IOTC) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "includeOT", "2", "1", "N", "", x, "1") $(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_C2IOTC)

                  @SetTextOvr(Err_C2WGDS)
                  <tr><td class="dsphdr"><span $(textOvr)>Process Distribution Tables</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_C2WGDS) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "processDistTables", "2", "1", "N", "", x, "1") $(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_C2WGDS)

                  @SetTextOvr(Err_C2SLDS)
                  <tr><td class="dsphdr"><span $(textOvr)>Process Salary Distribution</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_C2SLDS) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "processSalDist", "2", "1", "N", "", x, "1") $(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_C2SLDS)

                  @Default_Zero(V_C2SEQ)
                  @SetTextOvr(Err_C2SEQ)
                  <tr><td class="dsphdr"><span $(textOvr)>Processing Sequence</span></td>
                      <td class="inputnmbr"><input type="text" name="processingSeq" value="$(V_C2SEQ)" size="3" maxlength="3"></td>
                  </tr>
                  @DspErrMsg(Err_C2SEQ)

                  @Default_Zero(V_C2ACCT)
                  @Default_Zero(V_C2SUB)
                  @RtvFldDesc("CHACCT=$(V_C2ACCT) and CHSUB=$(V_C2SUB) ", "HDCHRT", "CHCHDS", acctDesc)
                  @SetTextOvr(Err_C2ACCT)
                  <tr><td class="dsphdr"><span $(textOvr)>G/L Account</span></td>
                      <td class="inputnmbr"><input name="glAcctNumber" value="$(V_C2ACCT)" type="text" size="4" maxlength="4"> - <input name="glSubAcctNumber" value="$(V_C2SUB)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=glAcctNumber&amp;subFld=glSubAcctNumber&amp;descFld=glAcctDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="glAcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_C2ACCT)

                  @SetTextOvr(Err_C2NOPY)
                  <tr><td class="dsphdr"><span $(textOvr)>Unpaid Hours/Units</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_C2NOPY) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "unpaidHoursUnits", "2", "1", "N", "", x, "1") $(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_C2NOPY)

                  @SetTextOvr(Err_C2RPHR)
                  <tr><td class="dsphdr"><span $(textOvr)>Worked Hours</span></td>
                      @dtw_tb_rows(designPhaseTable, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(designPhaseTable, x, "1") != V_C2RPHR) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(designPhaseTable, "workedHours", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_C2RPHR)

                  @RtvFldDesc("EVCODE='$(V_C2ATCD)' AND EVTYPE='A' ", "HDEVNT", "EVDESC", feventDesc)
                  @SetTextOvr(Err_C2ATCD)
                  <tr><td class="dsphdr"><span $(textOvr)>Attendance Exception</span></td>
                      <td class="inputalph"><input name="attendanceExcept" type="text" value="$(V_C2ATCD)" size="2" maxlength="2"> <a href="$(homeURL)$(phpPath)ETCodeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=attendanceExcept&amp;fldDesc=feventDesc&amp;fldType=A" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="feventDesc" value="$(feventDesc)"  type="text" size="30" maxlength="30"> </td>
                  </tr>
                  @DspErrMsg(Err_C2ATCD)

                  @Default_Zero(V_C2HRS)
                  @SetTextOvr(Err_C2HRS)
                  <tr><td class="dsphdr"><span $(textOvr)>Hours/Units/Earnings</span></td>
                      <td class="inputnmbr"><input type="text" name="hoursUnitsEarnings" value="$(V_C2HRS)" size="9" maxlength="9"></td>
                  </tr>
                  @DspErrMsg(Err_C2HRS)

                  @RtvFldDesc("EADEPT='$(V_C2DEPT)' ", "PREXAC", "EANAME", fieldDesc)
                  @SetTextOvr(Err_C2DEPT)
                  <tr><td class="dsphdr"><span $(textOvr)>Department Worked</span></td>
                      <td class="inputalph"><input name="deptWorked" type="text" value="$(V_C2DEPT)" size="5" maxlength="5">  <a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=deptWorked&amp;fldDesc=deptDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="deptDesc" value="$(fieldDesc)"  type="text" size="20" maxlength="20">  </td>
                  </tr>
                  @DspErrMsg(Err_C2DEPT)

                  @Default_Zero(V_C2OVRT)
                  @SetTextOvr(Err_C2OVRT)
                  <tr><td class="dsphdr"><span $(textOvr)>Override Rate</span></td>
                      <td class="inputnmbr"><input type="text" name="overrideRate" value="$(V_C2OVRT)" size="13" maxlength="13"></td>
                  </tr>
                  @DspErrMsg(Err_C2OVRT)

                  @RtvFldDesc("PPCOMP=$(V_C2COMP) and PPFACL=$(V_C2FACL) and PPDEPT='$(V_C2DEPT)' and PPSHFT='$(V_C2SHFW)' ", "PRPREM", "CHAR(PPDESC)", codeDesc)
                  %if (shiftDesc =="")
                      @RtvFldDesc("PPCOMP=$(V_C2COMP) and PPFACL=$(V_C2FACL) and PPDEPT=' ' and PPSHFT='$(V_C2SHFW)' ", "PRPREM", "CHAR(PPDESC)", codeDesc)
                  %endif
                  @SetTextOvr(Err_C2SHFW)
                  <tr><td class="dsphdr"><span $(textOvr)>Shift Worked</span></td>
                      <td class="inputalph"><input name="shiftWorked" type="text" value="$(V_C2SHFW)" size="2" maxlength="2"> <a href="$(homeURL)$(cGIPath)ShiftSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Chg&amp;fldName=shiftWorked&amp;fldDesc=shiftDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="shiftDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                  </tr>
                  @DspErrMsg(Err_C2SHFW)

                  @SetTextOvr(Err_C2JOB)
                  <tr><td class="dsphdr"><span $(textOvr)>Job Number</span></td>
                      <td class="inputalph"><input name="jobNumber" type="text" value="$(V_C2JOB)" size="14" maxlength="14"> </td>
                  </tr>
                  @DspErrMsg(Err_C2JOB)

                  @SetTextOvr(Err_C2STRT)
	           <tr><td class="dsphdr"><span $(textOvr)>Start Date</span></td>
                      <td class="inputnmbr"><input type="text" name="startDate" value="$(V_C2STRT)" size="6" maxlength="6"> 		
                          <a href="javascript:calWindow('startDate');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_C2STRT)

                  @SetTextOvr(Err_C2END)
	           <tr><td class="dsphdr"><span $(textOvr)>End Date</span></td>
                      <td class="inputnmbr"><input type="text" name="endDate" value="$(V_C2END)" size="6" maxlength="6"> 		
                          <a href="javascript:calWindow('endDate');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_C2END)

                  @Default_Zero(V_C2MAX1)
                  @SetTextOvr(Err_C2MAX1)
                  <tr><td class="dsphdr"><span $(textOvr)>Maximum YTD Hours/Units</span></td>
                      <td class="inputnmbr"><input type="text" name="maxYTDHoursUnits" value="$(V_C2MAX1)" size="11" maxlength="11"></td>
                  </tr>
                  @DspErrMsg(Err_C2MAX1)

                  @Default_Zero(V_C2MAX2)
                  @SetTextOvr(Err_C2MAX2)
                  <tr><td class="dsphdr"><span $(textOvr)>Maximum YTD Earnings</span></td>
                      <td class="inputnmbr"><input type="text" name="maxYTDEarnings" value="$(V_C2MAX2)" size="11" maxlength="11"></td>
                  </tr>
                  @DspErrMsg(Err_C2MAX2)

                  @SetTextOvr(Err_C2DFLT)
                  <tr><td class="dsphdr"><span $(textOvr)>Default Row</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_C2DFLT) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "defaultRecord", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_C2DFLT)
              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     warningFlag,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar,
                                        INOUT CHAR(8)     SUBR)

{%EXEC {HPRPYM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @hourunit_Query(profileHandle, dataBaseID, "HOURUNIT  ", hourunitTable)
	   @dtw_tb_insertrow(hourunitTable, "0", "1")
	   @dtw_tb_setv(hourunitTable, "", "1", "1")
	   @dtw_tb_setv(hourunitTable, "", "1", "2")
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @DesignPhase_Query(profileHandle, dataBaseID, "BYN       ", designPhaseTable)

      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(payCode)
  @dtw_mUPPERCASE(hoursOrUnits)
  @dtw_mUPPERCASE(summaryPayType)
  @dtw_mUPPERCASE(attendanceExcept)
  @dtw_mUPPERCASE(jobNumber)

  @dtw_assign(coNumber,@dtw_rstrip(coNumber))
  @dtw_assign(facNumber,@dtw_rstrip(facNumber))
  @dtw_assign(payCode,@dtw_rstrip(payCode))
  @dtw_assign(codeDesc,@dtw_rstrip(codeDesc))
  @dtw_assign(reportHeading,@dtw_rstrip(reportHeading))
  @dtw_assign(summaryPayType,@dtw_rstrip(summaryPayType))
  @dtw_assign(hoursOrUnits,@dtw_rstrip(hoursOrUnits))
  @dtw_assign(applyShiftPremium,@dtw_rstrip(applyShiftPremium))
  @dtw_assign(takeDeduction,@dtw_rstrip(takeDeduction))
  @dtw_assign(vacSickAccruals,@dtw_rstrip(vacSickAccruals))
  @dtw_assign(includeOT,@dtw_rstrip(includeOT))
  @dtw_assign(processDistTables,@dtw_rstrip(processDistTables))
  @dtw_assign(processSalDist,@dtw_rstrip(processSalDist))
  @dtw_assign(processingSeq,@dtw_rstrip(processingSeq))
  @dtw_assign(hoursUnitsEarnings,@dtw_rstrip(hoursUnitsEarnings))
  @dtw_assign(deptWorked,@dtw_rstrip(deptWorked))
  @dtw_assign(glAcctNumber,@dtw_rstrip(glAcctNumber))
  @dtw_assign(glSubAcctNumber,@dtw_rstrip(glSubAcctNumber))
  @dtw_assign(overrideRate,@dtw_rstrip(overrideRate))
  @dtw_assign(shiftWorked,@dtw_rstrip(shiftWorked))
  @dtw_assign(jobNumber,@dtw_rstrip(jobNumber))
  @dtw_assign(startDate,@dtw_rstrip(startDate))
  @dtw_assign(endDate,@dtw_rstrip(endDate))
  @dtw_assign(maxYTDHoursUnits,@dtw_rstrip(maxYTDHoursUnits))
  @dtw_assign(maxYTDEarnings,@dtw_rstrip(maxYTDEarnings))
  @dtw_assign(defaultRecord,@dtw_rstrip(defaultRecord))
  @dtw_assign(unpaidHoursUnits,@dtw_rstrip(unpaidHoursUnits))
  @dtw_assign(attendanceExcept,@dtw_rstrip(attendanceExcept))
  @dtw_assign(workedHours,@dtw_rstrip(workedHours))


  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(SUBR, "")

  @dtw_assign(edtVar, "")
  @Concat_Field("@@comp", coNumber)
  @Concat_Field("@@facl", facNumber)
  @Concat_Field("@@code", payCode)
  @Concat_Field("@@desc", codeDesc)
  @Concat_Field("@@rphd", reportHeading)
  @Concat_Field("@@smty", summaryPayType)
  @Concat_Field("@@hrcd", hoursOrUnits)
  @Concat_Field("@@prem", applyShiftPremium)
  @Concat_Field("@@ded@", takeDeduction)
  @Concat_Field("@@accr", vacSickAccruals)
  @Concat_Field("@@iotc", includeOT)
  @Concat_Field("@@wgds", processDistTables)
  @Concat_Field("@@slds", processSalDist)
  @Concat_Field("@@seq@", processingSeq)
  @Concat_Field("@@hrs@", hoursUnitsEarnings)
  @Concat_Field("@@dept", deptWorked)
  @Concat_Field("@@acct", glAcctNumber)
  @Concat_Field("@@sub@", glSubAcctNumber)
  @Concat_Field("@@ovrt", overrideRate)
  @Concat_Field("@@shfw", shiftWorked)
  @Concat_Field("@@job@", jobNumber)
  @Concat_Field("@@strt", startDate)
  @Concat_Field("@@end@", endDate)
  @Concat_Field("@@max1", maxYTDHoursUnits)
  @Concat_Field("@@max2", maxYTDEarnings)
  @Concat_Field("@@dflt", defaultRecord)
  @Concat_Field("@@nopy", unpaidHoursUnits)
  @Concat_Field("@@atcd", attendanceExcept)
  @Concat_Field("@@rphr", workedHours)
  @Concat_Field("@@tstp", timeStamp)
  @dtw_concat(edtVar, "}{", edtVar)


  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, warningFlag, errFound, edtVar, errVar, SUBR)
  @DecatErr_Field("@@code", "payCode")              @dtw_assign(Err_C2CODE, fieldValue)
  
  %if (errFound == "" )
      @Format_HRCoFac(coNumber, facNumber, "", F_CoFac)
      @RtvFldDesc("CFCOMP=$(coNumber) and CFFACL=$(facNumber)", "HRCOFC", "CFNAME", fieldDesc)
      @Format_ConfMsg_Desc(maintenanceCode, $(codeDesc), $(payCode), $(fieldDesc), $(F_CoFac), "", "", confMessage)
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=165&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %elif ((maintenanceCode == "C" || maintenanceCode == "D") && errFound != "" && fieldValue != "")      
      @Format_HRCoFac(coNumber, facNumber, "", F_CoFac)
      @RtvFldDesc("CFCOMP=$(coNumber) and CFFACL=$(facNumber)", "HRCOFC", "CFNAME", fieldDesc)
      @Format_ConfMsg_Desc("E", $(codeDesc), $(payCode), $(fieldDesc), $(F_CoFac), "<br>$(fieldValue)", "", confMessage)
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=165&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;coNumber=@dtw_rurlescseq(coNumber)&amp;facNumber=@dtw_rurlescseq(facNumber)&amp;payCode=@dtw_rurlescseq(payCode)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;warningFlag=@dtw_rurlescseq(warningFlag)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}



%HTML(COPYALL) {
  @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
  %if (backURL == "")
      @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=165")
  %endif
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "NewWindowOpen.icl"
              function validate(chgForm) {
                 if (document.Chg.fromcoNumber.value =="" ||
                     document.Chg.fromfacNumber.value =="" ||
                     document.Chg.tocoNumber.value =="" ||
                     document.Chg.tofacNumber.value =="")
                       {alert("$(reqFieldError)");
                           return false;}
                 if (editNum(document.Chg.fromcoNumber,  2, 0) &&
                     editNum(document.Chg.fromfacNumber, 4, 0) &&
                     editNum(document.Chg.tocoNumber,    2, 0) &&
                     editNum(document.Chg.tofacNumber,   4, 0))
                          return true;

              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PAYCODEMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      <table $(baseTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1> Copy Company/Facility Pay Code</h1></td>
                          <td class="toolbar">
                              %INCLUDE "MaintainTopNoTable.icl"
                          </td></tr>
                      </table>

                      $(hrTagAttr)
                      %INCLUDE "RequiredField.icl"
                      %INCLUDE "ErrorDisplay.icl"

                      <form class="formClass" METHOD=POST name=Chg onSubmit="return (editNum(tocoNumber, 3, 0) &&
                                                                                     editChg())"
                          ACTION="$(homeURL)$(cGIPath)$(d2wName)/EDIT_COPYALL$(d2wVarBase)&amp;fromcoNumber=@dtw_rurlescseq(fromcoNumber)&amp;fromfacNumber=@dtw_rurlescseq(fromfacNumber)&amp;tocoNumber=@dtw_rurlescseq(tocoNumber)&amp;tofacNumber=@dtw_rurlescseq(tofacNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromcoNumber")
                              %if (errFound != "" || maintenanceCode == "A")
                                  %if (errFound == "" && maintenanceCode == "A")
                                      @dtw_assign(edtVar, "")
                                  %else
                                      @EdtVarErr(profileHandle, typeValue, edtVar)
                                      @ErrVarErr(profileHandle, typeError, errVar)
                                      @DecatErr_Field("@@fcom", "fromcoNumber")    @dtw_assign(Err_FROMCOM,  fieldValue)
                                      @DecatErr_Field("@@ffac", "fromfacNumber")   @dtw_assign(Err_FROMFAC,  fieldValue)
                                      @DecatErr_Field("@@tcom", "tocoNumber")      @dtw_assign(Err_TOCOM,  fieldValue)
                                      @DecatErr_Field("@@tfac", "tofacNumber")     @dtw_assign(Err_TOFAC,  fieldValue)
                                  %endif

                                  @Decat_Field("@@fcom")   @dtw_assign(V_C2FCOM,  fieldValue)
                                  @Decat_Field("@@ffac")   @dtw_assign(V_C2FFAC,  fieldValue)
                                  @Decat_Field("@@tcom")   @dtw_assign(V_C2TCOM,  fieldValue)
                                  @Decat_Field("@@tfac")   @dtw_assign(V_C2TFAC,  fieldValue)

                                  @dtw_assign(errFound, "")

                              %elif (maintenanceCode == "Z")
                                  @dtw_assign(V_C2TCOM, "")
                                  @dtw_assign(V_C2TFAC, "")
                              %endif

                              @Default_Zero(V_C2FCOM)
                              @Default_Zero(V_C2FFAC)
                              @RtvFldDesc("CFCOMP=$(V_C2FCOM) and CFFACL=$(V_C2FFAC)", "HRCOFC", "CFNAME", fieldDesc)
                              @SetTextOvr(Err_FROMCOM)
                              <tr><td class="dsphdr"><span $(textOvr)>From Company/Facility</span></td>
                              %if (V_HDPERL > "0" || V_HDPRRL > "0") 
                                  <td class="inputnmbr"><input name="fromcoNumber" value="$(V_C2FCOM)" type="text" size="4" maxlength="2"> / <input name="fromfacNumber" value="$(V_C2FFAC)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=fromcoNumber&amp;fldFac=fromfacNumber&amp;fldDesc=fromcoFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="fromcoFacDesc" value="$(fieldDesc)"  type="text" size="30" maxlength="30">$(reqFieldChar)</td>
                              %else
                                  <td class="inputnmbr"><input name="fromcoNumber" value="$(V_C2FCOM)" type="text" size="4" maxlength="2"> / <input name="fromfacNumber" value="$(V_C2FFAC)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)CoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=fromcoNumber&amp;fldFac=fromfacNumber&amp;fldDesc=fromcoFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="fromcoFacDesc" value="$(fieldDesc)"  type="text" size="30" maxlength="30">$(reqFieldChar)</td>
                              %endif
                              </tr>
                              @DspErrMsg(Err_FROMCOM)
                              @DspErrMsg(Err_FROMFAC)

                              @Default_Zero(V_C2TCOM)
                              @Default_Zero(V_C2TFAC)
                              @RtvFldDesc("CFCOMP=$(V_C2TCOM) and CFFACL=$(V_C2TFAC)", "HRCOFC", "CFNAME", fieldDesc)
                              @SetTextOvr(Err_TOCOM)
                              <tr><td class="dsphdr"><span $(textOvr)>To Company/Facility</span></td>
                              %if (V_HDPERL > "0" || V_HDPRRL > "0") 
                                  <td class="inputnmbr"><input name="tocoNumber" value="$(V_C2TCOM)" type="text" size="4" maxlength="2"> / <input name="tofacNumber" value="$(V_C2TFAC)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=tocoNumber&amp;fldFac=tofacNumber&amp;fldDesc=tocoFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="tocoFacDesc" value="$(fieldDesc)"  type="text" size="30" maxlength="30">$(reqFieldChar)</td>
                              %else   
                                  <td class="inputnmbr"><input name="tocoNumber" value="$(V_C2TCOM)" type="text" size="4" maxlength="2"> / <input name="tofacNumber" value="$(V_C2TFAC)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)CoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=tocoNumber&amp;fldFac=tofacNumber&amp;fldDesc=tocoFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="tocoFacDesc" value="$(fieldDesc)"  type="text" size="30" maxlength="30">$(reqFieldChar)</td>
                              %endif
                              </tr>
                              @DspErrMsg(Err_TOCOM)
                              @DspErrMsg(Err_TOFAC)

                          </table>
                          %INCLUDE "MaintainBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </form>
                  </td>
              </tr>
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(EDIT_COPYALL) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(fromcoNumber,@dtw_rstrip(fromcoNumber))
  @dtw_assign(fromfacNumber,@dtw_rstrip(fromfacNumber))
  @dtw_assign(tocoNumber,@dtw_rstrip(tocoNumber))
  @dtw_assign(tofacNumber,@dtw_rstrip(tofacNumber))
  @dtw_assign(SUBR, "SRCpyAll")

  @dtw_assign(edtVar, "")
  @Concat_Field("@@fcom", fromcoNumber)
  @Concat_Field("@@ffac", fromfacNumber)
  @Concat_Field("@@tcom", tocoNumber)
  @Concat_Field("@@tfac", tofacNumber)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, maintCode, warningFlag, errFound, edtVar, errVar, SUBR)

  %if (errFound == "")
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=165&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/COPYALL$(d2wVarBase)&amp;fromcoNumber=@dtw_rurlescseq(fromcoNumber)&amp;fromfacNumber=@dtw_rurlescseq(fromfacNumber)&amp;tocoNumber=@dtw_rurlescseq(tocoNumber)&amp;tofacNumber=@dtw_rurlescseq(tofacNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}