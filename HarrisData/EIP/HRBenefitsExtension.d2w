%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define{
  page_title              = "Benefits Extension"
  d2wName                 = "HRBenefitsExtension.d2w"
  d2wVarBase              = "$(genericVarBase)$(hrCoFacVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;benefitCode=@dtw_rurlescseq(benefitCode)&amp;planCode=@dtw_rurlescseq(planCode)&amp;benefitDesc=@dtw_rurlescseq(benefitDesc)&amp;planDesc=@dtw_rurlescseq(planDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPECVE"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "HrCoFacURL.icl"
  @dtw_replace(workURL, "@@fromD2w", "@dtw_rurlescseq(fromD2w)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
              %INCLUDE "CheckEnterSearch.icl"
   		  %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "HRBENEFITSEXTENSION")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      @dtw_assign(uv_CompanyName, "CECOMP")
                      @dtw_assign(uv_FacilityName, "CEFACL")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " CBCOVE ", fileSQL)
                      @dtw_concat(selectSQL, " CECOMP=$(prCompany) and CEFACL=$(prFacility) and CECOVR='$(benefitCode)' and CEPLAN='$(planCode)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl" 
                      @HRBenefits_Extension_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) HRBenefits_Extension_Query (IN CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td ><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                          %if ((backHome != "$(d2wName)/report") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)HRBenefits.d2w/REPORT$(d2wVarBase)" title="Return To HR Benefits">$(portalHome)</a>
                          %endif
                      %if (sec_01 == "Y")
                              <a href="$(homeURL)$(cGIPath)HRBenefitsExtensionMaintain.d2w/HRBENEFITSEXTENSION$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>

              @RetHrCompNam(profileHandle, dataBaseID, prCompany, prFacility, coFacName)
              <tr><td><h2>$(coFacName)</h2></td></tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

          %if (formatToPrint != "Y")
              %INCLUDE "AssignPageValue.icl"
          %endif

      <table $(contentTable)>
          <tr>
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("CECOVR", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BenefitCode" title="Sequence By Benefit Code, Plan Code"> Benefit<br>Code</a></th>
                  @OrderBy_Sort("CEDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BenefitDesc" title="Sequence By Benefit Description, Plan Description"> Benefit Description</a></th>
                  @OrderBy_Sort("CEPLAN", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlanCode" title="Sequence By Plan Code, Benefit Code"> Plan<br>Code</a></th>
                  @OrderBy_Sort("CEDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlanDesc" title="Sequence By Plan Description, Benefit Description"> Plan Description</a></th>
                  @OrderBy_Sort("CEECEF", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=EffectiveDate" title="Sequence By Effective Date"> Effective<br>Date</a></th>
                  @OrderBy_Sort("CEECEX", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ExpirationDate" title="Sequence By Expiration Date"> Expiration<br>Date</a></th>
                  @OrderBy_Sort("CECSTM", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=EmployerCost" title="Sequence By Employer Cost"> Employer<br>Cost</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;seqNumber=@dtw_rurlescseq(V_CESEQU)&amp;effectiveDate=@dtw_rurlescseq(V_CEECEF)")
                  @RtvFldDesc("BCCOMP=$(V_CECOMP) AND BCFACL=$(V_CEFACL) AND BCCOVR='$(V_CECOVR)' AND BCPLAN='$(V_CEPLAN)' ", "HRBCMN", "char(count(*))", cmtCount)
              %INCLUDE "SetRowClass.icl"
              @Format_Date(V_CEECEF, "D", F_CEECEF)
              @Format_Date(V_CEECEX, "D", F_CEECEX)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)HRBenefitsExtensionMaintain.d2w/HRBENEFITSEXTENSION$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_04 == "Y")
                              <a href="$(homeURL)$(cGIPath)HRBenefitsExtensionMaintain.d2w/HRBENEFITSEXTENSION$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)HRBenefitsExtensionMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif

                          <td class="colcode">$(V_CECOVR)</td>
                          <td class="colalph">$(benefitDesc)</td>
                          <td class="colcode">$(V_CEPLAN)</td>
                          <td class="colalph">$(planDesc)</td>
                          <td class="coldate">$(F_CEECEF)</td>
                          <td class="coldate">$(F_CEECEX)</td>
                          <td class="colnmbr">$(V_CECSTM)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  @dtw_assign(uv_CompanyName, "CECOMP")
  @dtw_assign(uv_FacilityName, "CEFACL")
  %INCLUDE "userview.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
  @dtw_concat(fileSQL, " CBCOVE ", fileSQL)
  @dtw_concat(selectSQL, " CECOMP=$(prCompany) and CEFACL=$(prFacility) and CECOVR='$(benefitCode)' and CEPLAN='$(planCode)' ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @Benefit_Extension_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) Benefit_Extension_XMLQuery (IN CHAR(64)    profileHandle,
                                              CHAR(2)     dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("BenefitExtensionList")
          %ROW{
              @Date_CYMD_ISO(V_CEECEF, F_CEECEF)
              @Date_CYMD_ISO(V_CEECEX, F_CEECEX)

              @XMLIDTag(@DTW_rCONCAT(prCompany, @DTW_rCONCAT("/", @DTW_rCONCAT(prFacility, @DTW_rCONCAT("/", @DTW_rCONCAT(V_CECOVR, @DTW_rCONCAT("/", V_CEPLAN)))))), "Benefit ID")
                  @XMLTag(prCompany, "CompanyNumber")
                  @XMLTag(prFacility, "FacilityNumber")
                  @XMLTag(V_CECOVR, "BenefitCode")
                  @XMLTag(benefitDesc, "benefitDesc")
                  @XMLTag(V_CEPLAN, "PlanCode")
                  @XMLTag(planDesc, "planDesc")
                  @XMLTag(F_CEECEF, "EffectiveDate")
                  @XMLTag(F_CEECEX, "ExpirationDate")
                  @XMLTag(V_CECSTM, "EmployerCost")
              @XMLEndTag("Benefit")
	   %}
      @XMLEndTag("BenefitExtensionList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (sec_05 == "N")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)progOptSecError.d2w/DISPLAY$(genericVarBase)&amp;page_title=@dtw_rurlescseq(page_title)">
  %else
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "CEECEF,CECOMP")
          @DTW_ASSIGN(orderByDisplay, "Effective Date (descending)")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
  %endif
%}

%HTML(EXPORT){
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit ()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT){
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY){
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "BenefitCode")
      %if (orderBy == "CECOVR,CEPLAN,CEECEF")
          @DTW_ASSIGN(orderBy, "CECOVR DESC,CEPLAN,CEECEF DESC")
          @DTW_ASSIGN(orderByDisplay, "Benefit Code (descending), Plan Code")
      %else
          @DTW_ASSIGN(orderBy, "CECOVR,CEPLAN,CEECEF")
          @DTW_ASSIGN(orderByDisplay, "Benefit Code, Plan Code")
      %endif
  %elseif (sequence == "BenefitDesc")
      %if (orderBy == "CECOVR,CEPLAN,CEECEF")
          @DTW_ASSIGN(orderBy, "CECOVR DESC,CEPLAN,CEECEF DESC")
          @DTW_ASSIGN(orderByDisplay, "Benefit Description (descending), Plan Description")
      %else
          @DTW_ASSIGN(orderBy, "CECOVR,CEPLAN,CEECEF")
          @DTW_ASSIGN(orderByDisplay, "Benefit Description, Plan Description")
      %endif
  %elseif (sequence == "PlanCode")
      %if (orderBy == "CEPLAN,CECOVR,CEECEF")
          @DTW_ASSIGN(orderBy, "CEPLAN DESC,CECOVR,CEECEF DESC")
          @DTW_ASSIGN(orderByDisplay, "Plan Code (descending), Benefit Code")
      %else
          @DTW_ASSIGN(orderBy, "CEPLAN,CECOVR,CEECEF")
          @DTW_ASSIGN(orderByDisplay, "Plan Code, Benefit Code")
      %endif
  %elseif (sequence == "PlanDesc")
      %if (orderBy == "CEPLAN,CECOVR,CEECEF")
          @DTW_ASSIGN(orderBy, "CEPLAN DESC,CECOVR,CEECEF DESC")
          @DTW_ASSIGN(orderByDisplay, "Plan Description (descending), Benefit Description")
      %else
          @DTW_ASSIGN(orderBy, "CEPLAN,CECOVR,CEECEF")
          @DTW_ASSIGN(orderByDisplay, "Plan Description, Benefit Description")
      %endif
  %elseif(sequence == "EffectiveDate")
      %if (orderBy == "CEECEF,CECOMP")
          @DTW_ASSIGN(orderBy, "CEECEF DESC,CECOMP")
          @DTW_ASSIGN(orderByDisplay, "Effective Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CEECEF,CECOMP")
          @DTW_ASSIGN(orderByDisplay, "Effective Date")
      %endif
  %elseif (sequence == "ExpirationDate")
      %if (orderBy == "CEECEX,CECOMP")
          @DTW_ASSIGN(orderBy, "CEECEX DESC,CECOMP")
          @DTW_ASSIGN(orderByDisplay, "Expiration Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CEECEX,CECOMP")
          @DTW_ASSIGN(orderByDisplay, "Expiration Date")
      %endif
  %elseif (sequence == "EmployerCost")
      %if (orderBy == "CECSTM,CECOMP")
          @DTW_ASSIGN(orderBy, "CECSTM DESC,CECOMP")
          @DTW_ASSIGN(orderByDisplay, "Employer Cost (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CECSTM,CECOMP")
          @DTW_ASSIGN(orderByDisplay, "Employer Cost")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}



