%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Import Cross Reference Value Maintenance"
  d2wName                 = "MapXRefValueMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;crossReference=@dtw_rurlescseq(crossReference)&amp;mapImportTable=@dtw_rurlescseq(mapImportTable)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromXRefFromValue=@dtw_rurlescseq(fromXRefFromValue)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;updRecNbr=@dtw_rurlescseq(updRecNbr)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;xRefFromValue=@dtw_rurlescseq(xRefFromValue)&amp;maintenanceCode=D"
  programName             = "HSYIXV"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  V_PMTYPE                = ""
  V_PMSIZE                = ""
  V_PMDECM                = ""
  V_MXFLDT                = ""
  V_MXSIZE                = ""
  V_MXDECM                = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"

  @dtw_assign(editVariables, "")

  @RtvFldDesc("MXXREF='$(crossReference)' and MXIFIL='$(mapImportTable)' ", "SYMXRF", "MXFLDT", V_MXFLDT)
  @RtvFldDesc("MXXREF='$(crossReference)' and MXIFIL='$(mapImportTable)' ", "SYMXRF", "char(MXSIZE)", V_MXSIZE)
  @RtvFldDesc("MXXREF='$(crossReference)' and MXIFIL='$(mapImportTable)' ", "SYMXRF", "char(MXDECM)", V_MXDECM)
  %if (V_MXFLDT == "N")
      @dtw_concat(editVariables, " editNum(document.Chg.xRefFromValue, $(V_MXSIZE), $(V_MXDECM)) ", editVariables)
  %endif

  @RtvFldDesc("MXXREF='$(crossReference)' and MXIFIL='$(mapImportTable)'", "SYMXRF", "MXPARM", V_MXPARM)
  @RtvFldDesc("PMPARM='$(V_MXPARM)'", "WFPARM", "PMTYPE", V_PMTYPE)
  @RtvFldDesc("PMPARM='$(V_MXPARM)'", "WFPARM", "char(PMSIZE)", V_PMSIZE)
  @RtvFldDesc("PMPARM='$(V_MXPARM)'", "WFPARM", "char(PMDECM)", V_PMDECM)
  %if (V_PMTYPE != "A" && V_PMTYPE != "")
      %if (editVariables != "")
          @dtw_concat(editVariables, "  &&", editVariables)
      %endif
      @dtw_concat(editVariables, " editNum(document.Chg.xRefToValue, $(V_PMSIZE), $(V_PMDECM)) ", editVariables)
  %endif

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %if (editVariables == "" )
                  %INCLUDE "NoFormValidate.icl"
              %else
                  function validate(chgForm) {
                      if ($(editVariables))
                          return true;
                  }
              %endif
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "MAPXREFVALUEMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " SYMXRV ", fileSQL)
                          @dtw_concat(selectSQL, " MVXREF = '$(crossReference)' and MVIFIL='$(mapImportTable)' and MVFVAL='$(xRefFromValue)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          @RtvFldDesc("MXXREF='$(crossReference)' and MXIFIL='$(mapImportTable)' ", "SYMXRF", "MXDESC", V_MXDESC)
          @Format_Header("Cross Reference", $(V_MXDESC), $(crossReference))
          @Format_Header("Import Table", $(mapImportTable), "")
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          %ROW {
              %if (errFound != "" || maintenanceCode == "A")
                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(edtVar, "")
                      @dtw_assign(focusField, "xRefFromValue")
                  %else
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@fval", "xRefFromValue")    @dtw_assign(Err_MVFVAL, fieldValue)
                      @DecatErr_Field("@@tval", "xRefToValue")      @dtw_assign(Err_MVTVAL, fieldValue)
                  %endif

                  @Decat_Field("@@fval")   @dtw_assign(V_MVFVAL, fieldValue)
                  @Decat_Field("@@tval")   @dtw_assign(V_MVTVAL, fieldValue)

                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(focusField, "xRefFromValue")
                  %endif

                  @dtw_assign(errFound, "")

              %elif (maintenanceCode == "Z")
                  @dtw_assign(focusField, "xRefFromValue")
              %else
                  @dtw_assign(focusField, "xRefToValue")
              %endif

              <table $(contentTable)>
                  @dtw_assign(Size, @dtw_radd(V_MXSIZE, V_MXDECM))
                  %if (V_MXFLDT == "N" && V_MXDECM > "0")
                      @dtw_assign(Size, @dtw_radd(Size, "2"))
                  %endif
                  @SetTextOvr(Err_MVFVAL)
                  <tr><td class="dsphdr"><span $(textOvr)>From Value</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input type="text" name="xRefFromValue" value="$(V_MVFVAL)" size="$(Size)" maxlength="$(Size)"></td>
                      %else
                          <td class="inputalph"><input type="hidden" name="xRefFromValue" value="$(V_MVFVAL)">$(V_MVFVAL)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_MVFVAL)

                  @dtw_assign(Size, @dtw_radd(V_PMSIZE, V_PMDECM))
                  %if (V_PMTYPE == "N" && V_PMDECM > "0")
                      @dtw_assign(Size, @dtw_radd(Size, "2"))
                  %endif
                  @SetTextOvr(Err_MVTVAL)
                  <tr><td class="dsphdr"><span $(textOvr)>To Value</span></td>
                      <td class="inputalph"><input type="text" name="xRefToValue" value="$(V_MVTVAL)" size="$(Size)" maxlength="$(Size)"></td>
                  </tr>
                  @DspErrMsg(Err_MVTVAL)
              </table>
          %}

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSYIXV_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @RtvFldDesc("MXXREF='$(crossReference)' and MXIFIL='$(mapImportTable)' ", "SYMXRF", "MXUPPR", V_MXUPPR)
  %if (V_MXUPPR == "Y")
      @dtw_mUPPERCASE(xRefFromValue)
  %endif
  @RtvFldDesc("MXXREF='$(crossReference)' and MXIFIL='$(mapImportTable)' ", "SYMXRF", "MXFLDT", V_MXFLDT)
  %if (V_MXFLDT == "N")
      @dtw_strip(xRefFromValue,xRefFromValue)
      %if (xRefFromValue=="")
          @dtw_assign(xRefFromValue, "0")
      %endif
  %endif

  @RtvFldDesc("MXXREF='$(crossReference)' and MXIFIL='$(mapImportTable)' ", "SYMXRF", "MXPARM", V_MXPARM)
  @RtvFldDesc("PMPARM='$(V_MXPARM)'", "WFPARM", "PMUPPR", V_PMUPPR)
  @RtvFldDesc("PMPARM='$(V_MXPARM)'", "WFPARM", "PMTYPE", V_PMTYPE)
  %if (V_PMTYPE != "A" && V_PMTYPE != "")
      @dtw_strip(xRefToValue,xRefToValue)
      %if (xRefToValue=="")
          @dtw_assign(xRefToValue, "0")
      %endif
  %endif

  %if (V_PMUPPR == "Y")
      @dtw_mUPPERCASE(xRefToValue)
  %endif

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@frm1", fromXRefFromValue)
  @Concat_Field("@@xref", crossReference)
  @Concat_Field("@@ifil", mapImportTable)
  @Concat_Field("@@fval", xRefFromValue)
  @Concat_Field("@@tval", xRefToValue)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(xRefFromValue), "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@fval", "crossReference")
      @Format_ConfMsg_Desc("", $(xRefFromValue), "", "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;xRefFromValue=@dtw_rurlescseq(xRefFromValue)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
