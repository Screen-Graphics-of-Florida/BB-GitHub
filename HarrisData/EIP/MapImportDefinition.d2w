%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Import Definition"
  d2wName                 = "MapImportDefinition.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;specificMapKey=@dtw_rurlescseq(specificMapKey)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HSYIHM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  noMsg                   = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "MAPIMPORTDEFINITION")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select Distinct SYMIHD.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(MHWPGM,' ') as MHWPGM,  ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(MHDESC,' ') as MHDESC, coalesce(MHDESCU,' ') as MHDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(a.FLDESC,' ') as clearFLDESC, upper(coalesce(a.FLDESC,' ')) as clearFLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(b.FLDESC,' ') as inuseFLDESC, upper(coalesce(b.FLDESC,' ')) as inuseFLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(USDESC,' ') as USDESC, coalesce(USDESCU,' ') as USDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " SYMIHD ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYMMHD on MHMPKY=FHMPKY ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG a on a.FLTYPE='BY' and a.FLVALU=FHCIMP ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG b on b.FLTYPE='MAPOPT' and b.FLVALU=FHSOPT ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYUSER on USUSER=FHSUSR ", fileSQL)
                      %if (@dtw_rPos("FFIFIL",wildCardSearch) >"0")
                          @dtw_concat(fileSQL, " inner join SYMITB on FFIMKY=FHIMKY ", fileSQL)
                      %endif
                      %if (specificMapKey!="")
                          @dtw_concat(selectSQL, " FHMPKY=$(specificMapKey) ", selectSQL)
                      %elif (wildCardSearch!="")
                          @dtw_concat(selectSQL, " FHIMKY>0 ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)MapImportDefinitionMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      %if (specificMapKey!="")
          <table $(contentTable)>
              @RtvFldDesc("MHMPKY=$(specificMapKey)", "SYMMHD", "MHDESC", V_MHDESC)
              @RtvFldDesc("MHMPKY=$(specificMapKey)", "SYMMHD", "MHWPGM", V_MHWPGM)
              @Format_Header_URL("Map Definition", $(V_MHDESC), $(V_MHWPGM), "$(homeURL)$(cGIPath)MapDefinitionSelect.d2w/REPORT$(genericVarBase)&amp;mapKey=@dtw_rurlescseq(specificMapKey)")
          </table>
      %endif

      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint == "")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Description</th>
                      %if (specificMapKey=="")
                          <th class="colhdr">Map Definition</th>
                      %endif
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="15" maxlength="50">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      %if (specificMapKey=="")
                          <td><input type="text" class="inputalph" name="srchMapDefinition" size="15" maxlength="50">
                              <input type="hidden" name="operMapDefinition" value="LIKE">
                          </td>
                      %endif
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("FHDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description"       title="Sequence By Description, Import Definition">Description</a></th>
              %if (specificMapKey=="")
                  @OrderBy_Sort("MHDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MapDefinition" title="Sequence By Map Definition, Import Definition">Map Definition</a></th>
              %endif
              @OrderBy_Sort("clearFLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ClearImport"   title="Sequence By Clear Import Table, Import Definition">Clear Import Table</a></th>
              @OrderBy_Sort("FHEXT1U", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PreImportExit"     title="Sequence By Pre-Import Exit Point, Import Definition">Pre-Import Exit Point</a></th>
              @OrderBy_Sort("FHEXT3U", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PreDefaultExit"    title="Sequence By Pre-Default Logic Exit Point, Import Definition">Pre-Default Logic Exit Point</a></th>
              @OrderBy_Sort("FHEXT4U", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PostDefaultExit4"  title="Sequence By Post-Default Logic Exit Point, Import Definition">Post-Default Logic Exit Point</a></th>
               @OrderBy_Sort("FHEXT2U", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ReportExit"        title="Sequence By Interface Report Exit Point, Import Definition">Interface Report Exit Point</a></th>
              @OrderBy_Sort("inuseFLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=InUse"         title="Sequence By Option Selected, Import Definition">Option Selected</a></th>
              @OrderBy_Sort("USDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=User"          title="Sequence By Selected By, Import Definition">Selected By</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;importKey=@dtw_rurlescseq(V_FHIMKY)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;updRecNbr=@dtw_rurlescseq(START_ROW_NUM)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_FHDESC), $(V_FHIMKY), "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if ((sec_02 == "Y" || sec_03 == "Y") && V_FHSELC=="")
                              <a href="$(homeURL)$(cGIPath)MapImportDefinitionMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y" && V_FHSELC=="")
                              <a href="$(homeURL)$(cGIPath)MapImportDefinitionMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromImportKey=@dtw_rurlescseq(V_FHIMKY)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y" && V_FHSELC=="")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)MapImportDefinitionMaintain.d2w/EDIT_DATA$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)MapImportDefinitionSelect.d2w/REPORT$(d2wVarBase)&amp;importKey=@dtw_rurlescseq(V_FHIMKY)" title="View Import Definition">$(V_FHDESC)</a></td>
                  %if (specificMapKey=="")
                      <td class="colalph" $(helpCursor)><span title="$(V_MHWPGM)">$(V_MHDESC)</span></td>                                      	
                  %endif
                  <td class="colcode" $(helpCursor)><span title="$(V_FHCIMP)">$(V_clearFLDESC)</span></td>                                      	
                  <td class="colalph">$(V_FHEXT1)</td>                                      	
                  <td class="colalph">$(V_FHEXT3)</td>                                      	
                  <td class="colalph">$(V_FHEXT4)</td>                                      	
                  <td class="colalph">$(V_FHEXT2)</td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_FHSOPT)">$(V_inuseFLDESC)</span></td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_FHSUSR)">$(V_USDESC)</span></td>                                      	
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select Distinct SYMIHD.*, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(MHWPGM,' ') as MHWPGM,  ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(MHDESC,' ') as MHDESC, coalesce(MHDESCU,' ') as MHDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(FLDESC,' ') as FLDESC, upper(coalesce(FLDESC,' ')) as FLDESCU ", stmtSQL)
  @dtw_concat(fileSQL, " SYMIHD ", fileSQL)
  @dtw_concat(fileSQL, " left join SYMMHD on MHMPKY=FHMPKY ", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG on FLTYPE='BY'      and FLVALU=FHCIMP ", fileSQL)
  %if (@dtw_rPos("FFIFIL",wildCardSearch) >"0")
      @dtw_concat(fileSQL, " inner join SYMITB on FFIMKY=FHIMKY ", fileSQL)
  %endif
  %if (wildCardSearch!="")
      @dtw_concat(selectSQL, " FHIMKY>0 ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_XMLQuery (IN  CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("ImportDefinitionList")
          %ROW{
              @XMLIDTag(V_FHIMKY, "ImportDefinition ID")
                  @XMLTag(V_FHIMKY, "ImportKey")
                  @XMLTag(V_FHMPKY, "MapKey")
                  @XMLTag(V_FHDESC, "Description")
                  @XMLTag(V_FHCIMP, "ClearImportTable")
                  @XMLTag(V_FHEXT1, "PreImportExitPoint")
                  @XMLTag(V_FHEXT3, "PreDefaultLogicExitPoint")
                  @XMLTag(V_FHEXT4, "PostDefaultLogicExitPoint")
                  @XMLTag(V_FHEXT2, "ReportExitPoint")
              @XMLEndTag("ImportDefinition")
          %}
      @XMLEndTag("ImportDefinitionList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "FHDESCU,FHIMKY")
          @DTW_ASSIGN(orderByDisplay, "Description, Import Definition")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %if (updRecNbr > "0")
      @dtw_assign(START_ROW_NUM, updRecNbr)
      @dtw_assign(updRecNbr, "")
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Description")
      %if (orderBy == "FHDESCU,FHIMKY")
          @DTW_ASSIGN(orderBy, "FHDESCU DESC,FHIMKY")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Import Definition")
      %else
          @DTW_ASSIGN(orderBy, "FHDESCU,FHIMKY")
          @DTW_ASSIGN(orderByDisplay, "Description, Import Definition")
      %endif
  %elif (sequence == "MapDefinition")
      %if (orderBy == "MHDESCU,FHDESCU")
          @DTW_ASSIGN(orderBy, "MHDESCU DESC,FHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Map Definition (descending), Description")
      %else
          @DTW_ASSIGN(orderBy, "MHDESCU,FHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Map Definition, Description")
      %endif
  %elif (sequence == "ClearImport")
      %if (orderBy == "clearFLDESCU,FHDESCU")
          @DTW_ASSIGN(orderBy, "clearFLDESCU DESC,FHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Clear Import Table (descending), Description")
      %else
          @DTW_ASSIGN(orderBy, "clearFLDESCU,FHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Clear Import Table, Description")
      %endif
  %elif (sequence == "PreImportExit")
      %if (orderBy == "FHEXT1U,FHDESCU")
          @DTW_ASSIGN(orderBy, "FHEXT1U DESC,FHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Pre-Import Exit Point (descending), Description")
      %else
          @DTW_ASSIGN(orderBy, "FHEXT1U,FHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Pre-Import Exit Point, Description")
      %endif
  %elif (sequence == "PreDefaultExit")
      %if (orderBy == "FHEXT3U,FHDESCU")
          @DTW_ASSIGN(orderBy, "FHEXT3U DESC,FHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Pre-Default Logic Exit Point (descending), Description")
      %else
          @DTW_ASSIGN(orderBy, "FHEXT3U,FHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Pre-Default Logic Exit Point, Description")
      %endif
  %elif (sequence == "PostDefaultExit")
      %if (orderBy == "FHEXT4U,FHDESCU")
          @DTW_ASSIGN(orderBy, "FHEXT4U DESC,FHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Post-Default Logic Exit Point (descending), Description")
      %else
          @DTW_ASSIGN(orderBy, "FHEXT4U,FHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Post-Default Logic Exit Point, Description")
      %endif
  %elif (sequence == "ReportExit")
      %if (orderBy == "FHEXT2U,FHDESCU")
          @DTW_ASSIGN(orderBy, "FHEXT2U DESC,FHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Interface Report Exit Point (descending), Description")
      %else
          @DTW_ASSIGN(orderBy, "FHEXT2U,FHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Interface Report Exit Point, Description")
      %endif
  %elif (sequence == "InUse")
      %if (orderBy == "inuseFLDESCU,FHDESCU")
          @DTW_ASSIGN(orderBy, "inuseFLDESCU DESC,FHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Option Selected (descending), Description")
      %else
          @DTW_ASSIGN(orderBy, "inuseFLDESCU,FHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Option Selected, Description")
      %endif
  %elif (sequence == "User")
      %if (orderBy == "USDESCU,FHDESCU")
          @DTW_ASSIGN(orderBy, "USDESCU DESC,FHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Selected By (descending), Description")
      %else
          @DTW_ASSIGN(orderBy, "USDESCU,FHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Selected By, Description")
      %endif
  %endif
	
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "MAPIMPORTDEFINITIONSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="15" maxlength="50"></td>
                          </tr>

                          %if (specificMapKey=="")
                              <tr><td class="dsphdr">Map Definition</td>
                                  @dtw_assign(operNbr, "operMapDefinition")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchMapDefinition" size="15" maxlength="50"></td>
                              </tr>
                          %endif

                          <tr><td class="dsphdr">Clear Import Table</td>
                              @dtw_assign(operNbr, "operClearImport")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchClearImport" size="3" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Pre-Import Exit Point</td>
                              @dtw_assign(operNbr, "operPreImportExit")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchPreImportExit" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">Pre-Default Logic Exit Point</td>
                              @dtw_assign(operNbr, "operPreDefaultExit")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchPreDefaultExit" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">Post-Default Logic Exit Point</td>
                              @dtw_assign(operNbr, "operPostDefaultExit")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchPostDefaultExit" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">Interface Report Exit Point</td>
                              @dtw_assign(operNbr, "operReportExit")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchReportExit" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">Import Table</td>
                              @dtw_assign(operNbr, "operImportTable")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchImportTable" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Option Selected</td>
                              @dtw_assign(operNbr, "operOptSelect")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchOptSelect" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Selected By</td>
                              @dtw_assign(operNbr, "operUser")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchUser" size="15" maxlength="30"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDesc.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("FHDESCU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("MHDESCU", "Map Definition", $(srchMapDefinition), "U", operMapDefinition, "A")
  @Build_WildCard ("Upper(a.FLDESC)", "Clear Import Table", $(srchClearImport), "U", operClearImport, "A")
  @Build_WildCard ("FHEXT1U", "Pre-Import Exit Point", $(srchPreImportExit), "U", operPreImportExit, "A")
  @Build_WildCard ("FHEXT3U", "Pre-Default Logic Exit Point", $(srchPreDefaultExit), "U", operPreDefaultExit, "A")
  @Build_WildCard ("FHEXT4U", "Post-Default Logic Exit Point", $(srchPostDefaultExit), "U", operPostDefaultExit, "A")
  @Build_WildCard ("FHEXT2U", "Interface Report Exit Point", $(srchReportExit), "U", operReportExit, "A")
  @Build_WildCard ("FFIFIL", "Import Table", $(srchImportTable), "U", operImportTable, "A")
  @Build_WildCard ("Upper(b.FLDESC)", "Option Selected", $(srchOptSelect), "U", operOptSelect, "A")
  @Build_WildCard ("USDESCU", "Selected By", $(srchUser), "U", operUser, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}