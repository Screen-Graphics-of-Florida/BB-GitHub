%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "StoredProcedureVariables.icl"

%Define {
  page_title              = "Sales History Inquiry"
  d2wName                 = "SalesForecastInquirySalesHistory.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;type=@dtw_rurlescseq(type)&amp;reference=@dtw_rurlescseq(reference)&amp;year=@dtw_rurlescseq(year)&amp;fdky=@dtw_rurlescseq(fdky)&amp;cust=@dtw_rurlescseq(cust)&amp;FDCUST=@dtw_rurlescseq(FDCUST)&amp;ccls=@dtw_rurlescseq(ccls)&amp;FDCCLS=@dtw_rurlescseq(FDCCLS)&amp;creg=@dtw_rurlescseq(creg)&amp;FDCRGN=@dtw_rurlescseq(FDCRGN)&amp;loc=@dtw_rurlescseq(loc)&amp;FDLOC=@dtw_rurlescseq(FDLOC#)&amp;slmn=@dtw_rurlescseq(slmn)&amp;FDSLSM=@dtw_rurlescseq(FDSLSM)&amp;pcls=@dtw_rurlescseq(pcls)&amp;FDPCLS=@dtw_rurlescseq(FDPCLS)&amp;bac=@dtw_rurlescseq(bac)&amp;FDBAC=@dtw_rurlescseq(FDBAC)&amp;ptyp=@dtw_rurlescseq(ptyp)&amp;FDPTYP=@dtw_rurlescseq(FDPTYP)&amp;plant=@dtw_rurlescseq(plant)&amp;item=@dtw_rurlescseq(item)&amp;periodFormat=@dtw_rurlescseq(periodFormat)&amp;quantityFormat=@dtw_rurlescseq(quantityFormat)&amp;IQHBGN=@dtw_rurlescseq(IQHBGN)&amp;IQHEND=@dtw_rurlescseq(IQHEND)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
%}


%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@type", "@dtw_rurlescseq(type)", "1", "a", workURL)
  @dtw_replace(workURL, "@@reference", "@dtw_rurlescseq(reference)", "1", "a", workURL)
  @dtw_replace(workURL, "@@year", "@dtw_rurlescseq(year)", "1", "a", workURL)
  @dtw_replace(workURL, "@@fdky", "@dtw_rurlescseq(fdky)", "1", "a", workURL)
  @dtw_replace(workURL, "@@cust", "@dtw_rurlescseq(cust)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "SALESFORECASTINQUIRYSALESHISTORY")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select SHSHTO, SHWHS, SHDTLI, SHORD#, SHQSTC, CMCNA1", stmtSQL)
                      @dtw_concat(fileSQL, " WKSLSH left join HDCUST ON SHSHTO=CMCUST ", fileSQL)
                      @dtw_concat(selectSQL, " SHXHND='$(profileHandle)' ", selectSQL)
                      @dtw_concat(selectSQL, " and (SHDTLI>='$(IQHBGN)' and SHDTLI<='$(IQHEND)') ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td>&nbsp;</td>
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                      <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      <table $(contentTable)>
          %if (cust == "1")
              @RtvFldDesc("CMCUST=$(FDCUST)", "HDCUST", "CMCNA1", fieldDesc)
              @Format_Header_URL("Customer", $(fieldDesc), $(FDCUST), "")
          %elif (ccls == "1")
              @RtvFldDesc("CCCCLS='$(FDCCLS)' ", "HDCCLS", "CCCCDS", fieldDesc)
              @Format_Header_URL("Customer Class", $(fieldDesc), $(FDCCLS), "")
          %elif (creg == "1")
              @RtvFldDesc("RGCRGN='$(FDCRGN)' ", "HDCRGN", "RGCRDS", fieldDesc)
              @Format_Header_URL("Customer Region", $(fieldDesc), $(FDCRGN), "")
          %elif (loc == "1")
              @RtvFldDesc("LOLO#=$(FDLOC#)", "HDLCTN", "LOLNA1", fieldDesc)
              @Format_Header_URL("Location", $(fieldDesc), $(FDLOC#), "")
          %elif (slmn == "1")
              @RtvFldDesc("SMSLSM=$(FDSLSM)", "HDSLSM", "SMSNA1", fieldDesc)
              @Format_Header_URL("Salesman", $(fieldDesc), $(FDSLSM), "")
          %elif (pcls == "1")
              @RtvFldDesc("PCPCLS='$(FDPCLS)' ", "HDPCLS", "PCPCDS", fieldDesc)
              @Format_Header_URL("Product Class", $(fieldDesc), $(FDPCLS), "")
          %elif (bac == "1")
              @RtvFldDesc("BMBUYR=$(FDBAC)", "HDBUYR", "BMBNA1", fieldDesc)
              @Format_Header_URL("Buyer/Analyst", $(fieldDesc), $(FDBAC), "")
          %elif (ptyp == "1")
              @Format_Header_URL("Part Type", $(FDPTYP), "", "")
          %endif
          %if (cust == "2")
              @RtvFldDesc("CMCUST=$(FDCUST)", "HDCUST", "CMCNA1", fieldDesc)
              @Format_Header_URL("Customer", $(fieldDesc), $(FDCUST), "")
          %elif (ccls == "2")
              @RtvFldDesc("CCCCLS='$(FDCCLS)' ", "HDCCLS", "CCCCDS", fieldDesc)
              @Format_Header_URL("Customer Class", $(fieldDesc), $(FDCCLS), "")
          %elif (creg == "2")
              @RtvFldDesc("RGCRGN='$(FDCRGN)' ", "HDCRGN", "RGCRGN", fieldDesc)
              @Format_Header_URL("Customer Region", $(fieldDesc), $(FDCRGN), "")
          %elif (loc == "2")
              @RtvFldDesc("LOLO#=$(FDLOC#)", "HDLCTN", "LOLNA1", fieldDesc)
              @Format_Header_URL("Location", $(fieldDesc), $(FDLOC#), "")
          %elif (slmn == "2")
              @RtvFldDesc("SMSLSM=$(FDSLSM)", "HDSLSM", "SMSNA1", fieldDesc)
              @Format_Header_URL("Salesman", $(fieldDesc), $(FDSLSM), "")
          %elif (pcls == "2")
              @RtvFldDesc("PCPCLS='$(FDPCLS)' ", "HDPCLS", "PCPCDS", fieldDesc)
              @Format_Header_URL("Product Class", $(fieldDesc), $(FDPCLS), "")
          %elif (bac == "2")
              @RtvFldDesc("BMBUYR=$(FDBAC)", "HDBUYR", "BMBNA1", fieldDesc)
              @Format_Header_URL("Buyer/Analyst", $(fieldDesc), $(FDBAC), "")
          %elif (ptyp == "2")
              @Format_Header_URL("Part Type", $(FDPTYP), "", "")
          %endif
          %if (cust == "3")
              @RtvFldDesc("CMCUST=$(FDCUST)", "HDCUST", "CMCNA1", fieldDesc)
              @Format_Header_URL("Customer", $(fieldDesc), $(FDCUST), "")
          %elif (ccls == "3")
              @RtvFldDesc("CCCCLS='$(FDCCLS)' ", "HDCCLS", "CCCCDS", fieldDesc)
              @Format_Header_URL("Customer Class", $(fieldDesc), $(FDCCLS), "")
          %elif (creg == "3")
              @RtvFldDesc("RGCRGN='$(FDCRGN)' ", "HDCRGN", "RGCRGN", fieldDesc)
              @Format_Header_URL("Customer Region", $(fieldDesc), $(FDCRGN), "")
          %elif (loc == "3")
              @RtvFldDesc("LOLO#=$(FDLOC#)", "HDLCTN", "LOLNA1", fieldDesc)
              @Format_Header_URL("Location", $(fieldDesc), $(FDLOC#), "")
          %elif (slmn == "3")
              @RtvFldDesc("SMSLSM=$(FDSLSM)", "HDSLSM", "SMSNA1", fieldDesc)
              @Format_Header_URL("Salesman", $(fieldDesc), $(FDSLSM), "")
          %elif (pcls == "3")
              @RtvFldDesc("PCPCLS='$(FDPCLS)' ", "HDPCLS", "PCPCDS", fieldDesc)
              @Format_Header_URL("Product Class", $(fieldDesc), $(FDPCLS), "")
          %elif (bac == "3")
              @RtvFldDesc("BMBUYR=$(FDBAC)", "HDBUYR", "BMBNA1", fieldDesc)
              @Format_Header_URL("Buyer/Analyst", $(fieldDesc), $(FDBAC), "")
          %elif (ptyp == "3")
              @Format_Header_URL("Part Type", $(FDPTYP), "", "")
          %endif
          @RtvFldDesc("PLPLNT=$(plant)", "HDPLNT", "PLNAME", plantName)
          @Format_Header_URL("Plant Number", $(plantName), $(plant), "")
          @RtvFldDesc("IMITEM='$(item)'", "HDIMST", "IMIMDS", itemDescription)
          @Format_Header_URL("Item Number", $(itemDescription), $(item), "")
          @Format_Date(IQHEND, "1", F_IQHEND)
          @Format_Header_URL("Period End", $(F_IQHEND),"", "")
      </table>
      $(hrTagAttr)

      %if (formatToPrint != "Y")
              <table $(contentTable)>
                  <tr><td> %INCLUDE "AssignPageValue.icl" </td>
                      <td>&nbsp;</td>

                  </tr>
              </table>
          %endif
      <table $(contentTable)>
         @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              @OrderBy_Sort("SHSHTO", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=customer" title="Sequence By Customer">Customer</a></th>
              @OrderBy_Sort("CMCNA1", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=name" title="Sequence By Name">Name</a></th>
              @OrderBy_Sort("SHWHS", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=warehouse" title="Sequence By Warehouse">Warehouse</a></th>
              @OrderBy_Sort("SHDTLI", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=date" title="Sequence By Date">Date</a></th>
              @OrderBy_Sort("SHORD#", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=order" title="Sequence By Order Number">Order<br>Number</a></th>
              @OrderBy_Sort("SHQSTC", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=quantity" title="Sequence By Quantity">Quantity</a></th>
         </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Nbr(V_SHSHTO, F_SHSHTO, "0", "Z", "", "", "")
              @Format_Nbr(V_SHWHS, F_SHWHS, "0", "Z", "", "", "")
              @Format_Date(V_SHDTLI, "1", F_SHDTLI)
              @Format_Nbr(V_SHORD#, F_SHORD#, "0", "Z", "", "", "")
              %if (quantityFormat == "01")
                  @Format_Nbr(V_SHQSTC, F_SHQSTC, "0", "Z", "", "", "")
              %else
                  @Format_Nbr(V_SHQSTC, F_SHQSTC, "4", "M", "Y", "", "")
              %endif
              @RtvFldDesc("CMCUST=$(V_SHSHTO)", "HDCUST", "CMCNA1", CUSTNAME)
              <tr class="$(rowClass)">
                  <td class="colnmbr">$(F_SHSHTO)</td>
                  <td class="colalph">$(V_CMCNA1)</td>
                  <td class="colnmbr">$(F_SHWHS)</td>
                  <td class="colnmbr">$(F_SHDTLI)</td>
                  <td class="colnmbr">$(F_SHORD#)</td>
                  <td class="colnmbr">$(F_SHQSTC)</td>
              </tr>

          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}


%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"

  %if (formatToPrint == "Y")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else

      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "SHSHTO")
          @DTW_ASSIGN(orderByDisplay, "Customer Number")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif

  %INCLUDE "SearchReturn.icl"
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"

  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "SHSHTO")
          @DTW_ASSIGN(orderByDisplay, "Customer Number")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "customer")
      %if (orderBy == "SHSHTO")
          @DTW_ASSIGN(orderBy, "SHSHTO DESC")
          @DTW_ASSIGN(orderByDisplay, "Customer Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SHSHTO")
          @DTW_ASSIGN(orderByDisplay, "Customer Number")
      %endif
  %elif (sequence == "name")
      %if (orderBy == "CMCNA1")
          @DTW_ASSIGN(orderBy, "CMCNA1 DESC")
          @DTW_ASSIGN(orderByDisplay, "Customer Name (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CMCNA1")
          @DTW_ASSIGN(orderByDisplay, "Customer Name")
      %endif
  %elif (sequence == "warehouse")
      %if (orderBy == "SHWHS")
          @DTW_ASSIGN(orderBy, "SHWHS DESC")
          @DTW_ASSIGN(orderByDisplay, "Warehouse (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SHWHS")
          @DTW_ASSIGN(orderByDisplay, "Warehouse")
      %endif
  %elif (sequence == "date")
      %if (orderBy == "SHDTLI")
          @DTW_ASSIGN(orderBy, "SHDTLI DESC")
          @DTW_ASSIGN(orderByDisplay, "Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SHDTLI")
          @DTW_ASSIGN(orderByDisplay, "Date")
      %endif
  %elif (sequence == "order")
      %if (orderBy == "SHORD#")
          @DTW_ASSIGN(orderBy, "SHORD# DESC")
          @DTW_ASSIGN(orderByDisplay, "Order Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SHORD#")
          @DTW_ASSIGN(orderByDisplay, "Order Number")
      %endif
  %elif (sequence == "quantity")
      %if (orderBy == "SHQSTC")
          @DTW_ASSIGN(orderBy, "SHQSTC DESC")
          @DTW_ASSIGN(orderByDisplay, "Quantity (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SHQSTC")
          @DTW_ASSIGN(orderByDisplay, "Quantity")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}