%INCLUDE "$(baseVar)"
%INCLUDE "EdtVar.icl"
%INCLUDE "editRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title		   = ""
  page_title1		   = "Add Employee Benefit"
  page_title2		   = "Add Dependent Benefit"
  d2wName                 = "EmplBenefitsAdd.d2w"
  d2wVarBase              = "$(genericVarBase)$(employeeVarBase)&amp;dependentNbr=@dtw_rurlescseq(dependentNbr)&amp;benefitCode=@dtw_rurlescseq(benefitCode)&amp;planCode=@dtw_rurlescseq(planCode)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;backHome=@dtw_rurlescseq(backHome)"
  phpVarBase              = "$(altVarBase)$(employeeVarBase)&amp;dependentNbr=@dtw_rurlescseq(dependentNbr)&amp;benefitCode=@dtw_rurlescseq(benefitCode)&amp;planCode=@dtw_rurlescseq(planCode)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName             = "HPEECU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  applicationID           = "PE"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "doctype.icl"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script LANGUAGE="JavaScript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  function validate(chgForm) {
                      if (document.Chg.benefitPlan.value =="")
                         {alert("$(reqFieldError)"); return false;}
                          return true;
                  }
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "EMPLBENMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                         @dtw_assign(stmtSQL, "")
                          %INCLUDE "AddRecordSQL.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- Start Of Trailer Code -->
          </body>
      </html>
  %endif
  %}

%FUNCTION(dtw_sql) Maintain_Query (IN  CHAR(64) profileHandle,
                                       CHAR(2)   dataBaseID,
                                       CHAR(32000) stmtSQL)

{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %if (dependentNbr == "0000000")
          @dtw_assign(page_title, page_title1)
      %else
          @dtw_assign(page_title, page_title2)
      %endif

      <table $(contentTable)>
          <colgroup>
	       <col width="80%">
	       <col width="15%">

          <tr><td align="justify"><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  %if ((backHome != "$(d2wName)/ADD") && (backHome != ""))
                      <a href="$(homeURL)$(cGIPath)$(backHome)$(genericVarBase)$(employeeVarBase)&dependentNbr=@dtw_rurlescseq(dependentNbr)&backHome=@dtw_rurlescseq(backHome)" title="Back Home">$(portalHome)</a>
                  %endif
                  %INCLUDE "MaintainTopNoTable.icl"
              </td>
          </tr>
          @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)

          %if (dependentNbr == "0000000")
              <tr><td><h2>$(F_EmpName)</h2></td></tr>
          %else
              <tr><td><h2>$(F_EmpName)</h2></td></tr>
              @RetDepNam(profileHandle, dataBaseID, dependentNbr, depName)
              <tr><td><h2> Dependent $(depName)</h2></td></tr>
          %endif
      </table>

      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(genericVarBase)$(employeeVarBase)&dependentNbr=@dtw_rurlescseq(dependentNbr)&backHome=@dtw_rurlescseq(backHome)&benefitCode=@dtw_rurlescseq(V_ECCOVR)&planCode=@dtw_rurlescseq(V_ECPLAN)&maintenanceCode=@dtw_rurlescseq(maintenanceCode)&fromD2w=@dtw_rurlescseq(fromD2w)">
          %ROW {
              %if (errFound != "" || maintenanceCode == "A")
                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(edtVar, "")
                      @dtw_assign(focusField, "benefitPlan")
                  %else
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@covr", "benefitCode")       @dtw_assign(Err_ECCOVR, fieldValue)
                      @DecatErr_Field("@@plan", "planCode")          @dtw_assign(Err_ECPLAN, fieldValue)
                  %endif

                  @Decat_Field("@@covr")   @dtw_assign(V_ECCOVR, fieldValue)
                  @Decat_Field("@@plan")   @dtw_assign(V_ECPLAN, fieldValue)

                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(V_ECCOVR,"  ")
                      @dtw_assign(V_ECPLAN,"   ")
                  %endif

                  @dtw_assign(errFound, "")

              %elif (maintenanceCode == "Z")
                  @dtw_assign(V_ECCOVR, "")
                  @dtw_assign(V_ECPLAN,"   ")
              %elif (maintenanceCode != "A")
              %endif

              <table $(contentTable)>
                  @SetTextOvr(Err_ECCOVR)
                  %if (maintenanceCode == "A" || maintenanceCode == "Z")
                      @dtw_assign(benefitPlan, "     ")
                      @dtw_concat(V_ECCOVR, V_ECPLAN, benefitPlan)
                  %if (focusField == "benefitCode")
                      @dtw_assign(focusField, "benefitPlan")
                  %endif
                      <tr><td class="dsphdr"><span $(textOvr)>Benefit/Plan</span> </td>
                          @dtw_tb_rows(benefitCodeTable, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(benefitCodeTable, x, "5") != benefitPlan) && (x < maxRows))
                               {@dtw_add(x, "1", x)%}
                          <td> @dtw_tb_select(benefitCodeTable, "benefitPlan", "6", "1", "N", "", x, "5") $(reqFieldChar) </td>
                      </tr>
                      @DspErrMsg(Err_ECCOVR)
                  %endif

              </table>
          %}

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      <div class="copr"> $(copyright) </div>
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64) profileHandle,
                                        INOUT CHAR(1) maintenanceCode,
                                        INOUT CHAR(1) errFound,
                                        INOUT CHAR(32000) edtVar,
                                        INOUT CHAR(32000) errVar,
                                        INOUT CHAR(32000) wrnVar)

  {%EXEC {HPEECU_W.PGM %}
  %}
%HTML(ADD) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if ((sec_01 == "N" && maintenanceCode == "A") || ((sec_01=="N" || sec_04=="N") && maintenanceCode == "Z"))
      %INCLUDE "ProgSecurityError.icl"
  %else
     %if (maintenanceCode == "A" || maintenanceCode == "Z")
         @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMBGRP", benefitGroup)
         @BenefitCode_Query(profileHandle, dataBaseID, prCompany, prFacility, benefitGroup, benefitCodeTable)
             @dtw_tb_insertrow(benefitCodeTable, "0", "1")
             @dtw_tb_setv(benefitCodeTable, "None", "1", "2")
             @dtw_tb_setv(benefitCodeTable, "   ", "1", "3")
             @dtw_tb_setv(benefitCodeTable, "None", "1", "4")
             @dtw_tb_setv(benefitCodeTable, "     ", "1", "5")
             @dtw_tb_setv(benefitCodeTable, "None", "1", "6")
     %endif
  @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  %if (maintenanceCode == "A" || maintenanceCode == "Z")
      @dtw_substr(benefitPlan, "1", "2", "", benefitCode)
      @dtw_substr(benefitPlan, "3", "3", "", planCode)
      @dtw_assign(maintenanceCode,"A")
  %endif

  @dtw_assign(dependentNbr,@dtw_rstrip(dependentNbr))
  @dtw_assign(editcovrplan, "Y")

  @dtw_assign(edtVar, "")
  @Concat_Field("@@comp", prCompany)
  @Concat_Field("@@facl", prFacility)
  @Concat_Field("@@pecp", hrCompany)
  @Concat_Field("@@empl", hrEmployee)
  @Concat_Field("@@spdp", dependentNbr)
  @Concat_Field("@@ssn@", SSN)
  @Concat_Field("@@covr", benefitCode)
  @Concat_Field("@@plan", planCode)
  @Concat_Field("@@edcp", editcovrplan)
  @dtw_concat(edtVar, "}{", edtVar)

  @dtw_assign(wrnVar, "")
  @Validate_Data(profileHandle, maintenanceCode, errFound, edtVar, errVar, wrnVar)

  %if (errFound == "")
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)EmplBenefitsMaintain.php$(phpVarBase)&amp;tag=MAINTAIN&amp;maintenanceCode=A">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/ADD$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
  %endif
%}