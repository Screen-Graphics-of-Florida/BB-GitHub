%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Data Collection"
  d2wName                 = "DataCollection.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;touchScreen=Y"
  currentURL              = "$(d2wName)/REPORT$(d2wVarBase)"
  programName             = "HETDTC"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Get_Turn () {
  @dtw_assign(timeOutM, "0")
  %if (sfdTimeOut > "0")
      @dtw_multiply(sfdTimeOut, "1000", timeOutM)
  %endif
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script type="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.turnaroundNumber.value =="")
                      {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.turnaroundNumber, 9, 0))
                      return true;
              }
              %INCLUDE "NumEdit.icl"
              %INCLUDE "KeyboardFunctionsTS.icl"

              %if (timeOutM > "0")
                  setTimeout("window.location.assign('$(homeURL)$(cGIPath)ShopFloorDispatch.d2w/REPORT?baseVar=@dtw_rurlescseq(baseVar)&portal=@dtw_rurlescseq(portal)&eID=@dtw_rurlescseq(eID)&touchScreen=Y');",$(timeOutM));
              %endif
              
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @Display_Turn()
                  </td>
                  <td>
                      <ul class="toolbarTS">
                          <li class="optionTS"><a href="$(homeURL)$(cGIPath)ShopFloorDispatch.d2w/REPORT$(d2wVarBase)">&nbsp;<br>Back</a></li>                      
                          <li class="optionTS"><a href="javascript:check(document.Chg)">&nbsp;<br>Accept</a></li>
                      </ul>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%MACRO_FUNCTION Display_Turn () {

  <table $(contentTable)>
      <tr><td><h1>$(page_title)</h1></td></tr>
  </table>
  %INCLUDE "ConfMessageDisplay.icl"
  $(hrTagAttr)
  %INCLUDE "ErrorDisplay.icl"

  <form class="formClass" method="post" name="Chg" onsubmit="return validate(document.Chg)" action="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
      <table $(contentTable)>
          %if (errFound != "")
              @dtw_assign(focusField, "")
              @EdtVarErr(profileHandle, typeValue, edtVar)
              @ErrVarErr(profileHandle, typeError, errVar)
              @DecatErr_Field("@@turn", "turnaroundNumber")      @dtw_assign(Err_LBTURN,  fieldValue)

              @Decat_Field("@@turn")   @dtw_assign(F_LBTURN, fieldValue)

              @dtw_assign(errFound, "")
          %else
              @dtw_assign(F_LBTURN, "")
              @dtw_assign(focusField, "turnaroundNumber")
          %endif

          @SetTextOvr(Err_LBTURN)
          <tr><td class="dsphdr"><span $(textOvr)>Turnaround Number</span></td>
              <td class="input"><input class="input" id="turnaroundNumber" onfocus="kbActive(this, 'numericKeyboard');" name="turnaroundNumber" type="text" value="$(F_LBTURN)" size="10" maxlength="9"></td>
              <td><input type="hidden" id="submitChg"></td>
          </tr>
          @DspErrMsg(Err_LBTURN)
      </table>
	  %INCLUDE "KeyboardTS.icl"

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

  </form>

  $(hrTagAttr)
  %INCLUDE "Copyright.icl"
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HETDTC_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Get_Turn()
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(turnaroundNumber,@dtw_rstrip(turnaroundNumber))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@turn", turnaroundNumber)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, errFound, edtVar, errVar)

  %if (errFound == "")
      <script TYPE="text/javascript">
          %INCLUDE "AJAXRequest.icl"
          %INCLUDE "SaveCurrentURL.icl"
          saveCurrentURL();
      </script>
      @RtvFldDesc("DCTURN=$(turnaroundNumber)", "HDTRNM", "TRIM(DCIVTT)", transactionType)
            
      %if (transactionType == "OR")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)MfgOrderReceipt.d2w/REPORT$(d2wVarBase)&amp;turnaroundNumber=@dtw_rurlescseq(turnaroundNumber)">
      %elif (transactionType == "FI")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ComponentMaterialFill.d2w/BUILD$(genericVarBase)&amp;turnaroundNumber=@dtw_rurlescseq(turnaroundNumber)">
      %elif (transactionType == "IS")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ComponentMaterialIssue.d2w/REPORT$(d2wVarBase)&amp;turnaroundNumber=@dtw_rurlescseq(turnaroundNumber)">
      %elif (transactionType == "FT")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)MfgOrderFinalTag.d2w/REPORT$(d2wVarBase)&amp;turnaroundNumber=@dtw_rurlescseq(turnaroundNumber)">
      %elif (transactionType == "KI")
           <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)KanbanOrderAssignment.d2w/REPORT$(d2wVarBase)&amp;turnaroundNumber=@dtw_rurlescseq(turnaroundNumber)">
      %elif (transactionType == "KO")
           <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)KanbanOrderCompletion.d2w/REPORT$(d2wVarBase)&amp;turnaroundNumber=@dtw_rurlescseq(turnaroundNumber)">
      %elif (transactionType == "KP")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)KanbanPurchasingReceipt.d2w/REPORT$(d2wVarBase)&amp;turnaroundNumber=@dtw_rurlescseq(turnaroundNumber)">
      %elif (transactionType == "LB")
      	  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)LaborEntry.d2w/BUILD$(genericVarBase)">    
      %endif
  %elif (errFound == "C")
      @DecatErr_Field("@@cmsg", "confMessage")
      @dtw_assign(confMessage, fieldValue)
      @dtw_assign(errFound, "")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}