%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "QuickLink.icl"

%Define {
  page_title              = "Validation Program"
  d2wName                 = "WFValidationProgramSelect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;vldProgram=@dtw_rurlescseq(vldProgram)"
  programName             = "HWFVPM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
  V_VPDESC                = ""	
  quickLinkByUser         = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          @RtvFldDesc("VPVPGM='$(vldProgram)'", "WFVLPG", "VPDESC", V_VPDESC)
          @Format_Code(vldProgram, F_vldProgram)
          @dtw_assign(title, "$(V_VPDESC) $(F_vldProgram)")
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "WFVLDPROGRAMSELECT")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif

                  <td class="content">

%{ QuickLink Table %} %INCLUDE "QuickLinkTable.icl"

%{ QuickLink User %}  %INCLUDE "QuickLinkByUser.icl"

%{ Heading %}
                      @dtw_assign(RPT_MAX_ROWS, "99")
                      @dtw_assign(dspMaxRows, "10")
                      @dtw_assign(wildCardSearch, "")  %{ No wildCardSearch %}
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " WFVLPG ", fileSQL)
                      @dtw_concat(selectSQL, " VPVPGM='$(vldProgram)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Display_Header(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Begin %} %INCLUDE "QuickLinkBegLoop.icl"

    %{ Validation ID %}
                          %if (quicklinkRef == "validationid")
                              %INCLUDE "QuickLinkClear.icl"
                              @Retrieve_WebReg(userProfile, "", "WFValidationID.d2w", wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select WFVLID.*, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(FLDESC,' ') as FLDESC, upper(coalesce(FLDESC,' ')) as FLDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(ERERDS,' ') as ERERDS ", stmtSQL)
                              @dtw_concat(fileSQL, " WFVLID ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYFLAG on FLTYPE='WFVLDTYPE' and FLVALU=VIVTYP ", fileSQL)
                              @dtw_concat(fileSQL, " left join HDERROR on ERER#=VIER# ", fileSQL)
                              @dtw_concat(selectSQL, " VIVPGM='$(vldProgram)' ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %if (orderBy == "")
                                  @dtw_assign(orderBy, "VIDESCU,VIVLID")
                                  @dtw_assign(orderByDisplay, "Description, Validation ID")
                              %endif
                              @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @Display_Validation_ID(profileHandle, dataBaseID, stmtSQL)

    %{ Validation Exception %}
                          %elif (quicklinkRef == "exception")
                              %INCLUDE "QuickLinkClear.icl"
                              @dtw_assign(wildCardSearch, "")
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select WFPRVE.*, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(PRDESC,' ') as PRDESC, coalesce(PRDESCU,' ') as PRDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(VIDESC,' ') as VIDESC, coalesce(VIDESCU,' ') as VIDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(RMDESC,' ') as RMDESC, coalesce(RMDESCU,' ') as RMDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(FLDESC,' ') as FLDESC, upper(coalesce(FLDESC,' ')) as FLDESCU ", stmtSQL)
                              @dtw_concat(fileSQL, " WFPRVE ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFPRHD on PRPROC=VEPROC ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFVLID on VIVPGM=VEVPGM and VIVLID=VEVLID ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYROLM on RMROLE=VEROLE ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYFLAG on FLTYPE='WFBYPASSVL' and FLVALU=VEBYPS ", fileSQL)
                              @dtw_concat(selectSQL, " VEVPGM='$(vldProgram)' ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              @dtw_assign(orderBy, "PRDESCU,VIDESCU,RMDESCU")
                              @dtw_assign(orderByDisplay, "Process,Description,Role")
                              @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @Display_Exception(profileHandle, dataBaseID, stmtSQL)

    %{ Validation Process %}
                          %elif (quicklinkRef == "validationprocess")
                              %INCLUDE "QuickLinkClear.icl"
                              @dtw_assign(wildCardSearch, "")
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select WFPRVP.*, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(PRDESC,' ') as PRDESC, coalesce(PRDESCU,' ') as PRDESCU ", stmtSQL)
                              @dtw_concat(fileSQL, " WFPRVP ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFPRHD on PRPROC=VLPROC ", fileSQL)
                              @dtw_concat(selectSQL, " VLVPGM='$(vldProgram)'", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              @dtw_assign(orderBy, "PRDESCU")
                              @dtw_assign(orderByDisplay, "Process")
                              @dtw_concat(stmtSQL, " Order By $(orderBy)", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @Display_Validation_Process(profileHandle, dataBaseID, stmtSQL)
                          %endif

%{ Quicklink End %}   %INCLUDE "QuickLinkEndLoop.icl"

                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Display_Header (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;fromD2w=")
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)WFValidationProgramMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (sec_01=="Y" && sec_04=="Y")
                          <a href="$(homeURL)$(cGIPath)WFValidationProgramMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromVldProgram=@dtw_rurlescseq(vldProgram)&amp;maintenanceCode=Z">$(copyImageLrg)</a>
                      %endif
                      %if (sec_02 == "Y" || sec_03 == "Y")
                          <a href="$(homeURL)$(cGIPath)WFValidationProgramMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageLrg)</a>
                      %endif
                      %if (sec_03 == "Y")
                          @Format_Confirm_Desc($(V_VPDESC), $(vldProgram), "", "", "", "", confirmDesc)
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)WFValidationProgramMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %ROW{
          <table $(contentTable)>
              <tr><td class="dsphdr">Program</td>
                  @Format_Code(V_VPVPGM, F_VPVPGM)
                  <td class="dspalph">$(V_VPDESC) $(F_VPVPGM)</td>
              </tr>
          </table>

          $(hrTagAttr)

          %INCLUDE "QuickLinkDisplay.icl"
      %}
  %}
%}

%FUNCTION(dtw_sql) Display_Validation_ID (IN CHAR(64)    profileHandle,
                                             CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="validationid"></a>
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)WFValidationID.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("VIDESCU,VIVLID", "Description")
                  @Format_Column_Header("VIVLID", "Validation ID")
                  @Format_Column_Header("VIVTYP", "Validation Type")
                  @Format_Column_Header("VIER#", "Error Number")
                  @Format_Column_Header("ERERDS", "Error Description")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
			
              <tr class="$(rowClass)">
                  <td class="colalph">$(V_VIDESC)</td>                                      	
                  <td class="colnmbr">$(V_VIVLID)</td>                                      	
                  <td class="colcode" $(helpCursor)><span title="$(V_FLDESC)">$(V_VIVTYP)</span></td>                                      	
                  <td class="colalph">$(V_VIER#)</td>                                      	
                  <td class="colalph">$(V_ERERDS)</td>                                      	
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Display_Exception (IN CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="exception"></a>
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("PRDESCU,VIDESCU,RMDESCU", "Process")
                  @Format_Column_Header("VIDESCU,RMDESCU", "Validation")
                  @Format_Column_Header("RMDESCU,VIDESCU", "Role")
                  @Format_Column_Header("FLDESCU,RMDESCU,VIDESCU", "Bypass Validation")
                  @Format_Column_Header("VEVLID,RMDESCU", "Validation ID")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;documentType=@dtw_rurlescseq(V_FMDOCT)&amp;docDescr=@dtw_rurlescseq(V_DODESC)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              <tr class="$(rowClass)">
                  <td class="colalph" $(helpCursor)><span title="$(V_VEPROC)">$(V_PRDESC)</span></td>                                      	
                  <td class="colalph">$(V_VIDESC)</td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_VEROLE)">$(V_RMDESC)</span></td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_VEBYPS)">$(V_FLDESC)</span></td>                                      	
                  <td class="colnmbr">$(V_VEVLID)</td>                                      	
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Display_Validation_Process (IN CHAR(64)    profileHandle,
                                                  CHAR(2)     dataBaseID,
                                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="validationprocess"></a>
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("PRDESCU", "Description")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
			
              <tr class="$(rowClass)">
                  <td class="colalph" $(helpCursor)><span title="$(V_VLPROC)">$(V_PRDESC)</span></td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}