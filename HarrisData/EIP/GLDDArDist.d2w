%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "WildCardAcct.icl"

%Define {
  page_title              = "Invoice Detail - Distribution"
  d2wName                 = "GLDDArDist.d2w"
  d2wVarBase              = "$(genericVarBase)$(glDDVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;locationNumber=@dtw_rurlescseq(locationNumber)&amp;glDDSeq=@dtw_rurlescseq(glDDSeq)&amp;glDDFile=@dtw_rurlescseq(glDDFile)&amp;invoiceSequence=@dtw_rurlescseq(invoiceSequence)&amp;paymentSequence=@dtw_rurlescseq(paymentSequence)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  V_CMCNA1                = ""
  uv_Sql                  = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @CustomerUserView(profileHandle, dataBaseID, userPass, customerNumber, "Y")
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <link rel=stylesheet type="text/css" href="$(homeURL)$(homePath)$(GLDDStyleSheet)">
              <script TYPE="text/javascript">
    	       %INCLUDE "NumEdit.icl"
                  %INCLUDE "CheckEnterSearch.icl"
                  function validate(searchForm) {
                      if (editNum(document.Search.srchCo, 2, 0) &&
                          editNum(document.Search.srchFac, 4, 0) &&
                          editNum(document.Search.srchAcct, 4, 0) &&
                          editNum(document.Search.srchSub, 4, 0) &&
                          editNum(document.Search.srchAmt, 13, 2))
                          return true;
                  }
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "$(inquiryBanner)"
              <!-- End Of Banner Code -->

              @dtw_assign(uv_CompanyName, "ARCO")
              @dtw_assign(uv_FacilityName, "ARFAC")
              @dtw_assign(uv_AccountName, "ARACCT")
              @dtw_assign(uv_SubaccountName, "ARSUB")
              @dtw_assign(uv_CustomerName, "ARBLTO")
              @dtw_assign(uv_CustomerClassName, "CMCCLS")
              @dtw_assign(uv_RegionName, "CMCRGN")
              @dtw_assign(uv_BillingLocationName, "CMLOC#")
              @dtw_assign(uv_SalesmanName, "CMSLSM")
              @dtw_assign(uv_WarehouseName, "CMWH#")
              %INCLUDE "userview.icl"

              <table $(contentTable)>
                  <tr><td>
                      <table $(contentTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1>$(page_title)</h1></td>
                              %if (formatToPrint != "Y")
                                  <td class="toolbar">
                                      %if (ddReport!="")
                                          <a href="$(homeURL)$(cGIPath)GLDDReport.d2w/REPORT$(genericVarBase)$(glDDVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))" title="Return To Drill Down Report">$(portalHome)</a>
                                      %endif
                                      <a href="$(homeURL)$(cGIPath)$(d2wName)/ENTRY$(d2wVarBase)&amp;formatToPrint=Y" target=_blank>$(formatPrintDesc)</a>
                                      %INCLUDE "HelpPage.icl"
                                  </td>
                              %endif
                          </tr>

                          %if (uv_Sql != "")
                             <tr><td><h3> You may not be authorized to view some transactions </h3></td></tr>
                          %endif
                      </table>

                      $(inquiryhrTagAttr)

                      <table $(contentTable)>
        	           <colgroup>
        	               <col width="30%">
        	               <col width="10%">
        	               <col width="30%">
        	               <col width="10%">
                          <tr valign="top">
                              <td>@dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                                  @dtw_assign(SAVE_MAX_ROWS, RPT_MAX_ROWS)
                                  @dtw_assign(START_ROW_NUM, "1")
                                  @dtw_assign(RPT_MAX_ROWS, "9999")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_assign(appendUserView, "N")
                                  @dtw_assign(appendWildCard, "N")
                                  @dtw_concat(stmtSQL, "SELECT * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDCUST ", fileSQL)
                                  @dtw_concat(selectSQL, " CMCUST=$(customerNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_concat(stmtSQL, " order by CMCUST  ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @CustHdg_Query(profileHandle, dataBaseID, stmtSQL)
                                  @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                                  @dtw_assign(RPT_MAX_ROWS, SAVE_MAX_ROWS)
                              </td>
                              <td>&nbsp;</td>
                              <td>@dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                                  @dtw_assign(SAVE_MAX_ROWS, RPT_MAX_ROWS)
                                  @dtw_assign(START_ROW_NUM, "1")
                                  @dtw_assign(RPT_MAX_ROWS, "9999")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_assign(appendUserView, "N")
                                  @dtw_assign(appendWildCard, "N")
                                  @dtw_concat(stmtSQL, "SELECT * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDLCTN ", fileSQL)
                                  @dtw_concat(selectSQL, " LOLOC#=$(locationNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_concat(stmtSQL, " order by LOLOC#  ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @LocHdg_Query(profileHandle, dataBaseID, stmtSQL)
                                  @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                                  @dtw_assign(RPT_MAX_ROWS, SAVE_MAX_ROWS)
                              </td>
                              <td>&nbsp;</td>
                          </tr>
                      </table>

                      @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                      @dtw_assign(SAVE_MAX_ROWS, RPT_MAX_ROWS)
                      @dtw_assign(START_ROW_NUM, "1")
                      @dtw_assign(RPT_MAX_ROWS, "9999")
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_assign(appendUserView, "N")
                      @dtw_assign(appendWildCard, "N")
                      @dtw_concat(stmtSQL, "SELECT Distinct ARDDSQ, ARISEQ, ARPSEQ, ARAIV#, ARIVDT, ARSLSM, ARORD#, ", stmtSQL)
                      @dtw_concat(stmtSQL, "       ARORDT, ARBLTO ", stmtSQL)
                      @dtw_concat(fileSQL, " ARGLDD ", fileSQL)
                      @dtw_concat(selectSQL, " ARDDSQ=$(glDDSeq) and ARISEQ=$(invoiceSequence) and ARPSEQ=$(paymentSequence) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      @InvHdg_Query(profileHandle, dataBaseID, stmtSQL)
                      @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                      @dtw_assign(RPT_MAX_ROWS, SAVE_MAX_ROWS)

                      @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                      @dtw_assign(SAVE_MAX_ROWS, RPT_MAX_ROWS)
                      @dtw_assign(START_ROW_NUM, "1")
                      @dtw_assign(RPT_MAX_ROWS, "9999")
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_assign(appendUserView, "")
                      @dtw_assign(appendWildCard, "")
                      @dtw_concat(stmtSQL, "SELECT ARGLDD.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(CFCFNM,' ') as CFCFNM, ifnull(CFCFNMU,' ') as CFCFNMU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(CHCHDS,' ') as CHCHDS, ifnull(CHCHDSU,' ') as CHCHDSU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(d.FLDESC,' ') as typeDesc, upper(ifnull(d.FLDESC,' ')) as typeDescU ", stmtSQL)
                      @dtw_concat(fileSQL, " ARGLDD ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDCFAC on CFCO#=ARCO and CFFAC#=ARFAC ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDCHRT on CHACCT=ARACCT and CHSUB=ARSUB ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG d on d.FLTYPE='ARDISTTYPE' and trim(ARARTY)=trim(d.FLVALU) ", fileSQL)
                      @dtw_concat(selectSQL, " ARDDFL='$(glDDFile)' and ARISEQ=$(invoiceSequence) and ARPSEQ=$(paymentSequence) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                      @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                      @dtw_assign(RPT_MAX_ROWS, SAVE_MAX_ROWS)
                  </td></tr>
              </table>

              <!-- Start Of Trailer Code -->
              %INCLUDE "$(inquiryTrailer)"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) CustHdg_Query (IN  CHAR(64) profileHandle,
                                      CHAR(2)   dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %ROW{
          <table $(contentTable)>
              <tr><th class="colhdr">Customer</th></tr>

              <tr><td class="colalph">$(V_CMCNA1)</td></tr>
              <tr><td class="colalph">$(V_CMCNA2)</td></tr>
              %if (V_CMCNA3 != "")
                  <tr><td class="colalph">$(V_CMCNA3)</td></tr>
              %endif
              %if (V_CMCNA4 != "")
                  <tr><td class="colalph">$(V_CMCNA4)</td></tr>
              %endif
              %if (V_CMCCTY != "" || V_CMST !="" || V_CMZIP >"0")
                  <tr><td class="colalph">$(V_CMCCTY), $(V_CMST) $(V_CMZIP)</td></tr>
              %endif
          </table>
      %}
  %}
%}

%FUNCTION(dtw_sql) LocHdg_Query (IN  CHAR(64) profileHandle,
                                     CHAR(2)   dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %ROW{
          <table $(contentTable)>
              <tr><th class="colhdr">Location</th></tr>

              <tr><td class="colalph">$(V_LOLNA1)</td></tr>
              <tr><td class="colalph">$(V_LOLNA2)</td></tr>
              %if (V_LOLNA3 != "")
                  <tr><td class="colalph">$(V_LOLNA3)</td></tr>
              %endif
              %if (V_LOLNA4 != "")
                  <tr><td class="colalph">$(V_LOLNA4)</td></tr>
              %endif
              <tr><td class="colalph">$(V_LOLCTY), $(V_LOST) $(V_LOZIP)</td></tr>
          </table>
          <br>
      %}
  %}
%}

%FUNCTION(dtw_sql) InvHdg_Query (IN  CHAR(64) profileHandle,
                                     CHAR(2)   dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <br>
      <table $(contentTable)>
          <tr><th class="colhdr">Invoice<br>Number</th>
              <th class="colhdr">Invoice<br>Date</th>
              <th class="colhdr">Salesman<br>Number</th>
              <th class="colhdr">Salesman<br>Name</th>
              <th class="colhdr">Order<br>Number</th>
              <th class="colhdr">Order<br>Date</th>
          </tr>

          %ROW{
              %INCLUDE "SetRowClass.icl"

              @Check_Invoice(profileHandle, dataBaseID, V_ARAIV#, V_ARBLTO, invoiceFound)

              @dtw_assign(invoiceDate, V_ARIVDT)
              @Format_Date(V_ARIVDT, "D", F_ARIVDT)
              @Format_Date(V_ARORDT, "D", F_ARORDT)
              @RtvFldDesc("SMSLSM=$(V_ARSLSM)", "HDSLSM", "SMSNA1", V_SMSNA1)

              <tr class="$(rowClass)">
                  %if (invoiceFound == "Y")
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)SelectInvoice.d2w/DISPLAY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(V_ARBLTO)&amp;invoiceNumber=@dtw_rurlescseq(V_ARAIV#)&amp;invoiceDate=@dtw_rurlescseq(invoiceDate)&amp;formatToPrint=Y" onclick="$(invoiceWinVar)" title="Invoice Quickview">$(V_ARAIV#)</a></td>
                  %else
                      <td class="colnmbr">$(V_ARAIV#)</td>
                  %endif
                  <td class="coldate"><a href="$(homeURL)$(cGIPath)ARInvoiceInquiry.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;glJrnl=@dtw_rurlescseq(V_ARJRNL)&amp;customerNumber=@dtw_rurlescseq(V_ARBLTO)&amp;invoiceSequence=@dtw_rurlescseq(V_ARISEQ)&amp;glDDSeq=@dtw_rurlescseq(glDDSeq)&amp;glDDFile=@dtw_rurlescseq(glDDFile)&amp;noMenu=Y" title="View A/R Invoice">$(F_ARIVDT)</a></td>
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)SalesmanInquiry.d2w/DISPLAY$(genericVarBase)&amp;salesmanNumber=@dtw_rurlescseq(V_ARSLSM)" onclick="$(inquiryWinVar)" title="Salesman Quickview">$(V_ARSLSM)</a></td>
                  <td class="colalph">$(V_SMSNA1)</td>
                  @RtvFldDesc("(HHBLTO=$(customerNumber) or HHSHTO=$(customerNumber)) and HHLIV#=$(V_ARAIV#)", "OEORHH", "Char(Count(*))", recordsHave)
                  %if (recordsHave>"0")
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)CustomerOrderHistory.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;arInvoiceNumber=@dtw_rurlescseq(V_ARAIV#)&amp;noMenu=Y" onclick="$(drillDownWinVar)" title="View Customer Order History">$(V_ARORD#)</a></td>
                  %else
                      <td class="colnmbr">$(V_ARORD#)</td>
                  %endif
                  <td class="coldate">$(F_ARORDT) </td>
              </tr>
          %}
      </table>
      <br>
  %}
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64) profileHandle,
                                   CHAR(2)   dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST name="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Co</th>
                      <th class="colhdr">Fac</th>
                      <th class="colhdr">Name</th>
                      <th class="colhdr">Account</th>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">Amount</th>
                  </tr>
                  <tr>
                      <td><input type="text" class="inputnmbr" name="srchCo" size="2" maxlength="2">
                          <input type="hidden" name="operCo" value="=">
                      </td>
                      <td><input type="text" class="inputnmbr" name="srchFac" size="4" maxlength="4">
                          <input type="hidden" name="operFac" value="=">
                      </td>
                      <td><input type="text" class="inputalph" name="srchCoFacName" size="10" maxlength="30">
                          <input type="hidden" name="operCoFacName" value="LIKE">
                      </td>
                      <td><input type="text" class="inputnmbr" name="srchAcct" size="4" maxlength="4">
                          <input type="text" class="inputnmbr" name="srchSub" size="4" maxlength="4">
                          <input type="hidden" name="operAcct" value="=">
                      </td>
                      <td><input type="text" class="inputalph" name="srchAcctDesc" size="10" maxlength="30">
                          <input type="hidden" name="operAcctDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputnmbr" name="srchAmt" size="15" maxlength="15">
                          <input type="hidden" name="operAmt" value="=">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchCo.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("typeDescU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Type" title="Sequence By Type, Company/Facility, Account"> Type</a></th>
              @OrderBy_Sort("ARCO", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CoFac" title="Sequence By Company/Facility, Account"> Co/Fac</a></th>
              @OrderBy_Sort("CFCFNMU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CoFacName" title="Sequence By Name, Company/Facility, Account">Name</a></th>
              @OrderBy_Sort("ARACCT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Account" title="Sequence By Account, Company/Facility"> Account</a></th>
              @OrderBy_Sort("CHCHDSU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=AccountDesc" title="Sequence By Description, Account, Company/Facility">Description</a></th>
              @OrderBy_Sort("ARAMT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Amount" title="Sequence By Amount, Company/Facility, Account"> Amount</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{

              %INCLUDE "SetRowClass.icl"

              @Format_Acct("$(V_ARACCT)", "$(V_ARSUB)", "", F_AcctSub)
              @Format_Nbr($(V_ARAMT), F_ARAMT, "2", $(amtEditCode), "Y", "", "")
              @Format_CoFac("$(V_ARCO)", "$(V_ARFAC)", "", F_CoFac)
              <tr class="$(rowClass)">
                  <td class="colalph">$(V_typeDesc)</td>
                  <td class="colnmbr">$(F_CoFac)</td>
                  <td class="colalph">$(V_CFCFNM)</td>
                  <td class="colnmbr">$(F_AcctSub)</td>
                  <td class="colalph">$(V_CHCHDS)</td>
                  <td class="colnmbr">$(F_ARAMT)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(inquiryhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint == "Y")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "typeDescU,ARCO,ARFAC,ARACCT,ARSUB")
          @DTW_ASSIGN(orderByDisplay, "Type")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Type")
      %if (orderBy == "typeDescU,ARCO,ARFAC,ARACCT,ARSUB")
          @DTW_ASSIGN(orderBy, "typeDescU DESC,ARCO,ARFAC,ARACCT,ARSUB")
          @DTW_ASSIGN(orderByDisplay, "Type (descending), Company/Facility, Account")
      %else
          @DTW_ASSIGN(orderBy, "typeDescU,ARCO,ARFAC,ARACCT,ARSUB")
          @DTW_ASSIGN(orderByDisplay, "Type, Company/Facility, Account")
      %endif
  %elseif (sequence == "CoFac")
      %if (orderBy == "ARCO,ARFAC,ARACCT,ARSUB")
          @DTW_ASSIGN(orderBy, "ARCO DESC,ARFAC DESC,ARACCT,ARSUB")
          @DTW_ASSIGN(orderByDisplay, "Company/Facility (descending), Account")
      %else
          @DTW_ASSIGN(orderBy, "ARCO,ARFAC,ARACCT,ARSUB")
          @DTW_ASSIGN(orderByDisplay, "Company/Facility, Account")
      %endif
  %elseif (sequence == "CoFacName")
      %if (orderBy == "CFCFNMU,ARCO,ARFAC,ARACCT,ARSUB")
          @DTW_ASSIGN(orderBy, "CFCFNMU DESC,ARCO,ARFAC,ARACCT,ARSUB")
          @DTW_ASSIGN(orderByDisplay, "Name (descending), Company/Facility, Account")
      %else
          @DTW_ASSIGN(orderBy, "CFCFNMU,ARCO,ARFAC,ARACCT,ARSUB")
          @DTW_ASSIGN(orderByDisplay, "Name, Company/Facility, Account")
      %endif
  %elseif (sequence == "Account")
      %if (orderBy == "ARACCT,ARSUB,ARCO,ARFAC")
          @DTW_ASSIGN(orderBy, "ARACCT DESC,ARSUB DESC,ARCO,ARFAC")
          @DTW_ASSIGN(orderByDisplay, "Account (descending), Company/Facility")
      %else
          @DTW_ASSIGN(orderBy, "ARACCT,ARSUB,ARCO,ARFAC")
          @DTW_ASSIGN(orderByDisplay, "Account, Company/Facility")
      %endif
  %elseif (sequence == "AccountDesc")
      %if (orderBy == "CHCHDSU,ARACCT,ARSUB,ARCO,ARFAC")
          @DTW_ASSIGN(orderBy, "CHCHDSU DESC,ARACCT,ARSUB,ARCO,ARFAC")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Account, Company/Facility")
      %else
          @DTW_ASSIGN(orderBy, "CHCHDSU,ARACCT,ARSUB,ARCO,ARFAC")
          @DTW_ASSIGN(orderByDisplay, "Description, Account, Company/Facility")
      %endif
  %elseif (sequence == "Amount")
      %if (orderBy == "ARAMT,ARCO,ARFAC,ARACCT,ARSUB")
          @DTW_ASSIGN(orderBy, "ARAMT DESC,ARCO,ARFAC,ARACCT,ARSUB")
          @DTW_ASSIGN(orderByDisplay, "Amount (descending), Company/Facility, Account")
      %else
          @DTW_ASSIGN(orderBy, "ARAMT,ARCO,ARFAC,ARACCT,ARSUB")
          @DTW_ASSIGN(orderByDisplay, "Amount, Company/Facility, Account")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <link rel=stylesheet type="text/css" href="$(homeURL)$(homePath)$(GLDDStyleSheet)">
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchCo, 2, 0) &&
                      editNum(document.Search.srchFac, 4, 0) &&
                      editNum(document.Search.srchAcct, 4, 0) &&
                      editNum(document.Search.srchSub, 4, 0) &&
                      editNum(document.Search.srchAmt, 13, 2))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      %INCLUDE "SearchPageTitle.icl"
                      $(inquiryhrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Type</td>
                              @dtw_assign(operNbr, "operType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchType" size="10" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Company</td>
                              @dtw_assign(operNbr, "operCo")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchCo" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Facility</td>
                              @dtw_assign(operNbr, "operFac")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchFac" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Name</td>
                              @dtw_assign(operNbr, "operCoFacName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCoFacName" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Account</td>
                              @dtw_assign(operNbr, "operAcct")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchAcct" size="4" maxlength="4"><input type="text" name="srchSub" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operAcctDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchAcctDesc" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Amount</td>
                              @dtw_assign(operNbr, "operAmt")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchAmt" size="15" maxlength="15"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchType.focus();
                          </script>
                      </form>
                      $(inquiryhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("upper(d.FLDESC)", "Type", $(srchType), "U", $(operType), "A")
  @Build_WildCard ("ARCO", "Company", $(srchCo), "", $(operCo), "N")
  @Build_WildCard ("ARFAC", "Facility", $(srchFac), "", $(operFac), "N")
  @Build_WildCard ("CFCFNMU", "Name", $(srchCoFacName), "U", $(operCoFacName), "A")
  @Build_WildCard ("CHCHDSU", "Description", $(srchAcctDesc), "U", $(operAcctDesc), "A")
  @Build_WildCard ("ARAMT", "Amount", $(srchAmt), "", $(operAmt), "N")
  @Build_WildCard_Acct ("ARACCT", "ARSUB", "Account", $(srchAcct), $(srchSub), $(operAcct))

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
