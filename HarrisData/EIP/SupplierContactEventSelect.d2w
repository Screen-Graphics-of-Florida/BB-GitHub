*  Job: Supplier Contact Event Select                               *
*********************************************************************
%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Supplier Contact Event"
  d2wName                 = "SupplierContactEventSelect.d2w"
  attachFolder            = "SupplierContactEvent"
  d2wVarBase              = "$(genericVarBase)&amp;contactNumber=@dtw_rurlescseq(contactNumber)&amp;vendorNumber=@dtw_rurlescseq(vendorNumber)&amp;vendorName=@dtw_rurlescseq(vendorName)&amp;eventSequence=@dtw_rurlescseq(eventSequence)"
  programName             = "HSRCEM_E"
  fileName                = "SRCEVU"	
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "1000"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
  contactVendor           = ""	
  evtsec_01               = ""	
  evtsec_02               = ""	
  evtsec_03               = ""	
  saveOrigSeq             = "0"	
  quickLinkByUser         = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "SUPPCONTEVENTSELECT")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                      <td class="content">

%{ QuickLink Table %}     %INCLUDE "QuickLinkTable.icl"

%{ QuickLink By User %}   %INCLUDE "QuickLinkByUser.icl"

%{ Selected Event %}
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " SRCEVM ", fileSQL)
                          @dtw_concat(selectSQL, "RMCONT=$(contactNumber) and RMESEQ=$(eventSequence) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                          @Contact_Event_Selected(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Begin %}     %INCLUDE "QuickLinkBegLoop.icl"

        %{ Related Event %}
                              %if (quicklinkRef == "relatedevents")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " SRCEVM ", fileSQL)
                                  @dtw_concat(selectSQL, "RMCONT=$(contactNumber) ", selectSQL)
                                  %if (saveOrigSeq == "0")
                                      @dtw_concat(selectSQL, " and RMOSEQ=$(eventSequence) ", selectSQL)
                                  %else
                                      @dtw_concat(selectSQL, " and RMESEQ=$(saveOrigSeq) ", selectSQL)
                                  %endif
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_concat(stmtSQL, " Order By RMEVTD desc, RMEVNT ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Contact_Event_Related(profileHandle, dataBaseID, stmtSQL)

        %{ Contact Information %}
                              %elif (quicklinkRef == "contactinformation")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " SRCNTM ", fileSQL)
                                  @dtw_concat(selectSQL, "SRCONT=$(contactNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Contact_Event_ContactInfo(profileHandle, dataBaseID, stmtSQL)

        %{ Vendor Information %}
	   		       %elif (quicklinkRef == "vendorinformation" && contactVendor != "0")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT VMVNA1, VMVCTY, VMST, VMZIP, VMVEND", stmtSQL)
                                  @dtw_concat(fileSQL, " HDVEND ", fileSQL)
                                  @dtw_concat(selectSQL, "VMVEND=$(contactVendor) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Contact_Event_VendorInfo(profileHandle, dataBaseID, stmtSQL)

        %{ Related Contacts %}
	   		       %elif (quicklinkRef == "relatedcontacts" && contactVendor != "0")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                                  @dtw_concat(fileSQL, " SRCNTM ", fileSQL)
                                  @dtw_concat(selectSQL, "SRCONT<>$(contactNumber) and SRVEND=$(contactVendor) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Contact_Event_Related_Contacts(profileHandle, dataBaseID, stmtSQL)
	   		       %endif

        %{ Attachments %}     %INCLUDE "AttachmentSQL.icl"

%{ Quicklink End %}       %INCLUDE "QuickLinkEndLoop.icl"

                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Contact_Event_Selected (IN CHAR(64) profileHandle,
				               CHAR(2)   dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %ROW {
          @pgmOptSecurity(profileHandle, dataBaseID, programName, evtsec_01, evtsec_02, evtsec_03, evtsec_04, evtsec_05, evtsec_06, evtsec_07, evtsec_08, evtsec_09, evtsec_10, evtsec_11, evtsec_12, evtsec_13, evtsec_14, evtsec_15)
          @RtvSuppCont(profileHandle, dataBaseID, contactNumber, lastName, firstName, salutation, companyName)
          @Format_EmplName(firstName, lastName, "", "", "", "H", F_Name)
          @RtvFldDesc("ECFILN='$(fileName)' and ECEVNT='$(V_RMEVNT)' ", "SYEVNT", "ECDESC", eventDesc)
          @UserDefined_Query(profileHandle, dataBaseID, "SRCEVU    ", V_RMEVNT, userDefinedTable)	
          @dtw_assign(contactNumberFilled, $(contactNumber))
          %while(@dtw_rlength(contactNumberFilled) != "7") {@dtw_insert("0", contactNumberFilled, contactNumberFilled)%}
          @dtw_assign(eventSequenceFilled, $(eventSequence))
          %while(@dtw_rlength(eventSequenceFilled) != "7") {@dtw_insert("0", eventSequenceFilled, eventSequenceFilled)%}
          @dtw_assign(attachVarKey, "$(contactNumberFilled)$(V_RMEVNT)$(eventSequenceFilled)")
          @dtw_assign(attachForDesc, "$(F_Name) - $(eventDesc)")
          @dtw_assign(attachPrg1, "SRCEVM Where RMCONT=$(contactNumber) and RMESEQ=$(eventSequence)")

          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          <a href="$(homeURL)$(cGIPath)SupplierContactEvent.d2w/REPORT$(d2wVarBase)&amp;confMessage=" title="Return To Contact Events">$(portalHome)</a>
                          %INCLUDE "Attachment.icl"
                          %if (contactNumber <= "0")
                              @dtw_assign(vendCustNumber, $(vendorNumber))
                              @dtw_assign(vendCustName, $(vendorName))
                          %endif
                          %if (evtsec_01 == "Y")
                              <a href="$(homeURL)$(cGIPath)EventCodeSelection.d2w/REPORT$(genericVarBase)&amp;fileName=@dtw_rurlescseq(fileName)&amp;contactNumber=@dtw_rurlescseq(contactNumber)&amp;vendCustNumber=@dtw_rurlescseq(vendCustNumber)&amp;vendCustName=@dtw_rurlescseq(vendCustName)&amp;fromContactNumber=@dtw_rurlescseq(contactNumber)&amp;origSequence=0&amp;fromD2w=@dtw_rurlescseq(d2wName)" onclick="$(searchWinVar)">$(addEventImageLrg)</a>
                          %endif
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
          </table>
          <table $(contentTable)>
              @Format_Header_URL("Contact", "$(firstName) $(lastName)", $(contactNumber), "$(homeURL)$(cGIPath)SupplierContactSelect.d2w/REPORT$(d2wVarBase)")
          </table>
          %INCLUDE "ConfMessageDisplay.icl"

          $(hrTagAttr)
          %INCLUDE "QuickLinkDisplay.icl"

          <fieldset class="legendBody">
              <legend class="legendTitle">Selected Event</legend>
              %if (formatToPrint != "Y")
                  <table $(contentTable)>
                      <tr>
                          <td>
                              %if (evtsec_02 == "Y" || evtsec_03 == "Y")
                                  <a href="$(homeURL)$(cGIPath)SupplierContactEventMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;eventCode=@dtw_rurlescseq(V_RMEVNT)&amp;fromContactNumber=@dtw_rurlescseq(contactNumber)&amp;fromD2w=&amp;maintenanceCode=C">$(changeImageSml)</a>
                              %endif
                              %if (evtsec_01 == "Y")
                                  <a href="$(homeURL)$(cGIPath)EventCodeSelection.d2w/REPORT$(genericVarBase)&amp;fileName=@dtw_rurlescseq(fileName)&amp;contactNumber=@dtw_rurlescseq(contactNumber)&amp;vendCustNumber=@dtw_rurlescseq(vendCustNumber)&amp;vendCustName=@dtw_rurlescseq(vendCustName)&amp;fromContactNumber=@dtw_rurlescseq(contactNumber)&amp;origSequence=@dtw_rurlescseq(eventSequence)&amp;fromD2w=@dtw_rurlescseq(d2wName)" onclick="$(searchWinVar)">$(addEventImageSml)</a>
                              %endif
                          </td>
                      </tr>
                  </table>
              %endif
              <table $(contentTable)>

              @dtw_assign(saveOrigSeq, V_RMOSEQ)
              @retrieveUserRole(profileHandle, dataBaseID, V_RMUSER, userCustomer, userVendor, userSalesman, userBadge, userCatalog, newsLink, profileName)

              <tr>
                  @RtvFldDesc("ECFILN='$(fileName)' and ECEVNT='$(V_RMEVNT)' ", "SYEVNT", "ECDESC", eventDesc)
                  @Format_Code(V_RMEVNT, F_RMEVNT)
                  <td class="dsphdr">Event</td>
                  <td class="dspalph">$(eventDesc)</td>
                  <td class="dspalph">$(F_RMEVNT)</td>
              </tr>
              <tr>
                  <td class="dsphdr">Description</td>
                  <td class="dspalph">$(V_RMDESC)</td>
              </tr>
              <tr>
                  @Format_Code(V_RMUSER, F_RMUSER)
                  <td class="dsphdr">User Profile</td>
                  <td class="dspalph">$(profileName)</td>
                  <td class="dspalph">$(F_RMUSER)</td>
              </tr>
              <tr>
                  @Date_FromISO_ToCYMD(V_RMEVTD, F_CYMD)
                  @Format_Date(F_CYMD, "H", F_RMEVTD)
                  <td class="dsphdr">Event Date</td>
                  @dtw_assign(calYear, @dtw_rsubstr(V_RMEVTD, "1", "4"))
                  @dtw_assign(calMonth, @dtw_rsubstr(V_RMEVTD, "6", "2"))
                  <td class="dspalph"><a href="$(homeURL)$(cGIPath)EventCalendarSelect.d2w/Edit_Data$(genericVarBase)&amp;calYear=@dtw_rurlescseq(calYear)&amp;calMonth=@dtw_rurlescseq(calMonth)&amp;calWeek=0&amp;calView=M&amp;reload=Y&amp;user=@dtw_rurlescseq(V_RMUSER)&amp;dspSupplier=CHECKED&amp;dspOpen=CHECKED&amp;dspTime=CHECKED&amp;dspCompleted=CHECKED" title="View Calendar">$(F_RMEVTD)</a></td>
              </tr>
              <tr>
                  @EditHrsMinSec(V_RMEVTT)
                  <td class="dsphdr">Event Time</td>
                  <td class="dspalph">$(V_RMEVTT)</td>
              </tr>
              <tr>
                  @Date_FromISO_ToCYMD(V_RMCMPD, F_CYMD)
                  @Format_Date(F_CYMD, "H", F_RMCMPD)
                  <td class="dsphdr">Completion Date</td>
                  <td class="dspalph">$(F_RMCMPD)</td>
              </tr>
      %}

              @dtw_tb_rows(userDefinedTable, userMaxRows)
              @dtw_assign(ux, "1")
              %while(ux <= userMaxRows){
                  %INCLUDE "UserDefined.icl"
                  @dtw_tb_rows(suppContactEventTable, maxRows)
                  @dtw_assign(x, "1")
                  %while((@dtw_tb_rgetv(suppContactEventTable, x, @dtw_tb_rQuerycolnonj(suppContactEventTable, "RUFLDN")) != V_UFFLDN) && (x <= maxRows))
                      {@dtw_add(x, "1", x)%}
                  %if (x <=maxRows)
                      @dtw_tb_getv(suppContactEventTable, x, @dtw_tb_rQuerycolnonj(suppContactEventTable, "RUFLDD"), V_RUFLDD)
                      @dtw_tb_getv(suppContactEventTable, x, @dtw_tb_rQuerycolnonj(suppContactEventTable, "RUFLDV"), V_RUFLDV)
                      @dtw_tb_getv(suppContactEventTable, x, @dtw_tb_rQuerycolnonj(suppContactEventTable, "RUFLDR"), V_RUFLDR)
                  %else
                      @dtw_assign(V_RUFLDD, "")
                      @dtw_assign(V_RUFLDV, "")
                      @dtw_assign(V_RUFLDR, "")
                  %endif

        	       <tr><td class="dsphdr">$(V_UFDESC)</td>
                      %if (V_UFTYPE == "A")
                          %if (V_UFFFMT == "U")
                              <td class="dspalph"><a href="$(V_RUFLDV)" target=_blank>$(V_RUFLDV)</a></td>
                          %elif (V_UFFFMT == "E")
                              <td class="dspalph"><a href="mailto:$(V_RUFLDV)" target=_blank title="Click here to send e-mail">$(V_RUFLDV)</a></td>
                          %else
                              <td class="dspalph">$(V_RUFLDV)
                          %endif
                      %elif (V_UFTYPE == "C")
                          %if (formatToPrint != "Y")
                              <td colspan="3"><textarea name="$(V_UFFLDN)" readonly ROWS=$(V_UFBOXS) COLS=60 >$(V_RUFLDV)</textarea>
                          %else
                              @dtw_chartohex(V_RUFLDV, hexValue)
                              @dtw_length(hexValue, fldLength)
                              @dtw_assign(printRows, "1")
                              @dtw_assign(x, "1")
                              %while(x <= fldLength){
                                  @dtw_pos("0D25", hexValue, x, y)
                                  %if (y > "0")
                                      @dtw_add(printRows, "1", printRows)
                                      @dtw_add(y, "4", x)
                                  %else
                                      @dtw_add(fldLength, "1", x)
                                  %endif
                              %}
                              <td colspan="3"><textarea name="$(V_UFFLDN)" readonly ROWS=$(printRows) COLS=60 >$(V_RUFLDV)</textarea>
                          %endif
                      %elif (V_UFTYPE == "N")
                          @dtw_add(V_UFSIZE, V_UFDECM, V_UFSIZE)
                          %if (V_UFDECM != "0")
                              @dtw_add(V_UFSIZE, "2", V_UFSIZE)
                          %endif
                          @dtw_assign(Precision, @dtw_radd(V_UFSIZE, V_UFDECM))
                          @dtw_format(V_RUFLDR, V_UFSIZE, V_UFDECM, "", "", Precision, V_RUFLDR)
                          %if (V_UFFFMT == "P")
                              @EditPhoneNumber(V_RUFLDR)
                          %endif
                          <td class="dspnmbr">$(V_RUFLDR)
                      %elif (V_UFTYPE == "D")
                          @Date_FromISO_ToCYMD(V_RUFLDD, F_CYMD)
                          @Format_Date(F_CYMD, "H", F_RUFLDD)
                          <td class="inputnmbr">$(F_RUFLDD)
                      %endif
                  </td></tr>
                  @dtw_add(ux, "1", ux)
              %}
          </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Contact_Event_Related (IN CHAR(64)    profileHandle,
				              CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
          <a name="relatedevents"></a>
          @dtw_assign(moreURL, "")
          %INCLUDE "QuickLinkTopOfForm.icl"

          <table $(contentTable)>
              %if (sql_Record_Count == "0")
                  %INCLUDE "QuickLinkNoInfoMsg.icl"
              %else
                  <tr>
                      %if (formatToPrint != "Y" && evtsec_01 == "Y")
                          <th class="colhdr">$(optionHeading)</th>
                      %endif
                      <th class="colhdr">Event<br>Code</th>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">User Profile</th>
                      <th class="colhdr">Event<br>Date</th>
                      <th class="colhdr">Event<br>Time</th>
                      <th class="colhdr">Completion<br>Date</th>
                      <th>&nbsp; &nbsp; &nbsp; &nbsp;</th>
                  </tr>
              %endif

              %ROW {
                  %INCLUDE "SetRowClass.icl"
                  @Date_FromISO_ToCYMD(V_RMEVTD, F_CYMD)
                  @Format_Date(F_CYMD, "D", F_RMEVTD)
                  @EditHrsMinSec(V_RMEVTT)
                  @Date_FromISO_ToCYMD(V_RMCMPD, F_CYMD)
                  @Format_Date(F_CYMD, "D", F_RMCMPD)

                  @retrieveUserRole(profileHandle, dataBaseID, V_RMUSER, userCustomer, userVendor, userSalesman, userBadge, userCatalog, newsLink, profileName)
                  @RtvFldDesc("ECFILN='$(fileName)' and ECEVNT='$(V_RMEVNT)' ", "SYEVNT", "ECDESC", eventDesc)

                  <tr class="$(rowClass)">
                      %if (formatToPrint != "Y" && (evtsec_01 == "Y" || evtsec_02 == "Y" || evtsec_03 == "Y"))
                          <td class="opticon">
                              %if (evtsec_02 == "Y" || evtsec_03 == "Y")
                                  <a href="$(homeURL)$(cGIPath)SupplierContactEventMaintain.d2w/MAINTAIN$(genericVarBase)&amp;contactNumber=@dtw_rurlescseq(contactNumber)&amp;vendorNumber=@dtw_rurlescseq(vendorNumber)&amp;vendorName=@dtw_rurlescseq(vendorName)&amp;eventSequence=@dtw_rurlescseq(V_RMESEQ)&amp;eventCode=@dtw_rurlescseq(V_RMEVNT)&amp;fromContactNumber=@dtw_rurlescseq(contactNumber)&amp;fromD2w=&amp;maintenanceCode=C">$(changeImageSml)</a>
                              %endif
                              %if (evtsec_01 == "Y")
                                  <a href="$(homeURL)$(cGIPath)EventCodeSelection.d2w/REPORT$(genericVarBase)&amp;fileName=@dtw_rurlescseq(fileName)&amp;contactNumber=@dtw_rurlescseq(contactNumber)&amp;vendCustNumber=@dtw_rurlescseq(vendCustNumber)&amp;vendCustName=@dtw_rurlescseq(vendCustName)&amp;fromContactNumber=@dtw_rurlescseq(contactNumber)&amp;origSequence=@dtw_rurlescseq(V_RMESEQ)&amp;fromD2w=@dtw_rurlescseq(d2wName)" onclick="$(searchWinVar)">$(addEventImageSml)</a>
                              %endif
                          </td>
                      %endif
                      %if (contactNumber == "0")
                          <td class="colnmbr">$(V_RMCONT)</td>                                      	
                      %endif
                      <td class="colalph" $(helpCursor)><span title="$(eventDesc)">$(V_RMEVNT)</span></td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(genericVarBase)&amp;contactNumber=@dtw_rurlescseq(contactNumber)&amp;vendorNumber=@dtw_rurlescseq(vendorNumber)&amp;vendorName=@dtw_rurlescseq(vendorName)&amp;eventSequence=@dtw_rurlescseq(V_RMESEQ)&amp;eventCode=@dtw_rurlescseq(V_RMEVNT)" title="View Event">$(V_RMDESC)</a></td>
                      <td class="colalph" $(helpCursor)><span title="$(profileName)">$(V_RMUSER)</span></td>
                      @dtw_assign(calYear, @dtw_rsubstr(V_RMEVTD, "1", "4"))
                      @dtw_assign(calMonth, @dtw_rsubstr(V_RMEVTD, "6", "2"))
                      <td class="coldate"><a href="$(homeURL)$(cGIPath)EventCalendarSelect.d2w/Edit_Data$(genericVarBase)&amp;calYear=@dtw_rurlescseq(calYear)&amp;calMonth=@dtw_rurlescseq(calMonth)&amp;calWeek=0&amp;calView=M&amp;reload=Y&amp;user=@dtw_rurlescseq(V_RMUSER)&amp;dspSupplier=CHECKED&amp;dspOpen=CHECKED&amp;dspTime=CHECKED&amp;dspCompleted=CHECKED" title="View Calendar">$(F_RMEVTD)</a></td>
                      <td class="colcode">$(V_RMEVTT)</td>
                      <td class="coldate">$(F_RMCMPD)</td>
                  </tr>
              %}
          </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Contact_Event_ContactInfo (IN CHAR(64) profileHandle,
				                  CHAR(2)   dataBaseID,
                                                 CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="contactinformation"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      @UserDefined_Query(profileHandle, dataBaseID, "SRCNTU    ", "          ", userDefinedTable)	
      @SupplierContactUser_Query(profileHandle, dataBaseID, contactNumber, suppContactUserTable)	
      <table $(contentTable)>
          <colgroup>
              <col width="5%">
              <col width="60%">
              <col width="20%">
          %ROW {
              @Format_EmplName(V_SRFNAM, V_SRLNAM, "", "", "", "H", F_Name)
              <tr><td>&nbsp;</td>
                  <td rowspan="7" class="dspalph">
                       %if (V_SRCNAM != "")
                           $(V_SRCNAM) <br>
                       %endif
                       $(F_Name)<br>
                       %if (V_SRTITL != "")
                           $(V_SRTITL) <br>
                       %endif
                       %if (V_SRADR1 != "")
                           $(V_SRADR1) <br>
                       %endif
                       %if (V_SRADR2 != "")
                           $(V_SRADR2) <br>
                       %endif
                       %if (V_SRADR3 != "")
                           $(V_SRADR3) <br>
                       %endif
                       $(V_SRCITY), $(V_SRST) $(V_SRZIP)
                  </td>
              </tr>
              <tr><td>&nbsp;</td>
                  <td class="dsphdr">Contact Number</td>
                  <td class="dspnmbr">$(V_SRCONT)</td>
              </tr>

              <tr><td>&nbsp;</td>
                  @Date_FromISO_ToCYMD(V_SRDATI, F_CYMD)
                  @Format_Date(F_CYMD, "H", F_SRDATI)
                  <td class="dsphdr">Date Inactive</td>
                  <td class="dspalph">$(F_SRDATI)</td>
              </tr>

              <tr>
                  <td>&nbsp;</td>
                  <td class="dsphdr">Last Updated</td>
                  <td class="dspalph">$(V_SRTSTP)</td>
              </tr>
              <tr><td>&nbsp;</td></tr>
              <tr><td>&nbsp;</td></tr>
              <tr><td>&nbsp;</td></tr>
          %}
      </table>
      <table $(contentTable)>
          @dtw_tb_rows(userDefinedTable, userMaxRows)
          @dtw_assign(ux, "1")
          %while(ux <= userMaxRows){
              %INCLUDE "UserDefined.icl"
              @dtw_tb_rows(suppContactUserTable, maxRows)
              @dtw_assign(x, "1")
              %while((@dtw_tb_rgetv(suppContactUserTable, x, @dtw_tb_rQuerycolnonj(suppContactUserTable, "SUFLDN")) != V_UFFLDN) && (x <= maxRows))
                  {@dtw_add(x, "1", x)%}
              %if (x <=maxRows)
                  @dtw_tb_getv(suppContactUserTable, x, @dtw_tb_rQuerycolnonj(suppContactUserTable, "SUFLDD"), V_SUFLDD)
                  @dtw_tb_getv(suppContactUserTable, x, @dtw_tb_rQuerycolnonj(suppContactUserTable, "SUFLDV"), V_SUFLDV)
                  @dtw_tb_getv(suppContactUserTable, x, @dtw_tb_rQuerycolnonj(suppContactUserTable, "SUFLDR"), V_SUFLDR)
              %else
                  @dtw_assign(V_SUFLDD, "")
                  @dtw_assign(V_SUFLDV, "")
                  @dtw_assign(V_SUFLDR, "")
              %endif

    	       <tr><td class="dsphdr">$(V_UFDESC)</td>
                  %if (V_UFTYPE == "A")
                      %if (V_UFFFMT == "U")
                          <td class="dspalph"><a href="$(V_SUFLDV)" target=_blank>$(V_SUFLDV)</a></td>
                      %elif (V_UFFFMT == "E")
                          <td class="dspalph"><a href="mailto:$(V_SUFLDV)" target=_blank title="Click here to send e-mail">$(V_SUFLDV)</a></td>
                      %else
                          <td class="dspalph">$(V_SUFLDV)
                      %endif
                  %elif (V_UFTYPE == "C")
                      %if (formatToPrint != "Y")
                          <td><textarea name="$(V_UFFLDN)" readonly ROWS=$(V_UFBOXS) COLS=60>$(V_SUFLDV)</textarea>
                      %else
                          @dtw_chartohex(V_SUFLDV, hexValue)
                          @dtw_length(hexValue, fldLength)
                          @dtw_assign(printRows, "1")
                          @dtw_assign(x, "1")
                          %while(x <= fldLength){
                              @dtw_pos("0D25", hexValue, x, y)
                              %if (y > "0")
                                  @dtw_add(printRows, "1", printRows)
                                  @dtw_add(y, "4", x)
                              %else
                                  @dtw_add(fldLength, "1", x)
                              %endif
                          %}
                          <td><textarea name="$(V_UFFLDN)" readonly ROWS=$(printRows) COLS=60>$(V_SUFLDV)</textarea>
                      %endif
                  %elif (V_UFTYPE == "N")
                      @dtw_add(V_UFSIZE, V_UFDECM, V_UFSIZE)
                      %if (V_UFDECM != "0")
                          @dtw_add(V_UFSIZE, "2", V_UFSIZE)
                      %endif
                      @dtw_assign(Precision, @dtw_radd(V_UFSIZE, V_UFDECM))
                      @dtw_format(V_SUFLDR, V_UFSIZE, V_UFDECM, "", "", Precision, V_SUFLDR)
                      %if (V_UFFFMT == "P")
                          @EditPhoneNumber(V_SUFLDR)
                      %endif
                      <td class="dspnmbr">$(V_SUFLDR)
                  %elif (V_UFTYPE == "D")
                      @Date_FromISO_ToCYMD(V_SUFLDD, F_CYMD)
                      @Format_Date(F_CYMD, "H", F_SUFLDD)
                      <td class="inputnmbr">$(F_SUFLDD)
                  %endif
              </td></tr>
              @dtw_add(ux, "1", ux)
          %}
      </table>
      </fieldset>	
  %}
%}

%FUNCTION(dtw_sql) Contact_Event_VendorInfo (IN CHAR(64) profileHandle,
				                 CHAR(2)   dataBaseID,
                                                CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="vendorinformation"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"
      	
      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <colgroup>
                  <col width="10%">
                  <col width="50%">
                  <col width="40%">
              </colgroup>
          	
              <tr><th class="colhdr">Number</th>
                  <th class="colhdr">Vendor </th>
                  <th class="colhdr">Location</th>
              </tr>
          %endif

          %ROW {
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_VMVEND)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)VendorSelect.d2w/REPORT?baseVar=@dtw_rurlescseq(baseVar)&amp;eID=@dtw_rurlescseq(eID)&amp;portal=VENDOR&amp;vendorNumber=@dtw_rurlescseq(V_VMVEND)&amp;vendorName=@dtw_rurlescseq(V_VMVNA1)" title="View Related Entity">$(V_VMVNA1)</a></td>
                  <td class="colalph">$(V_VMVCTY), $(V_VMST) $(V_VMZIP)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Contact_Event_Related_Contacts (IN CHAR(64)    profileHandle,
				                       CHAR(2)     dataBaseID,
                                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="relatedcontacts"></a>
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <colgroup>
                  <col width="5%">
                  <col width="10%">
                  <col width="35%">
                  <col width="10%">
                  <col width="25%">

              <tr><th class="colhdr">Number</th>
                  <th class="colhdr">Contact</th>
                  <th class="colhdr">Company</th>
                  <th class="colhdr">Title</th>
                  <th class="colhdr">Location</th>
              </tr>
          %endif

          %ROW {
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_SRCONT)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)SupplierContactSelect.d2w/REPORT$(genericVarBase)&amp;contactNumber=@dtw_rurlescseq(V_SRCONT)" title="View Related Entity">$(V_SRFNAM) $(V_SRLNAM)</a></td>
                  <td class="colalph">$(V_SRCNAM)</td>
                  <td class="colalph">$(V_SRTITL)</td>
                  <td class="colalph">$(V_SRCITY), $(V_SRST) $(V_SRZIP)</td>
              </tr>
          %}
      </table>
      </fieldset>	
  %}
%}

%INCLUDE "AttachmentSelect.icl"

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @SuppContactEvent_Query(profileHandle, dataBaseID, contactNumber, eventSequence, suppContactEventTable)	
  @RtvFldDesc("SRCONT=$(contactNumber)", "SRCNTM", "char(SRVEND)", contactVendor)

  @Set_SQL(stmtSQL)
%}