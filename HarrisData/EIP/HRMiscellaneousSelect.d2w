%INCLUDE "$(baseVar)"
%INCLUDE "EdtVar.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title 	        = "Miscellaneous Data Select"
  d2wName              = "HRMiscellaneousSelect.d2w"
  attachFolder         = "HRMiscellaneous"
  d2wVarBase           = "$(genericVarBase)$(employeeVarBase)&amp;miscellaneousCode=@dtw_rurlescseq(miscellaneousCode)&amp;miscellaneousCodeDesc=@dtw_rurlescseq(miscellaneousCodeDesc)&amp;miscellaneousName=@dtw_rurlescseq(miscellaneousName)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(d2wName)"
  programName          = "HPEMDU"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  UVCo                 = "00"
  UVFAC                = "0000"
  UVPREmpl             = "00000"
  applicationID        = "PE"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  attachVarKey         = ""
  attachForDesc        = ""
  quickLinksInUse      = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
  @dtw_replace(workURL, "@@sequenceNumber", "@dtw_rurlescseq(sequenceNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@fromD2w", "@dtw_rurlescseq(fromD2w)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                          @dtw_assign(pageID, "EMPLMISCDISPLAY ")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          @dtw_concat(stmtSQL, "Select * From PEMISC Where MICOMP = $(hrCompany) and ", stmtSQL)
                          @dtw_concat(stmtSQL, " MIEMPL = $(hrEmployee) and MISEQ = $(sequenceNumber)", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @Empl_Miscellaneous_Display_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
    %endif
  %}

%FUNCTION(DTW_SQL) Empl_Miscellaneous_Display_Query(IN CHAR(64)    profileHandle,
                                                       CHAR(2)     dataBaseID,
                                                       CHAR(32000) stmtSQL)

{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @Ret_Format_EmplName(UVCo, UVFac, UVPREmpl, hrCompany, hrEmployee, "H", F_EmpName)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title) </h1></td>
              @dtw_assign(seqNbrFilled, "$(sequenceNumber)")
              %while(@dtw_rlength(seqNbrFilled) != "4") {@dtw_insert("0", seqNbrFilled, seqNbrFilled)%}
              @dtw_assign(attVar, "Misc_$(seqNbrFilled)")
              %INCLUDE "emplAttachment.icl"
              @dtw_assign(attachForDesc, "$(F_EmpName) Miscellaneous Seq $(sequenceNumber)")
              @dtw_assign(attachPrg1, "HREMPL inner join PEMISC on EMCOMP=MICOMP and EMFACL=MIFACL and EMEMPL=MIEMPL Where EMEMID=$(employeeID) and MISEQ=$(sequenceNumber)")
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/displaymiscellaneous") && (backHome != "") )
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Return To Employee">$(portalHome)</a>
                      %endif
                      %INCLUDE "Attachment.icl"
                      %if (sec_01 == "Y")
                          @dtw_assign(noNumber, "")
                          <a href="$(homeURL)$(cGIPath)HRMiscellaneousMaintain.d2w/REPORT$(d2wVarBase)&amp;sequenceNumber=@dtw_rurlescseq(noNumber)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (sec_01=="Y" && sec_04=="Y")
                          <a href="$(homeURL)$(cGIPath)HRMiscellaneousMaintain.d2w/REPORT$(d2wVarBase)&amp;sequenceNumber=@dtw_rurlescseq(sequenceNumber)&amp;maintenanceCode=Z">$(copyImageLrg)</a>
                      %endif
                      %if (sec_02 == "Y" || sec_03 == "Y")
                          <a href="$(homeURL)$(cGIPath)HRMiscellaneousMaintain.d2w/REPORT$(d2wVarBase)&amp;sequenceNumber=@dtw_rurlescseq(sequenceNumber)&amp;maintenanceCode=C">$(changeImageLrg)</a>
                      %endif
                      %if (sec_03 == "Y")
                          @Format_Confirm_Desc($(miscellaneousName), "", $(miscellaneousCodeDesc), $(miscellaneousCode), "", "", confirmDesc)
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)HRMiscellaneousMaintain.d2w/Edit_Data$(d2wVarBase)&amp;sequenceNumber=@dtw_rurlescseq(sequenceNumber)&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                      %endif
                      <a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;sequenceNumber=@dtw_rurlescseq(sequenceNumber)&amp;formatToPrint=Y" target=_blank>$(formatPrintDesc)</a>
                  </td>
              %endif
          </tr>
          <tr><td><h2>$(F_EmpName)</h2></td></tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"
      $(hrTagAttr)
      <table $(contentTable)>
          %ROW{
              <tr><td class="dsphdr">Sequence Number</td>
                  <td class="dspalph">$(V_MISEQ)</td>
              </tr>
              @RtvFldDesc("ODCOMP=$(hrCompany) and ODTYPE='K' and ODCODE='$(miscellaneousCode)' ", "PECODE", "ODDESC", HrCodeDesc)
              <tr><td class="dsphdr">Miscellaneous Code</td>
	   	   <td class="dspalph">$(HrCodeDesc)</td>
              </tr>
              <tr><td class="dsphdr">Miscellaneous Name</td>
                  <td class="dspnmbr">$(V_MITYPE)</td>
              </tr>

              @Format_Date(V_MIEFDT, "H", F_MIEFDT)
              <tr><td class="dsphdr">Effective Date</td>
                  <td class="dspdate">$(F_MIEFDT)</td>
              </tr>

              %if (V_MIPREM != ".00")
                  @Format_Nbr($(V_MIPREM), F_MIPREM, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Premium Amount</td>
                      <td class="dspnmbr">$(F_MIPREM)</td>
                  </tr>
              %endif
              %if (V_MIAMT != "0")
                  @Format_Nbr($(V_MIAMT), F_MIAMT, "0", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Amount</td>
                      <td class="dspnmbr">$(F_MIAMT)</td>
                  </tr>
              %endif
              %if (V_MIBENF != "")
                  <tr><td class="dsphdr">Beneficiary</td>
                      <td class="dspalph">$(V_MIBENF)</td>
                  </tr>
              %endif
              %if (V_MICMT1 != "")
                  <tr><td class="dsphdr">Comment 1</td>
                      <td class="dspalph">$(V_MICMT1)</td>
                  </tr>
              %endif
              %if (V_MICMT2 != "")
                  <tr><td class="dsphdr">Comment 2</td>
                      <td class="dspalph">$(V_MICMT2)</td>
                  </tr>
              %endif
          %}
      </table>
      %INCLUDE "AttachmentSQL.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%INCLUDE "AttachmentSelect.icl"

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
 %endif
%}