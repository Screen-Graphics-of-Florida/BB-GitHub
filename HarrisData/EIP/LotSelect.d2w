%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Lot"
  d2wName                 = "LotSelect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;lotNumber=@dtw_rurlescseq(lotNumber)&amp;fromSel=Y"
  programName             = "HIVLNM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
  quickLinkByUser         = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @LotUserView(profileHandle, dataBaseID, userPass, warehouseNumber, itemNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
                  <!-- Start Of Trailer Code -->
                  %INCLUDE "banner.icl"
                  <!-- End Of Trailer Code -->
                  <table $(baseTable)>
                      <tr valign="top">
                          %if (formatToPrint == "")
                               @dtw_assign(pageID, "LOTSELECT")
                              <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                          %endif
                          <td class="content">

%{ stockLocatorActive %}  @RtvFldDesc("IWITEM='$(itemNumber)' and IWWHS=$(warehouseNumber)", "HDIWHS", "IWSTKL", stockLocatorActive)

%{ QuickLink Table %}     %INCLUDE "QuickLinkTable.icl"

                          %if (stockLocatorActive != "Y" )
                              @Remove_Quick_Link("stocklocations")
                          %endif

                          %if ($(V_CILUS1)=="" && $(V_CILUS2)=="" && $(V_CILUS3)=="")
                              @Remove_Quick_Link("userdefined")
                          %endif

%{ QuickLink By User %}   %INCLUDE "QuickLinkByUser.icl"

%{ Lot Heading %}
                          @dtw_strip(lotNumber, lotNumber)
                          @dtw_assign(RPT_MAX_ROWS, "99")
                          @dtw_assign(dspMaxRows, "10")
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select a.*, IMIMDS, IMUOMS ", stmtSQL)
                          @dtw_concat(fileSQL, " HDLOT a", fileSQL)
                          @dtw_concat(fileSQL, " left join HDIMST on a.LTITEM=IMITEM", fileSQL)
                          @dtw_concat(selectSQL, "LTITEM='$(itemNumber)' and LTWH=$(warehouseNumber) and trim(LTLT#)='$(lotNumber)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                          @Lot_Select_Header(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Begin %}     %INCLUDE "QuickLinkBegLoop.icl"

    %{ Demographics %}
                              %if (quicklinkRef == "demographics")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select a.*, IMIMDS, IMUOMS ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDLOT a", fileSQL)
                                  @dtw_concat(fileSQL, " left join HDIMST on a.LTITEM=IMITEM", fileSQL)
                                  @dtw_concat(selectSQL, "LTITEM='$(itemNumber)' and LTWH=$(warehouseNumber) and trim(LTLT#)='$(lotNumber)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Lot_Select_Demographics(profileHandle, dataBaseID, stmtSQL)

    %{ Quantities %}
                              %elif (quicklinkRef == "quantities")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDLOT ", fileSQL)
                                  @dtw_concat(selectSQL, "LTITEM='$(itemNumber)' and LTWH=$(warehouseNumber) and trim(LTLT#)='$(lotNumber)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Lot_Select_Quantities(profileHandle, dataBaseID, stmtSQL)

    %{ Dates %}
                              %elif (quicklinkRef == "dates")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDLOT ", fileSQL)
                                  @dtw_concat(selectSQL, "LTITEM='$(itemNumber)' and LTWH=$(warehouseNumber) and trim(LTLT#)='$(lotNumber)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Lot_Select_Dates(profileHandle, dataBaseID, stmtSQL)

    %{ Stock Locations %}
                              %elif (quicklinkRef == "stocklocations")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select HDITSL.*, ISQOH-(ISQRES+ISQHSR) as ISAVQT ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDITSL ", fileSQL)
                                  @dtw_concat(selectSQL, "ISITEM='$(itemNumber)' and ISWHS=$(warehouseNumber) and trim(ISLOT)='$(lotNumber)' ", selectSQL)
                                  @DTW_ASSIGN(orderBy, "ISSTKR,ISAILE,ISSLOC")
                                  @DTW_ASSIGN(orderByDisplay, "Stock Location")
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Lot_Select_StockLoc(profileHandle, dataBaseID, stmtSQL)

    %{ User Defined %}
                              %elif (quicklinkRef == "userdefined")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDLOT ", fileSQL)
                                  @dtw_concat(selectSQL, "LTITEM='$(itemNumber)' and LTWH=$(warehouseNumber) and trim(LTLT#)='$(lotNumber)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Lot_Select_UserDefined(profileHandle, dataBaseID, stmtSQL)
                              %endif

%{ Quicklink End %}       %INCLUDE "QuickLinkEndLoop.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Lot_Select_Header (IN CHAR(64)    profileHandle,
			                  CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  %if (sec_03 == "Y")
                      @RtvFldDesc("LTITEM='$(itemNumber)' and LTWH=$(warehouseNumber) and LTLT#='$(lotNumber)' ", "HDLOT", "char(LTQOH+LTQAL+LTLRCP+LTLQHR+LTQHSR)", lotQty)
                      %if (sec_03 == "Y" && lotQty > ".0000")
                          @dtw_assign(sec_03, "N")
                      %endif
                  %endif
                  <td class="toolbar">
                      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
                      @dtw_pos(".d2w", "$(backURL)", posD2W)
                      %if (backURL == "")
                          <a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=183" title="Back Home">$(portalHome)</a>
                      %elif (posD2W > "0")
                          <a href="$(homeURL)$(cGIPath)$(backURL)">$(portalHome)</a>
                      %else
                          <a href="$(backURL)">$(portalHome)</a>
                      %endif
                      %if (sec_02 == "Y" || sec_03 == "Y")
                          <a href="$(homeURL)$(cGIPath)LotMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=C">$(changeImageLrg)</a>
                      %endif
                      %if (sec_03 == "Y")
                          @Format_Confirm_Desc("Lot Number", $(lotNumber), "", "", "", "", confirmDesc)
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)lotmaintain.d2w/Edit_Data$(d2wVarBase)&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %ROW{
          @RtvFldDesc("WHWHS=$(warehouseNumber)", "HDWHSM", "WHWHNM", warehouseName)
          <table $(contentTable)>
              @Format_Header_URL("Item", $(V_IMIMDS), $(itemNumber), "$(homeURL)$(cGIPath)ItemSelect.d2w/REPORT$(d2wVarBase)&amp;itemDescription=@dtw_rurlescseq(itemDescription)")
              @Format_Header_URL("Warehouse", $(warehouseName), $(warehouseNumber), "$(homeURL)$(cGIPath)WarehouseSelect.d2w/REPORT$(d2wVarBase)&amp;warehouseName=@dtw_rurlescseq(warehouseName)")
              @Format_Header("Lot Number", $(lotNumber), "")
          </table>

          $(hrTagAttr)	

          %INCLUDE "QuickLinkDisplay.icl"
      %}
  %}
%}

%FUNCTION(dtw_sql) Lot_Select_Demographics (IN CHAR(64)    profileHandle,
				                CHAR(2)     dataBaseID,
                                               CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="demographics"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %ROW {
              @RtvFldDesc("UMUOM='$(V_IMUOMS)'", "HDUOM", "UMUMLD", fieldDesc)
              @Format_Code(V_IMUOMS, F_IMUOMS)
              <tr><td class="dsphdr">Unit Of Measure</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_IMUOMS)</td>
              </tr>
	
              %if (V_HDPDRL > "0")
                  @RtvFldDesc("PLPLNT=$(V_LTPLT)", "HDPLNT", "PLNAME", plantName)
                  @Format_Code(V_LTPLT, F_LTPLT)
                  <tr><td class="dsphdr">Plant Number</td>
                      <td class="dspnmbr">$(plantName)</td>
                      <td class="dspalph">$(F_LTPLT)</td>
                  </tr>
              %endif

              %if (V_LTVEND > "0")
                  @RtvFldDesc("VMVEND=$(V_LTVEND)", "HDVEND", "VMVNA1", vendorName)
                  @Format_Code(V_LTVEND, F_LTVEND)
                  <tr><td class="dsphdr">Vendor Number</td>
                      <td class="dspnmbr">$(vendorName)</td>
                      <td class="dspalph">$(F_LTVEND)</td>
                  </tr>
              %endif

              %if (V_LTVLOT != "")
                  <tr><td class="dsphdr">Vendor Lot Number</td>
                      <td class="dspalph">$(V_LTVLOT)</td>
                  </tr>
              %endif

              %if (V_LTPO# > "0")
                  <tr><td class="dsphdr">Purchase Order Number</td>
                      <td class="dspnmbr">$(V_LTPO#)</td>
                  </tr>
              %endif

              %if (V_LTECN != "")
                  <tr><td class="dsphdr">Engineering Chg Notice</td>
                      <td class="dspalph">$(V_LTECN)</td>
                  </tr>
              %endif

              %if (V_HDPDRL > "0" && V_LTMORD != "")
                  @RtvFldDesc("OHPLT=$(V_LTPLT) and OHORD='$(V_LTMORD)'", "HDMOHM", "count(*)", mfgCnt)
                  <tr><td class="dsphdr">Manufacturing Order</td>
                      %if (mfgCnt > "0")
                          <td class="dspalph"><a href="$(homeURL)$(cGIPath)SelectMfgOrder.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(V_LTPLT)&amp;plantName=@dtw_rurlescseq(plantName)&amp;mfgOrder=@dtw_rurlescseq(V_LTMORD)" onclick="$(inquiryWinVar)" title="View Manufacturing Order">$(V_LTMORD)</a></td>
                      %else
                          <td class="dspalph">$(V_LTMORD)</td>
                      %endif
                  </tr>
              %endif

              %if (V_LTLTCM != "")
                  <tr><td class="dsphdr">Comment</td>
                      <td class="dspalph">$(V_LTLTCM)</td>
                  </tr>
              %endif
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Lot_Select_Quantities (IN CHAR(64)    profileHandle,
				              CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="quantities"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      %ROW {
          <table $(contentTable)>
              <colgroup>
                  <col width="35%">
                  <col width="30%">
                  <col width="30%">
              <tr valign="top">
                  <td>
                      <table $(contentTable)>
                          @Format_Nbr(V_LTQOH, F_LTQOH, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                          <tr><td class="dsphdr">On Hand</td>
                              <td class="dspcode">&nbsp;</td>
                              <td class="dspqty">$(F_LTQOH)</td>
                          </tr>

                          @Format_Nbr(V_LTQAL, F_LTQAL, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                          <tr><td class="dsphdr">Reserved</td>
                              <td class="dspcode">-</td>
                              <td class="dspqty">$(F_LTQAL)</td>
                          </tr>

                          @Format_Nbr(V_LTQHSR, F_LTQHSR, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                          <tr><td class="dsphdr">Held In Stock</td>
                              <td class="dspcode">-</td>
                              <td class="dspqty">$(F_LTQHSR)</td>
                          </tr>


                          @Format_Nbr(@dtw_rsubtract(V_LTQOH, @dtw_radd(V_LTQAL, V_LTQHSR)), F_AVAIL, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                          <tr><td class="dsphdr">Available</td>
                              <td class="dspcode">&nbsp;</td>
                              <td class="dsptotal">$(F_AVAIL)</td>
                          </tr>
                      </table>
                  </td>
                  <td>
                      <table $(contentTable)>
                          @Format_Nbr(V_LTQRC, F_LTQRC, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                          <tr><td class="dsphdr">Received</td>
                              <td class="dspqty">$(F_LTQRC)</td>
                          </tr>

                          @Format_Nbr(V_LTQSL, F_LTQSL, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                          <tr><td class="dsphdr">Sold</td>
                              <td class="dspqty">$(F_LTQSL)</td>
                          </tr>

                          @Format_Nbr(V_LTQIS, F_LTQIS, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                          <tr><td class="dsphdr">Issued</td>
                              <td class="dspqty">$(F_LTQIS)</td>
                          </tr>

                          @Format_Nbr(V_LTQAD, F_LTQAD, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                          <tr><td class="dsphdr">Adjusted</td>
                              <td class="dspqty">$(F_LTQAD)</td>
                          </tr>

                          @Format_Nbr(V_LTQTR, F_LTQTR, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                          <tr><td class="dsphdr">Transferred</td>
                              <td class="dspqty">$(F_LTQTR)</td>
                          </tr>

                          @Format_Nbr(V_LTQKI, F_LTQKI, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                          <tr><td class="dsphdr">Kit Issued</td>
                              <td class="dspqty">$(F_LTQKI)</td>
                          </tr>
                      </table>
                  </td>
                  <td>
                      <table $(contentTable)>
                          @Format_Nbr(V_LTQRVT, F_LTQRVT, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                          <tr><td class="dsphdr">Returned To Vendor</td>
                              <td class="dspqty">$(F_LTQRVT)</td>
                          </tr>

                          @Format_Nbr(V_LTLRCP, F_LTLRCP, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                          <tr><td class="dsphdr">On Hand In Receiving</td>
                              <td class="dspqty">$(F_LTLRCP)</td>
                          </tr>

                          @Format_Nbr(V_LTLQHR, F_LTLQHR, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                          <tr><td class="dsphdr">Held In Receiving</td>
                              <td class="dspqty">$(F_LTLQHR)</td>
                          </tr>

                          @Format_Nbr(V_LTLSCR, F_LTLSCR, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                          <tr><td class="dsphdr">Scrapped In Receiving</td>
                              <td class="dspqty">$(F_LTLSCR)</td>
                          </tr>

                          @Format_Nbr(V_LTLSCS, F_LTLSCS, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                          <tr><td class="dsphdr">Scrapped In Stock</td>
                              <td class="dspqty">$(F_LTLSCS)</td>
                          </tr>

                          %if (V_HDPDRL > "0")
                              @Format_Nbr(V_LTLSCW, F_LTLSCW, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                              <tr><td class="dsphdr">Scrapped In WIP</td>
                                  <td class="dspqty">$(F_LTLSCW)</td>
                              </tr>
                          %endif
                      </table>
                  </td>
              </tr>
          </table>
                      <fieldset class="legendBody">
                          <legend class="legendTitle">On Hand Value</legend>
          <table $(contentTable)>
              %if (V_CILCSE == "Y")
                  @dtw_assign(workValue, @dtw_rformat(@dtw_rmultiply(V_LTQOH, V_LTIMCS), "21", "2", "0", "", "23"))
                  @Format_Nbr(workValue, F_workValue, "2", $(amtEditCode), "Y", "$", "")
                  @Format_Nbr(V_LTIMCS, F_LTIMCS, $(cstNbrDec), $(amtEditCode), "Y", "", "")
                  <tr><td class="dspalph">$(F_workValue) at Actual Cost of $(F_LTIMCS)</td></tr>
              %endif

              %if (V_HDTCV == "A")
                  @dtw_assign(avgStd, "Average")
              %else
                  @dtw_assign(avgStd, "Standard")
              %endif

              @Rtv_Unit_Cost(V_LTPLT, V_LTITEM, V_LTWH, V_LTLT#, totalCost, cat1Cost, cat2Cost, cat3Cost, cat4Cost, cat5Cost)
              @dtw_assign(workValue, @dtw_rformat(@dtw_rmultiply(V_LTQOH, totalCost), "21", "2", "0", "", "23"))
              @Format_Nbr(workValue, F_workValue, "2", $(amtEditCode), "Y", "$", "")
              @Format_Nbr(totalCost, F_totalCost, $(cstNbrDec), $(amtEditCode), "Y", "", "")
              <tr><td class="dspalph">$(F_workValue) at $(avgStd) Cost of $(F_totalCost)</td></tr>
          </table>
      </fieldset>
      %}
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Lot_Select_Dates (IN CHAR(64)    profileHandle,
				         CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="dates"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          <colgroup>
              <col width="40%">
              <col width="10%">
              <col width="40%">
          %ROW {
              <tr valign="top">
                  <td>
                      <table $(contentTable)>
                          @Format_Date(V_LTDTRC, "D", F_LTDTRC)
                          <tr><td class="dsphdr">Date Received</td>
                              <td class="dspdate">$(F_LTDTRC)</td>
                          </tr>

                          @Format_Date(V_LTDTEX, "D", F_LTDTEX)
                          <tr><td class="dsphdr">Expiration Date</td>
                              <td class="dspdate">$(F_LTDTEX)</td>
                          </tr>

                          @Format_Date(V_LTTSDT, "D", F_LTTSDT)
                          <tr><td class="dsphdr">Requested Ship Date</td>
                              <td class="dspdate">$(F_LTTSDT)</td>
                          </tr>

                          @Format_Date(V_LTLLDT, "D", F_LTLLDT)
                          <tr><td class="dsphdr">Last Transaction</td>
                              <td class="dspdate">$(F_LTLLDT)</td>
                          </tr>
                      </table>
                  </td>
                  <td>&nbsp;</td>
                  <td>
                      <table $(contentTable)>
                          @Format_Date(V_LTDTLP, "D", F_LTDTLP)
                          <tr><td class="dsphdr">Last Physical Inventory</td>
                              <td class="dspdate">$(F_LTDTLP)</td>
                          </tr>

                          @Format_Date(V_LTLFDS, "D", F_LTLFDS)
                          <tr><td class="dsphdr">First Date To Stock</td>
                              <td class="dspdate">$(F_LTLFDS)</td>
                          </tr>

                          @Format_Date(V_LTLLDS, "D", F_LTLLDS)
                          <tr><td class="dsphdr">Last Date To Stock</td>
                              <td class="dspdate">$(F_LTLLDS)</td>
                          </tr>
                      </table>
                  </td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Lot_Select_StockLoc (IN CHAR(64)    profileHandle,
				            CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="stocklocations"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          <tr>
              @OrderBy_Sort("ISSTKR", sortVar)
              @dtw_assign(columnHdr, "Stock Location")
              %if (sortVar == "sort")
                 <th class="colhdr$(sortVar)" colspan="3" $(helpCursor)><span title="$(orderByDisplay)">$(columnHdr)</span></th>
              %else
                 <th class="colhdr" colspan="3">$(columnHdr)</th>
              %endif

              @Format_Column_Header("ISRATE", "Priority")
              @Format_Column_Header("ISDTRC", "Date<br>Received")
              @Format_Column_Header("ISQOH", "Quantity<br>On Hand")
              @Format_Column_Header("ISQRES", "Quantity<br>Reserved")
              @Format_Column_Header("ISQHSR", "Quantity<br>Held<br>In Stock")
              @Format_Column_Header("ISAVQT", "Quantity<br>Available")
          </tr>

          %ROW {
              %INCLUDE "SetRowClass.icl"
              @Format_Date(V_ISDTRC, "D", F_ISDTRC)
              @dtw_add(T_ISQOH, V_ISQOH, "15", T_ISQOH)
              @dtw_add(T_ISQRES, V_ISQRES, "15", T_ISQRES)
              @dtw_add(T_ISQHSR, V_ISQHSR, "15", T_ISQHSR)
              @dtw_add(T_ISAVQT, V_ISAVQT, "15", T_ISAVQT)
              @Format_Nbr($(V_ISQOH), F_ISQOH, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_ISQRES), F_ISQRES, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_ISQHSR), F_ISQHSR, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_ISAVQT), F_ISAVQT, $(qtyNbrDec), $(qtyEditCode), "", "", "")

              <tr class="$(rowClass)">
                  <td class="colalph">$(V_ISSTKR)</td>
                  <td class="colalph">$(V_ISAILE)</td>
                  <td class="colalph">$(V_ISSLOC)</td>
                  <td class="colcode">$(V_ISRATE)</td>
                  <td class="colnmbr">$(F_ISDTRC)</td>
                  <td class="colnmbr">$(F_ISQOH)</td>
                  <td class="colnmbr">$(F_ISQRES)</td>
                  <td class="colnmbr">$(F_ISQHSR)</td>
                  <td class="colnmbr">$(F_ISAVQT)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Lot_Select_UserDefined (IN CHAR(64)    profileHandle,
				               CHAR(2)     dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="userdefined"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %ROW {
              <tr><td class="dsphdr">$(V_CILUS1)</td>
                  <td class="dspalph">$(V_LTUDF1)</td>
              </tr>

              <tr><td class="dsphdr">$(V_CILUS2)</td>
                  <td class="dspalph">$(V_LTUDF2)</td>
              </tr>

              <tr><td class="dsphdr">$(V_CILUS3)</td>
                  <td class="dspalph">$(V_LTUDF3)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}
