%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Kanban Purchasing Receipt"
  d2wName                 = "KanbanPurchasingReceipt.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;turnaroundNumber=@dtw_rurlescseq(turnaroundNumber)&amp;touchScreen=Y"
  programName             = ""
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  apIDSI                  = "SI"
  orderType               = ""
  stkLocActive            = ""
  rcvTickAssign           = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")	
          <script type="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (
                      document.Chg.qtyComplete.value ==""
                      )
                     {alert("$(reqFieldError)"); return false;}
                                                         var ok = true;   
                  document.Chg.qtyComplete.value = numberWithoutCommas(document.Chg.qtyComplete.value);
                  ok = (editNum(document.Chg.qtyComplete, 9, 4));
                  document.Chg.qtyComplete.value = numberWithCommas(document.Chg.qtyComplete.value);
                  return ok;
              }
              %INCLUDE "NumEdit.icl"
              %INCLUDE "KeyboardFunctionsTS.icl"
              %INCLUDE "ShowHideSelCriteria.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      @dtw_concat(stmtSQL, "Select * From HDTRNM inner join POPOMD on DCORD#=PDPO and DCORL#=PDPOL# and DCBLN#=PDPORL inner join HDKBMS on DCTURN=KBTURN Where DCTURN = $(turnaroundNumber)", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Receipt_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
                   <td>
                       <ul class="toolbarTS">
                          <li class="optionTS"><a href="$(homeURL)$(cGIPath)$(d2wName)/NOUPDATE$(d2wVarBase)">&nbsp;<br>Back</a></li>                       
                          <li class="optionTS"><a href="javascript:check(document.Chg)">&nbsp;<br>Accept</a></li>
                      </ul>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Receipt_Query (IN CHAR(64)    profileHandle,
                                     CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)

      <table $(contentTable)>
          <tr><td><h1>$(page_title)</h1></td></tr>
      </table>

      %ROW {
          @RtvFldDesc("RRN(IVCTRL)=1 and WHSTKL='Y' and IWSTKL='Y'", "IVCTRL inner join HDWHSM on WHWHS=$(V_PDOVWH) inner join HDIWHS on IWWHS=WHWHS and IWITEM='$(V_PDITEM)'", "CISTKL", stkLocActive)
          @RtvFldDesc("RRN(POCTRL)=1", "POCTRL", "COARAM", rcvTickAssign)
          <table $(contentTable)>
              <colgroup>
                  <col width="20%">
                  <col width="60%">
                  <col width="15%">
              <tr><td class="hdrtitl">Purchase Order/Line:</td>
                  <td class="hdrdata">$(V_DCORD#) / $(V_DCORL#)</td>
              </tr>
              @RtvFldDesc("POPO=$(V_DCORD#)", "POPOMS", "POVEND", vendorNum)
              @RtvFldDesc("VMVEND=$(vendorNum)", "HDVEND", "VMVNA1", vendorName)
              @Format_Code($(vendorNum), F_POVEND)
              <tr><td class="hdrtitl">Vendor:</td>
                  <td class="hdrdata">$(vendorName) &nbsp; $(F_POVEND)</td>
              </tr>
              @RtvFldDesc("WHWHS=$(V_PDOVWH)", "HDWHSM", "WHWHNM", warehouseName)
              @Format_Code($(V_PDOVWH), F_PDOVWH)
              <tr><td class="hdrtitl">Warehouse:</td>
                  <td class="hdrdata">$(warehouseName) &nbsp; $(F_PDOVWH)</td>
              </tr>
              @RtvFldDesc("IMITEM='$(V_PDITEM)'", "HDIMST", "IMIMDS", itemDescription)
              @Format_Code($(V_PDITEM), F_PDITEM)
              <tr><td class="hdrtitl">Item:</td>
                  <td class="hdrdata">$(itemDescription) &nbsp; $(F_PDITEM)</td>
                  <td><a href="javascript:void+0" onClick="showSel('selData')" onBlur="hideSel('selData')">$(smMoreInfoImage)</a></td>
              </tr>
          </table>
          @RtvFldDesc("PLPLNT=$(V_DCPLT)", "HDPLNT", "PLNAME", plantName)
          @Format_Code($(V_DCPLT), F_plantNumber)
          @RtvFldDesc("UMUOM='$(V_PDBUOM)'", "HDUOM", "UMUMLD", purUOMDesc)
          @Format_Code(V_PDBUOM, F_PDBUOM)
          @RtvFldDesc("UMUOM='$(V_PDSUOM)'", "HDUOM", "UMUMLD", stkUOMDesc)
          @Format_Code(V_PDSUOM, F_PDSUOM)

          @dtw_assign(moreInfo, "")
          @Build_More_Info("Plant", plantName, F_plantNumber, moreInfo)
          @Build_More_Info("Purchasing UOM", purUOMDesc, F_PDBUOM, moreInfo)
          @Build_More_Info("Stocking UOM", stkUOMDesc, F_PDSUOM, moreInfo)
          @Build_More_Info("Turnaround", turnaroundNumber, "", moreInfo)
          %INCLUDE "MoreInfo.icl"

          $(hrTagAttr)

          %INCLUDE "ErrorDisplay.icl"
			
          <form class="formClass" method="post" name="Chg" onsubmit="return validate(document.Chg)"  action="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
              %INCLUDE "RequiredFieldTS.icl"
              <table $(contentTable)>
                  %if (errFound != "")
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@qtyc", "qtyComplete")       @dtw_assign(Err_QTYC, fieldValue)
                      @DecatErr_Field("@@stkr", "stockRoom")         @dtw_assign(Err_STKR, fieldValue)
                      @DecatErr_Field("@@recv", "rcvTicket")         @dtw_assign(Err_RECV, fieldValue)

                      @Decat_Field("@@turn")   @dtw_assign(V_DCTURN,  fieldValue)
                      @Decat_Field("@@qtyc")   @dtw_assign(F_QTYC,  fieldValue)
                      @Decat_Field("@@stkr")   @dtw_assign(F_STKR, fieldValue)
                      @Decat_Field("@@aile")   @dtw_assign(F_AILE, fieldValue)
                      @Decat_Field("@@sloc")   @dtw_assign(F_SLOC, fieldValue)
                      @Decat_Field("@@recv")   @dtw_assign(F_RECV, fieldValue)
                      @Decat_Field("@@quom")   @dtw_assign(qtyUOM, fieldValue)

                      @dtw_assign(errFound, "")
                  %else
                      
                      %if (stkLocActive == "Y")
                          %if (V_KBFSTK == "" && V_KBFAIL == "" && V_KBFSLC == "")
                              @Rtv_Dft_StockLoc(apIDSI, V_PDOVWH, V_PDITEM, orderType, F_STKR, F_AILE, F_SLOC, stkID)
                          %else
                              @dtw_assign(F_STKR, "$(V_KBFSTK)")
                              @dtw_assign(F_AILE, "$(V_KBFAIL)")
                              @dtw_assign(F_SLOC, "$(V_KBFSLC)")
                          %endif
                      %endif

                      @dtw_assign(F_QTYC, @dtw_rsubtract(V_PDQTOR, @dtw_rADD(V_PDQRST, @dtw_rADD(V_PDQRRT, V_PDQRFT))))
                      %if (V_PDPCPB > "1.0000" && qtyUOM != "S")
                          @dtw_divide(F_QTYC, V_PDPCPB, "13", F_QTYC)
                      %endif
                      @dtw_assign(focusField, "qtyComplete")
                  %endif

                  %if (focusField == "")
                      @dtw_assign(focusField, "qtyComplete")
                  %endif

                  @dtw_assign(purChecked, "")
                  @dtw_assign(stkChecked, "")
                  %if (qtyUOM == "S")
                      @dtw_assign(stkChecked, "CHECKED")
                  %else
                      @dtw_assign(purChecked, "CHECKED")
                  %endif
                  <tr><td class="dsphdr">Unit Of Measure</td>
                      <td class="input"><input type="radio" name="qtyUOMChg" $(purChecked) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;qtyUOM=P'">Purchasing
                                        <input type="radio" name="qtyUOMChg" $(stkChecked) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;qtyUOM=S'">Stocking
                                        <input type="hidden" name="qtyUOM" value="$(qtyUOM)">
                      </td>
                  </tr>

                  @dtw_assign(creditCodeOvr, "N")
                  @Format_Nbr($(F_QTYC), F_QTYC, "4", "K", "", "", "")
                  %if (@dtw_rpos("-", F_QTYC) > "0")
                      @dtw_concat("-", @dtw_rreplace("$(F_QTYC)", "-", ""), F_QTYC)
                  %endif
                  @SetTextOvr(Err_QTYC)
                  <tr><td class="dsphdr"><span $(textOvr)>Quantity Received</span></td>
                      <td class="input"><input class="input" id="qtyComplete" onfocus="kbActive(this, 'numericKeyboard', true);" onkeyup="formatInput(this.id);" name="qtyComplete" type="text" value="$(F_QTYC)" size="15" maxlength="17"> $(reqFieldChar)
                          %if (qtyUOM == "S")
                              $(stkUOMDesc) &nbsp; $(F_PDSUOM)
                          %else
                              $(purUOMDesc) &nbsp; $(F_PDBUOM)
                          %endif
                      </td>
                  </tr>
                  @DspErrMsg(Err_QTYC)

                  %if (stkLocActive == "Y")
                  	  @SetTextOvr(Err_STKR)
                      <tr><td class="dsphdr"><span $(textOvr)>Stock Location</span></td>
                          <td class="input"><input class="input" id="stockRoom" onfocus="kbActive(this, 'keyboard');" name="stockRoom" type="text" value="$(F_STKR)" size="3" maxlength="3"> - <input class="input" id="stockAile" onfocus="kbActive(this, 'keyboard');" name="stockAile" type="text" value="$(F_AILE)" size="4" maxlength="4"> - <input class="input" id="stockLoc" onfocus="kbActive(this, 'keyboard');" name="stockLoc" type="text" value="$(F_SLOC)" size="8" maxlength="8">
                                            <a href="$(homeURL)$(phpPath)StockLocSearch.php$(altVarBase)&amp;docName=Chg&amp;forWhs=$(V_PDOVWH)&amp;fldStkr=stockRoom&amp;fldAisle=stockAile&amp;fldLoc=stockLoc&amp;fldStkID=stockLocId&amp;touchScreen=Y" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchDesc)</a>
                                            <input name="stockLocId" type="hidden" size="9" maxlength="9">
                          </td>
                      </tr>
                      @DspErrMsg(Err_STKR)
                  %endif

                  %if (rcvTickAssign != "A")
                      @SetTextOvr(Err_RECV)
                      <tr><td class="dsphdr"><span $(textOvr)>Receiving Ticket</span></td>
                          <td class="input"><input class="input" id="rcvTicket" onfocus="kbActive(this, 'keyboard');" name="rcvTicket" type="text" value="$(F_RECV)" size="15" maxlength="8"></td>
                      </tr>
                      @DspErrMsg(Err_RECV)
                  %endif
  	   		
              %}	
          </table>
          %INCLUDE "KeyboardTS.icl"

      </form>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Rtv_Dft_StockLoc (INOUT CHAR(2)   apID,
                                                  DEC(3,0)  whs,
                                                  CHAR(15)  item,
                                                  CHAR(1)   orderType,
                                                  CHAR(3)   stkRoom,                             	
                                                  CHAR(4)   stkAisle,                             	
                                                  CHAR(8)   stkLoc,                             	
                                                  DEC(9,0)  stkID)
{%EXEC {HHDRDL_W.PGM %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSIKPR_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(NOUPDATE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(confMessage, "Confirm No Update")
  @dtw_assign(returnURL, "DataCollection.d2w/REPORT$(genericVarBase)")
  %INCLUDE "ReturnTS.icl"
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(stockRoom)
  @dtw_mUPPERCASE(stockAile)
  @dtw_mUPPERCASE(stockLoc)
  @dtw_mUPPERCASE(rcvTicket)

  @dtw_assign(qtyComplete,  @dtw_rstrip(qtyComplete))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@turn", turnaroundNumber)
  @dtw_replace("$(qtyComplete)", ",", "", qtyComplete)
  @Concat_Field("@@qtyc", qtyComplete)
  @Concat_Field("@@stkr", stockRoom)
  @Concat_Field("@@aile", stockAile)
  @Concat_Field("@@sloc", stockLoc)
  @Concat_Field("@@recv", rcvTicket)
  @Concat_Field("@@quom", qtyUOM)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, errFound, edtVar, errVar)

  %if (errFound == "")
      @ErrVarErr(profileHandle, typeError, errVar)
      @DecatErr_Field("@@cmsg", "")
      @dtw_assign(confMessage, fieldValue)
      @dtw_assign(returnURL, "DataCollection.d2w/REPORT$(genericVarBase)")
      %INCLUDE "ReturnTS.icl"
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
