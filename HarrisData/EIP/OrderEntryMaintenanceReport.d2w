%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Order Entry Maintenance Report"
  d2wName                 = "OrderEntryMaintenanceReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  forPlant                = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromPlantNumber, 3, 0) &&
                      editNum(document.Chg.toPlantNumber, 3, 0) &&
                      editdate(document.Chg.fromMaintenanceDate) &&
                      editdate(document.Chg.toMaintenanceDate) &&
                      editFromToAll(document.Chg.fromPlantNumber, document.Chg.toPlantNumber, document.Chg.allPlantNumber, 3) &&
                      editFromToAll(document.Chg.fromMaintenanceDate, document.Chg.toMaintenanceDate, document.Chg.allMaintenanceDate, "D") &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromMaintenanceOption, document.Chg.toMaintenanceOption, document.Chg.allMaintenanceOption, "A")
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ORDERENTRYMAINTENANCEREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromPlantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@fplt", "fromPlantNumber")        @dtw_assign(Err_N2FPLT,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}

                                  @Decat_Field("@@fplt")  @dtw_assign(V_N2FPLT,  fieldValue)
                                  @Decat_Field("@@tplt")  @dtw_assign(V_N2TPLT,  fieldValue)
                                  @Decat_Field("@@aplt")  @dtw_assign(V_N2APLT,  fieldValue)

                                  @Decat_Field("@@fdat")  @dtw_assign(V_N2FDAT, fieldValue)
                                  @Decat_Field("@@tdat")  @dtw_assign(V_N2TDAT, fieldValue)
                                  @Decat_Field("@@adat")  @dtw_assign(V_N2ADAT, fieldValue)

                                  @Decat_Field("@@fitm")  @dtw_assign(V_N2FITM, fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N2TITM, fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N2AITM, fieldValue)

                                  @Decat_Field("@@fmnt")  @dtw_assign(V_N2FMNT, fieldValue)
                                  @Decat_Field("@@tmnt")  @dtw_assign(V_N2TMNT, fieldValue)
                                  @Decat_Field("@@amnt")  @dtw_assign(V_N2AMNT, fieldValue)

                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries
 Values %}
                                  %if (V_N1NPRO == "02")
                                      @dtw_assign(no, "")
                                      @dtw_assign(yes, "CHECKED")
                                  %else
                                      @dtw_assign(no, "CHECKED")
                                      @dtw_assign(yes, "")
                                  %endif
                                  %if (V_N2APLT == "ALL")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPlantNumber, "")
                                  %endif
                                  %if (V_N2ADAT == "ALL")
                                      @dtw_assign(checkedallMaintenanceDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallMaintenanceDate, "")
                                  %endif
                                  %if (V_N2AITM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_N2AMNT == "ALL")
                                      @dtw_assign(checkedallMaintenanceOption, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallMaintenanceOption, "")
                                  %endif

                              %else
                                  @dtw_assign(no, "CHECKED")
                                  @dtw_assign(yes, "")
                                  @RtvDftPlant(plantNumber, plantName)
                                  %if (plantNumber == "0")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(V_N2FPLT, plantNumber)
                                      @dtw_assign(V_N2TPLT, plantNumber)
                                      @dtw_assign(checkedallPlantNumber, "")
                                      @dtw_assign(focusField, "fromMaintenanceDate")
                                  %endif
                                  @dtw_assign(checkedallMaintenanceDate, "CHECKED")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallMaintenanceOption, "CHECKED")
                              %endif

                              <tr><td  class="dsphdr"><span $(textOvr)>Print Previously Printed Transactions </span></td>
                                  <td class="inputnmbr"><input name="previouslyPrinted" type="radio" VALUE='01' $(no)>No</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="previouslyPrinted" type="radio" VALUE='02' $(yes)>Yes</td>
                              </tr>
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_N2FPLT)
                              <tr><td  class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                  <td class="inputnmbr"><input name="fromPlantNumber" value="$(V_N2FPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromPlantNumber&amp;fldDesc=fplantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fplantName"  type="hidden"></td>
                                  <td class="inputnmbr"><input name="toPlantNumber" value="$(V_N2TPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toPlantNumber&amp;fldDesc=tplantName" onclick="$(searchWinVar)">  $(searchImage) </a><input name="tplantName"  type="hidden"></td>
                                  <td class="inputalph"><input name="allPlantNumber" value='ALL' $(checkedallPlantNumber) type="checkbox" onClick="if (this.checked) this.form.fromPlantNumber.value='', this.form.toPlantNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N2FPLT)

                              <tr><td  class="dsphdr">Maintenance Date</td>
                                  <td class="inputnmbr"><input name="fromMaintenanceDate" value="$(V_N2FDAT)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromMaintenanceDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toMaintenanceDate" value="$(V_N2TDAT)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toMaintenanceDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allMaintenanceDate" value='ALL' $(checkedallMaintenanceDate) type="checkbox" onClick="if (this.checked) this.form.fromMaintenanceDate.value='', this.form.toMaintenanceDate.value='';"></td>
                              </tr>

                              <tr><td  class="dsphdr">Item Number</td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N2FITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N2TITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                              </tr>

                              <tr><td  class="dsphdr">Maintenance Option</td>
                                  <td class="inputalph"><input name="fromMaintenanceOption" value="$(V_N2FMNT)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="toMaintenanceOption" value="$(V_N2TMNT)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="allMaintenanceOption" value='ALL' $(checkedallMaintenanceOption) type="checkbox" onClick="if (this.checked) this.form.fromMaintenanceOption.value='', this.form.toMaintenanceOption.value='';"></td>
                              </tr>
                          </table>

                          @dtw_assign(envProgram, "HSIOML")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSIOMS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allPlantNumber)
  @dtw_mUPPERCASE(allMaintenanceDate)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(fromMaintenanceOption)
  @dtw_mUPPERCASE(toMaintenanceOption)
  @dtw_mUPPERCASE(allMaintenanceOption)

  @dtw_assign(fromPlantNumber,@dtw_rstrip(fromPlantNumber))
  @dtw_assign(toPlantNumber,@dtw_rstrip(toPlantNumber))
  @dtw_assign(fromMaintenanceDate,@dtw_rstrip(fromMaintenanceDate))
  @dtw_assign(toMaintenanceDate,@dtw_rstrip(toMaintenanceDate))

  %if (allPlantNumber != "ALL")
      @dtw_assign(allPlantNumber, "")
  %endif
  %if (allMaintenanceDate != "ALL")
      @dtw_assign(allMaintenanceDate, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allMaintenanceOption != "ALL")
      @dtw_assign(allMaintenanceOption, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@opt@", "1")
  @Concat_Field("@@npro", previouslyPrinted)
  @Concat_Field("@@fplt", fromPlantNumber)
  @Concat_Field("@@tplt", toPlantNumber)
  @Concat_Field("@@aplt", allPlantNumber)
  @Concat_Field("@@fdat", fromMaintenanceDate)
  @Concat_Field("@@tdat", toMaintenanceDate)
  @Concat_Field("@@adat", allMaintenanceDate)
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@fmnt", fromMaintenanceOption)
  @Concat_Field("@@tmnt", toMaintenanceOption)
  @Concat_Field("@@amnt", allMaintenanceOption)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}