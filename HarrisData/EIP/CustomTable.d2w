%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Custom Table"
  d2wName                 = "CustomTable.d2w"
  d2wVarBase              = "$(genericVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  currentURL              = "$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;START_ROW_NUM=@dtw_rurlescseq(START_ROW_NUM)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName             = "CUSTOMTBL"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  lgCTitle                = "Display a list of column conditions"	
  checkImageTitle         = "Display a list of filter checkboxes"	
  smFTitle                = "Click here to maintain the table foreign keys"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "AJAXRequest.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "SaveCurrentURL.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              function confirmPublish(text) {return confirm("Confirm Publish of" + "\n" + "\n" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "TABLENAME")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " SYTBLN", fileSQL)
                      @dtw_concat(selectSQL, "TNTBID>=5000", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy)", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Table_Name_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Table_Name_Query (IN CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{ 
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
					  <a href="$(homeURL)$(cGIPath)CustomTableMaintain.d2w/MAINTAIN$(genericVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      <!-- %INCLUDE "FormatToPrint.icl" -->
		              <a href="$(homePath)R15.0_Custom_List_Widgets.pdf" target="_blank"><img border="0" src="$(homeURL)$(imagePath)lgHelp.gif" title="View Custom List Widget Design" alt="Help"></a>
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Table</th>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">ID</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchTable" size="20" maxlength="130">
                          <input type="hidden" name="operTable" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchDesc" size="20" maxlength="100">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchID" size="3" maxlength="5">
                          <input type="hidden" name="operID" value=">=">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchTable.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y")
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("TNTBLN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Table" title="Sequence By Custom Table">Custom Table</a></th>
              @OrderBy_Sort("TNTBID", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ID" title="Sequence By ID">ID</a></th>
              @OrderBy_Sort("TNDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description, Table">Description</a></th>
              @OrderBy_Sort("TNPGOS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Prog" title="Sequence By Security Program, Table">Security<br>Program</a></th>
              @OrderBy_Sort("TNXMLC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=XML" title="Sequence By XML Container, Table">XML Container</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(genericVarBase)&amp;tableName=@dtw_rurlescseq(V_TNTBLN)&amp;tableDesc=@dtw_rurlescseq(V_TNDESC)&amp;tblID=@dtw_rurlescseq(V_TNTBID)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_TNDESC), $(V_TNTBLN), "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y")
                      <td class="opticon">
						  <a onClick="saveCurrentURL();" href="$(homeURL)$(cGIPath)CustomTableMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
						  <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)CustomTableMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
						  <a onClick="saveCurrentURL();" href="$(homeURL)$(cGIPath)TableColumnMaintain.d2w/REFRESH$(maintainVar)">$(tableColumn)</a>
                          <a href="$(homeURL)$(cGIPath)TableLink.d2w/REPORT$(maintainVar)&amp;progOptName=@dtw_rurlescseq(V_TNPGOS)&amp;dftD2WName=@dtw_rurlescseq(V_TND2WN)">$(tableLink)</a>
                          <a onClick="saveCurrentURL();" href="$(homeURL)$(cGIPath)ColumnRelation.d2w/REPORT$(maintainVar)">$(relatedColumns)</a>
                          <a href="$(homeURL)$(phpPath)FilterCheckbox.php$(altVarBase)&amp;tableName=@dtw_rurlescseq(V_TNTBLN)&amp;tableDesc=@dtw_rurlescseq(V_TNDESC)&amp;fromTblID=@dtw_rurlescseq(V_TNTBID)">$(checkImage)</a>
                          <a href="$(homeURL)$(phpPath)TableForeignKeyMaintain.php$(altVarBase)&amp;tag=MAINTAIN&amp;tableName=@dtw_rurlescseq(V_TNTBLN)&amp;tableDesc=@dtw_rurlescseq(V_TNDESC)&amp;fromTblID=@dtw_rurlescseq(V_TNTBID)">$(smF)</a>
                          <a href="$(homeURL)$(phpPath)Page.php$(altVarBase)&amp;tableName=@dtw_rurlescseq(V_TNTBLN)&amp;tableDesc=@dtw_rurlescseq(V_TNDESC)&amp;tblID=@dtw_rurlescseq(V_TNTBID)">$(pageIDImageSml)</a>
                          <a onClick="saveCurrentURL(); return confirmPublish('$(confirmDesc)')" href="$(homeURL)$(phpPath)TablePublish.php$(altVarBase)&amp;tblDesc=@dtw_rurlescseq(V_TNDESC)&amp;tblID=@dtw_rurlescseq(V_TNTBID)">$(publishSml)</a>
                      </td>
                  %endif
                  <td class="colalph"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=@dtw_rurlescseq(V_TNTBID)">$(V_TNTBLN)</a></td>
                  <td class="colnmbr">$(V_TNTBID)</td>
                  <td class="colalph">$(V_TNDESC)</td>
                  <td class="colalph">$(V_TNPGOS)</td>
                  <td class="colalph">$(V_TNXMLC)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
   %if (sec_01!="Y")
      %INCLUDE "ProgSecurityError.icl"
  %else
	  %INCLUDE "WebReg.icl"
	  %if (formatToPrint != "")
		  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
	  %else
		  %if (orderBy == "")
			  @DTW_ASSIGN(orderBy, "TNTBLN")
			  @DTW_ASSIGN(orderByDisplay, "Table")
			  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
		  %endif
		  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
	  %endif
	  @Set_SQL(stmtSQL)
  %endif
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Table")
      %if (orderBy == "TNTBLN")
          @DTW_ASSIGN(orderBy, "TNTBLN DESC")
          @DTW_ASSIGN(orderByDisplay, "Table (descending)")
      %else
          @DTW_ASSIGN(orderBy, "TNTBLN")
          @DTW_ASSIGN(orderByDisplay, "Table")
      %endif
  %elif (sequence == "ID")
      %if (orderBy == "TNTBID")
          @DTW_ASSIGN(orderBy, "TNTBID DESC")
          @DTW_ASSIGN(orderByDisplay, "ID (descending)")
      %else
          @DTW_ASSIGN(orderBy, "TNTBID")
          @DTW_ASSIGN(orderByDisplay, "ID")
      %endif
  %elif (sequence == "Desc")
      %if (orderBy == "TNDESCU,TNTBLN")
          @DTW_ASSIGN(orderBy, "TNDESCU DESC,TNTBLN")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Table")
      %else
          @DTW_ASSIGN(orderBy, "TNDESCU,TNTBLN")
          @DTW_ASSIGN(orderByDisplay, "Description, Table")
      %endif
  %elif (sequence == "Script")
      %if (orderBy == "TND2WNU,TNTBLN")
          @DTW_ASSIGN(orderBy, "TND2WNU DESC,TNTBLN")
          @DTW_ASSIGN(orderByDisplay, "Maintenance Script (descending), Table")
      %else
          @DTW_ASSIGN(orderBy, "TND2WNU,TNTBLN")
          @DTW_ASSIGN(orderByDisplay, "Maintenance Script, Table")
      %endif
  %elif (sequence == "Doc")
      %if (orderBy == "TNDOCSU,TNTBLN")
          @DTW_ASSIGN(orderBy, "TNDOCSU DESC,TNTBLN")
          @DTW_ASSIGN(orderByDisplay, "Documentation Script (descending), Table")
      %else
          @DTW_ASSIGN(orderBy, "TNDOCSU,TNTBLN")
          @DTW_ASSIGN(orderByDisplay, "Documentation Script, Table")
      %endif
  %elif (sequence == "Prog")
      %if (orderBy == "TNPGOS,TNTBLN")
          @DTW_ASSIGN(orderBy, "TNPGOS DESC,TNTBLN")
          @DTW_ASSIGN(orderByDisplay, "Security Program (descending), Table")
      %else
          @DTW_ASSIGN(orderBy, "TNPGOS,TNTBLN")
          @DTW_ASSIGN(orderByDisplay, "Security Program, Table")
      %endif
  %elif (sequence == "XML")
      %if (orderBy == "TNXMLC,TNTBLN")
          @DTW_ASSIGN(orderBy, "TNXMLC DESC,TNTBLN")
          @DTW_ASSIGN(orderByDisplay, "XML Container (descending), Table")
      %else
          @DTW_ASSIGN(orderBy, "TNXMLC,TNTBLN")
          @DTW_ASSIGN(orderByDisplay, "XML Container, Table")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          @dtw_assign(formName, "Search")
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "TABLENAME")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Table</td>
                              @dtw_assign(operNbr, "operTable")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchTable" type="text" size="20" maxlength="130"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchDesc" type="text" size="20" maxlength="100"></td>
                          </tr>

                          <tr><td class="dsphdr">Maintenance Script</td>
                              @dtw_assign(operNbr, "operScript")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchScript" type="text" size="20" maxlength="100"></td>
                          </tr>
                          %INCLUDE "SearchBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
  @Build_WildCard ("TNTBLN", "Table", $(srchTable), "U", $(operTable), "A")
  @Build_WildCard ("TNDESCU", "Description", $(srchDesc), "U", $(operDesc), "A")
  @Build_WildCard ("TND2WNU", "Maintenance Script", $(srchScript), "U", $(operScript), "A")
  @Build_WildCard ("TNTBID", "Table ID", $(srchID), "", $(operID), "N")
  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}