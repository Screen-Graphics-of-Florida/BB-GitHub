%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Validation ID Maintenance"
  d2wName                 = "WFValidationIdMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;vldProgram=@dtw_rurlescseq(vldProgram)&amp;fromValidationId=@dtw_rurlescseq(fromValidationId)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;updRecNbr=@dtw_rurlescseq(updRecNbr)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;validationId=@dtw_rurlescseq(validationId)&amp;maintenanceCode=D"
  programName             = "HWFVIM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function confirmDelete() {return confirm("$(delRecordConf)")}
              function validate(chgForm) {
                  if (document.Chg.validationId.value =="")
                         {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.validationId, 15, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFVALIDATIONIDMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " WFVLID ", fileSQL)
                          @dtw_concat(selectSQL, " VIVPGM='$(vldProgram)' and VIVLID=$(validationId) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"

      <table $(contentTable)>
          @RtvFldDesc("VPVPGM='$(vldProgram)'", "WFVLPG", "VPDESC", vldProgramDescription)
          @Format_Header("", $(vldProgramDescription), $(vldProgram))
      </table>

      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "validationId")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@vlid", "validationId")          @dtw_assign(Err_VIVLID, fieldValue)
                          @DecatErr_Field("@@desc", "validationDescription") @dtw_assign(Err_VIDESC, fieldValue)
                          @DecatErr_Field("@@vtyp", "validationType")        @dtw_assign(Err_VIVTYP, fieldValue)
                          @DecatErr_Field("@@er#@", "validationErr")         @dtw_assign(Err_VIER#, fieldValue)
                      %endif

                      @Decat_Field("@@vlid")   @dtw_assign(V_VIVLID, fieldValue)
                      @Decat_Field("@@desc")   @dtw_assign(V_VIDESC, fieldValue)
                      @Decat_Field("@@vtyp")   @dtw_assign(V_VIVTYP, fieldValue)
                      @Decat_Field("@@er#@")   @dtw_assign(V_VIER#, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "validationDescription")
                          @RtvFldDesc("VIVPGM='$(vldProgram)' ", "WFVLID", "CHAR(MAX(VIVLID))", V_VIVLID)
                          %if (V_VIVLID=="")
                              @dtw_assign(V_VIVLID, "1")
                          %else
                              @dtw_add(V_VIVLID, "1", V_VIVLID)
                          %endif
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "validationId")
                  %else
                      @dtw_assign(focusField, "validationDescription")
                  %endif

                  @SetTextOvr(Err_VIVLID)
                  <tr><td class="dsphdr"><span $(textOvr)>Validation ID</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input type="text" name="validationId" value="$(V_VIVLID)" size="15" maxlength="15">$(reqFieldChar)</td>
                      %else
                          <td class="inputnmbr"><input type="hidden" name="validationId" value="$(V_VIVLID)">$(V_VIVLID)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_VIVLID)

                  @SetTextOvr(Err_VIDESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input type="text" name="validationDescription" value="$(V_VIDESC)" size="50" maxlength="50"></td>
                  </tr>
                  @DspErrMsg(Err_VIDESC)

                  @RtvFldDesc("FLTYPE='WFVLDTYPE' and FLVALU='$(V_VIVTYP)'", "SYFLAG", "FLDESC", fieldDesc)
                  @SetTextOvr(Err_VIVTYP)
                  <tr><td class="dsphdr"><span $(textOvr)>Validation Type</span></td>
                      <td class="inputalph"><input type="text" name="validationType" value="$(V_VIVTYP)" size="10" maxlength="1">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=WFVLDTYPE&amp;flagSrchHdr=@dtw_rurlescseq("Validation Type")&amp;docName=Chg&amp;fldName=validationType&amp;fldDesc=validationTypeDesc" onclick="$(searchWinVar)"> $(searchImage)</a>
                                            <input type="text" disabled name="validationTypeDesc" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_VIVTYP)

                  @Rtv_Error_Desc("$(V_VIER#)", fieldDesc)
                  @SetTextOvr(Err_VIER#)
                  <tr><td class="dsphdr"><span $(textOvr)>Error Number</span></td>
                      <td class="inputalph"><input type="text" name="validationErr" value="$(V_VIER#)" size="10" maxlength="10">
                                            <a href="$(homeURL)$(cGIPath)ErrorMessageSearch.d2w/REPORT$(genericVarBase)&amp;docName=Chg&amp;fldName=validationErr&amp;fldDesc=validationErrDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                                            <input type="text" disabled name="validationErrDesc" value="$(fieldDesc)" size="67"></td>
                  </tr>
                  @DspErrMsg(Err_VIER#)
              %}
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HWFVIM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @dtw_mUPPERCASE(validationType)
  @dtw_mUPPERCASE(validationErr)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@frm1", fromValidationId)
  @Concat_Field("@@vpgm", vldProgram)
  @Concat_Field("@@vlid", validationId)
  @Concat_Field("@@desc", validationDescription)
  @Concat_Field("@@vtyp", validationType)
  @Concat_Field("@@er#@", validationErr)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (validationDescription=="")
      @RtvFldDesc("VIVPGM='$(vldProgram)' and VIVLID=$(validationId) ", "WFVLID", "VIDESC", validationDescription)
  %endif

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(validationDescription), $(validationId), "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)WFValidationId.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@vlid", "validationId")
      @Format_ConfMsg_Desc("", $(validationDescription), $(validationId), "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)WFValidationId.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;validationId=@dtw_rurlescseq(validationId)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
