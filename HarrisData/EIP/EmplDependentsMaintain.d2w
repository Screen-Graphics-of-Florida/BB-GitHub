%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "EmplDependentsMaintain.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Spouse/Dependent Maintenance"
  d2wName                 = "EmplDependentsMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)$(employeeVarBase)&amp;dependentNbr=@dtw_rurlescseq(dependentNbr)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;socialSecurityNo=@dtw_rurlescseq(svss)&amp;firstName=@dtw_rurlescseq(svfirst)&amp;lastName=@dtw_rurlescseq(svlast)&amp;maintenanceCode=D"
  programName             = "HPESDU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  applicationID           = "PE"
  dataType                = "SSNO"
  modeD                   = "D"
  modeI                   = "I"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
  @dtw_replace(workURL, "@@dependentNbr", "@dtw_rurlescseq(dependentNbr)", "1", "a", workURL)
%}


%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script type="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  function validate(chgForm) {
                      if (document.Chg.lastName.value =="" ||
                          document.Chg.firstName.value =="" ||
                          document.Chg.address1.value =="" ||
                          document.Chg.city.value =="" ||
                          document.Chg.zipCode.value =="")
                         {alert("$(reqFieldError)"); return false;}
                      if (editNum(document.Chg.socialSecurityNo, 9, 0) &&
                          editNum(document.Chg.homePhoneNumber, 10, 0) &&
                          editdate(document.Chg.dateOfBirth))
                          return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
	           %INCLUDE "numedit.icl"
                  %INCLUDE "dateedit.icl"
                  %INCLUDE "calendar.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "EMPLDEPMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "SELECT * FROM HRSPDP WHERE SDCOMP = $(prCompany) and SDFACL = $(prFacility) and SDEMPL = $(hrEmployee) and SDSPDP = $(dependentNbr)", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
          <tr><td><h2> Dependent Of $(F_EmpName)</h2></td>
          </tr>
      </table>

      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  @dtw_assign(svss, V_SDSSN)
                  @dtw_assign(svfirst, V_SDFNAM)
                  @dtw_assign(svlast, V_SDLNAM)

                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "socialSecurityNo")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@ssn@", "socialSecurityNo")  @dtw_assign(Err_SDSSN,  fieldValue)
                          @DecatErr_Field("@@ss@@", "timeStamp")         @dtw_assign(Err_SDTSTP,  fieldValue)
                          @DecatErr_Field("@@lnam", "lastName")          @dtw_assign(Err_SDLNAM, fieldValue)
                          @DecatErr_Field("@@fnam", "firstName")         @dtw_assign(Err_SDFNAM, fieldValue)
                          @DecatErr_Field("@@midi", "middleInitial")     @dtw_assign(Err_SDMIDI, fieldValue)
                          @DecatErr_Field("@@adr1", "address1")          @dtw_assign(Err_SDADR1, fieldValue)
                          @DecatErr_Field("@@adr2", "address2")          @dtw_assign(Err_SDADR2, fieldValue)
                          @DecatErr_Field("@@city", "city")              @dtw_assign(Err_SDCITY, fieldValue)
                          @DecatErr_Field("@@stat", "state")             @dtw_assign(Err_SDSTAT, fieldValue)
                          @DecatErr_Field("@@prov", "province")          @dtw_assign(Err_SDPROV, fieldValue)
                          @DecatErr_Field("@@zip@", "zipCode")           @dtw_assign(Err_SDZIP,  fieldValue)
                          @DecatErr_Field("@@cntr", "country")           @dtw_assign(Err_SDCNTR, fieldValue)
                          @DecatErr_Field("@@phon", "homePhoneNumber")   @dtw_assign(Err_SDPHON, fieldValue)
                          @DecatErr_Field("@@dob@", "dateOfBirth")       @dtw_assign(Err_SDDOB,  fieldValue)
                          @DecatErr_Field("@@clas", "classification")    @dtw_assign(Err_SDCLAS, fieldValue)
                          @DecatErr_Field("@@rel@", "relationship")      @dtw_assign(Err_SDREL,  fieldValue)
                          @DecatErr_Field("@@gndr", "gender")            @dtw_assign(Err_SDGNDR, fieldValue)
                      %endif

                      @Decat_Field("@@ssn@")   @dtw_assign(V_SDSSN,  fieldValue)
                      @Decat_Field("@@ss@@")   @dtw_assign(V_SDTSTP, fieldValue)
                      @Decat_Field("@@lnam")   @dtw_assign(V_SDLNAM, fieldValue)
                      @Decat_Field("@@fnam")   @dtw_assign(V_SDFNAM, fieldValue)
                      @Decat_Field("@@midi")   @dtw_assign(V_SDMIDI, fieldValue)
                      @Decat_Field("@@adr1")   @dtw_assign(V_SDADR1, fieldValue)
                      @Decat_Field("@@adr2")   @dtw_assign(V_SDADR2, fieldValue)
                      @Decat_Field("@@city")   @dtw_assign(V_SDCITY, fieldValue)
                      @Decat_Field("@@stat")   @dtw_assign(V_SDSTAT, fieldValue)
                      @Decat_Field("@@prov")   @dtw_assign(V_SDPROV, fieldValue)
                      @Decat_Field("@@zip@")   @dtw_assign(V_SDZIP,  fieldValue)
                      @Decat_Field("@@cntr")   @dtw_assign(V_SDCNTR, fieldValue)
                      @Decat_Field("@@phon")   @dtw_assign(V_SDPHON, fieldValue)
                      @Decat_Field("@@dob@")   @dtw_assign(V_SDDOB,  fieldValue)
                      @Decat_Field("@@clas")   @dtw_assign(V_SDCLAS, fieldValue)
                      @Decat_Field("@@rel@")   @dtw_assign(V_SDREL,  fieldValue)
                      @Decat_Field("@@gndr")   @dtw_assign(V_SDGNDR, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                         @dtw_assign(socialSecurityNo, "000000000")
                         @dtw_assign(dateOfBirth, "000000")
                         @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMLNAM", V_SDLNAM)
                         @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMADR1", V_SDADR1)
                         @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMADR2", V_SDADR2)
                         @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMCITY", V_SDCITY)
                         @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMSTAT", V_SDSTAT)
                         @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMZIP", V_SDZIP)
                         @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMPROV", V_SDPROV)
                         @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMCNTR", V_SDCNTR)
                         @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "char(EMPHON)", V_SDPHON)
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @DateBirthFromCYMD(V_SDDOB)
                      @dtw_assign(focusField, "socialSecurityNo")
                  %else
                      @DateBirthFromCYMD(V_SDDOB)
                      @dtw_assign(focusField, "lastName")
                  %endif


                  @SetTextOvr(Err_SDSSN)
                  %if (maintenanceCode == "C")
                  @RtvColVal("SDCOMP = $(prCompany) and SDFACL = $(prFacility) and SDEMPL = $(hrEmployee) and SDSPDP = $(dependentNbr)", "HRSPDP", "(SDSSN)", "D", xsocsec) 
                  @dtw_assign(V_SDSSN, xsocsec)
                  
                  %endif
                  @SetTextOvr(Err_SDTSTP)
                  <tr><td class="dsphdr"><span $(textOvr)>.</span></td>
                  	  <td><input name="timeStamp" type="hidden" value="$(V_SDTSTP)"></td> 
                  </tr>
                  @DspErrMsg(Err_SDTSTP)
                  
                  <tr><td class="dsphdr"><span $(textOvr)>Social Security Number</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z" || maintenanceCode == "C")
                          <td class="inputnmbr"><input name="socialSecurityNo" type="text" value="$(V_SDSSN)" size="9" maxlength="9"></td>
                      %else
          	
          	      @Format_SSN(V_SDSSN, F_SDSSN)
                         
                          <td class="inputnmbr"><input name="socialSecurityNo" type="hidden" value="$(V_SDSSN)" size="9" maxlength="9">$(F_SDSSN)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_SDSSN)

                  @SetTextOvr(Err_SDSSSF)
                  <tr><td class="dsphdr"><span $(textOvr)>Social Security Suffix</span></td>
                      <td class="inputalph"><input name="socialSecuritySuffix" type="text" value="$(V_SDSSSF)" size="1" maxlength="1"></td>
                  </tr>
                  @DspErrMsg(Err_SDSSSF)

                  @SetTextOvr(Err_SDLNAM)
                  <tr><td class="dsphdr"><span $(textOvr)>Last Name</span></td>
                      <td class="inputalph"><input name="lastName" type="text" value="$(V_SDLNAM)" size="18" maxlength="18"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_SDLNAM)

                  @SetTextOvr(Err_SDFNAM)
                  <tr><td class="dsphdr"><span $(textOvr)>First Name</span></td>
                      <td class="inputalph"><input name="firstName" type="text" value="$(V_SDFNAM)" size="18" maxlength="18"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_SDFNAM)

                  @SetTextOvr(Err_SDMIDI)
                  <tr><td class="dsphdr"><span $(textOvr)>Middle Initial</span></td>
                      <td class="inputalph"><input name="middleInitial" type="text" value="$(V_SDMIDI)" size="1" maxlength="1"></td>
                  </tr>
                  @DspErrMsg(Err_SDMIDI)

                  @SetTextOvr(Err_SDADR1)
                  <tr><td class="dsphdr"><span $(textOvr)>Address Line 1</span></td>
                      <td class="inputalph"><input name="address1" type="text" value="$(V_SDADR1)" size="30" maxlength="30"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_SDADR1)

                  @SetTextOvr(Err_SDADR2)
                  <tr><td class="dsphdr"><span $(textOvr)>Address Line 2</span></td>
                      <td class="inputalph"><input name="address2" type="text" value="$(V_SDADR2)" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_SDADR2)

                  @SetTextOvr(Err_SDCITY)
                  <tr><td class="dsphdr"><span $(textOvr)>City</span></td>
                      <td class="inputalph"><input name="city" type="text" value="$(V_SDCITY)" size="18" maxlength="18"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_SDCITY)

                  @RtvFldDesc("STID='$(V_SDSTAT)'", "HDSTID", "STDESC", fieldDesc)
                  @SetTextOvr(Err_SDSTAT)
                  <tr><td class="dsphdr"><span $(textOvr)>State</span></td>
                      <td class="inputalph"><input name="state" type="text" value="$(V_SDSTAT)" size="3" maxlength="2"><a href="$(homeURL)$(phpPath)StateSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=state&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stateDesc" value="$(fieldDesc)" type="text" size="35" disabled> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_SDSTAT)

                  @SetTextOvr(Err_SDPROV)
                  <tr><td class="dsphdr"><span $(textOvr)>Canadian Province</span></td>
                      @dtw_tb_rows(provinceTable, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(provinceTable, x, "1") != V_SDPROV) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(provinceTable, "province", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_SDPROV)

                  @SetTextOvr(Err_SDZIP)
                  <tr><td class="dsphdr"><span $(textOvr)>Zip Code</span></td>
                      <td class="inputalph"><input name="zipCode" type="text" value="$(V_SDZIP)" size="10" maxlength="10"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_SDZIP)

                  @SetTextOvr(Err_SDCNTR)
                  <tr><td class="dsphdr"><span $(textOvr)>Country</span></td>
                      @dtw_tb_rows(prCountryCodeTable, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(prCountryCodeTable, x, "1") != V_SDCNTR) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(prCountryCodeTable, "country", "2", "1", "N", "", x, "1") $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_SDCNTR)

                  @SetTextOvr(Err_SDPHON)
                  <tr><td class="dsphdr"><span $(textOvr)>Home Phone Number</span></td>
                      <td class="inputnmbr"><input name="homePhoneNumber" type="text" value="$(V_SDPHON)" size="10" maxlength="10"></td>
                  </tr>
                  @DspErrMsg(Err_SDPHON)

                  @SetTextOvr(Err_SDDOB)
                  <tr><td class="dsphdr"><span $(textOvr)>Date Of Birth</span></td>
                      <td class="inputnmbr"><input name="dateOfBirth" type="text" value="$(V_SDDOB)" size="6" maxlength="6"> $(reqFieldChar)
                          <a href="javascript:calWindow('dateOfBirth');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_SDDOB)

                  @SetTextOvr(Err_SDCLAS)
                  <tr><td class="dsphdr"><span $(textOvr)>Classification</span></td>
                      @dtw_tb_rows(classificationTable, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(classificationTable, x, "1") != V_SDCLAS) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(classificationTable, "classification", "2", "1", "N", "", x, "1") $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_SDCLAS)

                  @SetTextOvr(Err_SDREL)
                  <tr><td class="dsphdr"><span $(textOvr)>Relationship</span></td>
                      <td class="inputalph"><input name="relationship" type="text" value="$(V_SDREL)" size="8" maxlength="8"></td>
                  </tr>
                  @DspErrMsg(Err_SDREL)

                  @SetTextOvr(Err_SDGNDR)
                  <tr><td class="dsphdr"><span $(textOvr)>Gender</span></td>
                      @dtw_tb_rows(genderTable, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(genderTable, x, "1") != V_SDGNDR) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(genderTable, "gender", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_SDGNDR)
                  
                  <tr><td><input name="timeStamp" type="hidden" value="$(V_SDTSTP)"></td></tr>
              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,
                                        INOUT CHAR(32000) errVar)
{%EXEC {HPESDU_W.PGM %}
%}

%HTML(EMPLDEPENDENTS) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F" || sec_05 == "N")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Province_Query(profileHandle, dataBaseID, "PROVINCE  ", provinceTable)
      @PrCountryCode_Query(profileHandle, dataBaseID, prCountryCodeTable)
          @dtw_tb_insertrow(prCountryCodeTable, "0", "1")
	   @dtw_tb_setv(prCountryCodeTable, "", "1", "2")
      @Classification_Query(profileHandle, dataBaseID, "DEPCLASS  ", classificationTable)
          @dtw_tb_insertrow(classificationTable, "0", "1")
	   @dtw_tb_setv(classificationTable, "", "1", "2")
      @Gender_Query(profileHandle, dataBaseID, "GENDER    ", genderTable)
          @dtw_tb_insertrow(genderTable, "0", "1")
	   @dtw_tb_setv(genderTable, "", "1", "2")
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(state)
  @dtw_mUPPERCASE(middleInitial)
  @dtw_mUPPERCASE(socialSecuritySuffix)

  @dtw_assign(socialSecurityNo,@dtw_rstrip(socialSecurityNo))
  @dtw_assign(homePhoneNumber,@dtw_rstrip(homePhoneNumber))
  @dtw_assign(dateOfBirth,@dtw_rstrip(dateOfBirth))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
      @dtw_assign(dependentNbr, "0")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@comp", prCompany)
  @Concat_Field("@@facl", prFacility)
  @Concat_Field("@@empl", hrEmployee)
  @Concat_Field("@@pecp", hrCompany)
  @Concat_Field("@@ssn@", socialSecurityNo)
  @Concat_Field("@@ss@@", timeStamp)
  @Concat_Field("@@sssf", socialSecuritySuffix)
  @Concat_Field("@@lnam", lastName)
  @Concat_Field("@@fnam", firstName)
  @Concat_Field("@@midi", middleInitial)
  @Concat_Field("@@adr1", address1)
  @Concat_Field("@@adr2", address2)
  @Concat_Field("@@city", city)
  @Concat_Field("@@stat", state)
  @Concat_Field("@@prov", province)
  @Concat_Field("@@zip@", zipCode)
  @Concat_Field("@@cntr", country)
  @Concat_Field("@@phon", homePhoneNumber)
  @Concat_Field("@@dob@", dateOfBirth)
  @Concat_Field("@@clas", classification)
  @Concat_Field("@@rel@", relationship)
  @Concat_Field("@@gndr", gender)

  %if (maintenanceCode != "A")
      @Concat_Field("@@spdp", dependentNbr)
  %endif
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)
  @DecatErr_Field("@@ss@@", "timeStamp")  @dtw_assign(Err_SDTSTP,  fieldValue)
  
  @Format_EmplName(firstName, lastName, middleInitial, "", "", "D", F_dependentName)
  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(F_dependentName), $(relationship), "", "", "", "", confMessage)
      %if (maintenanceCode == "D")
          %if ((fromD2w != "") && (fromD2w != "EmplDependentsSelect.d2w"))
              <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %else
              <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)emplDependents.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %endif
      %elif (fromD2w != "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)emplDependents.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %elif ((maintenanceCode == "C" || maintenanceCode == "D") && errFound != "" && fieldValue != "")
      @Format_ConfMsg_Desc("E", $(F_dependentName), $(relationship), "<br>$(fieldValue)", "", "", "", confMessage)
      %if (fromD2w != "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)emplDependents.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/EMPLDEPENDENTS$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif

%}
