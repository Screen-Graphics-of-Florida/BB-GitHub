%INCLUDE "$(baseVar)"
%INCLUDE "$(catalogVarName)"
%INCLUDE "BrowserType.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Ship Product To"
  d2wName                 = "ProdCatalogShipTo.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;catalogVarName=@dtw_rurlescseq(catalogVarName)&amp;catalog=@dtw_rurlescseq(catalog)&amp;catalogDesc=@dtw_rurlescseq(catalogDesc)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
  retrieveCode            = "R"
  vendCustFlag            = "C"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.dropShipName.value =="" ||
                      document.Chg.addressLineOne.value =="" ||
                      document.Chg.city.value =="" ||
                      document.Chg.zip.value =="" ||
                      (document.Chg.referenceNumber.value =="" && document.Chg.refNbrReq.value =="Y"))
                         {alert("$(reqFieldError)");
                          return false;}
                      return true;
              }
              function confirmDeleteCC() {
                      return confirm("Confirm Removal Of Credit Card Payment")
              }
              function confirmAccept() {
                      return confirm("Continue With Checkout?")
              }
              function confirmCancel() {
                      return confirm("Confirm Cancel Of Order")
              }
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(catBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      @dtw_assign(stmtSQL, "")
                      @dtw_concat(stmtSQL, "Select * From OECATO Where OOXHND = '$(profileHandle)' ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Ship_To_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(catTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Ship_To_Query (IN CHAR(64)    profileHandle,
                                     CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              @dtw_assign(edtVar, "")
              @Order_Control(profileHandle, dataBaseID, orderControlNumber, retrieveCode, dropShip, edtVar)
              @RtvFldDesc("O1OCTL=$(orderControlNumber) and O1BLN#=0", "OEDTWK", " char(count(O1ITEM))", numberOfItems)
              @RtvFldDesc("H1OCTL=$(orderControlNumber)", "OEHDWK", "char(H1OTOT)", orderTotal)
              @Format_Nbr(numberOfItems, F_numberOfItems, "0", "3", "", "", "")
              @Format_Nbr(orderTotal, F_orderTotal, "2", $(amtEditCode), "", "$", "")
              <td class="toolbar">
                  <table $(contentTable)>
                      @Format_Header("Item Count", $(F_numberOfItems), "")
                      @Format_Header("Order Total", $(F_orderTotal), "")
                  </table>
              </td>
              <td class="toolbar">
                  <a href="$(homeURL)$(cGIPath)ProdCatalogViewCart.d2w/VIEW$(d2wVarBase)">$(selectBackImage)</a>
                  <a href="javascript:check(document.Chg)">$(orderContinueImage)</a>
                  %INCLUDE "CloseWindow.icl"
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
                  <a onClick="return confirmCancel()" href="$(homeURL)$(cGIPath)$(d2wName)/CANCEL$(d2wVarBase)">$(orderCancelImage)</a>
                  &nbsp;
              </td>
          </tr>
      </table>

      %ROW {
          $(cathrTagAttr)

          <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return (editChg())"
              ACTION="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)">

              <table $(contentTable)>

                  <tr><td class="dsphdr">Name</td>
                      <td class="inputalph"><input name="dropShipName" type="text" value="$(V_OONAME)" size="30" maxlength="30"> $(reqFieldChar) </td>
                      <td>%INCLUDE "RequiredField.icl"</td>
                  </tr>

                  <tr><td class="dsphdr">Address Line One</td>
                      <td class="inputalph"><input name="addressLineOne" type="text" value="$(V_OOADR1)" size="30" maxlength="30"> $(reqFieldChar) </td></tr>

                  <tr><td class="dsphdr">Address Line Two</td>
                      <td class="inputalph"><input type="text" name="addressLineTwo" value="$(V_OOADR2)" size="30" maxlength="30"></td></tr>
    				
                  <tr><td class="dsphdr">Address Line Three</td>
                      <td class="inputalph"><input type="text" name="addressLineThree" value="$(V_OOADR3)" size="30" maxlength="30"></td></tr>

                  <tr><td class="dsphdr">City</td>
                      <td class="inputalph"><input type="text" name="city" value="$(V_OOCITY)" size="26" maxlength="26"> $(reqFieldChar) </td></tr>

                  @RtvFldDesc("STID='$(V_OOST)'", "HDSTID", "STDESC", fieldDesc)
                  <tr><td class="dsphdr"><span $(textOvr)>State</span></td>
                      <td class="inputalph"><input name="state" type="text" value="$(V_OOST)" size="3" maxlength="2"><a href="$(homeURL)$(phpPath)StateSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=state&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stateDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>

                  <tr><td class="dsphdr">Zip</td>
                      <td class="inputalph"><input type="text" name="zip" value="$(V_OOZIP)" size="13" maxlength="13"> $(reqFieldChar) </td></tr>

                  @RtvFldDesc("CNCTCD='$(V_OOCTRY)'", "HDCTRY", "CNCDES", fieldDesc)
                  <tr><td class="dsphdr"><span $(textOvr)>Country</span></td>
                      <td class="inputalph"><input name="country" type="text" value="$(V_OOCTRY)" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)CountrySearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=country&amp;fldDesc=countryDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="countryDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>

                  <tr><td class="dsphdr">Phone Number</td>
                      <td class="inputnmbr"><input type="text" name="phoneNumber" value="$(V_OOPHON)" size="11" maxlength="11"></td></tr>

                  <tr>
	               <td class="dsphdr">$(refNbrDesc)</td>
                      <td class="inputalph"><input type="text" name="referenceNumber" value="$(V_OOORRF)" size="22" maxlength="22">
                          %if (refNbrReq=="Y")
                              $(reqFieldChar)
                          %endif
                      </td>
                      <td><input type="hidden" name="refNbrReq" value="$(refNbrReq)"></td>
                  </tr>

                  <tr>
	               <td class="dsphdr">E-mail Address</td>
                      <td class="inputalph"><input type="text" name="emailAddress" value="$(V_OOEMAL)" size="60" maxlength="60">
                  </tr>
              </table>
          </form>
      %}
      $(cathrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(state)
  @dtw_mUPPERCASE(zip)
  @dtw_mUPPERCASE(country)
  @dtw_assign(phoneNumber,@dtw_rstrip(phoneNumber))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@name", dropShipName)
  @Concat_Field("@@adr1", addressLineOne)
  @Concat_Field("@@adr2", addressLineTwo)
  @Concat_Field("@@adr3", addressLineThree)
  @Concat_Field("@@city", city)
  @Concat_Field("@@st@@", state)
  @Concat_Field("@@zip@", zip)
  @Concat_Field("@@ctry", country)
  @Concat_Field("@@phon", phoneNumber)
  @Concat_Field("@@orrf", referenceNumber)
  @Concat_Field("@@emal", emailAddress)
  @Concat_Field("@@anon", "$(AnonymousUser)")
  @dtw_concat(edtVar, "}{", edtVar)

  @DTW_ASSIGN(maintenanceCode, "U")
  @Order_Control(profileHandle, dataBaseID, orderControlNumber, maintenanceCode, dropShip, edtVar)
  @DTW_ASSIGN(updateTotal, "Y")
  @Update_Misc_Charges (profileHandle, dataBaseID, orderControlNumber, freightCharge, specialCharge, updateTotal)
  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ProdCatalogPayment.d2w/ENTRY$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(CANCEL) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(maintenanceCode, "D")
  @Order_Control(profileHandle, dataBaseID, orderControlNumber, maintenanceCode, dropShip, edtVar)
  @dtw_assign(edtVar, "")
  @Concat_Field("@@octl", orderControlNumber)
  @Concat_Field("@@rmcc", "Y")
  @dtw_concat(edtVar, "}{", edtVar)
  @Update_Credit_Card(profileHandle, dataBaseID, errFound, edtVar, errVar)
  @DTW_ASSIGN(confMessage, "Confirm Cancel Of Order")
  @Process_Order (profileHandle, dataBaseID, orderControlNumber, orderNumber, maintenanceCode)

  @BrowserType(browserCode)
  %if (browserCode == "IE")
      <script TYPE="text/javascript">
          opener.location.href='$(homeURL)$(cGIPath)ProdCatalog.d2w/REPORT$(d2wVarBase)';
          window.close();
      </script>
  %else
      <meta http-equiv="refresh" content="0; URL=javascript:opener.document.location='$(homeURL)$(cGIPath)ProdCatalog.d2w/REPORT$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))';self.close();">
  %endif
%}