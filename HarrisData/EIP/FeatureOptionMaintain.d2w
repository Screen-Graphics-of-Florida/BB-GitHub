%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_titlef             = "Feature Option Maintenance"
  page_titleb             = "Bi-Level Option Maintenance"
  d2wName                 = "FeatureOptionMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;selectPlant=@dtw_rurlescseq(selectPlant)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;feature=@dtw_rurlescseq(feature)&amp;featuredItem=@dtw_rurlescseq(featuredItem)&amp;featureDesc=@dtw_rurlescseq(featureDesc)&amp;maintenanceCodeFB=@dtw_rurlescseq(maintenanceCodeFB)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;optionItem=@dtw_rurlescseq(optionItem)&amp;subSequence=@dtw_rurlescseq(subSequence)&amp;maintenanceCode=D"
  programName             = "HPDFOM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  function validate(chgForm) {
                      if (document.Chg.optionItem.value =="")
                         {alert("$(reqFieldError)");
                          return false;}
                      if (editNum(document.Chg.extraCharge, 4, 5))
                          return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
	           %INCLUDE "NumEdit.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "FEATUREOPTIONMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "Select * From HDMFOW", stmtSQL)
                              @dtw_concat(stmtSQL, " Where WKPLT = $(plantNumber)", stmtSQL)
                              @dtw_concat(stmtSQL, " and WKFPRT = '$(featuredItem)'", stmtSQL)
                              @dtw_concat(stmtSQL, " and WKFEAT = '$(feature)'", stmtSQL)
                              @dtw_concat(stmtSQL, " and WKXHND = '$(profileHandle)'", stmtSQL)
                              @dtw_concat(stmtSQL, " and WKOPTN = '$(optionItem)'", stmtSQL)
                              @dtw_concat(stmtSQL, " and WKSSEQ =  $(subSequence)", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      @RtvFldDesc("FOPLT=$(plantNumber) and FOOPTN='$(feature)'", "HDMFOP","FOBLOP", biLevel)
      <table $(contentTable)>
    	   <colgroup>
    	       <col width="80%">
    	       <col width="15%">
          <tr>
              <td>
                  %if (biLevel == "Y")
                      <h1>$(page_titleb)</h1>
                  %else
                      <h1>$(page_titlef)</h1>
                  %endif
              </td>
              <td class="toolbar">
                 %INCLUDE "MaintainTopNoTable.icl"
              </td>
          </tr>
      </table>

      <table $(contentTable)>
          @Format_Header("Plant", $(plantName), $(plantNumber))
          %if (biLevel == "Y")
              @Format_Header("Bi-Level", $(featureDesc), $(feature))
          %else
              @Format_Header("Feature", $(featureDesc), $(feature))
          %endif
          %if (featuredItem !="")
              @dtw_assign(itemDesc, "")
              @RtvFldDesc("IMITEM='$(featuredItem)'", "HDIMST", "IMIMDS", itemDesc)
              %if (itemDesc =="")
                  @RtvFldDesc("IGTYPE='F' and IGIGRP='$(featuredItem)' and IGPLT=$(plantNumber)", "HDIGPH", "IGDESC", itemDesc)
              %endif
              @Format_Header("Featured Item/Family", $(itemDesc), $(featuredItem))
          %endif
      </table>

      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "optionItem")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@plt@", "plantNumber")         @dtw_assign(Err_WKPLT,   fieldValue)
                          @DecatErr_Field("@@feat", "feature")             @dtw_assign(Err_WKFEAT,  fieldValue)
                          @DecatErr_Field("@@fprt", "featuredItem")        @dtw_assign(Err_WKFPRT,  fieldValue)
                          @DecatErr_Field("@@optn", "optionItem")          @dtw_assign(Err_WKOPTN,  fieldValue)
                          @DecatErr_Field("@@xchg", "extraCharge")         @dtw_assign(Err_WKXCHG,  fieldValue)
                          @DecatErr_Field("@@xflg", "extraChargeFlag")     @dtw_assign(Err_WKXFLG,  fieldValue)
                          @DecatErr_Field("@@dflt", "defaultOption")       @dtw_assign(Err_WKDFLT,  fieldValue)
                          @DecatErr_Field("@@blop", "bilevelOption")       @dtw_assign(Err_WKBLOP,  fieldValue)
                          @DecatErr_Field("@@dblo", "defaultBLOption")     @dtw_assign(Err_WKDBLO,  fieldValue)
                          @DecatErr_Field("@@seg1", "smartPartSeg1")       @dtw_assign(Err_WKSEG1,  fieldValue)
                          @DecatErr_Field("@@spc1", "smartPartCod1")       @dtw_assign(Err_WKSPC1,  fieldValue)
                          @DecatErr_Field("@@seg2", "smartPartSeg2")       @dtw_assign(Err_WKSEG2,  fieldValue)
                          @DecatErr_Field("@@spc2", "smartPartCod2")       @dtw_assign(Err_WKSPC2,  fieldValue)
                          @DecatErr_Field("@@seg3", "smartPartSeg3")       @dtw_assign(Err_WKSEG3,  fieldValue)
                          @DecatErr_Field("@@spc3", "smartPartCod3")       @dtw_assign(Err_WKSPC3,  fieldValue)
                          @DecatErr_Field("@@seg4", "smartPartSeg4")       @dtw_assign(Err_WKSEG4,  fieldValue)
                          @DecatErr_Field("@@spc4", "smartPartCod4")       @dtw_assign(Err_WKSPC4,  fieldValue)
                          @DecatErr_Field("@@seg5", "smartPartSeg5")       @dtw_assign(Err_WKSEG5,  fieldValue)
                          @DecatErr_Field("@@spc5", "smartPartCod5")       @dtw_assign(Err_WKSPC5,  fieldValue)
                      %endif
                      @Decat_Field("@@plt@")   @dtw_assign(V_WKPLT,  fieldValue)
                      @Decat_Field("@@feat")   @dtw_assign(V_WKFEAT, fieldValue)
                      @Decat_Field("@@fprt")   @dtw_assign(V_WKFPRT, fieldValue)
                      @Decat_Field("@@optn")   @dtw_assign(V_WKOPTN, fieldValue)
                      @Decat_Field("@@sseq")   @dtw_assign(V_WKSSEQ, fieldValue)
                      @Decat_Field("@@xchg")   @dtw_assign(V_WKXCHG, fieldValue)
                      @Decat_Field("@@xflg")   @dtw_assign(V_WKXFLG, fieldValue)
                      @Decat_Field("@@dflt")   @dtw_assign(V_WKDFLT, fieldValue)
                      @Decat_Field("@@blop")   @dtw_assign(V_WKBLOP, fieldValue)
                      @Decat_Field("@@dblo")   @dtw_assign(V_WKDBLO, fieldValue)
                      @Decat_Field("@@seg1")   @dtw_assign(V_WKSEG1, fieldValue)
                      @Decat_Field("@@spc1")   @dtw_assign(V_WKSPC1, fieldValue)
                      @Decat_Field("@@seg2")   @dtw_assign(V_WKSEG2, fieldValue)
                      @Decat_Field("@@spc2")   @dtw_assign(V_WKSPC2, fieldValue)
                      @Decat_Field("@@seg3")   @dtw_assign(V_WKSEG3, fieldValue)
                      @Decat_Field("@@spc3")   @dtw_assign(V_WKSPC3, fieldValue)
                      @Decat_Field("@@seg4")   @dtw_assign(V_WKSEG4, fieldValue)
                      @Decat_Field("@@spc4")   @dtw_assign(V_WKSPC4, fieldValue)
                      @Decat_Field("@@seg5")   @dtw_assign(V_WKSEG5, fieldValue)
                      @Decat_Field("@@spc5")   @dtw_assign(V_WKSPC5, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(V_WKOPTN, "")
                          @dtw_assign(V_WKSSEQ, "0000")
                          @dtw_assign(V_WKDFLT, "N")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_WKOPTN, "")
                      @dtw_assign(V_WKSSEQ, "0000")
                      @dtw_assign(focusField, "optionItem")
                  %else
                      @dtw_assign(focusField, "defaultOption")
                  %endif

                  %if (biLevel != "Y" && V_WKBLOP == "Y")
                      @RtvFldDesc("FOPLT=$(plantNumber) and FOFEAT='$(V_WKOPTN)'", "HDMFOP", "FOFDSC", optionDesc)
                  %else
                      @RtvFldDesc("IMITEM='$(V_WKOPTN)'", "HDIMST", "IMIMDS", optionDesc)
                  %endif
                  @SetTextOvr(Err_WKOPTN)
                  <tr><td class="dsphdr"><span $(textOvr)>Option</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="optionItem" type="text" value="$(V_WKOPTN)" size="15" maxlength="15"> $(reqFieldChar)
                          %if (biLevel != "Y")
                              @dtw_assign(searchTitle, "Item Plant")
                          %endif
                          <a href="$(homeURL)$(cGIPath)itemplantsearch.d2w/ENTRY$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;docName=Chg&amp;fldName=optionItem&amp;fldDesc=optionDesc" onclick="$(searchWinVar)">  $(searchImage) </a>
                          %if (biLevel != "Y")
                              /
                              @dtw_assign(searchTitle, "Bi-Level Option")
                              <a href="$(homeURL)$(cGIPath)OptionSearch.d2w/ENTRY$(genericVarBase)&amp;forPlant=@dtw_rurlescseq(plantNumber)&amp;includeBiLevels=O&amp;docName=Chg&amp;fldName=optionItem&amp;fldDesc=optionDesc" onclick="$(searchWinVar)">  $(searchImage) </a>
                          %endif
                          <input disabled name="optionDesc" value="$(optionDesc)"  type="text" size="30" maxlength="30"></td>
                      %else
                          <td class="inputalph"><input name="optionItem" type="hidden" value="$(V_WKOPTN)">$(V_WKOPTN) &nbsp; $(V_WKODSC) <input name="subSequence" type="hidden" value="$(V_WKSSEQ)"></td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_WKOPTN)

                  @SetTextOvr(Err_WKDFLT)
                  <tr><td class="dsphdr"><span $(textOvr)>Default</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_WKDFLT) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "defaultOption", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_WKDFLT)

                  @Default_Zero(V_WKXCHG)    	
                  @SetTextOvr(Err_WKXCHG)
                  <tr><td class="dsphdr"><span $(textOvr)>Extra Charge</span></td>
                      <td class="inputnmbr"><input name="extraCharge" type="text" value="$(V_WKXCHG)" size="10" maxlength="10"></td>
                  </tr>
                  @DspErrMsg(Err_WKXCHG)

                  @SetTextOvr(Err_WKXFLG)
                  <tr><td class="dsphdr"><span $(textOvr)>Percent</span></td>
                      @dtw_tb_rows(yn02Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn02Table, x, "1") != V_WKXFLG) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn02Table, "extraChargeFlag", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_WKXFLG)

                  %if (biLevel != "Y")
                      @SetTextOvr(Err_WKBLOP)
                      <tr><td class="dsphdr"><span $(textOvr)>Bi-Level</span></td>
                          @dtw_tb_rows(yn03Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn03Table, x, "1") != V_WKBLOP) && (x < maxRows))
                              {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(yn03Table, "bilevelOption", "2", "1", "N", "", x, "1")</td>
                      </tr>
                      @DspErrMsg(Err_WKBLOP)
    	     
                      @RtvFldDesc("IMITEM='$(V_WKDBLO)'", "HDIMST", "IMIMDS", defaultOptionDsc)
                      @SetTextOvr(Err_WKDBLO)
                      <tr><td class="dsphdr"><span $(textOvr)>Default Bi-Level Option</span></td>
                          <td class="inputalph"><input name="defaultBLOption" type="text" value="$(V_WKDBLO)" size="15" maxlength="15"> 
                          @dtw_assign(searchTitle, "Bi-Level Option")
                          <a href="$(homeURL)$(cGIPath)OptionSearch.d2w/ENTRY$(genericVarBase)&amp;forPlant=@dtw_rurlescseq(plantNumber)&amp;includeBiLevels=N&amp;docName=Chg&amp;fldName=defaultBLOption&amp;fldDesc=defaultOptionDsc" onclick="$(searchWinVar)">  $(searchImage) </a>
                          <input disabled name="defaultOptionDsc" value="$(defaultOptionDsc)"  type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_WKDBLO)
    	           %endif

                  %if (V_CIUSMP == "Y")		
                      <tr><td class="dsphdr"><span $(textOvr)>Smart Part</span></td>
                          <td>
                              <table $(contentTable)>
                                 <tr><td class="colhdr">Segment</td><td class="colhdr">Code</td></tr>

                      @SetTextOvr(Err_IXSEG1)
                      <tr>
                          @dtw_assign(cnt, "0")
                          <td class="inputalph">
                              <select class="page" name="smartPartSeg1">
                                  %while(@dtw_rformat(cnt, "2", "1") <= "99"){
                                      %if (cnt == V_WKSEG1)
                                          <option value="$(cnt)" SELECTED>$(cnt)
                                      %else
                                          <option value="$(cnt)">$(cnt)
                                      %endif
                                      @dtw_add(cnt, "1", cnt)
                                  %}
                              </select>
                          </td>
                          <td class="inputalph"><input name="smartPartCod1" type="text" value="$(V_WKSPC1)" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_IXSEG1)

                      @SetTextOvr(Err_IXSEG2)
                      <tr>
                          @dtw_assign(cnt, "0")
                          <td class="inputalph">
                              <select class="page" name="smartPartSeg2">
                                  %while(@dtw_rformat(cnt, "2", "1") <= "99"){
                                      %if (cnt == V_WKSEG2)
                                          <option value="$(cnt)" SELECTED>$(cnt)
                                      %else
                                          <option value="$(cnt)">$(cnt)
                                      %endif
                                      @dtw_add(cnt, "1", cnt)
                                  %}
                              </select>
                          </td>
                          <td class="inputalph"><input name="smartPartCod2" type="text" value="$(V_WKSPC2)" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_IXSEG2)

                      @SetTextOvr(Err_IXSEG3)
                      <tr>
                          @dtw_assign(cnt, "0")
                          <td class="inputalph">
                              <select class="page" name="smartPartSeg3">
                                  %while(@dtw_rformat(cnt, "2", "1") <= "99"){
                                      %if (cnt == V_WKSEG3)
                                          <option value="$(cnt)" SELECTED>$(cnt)
                                      %else
                                          <option value="$(cnt)">$(cnt)
                                      %endif
                                      @dtw_add(cnt, "1", cnt)
                                  %}
                              </select>
                          </td>
                          <td class="inputalph"><input name="smartPartCod3" type="text" value="$(V_WKSPC3)" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_IXSEG3)

                      @SetTextOvr(Err_IXSEG4)
                      <tr>
                          @dtw_assign(cnt, "0")
                          <td class="inputalph">
                              <select class="page" name="smartPartSeg4">
                                  %while(@dtw_rformat(cnt, "2", "1") <= "99"){
                                      %if (cnt == V_WKSEG4)
                                          <option value="$(cnt)" SELECTED>$(cnt)
                                      %else
                                          <option value="$(cnt)">$(cnt)
                                      %endif
                                      @dtw_add(cnt, "1", cnt)
                                  %}
                              </select>
                          </td>
                          <td class="inputalph"><input name="smartPartCod4" type="text" value="$(V_WKSPC4)" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_IXSEG4)

                      @SetTextOvr(Err_IXSEG5)
                      <tr>
                          @dtw_assign(cnt, "0")
                          <td class="inputalph">
                              <select class="page" name="smartPartSeg5">
                                  %while(@dtw_rformat(cnt, "2", "1") <= "99"){
                                      %if (cnt == V_WKSEG5)
                                          <option value="$(cnt)" SELECTED>$(cnt)
                                      %else
                                          <option value="$(cnt)">$(cnt)
                                      %endif
                                      @dtw_add(cnt, "1", cnt)
                                  %}
                              </select>
                          </td>
                          <td class="inputalph"><input name="smartPartCod5" type="text" value="$(V_WKSPC5)" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_IXSEG5)
                      </table>
                      </td>

                  %endif
              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar,
                                        INOUT CHAR(10)    SUBR)

{%EXEC {HPDFOM_W.PGM %}
%}

%FUNCTION(dtw_directcall) Validate_Add(INOUT CHAR(64)    profileHandle,
                                       INOUT CHAR(2)     dataBaseID,
                                       INOUT CHAR(1)     maintCode,
                                       INOUT CHAR(1)     errFound,
                                       INOUT CHAR(32000) edtVar,                             	
                                       INOUT CHAR(32000) errVar,
                                       INOUT CHAR(10)    SUBR)

{%EXEC {HPDFOM_W.PGM %}
%}

%FUNCTION(dtw_directcall) Validate_Chg(INOUT CHAR(64)    profileHandle,
                                       INOUT CHAR(2)     dataBaseID,
                                       INOUT CHAR(1)     maintenanceCodeFB,
                                       INOUT CHAR(1)     errFound,
                                       INOUT CHAR(32000) edtVar,                             	
                                       INOUT CHAR(32000) errVar,
                                       INOUT CHAR(10)    SUBR)

{%EXEC {HPDFOM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      @RtvFldDesc("FOPLT=$(plantNumber) and FOOPTN='$(feature)'", "HDMFOP","FOBLOP", biLevel)

      %if (biLevel == "Y")
          @dtw_assign(page_title, page_titleb)
      %else
          @dtw_assign(page_title, page_titlef)
      %endif
      %INCLUDE "ProgSecurityError.icl"
  %else
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @yn02_Table_Query(profileHandle, dataBaseID, "BY        ", yn02Table)
	   @dtw_tb_insertrow(yn02Table, "2", "1")
	   @dtw_tb_setv(yn02Table, "F", "3", "1")
	   @dtw_tb_setv(yn02Table, "Fixed", "3", "2")
      @yn03_Table_Query(profileHandle, dataBaseID, "BY        ", yn03Table)

      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(ADD) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterAdd.icl"
              %INCLUDE "Menu.js"
              function validate(addForm) {
                  if (document.Add.plantNumber.value =="" ||
                      document.Add.feature.value =="" ||
                      document.Add.featureDesc.value =="")
                     {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Add.plantNumber, 3, 0))
                  return true;
              }
	       %INCLUDE "NumEdit.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterAdd()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "FEATUREOPTIONMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      <table $(contentTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1>Add Feature</h1></td>
                              <td class="toolbar">
                                  %if (sec_01 == "Y")
                                      <a href="javascript:check(document.Add)">$(acceptImageMed)</a>
                                  %endif
                                  <a href="javascript:history.back()">$(cancelImageMed)</a>
                                  @dtw_assign(medIcon, "Y")
                                  %INCLUDE "HelpPage.icl"
                              </td>
                          </tr>
                      </table>

                      $(hrTagAttr)
                      %INCLUDE "RequiredField.icl"
                      %INCLUDE "ErrorDisplay.icl"

                      <form class="formClass" METHOD=POST name=Add ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Add$(d2wVarBase)&amp;fromPlant=@dtw_rurlescseq(fromPlant)&amp;fromFeature=@dtw_rurlescseq(fromFeature)&amp;fromFeaturedItem=@dtw_rurlescseq(fromFeaturedItem)">
                          <table $(contentTable)>
                              %if (errFound != "" || maintenanceCodeFB == "A")
                                  %if (errFound == "" && maintenanceCodeFB == "A")
                                      @dtw_assign(edtVar, "")
                                      @dtw_assign(focusField, "plantNumber")
                                  %else
                                      @dtw_assign(focusField, "")
                                      @EdtVarErr(profileHandle, typeValue, edtVar)
                                      @ErrVarErr(profileHandle, typeError, errVar)
                                      @DecatErr_Field("@@plt@", "plantNumber")  @dtw_assign(Err_WKPLT,  fieldValue)
                                      @DecatErr_Field("@@feat", "feature")      @dtw_assign(Err_WKFEAT, fieldValue)
                                      @DecatErr_Field("@@fprt", "featuredItem") @dtw_assign(Err_WKFPRT, fieldValue)
                                      @DecatErr_Field("@@fdsc", "featureDesc")  @dtw_assign(Err_WKFDSC, fieldValue)
                                  %endif

                                  @Decat_Field("@@plt@")   @dtw_assign(V_WKPLT,  fieldValue)
                                  @Decat_Field("@@feat")   @dtw_assign(V_WKFEAT, fieldValue)
                                  @Decat_Field("@@fprt")   @dtw_assign(V_WKFPRT, fieldValue)
                                  @Decat_Field("@@fdsc")   @dtw_assign(V_WKFDSC, fieldValue)

                                  %if (errFound == "" && maintenanceCodeFB == "A")
                                      %if (selectPlant > "0")
                                          @dtw_assign(V_WKPLT, selectPlant)
                                      %else
                                          @RtvDftPlant(V_WKPLT, plantName)
                                      %endif
                                      %if (V_WKPLT > "0")
                                          @dtw_assign(focusField, "feature")
                                      %else
                                          @dtw_assign(focusField, "plantNumber")
                                      %endif
                                  %endif

                                  @dtw_assign(errFound, "")

                              %elif (maintenanceCodeFB == "Z")
                                  @dtw_assign(V_WKPLT, fromPlant)
                                  @dtw_assign(V_WKFEAT, "")
                                  @dtw_assign(V_WKFPRT, fromFeaturedItem)
                                  @dtw_assign(V_WKFDSC, "")
                                  @dtw_assign(focusField, "feature")
                              %endif

                              @RtvFldDesc("PLPLNT=$(V_WKPLT)", "HDPLNT", "PLNAME", plantName)
                              @SetTextOvr(Err_WKPLT)
                              <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                  <td class="inputnmbr"><input name="plantNumber" type="text" value="$(V_WKPLT)" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Add&amp;fldName=plantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="plantName" value="$(plantName)" type="text" size="30"></td>
                              </tr>
                              @DspErrMsg(Err_WKPLT)

                              @SetTextOvr(Err_WKFEAT)
	                       <tr><td class="dsphdr"><span $(textOvr)>Feature / Bi-Level</span></td>
                                  <td class="inputalph"><input name="feature" type="text" value="$(V_WKFEAT)" size="15" maxlength="15"> $(reqFieldChar) </td>
                              </tr>
                              @DspErrMsg(Err_WKFEAT)

                              @SetTextOvr(Err_WKFDSC)
	                       <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                                  <td class="inputalph"><input name="featureDesc" type="text" value="$(V_WKFDSC)" size="30" maxlength="30"> $(reqFieldChar) </td>
                              </tr>
                              @DspErrMsg(Err_WKFDSC)

                              @dtw_assign(featuredItemDesc, "")
                              @RtvFldDesc("IMITEM='$(V_WKFPRT)'", "HDIMST", "IMIMDS", featuredItemDesc)
                              %if (featuredItemDesc =="")
                                  @RtvFldDesc("IGTYPE='F' and IGIGRP='$(V_WKFPRT)' and IGPLT=$(V_WKPLT)", "HDIGPH", "IGDESC", featuredItemDesc)
                              %endif
                              @SetTextOvr(Err_WKFPRT)
	                       <tr><td class="dsphdr"><span $(textOvr)>Featured Item/Family</span></td>
                                  <td class="inputalph"><input name="featuredItem" type="text" value="$(V_WKFPRT)" size="15" maxlength="15">
                                          @dtw_assign(searchTitle, "Item Plant")
                                          <a href="$(homeURL)$(cGIPath)itemplantsearch.d2w/ENTRY$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;docName=Add&amp;fldPlant=plantNumber&amp;fldPltName=plantName&amp;fldName=featuredItem&amp;fldDesc=featuredItemDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                                          /
                                          @dtw_assign(searchTitle, "Feature Family")
                                          <a href="$(homeURL)$(cGIPath)ItemGroupSearch.d2w/ENTRY$(genericVarBase)&amp;groupType=F&amp;docName=Add&amp;fldName=featuredItem&amp;fldDesc=featuredItemDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                                          <input disabled name="featuredItemDesc" value="$(featuredItemDesc)" type="text" size="30" maxlength="30"></td>
                              </tr>
                              @DspErrMsg(Err_WKFPRT)

                          </table>

                          <script TYPE="text/javascript">
                              document.Add.$(focusField).focus();
                          </script>

                      </form>
                      <table $(contentTable)>
                            <tr>
                                <td class="toolbar">
                                    %if (sec_01 == "Y")
                                        <a href="javascript:check(document.Add)">$(acceptImageMed)</a>
                                    %endif
                                    <a href="javascript:history.back()">$(cancelImageMed)</a>
                                    @dtw_assign(medIcon, "Y")
                                    %INCLUDE "HelpPage.icl"
                                </td>
                            </tr>
                      </table>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>

          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(Edit_Add) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(feature)
  @dtw_mUPPERCASE(featuredItem)

  @dtw_assign(plantNumber,@dtw_rstrip(plantNumber))

  %if (maintenanceCodeFB == "Z")
      @dtw_assign(maintCode, "A")
  %else
      @dtw_assign(maintCode, maintenanceCodeFB)
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@feat", feature)
  @Concat_Field("@@fprt", featuredItem)
  @Concat_Field("@@fdsc", featureDesc)
  @dtw_concat(edtVar, "}{", edtVar)

  @dtw_assign(SUBR, "SRAdd")

  @Validate_Add(profileHandle, dataBaseID, maintCode, errFound, edtVar, errVar, SUBR)

  %if (errFound == "")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)FeatureOption.d2w/BUILD$(d2wVarBase)&amp;fromPlant=@dtw_rurlescseq(fromPlant)&amp;fromFeature=@dtw_rurlescseq(fromFeature)&amp;fromFeaturedItem=@dtw_rurlescseq(fromFeaturedItem)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/ADD$(genericVarBase)&amp;selectPlant=@dtw_rurlescseq(selectPlant)&amp;fromPlant=@dtw_rurlescseq(fromPlant)&amp;fromFeature=@dtw_rurlescseq(fromFeature)&amp;fromFeaturedItem=@dtw_rurlescseq(fromFeaturedItem)&amp;maintenanceCodeFB=@dtw_rurlescseq(maintenanceCodeFB)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}

%HTML(CHANGE) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
  @RtvFldDesc("FOPLT=$(plantNumber) and FOOPTN='$(feature)'", "HDMFOP","FOBLOP", biLevel)
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.featureDesc.value =="")
                     {alert("$(reqFieldError)");
                      return false;}
                  return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "FEATUREOPTIONMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      <table $(contentTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td>
                                  %if (biLevel == "Y")
                                      <h1>Bi-Level Maintenance</h1>
                                  %else
                                      <h1>Feature Maintenance</h1>
                                  %endif
                              </td>
                              <td class="toolbar">
                                  %if (sec_02 == "Y")
                                      <a href="javascript:check(document.Chg)">$(acceptImageMed)</a>
                                  %endif
                                  <a href="javascript:history.back()">$(cancelImageMed)</a>
                                  @dtw_assign(medIcon, "Y")
                                  %INCLUDE "HelpPage.icl"
                              </td>
                          </tr>
                      </table>

                      <table $(contentTable)>
                          @Format_Header("Plant", $(plantName), $(plantNumber))
                          %if (biLevel == "Y")
                              @Format_Header("Bi-Level", $(feature), "")
                          %else
                              @Format_Header("Feature", $(feature), "")
                          %endif
                          %if (featuredItem !="")
                              @dtw_assign(itemDesc, "")
                              @RtvFldDesc("IMITEM='$(featuredItem)'", "HDIMST", "IMIMDS", itemDesc)
                              %if (itemDesc =="")
                                  @RtvFldDesc("IGTYPE='F' and IGIGRP='$(featuredItem)' and IGPLT=$(plantNumber)", "HDIGPH", "IGDESC", itemDesc)
                              %endif
                              @Format_Header("Featured Item/Family", $(itemDesc), $(featuredItem))
                          %endif
                      </table>

                      $(hrTagAttr)
                      %INCLUDE "RequiredField.icl"
                      %INCLUDE "ErrorDisplay.icl"

                      <form class="formClass" METHOD=POST name="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Chg$(genericVarBase)&amp;selectPlant=@dtw_rurlescseq(selectPlant)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;feature=@dtw_rurlescseq(feature)&amp;featuredItem=@dtw_rurlescseq(featuredItem)&amp;featureDesc=@dtw_rurlescseq(V_WKFDSC)&amp;maintenanceCodeFB=@dtw_rurlescseq(maintenanceCodeFB)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "featureDesc")
                              @dtw_assign(V_WKFDSC, featureDesc)
	                       <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                                  <td class="inputalph"><input name="featureDesc" type="text" value="$(V_WKFDSC)" size="30" maxlength="30"> $(reqFieldChar) </td>
                              </tr>

                          </table>

                          <script TYPE="text/javascript">
                              document.Chg.$(focusField).focus();
                          </script>

                      </form>
                      <table $(contentTable)>
                          <tr>
                              <td class="toolbar">
                                  %if (sec_02 == "Y")
                                      <a href="javascript:check(document.Chg)">$(acceptImageMed)</a>
                                  %endif
                                  <a href="javascript:history.back()">$(cancelImageMed)</a>
                                  @dtw_assign(medIcon, "Y")
                                  %INCLUDE "HelpPage.icl"
                              </td>
                          </tr>
                      </table>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>

          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(Edit_Chg) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(feature)
  @dtw_mUPPERCASE(featuredItem)

  @dtw_assign(plantNumber,@dtw_rstrip(plantNumber))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@feat", feature)
  @Concat_Field("@@fprt", featuredItem)
  @Concat_Field("@@fdsc", featureDesc)
  @dtw_concat(edtVar, "}{", edtVar)

  @dtw_assign(SUBR, "SRChg")

  @Validate_Chg(profileHandle, dataBaseID, maintenanceCodeFB, errFound, edtVar, errVar, SUBR)

  @dtw_assign(maintenanceCode, "$(maintenanceCodeFB)")
  %if (biLevel == "Y" && featuredItem != "")
      @Format_ConfMsg_Desc(maintenanceCode, "Bi-Level", $(feature), "Featured Item/Family", $(featuredItem), "", "", confMessage)
  %elif (biLevel == "Y")
      @Format_ConfMsg_Desc(maintenanceCode, "Bi-Level", $(feature), "", "", "", "", confMessage)
  %elif (featuredItem != "")
      @Format_ConfMsg_Desc(maintenanceCode, "Feature", $(feature), "Featured Item/Family", $(featuredItem), "", "", confMessage)
  %else
      @Format_ConfMsg_Desc(maintenanceCode, "Feature", $(feature), "", "", "", "", confMessage)
  %endif
  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)FeatureBiLevel.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(selectPlant)&amp;confMessage=@dtw_rurlescseq(confMessage)">
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(feature)
  @dtw_mUPPERCASE(featuredItem)
  @dtw_mUPPERCASE(optionItem)
  @dtw_mUPPERCASE(extraChargeFlag)
  @dtw_mUPPERCASE(defaultOption)
  @dtw_mUPPERCASE(bilevelOption)
  @dtw_mUPPERCASE(defaultBLOption)

  @dtw_assign(plantNumber,       @dtw_rstrip(plantNumber))
  @dtw_assign(subSequence,       @dtw_rstrip(subSequence))
  @dtw_assign(extraCharge,       @dtw_rstrip(extraCharge))


  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@feat", feature)
  @Concat_Field("@@fprt", featuredItem)
  @Concat_Field("@@optn", optionItem)
  @Concat_Field("@@sseq", subSequence)
  @Concat_Field("@@xchg", extraCharge)
  @Concat_Field("@@xflg", extraChargeFlag)
  @Concat_Field("@@dflt", defaultOption)
  @Concat_Field("@@blop", bilevelOption)
  @Concat_Field("@@dblo", defaultBLOption)
  @Concat_Field("@@fdsc", featureDesc)
  %if (V_CIUSMP == "Y")
      @Concat_Field("@@seg1", smartPartSeg1)
      @Concat_Field("@@spc1", smartPartCod1)
      @Concat_Field("@@seg2", smartPartSeg2)
      @Concat_Field("@@spc2", smartPartCod2)
      @Concat_Field("@@seg3", smartPartSeg3)
      @Concat_Field("@@spc3", smartPartCod3)
      @Concat_Field("@@seg4", smartPartSeg4)
      @Concat_Field("@@spc4", smartPartCod4)
      @Concat_Field("@@seg5", smartPartSeg5)
      @Concat_Field("@@spc5", smartPartCod5)
  %endif
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar, SUBR)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, "Option", $(optionItem), "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)FeatureOption.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;optionItem=@dtw_rurlescseq(optionItem)&amp;subSequence=@dtw_rurlescseq(subSequence)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
