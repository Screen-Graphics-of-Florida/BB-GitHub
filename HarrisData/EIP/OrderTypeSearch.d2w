%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Order Type Search"
  d2wName                 = "OrderTypeSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)&amp;appID=@dtw_rurlescseq(appID)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "100"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
  advanceSearch           = "N"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectOrderType(orderType, desc){
                  window.opener.document.$(docName).$(fldName).value = orderType;
		          if (window.opener.document.$(docName).$(fldDesc))
	 	             {window.opener.document.$(docName).$(fldDesc).value = desc;} 
		          else if (window.opener.document.getElementById('$(fldDesc)'))
		                  {window.opener.document.getElementById('$(fldDesc)').innerHTML = desc;}
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(uv_OEOrderTypeName, "OTOTCD")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select OTOTCD, OTDESC, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(OTDESC) as OTDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " HDOTYP ", fileSQL)
                      @dtw_concat(selectSQL, "OTOTCD>' ' and OTAPID='$(appID)'", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"

                      @Order_Type_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Order_Type_Search (IN  CHAR(64)    profileHandle,
				           CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"

      $(searchhrTagAttr)
	   	
          <form class="formClass" METHOD=POST name="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Description</th>
                  </tr>
                  <tr><td class="inputalph">
                          <input type="text" name="srchDesc" size="30" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>
	
          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              <tr>	
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("OTDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=description" title="Sequence By Description, Order Type"> Description</a></th>
                  @OrderBy_Sort("OTOTCD", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=orderType" title="Sequence By Order Type"> Order<br>Type</a></th>
              </tr>
	          	 %INCLUDE "NoRecordsFound.icl"	

          %ROW{
              @dtw_assign(displayRow, "Y")
              %if (appID == "OE" && V_HDAPRV != "N")
                  @dtw_assign(edtVar, "")
                  @Concat_Field("@@user", userProfile)
                  @Concat_Field("@@ortx", V_OTOTCD)
                  @Concat_Field("@@orty", "Y")
                  @dtw_concat(edtVar, "}{", edtVar)
                  @Check_Privileges(edtVar)
                  @Decat_Field("@@pv01") @dtw_assign(pvAdd, fieldValue)
                  @Decat_Field("@@nosu") @dtw_assign(userSetup, fieldValue)
                  %if (userSetup == "Y" && pvAdd != "Y")
                      @dtw_assign(displayRow, "N")
                  %endif   
              %endif   

              %if (displayRow == "Y")
                  %INCLUDE "SetRowClass.icl"
                  @Format_Quote(V_OTOTCD, F_OTOTCD)
                  @Format_Quote(V_OTDESC, F_OTDESC)

                  <tr class="$(rowClass)">
                      <td class="colalph"><a href="javascript:selectOrderType('$(F_OTOTCD)', '$(F_OTDESC)')" title="Select Order Type">$(V_OTDESC)</a></td>
                      <td class="colcode">$(V_OTOTCD)</td>
                  </tr>
              %endif
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "OTDESCU,OTOTCD")
      @DTW_ASSIGN(orderByDisplay, "Description, Order Type")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "description")
      %if (orderBy == "OTDESCU,OTOTCD")
          @DTW_ASSIGN(orderBy, "OTDESCU DESC,OTOTCD")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Order Type")
      %else
          @DTW_ASSIGN(orderBy, "OTDESCU,OTOTCD")
          @DTW_ASSIGN(orderByDisplay, "Description, Order Type")
      %endif
  %elif (sequence == "orderType")
      %if (orderBy == "OTOTCD")
          @DTW_ASSIGN(orderBy, "OTOTCD DESC")
          @DTW_ASSIGN(orderByDisplay, "Order Type (descending)")
      %else
          @DTW_ASSIGN(orderBy, "OTOTCD")
          @DTW_ASSIGN(orderByDisplay, "Order Type")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("upper(OTDESC)", "Description", $(srchDesc), "U", operDesc, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}