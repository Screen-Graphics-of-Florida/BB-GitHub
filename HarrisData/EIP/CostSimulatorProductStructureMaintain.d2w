%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Cost Simulation Product Structure Maintenance"
  d2wName                 = "CostSimulatorProductStructureMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(fromPlant)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;componentNumber=@dtw_rurlescseq(componentNumber)&amp;maintenanceCode=D"
  programName             = "HSCSIM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  medIcon = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  function validate(chgForm) {
                      if (document.Chg.componentNumber.value =="" ||
                          document.Chg.quantityper.value =="")
                             {alert("$(reqFieldError)");
                              return false;}
                      if (editNum(document.Chg.quantityper, 4, 5) &&
                          editNum(document.Chg.scrappercent, 1, 2) &&
                          editNum(document.Chg.unitCost, 6, 5))
                          return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
                  %INCLUDE "numedit.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "COSTSIMULATORPRODUCTSTRUCTUREMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "SELECT * FROM WRKPSM WHERE WKXHND='$(profileHandle)' and WKPPN='$(itemNumber)' and WKCPN='$(componentNumber)'", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
      @RtvFldDesc("WKXHND='$(profileHandle)'", "WRKSIM", "WKCSET", costSet)
      @RtvFldDesc("WKXHND='$(profileHandle)'", "WRKSIM", "WKCUST", customerNumber)
      @RtvFldDesc("WKXHND='$(profileHandle)'", "WRKSIM", "WKQTY", orderQuantity)
      @RtvFldDesc("STCSET=$(costSet)", "SCMSTM", "STCSLD", costSetDesc)
      <table $(contentTable)>
    	   <colgroup>
    	       <col width="80%">
    	       <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  <a href="javascript:check(document.Chg)">$(acceptImageMed)</a>
                  <a href="javascript:history.back()">$(cancelImageMed)</a>
                  %if (maintenanceCode == "C")
                      <a onClick="return confirmDelete()" href="$(deleteURL)">$(deleteImageMed)</a>
                  %endif
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>

      <table $(contentTable)>
          @Format_Header("Plant", $(plantName), $(plantNumber))
          @Format_Header("Item", $(itemDescription), $(itemNumber))
          @Format_Header("Cost Set", "$(costSetDesc)", $(costSet))
          %if (customerNumber != "0")
              @RtvFldDesc("CMCUST=$(customerNumber)", "HDCUST", "CMCNA1", customerName)
              @Format_Header("Customer Number", "$(customerName)", $(customerNumber))
          %endif
          @Format_Header("Quantity", "$(orderQuantity)", "")
      </table>

      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "componentNumber")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@comp", "componentNumber")  @dtw_assign(Err_WKCPN,  fieldValue)
                          @DecatErr_Field("@@rqty", "quantityper")      @dtw_assign(Err_WKQPER, fieldValue)
                          @DecatErr_Field("@@scrp", "scrappercent")     @dtw_assign(Err_WKSCPP, fieldValue)
                          @DecatErr_Field("@@clas", "partClass")        @dtw_assign(Err_WKCLAS, fieldValue)
                          @DecatErr_Field("@@type", "partType")         @dtw_assign(Err_WKPTYP, fieldValue)
                          @DecatErr_Field("@@uoms", "stockUOM")         @dtw_assign(Err_WKUOMS, fieldValue)
                          @DecatErr_Field("@@cost", "unitCost")         @dtw_assign(Err_WKUCST, fieldValue)
                      %endif
                      @Decat_Field("@@comp")   @dtw_assign(V_WKCPN, fieldValue)
                      @Decat_Field("@@rqty")   @dtw_assign(V_WKQPER, fieldValue)
                      @Decat_Field("@@scrp")   @dtw_assign(V_WKSCPP, fieldValue)
                      @Decat_Field("@@clas")   @dtw_assign(V_WKCLAS, fieldValue)
                      @Decat_Field("@@type")   @dtw_assign(V_WKPTYP, fieldValue)
                      @Decat_Field("@@uoms")   @dtw_assign(V_WKUOMS, fieldValue)
                      @Decat_Field("@@cost")   @dtw_assign(V_WKUCST, fieldValue)

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_WKCPN, "")
                      @dtw_assign(focusField, "componentNumber")
                  %else
                      @dtw_assign(focusField, "quantityper")
                  %endif

                  @RtvFldDesc("IMITEM='$(V_WKCPN)'", "HDIMST", "IMIMDS", compdesc)
                  @SetTextOvr(Err_WKCPN)
                  <tr><td class="dsphdr"><span $(textOvr)>Component Item Number</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="componentNumber" type="text" value="$(V_WKCPN)" size="15" maxlength="15"> $(reqFieldChar) <a href="$(homeURL)$(cGIPath)itemplantsearch.d2w/ENTRY$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;docName=Chg&amp;fldName=componentNumber&amp;fldDesc=compdesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input disabled name="compdesc" value="$(compdesc)"  type="text" size="30"></td>
                      %else
                          @Format_Code(V_WKCPN, F_WKCPN)
                          <td class="inputalph"><input name="componentNumber" type="hidden" value="$(V_WKCPN)" size="15" maxlength="15">$(compdesc) &nbsp; $(F_WKCPN)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_WKCPN)

                  @SetTextOvr(Err_WKQPER)
                  <tr><td class="dsphdr"><span $(textOvr)>Quantity Per</span></td>
                      <td class="inputnmbr"><input name="quantityper" type="text" value="$(V_WKQPER)" size="10" maxlength="10"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_WKQPER)
    	   		
                  @RtvFldDesc("ICCLAS='$(V_WKCLAS)'", "HDMICM", "ICDESC", fieldDesc)
                  @SetTextOvr(Err_WKCLAS)
                  <tr><td class="dsphdr"><span $(textOvr)>Part Class</span></td>
                      <td class="inputalph"><input name="partClass" type="text" value="$(V_WKCLAS)" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)PartClassSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=partClass&amp;fldDesc=partClassDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input disabled name="partClassDesc" value="$(fieldDesc)"  type="text" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_WKCLAS)
    	   		
                  @RtvFldDesc("FLTYPE='PARTTYPE' and FLVALU='$(V_WKPTYP)'", "SYFLAG", "FLDESC", fieldDesc)
                  @SetTextOvr(Err_WKPTYP)
                  <tr><td class="dsphdr"><span $(textOvr)>Part Type</span></td>
                      <td class="inputalph"><input name="partType" type="text" value="$(V_WKPTYP)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=PARTTYPE&amp;flagSrchHdr=@dtw_rurlescseq("Part Type")&amp;docName=Chg&amp;fldName=partType&amp;fldDesc=partTypeDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input disabled name="partTypeDesc" value="$(fieldDesc)"  type="text" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_WKPTYP)
    	   		
                  @RtvFldDesc("UMUOM='$(V_WKUOMS)'", "HDUOM", "UMUMLD", fieldDesc)
                  @SetTextOvr(Err_WKUOMS)
                  <tr><td class="dsphdr"><span $(textOvr)>Stocking Unit Of Measure</span></td>
                      <td class="inputalph"><input name="stockUOM" type="text" value="$(V_WKUOMS)" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)UnitOfMeasureSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=stockUOM&amp;fldDesc=stockUOMDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input disabled name="stockUOMDesc" value="$(fieldDesc)"  type="text" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_WKUOMS)

                  @Default_Zero(V_WKSCPP)
                  @SetTextOvr(Err_WKSCPP)
                  <tr><td class="dsphdr"><span $(textOvr)>Scrap Percent</span></td>
                      <td class="inputnmbr"><input type="text" name="scrappercent" value="$(V_WKSCPP)" size="4" maxlength="4"></td>
                  </tr>
                  @DspErrMsg(Err_WKSCPP)

                  @SetTextOvr(Err_WKUCST)
                  <tr><td class="dsphdr"><span $(textOvr)>Unit Cost</span></td>
                      <td class="inputnmbr"><input type="text" name="unitCost" value="$(V_WKUCST)" size="12" maxlength="12"></td>
                  </tr>
                  @DspErrMsg(Err_WKUCST)
              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>

      <table $(contentTable)>
          <tr>
              <td class="toolbar">
                  <a href="javascript:check(document.Chg)">$(acceptImageMed)</a>
                  <a href="javascript:history.back()">$(cancelImageMed)</a>
                  %if (maintenanceCode == "C")
                      <a onClick="return confirmDelete()" href="$(deleteURL)">$(deleteImageMed)</a>
                  %endif
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data (INOUT CHAR(64)      profileHandle,
                                         INOUT CHAR(10)      callSubr,
                                         INOUT CHAR(1)       maintenanceCode,
                                         INOUT CHAR(32000)   edtVar,
                                         INOUT CHAR(32000)   errVar,
                                         INOUT CHAR(1)       errFound)

{%EXEC {HSCSIM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(itemNumber)
  @dtw_mUPPERCASE(componentNumber)
  @dtw_mUPPERCASE(partClass)
  @dtw_mUPPERCASE(partType)
  @dtw_mUPPERCASE(stockUOM)

  @dtw_assign(plantNumber,@dtw_rstrip(plantNumber))
  @dtw_assign(quantityper,@dtw_rstrip(quantityper))
  @dtw_assign(scrappercent,@dtw_rstrip(scrappercent))
  @dtw_assign(unitCost,@dtw_rstrip(unitCost))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@item", itemNumber)
  @Concat_Field("@@comp", componentNumber)
  @Concat_Field("@@rqty", quantityper)
  @Concat_Field("@@clas", partClass)
  @Concat_Field("@@type", partType)
  @Concat_Field("@@uoms", stockUOM)
  @Concat_Field("@@scrp", scrappercent)
  @Concat_Field("@@cost", unitCost)
  @dtw_concat(edtVar, "}{", edtVar)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(callSubr, "ProdStruc")

  @Validate_Data(profileHandle, callSubr, maintenanceCode, edtVar, errVar, errFound)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, "$(compdesc)", "$(componentNumber)", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)CostSimulatorDisplay.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@cpn@", "componentNumber")
      @Format_ConfMsg_Desc("", "$(compdesc)", "$(componentNumber)", "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)CostSimulatorDisplay.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;componentNumber=@dtw_rurlescseq(componentNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}