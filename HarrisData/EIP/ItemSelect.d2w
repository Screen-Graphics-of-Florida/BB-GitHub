%INCLUDE "$(baseVar)"
%INCLUDE "CostErrorMsg.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Item"
  d2wName                 = "ItemSelect.d2w"
  attachFolder            = "Item"
  d2wVarBase              = "$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;itemDescription=@dtw_rurlescseq(itemDescription)&amp;fromSel=Y"
  currentURL              = "$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)"
  programName             = "HHDIMU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
  plantNumber             = ""
  plantName               = ""
  haveHeader              = ""
  headerTable             = %table
  routingBOMInterface     = ""
  PDBRelease              = ""
  lotControlActive        = ""
  plantURL                = "plantNumber=@dtw_rurlescseq(plantNumber)&amp;plantName=@dtw_rurlescseq(plantName)"
  totalQuantity           = ""
  quickLinkByUser         = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@itemNumber", "@dtw_rurlescseq(itemNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@itemDescription", "@dtw_rurlescseq(itemDescription)", "1", "a", workURL)
  @dtw_replace(workURL, "@@plantNumber", "@dtw_rurlescseq(plantNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@warehouseNumber", "@dtw_rurlescseq(warehouseNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@warehouseName", "@dtw_rurlescseq(warehouseName)", "1", "a", workURL)
%}

%FUNCTION(dtw_directcall) Retrieve_Category(INOUT CHAR(64) profileHandle,
                                            INOUT CHAR(2) dataBaseID,
                                            INOUT CHAR(15) category,
                                            INOUT CHAR(50) categoryDesc,
                                            INOUT CHAR(50) catalogHeaderPage,
                                            INOUT CHAR(256) categoryImage,
                                            INOUT CHAR(75) error)
  {%EXEC {HOECTR_W.PGM %}
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @ItemUserView(profileHandle, dataBaseID, userPass, itemNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              @dtw_assign(title, @dtw_rconcat(itemNumber, @dtw_rconcat(" ", itemDescription)))
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "AJAXRequest.icl"
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
                  %INCLUDE "SaveCurrentURL.icl"
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "ITEMSELECT")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">

%{ ProductStructure/Routing Interface %}
                          @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLRSF", routingBOMInterface)

%{ lotControlActive %}
                          %if (V_CILTUS=="Y")		
                              @dtw_assign(lotControlActive, "Y")
                          %endif

%{ QuickLink Table %}     %INCLUDE "QuickLinkTable.icl"
	
%{ PDBRelease %}
                          %if (V_HDPDRL>"0")		
                              @dtw_assign(PDBRelease, "Y")
                          %else
                              @Remove_Quick_Link("plants")
                              @Remove_Quick_Link("availabletopromise")
                              @Remove_Quick_Link("demand")
                              @Remove_Quick_Link("routing")
                              @Remove_Quick_Link("productstructure")
                              @Remove_Quick_Link("costsummary")
                          %endif

%{ QuickLink By User %}   %INCLUDE "QuickLinkByUser.icl"

%{ Item Heading %}
                          @dtw_assign(RPT_MAX_ROWS, "99")
                          @dtw_assign(dspMaxRows, "10")
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " HDIMST ", fileSQL)
                          @dtw_concat(selectSQL, "IMITEM='$(itemNumber)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                          @Item_Select_Header(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Begin %}     %INCLUDE "QuickLinkBegLoop.icl"

    %{ Demographics %}
                              %if (quicklinkRef == "demographics")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select HDIMST.*, HDIMSX.* ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDIMST left join HDIMSX on IMITEM=IXITEM", fileSQL)
                                  @dtw_concat(selectSQL, "IMITEM='$(itemNumber)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Item_Select_Demographics(profileHandle, dataBaseID, stmtSQL)

    %{ Extended Description Detail %}
                              %elif (quicklinkRef == "extendeddescdetail")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select IXDOCT, IXSEQ#, IXDESC ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDIMXD ", fileSQL)
                                  @dtw_concat(selectSQL, "IXITEM='$(itemNumber)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_assign(orderBy, "IXDOCT, IXSEQ#")
                                  @dtw_assign(orderByDisplay, "Document Type")
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Item_Select_ExtDesc_Detail(profileHandle, dataBaseID, stmtSQL)

    %{ Extended Description Summary %}
                              %elif (quicklinkRef == "extendeddescsummary")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(distinctSQL, "IXDOCT", distinctSQL)
                                  @dtw_concat(stmtSQL, " Select Distinct IXDOCT ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDIMXD ", fileSQL)
                                  @dtw_concat(selectSQL, "IXITEM='$(itemNumber)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_assign(orderBy, "IXDOCT")
                                  @dtw_assign(orderByDisplay, "Document Type")
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Item_Select_ExtDesc_Summary(profileHandle, dataBaseID, stmtSQL)
    %{ Warehouses %}
                              %elif (quicklinkRef == "warehouses")
                                  %INCLUDE "QuickLinkClear.icl"
                                  @dtw_assign(uv_WarehouseName, "IWWHS")
                                  @dtw_assign(uv_ProductClassName, "IMPCLS")
                                  @dtw_assign(uv_ProductGroupName, "IWPGRP")
                                  @dtw_assign(uv_ProdInventoryTypeName, "IMITC")
                                  @dtw_assign(uv_ProdPartTypeName, "IMPTYP")
                                  %INCLUDE "userview.icl"

                                  @RtvFldDesc("IWITEM='$(itemNumber)'", "HDIWHS", "char(Sum(IWOHQT))", totalQuantity)

                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select IWWHS, IWITEM, IWOHQT, IWOHRC, IWQHSR, IWRESQ, IWQOO, IWLIST, IWIWAC, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " IMPTYP, IMITC, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " coalesce(WHWHNM,' ') as WHWHNM, upper(coalesce(WHWHNM,' ')) as WHWHNMU ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDIWHS ", fileSQL)
                                  @dtw_concat(fileSQL, " left join HDIMST on IMITEM=IWITEM ", fileSQL)
                                  @dtw_concat(fileSQL, " left join HDWHSM on WHWHS =IWWHS ", fileSQL)
                                  @dtw_concat(selectSQL, "IWITEM='$(itemNumber)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_assign(orderBy, "IWOHQT Desc")
                                  @dtw_assign(orderByDisplay, "Quantity On Hand (descending)")
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Item_Select_Warehouses(profileHandle, dataBaseID, stmtSQL)

    %{ Plants %}
                              %elif (quicklinkRef == "plants")
                                  %INCLUDE "QuickLinkClear.icl"
                                  @dtw_assign(uv_PlantName, "IPPLT")
                                  @dtw_assign(uv_PltInventoryTypeName, "IPITC")
                                  @dtw_assign(uv_PltPartTypeName, "IPPTYP")
                                  @dtw_assign(uv_PartClassName, "IPCLAS")
                                  @dtw_assign(uv_BuyerName, "IPBAC")
                                  @dtw_assign(uv_VendorName, "IPVEND")
                                  %INCLUDE "userview.icl"

                                  @RtvFldDesc("IPITEM='$(itemNumber)'", "HDIPLT", "char(Sum(IPOHFS))", totalQuantity)

                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select IPPLT, IPITEM, IPBAC, IPPTYP, IPABCC, IPOHFS, IPCMTO, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " coalesce(PLNAME,' ') as PLNAME, upper(coalesce(PLNAME,' ')) as PLNAMEU, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " coalesce(BMBNA1,' ') as BMBNA1, FLDESC as FLDESC ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDIPLT ", fileSQL)
                                  @dtw_concat(fileSQL, " left join HDPLNT on PLPLNT=IPPLT ", fileSQL)
                                  @dtw_concat(fileSQL, " left join SYFLAG on FLTYPE='PARTTYPE' and FLVALU=IPPTYP ", fileSQL)
                                  @dtw_concat(fileSQL, " left join HDBUYR on BMBUYR=IPBAC ", fileSQL)
                                  @dtw_concat(selectSQL, "IPITEM='$(itemNumber)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_assign(orderBy, "IPPLT")
                                  @dtw_assign(orderByDisplay, "Plant Number")
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Item_Select_Plants(profileHandle, dataBaseID, stmtSQL)

    %{ Available To Promise %}
                              %elif (quicklinkRef == "availabletopromise")
                                  %INCLUDE "QuickLinkClear.icl"
                                  @dtw_concat(quicklinkTitle, " for Plant $(plantNumber) - $(plantName)", quicklinkTitle)
                                  @Fill_ATP_Work_File(profileHandle,dataBaseID,plantNumber,itemNumber)
                                  @MS230A_Query(profileHandle, dataBaseID, plantNumber, itemNumber, headerTable)
                                  %if (@DTW_TB_rROWS(headerTable)>"0")
                                      @dtw_assign(haveHeader, "Y")
                                  %else
                                      @dtw_assign(haveHeader, "")
                                  %endif
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " MS230W ", fileSQL)
                                  @dtw_concat(selectSQL, "E_PLNT=$(plantNumber) and E_ITEM='$(itemNumber)' and E_XHND='$(profileHandle)' ", selectSQL)
                                  @Retrieve_WebReg(userProfile, "", "AvailableToPromise.d2w", wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %if (orderBy == "")
                                      @dtw_assign(orderBy, "E_DATE")
                                      @dtw_assign(orderByDisplay, "Date")
                                  %endif
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Item_Select_AvailableToPromise(profileHandle, dataBaseID, stmtSQL)

    %{ Demand %}
                              %elif (quicklinkRef == "demand")
                                  %INCLUDE "QuickLinkClear.icl"
                                  @dtw_concat(quicklinkTitle, " for Plant $(plantNumber) - $(plantName)", quicklinkTitle)
                                  @RtvFldDesc("ODITEM='$(itemNumber)' and ODPLT=$(plantNumber) and ODORST='O' and ODBLKT<>'Y' and OEORTY<>'Q'", "OEORDT inner join OEORHD on OEORD#=ODORD#", "char(Sum(ODQORD-ODQSTD-ODQSTC))", totalQuantity)

                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select ODITEM,ODPLT,ODBLKT,ODORD#,ODORL#,ODRQDT,ODMORD,ODQOPK,ODQSTC, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " ODWH, ODOREC, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " ODQORD,ODQSTD,ODQORD-ODQSTD-ODQSTC as ODQTY, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " OEORTY,OESHTO, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " CMCNA1,CMCNA1U, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " WHWHNM ", stmtSQL)
                                  @dtw_concat(fileSQL, " OEORDT ", fileSQL)
                                  @dtw_concat(fileSQL, " inner join OEORHD on OEORD#=ODORD# ", fileSQL)
                                  @dtw_concat(fileSQL, " inner join HDCUST on CMCUST=OESHTO ", fileSQL)
                                  @dtw_concat(fileSQL, " left join HDWHSM on WHWHS=ODWH ", fileSQL)
                                  @dtw_concat(selectSQL, "ODITEM='$(itemNumber)' and ODPLT=$(plantNumber) ", selectSQL)
                                  @dtw_concat(selectSQL, "and ODORST='O' and ODBLKT<>'Y' and OEORTY<>'Q' and OEORTY<>'X' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @Retrieve_WebReg(userProfile, "", "ItemDemand.d2w", wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
                                  %if (orderBy == "")
                                      @dtw_assign(orderBy, "ODRQDT")
                                      @dtw_assign(orderByDisplay, "Required Date")
                                  %endif
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Item_Select_Demand(profileHandle, dataBaseID, stmtSQL)

    %{ Routing %}
                              %elif (quicklinkRef == "routing")
                                  %INCLUDE "QuickLinkClear.icl"
                                  @dtw_concat(quicklinkTitle, " for Plant $(plantNumber) - $(plantName)", quicklinkTitle)
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDMRTM ", fileSQL)
                                  @dtw_concat(selectSQL, "RTPLT=$(plantNumber) and RTPN='$(itemNumber)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @Retrieve_WebReg(userProfile, "", "Routings.d2w", wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
                                  %if (orderBy == "")
                                      @dtw_assign(orderBy, "RTSEQN")
                                      @dtw_assign(orderByDisplay, "Rtg Seq")
                                  %endif
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Item_Select_Routing(profileHandle, dataBaseID, stmtSQL)

    %{ Product Structure %}
                              %elif (quicklinkRef == "productstructure")
                                  %INCLUDE "QuickLinkClear.icl"
                                  @dtw_concat(quicklinkTitle, " for Plant $(plantNumber) - $(plantName)", quicklinkTitle)
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select PSPPLT, PSPPN, PSSEQN, PSCPN, PSREFN,  PSQPER, PSFSTK, PSSCPP, PSSTDT, PSDSDT,  ", stmtSQL)
                                  @dtw_concat(stmtSQL, " IMIMDS, IMIMDSU, IPITEM, IPECDP ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDMPSM Left Outer Join (HDIPLT Join HDIMST on IPITEM=IMITEM) On PSPPLT=IPPLT and PSCPN=IPITEM", fileSQL)
                                  @dtw_concat(selectSQL, "PSPPLT=$(plantNumber) and PSPPN='$(itemNumber)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @Retrieve_WebReg(userProfile, "", "ProductStructure.d2w", wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
                                  %if (orderBy == "")
                                      %if (routingBOMInterface == "Y")
                                          @dtw_assign(orderBy, "PSSEQN, PSCPN")
                                          @dtw_assign(orderByDisplay, "Rtg Seq, Component Item")
                                      %else
                                          @dtw_assign(orderBy, "PSCPN")
                                          @dtw_assign(orderByDisplay, "Component Item")
                                      %endif
                                  %endif
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Item_Select_Product_Structure(profileHandle, dataBaseID, stmtSQL)

    %{ Cost Summary %}
                              %elif (quicklinkRef == "costsummary")
                                  %INCLUDE "QuickLinkClear.icl"
                                  @dtw_concat(quicklinkTitle, " for Plant $(plantNumber) - $(plantName)", quicklinkTitle)
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDMCMM a left join SCMSTM b on CMCSET=STCSET ", fileSQL)
                                  @dtw_concat(selectSQL, "CMPLT=$(plantNumber) and CMPN='$(itemNumber)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @Retrieve_WebReg(userProfile, "", "CostSummary.d2w", wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
                                  %if (orderBy == "")
                                      @dtw_assign(orderBy, "CMCSET")
                                      @dtw_assign(orderByDisplay, "Cost Set")
                                  %endif
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Item_Select_Cost_Summary(profileHandle, dataBaseID, stmtSQL)
                              %endif

    %{ Attachments %}         %INCLUDE "AttachmentSQL.icl"

%{ Quicklink End %}       %INCLUDE "QuickLinkEndLoop.icl"

                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
%endif
%}

%FUNCTION(dtw_sql) Item_Select_Header (IN  CHAR(64)    profileHandle,
			                    CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      %ROW{
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  @dtw_assign(attachVarKey, itemNumber)
                  %if (itemDescription == "") @dtw_assign(itemDescription, V_IMIMDS) %endif
                  @dtw_assign(attachForDesc, itemDescription)
                  @dtw_assign(attachPrg1, "HDIMST Where IMITEM='$(itemNumber)'")
                  %if (formatToPrint != "Y")
                      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                      <td class="toolbar">
                          %if (V_IMKIT == "K")
                              <a href="$(homeURL)$(phpPath)KitInquiry.php$(altVarBase)&amp;itemNumber=@dtw_rurlescseq($(V_IMITEM))" onclick="$(inquiryWinVar)" title="Kit Quickview">$(kitOptionImageLrg)</a>
                          %endif
                          %INCLUDE "Attachment.icl"
                          %if (sec_01 == "Y")
                              <a href="$(homeURL)$(cGIPath)ItemMaintain.d2w/MAINTAIN$(genericVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)ItemMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=Z">$(copyImageLrg)</a>
                          %endif
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)ItemMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=C&amp;fromD2w=@dtw_rurlescseq(d2wName)">$(changeImageLrg)</a>
                          %endif
                          %if (sec_03 == "Y")
                              @Format_Confirm_Desc($(itemDescription), $(itemNumber), "", "", "", "", confirmDesc)
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)ItemMaintain.d2w/Edit_Data$(d2wVarBase)&amp;maintenanceCode=D&amp;fromD2w=@dtw_rurlescseq(fromD2w)">$(deleteImageLrg)</a>
                          %endif
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
          </table>
          <table $(contentTable)>
              %if (warehouseName !="")
                  @Format_Header_URL("Warehouse", $(warehouseName), $(warehouseNumber), "$(homeURL)$(cGIPath)WarehouseSelect.d2w/REPORT$(genericVarBase)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)")
              %endif
              @Format_Header_URL("Item", $(itemDescription), $(itemNumber), "")
          </table>
          %INCLUDE "ConfMessageDisplay.icl"

          %if (PDBRelease == "Y" && V_IMPTYP=="P")
              @Remove_Quick_Link("productstructure")
              @Remove_Quick_Link("routing")
          %endif
      %}

      $(hrTagAttr)
      %INCLUDE "QuickLinkDisplay.icl"
  %}
%}

%FUNCTION(dtw_sql) Item_Select_Demographics (IN  CHAR(64)    profileHandle,
				                  CHAR(2)     dataBaseID,
                                                 CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      <a name="demographics"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %ROW{
              @RtvFldDesc("PCPCLS='$(V_IMPCLS)'", "HDPCLS", "PCPCDS", fieldDesc)
              @Format_Code(V_IMPCLS, F_IMPCLS)
              <tr><td class="dsphdr">Product Class</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_IMPCLS)</td>
              </tr>

              @RtvFldDesc("UMUOM='$(V_IMUOMS)'", "HDUOM", "UMUMLD", fieldDesc)
              @Format_Code(V_IMUOMS, F_IMUOMS)
              <tr><td class="dsphdr">Stocking Unit Of Measure</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_IMUOMS)</td>
              </tr>

              @RtvFldDesc("FLTYPE='KIT' and FLVALU='$(V_IMKIT)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_IMKIT, F_IMKIT)
              <tr><td class="dsphdr">Kit/Featured Item/Configurable</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_IMKIT)</td>
              </tr>

              %if (lotControlActive == "Y")
                  @RtvFldDesc("FLTYPE='LOT' and FLVALU='$(V_IMLOT)'", "SYFLAG", "FLDESC", fieldDesc)
                  <tr><td class="dsphdr">Lot Controlled</td>
                      <td class="dspalph">$(fieldDesc)</td>
                  </tr>
              %endif

              %if (PDBRelease == "Y")
                  @RtvFldDesc("FLTYPE='PARTTYPE' and FLVALU='$(V_IMPTYP)'", "SYFLAG", "FLDESC", fieldDesc)
                  @Format_Code(V_IMPTYP, F_IMPTYP)
                  <tr><td class="dsphdr">Part Type</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_IMPTYP)</td>
                  </tr>
              %endif

              @RtvFldDesc("ITITC='$(V_IMITC)'", "HDITYP", "ITDESC", fieldDesc)
              @Format_Code(V_IMITC, F_IMITC)
              <tr><td class="dsphdr">Inventory Type</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_IMITC)</td>
              </tr>

              @RtvYNDesc($(V_IMHAZM), fieldDesc)
              <tr><td class="dsphdr">Hazardous Material</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              @RtvYNDesc($(V_IMDSHP), fieldDesc)
              <tr><td class="dsphdr">Drop Ship Item</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              @RtvFldDesc("FLTYPE='UPCBAR' AND FLVALU='$(V_IMUPCT)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_IMUPCT, F_IMUPCT)
              <tr><td class="dsphdr">U.P.C. Bar Code Type</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_IMUPCT)</td>
              </tr>

              <tr><td class="dsphdr">U.P.C. Number</td>
