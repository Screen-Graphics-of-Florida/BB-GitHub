                      @SetTextOvr(Err_EPSCHL)
                      <tr><td class="dsphdr"><span $(textOvr)>School</span></td>
                          <td class="inputalph"><input name="school" type="text" value="$(V_EPSCHL)" size="15" maxlength="15"></td>
                      </tr>
                      @DspErrMsg(Err_EPSCHL)

                  </table>
              </fieldset>

              <a name="latestEmployChg"></a>
              <fieldset class="legendBody">
                  <legend class="legendTitle">Latest Employment Changes</legend>
                  <div class="quickLinksTop">
                      <a href="#top">$(topOfFormImage)</a>
                  </div>
                  <table $(contentTable)>
                      @RtvFldDesc("EADEPT='$(V_EPPDPT)' ", "PREXAC", "EANAME", prevDepartmentDesc)
                      @SetTextOvr(Err_EPPDPT)
                      <tr><td class="dsphdr"><span $(textOvr)>Previous Department</span></td>
                          <td class="inputalph"><input name="prevDepartment" type="text" value="$(V_EPPDPT)" size="5" maxlength="5"> <a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=prevDepartment&amp;fldDesc=prevDepartmentDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input  name="prevDepartmentDesc" value="$(prevDepartmentDesc)"  type="hidden" size="20" maxlength="20"></td>
                      </tr>
                      @DspErrMsg(Err_EPPDPT)

                      @SetTextOvr(Err_EPDPCD)
        	           <tr><td class="dsphdr"><span $(textOvr)>Department Change Date</span></td>
                          <td class="inputnmbr"><input type="text" name="deptChangeDate" value="$(V_EPDPCD)" size="6" maxlength="6"> 		
                              <a href="javascript:calWindow('deptChangeDate');">$(calendarImage)</a></td>
                      </tr>
                      @DspErrMsg(Err_EPDPCD)

                      @RtvFldDesc("ODCOMP=$(V_EPCOMP) and ODTYPE='J' and ODCODE='$(V_EPPJOB)' ", "PECODE", "CHAR(ODDESC)", codeDesc)
                      @SetTextOvr(Err_EPPJOB)
                      <tr><td class="dsphdr"><span $(textOvr)>Previous Job Code </span></td>
                          <td class="inputalph"><input name="prevJob" type="text" value="$(V_EPPJOB)" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Chg&amp;fldComp=@dtw_rurlescseq(hrCompany)&amp;fldType=J&amp;fldName=prevJob&amp;fldDesc=prevJobDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="prevJobDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                      </tr>
                      @DspErrMsg(Err_EPPJOB)

                      @SetTextOvr(Err_EPJBCD)
        	           <tr><td class="dsphdr"><span $(textOvr)>Job Code Change Date</span></td>
                          <td class="inputnmbr"><input type="text" name="jobChangeDate" value="$(V_EPJBCD)" size="6" maxlength="6"> 		
                              <a href="javascript:calWindow('jobChangeDate');">$(calendarImage)</a></td>
                      </tr>
                      @DspErrMsg(Err_EPJBCD)

                      @RtvFldDesc("ODCOMP=$(V_EPCOMP) and ODTYPE='S' and ODCODE='$(V_EPPSTS)' ", "PECODE", "CHAR(ODDESC)", codeDesc)
                      @SetTextOvr(Err_EPPSTS)
                      <tr><td class="dsphdr"><span $(textOvr)>Previous Status</span></td>
                          <td class="inputalph"><input name="prevStatus" type="text" value="$(V_EPPSTS)" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Chg&amp;fldComp=@dtw_rurlescseq(hrCompany)&amp;fldType=S&amp;fldName=prevStatus&amp;fldDesc=prevStatusDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="prevStatusDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                      </tr>
                      @DspErrMsg(Err_EPPSTS)

                      @SetTextOvr(Err_EPSTCD)
        	           <tr><td class="dsphdr"><span $(textOvr)>Status Change Date</span></td>
                          <td class="inputnmbr"><input type="text" name="statusChangeDate" value="$(V_EPSTCD)" size="6" maxlength="6"> 		
                              <a href="javascript:calWindow('statusChangeDate');">$(calendarImage)</a></td>
                      </tr>
                      @DspErrMsg(Err_EPSTCD)
                  </table>
              </fieldset>
              
          %}

      </form>

      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHREMH_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMTYPE", PAYTYPECODE)
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (sec_02 == "N" || sec_10 == "N")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @dtw_assign(sec_03, "")
      @ethnic_Id_Query(profileHandle, dataBaseID, "ETHNICID  ", ethnicIdTable)
          @dtw_tb_insertrow(ethnicIdTable, "0", "1")
	   @dtw_tb_setv(ethnicIdTable, "", "1", "2")
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
          @dtw_tb_insertrow(yn01Table, "0", "1")
	   @dtw_tb_setv(yn01Table, "", "1", "2")
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(hireSource)
  @dtw_mUPPERCASE(subDepartment)
  @dtw_mUPPERCASE(statusCode)
  @dtw_mUPPERCASE(pensionCode)
  @dtw_mUPPERCASE(laborCategory)
  @dtw_mUPPERCASE(mailGroup)
  @dtw_mUPPERCASE(militaryStatus)
  @dtw_mUPPERCASE(Classification)
  @dtw_mUPPERCASE(leaveReason)
  @dtw_mUPPERCASE(securityCode)
  @dtw_mUPPERCASE(licenseState)
  @dtw_mUPPERCASE(licensePlate)
  @dtw_mUPPERCASE(contactOneState)
  @dtw_mUPPERCASE(contactTwoState)
  @dtw_mUPPERCASE(disabilityCode)
  @dtw_mUPPERCASE(prevDepartment)
  @dtw_mUPPERCASE(prevJob)
  @dtw_mUPPERCASE(prevStatus)

  @dtw_assign(ethnicId,@dtw_rstrip(ethnicId))
  @dtw_assign(firstAssocDate,@dtw_rstrip(firstAssocDate))
  @dtw_assign(workersCompNbr,@dtw_rstrip(workersCompNbr))
  @dtw_assign(reportsTo,@dtw_rstrip(reportsTo))
  @dtw_assign(reviewerEmpl,@dtw_rstrip(reviewerEmpl))
  @dtw_assign(budgetHours,@dtw_rstrip(budgetHours))
  @dtw_assign(workPhone,@dtw_rstrip(workPhone))
  @dtw_assign(workExtension,@dtw_rstrip(workExtension))
  @dtw_assign(leaveDate,@dtw_rstrip(leaveDate))
  @dtw_assign(leaveReturn,@dtw_rstrip(leaveReturn))
  @dtw_assign(securityIssue,@dtw_rstrip(securityIssue))
  @dtw_assign(securityExpiration,@dtw_rstrip(securityExpiration))
  @dtw_assign(physicianPhone,@dtw_rstrip(physicianPhone))
  @dtw_assign(bloodDonation,@dtw_rstrip(bloodDonation))
  @dtw_assign(contactOnePhone,@dtw_rstrip(contactOnePhone))
  @dtw_assign(contactTwoPhone,@dtw_rstrip(contactTwoPhone))
  @dtw_assign(yearGraduated,@dtw_rstrip(yearGraduated))
  @dtw_assign(deptChangeDate,@dtw_rstrip(deptChangeDate))
  @dtw_assign(jobChangeDate,@dtw_rstrip(jobChangeDate))
  @dtw_assign(statusChangeDate,@dtw_rstrip(statusChangeDate))
  @dtw_assign(organizationLevel,@dtw_rstrip(organizationLevel))
  @dtw_assign(organizationSeq,@dtw_rstrip(organizationSeq))

  @dtw_assign(edtVar, "")

  @Concat_Field("@@comp", prCompany)
  @Concat_Field("@@facl", prFacility)
  @Concat_Field("@@empl", prEmployee)
  @Concat_Field("@@pecp", hrCompany)
  @Concat_Field("@@pemp", hrEmployee)
  @Concat_Field("@@levl", organizationLevel)
  @Concat_Field("@@oseq", organizationSeq)
  @Concat_Field("@@titl", title)
  @Concat_Field("@@ethn", ethnicId)
  @Concat_Field("@@otid", visaId)
  @Concat_Field("@@hire", hireSource)
  @Concat_Field("@@fasc", firstAssocDate)
  @Concat_Field("@@sdep", subDepartment)
  @Concat_Field("@@stat", statusCode)
  @Concat_Field("@@pens", pensionCode)
  @Concat_Field("@@labc", laborCategory)
  @Concat_Field("@@mail", mailGroup)
  @Concat_Field("@@milt", militaryStatus)
  @Concat_Field("@@wcmp", workersCompNbr)
  @Concat_Field("@@rtem", reportsTo)
  @Concat_Field("@@rvem", reviewerEmpl)
  @Concat_Field("@@temp", temporaryEmpl)
  @Concat_Field("@@sbhr", budgetHours)
  @Concat_Field("@@phon", workPhone)
  @Concat_Field("@@extn", workExtension)
  @Concat_Field("@@clas", classification)
  @Concat_Field("@@lvre", leaveReason)
  @Concat_Field("@@lvdt", leaveDate)
  @Concat_Field("@@lvrt", leaveReturn)
  @Concat_Field("@@sccl", securityCode)
  @Concat_Field("@@scid", securityId)
  @Concat_Field("@@scdt", securityIssue)
  @Concat_Field("@@scex", securityExpiration)
  @Concat_Field("@@park", parkingSpace)
  @Concat_Field("@@lcst", licenseState)
  @Concat_Field("@@lcpl", licensePlate)
  @Concat_Field("@@hndc", disabilityCode)
  @Concat_Field("@@phys", physicianName)
  @Concat_Field("@@pphn", physicianPhone)
  @Concat_Field("@@blod", bloodType)
  @Concat_Field("@@lbd@", bloodDonation)
  @Concat_Field("@@cnme", contactOneName)
  @Concat_Field("@@cadr", contactOneAddrOne)
  @Concat_Field("@@cad2", contactOneAddrTwo)
  @Concat_Field("@@c1ct", contactOneCity)
  @Concat_Field("@@c1st", contactOneState)
  @Concat_Field("@@c1zp", contactOneZip)
  @Concat_Field("@@cphn", contactOnePhone)
  @Concat_Field("@@c2nm", contactTwoName)
  @Concat_Field("@@c2a1", contactTwoAddrOne)
  @Concat_Field("@@c2a2", contactTwoAddrTwo)
  @Concat_Field("@@c2ct", contactTwoCity)
  @Concat_Field("@@c2st", contactTwoState)
  @Concat_Field("@@c2zp", contactTwoZip)
  @Concat_Field("@@c2ph", contactTwoPhone)
  @Concat_Field("@@grad", yearGraduated)
  @Concat_Field("@@dgre", degree)
  @Concat_Field("@@subj", subjectMajor)
  @Concat_Field("@@schl", school)
  @Concat_Field("@@pdpt", prevDepartment)
  @Concat_Field("@@dpcd", deptChangeDate)
  @Concat_Field("@@pjob", prevJob)
  @Concat_Field("@@jbcd", jobChangeDate)
  @Concat_Field("@@psts", prevStatus)
  @Concat_Field("@@stcd", statusChangeDate)
  @Concat_Field("@@tstp", timeStamp)

  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
      @Format_ConfMsg_Desc(maintenanceCode, $(F_EmpName), $(prEmployee), "", "", "", "", confMessage)
      %if (fromD2w != "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)EmployeeMaintainSelect.d2w/REPORT$(d2wVarBase)&amp;employeeNumber=@dtw_rurlescseq(employeeNumber)&amp;reportName=@dtw_rurlescseq(reportName)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;employeeNumber=@dtw_rurlescseq(employeeNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}