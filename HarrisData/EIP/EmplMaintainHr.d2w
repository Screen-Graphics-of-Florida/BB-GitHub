%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "Employee.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"
%INCLUDE "QuickLink.icl"

%Define {
  page_title              = "Employee Human Resources Maintenance"
  d2wName                 = "EmplMaintainHr.d2w"
  d2wVarBase              = "$(genericVarBase)$(employeeVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  programName             = "HHREMU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  PAYTYPECODE             = ""
  SCRS                    = ""
  DLIN                    = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
  @dtw_replace(workURL, "@@fromD2w", "@dtw_rurlescseq(fromD2w)", "1", "a", workURL)
%}






%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  function validate(chgForm) {
                      %if (prEmployee == "99999")
                          if (document.Chg.temporaryEmpl.value =="")
                              {alert("$(reqFieldError)"); return false;}
                      %endif
                      %if (prEmployee != "99999")
                          if (document.Chg.title.value =="" ||
                              document.Chg.temporaryEmpl.value =="")
                              {alert("$(reqFieldError)"); return false;}
                      %endif
                      if (editNum(document.Chg.organizationLevel, 1, 0) &&
                          editNum(document.Chg.organizationSeq, 5, 0) &&
                          editNum(document.Chg.ethnicId, 1, 0) &&
                          editNum(document.Chg.firstAssocDate, 6, 0) &&
                          editNum(document.Chg.workersCompNbr, 9, 0) &&
                          editNum(document.Chg.reportsTo, 9, 0) &&
                          editNum(document.Chg.budgetHours, 2, 0) &&
                          editNum(document.Chg.workPhone, 10, 0) &&
                          editNum(document.Chg.workExtension, 5, 0) &&
                          editNum(document.Chg.reviewerEmpl, 9, 0) &&
                          editNum(document.Chg.leaveDate, 6, 0) &&
                          editNum(document.Chg.leaveReturn, 6, 0) &&
                          editNum(document.Chg.securityIssue, 6, 0) &&
                          editNum(document.Chg.securityExpiration, 6, 0) &&
                          editNum(document.Chg.physicianPhone, 10, 0) &&
                          editNum(document.Chg.bloodDonation, 6, 0) &&
                          editNum(document.Chg.contactOnePhone, 10, 0) &&
                          editNum(document.Chg.contactTwoPhone, 10, 0) &&
                          editNum(document.Chg.yearGraduated, 4, 0) &&
                          editNum(document.Chg.deptChangeDate, 6, 0) &&
                          editNum(document.Chg.jobChangeDate, 6, 0) &&
                          editNum(document.Chg.statusChangeDate, 6, 0) &&
                          editdate(document.Chg.firstAssocDate) &&
                          editdate(document.Chg.leaveDate) &&
                          editdate(document.Chg.leaveReturn) &&
                          editdate(document.Chg.securityIssue) &&
                          editdate(document.Chg.securityExpiration) &&
                          editdate(document.Chg.bloodDonation) &&
                          editdate(document.Chg.deptChangeDate) &&
                          editdate(document.Chg.jobChangeDate) &&
                          editdate(document.Chg.statusChangeDate))
                      return true;
                  }
	           %INCLUDE "numedit.icl"
                  %INCLUDE "dateedit.icl"
                  %INCLUDE "calendar.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "EMPLMAINTAINPAY")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, " Select * From PEEMPL ", stmtSQL)
                              @dtw_concat(stmtSQL, " Where EPCOMP=$(hrCompany) and EPEMPL=$(hrEmployee)", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @HumanResources_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) HumanResources_Query (IN CHAR(64)    profileHandle,
                                            CHAR(2)     dataBaseID,
                                            CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @dtw_assign(sec_03, "N")
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
	   <colgroup>
	       <col width="80%">
	       <col width="15%">
          @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
          <tr><td><h2>$(F_EmpName)</h2></td></tr>
      </table>
      $(hrTagAttr)

      <table $(quickLinkTable)>
           %if (genEmplImage != "" && quicklinkDspImage == "Y")
              <tr>
                  <td><a href="#generalEmpl">$(genEmplImage)</a></td>
                  <td><a href="#supervision">$(supervisionImage)</a></td>
                  <td><a href="#security">$(securityImage)</a></td>
                  <td><a href="#emergencyInfo">$(emergencyInfoImage)</a></td>
              </tr>
              <tr><td><a href="#contact1">$(contact1Image)</a></td>
                  <td><a href="#contact2">$(contact2Image)</a></td>
                  <td><a href="#highestEducation">$(higestEducationImage)</a></td>
                  <td><a href="#latestEmployChg">$(latestEmployChgImage)</a></td>
              </tr>
           %else
              <tr>
                  <td class="quickLinkTabs"><a href="#generalEmpl">General Employment</a></td>
                  <td class="quickLinkTabs"><a href="#supervision">Supervision</a></td>
                  <td class="quickLinkTabs"><a href="#security">Security</a></td>
                  <td class="quickLinkTabs"><a href="#emergencyInfo">Emergency Information</a></td>
              </tr>
              <tr>
                  <td class="quickLinkTabs"><a href="#contact1">Contact 1</a></td>
                  <td class="quickLinkTabs"><a href="#contact2">Contact 2</a></td>
                  <td class="quickLinkTabs"><a href="#highestEducation">Highest Education</a></td>
                  <td class="quickLinkTabs"><a href="#latestEmployChg">Latest Employment Changes</a></td>
              </tr>
           %endif
              <tr><td>&nbsp;</td></tr>
      </table>


      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"		

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          %ROW {

              %if (errFound != "" || maintenanceCode == "A")
                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(edtVar, "")
                  %else
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@levl", "organizationLevel")  @dtw_assign(Err_EPLEVL, fieldValue)
                      @DecatErr_Field("@@oseq", "organizationSeq")    @dtw_assign(Err_EPOSEQ, fieldValue)
                      @DecatErr_Field("@@titl", "title")              @dtw_assign(Err_EPTITL, fieldValue)
                      @DecatErr_Field("@@ethn", "ethnicId")           @dtw_assign(Err_EPETHN, fieldValue)
                      @DecatErr_Field("@@otid", "visaId")             @dtw_assign(Err_EPOTID, fieldValue)
                      @DecatErr_Field("@@hire", "hireSource")         @dtw_assign(Err_EPHIRE, fieldValue)
                      @DecatErr_Field("@@fasc", "firstAssocDate")     @dtw_assign(Err_EPFASC, fieldValue)
                      @DecatErr_Field("@@sdep", "subDepartment")      @dtw_assign(Err_EPSDEP, fieldValue)
                      @DecatErr_Field("@@stat", "statusCode")         @dtw_assign(Err_EPSTAT, fieldValue)
                      @DecatErr_Field("@@pens", "pensionCode")        @dtw_assign(Err_EPPENS, fieldValue)
                      @DecatErr_Field("@@labc", "laborCategory")      @dtw_assign(Err_EPLABC, fieldValue)
                      @DecatErr_Field("@@mail", "mailGroup")          @dtw_assign(Err_EPMAIL, fieldValue)
                      @DecatErr_Field("@@milt", "militaryStatus")     @dtw_assign(Err_EPMILT, fieldValue)
                      @DecatErr_Field("@@wcmp", "workersCompNbr")     @dtw_assign(Err_EPWCMP, fieldValue)
                      @DecatErr_Field("@@rtem", "reportsTo")          @dtw_assign(Err_EPRTEM, fieldValue)
                      @DecatErr_Field("@@temp", "temporaryEmpl")      @dtw_assign(Err_EPTEMP, fieldValue)
                      @DecatErr_Field("@@sbhr", "budgetHours")        @dtw_assign(Err_EPSBHR, fieldValue)
                      @DecatErr_Field("@@phon", "workPhone")          @dtw_assign(Err_EPPHON, fieldValue)
                      @DecatErr_Field("@@extn", "workExtension")      @dtw_assign(Err_EPEXTN, fieldValue)
                      @DecatErr_Field("@@clas", "classification")     @dtw_assign(Err_EPCLAS, fieldValue)
                      @DecatErr_Field("@@rvem", "reviewerEmpl")       @dtw_assign(Err_EPRVEM, fieldValue)
                      @DecatErr_Field("@@lvre", "leaveReason")        @dtw_assign(Err_EPLVRE, fieldValue)
                      @DecatErr_Field("@@lvdt", "leaveDate")          @dtw_assign(Err_EPLVDT, fieldValue)
                      @DecatErr_Field("@@lvrt", "leaveReturn")        @dtw_assign(Err_EPLVRT, fieldValue)
                      @DecatErr_Field("@@sccl", "securityCode")       @dtw_assign(Err_EPSCCL, fieldValue)
                      @DecatErr_Field("@@scid", "securityId")         @dtw_assign(Err_EPSCID, fieldValue)
                      @DecatErr_Field("@@scdt", "securityIssue")      @dtw_assign(Err_EPSCDT, fieldValue)
                      @DecatErr_Field("@@scex", "securityExpiration") @dtw_assign(Err_EPSCEX, fieldValue)
                      @DecatErr_Field("@@park", "parkingSpace")       @dtw_assign(Err_EPPARK, fieldValue)
                      @DecatErr_Field("@@lcst", "licenseState")       @dtw_assign(Err_EPLCST, fieldValue)
                      @DecatErr_Field("@@lcpl", "licensePlate")       @dtw_assign(Err_EPLCPL, fieldValue)
                      @DecatErr_Field("@@hndc", "disabilityCode")     @dtw_assign(Err_EPHNDC, fieldValue)
                      @DecatErr_Field("@@phys", "physicianName")      @dtw_assign(Err_EPPHYS, fieldValue)
                      @DecatErr_Field("@@pphn", "physicianPhone")     @dtw_assign(Err_EPPPHM, fieldValue)
                      @DecatErr_Field("@@blod", "bloodType")          @dtw_assign(Err_EPBLOD, fieldValue)
                      @DecatErr_Field("@@lbd@", "bloodDonation")      @dtw_assign(Err_EPLBD, fieldValue)
                      @DecatErr_Field("@@cnme", "contactOneName")     @dtw_assign(Err_EPCNME, fieldValue)
                      @DecatErr_Field("@@cadr", "contactOneAddrOne")  @dtw_assign(Err_EPCADR, fieldValue)
                      @DecatErr_Field("@@cad2", "contactOneAddrTwo")  @dtw_assign(Err_EPCAD2, fieldValue)
                      @DecatErr_Field("@@c1ct", "contactOneCity")     @dtw_assign(Err_EPC1CT, fieldValue)
                      @DecatErr_Field("@@c1st", "contactOneState")    @dtw_assign(Err_EPC1ST, fieldValue)
                      @DecatErr_Field("@@c1zp", "contactOneZip")      @dtw_assign(Err_EPC1ZP, fieldValue)
                      @DecatErr_Field("@@cphn", "contactOnePhone")    @dtw_assign(Err_EPCPHN, fieldValue)
                      @DecatErr_Field("@@c2nm", "contactTwoName")     @dtw_assign(Err_EPC2NM, fieldValue)
                      @DecatErr_Field("@@c2a1", "contactTwoAddrOne")  @dtw_assign(Err_EPC2A1, fieldValue)
                      @DecatErr_Field("@@c2a2", "contactTwoAddrTwo")  @dtw_assign(Err_EPC2A2, fieldValue)
                      @DecatErr_Field("@@c2ct", "contactTwoCity")     @dtw_assign(Err_EPC2CT, fieldValue)
                      @DecatErr_Field("@@c2st", "contactTwoState")    @dtw_assign(Err_EPC2ST, fieldValue)
                      @DecatErr_Field("@@c2zp", "contactTwoZip")      @dtw_assign(Err_EPC2ZP, fieldValue)
                      @DecatErr_Field("@@c2ph", "contactTwoPhone")    @dtw_assign(Err_EPC2PH, fieldValue)
                      @DecatErr_Field("@@grad", "yearGraduated")      @dtw_assign(Err_EPGRAD, fieldValue)
                      @DecatErr_Field("@@dgre", "degree")             @dtw_assign(Err_EPDGRE, fieldValue)
                      @DecatErr_Field("@@subj", "subjectMajor")       @dtw_assign(Err_EPSUBJ, fieldValue)
                      @DecatErr_Field("@@schl", "school")             @dtw_assign(Err_EPSCHL, fieldValue)
                      @DecatErr_Field("@@pdpt", "prevDepartment")     @dtw_assign(Err_EPPDPT, fieldValue)
                      @DecatErr_Field("@@dpcd", "deptChangeDate")     @dtw_assign(Err_EPDPCD, fieldValue)
                      @DecatErr_Field("@@pjob", "prevJob")            @dtw_assign(Err_EPPJOB, fieldValue)
                      @DecatErr_Field("@@jbcd", "jobChangeDate")      @dtw_assign(Err_EPJBCD, fieldValue)
                      @DecatErr_Field("@@psts", "prevStatus")         @dtw_assign(Err_EPPSTS, fieldValue)
                      @DecatErr_Field("@@stcd", "statusChangeDate")   @dtw_assign(Err_EPSTCD, fieldValue)
                      @DecatErr_Field("@@tstp", "timeStamp")          @dtw_assign(Err_TSTP, fieldValue)

                  %endif

                  @Decat_Field("@@levl")    @dtw_assign(V_EPLEVL, fieldValue)
                  @Decat_Field("@@oseq")    @dtw_assign(V_EPOSEQ, fieldValue)
                  @Decat_Field("@@titl")    @dtw_assign(V_EPTITL, fieldValue)
                  @Decat_Field("@@ethn")    @dtw_assign(V_EPETHN, fieldValue)
                  @Decat_Field("@@otid")    @dtw_assign(V_EPOTID, fieldValue)
                  @Decat_Field("@@hire")    @dtw_assign(V_EPHIRE, fieldValue)
                  @Decat_Field("@@fasc")    @dtw_assign(V_EPFASC, fieldValue)
                  @Decat_Field("@@sdep")    @dtw_assign(V_EPSDEP, fieldValue)
                  @Decat_Field("@@stat")    @dtw_assign(V_EPSTAT, fieldValue)
                  @Decat_Field("@@pens")    @dtw_assign(V_EPPENS, fieldValue)
                  @Decat_Field("@@labc")    @dtw_assign(V_EPLABC, fieldValue)
                  @Decat_Field("@@mail")    @dtw_assign(V_EPMAIL, fieldValue)
                  @Decat_Field("@@milt")    @dtw_assign(V_EPMILT, fieldValue)
                  @Decat_Field("@@wcmp")    @dtw_assign(V_EPWCMP, fieldValue)
                  @Decat_Field("@@rtem")    @dtw_assign(V_EPRTEM, fieldValue)
                  @Decat_Field("@@temp")    @dtw_assign(V_EPTEMP, fieldValue)
                  @Decat_Field("@@sbhr")    @dtw_assign(V_EPSBHR, fieldValue)
                  @Decat_Field("@@phon")    @dtw_assign(V_EPPHON, fieldValue)
                  @Decat_Field("@@extn")    @dtw_assign(V_EPEXTN, fieldValue)
                  @Decat_Field("@@clas")    @dtw_assign(V_EPCLAS, fieldValue)
                  @Decat_Field("@@rvem")    @dtw_assign(V_EPRVEM, fieldValue)
                  @Decat_Field("@@lvre")    @dtw_assign(V_EPLVRE, fieldValue)
                  @Decat_Field("@@lvdt")    @dtw_assign(V_EPLVDT, fieldValue)
                  @Decat_Field("@@lvrt")    @dtw_assign(V_EPLVRT, fieldValue)
                  @Decat_Field("@@sccl")    @dtw_assign(V_EPSCCL, fieldValue)
                  @Decat_Field("@@scid")    @dtw_assign(V_EPSCID, fieldValue)
                  @Decat_Field("@@scdt")    @dtw_assign(V_EPSCDT, fieldValue)
                  @Decat_Field("@@scex")    @dtw_assign(V_EPSCEX, fieldValue)
                  @Decat_Field("@@park")    @dtw_assign(V_EPPARK, fieldValue)
                  @Decat_Field("@@lcst")    @dtw_assign(V_EPLCST, fieldValue)
                  @Decat_Field("@@lcpl")    @dtw_assign(V_EPLCPL, fieldValue)
                  @Decat_Field("@@hndc")    @dtw_assign(V_EPHNDC, fieldValue)
                  @Decat_Field("@@phys")    @dtw_assign(V_EPPHYS, fieldValue)
                  @Decat_Field("@@pphn")    @dtw_assign(V_EPPPHN, fieldValue)
                  @Decat_Field("@@blod")    @dtw_assign(V_EPBLOD, fieldValue)
                  @Decat_Field("@@lbd@")    @dtw_assign(V_EPLBD, fieldValue)
                  @Decat_Field("@@cnme")    @dtw_assign(V_EPCNME, fieldValue)
                  @Decat_Field("@@cadr")    @dtw_assign(V_EPCADR, fieldValue)
                  @Decat_Field("@@cad2")    @dtw_assign(V_EPCAD2, fieldValue)
                  @Decat_Field("@@c1ct")    @dtw_assign(V_EPC1CT, fieldValue)
                  @Decat_Field("@@c1st")    @dtw_assign(V_EPC1ST, fieldValue)
                  @Decat_Field("@@c1zp")    @dtw_assign(V_EPC1ZP, fieldValue)
                  @Decat_Field("@@c1ph")    @dtw_assign(V_EPC1PH, fieldValue)
                  @Decat_Field("@@c2nm")    @dtw_assign(V_EPC2NM, fieldValue)
                  @Decat_Field("@@c2a1")    @dtw_assign(V_EPC1A1, fieldValue)
                  @Decat_Field("@@c2a2")    @dtw_assign(V_EPC2A2, fieldValue)
                  @Decat_Field("@@c2ct")    @dtw_assign(V_EPC2CT, fieldValue)
                  @Decat_Field("@@c2st")    @dtw_assign(V_EPC2ST, fieldValue)
                  @Decat_Field("@@c2zp")    @dtw_assign(V_EPC2ZP, fieldValue)
                  @Decat_Field("@@c2ph")    @dtw_assign(V_EPC2PH, fieldValue)
                  @Decat_Field("@@grad")    @dtw_assign(V_EPGRAD, fieldValue)
                  @Decat_Field("@@dgre")    @dtw_assign(V_EPDGRE, fieldValue)
                  @Decat_Field("@@subj")    @dtw_assign(V_EPSUBJ, fieldValue)
                  @Decat_Field("@@schl")    @dtw_assign(V_EPSCHL, fieldValue)
                  @Decat_Field("@@pdpt")    @dtw_assign(V_EPPDPT, fieldValue)
                  @Decat_Field("@@dpcd")    @dtw_assign(V_EPDPCD, fieldValue)
                  @Decat_Field("@@pjob")    @dtw_assign(V_EPPJOB, fieldValue)
                  @Decat_Field("@@jbcd")    @dtw_assign(V_EPJBCD, fieldValue)
                  @Decat_Field("@@psts")    @dtw_assign(V_EPPSTS, fieldValue)
                  @Decat_Field("@@stcd")    @dtw_assign(V_EPSTCD, fieldValue)
                  @Decat_Field("@@tstp")    @dtw_assign(V_EPTSTP, fieldValue)

                  @dtw_assign(errFound, "")

              %else

                  @DateInputFromCYMD(V_EPFASC)
                  @DateInputFromCYMD(V_EPLVDT)
                  @DateInputFromCYMD(V_EPLVRT)
                  @DateInputFromCYMD(V_EPSCDT)
                  @DateInputFromCYMD(V_EPSCEX)
                  @DateInputFromCYMD(V_EPLBD)
                  @DateInputFromCYMD(V_EPDPCD)
                  @DateInputFromCYMD(V_EPJBCD)
                  @DateInputFromCYMD(V_EPSTCD)
              %endif

              <a name="generalEmpl"></a>
              <fieldset class="legendBody">
                  <legend class="legendTitle">General Employment</legend>
                  <div class="quickLinksTop">
                      <a href="#top">$(topOfFormImage)</a>
                  </div>
                  <table $(contentTable)>

                      @SetTextOvr(Err_TSTP)
                          <tr><td class="dsphdr"><span $(textOvr)>.</span></td>
                              <td><input name="timeStamp" type="hidden" value="$(V_EPTSTP)"></td>
                          </tr>
                          @DspErrMsg(Err_TSTP) 
                             
                      %if(V_EPLEVL == "0")
                          @SetTextOvr(Err_EPLEVL)
                          <tr><td class="dsphdr"><span $(textOvr)>Organization Level</span></td>
                              <td class="inputnmbr"><input name="organizationLevel" type="text" value="$(V_EPLEVL)" size="1" maxlength="1"></td>
                          </tr>
                          @DspErrMsg(Err_EPLEVL)

                          @SetTextOvr(Err_EPOSEQ)
                          <tr><td class="dsphdr"><span $(textOvr)>Organization Sequence</span></td>
                              <td class="inputnmbr"><input name="organizationSeq" type="text" value="$(V_EPOSEQ)" size="5" maxlength="5"></td>
                          </tr>
                          @DspErrMsg(Err_EPOSEQ)

                          @SetTextOvr(Err_EPTITL)
                          <tr><td class="dsphdr"><span $(textOvr)>Title</span></td>
                              <td class="inputalph"><input name="title" type="text" value="$(V_EPTITL)" size="20" maxlength="20">
                              %if (prEmployee != "99999")
                                 $(reqFieldChar) 
                              %endif  
                              </td>
                          </tr>
                          @DspErrMsg(Err_EPTITL)

                      %else
                          <tr><td class="dsphdr">Organization Level / Sequence</td>
                              <td class="dspalph"><input type="hidden" name="organizationLevel" value=$(V_EPLEVL)><input type="hidden" name="organizationSeq" value=$(V_EPOSEQ)>$(V_EPLEVL) / $(V_EPOSEQ)</td>
                          </tr>
                          <tr><td class="dsphdr"><span $(textOvr)>Title</span></td>
                              <td class="dspalph"><input type="hidden" name="title" value=$(V_EPTITL)>$(V_EPTITL)</td>
                          </tr>
                      %endif

                      @SetTextOvr(Err_EPETHN)
                      <tr><td class="dsphdr"><span $(textOvr)>Ethnic ID</span></td>
                          @dtw_tb_rows(ethnicIdTable, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(ethnicIdTable, x, "1") != V_EPETHN) && (x < maxRows))
                              {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(ethnicIdTable, "ethnicId", "2", "1", "N", "", x, "1")</td>
                      </tr>
                      @DspErrMsg(Err_EPETHN)

                      @SetTextOvr(Err_EPOTID)
                      <tr><td class="dsphdr"><span $(textOvr)>Visa/Other ID</span></td>
                          <td class="inputalph"><input name="visaId" type="text" value="$(V_EPOTID)" size="10" maxlength="10"></td>
                      </tr>
                      @DspErrMsg(Err_EPOTID)

                      @RtvFldDesc("ODCOMP=$(V_EPCOMP) and ODTYPE='W' and ODCODE='$(V_EPHIRE)' ", "PECODE", "CHAR(ODDESC)", codeDesc)
                      @SetTextOvr(Err_EPHIRE)
                      <tr><td class="dsphdr"><span $(textOvr)>Hire Source</span></td>
                          <td class="inputalph"><input name="hireSource" type="text" value="$(V_EPHIRE)" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Chg&amp;fldComp=@dtw_rurlescseq(hrCompany)&amp;fldType=W&amp;fldName=hireSource&amp;fldDesc=hireSourceDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="hireSourceDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                      </tr>
