%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "URL Maintenance"
  d2wName                 = "URLMasterMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;urlID=@dtw_rurlescseq(urlID)&amp;urlDesc=@dtw_rurlescseq(urlDesc)&amp;maintenanceCode=D"
  programName             = "HSYURM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.urlID.value =="" ||
                      document.Chg.urlDesc.value =="")
                         {alert("$(reqFieldError)"); return false;}
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "URLMASTERMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "SELECT *  ", stmtSQL)
                          @dtw_concat(fileSQL, " SYURLM  ", fileSQL)
                          @dtw_concat(selectSQL, " FUID='$(urlID)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN  CHAR(64) profileHandle,
                                       CHAR(2)   dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=145")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "urlID")
                      %else
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @dtw_assign(focusField, "")
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@id@@", "urlID")   @dtw_assign(Err_FUID, fieldValue)
                          @DecatErr_Field("@@desc", "urlDesc")   @dtw_assign(Err_FUDESC, fieldValue)
                          @DecatErr_Field("@@titl", "title")   @dtw_assign(Err_FUTITL, fieldValue)
                          @DecatErr_Field("@@trgt", "target")   @dtw_assign(Err_FUTRGT, fieldValue)
                          @DecatErr_Field("@@url@", "url")   @dtw_assign(Err_FUURL, fieldValue)
                          @DecatErr_Field("@@img@", "image")   @dtw_assign(Err_FUIMG, fieldValue)
                      %endif

                      @Decat_Field("@@id@@")   @dtw_assign(V_FUID, fieldValue)
                      @Decat_Field("@@desc")   @dtw_assign(V_FUDESC, fieldValue)
                      @Decat_Field("@@titl")   @dtw_assign(V_FUTITL, fieldValue)
                      @Decat_Field("@@trgt")   @dtw_assign(V_FUTRGT, fieldValue)
                      @Decat_Field("@@url@")   @dtw_assign(V_FUURL, fieldValue)
                      @Decat_Field("@@img@")   @dtw_assign(V_FUIMG, fieldValue)
                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "urlID")
                  %else
                      @dtw_assign(focusField, "urlDesc")
                  %endif

                  @SetTextOvr(Err_FUID)
                  <tr><td class="dsphdr"><span $(textOvr)>URL ID</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="urlID" type="text" value="$(V_FUID)" size="55" maxlength="55"> $(reqFieldChar) </td>
                      %else
                          <td class="inputalph"><input name="urlID" type="hidden" value="$(V_FUID)">$(V_FUID)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_FUID)

                  @SetTextOvr(Err_FUDESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="urlDesc" type="text" value="$(V_FUDESC)" size="20" maxlength="20"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_FUDESC)
	   		
                  @SetTextOvr(Err_FUTITL)
                  <tr><td class="dsphdr"><span $(textOvr)>Title</span></td>
                      <td class="inputalph"><input type="text" name="title" value="$(V_FUTITL)" size="50" maxlength="50"></td>
                  </tr>
	   		
                  @SetTextOvr(Err_FUTRGT)
                  <tr><td class="dsphdr"><span $(textOvr)>Target</span></td>
                      <td class="inputalph"><input type="text" name="target" value="$(V_FUTRGT)" size="10" maxlength="10"></td>
                  </tr>
                  @DspErrMsg(Err_FUTRGT)
	   		
                  @SetTextOvr(Err_FUURL)
                  <tr><td class="dsphdr"><span $(textOvr)>URL</span></td>
                      <td class="inputalph"><input type="text" name="url" value="$(V_FUURL)" size="512" maxlength="512"></td>
                  </tr>
                  @DspErrMsg(Err_FUURL)
	   		
                  @SetTextOvr(Err_FUIMG)
                  <tr><td class="dsphdr"><span $(textOvr)>Image</span></td>
                      <td class="inputalph"><input type="text" name="image" value="$(V_FUIMG)" size="256" maxlength="256"></td>
                  </tr>
                  @DspErrMsg(Err_FUIMG)
              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSYURM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(urlID)
  @dtw_replace(url, "&", "&amp;", url)
  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@id@@", urlID)
  @Concat_Field("@@desc", urlDesc)
  @Concat_Field("@@titl", title)
  @Concat_Field("@@trgt", target)
  @Concat_Field("@@url@", url)
  @Concat_Field("@@img@", image)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(urlDesc), $(urlID), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@id@@", "urlID")
          @Format_ConfMsg_Desc("", $(urlDesc), $(urlID), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=145&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;urlID=@dtw_rurlescseq(urlID)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
