%INCLUDE "$(baseVar)"
%INCLUDE "CostErrorMsg.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Cost Summary"
  d2wName                 = "CostSummary.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPD030"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script type="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
                  %INCLUDE "Menu.js"
    	           %INCLUDE "numedit.icl"
                  %INCLUDE "NewWindowOpen.icl"
                  %INCLUDE "CheckEnterSearch.icl"
                  function validate(searchForm) {
                      if (editNum(document.Search.srchCostSet, 2, 0))
                          return true;
                  }
               </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                          @dtw_assign(pageID, "Cost Summary")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " HDMCMM left join SCMSTM on CMCSET=STCSET ", fileSQL)
                          @dtw_concat(selectSQL, " CMCSET<>0 and ", selectSQL)
                          @dtw_concat(selectSQL, " CMPLT=$(plantNumber) and CMPN='$(itemNumber)'", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @CostSummary_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) CostSummary_Query (IN CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)

          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                      <td class="toolbar">
                          @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
                          %if (backURL != "")
                              <a href="$(backURL)" title="BackHome">$(portalHome)</a>
                          %elseif ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="BackHome">$(portalHome)</a>
                          %endif
                          %if (sec_01 == "Y")
                              <a href="$(homeURL)$(cGIPath)CostSummaryMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
          </table>

          <table $(contentTable)>
              @Format_Header_URL("Plant", $(plantName), $(plantNumber), "$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(d2wVarBase)")
              @Format_Header_URL("Item", $(itemDescription), $(itemNumber), "$(homeURL)$(cGIPath)ItemSelect.d2w/REPORT$(d2wVarBase)&amp;itemDescription=@dtw_rurlescseq(itemDescription)")
          </table>
          %INCLUDE "ConfMessageDisplay.icl"

          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Set</th></tr>
                      <tr><td><input type="text" class="inputnmbr" name="srchCostSet" size="5" maxlength="2">
                              <input type="hidden" name="operCostSet" value="=">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchCostSet.focus();
                  </script>
              </form>

              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              <tr>
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLCC1D", Cat1Desc)
                  @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLCC2D", Cat2Desc)
                  @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLCC3D", Cat3Desc)
                  @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLCC4D", Cat4Desc)
                  @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLCC5D", Cat5Desc)

                  @OrderBy_Sort("CMCSET", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CostSet" title="Sequence By Cost Set"> Cost<br>Set</a></th>
                  @OrderBy_Sort("STCSLD", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Description"> Description</a></th>
                  <th class="colhdr">$(Cat1Desc)</th>
                  <th class="colhdr">$(Cat2Desc)</th>
                  <th class="colhdr">$(Cat3Desc)</th>
                  <th class="colhdr">$(Cat4Desc)</th>
                  <th class="colhdr">$(Cat5Desc)</th>
                  <th class="colhdr">Total Cost</th>
                  @OrderBy_Sort("CMDTMT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=LastMaintenance" title="Sequence By Last Maintenance Date"> Last<br>Maint</a></th>
                  @OrderBy_Sort("CMRUDT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=LastCostRoll" title="Sequence By Last Cost Roll Date"> Last Cost<br>Roll</a></th>
                  @OrderBy_Sort("CMCEFL", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CostError" title="Sequence By Cost Roll Error"> C<br>E</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"

              %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;costSet=@dtw_rurlescseq(V_CMCSET)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
                  %INCLUDE "SetRowClass.icl"
                  @Format_Date(V_CMDTMT, "D", F_CMDTMT)
                  @Format_Date(V_CMRUDT, "D", F_CMRUDT)
                  @Format_Confirm_Desc($(V_STCSLD), $(V_CMCSET), "", "", "", "", confirmDesc)

                  <tr class="$(rowClass)">
                      %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                          <td class="opticon">
                              %if (sec_02 == "Y" || sec_03 == "Y")
                                  <a href="$(homeURL)$(cGIPath)CostSummaryMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                              %endif
                              %if (sec_01=="Y" && sec_04=="Y")
                                  <a href="$(homeURL)$(cGIPath)CostSummaryMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                              %endif
                              %if (sec_03 == "Y")
                                  <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)CostSummaryMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                              %endif
                          </td>
                      %endif
                      <td class="colnmbr">$(V_CMCSET)</td>
                      <td class="colalph">$(V_STCSLD)</td>
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)CostSummaryDetCostInquiry.d2w/REPORT$(d2wVarBase)&amp;$(plantURL)&amp;costSet=@dtw_rurlescseq(V_CMCSET)&amp;costCategory=1&amp;totalCost=@dtw_rurlescseq(V_CMUCC1)" onclick="$(inquiryWinVar)" title="Detail Cost Quickview">$(V_CMUCC1)</a></td>
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)CostSummaryDetCostInquiry.d2w/REPORT$(d2wVarBase)&amp;$(plantURL)&amp;costSet=@dtw_rurlescseq(V_CMCSET)&amp;costCategory=2&amp;totalCost=@dtw_rurlescseq(V_CMUCC2)" onclick="$(inquiryWinVar)" title="Detail Cost Quickview">$(V_CMUCC2)</a></td>
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)CostSummaryDetCostInquiry.d2w/REPORT$(d2wVarBase)&amp;$(plantURL)&amp;costSet=@dtw_rurlescseq(V_CMCSET)&amp;costCategory=3&amp;totalCost=@dtw_rurlescseq(V_CMUCC3)" onclick="$(inquiryWinVar)" title="Detail Cost Quickview">$(V_CMUCC3)</a></td>
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)CostSummaryDetCostInquiry.d2w/REPORT$(d2wVarBase)&amp;$(plantURL)&amp;costSet=@dtw_rurlescseq(V_CMCSET)&amp;costCategory=4&amp;totalCost=@dtw_rurlescseq(V_CMUCC4)" onclick="$(inquiryWinVar)" title="Detail Cost Quickview">$(V_CMUCC4)</a></td>
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)CostSummaryDetCostInquiry.d2w/REPORT$(d2wVarBase)&amp;$(plantURL)&amp;costSet=@dtw_rurlescseq(V_CMCSET)&amp;costCategory=5&amp;totalCost=@dtw_rurlescseq(V_CMUCC5)" onclick="$(inquiryWinVar)" title="Detail Cost Quickview">$(V_CMUCC5)</a></td>
                      @DTW_ASSIGN(costTotal, @dtw_radd(V_CMUCC1, @dtw_radd(V_CMUCC2, @dtw_radd(V_CMUCC3, @dtw_radd(V_CMUCC4, V_CMUCC5)))))
                      <td class="colnmbr">$(costTotal)</td>
                      <td class="coldate">$(F_CMDTMT)</td>
                      <td class="coldate">$(F_CMRUDT)</td>
                      <td class="colalph">$(V_CMCEFL)</td>
                  </tr>
                  %if ($(V_CMCEFL) != "")
                      @Retrieve_Cost_Error(V_CMCEFL, errMsg)
                      <tr class="$(rowClass)">
                          %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                              <td>&nbsp;</td>
                          %endif
                          <td class="colalph">&nbsp;</td><td class="colalph">&nbsp;</td><td class="colalph" colspan="9">$(errMsg)</td>
                      </tr>
                  %endif
              %}
          </table>
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
          $(hrTagAttr)
          %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
  @dtw_concat(fileSQL, " HDMCMM left join SCMSTM on CMCSET=STCSET ", fileSQL)
  @dtw_concat(selectSQL, " CMCSET<>0 and ", selectSQL)
  @dtw_concat(selectSQL, " CMPLT=$(plantNumber) and CMPN='$(itemNumber)'", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @CostSummary_XMLQuery(profileHandle, dataBaseID, stmtSQL)

%}

%FUNCTION(dtw_sql) CostSummary_XMLQuery (IN  CHAR(64)    profileHandle,
			               CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("CostSummaryList")
		
          %ROW{
              @XMLIDTag("$(V_CMPLT)/$(V_CMCSET)/$(V_CMPN)", "Cost Summary")
                  @XMLTag(V_CMPLT, "PlantName")
                  @XMLTag(V_CMCSET, "CostSet")
                  @XMLTag(V_CMPN, "ItemNumber")
                  @XMLTag(V_CMUCC1, "UnitCostCategory1")
                  @XMLTag(V_CMUCC2, "UnitCostCategory2")
                  @XMLTag(V_CMUCC3, "UnitCostCategory3")
                  @XMLTag(V_CMUCC4, "UnitCostCategory4")
                  @XMLTag(V_CMUCC5, "UnitCostCategory5")
                  @XMLTag(V_CMLCC1, "ThisLevelCostCategory1")
                  @XMLTag(V_CMLCC2, "ThisLevelCostCategory2")
                  @XMLTag(V_CMLCC3, "ThisLevelCostCategory3")
                  @XMLTag(V_CMLCC4, "ThisLevelCostCategory4")
                  @XMLTag(V_CMLCC5, "ThisLevelCostCategory5")
                  @XMLTag(V_CMBSC1, "BaseCostCategory1")
                  @XMLTag(V_CMBSC2, "BaseCostCategory2")
                  @XMLTag(V_CMBSC3, "BaseCostCategory3")
                  @XMLTag(V_CMBSC4, "BaseCostCategory4")
                  @XMLTag(V_CMBSC5, "BaseCostCategory5")
                  @XMLTag(V_CMRUDT, "DateLastCostRoll")
                  @XMLTag(V_CMEFDT, "CostRollEffectivityDate")
                  @XMLTag(V_CMDTMT, "DateOfLastMaintenance")
                  @XMLTag(V_CMCEFL, "CostError")
              @XMLEndTag("Cost")
	   %}

      @XMLEndTag("CostSummaryList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "CMCSET")
          @DTW_ASSIGN(orderByDisplay, "Cost Set")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "CostSet")
      %if (orderBy == "CMCSET")
          @DTW_ASSIGN(orderBy, "CMCSET DESC")
          @DTW_ASSIGN(orderByDisplay, "Cost Set (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CMCSET")
          @DTW_ASSIGN(orderByDisplay, "Cost Set")
      %endif
  %elif (sequence == "Description")
      %if (orderBy == "STCSLD,CMCSET")
          @DTW_ASSIGN(orderBy, "STCSLD DESC,CMCSET")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Cost Set")
      %else
          @DTW_ASSIGN(orderBy, "STCSLD,CMCSET")
          @DTW_ASSIGN(orderByDisplay, "Description, Cost Set")
      %endif
  %elif (sequence == "LastMaintenance")
      %if (orderBy == "CMDTMT,CMCSET")
          @DTW_ASSIGN(orderBy, "CMDTMT DESC,CMCSET")
          @DTW_ASSIGN(orderByDisplay, "Last Maintenance (descending), Cost Set")
      %else
          @DTW_ASSIGN(orderBy, "CMDTMT,CMCSET")
          @DTW_ASSIGN(orderByDisplay, "Last Maintenance, Cost Set")
      %endif
  %elif (sequence == "LastCostRoll")
      %if (orderBy == "CMRUDT,CMCSET")
          @DTW_ASSIGN(orderBy, "CMRUDT DESC,CMCSET")
          @DTW_ASSIGN(orderByDisplay, "Last Cost Roll (descending), Cost Set")
      %else
          @DTW_ASSIGN(orderBy, "CMRUDT,CMCSET")
          @DTW_ASSIGN(orderByDisplay, "Last Cost Roll, Cost Set")
      %endif
  %elif (sequence == "CostError")
      %if (orderBy == "CMCEFL,CMCSET")
          @DTW_ASSIGN(orderBy, "CMCEFL DESC,CMCSET")
          @DTW_ASSIGN(orderByDisplay, "Cost Error (descending), Cost Set")
      %else
          @DTW_ASSIGN(orderBy, "CMCEFL,CMCSET")
          @DTW_ASSIGN(orderByDisplay, "Cost Error, Cost Set")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "Menu.js"
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchCostSet, 2, 0) &&
                      editNum(document.Search.srchMaintDate, 6, 0) &&
                      editNum(document.Search.srchRollDate, 6, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "COSTSUMMARYSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"

                      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
                      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
                      <table $(contentTable)>
                          @Format_Header_URL("Plant", $(plantName), $(plantNumber), "$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)")
                          @Format_Header_URL("Item", $(itemDescription), $(itemNumber), "$(homeURL)$(cGIPath)ItemSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;itemDescription=@dtw_rurlescseq(itemDescription)")
                      </table>

                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Cost Set</td>
                              @dtw_assign(operNbr, "operCostSet")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchCostSet" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDescription")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDescription" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Date Of Last Maintenance</td>
                              @dtw_assign(operNbr, "operMaintDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchMaintDate" size="6" maxlength="6"><a href="javascript:calWindow('srchMaintDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Date Of Last Cost Roll</td>
                              @dtw_assign(operNbr, "operRollDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchRollDate" size="6" maxlength="6"><a href="javascript:calWindow('srchRollDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Cost Error Code</td>
                              @dtw_assign(operNbr, "operCostError")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCostError" size="1" maxlength="1"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchCostSet.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
  @dtw_mUPPERCASE(srchCostError)

  @Build_WildCard ("CMCSET", "Cost Set", $(srchCostSet), "", operCostSet, "N")
  @Build_WildCard ("STCSLD", "Description", $(srchDescription), "", operDescription, "A")
  @Build_WildCard ("CMDTMT", "Date Of Last Maintenance", $(srchMaintDate), "", operMaintDate, "D")
  @Build_WildCard ("CMRUDT", "Date Of Last Roll", $(srchRollDate), "", operRollDate, "D")
  @Build_WildCard ("CMCEFL", "Cost Error Code", $(srchCostError), "", operCostError, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
