%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Vendor Kanban Activity Report"
  d2wName                 = "VendorKanbanActivityReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;PDRL=@dtw_rurlescseq(PDRL)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "5"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if  (editNum(document.Chg.fromPlantNumber, 3, 0) &&
                      editNum(document.Chg.toPlantNumber, 3, 0) &&
                      editNum(document.Chg.fromVendorNumber, 7, 0) &&
                      editNum(document.Chg.toVendorNumber, 7, 0) &&
                      editNum(document.Chg.fromBuyerNumber, 7, 0) &&
                      editNum(document.Chg.toBuyerNumber, 7, 0) &&
                      editdate(document.Chg.fromDateLastTriggered) &&
                      editdate(document.Chg.toDateLastTriggered) &&
                      editFromToAll(document.Chg.fromPlantNumber, document.Chg.toPlantNumber, document.Chg.allPlantNumber, 3) &&
                      editFromToAll(document.Chg.fromVendorNumber, document.Chg.toVendorNumber, document.Chg.allVendorNumber, 7) &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromBuyerNumber, document.Chg.toBuyerNumber, document.Chg.allBuyerNumber, 7) &&
                      editFromToAll(document.Chg.fromDateLastTriggered, document.Chg.toDateLastTriggered, document.Chg.allDateLastTriggered, "D"))
                      return true;

              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "VENDORKANBANACTIVITYREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromPlantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb") @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@selc", "printPrevious")     @dtw_assign(Err_N1PPRV,  fieldValue)
                                  @DecatErr_Field("@@fplt", "fromPlantNumber")        @dtw_assign(Err_N1FPLT,  fieldValue)
                                  @DecatErr_Field("@@tplt", "toPlantNumber")        @dtw_assign(Err_N1TPLT,  fieldValue)
                                  @DecatErr_Field("@@aplt", "allPlantNumber")        @dtw_assign(Err_N1APLT,  fieldValue)
                                  @DecatErr_Field("@@splt", "sortPlantNumber")        @dtw_assign(Err_N1SPLT,  fieldValue)
                                  @DecatErr_Field("@@pplt", "pageBrkPlantNumber")        @dtw_assign(Err_N1PPLT,  fieldValue)
                                  @DecatErr_Field("@@fvnd", "fromVendorNumber")        @dtw_assign(Err_N1FVND,  fieldValue)
                                  @DecatErr_Field("@@tvnd", "toVendorNumber")        @dtw_assign(Err_N1TVND,  fieldValue)
                                  @DecatErr_Field("@@avnd", "allVendorNumber")        @dtw_assign(Err_N1AVND,  fieldValue)
                                  @DecatErr_Field("@@svnd", "sortVendorNumber")        @dtw_assign(Err_N1SVND,  fieldValue)
                                  @DecatErr_Field("@@pvnd", "pageBrkVendorNumber")        @dtw_assign(Err_N1PVND,  fieldValue)
                                  @DecatErr_Field("@@fitm", "fromItemNumber")        @dtw_assign(Err_N1FITM,  fieldValue)
                                  @DecatErr_Field("@@titm", "toItemNumber")        @dtw_assign(Err_N1TITM,  fieldValue)
                                  @DecatErr_Field("@@aitm", "allItemNumber")        @dtw_assign(Err_N1AITM,  fieldValue)
                                  @DecatErr_Field("@@sitm", "sortItemNumber")        @dtw_assign(Err_N1SITM,  fieldValue)
                                  @DecatErr_Field("@@pitm", "pageBrkItemNumber")        @dtw_assign(Err_N1PITM,  fieldValue)
                                  @DecatErr_Field("@@fbyr", "fromBuyerNumber")        @dtw_assign(Err_N1FBYR,  fieldValue)
                                  @DecatErr_Field("@@tbyr", "toBuyerNumber")        @dtw_assign(Err_N1TBYR,  fieldValue)
                                  @DecatErr_Field("@@abyr", "allBuyerNumber")        @dtw_assign(Err_N1ABYR,  fieldValue)
                                  @DecatErr_Field("@@sbyr", "sortBuyerNumber")        @dtw_assign(Err_N1SBYR,  fieldValue)
                                  @DecatErr_Field("@@pbyr", "pageBrkBuyerNumber")        @dtw_assign(Err_N1PBYR,  fieldValue)
                                  @DecatErr_Field("@@fdat", "fromDateLastTriggered")      @dtw_assign(Err_N1FDAT,  fieldValue)
                                  @DecatErr_Field("@@tdat", "toDateLastTriggered")        @dtw_assign(Err_N1TDAT,  fieldValue)
                                  @DecatErr_Field("@@adat", "allDateLastTriggered")       @dtw_assign(Err_N1ADAT,  fieldValue)
                                  @DecatErr_Field("@@sdat", "sortDateLastTriggered")      @dtw_assign(Err_N1SDAT,  fieldValue)
                                  @DecatErr_Field("@@pdat", "pageBrkDateLastTriggered")      @dtw_assign(Err_N1PDAT,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@selc")  @dtw_assign(V_N1PPRV,  fieldValue)
                                  @Decat_Field("@@fplt")  @dtw_assign(V_N1FPLT,  fieldValue)
                                  @Decat_Field("@@tplt")  @dtw_assign(V_N1TPLT,  fieldValue)
                                  @Decat_Field("@@aplt")  @dtw_assign(V_N1APLT,  fieldValue)
                                  @Decat_Field("@@splt")  @dtw_assign(V_N1SPLT,  fieldValue)
                                  @Decat_Field("@@pplt")  @dtw_assign(V_N1PPLT,  fieldValue)
                                  @Decat_Field("@@fvnd")  @dtw_assign(V_N1FVND,  fieldValue)
                                  @Decat_Field("@@tvnd")  @dtw_assign(V_N1TVND,  fieldValue)
                                  @Decat_Field("@@avnd")  @dtw_assign(V_N1AVND,  fieldValue)
                                  @Decat_Field("@@svnd")  @dtw_assign(V_N1SVND,  fieldValue)
                                  @Decat_Field("@@pvnd")  @dtw_assign(V_N1PVND,  fieldValue)
                                  @Decat_Field("@@fitm")  @dtw_assign(V_N1FITM,  fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N1TITM,  fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N1AITM,  fieldValue)
                                  @Decat_Field("@@sitm")  @dtw_assign(V_N1SITM,  fieldValue)
                                  @Decat_Field("@@pitm")  @dtw_assign(V_N1PITM,  fieldValue)
                                  @Decat_Field("@@fbyr")  @dtw_assign(V_N1FBYR,  fieldValue)
                                  @Decat_Field("@@tbyr")  @dtw_assign(V_N1TBYR,  fieldValue)
                                  @Decat_Field("@@abyr")  @dtw_assign(V_N1ABYR,  fieldValue)
                                  @Decat_Field("@@sbyr")  @dtw_assign(V_N1SBYR,  fieldValue)
                                  @Decat_Field("@@pbyr")  @dtw_assign(V_N1PBYR, fieldValue)
                                  @Decat_Field("@@fdat")  @dtw_assign(V_N1FDAT,  fieldValue)
                                  @Decat_Field("@@tdat")  @dtw_assign(V_N1TDAT,  fieldValue)
                                  @Decat_Field("@@adat")  @dtw_assign(V_N1ADAT,  fieldValue)
                                  @Decat_Field("@@sdat")  @dtw_assign(V_N1SDAT,  fieldValue)
                                  @Decat_Field("@@pdat")  @dtw_assign(V_N1PDAT,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1PPRV == "02")
                                      @dtw_assign(no, "")
                                      @dtw_assign(yes, "CHECKED")
                                  %else
                                      @dtw_assign(no, "CHECKED")
                                      @dtw_assign(yes, "")
                                  %endif

                                  %if (V_N1APLT == "ALL")
                                      @dtw_assign(checkedAllPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllPlantNumber, "")
                                  %endif
                                  %if (V_N1AVND == "ALL")
                                      @dtw_assign(checkedAllVendorNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllVendorNumber, "")
                                  %endif
                                  %if (V_N1AITM == "ALL")
                                      @dtw_assign(checkedAllItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllItemNumber, "")
                                  %endif
                                  %if (V_N1ABYR == "ALL")
                                      @dtw_assign(checkedAllBuyerNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllBuyerNumber, "")
                                  %endif
                                  %if (V_N1ADAT == "ALL")
                                      @dtw_assign(checkedAllDateLastTriggered, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllDateLastTriggered, "")
                                  %endif

                                  %if (V_N1PPLT == "Y")
                                      @dtw_assign(checkedPageBrkPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedPageBrkPlantNumber, "")
                                  %endif
                                  %if (V_N1PVND == "Y")
                                      @dtw_assign(checkedPageBrkVendorNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedPageBrkVendorNumber, "")
                                  %endif
                                  %if (V_N1PITM == "Y")
                                      @dtw_assign(checkedPageBrkItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedPageBrkItemNumber, "")
                                  %endif
                                  %if (V_N1PBYR == "Y")
                                      @dtw_assign(checkedPageBrkBuyerNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedPageBrkBuyerNumber, "")
                                  %endif
                                  %if (V_N1PDAT == "Y")
                                      @dtw_assign(checkedPageBrkDateLastTriggered, "CHECKED")
                                  %else
                                      @dtw_assign(checkedPageBrkDateLastTriggered, "")
                                  %endif
                              %else
                                  @dtw_assign(no, "CHECKED")
                                  @dtw_assign(yes, "")
                                  @dtw_assign(printPrevious, "01")
                                  @dtw_assign(checkedAllPlantNumber, "CHECKED")
                                  @dtw_assign(checkedAllVendorNumber, "CHECKED")
                                  @dtw_assign(checkedAllItemNumber, "CHECKED")
                                  @dtw_assign(checkedAllBuyerNumber, "CHECKED")
                                  @dtw_assign(checkedAllDateLastTriggered, "CHECKED")
                                  @dtw_assign(V_N1SPLT, "1")
                                  @dtw_assign(V_N1SVND, "2")
                                  @dtw_assign(V_N1SITM, "3")
                                  @dtw_assign(checkedPageBrkPlantNumber, "CHECKED")
                                  @dtw_assign(checkedPageBrkVendorNumber, "CHECKED")
                                  @dtw_assign(checkedPageBrkItemNumber, "")
                                  @dtw_assign(checkedPageBrkBuyerNumber, "")
                                  @dtw_assign(checkedPageBrkDateLastTriggered, "")
                              %endif

                              @SetTextOvr(Err_N1PPRV)
                              <tr><td  class="dsphdr"><span $(textOvr)>Print Previously Printed Rows</span></td>
                                  <td class="inputnmbr"><input name="printPrevious" type="radio" VALUE='01' $(no)>No</td>
                              </tr>
                              @DspErrMsg(Err_N1PPRV)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="printPrevious" type="radio" VALUE='02' $(yes)>Yes</td>
                              </tr>
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                                  <td class="colhdr">Page<br>Break</td>
                              </tr>

                              @SetTextOvr(Err_N1FPLT)
                              %if (textOvr == "") @SetTextOvr(Err_N1TPLT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1APLT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SPLT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PPLT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                  <td class="inputnmbr"><input name="fromPlantNumber" value="$(V_N1FPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromPlantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toPlantNumber" value="$(V_N1TPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toPlantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName" type="hidden"></td>
                                  <td class="inputalph"><input name="allPlantNumber" value='ALL' $(checkedAllPlantNumber) type="checkbox" onClick="if (this.checked) this.form.fromPlantNumber.value='', this.form.toPlantNumber.value='';"></td>
                                  @Build_Sort_Select("sortPlantNumber", "$(V_N1SPLT)")
                                  <td align=center ><input name="pageBrkPlantNumber" type="checkbox" $(checkedPageBrkPlantNumber) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1FPLT)
                              @DspErrMsg(Err_N1TPLT)
                              @DspErrMsg(Err_N1APLT)
                              @DspErrMsg(Err_N1SPLT)
                              @DspErrMsg(Err_N1PPLT)

                              @SetTextOvr(Err_N1FVND)
                              %if (textOvr == "") @SetTextOvr(Err_N1TVND) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AVND) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SVND) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PVND) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Vendor Number</span></td>
                                  <td class="inputnmbr"><input name="fromVendorNumber" value="$(V_N1FVND)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="vendorName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toVendorNumber" value="$(V_N1TVND)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="vendorName" type="hidden"></td>
                                  <td class="inputalph"><input name="allVendorNumber" value='ALL' $(checkedAllVendorNumber) type="checkbox" onClick="if (this.checked) this.form.fromVendorNumber.value='', this.form.toVendorNumber.value='';"></td>
                                  @Build_Sort_Select("sortVendorNumber", "$(V_N1SVND)")
                                  <td align=center ><input name="pageBrkVendorNumber" type="checkbox" $(checkedPageBrkVendorNumber) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1FVND)
                              @DspErrMsg(Err_N1TVND)
                              @DspErrMsg(Err_N1AVND)
                              @DspErrMsg(Err_N1SVND)
                              @DspErrMsg(Err_N1PVND)

                              @SetTextOvr(Err_N1FITM)
                              %if (textOvr == "") @SetTextOvr(Err_N1TITM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AITM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SITM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PITM) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N1FITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N1TITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedAllItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                                  @Build_Sort_Select("sortItemNumber", "$(V_N1SITM)")
                                  <td align=center ><input name="pageBrkItemNumber" type="checkbox" $(checkedPageBrkItemNumber) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1FITM)
                              @DspErrMsg(Err_N1TITM)
                              @DspErrMsg(Err_N1AITM)
                              @DspErrMsg(Err_N1SITM)
                              @DspErrMsg(Err_N1PITM)

                              @SetTextOvr(Err_N1FBYR)
                              %if (textOvr == "") @SetTextOvr(Err_N1TBYR) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ABYR) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SBYR) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PBYR) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Buyer Number</span></td>
                                  <td class="inputalph"><input name="fromBuyerNumber" value="$(V_N1FBYR)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)BuyerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromBuyerNumber&amp;fldDesc=analystName&amp;buyerAnalyst=Analyst" onclick="$(searchWinVar)"> $(searchImage) </a><input name="analystName" type="hidden"></td>
                                  <td class="inputalph"><input name="toBuyerNumber" value="$(V_N1TBYR)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)BuyerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toBuyerNumber&amp;fldDesc=analystName&amp;buyerAnalyst=Analyst" onclick="$(searchWinVar)"> $(searchImage) </a><input name="analystName" type="hidden"></td>
                                  <td class="inputalph"><input name="allBuyerNumber" value='ALL' $(checkedAllBuyerNumber) type="checkbox" onClick="if (this.checked) this.form.fromBuyerNumber.value='', this.form.toBuyerNumber.value='';"></td>
                                  @Build_Sort_Select("sortBuyerNumber", "$(V_N1SBYR)")
                                  <td align=center ><input name="pageBrkBuyerNumber" type="checkbox" $(checkedPageBrkBuyerNumber) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1FBYR)
                              @DspErrMsg(Err_N1TBYR)
                              @DspErrMsg(Err_N1ABYR)
                              @DspErrMsg(Err_N1SBYR)
                              @DspErrMsg(Err_N1PBYR)

                              @SetTextOvr(Err_N1FDAT)
                              %if (textOvr == "") @SetTextOvr(Err_N1TDAT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ADAT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SDAT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PDAT) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Date Last Triggered</span></td>
                                  <td class="inputnmbr"><input name="fromDateLastTriggered" value="$(V_N1FDAT)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromDateLastTriggered');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toDateLastTriggered" value="$(V_N1TDAT)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toDateLastTriggered');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allDateLastTriggered" value='ALL' $(checkedAllDateLastTriggered) type="checkbox" onClick="if (this.checked) this.form.fromDateLastTriggered.value='', this.form.toDateLastTriggered.value='';"></td>
                                  @Build_Sort_Select("sortDateLastTriggered", "$(V_N1SDAT)")
                                  <td align=center ><input name="pageBrkDateLastTriggered" type="checkbox" $(checkedPageBrkDateLastTriggered) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1FDAT)
                              @DspErrMsg(Err_N1TDAT)
                              @DspErrMsg(Err_N1ADAT)
                              @DspErrMsg(Err_N1SDAT)
                              @DspErrMsg(Err_N1PDAT)

                          </table>

                          @dtw_assign(envProgram, "HSIVKA")
                          @dtw_assign(envPrinter, "HSIVKAPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSIVKS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allPlantNumber)
  @dtw_mUPPERCASE(allVendorNumber)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(allBuyerNumber)
  @dtw_mUPPERCASE(allDateLastTriggered)

  @dtw_assign(fromPlantNumber,@dtw_rstrip(fromPlantNumber))
  @dtw_assign(toPlantNumber,@dtw_rstrip(toPlantNumber))
  @dtw_assign(sortPlantNumber,@dtw_rstrip(sortPlantNumber))
  @dtw_assign(fromVendorNumber,@dtw_rstrip(fromVendorNumber))
  @dtw_assign(toVendorNumber,@dtw_rstrip(toVendorNumber))
  @dtw_assign(sortVendorNumber,@dtw_rstrip(sortVendorNumber))
  @dtw_assign(sortItemNumber,@dtw_rstrip(sortItemNumber))
  @dtw_assign(fromBuyerNumber,@dtw_rstrip(fromBuyerNumber))
  @dtw_assign(toBuyerNumber,@dtw_rstrip(toBuyerNumber))
  @dtw_assign(sortBuyerNumber,@dtw_rstrip(sortBuyerNumber))
  @dtw_assign(fromDateLastTriggered,@dtw_rstrip(fromDateLastTriggered))
  @dtw_assign(toDateLastTriggered,@dtw_rstrip(toDateLastTriggered))
  @dtw_assign(sortDateLastTriggered,@dtw_rstrip(sortDateLastTriggered))


  %if (allPlantNumber != "ALL")
      @dtw_assign(allPlantNumber, "")
  %endif
  %if (allVendorNumber != "ALL")
      @dtw_assign(allVendorNumber, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allBuyerNumber != "ALL")
      @dtw_assign(allBuyerNumber, "")
  %endif
  %if (allDateLastTriggered != "ALL")
      @dtw_assign(allDateLastTriggered, "")
  %endif

  %if (pageBrkPlantNumber != "Y")
      @dtw_assign(pageBrkPlantNumber, "N")
  %endif
  %if (pageBrkVendorNumber != "Y")
      @dtw_assign(pageBrkVendorNumber, "N")
  %endif
  %if (pageBrkItemNumber != "Y")
      @dtw_assign(pageBrkItemNumber, "N")
  %endif
  %if (pageBrkBuyerNumber != "Y")
      @dtw_assign(pageBrkBuyerNumber, "N")
  %endif
  %if (pageBrkDateLastTriggered != "Y")
      @dtw_assign(pageBrkDateLastTriggered, "N")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@selc", printPrevious)
  @Concat_Field("@@fplt", fromPlantNumber)
  @Concat_Field("@@tplt", toPlantNumber)
  @Concat_Field("@@aplt", allPlantNumber)
  @Concat_Field("@@splt", sortPlantNumber)
  @Concat_Field("@@pplt", pageBrkPlantNumber)
  @Concat_Field("@@fvnd", fromVendorNumber)
  @Concat_Field("@@tvnd", toVendorNumber)
  @Concat_Field("@@avnd", allVendorNumber)
  @Concat_Field("@@svnd", sortVendorNumber)
  @Concat_Field("@@pvnd", pageBrkVendorNumber)
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@sitm", sortItemNumber)
  @Concat_Field("@@pitm", pageBrkItemNumber)
  @Concat_Field("@@fbyr", fromBuyerNumber)
  @Concat_Field("@@tbyr", toBuyerNumber)
  @Concat_Field("@@abyr", allBuyerNumber)
  @Concat_Field("@@sbyr", sortBuyerNumber)
  @Concat_Field("@@pbyr", pageBrkBuyerNumber)
  @Concat_Field("@@fdat", fromDateLastTriggered)
  @Concat_Field("@@tdat", toDateLastTriggered)
  @Concat_Field("@@adat", allDateLastTriggered)
  @Concat_Field("@@sdat", sortDateLastTriggered)
  @Concat_Field("@@pdat", pageBrkDateLastTriggered)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}