%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Reprint Picking Tickets"
  d2wName                 = "OrderDocPickReprtRvw.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;stmtSQL=@dtw_rurlescseq(stmtSQL)&amp;summary=@dtw_rurlescseq(summary)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  stmtSQL                 = ""
  haveRec                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ORDERDOCPICKREPRTRVW")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " OEPICW ", fileSQL)
                      @dtw_concat(selectSQL, "PWXHND='$(profileHandle)' and PWSEL='S' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Pick_Reprint_Review_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Pick_Reprint_Review_Query (IN  CHAR(64)    profileHandle,
                                                  CHAR(2)     dataBaseID,
                                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="50%">
              <col width="45%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  <a href="javascript:history.back()">$(selectBackImage)</a>
                  <a href="javascript:check(document.Chg)">$(selectAcceptImage)</a>
              </td>
          </tr>
      </table>

      $(hrTagAttr)

      <form class="formClass" name="Chg" METHOD=POST ACTION="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)">
          <table $(contentTable)>
              <tr><td class="dsphdr">Print Picking Summary Report</td>
                  <td class="inputnmbr"><input name="summary" type="radio" VALUE='01' CHECKED>No</td>
              </tr>
              <tr><td>&nbsp;</td>
                  <td class="inputnmbr"><input name="summary" type="radio" VALUE='02'>Yes</td>
              </tr>
          </table>
      </form>

      <table $(contentTable)>
          <tr>
              <td class="colhdr">Turnaround</td>
              <td class="colhdr">Order<br>Number</td>
              <td class="colhdr">Ship-To</td>
              <td class="colhdr">Name</td>
              <td class="colhdr">Required<br>Date</td>
              <td class="colhdr">Ship<br>Via</td>
              <td class="colhdr">Order<br>Type</td>
              <td class="colhdr">User</td>
              <td class="colhdr">Generation<br>Date</td>
          </tr>
		
          %ROW{

              %INCLUDE "SetRowClass.icl"
              %if (V_PWSEL == "S")
                  @dtw_assign(selected, "CHECKED")
              %else
                  @dtw_assign(selected, "")
              %endif

              @Format_Date(V_PWRQDT, "D", F_PWRQDT)
              @Format_Date(V_PWGEND, "D", F_PWGEND)
      	       @RtvFldDesc("OTOTCD='$(V_PWORTY)' and OTAPID='OE'", "HDOTYP", "OTDESC", orderTypeDesc)
      	       @RtvFldDesc("SVSVSV='$(V_PWSVSV)' ", "HDSHPV", "SVSVDS", shipViaDesc)
      	       @RtvFldDesc("USUSER='$(V_PWUSER)' ", "SYUSER", "USDESC", userName)
      	
              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_PWTURN)</td>
                  <td class="colnmbr">$(V_PWORD#)</td>
                  <td class="colnmbr">$(V_PWSHTO)</td>
                  <td class="colalph">$(V_PWCNA1)</td>
                  <td class="coldate">$(F_PWRQDT)</td>
                  <td class="colalph" $(helpCursor)><span title="$(V_PWSVSV)">$(shipViaDesc)</span></td>
                  <td class="colcode" $(helpCursor)><span title="$(orderTypeDesc)">$(V_PWORTY)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_PWUSER)">$(userName)</span></td>
                  <td class="coldate">$(F_PWGEND)</td>
              </tr>
          %}
      </table>
      $(hrTagAttr)
      <a href="javascript:history.back()">$(selectBackImage)</a>
      <a href="javascript:check(document.Chg)">$(selectAcceptImage)</a>
      %INCLUDE "Copyright.icl"
  %}
%}
%FUNCTION(dtw_directcall) Update_Pick_Reprint (IN    CHAR(64)    profileHandle,
                                                     CHAR(2)     dataBaseID,
                                                     CHAR(1)     updCode,
                                               INOUT CHAR(1)     haveRec,
                                               INOUT CHAR(1)     errFound,
                                               INOUT CHAR(32000) edtVar,                             	
                                               INOUT CHAR(32000) errVar)
{%EXEC {HOERPS_W.PGM %}
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  %if (summary == "01")
      @dtw_assign(summary, "1")
  %else
      @dtw_assign(summary, "2")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@psum", summary)
  @Concat_Field("@@sql@", stmtSQL)
  @dtw_concat(edtVar, "}{", edtVar)

  @dtw_assign(updCode, "U")
  @dtw_assign(confMessage, "Selected Pick Tickets have been printed")
  @Update_Pick_Reprint (profileHandle, dataBaseID, updCode, haveRec, errFound, edtVar, errVar)
  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)orderdocument.d2w/REPORT$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}
