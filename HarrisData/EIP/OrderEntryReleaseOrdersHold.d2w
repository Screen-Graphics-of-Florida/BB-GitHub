%INCLUDE "$(baseVar)"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "VarBase.icl"

%Define {	
  d2wName                 = "OrderEntryReleaseOrdersHold.d2w"
%}

%FUNCTION(dtw_directcall) Validate_OE_Hold_Code(INOUT CHAR(64) profileHandle,
                                                INOUT CHAR(2) dataBaseID,
                                                INOUT CHAR(1) releaseFlag,
                                                INOUT DEC(8,0) orderNumber,
                                                INOUT CHAR(75) error)
{%EXEC {HOEOCH_W.PGM %}
%}

%HTML(Edit_Data)
{
  %INCLUDE "setLibraryList.icl"
  @Validate_OE_Hold_Code(profileHandle, dataBaseID, releaseFlag, orderNumber, error)

  %if (error == "")
      %if (releaseFlag== "C")
          @dtw_assign(confMessage, "Confirm Release Credit Hold for Order $(orderNumber)")
      %else
          @dtw_assign(confMessage, "Confirm Release Hold Code for Order $(orderNumber)")
      %endif
  %else
      @dtw_assign(confMessage, error)
  %endif
  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=448&amp;confMessage=@dtw_rurlescseq(confMessage)">
%}