%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Employee Pay Code Defaults"
  d2wName                 = "EmplPayCodeDefaults.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
  plantNumber             = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterSearch.icl"
     	           %INCLUDE "numedit.icl"
                  function validate(searchForm) {
                      if (editNum(document.Search.srchCo, 2, 0) &&
                          editNum(document.Search.srchFac, 4, 0) &&
                          editNum(document.Search.srchEmpl, 5, 0))
                          return true;

                  }
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
             <!-- Start Of Banner Code -->
             %INCLUDE "banner.icl"
             <!-- End Of Banner Code -->
             <table $(baseTable)>
                 <tr valign="top">
                     %if (formatToPrint == "")
                         @dtw_assign(pageID, "EMPLPAYCODEDEFAULTS")
                         <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                     %endif
                     <td class="content">
                         @dtw_assign(uv_CompanyName, "EMCOMP")
                         @dtw_assign(uv_FacilityName, "EMFACL")
                         @dtw_assign(uv_PREmployeeName, "EMEMPL")
                         @dtw_assign(uv_HomeDepartmentName, "EMDEPT")
                         @dtw_assign(uv_HRLocationName, "EMLOC")
                         @dtw_assign(uv_PayTypeName, "EMTYPE")
                         %INCLUDE "userview.icl"

                         %INCLUDE "stmtSQLClear.icl"
                         @dtw_concat(stmtSQL, " Select EMCOMP, EMFACL, EMEMPL, EMTYPE, EMLNAMU  ", stmtSQL)
                         @dtw_concat(fileSQL, " HREMPL ", fileSQL)
                         @dtw_concat(selectSQL, " EMEMPL<>99999 and EMPRAC<>'D'", selectSQL)
                         %INCLUDE "stmtSQLSelect.icl"
                         @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                         %INCLUDE "stmtSQLEnd.icl"
                         %INCLUDE "stmtSQLTotalRows.icl"
                         @EmplPayCodeDefaults_Query(profileHandle, dataBaseID, stmtSQL)
                     </td>
                 </tr>
             </table>
             <!-- Start Of Trailer Code -->
             %INCLUDE "trailer.icl"
             <!-- End Of Trailer Code -->
        </body>
     </html>
%}

%FUNCTION(dtw_sql) EmplPayCodeDefaults_Query (IN CHAR(64)    profileHandle,
                                                 CHAR(2)     dataBaseID,
                                                 CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/report") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search"   onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Co / Fac</th>
                      <th class="colhdr">Employee <br>Number</th>
                      <th class="colhdr">Employee <br>Last Name</th>
                  </tr>
                  <tr><td class="inputnmbr"><input name="srchCo" type="text" size="2" maxlength="2"> / <input name="srchFac" type="text" size="2" maxlength="4">
                          <input type="hidden" name="operCo" value="=">
                          <input type="hidden" name="operFac" value="=">
                      </td>
                      <td class="inputnmbr"><input name="srchEmpl" type="text" size="5" maxlength="5">
                          <input type="hidden" name="operEmpl" value="=">
                      </td>
                      <td class="inputalph"><input name="srchLastName" type="text"  size="18" maxlength="18">
                          <input type="hidden" name="operLastName" value="LIKE">
                      </td>

                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchCo.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              @OrderBy_Sort("EMLNAMU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Name" title="Sequence By Last Name, First Name, Company/Facility, Employee Number">Name</a></th>
              @OrderBy_Sort("EMCOMP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CoFac" title="Sequence By Company/Facility, Employee Number">Co/Fac</a></th>
              @OrderBy_Sort("EMEMPL", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Number" title="Sequence By Employee Number, Company/Facility">Employee<br>Number</a></th>
              <th class="colhdr">Activity</th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"
          %ROW{
              @dtw_assign(maintainVar, "$(genericVarBase)&amp;coNumber=@dtw_rurlescseq(V_EMCOMP)&amp;facNumber=@dtw_rurlescseq(V_EMFACL)&amp;emplNumber=@dtw_rurlescseq(V_EMEMPL)")
                  %INCLUDE "SetRowClass.icl"
                  @RtvFldDesc("C3COMP=$(V_EMCOMP) and C3FACL=$(V_EMFACL) and C3EMPL=$(V_EMEMPL)", "PREMDF","C3CODE", payCode)
                  %if (payCode != "")
                      @dtw_assign(activityExist, "Y")
                  %else
                      @dtw_assign(activityExist, "")
                  %endif
                  @Format_HRCoFac(V_EMCOMP, V_EMFACL, "N", F_CoFac)
                  @Ret_Format_EmplName($(V_EMCOMP), $(V_EMFACL), $(V_EMEMPL), "", "", "", F_EmpName)
                  <tr class="$(rowClass)">
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)EmplPayCodeDefaultsList.d2w/REPORT$(maintainVar)" title="View Pay Code Defaults">$(F_EmpName)</a></td>
                      <td class="colalph">$(F_CoFac)</td>
                      <td class="colnmbr"> $(V_EMEMPL)</td>
                      <td class="colcode">$(activityExist)</td>
                  </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  @dtw_assign(uv_CompanyName, "EMCOMP")
  @dtw_assign(uv_FacilityName, "EMFACL")
  @dtw_assign(uv_PREmployeeName, "EMEMPL")
  @dtw_assign(uv_HomeDepartmentName, "EMDEPT")
  @dtw_assign(uv_HRLocationName, "EMLOC")
  @dtw_assign(uv_PayTypeName, "EMTYPE")
  %INCLUDE "userview.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select EMCOMP, EMFACL, EMEMPL, EMTYPE, EMLNAMU, EMRNAM  ", stmtSQL)
  @dtw_concat(fileSQL, " HREMPL ", fileSQL)
  @dtw_concat(selectSQL, " EMEMPL<>99999 and EMPRAC<>'D'", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @PaycodeDefaults_XMLQuery(profileHandle, dataBaseID, stmtSQL)

%}

%FUNCTION(dtw_sql) PaycodeDefaults_XMLQuery (IN CHAR(64)    profileHandle,
			                         CHAR(2)     dataBaseID,
                                                CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("PayCodeDefaultsList")
          %ROW{
              @RtvFldDesc("C3COMP=$(V_EMCOMP) and C3FACL=$(V_EMFACL) and C3EMPL=$(V_EMEMPL)", "PREMDF","C3CODE", payCode)
              %if (payCode != "")
                  @dtw_assign(activityExist, "Y")
              %else
                  @dtw_assign(activityExist, "N")
              %endif
              @XMLIDTag(V_EMRNAM, "EmployeeName ID")
                  @XMLTag(V_EMCOMP, "Company")
                  @XMLTag(V_EMFACL, "Facility")
                  @XMLTag(activityExist, "Activity")
              @XMLEndTag("EmployeeName")
	   %}

      @XMLEndTag("PayCodeDefaultsList")
  %}
%}


%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "EMCOMP, EMFACL, EMEMPL")
          @DTW_ASSIGN(orderByDisplay, "Co/Fac Empl")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "CoFac")
      %if (orderBy == "EMCOMP,EMFACL,EMEMPL")
          @DTW_ASSIGN(orderBy, "EMCOMP DESC,EMFACL DESC,EMEMPL")
          @DTW_ASSIGN(orderByDisplay, "Company/Facility (descending), Employee Number")
      %else
          @DTW_ASSIGN(orderBy, "EMCOMP,EMFACL,EMEMPL")
          @DTW_ASSIGN(orderByDisplay, "Company/Facility, Employee Number")
      %endif
  %elseif (sequence == "Number")
      %if (orderBy == "EMEMPL,EMCOMP,EMFACL")
          @DTW_ASSIGN(orderBy, "EMEMPL DESC,EMCOMP,EMFACL")
          @DTW_ASSIGN(orderByDisplay, "Employee Number (descending), Company/Facility")
      %else
          @DTW_ASSIGN(orderBy, "EMEMPL,EMCOMP,EMFACL")
          @DTW_ASSIGN(orderByDisplay, "Employee Number, Company/Facility")
      %endif
  %elseif (sequence == "Name")
      %if (orderBy == "EMLNAMU,EMFNAMU,EMCOMP,EMFACL,EMEMPL")
          @DTW_ASSIGN(orderBy, "EMLNAMU DESC,EMFNAMU,EMCOMP,EMFACL,EMEMPL")
          @DTW_ASSIGN(orderByDisplay, "Last Name (descending), First Name, Company/Facility, Employee Number")
      %else
          @DTW_ASSIGN(orderBy, "EMLNAMU,EMFNAMU,EMCOMP,EMFACL,EMEMPL")
          @DTW_ASSIGN(orderByDisplay, "Last Name, First Name, Company/Facility, Employee Number")
      %endif
  %endif


  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("EMCOMP", "Company Number", $(srchCo), "", operCo, "N")
  @Build_WildCard ("EMFACL", "Facility Number", $(srchFac), "", operFac, "N")
  @Build_WildCard ("EMEMPL", "Employee Number", $(srchEmpl), "", operEmpl, "N")
  @Build_WildCard ("EMLNAMU", "Last Name", $(srchLastName), "U", operLastName, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
