%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Inventory Ranking Report"
  d2wName                 = "InventoryRankingReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "4"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromWarehouse, 3, 0) &&
                      editNum(document.Chg.toWarehouse, 3, 0) &&
                      editNum(document.Chg.fromVendorNumber, 7, 0) &&
                      editNum(document.Chg.toVendorNumber, 7, 0) &&
                      editNum(document.Chg.fromRanking, 5, 0) &&
                      editNum(document.Chg.toRanking, 5, 0) &&
                      editdate(document.Chg.fromTransactionDate) &&
                      editdate(document.Chg.toTransactionDate) &&
                      editFromToAll(document.Chg.fromWarehouse, document.Chg.toWarehouse, document.Chg.allWarehouse, 3) &&
                      editFromToAll(document.Chg.fromProductClass, document.Chg.toProductClass, document.Chg.allProductClass, "A") &&
                      editFromToAll(document.Chg.fromVendorNumber, document.Chg.toVendorNumber, document.Chg.allVendorNumber, 7) &&
                      editFromToAll(document.Chg.fromRanking, document.Chg.toRanking, document.Chg.allRanking, 5) &&
                      editFromToAll(document.Chg.fromTransactionDate, document.Chg.toTransactionDate, document.Chg.allTransactionDate, "D"))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "INVENTORYRANKINGREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromWarehouse")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@selc", "rankBy")     @dtw_assign(Err_N1SEL,  fieldValue)
                                  @DecatErr_Field("@@fwhs", "fromWarehouse")        @dtw_assign(Err_N2FR01,  fieldValue)
                                  @DecatErr_Field("@@twhs", "toWarehouse")        @dtw_assign(Err_N2TO01,  fieldValue)
                                  @DecatErr_Field("@@awhs", "allWarehouse")        @dtw_assign(Err_N2AL01,  fieldValue)
                                  @DecatErr_Field("@@swhs", "sortWarehouse")        @dtw_assign(Err_N2SQ01,  fieldValue)
                                  @DecatErr_Field("@@pwhs", "totalWarehouse")        @dtw_assign(Err_N2PT01,  fieldValue)
                                  @DecatErr_Field("@@fpcl", "fromProductClass")        @dtw_assign(Err_N2FR02,  fieldValue)
                                  @DecatErr_Field("@@tpcl", "toProductClass")        @dtw_assign(Err_N2TO02,  fieldValue)
                                  @DecatErr_Field("@@apcl", "allProductClass")        @dtw_assign(Err_N2AL02,  fieldValue)
                                  @DecatErr_Field("@@spcl", "sortProductClass")        @dtw_assign(Err_N2SQ02,  fieldValue)
                                  @DecatErr_Field("@@ppcl", "totalProductClass")        @dtw_assign(Err_N2PT02,  fieldValue)
                                  @DecatErr_Field("@@fvnd", "fromVendorNumber")        @dtw_assign(Err_N2FR03,  fieldValue)
                                  @DecatErr_Field("@@tvnd", "toVendorNumber")        @dtw_assign(Err_N2TO03,  fieldValue)
                                  @DecatErr_Field("@@avnd", "allVendorNumber")        @dtw_assign(Err_N2AL03,  fieldValue)
                                  @DecatErr_Field("@@svnd", "sortVendorNumber")        @dtw_assign(Err_N2SQ03,  fieldValue)
                                  @DecatErr_Field("@@pvnd", "totalVendorNumber")        @dtw_assign(Err_N2PT03,  fieldValue)
                                  @DecatErr_Field("@@frnk", "fromRanking")        @dtw_assign(Err_N2FR04,  fieldValue)
                                  @DecatErr_Field("@@trnk", "toRanking")        @dtw_assign(Err_N2TO04,  fieldValue)
                                  @DecatErr_Field("@@arnk", "allRanking")        @dtw_assign(Err_N2AL04,  fieldValue)
                                  @DecatErr_Field("@@srnk", "sortRanking")        @dtw_assign(Err_N2SQ04,  fieldValue)
                                  @DecatErr_Field("@@prnk", "totalRanking")        @dtw_assign(Err_N2PT04,  fieldValue)
                                  @DecatErr_Field("@@fdat", "fromTransactionDate")      @dtw_assign(Err_N2FR05,  fieldValue)
                                  @DecatErr_Field("@@tdat", "toTransactionDate")        @dtw_assign(Err_N2TO05,  fieldValue)
                                  @DecatErr_Field("@@adat", "allTransactionDate")       @dtw_assign(Err_N2AL05,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@selc")  @dtw_assign(V_N1SEL,  fieldValue)
                                  @Decat_Field("@@fwhs")  @dtw_assign(V_N2FR01,  fieldValue)
                                  @Decat_Field("@@twhs")  @dtw_assign(V_N2TO01,  fieldValue)
                                  @Decat_Field("@@awhs")  @dtw_assign(V_N2AL01,  fieldValue)
                                  @Decat_Field("@@swhs")  @dtw_assign(V_N2SQ01,  fieldValue)
                                  @Decat_Field("@@pwhs")  @dtw_assign(V_N2PT01,  fieldValue)
                                  @Decat_Field("@@fpcl")  @dtw_assign(V_N2FR02,  fieldValue)
                                  @Decat_Field("@@tpcl")  @dtw_assign(V_N2TO02,  fieldValue)
                                  @Decat_Field("@@apcl")  @dtw_assign(V_N2AL02,  fieldValue)
                                  @Decat_Field("@@spcl")  @dtw_assign(V_N2SQ02,  fieldValue)
                                  @Decat_Field("@@ppcl")  @dtw_assign(V_N2PT02,  fieldValue)
                                  @Decat_Field("@@fvnd")  @dtw_assign(V_N2FR03,  fieldValue)
                                  @Decat_Field("@@tvnd")  @dtw_assign(V_N2TO03,  fieldValue)
                                  @Decat_Field("@@avnd")  @dtw_assign(V_N2AL03,  fieldValue)
                                  @Decat_Field("@@svnd")  @dtw_assign(V_N2SQ03,  fieldValue)
                                  @Decat_Field("@@pvnd")  @dtw_assign(V_N2PT03,  fieldValue)
                                  @Decat_Field("@@frnk")  @dtw_assign(V_N2FR04,  fieldValue)
                                  @Decat_Field("@@trnk")  @dtw_assign(V_N2TO04,  fieldValue)
                                  @Decat_Field("@@arnk")  @dtw_assign(V_N2AL04,  fieldValue)
                                  @Decat_Field("@@srnk")  @dtw_assign(V_N2SQ04,  fieldValue)
                                  @Decat_Field("@@prnk")  @dtw_assign(V_N2PT04,  fieldValue)
                                  @Decat_Field("@@fdat")  @dtw_assign(V_N2FR05,  fieldValue)
                                  @Decat_Field("@@tdat")  @dtw_assign(V_N2TO05,  fieldValue)
                                  @Decat_Field("@@adat")  @dtw_assign(V_N2AL05,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1SEL == "02")
                                      @dtw_assign(grossMarginPct, "")
                                      @dtw_assign(salesAmount, "CHECKED")
                                  %else
                                      @dtw_assign(grossMarginPct, "CHECKED")
                                      @dtw_assign(salesAmount, "")
                                  %endif
                                  %if (V_N2AL01 == "ALL")
                                      @dtw_assign(checkedallWarehouse, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallWarehouse, "")
                                  %endif
                                  %if (V_N2AL02 == "ALL")
                                      @dtw_assign(checkedallProductClass, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallProductClass, "")
                                  %endif
                                  %if (V_N2AL03 == "ALL")
                                      @dtw_assign(checkedallVendorNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallVendorNumber, "")
                                  %endif
                                  %if (V_N2AL04 == "ALL")
                                      @dtw_assign(checkedallRanking, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallRanking, "")
                                  %endif
                                  %if (V_N2AL05 == "ALL")
                                      @dtw_assign(checkedallTransactionDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallTransactionDate, "")
                                  %endif

                                  %if (V_N2PT01 == "Y")
                                      @dtw_assign(checkedWarehouseTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedWarehouseTotals, "")
                                  %endif
                                  %if (V_N2PT02 == "Y")
                                      @dtw_assign(checkedProductClassTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedProductClassTotals, "")
                                  %endif
                                  %if (V_N2PT03 == "Y")
                                      @dtw_assign(checkedVendorNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedVendorNumberTotals, "")
                                  %endif
                                  %if (V_N2PT04 == "Y")
                                      @dtw_assign(checkedRankingTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedRankingTotals, "")
                                  %endif
                              %else
                                  @dtw_assign(grossMarginPct, "CHECKED")
                                  @dtw_assign(salesAmount, "")
                                  @dtw_assign(checkedallWarehouse, "CHECKED")
                                  @dtw_assign(checkedallProductClass, "CHECKED")
                                  @dtw_assign(checkedallVendorNumber, "CHECKED")
                                  @dtw_assign(checkedallRanking, "CHECKED")
                                  @dtw_assign(checkedallTransactionDate, "CHECKED")
                                  @dtw_assign(checkedWarehouseTotals, "")
                                  @dtw_assign(checkedProductClassTotals, "")
                                  @dtw_assign(checkedVendorNumberTotals, "")
                                  @dtw_assign(checkedRankingTotals, "")
                              %endif

                              @SetTextOvr(Err_N1SEL)
                              <tr><td  class="dsphdr"><span $(textOvr)>Rank By</span></td>
                                  <td class="inputnmbr"><input name="rankBy" type="radio" VALUE='01' $(grossMarginPct)>Gross Margin Pct</td>
                              </tr>
                              @DspErrMsg(Err_N1SEL)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="rankBy" type="radio" VALUE='02' $(salesAmount)>Sales Amount</td>
                              </tr>

                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                                  <td class="colhdr">Print<br>Totals</td>
                              </tr>

                              @SetTextOvr(Err_N2FR01)
                              %if (textOvr == "") @SetTextOvr(Err_N2TO01) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2AL01) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SQ01) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2PT01) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Warehouse</span></td>
                                  <td class="inputnmbr"><input name="fromWarehouse" value="$(V_N2FR01)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromWarehouse&amp;fldDesc=fwarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fwarehouseName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toWarehouse" value="$(V_N2TO01)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toWarehouse&amp;fldDesc=twarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="twarehouseName" type="hidden"></td>
                                  <td class="inputalph"><input name="allWarehouse" value='ALL' $(checkedallWarehouse) type="checkbox" onClick="if (this.checked) this.form.fromWarehouse.value='', this.form.toWarehouse.value='';"></td>
                                  @Build_Sort_Select("sortWarehouse", "$(V_N2SQ01)")
                                  <td align=center ><input name="totalWarehouse" type="checkbox" $(checkedWarehouseTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2FR01)
                              @DspErrMsg(Err_N2TO01)
                              @DspErrMsg(Err_N2AL01)
                              @DspErrMsg(Err_N2SQ01)
                              @DspErrMsg(Err_N2PT01)

                              @SetTextOvr(Err_N2FR02)
                              %if (textOvr == "") @SetTextOvr(Err_N2TO02) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2AL02) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SQ02) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2PT02) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Product Class</span></td>
                                  <td class="inputalph"><input name="fromProductClass" value="$(V_N2FR02)" type="text" size="8" maxlength="4"><a href="$(homeURL)$(cGIPath)ProdClassSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromProductClass&amp;fldDesc=fproductClassDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fproductClassDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="toProductClass" value="$(V_N2TO02)" type="text" size="8" maxlength="4"><a href="$(homeURL)$(cGIPath)ProdClassSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toProductClass&amp;fldDesc=tproductClassDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="tproductClassDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allProductClass" value='ALL' $(checkedallProductClass) type="checkbox" onClick="if (this.checked) this.form.fromProductClass.value='', this.form.toProductClass.value='';"></td>
                                  @Build_Sort_Select("sortProductClass", "$(V_N2SQ02)")
                                  <td align=center ><input name="totalProductClass" type="checkbox" $(checkedProductClassTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2FR02)
                              @DspErrMsg(Err_N2TO02)
                              @DspErrMsg(Err_N2AL02)
                              @DspErrMsg(Err_N2SQ02)
                              @DspErrMsg(Err_N2PT02)

                              @SetTextOvr(Err_N2FR03)
                              %if (textOvr == "") @SetTextOvr(Err_N2TO03) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2AL03) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SQ03) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2PT03) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Vendor Number</span></td>
                                  <td class="inputnmbr"><input name="fromVendorNumber" value="$(V_N2FR03)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="vendorName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toVendorNumber" value="$(V_N2TO03)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="vendorName" type="hidden"></td>
                                  <td class="inputalph"><input name="allVendorNumber" value='ALL' $(checkedallVendorNumber) type="checkbox" onClick="if (this.checked) this.form.fromVendorNumber.value='', this.form.toVendorNumber.value='';"></td>
                                  @Build_Sort_Select("sortVendorNumber", "$(V_N2SQ03)")
                                  <td align=center ><input name="totalVendorNumber" type="checkbox" $(checkedVendorNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2FR03)
                              @DspErrMsg(Err_N2TO03)
                              @DspErrMsg(Err_N2AL03)
                              @DspErrMsg(Err_N2SQ03)
                              @DspErrMsg(Err_N2PT03)

                              @SetTextOvr(Err_N2FR04)
                              %if (textOvr == "") @SetTextOvr(Err_N2TO04) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2AL04) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2SQ04) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2PT04) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Ranking</span></td>
                                  <td class="inputnmbr"><input name="fromRanking" value="$(V_N2FR04)" type="text" size="7" maxlength="5"></td>
                                  <td class="inputnmbr"><input name="toRanking" value="$(V_N2TO04)" type="text" size="7" maxlength="5"></td>
                                  <td class="inputalph"><input name="allRanking" value='ALL' $(checkedallRanking) type="checkbox" onClick="if (this.checked) this.form.fromRanking.value='', this.form.toRanking.value='';"></td>
                                  @Build_Sort_Select("sortRanking", "$(V_N2SQ04)")
                                  <td align=center ><input name="totalRanking" type="checkbox" $(checkedRankingTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2FR04)
                              @DspErrMsg(Err_N2TO04)
                              @DspErrMsg(Err_N2AL04)
                              @DspErrMsg(Err_N2SQ04)
                              @DspErrMsg(Err_N2PT04)

                              @SetTextOvr(Err_N2FR05)
                              %if (textOvr == "") @SetTextOvr(Err_N2TO05) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N2AL05) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Transaction Date</span></td>
                                  <td class="inputnmbr"><input name="fromTransactionDate" value="$(V_N2FR05)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromTransactionDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toTransactionDate" value="$(V_N2TO05)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toTransactionDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allTransactionDate" value='ALL' $(checkedallTransactionDate) type="checkbox" onClick="if (this.checked) this.form.fromTransactionDate.value='', this.form.toTransactionDate.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N2FR05)
                              @DspErrMsg(Err_N2TO05)
                              @DspErrMsg(Err_N2AL05)

                          </table>

                          @dtw_assign(envProgram, "HIVRNK")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HIVRNS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allWarehouse)
  @dtw_mUPPERCASE(fromProductClass)
  @dtw_mUPPERCASE(toProductClass)
  @dtw_mUPPERCASE(allProductClass)
  @dtw_mUPPERCASE(allVendorNumber)
  @dtw_mUPPERCASE(allRanking)
  @dtw_mUPPERCASE(allTransactionDate)

  @dtw_assign(fromWarehouse,@dtw_rstrip(fromWarehouse))
  @dtw_assign(toWarehouse,@dtw_rstrip(toWarehouse))
  @dtw_assign(sortWarehouse,@dtw_rstrip(sortWarehouse))
  @dtw_assign(sortProductClass,@dtw_rstrip(sortProductClass))
  @dtw_assign(fromVendorNumber,@dtw_rstrip(fromVendorNumber))
  @dtw_assign(toVendorNumber,@dtw_rstrip(toVendorNumber))
  @dtw_assign(sortVendorNumber,@dtw_rstrip(sortVendorNumber))
  @dtw_assign(fromRanking,@dtw_rstrip(fromRanking))
  @dtw_assign(toRanking,@dtw_rstrip(toRanking))
  @dtw_assign(sortRanking,@dtw_rstrip(sortRanking))
  @dtw_assign(fromTransactionDate,@dtw_rstrip(fromTransactionDate))
  @dtw_assign(toTransactionDate,@dtw_rstrip(toTransactionDate))

  %if (allWarehouse != "ALL")
      @dtw_assign(allWarehouse, "")
  %endif
  %if (allProductClass != "ALL")
      @dtw_assign(allProductClass, "")
  %endif
  %if (allVendorNumber != "ALL")
      @dtw_assign(allVendorNumber, "")
  %endif
  %if (allRanking != "ALL")
      @dtw_assign(allRanking, "")
  %endif
  %if (allTransactionDate != "ALL")
      @dtw_assign(allTransactionDate, "")
  %endif

  %if (totalWarehouse != "Y")
      @dtw_assign(totalWarehouse, "N")
  %endif
  %if (totalProductClass != "Y")
      @dtw_assign(totalProductClass, "N")
  %endif
  %if (totalVendorNumber != "Y")
      @dtw_assign(totalVendorNumber, "N")
  %endif
  %if (totalRanking != "Y")
      @dtw_assign(totalRanking, "N")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@selc", rankBy)
  @Concat_Field("@@fwhs", fromWarehouse)
  @Concat_Field("@@twhs", toWarehouse)
  @Concat_Field("@@awhs", allWarehouse)
  @Concat_Field("@@swhs", sortWarehouse)
  @Concat_Field("@@pwhs", totalWarehouse)
  @Concat_Field("@@fpcl", fromProductClass)
  @Concat_Field("@@tpcl", toProductClass)
  @Concat_Field("@@apcl", allProductClass)
  @Concat_Field("@@spcl", sortProductClass)
  @Concat_Field("@@ppcl", totalProductClass)
  @Concat_Field("@@fvnd", fromVendorNumber)
  @Concat_Field("@@tvnd", toVendorNumber)
  @Concat_Field("@@avnd", allVendorNumber)
  @Concat_Field("@@svnd", sortVendorNumber)
  @Concat_Field("@@pvnd", totalVendorNumber)
  @Concat_Field("@@frnk", fromRanking)
  @Concat_Field("@@trnk", toRanking)
  @Concat_Field("@@arnk", allRanking)
  @Concat_Field("@@srnk", sortRanking)
  @Concat_Field("@@prnk", totalRanking)
  @Concat_Field("@@fdat", fromTransactionDate)
  @Concat_Field("@@tdat", toTransactionDate)
  @Concat_Field("@@adat", allTransactionDate)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}