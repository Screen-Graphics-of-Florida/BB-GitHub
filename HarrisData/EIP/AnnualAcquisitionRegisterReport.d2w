%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Annual Acquisition Register Report"
  d2wName                 = "AnnualAcquisitionRegisterReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if ((document.Chg.schedule.value =="") || (document.Chg.schedule.value =="0"))
                     {alert("$(reqFieldError)");
                      document.Chg.schedule.focus();
                      document.Chg.schedule.select();
                      return false;}
                  if (editNum(document.Chg.schedule, 2, 0) &&
                      editNum(document.Chg.fromSite, 3, 0) &&
                      editNum(document.Chg.toSite, 3, 0) &&
                      editNum(document.Chg.fromAssetNumber, 12, 0) &&
                      editNum(document.Chg.toAssetNumber, 12, 0) &&
                      editFromToAll(document.Chg.fromSite, document.Chg.toSite, document.Chg.allSite, 3) &&
                      editFromToAll(document.Chg.fromAssetNumber, document.Chg.toAssetNumber, document.Chg.allAssetNumber, 12)
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ANNUALACQUISITIONREGISTERREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
                      %INCLUDE "RequiredField.icl"
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "schedule")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@schd", "schedule") @dtw_assign(Err_SCHED,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@schd")  @dtw_assign(V_SCHED,  fieldValue)
                                  @Decat_Field("@@fsit")  @dtw_assign(V_N1FSIT,  fieldValue)
                                  @Decat_Field("@@tsit")  @dtw_assign(V_N1TSIT,  fieldValue)
                                  @Decat_Field("@@asit")  @dtw_assign(V_N1ASIT,  fieldValue)
                                  @Decat_Field("@@fitm")  @dtw_assign(V_N1FITM,  fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N1TITM,  fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N1AITM,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1ASIT == "ALL")
                                      @dtw_assign(checkedallSite, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallSite, "")
                                  %endif
                                  %if (V_N1AITM == "ALL")
                                      @dtw_assign(checkedallAssetNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallAssetNumber, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedallSite, "CHECKED")
                                  @dtw_assign(checkedallAssetNumber, "CHECKED")
                              %endif

                               @Default_Zero(V_SCHED)
                               @RtvFldDesc("SMSCHD=$(V_SCHED)", "FASCHD", "SMDESC", V_N1SCDD)
                               @SetTextOvr(Err_SCHED)
                              <tr><td align=right class="dsphdr"><span $(textOvr)>Schedule</span></td>
                                  <td class="inputnmbr"><input type="text" name="schedule" value="$(V_SCHED)" size="2" maxlength="2">$(reqFieldChar)
                                                        <a href="$(homeURL)$(cGIPath)AssetScheduleSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=schedule&amp;fldDesc=scheduleDescription" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="text" disabled name="scheduleDescription" value="$(V_N1SCDD)" size="30"></td>
                              </tr>
                              @DspErrMsg(Err_SCHED)
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              <tr><td class="dsphdr">Site</td>
                                  <td class="inputnmbr"><input type="text" name="fromSite" value="$(V_N1FSIT)" size="12" maxlength="3">
                                                        <a href="$(homeURL)$(cGIPath)FASiteSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromSite&amp;fldDesc=frDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="frDesc"></td>
                                  <td class="inputnmbr"><input type="text" name="toSite" value="$(V_N1TSIT)" size="12" maxlength="3">
                                                        <a href="$(homeURL)$(cGIPath)FASiteSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toSite&amp;fldDesc=toDesc" onclick="$(searchWinVar)">$(searchImage) </a>
                                                        <input type="hidden" name="toDesc"></td>
                                  <td class="inputalph"><input type="checkbox" name="allSite" value='ALL' $(checkedallSite) onClick="if (this.checked) this.form.fromSite.value='', this.form.toSite.value='';"></td>
                              </tr>

                              <tr><td class="dsphdr">Asset Number</td>
                                  <td class="inputnmbr"><input type="text" name="fromAssetNumber" value="$(V_N1FITM)" size="12" maxlength="12"></td>
                                  <td class="inputnmbr"><input type="text" name="toAssetNumber" value="$(V_N1TITM)" size="12" maxlength="12"></td>
                                  <td class="inputalph"><input type="checkbox" name="allAssetNumber" value='ALL' $(checkedallAssetNumber) onClick="if (this.checked) this.form.fromAssetNumber.value='', this.form.toAssetNumber.value='';"></td>
                              </tr>
                          </table>

                          @dtw_assign(envProgram, "HFAACQ")
                          @dtw_assign(envPrinter, "HFAACQPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HFAACS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allSite)
  @dtw_mUPPERCASE(allAssetNumber)

  @dtw_assign(schedule,@dtw_rstrip(schedule))
  @dtw_assign(fromSite,@dtw_rstrip(fromSite))
  @dtw_assign(toSite,@dtw_rstrip(toSite))
  @dtw_assign(fromAssetNumber,@dtw_rstrip(fromAssetNumber))
  @dtw_assign(toAssetNumber,@dtw_rstrip(toAssetNumber))

  %if (allSite != "ALL")
      @dtw_assign(allSite, "")
  %endif
  %if (allAssetNumber != "ALL")
      @dtw_assign(allAssetNumber, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@schd", schedule)
  @Concat_Field("@@fsit", fromSite)
  @Concat_Field("@@tsit", toSite)
  @Concat_Field("@@asit", allSite)
  @Concat_Field("@@fitm", fromAssetNumber)
  @Concat_Field("@@titm", toAssetNumber)
  @Concat_Field("@@aitm", allAssetNumber)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}