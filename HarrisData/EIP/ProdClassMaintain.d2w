%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Product Class Maintenance"
  d2wName                 = "ProdClassMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;productClass=@dtw_rurlescseq(productClass)&amp;productClassDesc=@dtw_rurlescseq(productClassDesc)&amp;maintenanceCode=D"
  programName             = "HHDPCM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.productClass.value =="" ||
                      document.Chg.productClassDesc.value =="")
                     {alert("$(reqFieldError)"); return false;}
                  if (parseFloat(document.Chg.lowProfitPercent.value) > parseFloat(document.Chg.highProfitPercent.value))
                     {alert("Lowest % Profit Allowed cannot be greater than Highest % Profit Allowed"); return false;}
                  if (   editNum(document.Chg.lowProfitPercent, 3, 4)
                      && editNum(document.Chg.highProfitPercent, 3, 4)
                      && editNum(document.Chg.commissionPercent, 3, 4)
                      %if (V_HDTCV=="A")
                          && editNum(document.Chg.kitAcct, 4, 0)
                          && editNum(document.Chg.kitSub, 4, 0)
                      %endif
                      %if (V_HDPDRL == "0")
                          && editNum(document.Chg.salesAcct, 4, 0)
                          && editNum(document.Chg.salesSub, 4, 0)
                          && editNum(document.Chg.costAcct, 4, 0)
                          && editNum(document.Chg.costSub, 4, 0)
                      %endif
                      && editNum(document.Chg.invAssetAcct, 4, 0)
                      && editNum(document.Chg.invAssetSub, 4, 0))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PRODCLASSMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From HDPCLS Where PCPCLS='$(productClass)'", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=158")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "productClass")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@pcls", "productClass")      @dtw_assign(Err_PCPCLS, fieldValue)
                          @DecatErr_Field("@@pcds", "productClassDesc")  @dtw_assign(Err_PCPCDS, fieldValue)
                          @DecatErr_Field("@@lopp", "lowProfitPercent")  @dtw_assign(Err_PCLOPP, fieldValue)
                          @DecatErr_Field("@@hipp", "highProfitPercent") @dtw_assign(Err_PCHIPP, fieldValue)
                          @DecatErr_Field("@@comm", "commissionable")    @dtw_assign(Err_PCCOMM, fieldValue)
                          @DecatErr_Field("@@cmpc", "commissionPercent") @dtw_assign(Err_PCCMPC, fieldValue)
                          @DecatErr_Field("@@iaac", "invAssetAcct")      @dtw_assign(Err_PCIAAC, fieldValue)
                          @DecatErr_Field("@@iasb", "invAssetSub")       @dtw_assign(Err_PCIASB, fieldValue)
                          @DecatErr_Field("@@slac", "salesAcct")         @dtw_assign(Err_PCSLAC, fieldValue)
                          @DecatErr_Field("@@slsb", "salesSub")          @dtw_assign(Err_PCSLSB, fieldValue)
                          @DecatErr_Field("@@csac", "costAcct")          @dtw_assign(Err_PCCSAC, fieldValue)
                          @DecatErr_Field("@@cssb", "costSub")           @dtw_assign(Err_PCCSSB, fieldValue)
                          @DecatErr_Field("@@kaac", "kitAcct")           @dtw_assign(Err_PCKAAC, fieldValue)
                          @DecatErr_Field("@@kasb", "kitSub")            @dtw_assign(Err_PCKASB, fieldValue)
                      %endif

                      @Decat_Field("@@pcls")   @dtw_assign(V_PCPCLS, fieldValue)
                      @Decat_Field("@@pcds")   @dtw_assign(V_PCPCDS, fieldValue)
                      @Decat_Field("@@lopp")   @dtw_assign(V_PCLOPP, fieldValue)
                      @Decat_Field("@@hipp")   @dtw_assign(V_PCHIPP, fieldValue)
                      @Decat_Field("@@comm")   @dtw_assign(V_PCCOMM, fieldValue)
                      @Decat_Field("@@cmpc")   @dtw_assign(V_PCCMPC, fieldValue)
                      @Decat_Field("@@iaac")   @dtw_assign(V_PCIAAC, fieldValue)
                      @Decat_Field("@@iasb")   @dtw_assign(V_PCIASB, fieldValue)
                      @Decat_Field("@@slac")   @dtw_assign(V_PCSLAC, fieldValue)
                      @Decat_Field("@@slsb")   @dtw_assign(V_PCSLSB, fieldValue)
                      @Decat_Field("@@csac")   @dtw_assign(V_PCCSAC, fieldValue)
                      @Decat_Field("@@cssb")   @dtw_assign(V_PCCSSB, fieldValue)
                      @Decat_Field("@@kaac")   @dtw_assign(V_PCKAAC, fieldValue)
                      @Decat_Field("@@kasb")   @dtw_assign(V_PCKASB, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "productClass")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_PCPCLS,  "")
                      @dtw_assign(focusField, "productClass")
                      @dtw_assign(V_PCLOPP, "@dtw_rformat(@dtw_rmultiply(V_PCLOPP, "100"),"","4")")
                      @dtw_assign(V_PCHIPP, "@dtw_rformat(@dtw_rmultiply(V_PCHIPP, "100"),"","4")")
                      @dtw_assign(V_PCCMPC, "@dtw_rformat(@dtw_rmultiply(V_PCCMPC, "100"),"","4")")
                  %else
                      @dtw_assign(focusField, "productClassDesc")
                      @dtw_assign(V_PCLOPP, "@dtw_rformat(@dtw_rmultiply(V_PCLOPP, "100"),"","4")")
                      @dtw_assign(V_PCHIPP, "@dtw_rformat(@dtw_rmultiply(V_PCHIPP, "100"),"","4")")
                      @dtw_assign(V_PCCMPC, "@dtw_rformat(@dtw_rmultiply(V_PCCMPC, "100"),"","4")")
                  %endif

                  @SetTextOvr(Err_PCPCLS)
                  <tr><td class="dsphdr"><span $(textOvr)>Product Class</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="productClass" type="text" value="$(V_PCPCLS)" size="4" maxlength="4"> $(reqFieldChar)</td>
                      %else
                          <td class="inputalph"><input name="productClass" type="hidden" value="$(V_PCPCLS)" size="4" maxlength="4">$(V_PCPCLS)</td>
                      %endif
                      <td class="inputalph"><input name="fromProductClass" type="hidden" value="$(productClass)"></td>
                  </tr>
                  @DspErrMsg(Err_PCPCLS)

                  @SetTextOvr(Err_PCPCDS)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="productClassDesc" type="text" value="$(V_PCPCDS)" size="20" maxlength="20"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_PCPCDS)
	   		
                  @SetTextOvr(Err_PCLOPP)
                  <tr><td class="dsphdr"><span $(textOvr)>Lowest % Profit Allowed</span></td>
                      <td class="inputnmbr"><input type="text" name="lowProfitPercent" value="$(V_PCLOPP)" size="9" maxlength="9"></td>
                  </tr>
                  @DspErrMsg(Err_PCLOPP)
	   		
                  @SetTextOvr(Err_PCHIPP)
                  <tr><td class="dsphdr"><span $(textOvr)>Highest % Profit Allowed</span></td>
                      <td class="inputnmbr"><input type="text" name="highProfitPercent" value="$(V_PCHIPP)" size="9" maxlength="9"></td>
                  </tr>
                  @DspErrMsg(Err_PCHIPP)
	   		
                  @SetTextOvr(Err_PCCOMM)
                  <tr><td class="dsphdr"><span $(textOvr)>Commissionable</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_PCCOMM) && (x < maxRows))
                             {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "commissionable", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_PCCOMM)

                  @SetTextOvr(Err_PCCMPC)
                  <tr><td class="dsphdr"><span $(textOvr)>Commission Percent</span></td>
                      <td class="inputnmbr"><input type="text" name="commissionPercent" value="$(V_PCCMPC)" size="9" maxlength="9"></td>
                  </tr>
                  @DspErrMsg(Err_PCCMPC)

                  @Default_Zero(V_PCIAAC)
                  @Default_Zero(V_PCIASB)
                  @RtvFldDesc("CHACCT=$(V_PCIAAC) and CHSUB=$(V_PCIASB) ", "HDCHRT", "CHCHDS", acctDesc)
                  @SetTextOvr(Err_PCIAAC)
                  <tr><td class="dsphdr"><span $(textOvr)>Inventory Asset Account</span></td>
                      <td class="inputnmbr"><input name="invAssetAcct" value="$(V_PCIAAC)" type="text" size="4" maxlength="4"> - <input name="invAssetSub" value="$(V_PCIASB)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=invAssetAcct&amp;subFld=invAssetSub&amp;descFld=assetAcctDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="assetAcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_PCIAAC)

                  %if (V_HDPDRL == "0")
                      @Default_Zero(V_PCSLAC)
                      @Default_Zero(V_PCSLSB)
                      @RtvFldDesc("CHACCT=$(V_PCSLAC) and CHSUB=$(V_PCSLSB) ", "HDCHRT", "CHCHDS", acctDesc)
                      @SetTextOvr(Err_PCSLAC)
                      <tr><td class="dsphdr"><span $(textOvr)>Sales Account</span></td>
                          <td class="inputnmbr"><input name="salesAcct" value="$(V_PCSLAC)" type="text" size="4" maxlength="4"> - <input name="salesSub" value="$(V_PCSLSB)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=salesAcct&amp;subFld=salesSub&amp;descFld=salesAcctDesc" onclick="$(searchWinVar)">%if (V_HDVLCH=="Y") $(reqFieldChar) %endif $(searchImage) </a> <input disabled name="salesAcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_PCSLAC)

                      @Default_Zero(V_PCCSAC)
                      @Default_Zero(V_PCCSSB)
                      @RtvFldDesc("CHACCT=$(V_PCCSAC) and CHSUB=$(V_PCCSSB) ", "HDCHRT", "CHCHDS", acctDesc)
                      @SetTextOvr(Err_PCCSAC)
                      <tr><td class="dsphdr"><span $(textOvr)>Cost Of Goods Sold Account</span></td>
                          <td class="inputnmbr"><input name="costAcct" value="$(V_PCCSAC)" type="text" size="4" maxlength="4"> - <input name="costSub" value="$(V_PCCSSB)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=costAcct&amp;subFld=costSub&amp;descFld=costAcctDesc" onclick="$(searchWinVar)">%if (V_HDVLCH=="Y") $(reqFieldChar) %endif $(searchImage) </a> <input disabled name="costAcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_PCCSAC)
                  %endif

                  %if (V_HDTCV=="A")
                      @Default_Zero(V_PCKAAC)
                      @Default_Zero(V_PCKASB)
                      @RtvFldDesc("CHACCT=$(V_PCKAAC) and CHSUB=$(V_PCKASB) ", "HDCHRT", "CHCHDS", acctDesc)
                      @SetTextOvr(Err_PCKAAC)
                      <tr><td class="dsphdr"><span $(textOvr)>Kit Additional Cost Account</span></td>
                          <td class="inputnmbr"><input name="kitAcct" value="$(V_PCKAAC)" type="text" size="4" maxlength="4"> - <input name="kitSub" value="$(V_PCKASB)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=kitAcct&amp;subFld=kitSub&amp;descFld=kitAcctDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="kitAcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_PCKAAC)
                  %endif
              %}
          </table>
	
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDPCM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(productClass)

  %if (maintenanceCode == "Z")
      @dtw_assign(copy, "Y")
      @dtw_assign(maintenanceCode, "A")
  %else
      @dtw_assign(copy, "N")
      @dtw_assign(fromProductClass, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@pcls", productClass)
  @Concat_Field("@@fpcl", fromProductClass)
  @Concat_Field("@@pcds", productClassDesc)
  @Concat_Field("@@lopp", lowProfitPercent)
  @Concat_Field("@@hipp", highProfitPercent)
  @Concat_Field("@@comm", commissionable)
  @Concat_Field("@@cmpc", commissionPercent)
  @Concat_Field("@@iaac", invAssetAcct)
  @Concat_Field("@@iasb", invAssetSub)
  %if (V_HDPDRL == "0")
      @Concat_Field("@@slac", salesAcct)
      @Concat_Field("@@slsb", salesSub)
      @Concat_Field("@@csac", costAcct)
      @Concat_Field("@@cssb", costSub)
  %endif
  %if (V_HDTCV=="A")
      @Concat_Field("@@kaac", kitAcct)
      @Concat_Field("@@kasb", kitSub)
  %endif
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (V_HDPDRL > "0" && maintenanceCode == "A" && copy == "N")
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)ProdClassByPlantMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;productClass=@dtw_rurlescseq(productClass)&amp;productClassDesc=@dtw_rurlescseq(productClassDesc)&amp;plantNumber=000&amp;maintenanceCode=A">
      %else
          %if (errFound == "")
              @Format_ConfMsg_Desc(maintenanceCode, $(productClassDesc), $(productClass), "", "", "", "", confMessage)
          %else
              @DecatErr_Field("@@pcls", "productClass")
              @Format_ConfMsg_Desc("", $(productClassDesc), $(productClass), "<br>$(fieldValue)", "", "", "", confMessage)
          %endif
          @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
          %if (backURL == "")
              <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=158&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %else
              <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %endif
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;productClass=@dtw_rurlescseq(productClass)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}