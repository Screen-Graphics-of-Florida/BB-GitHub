%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "OEControl$(dataBaseID).icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Order Shipping"
  d2wName                 = "OrderShippingEntry.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;turnaround=@dtw_rurlescseq(turnaround)"
  nextPrevVar             = "$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "999"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "10"
  rowIndexNext            = "1"
  totalPages              = "0"
  useQtyShipped           = "Y"
  tabID                   = "ITEM"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          %INCLUDE "OrderEntryProgOpt.icl"
          %INCLUDE "OrderEntryRetInfo.icl"

          @dtw_assign(editVariables, "")
          @RtvFldDesc("O1OCTL=$(orderControlNumber) ", "OEDTWK", "char(count(*))", recCount)	
          @dtw_assign(ux, "1")
          %while(ux <= recCount){
              @dtw_assign(recNbr, ux)
              %while(@dtw_rlength(recNbr) != "3") {@dtw_insert("0", recNbr, recNbr)%}
              @dtw_concat(editVariables, " if (rows >= $(recNbr) && ok == true)  {if (editNum(document.Chg.qty$(recNbr), 9, 4) == false  || editQty(document.Chg.qty$(recNbr),  document.Chg.opn$(recNbr),  document.Chg.pct$(recNbr))== false) {ok = false};} ", editVariables)
              @dtw_add(ux, "1", ux)
          %}
          <script TYPE="text/javascript">
              %INCLUDE "OrderEntryConfirm.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  var rows = document.Chg.row001.value;
                  var ok = true;
                  $(editVariables)
                  if (ok == false) {return false;} else {return true;}
              }
              function editQty(ship, open, percent) {
                  var shipQty = parseFloat(ship.value);
                  var openQty = parseFloat(open.value);
                  var overPct = parseFloat(percent.value);
                  if ((shipQty>0 && shipQty>openQty) || (shipQty<0 && shipQty<openQty)) {
                      if (overPct>0) {alert ("Quantity Shipped cannot be greater than" + '\n' + 'Quantity Open + Overshipment allowance of ' + overPct + '%.' + '\n\n' + 'Maximum quantity shipped for this item is ' + openQty);}
                      else {alert ("Quantity Shipped cannot be greater than Quantity Open");}
                      ship.focus();
                      ship.select();
                      return false;}
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ORDERSHIPPINGENTRY")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " OEDTWK ", fileSQL)
                      @dtw_concat(selectSQL, "O1OCTL=$(orderControlNumber) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By O1ORL#,O1BLN#", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Order_Shipping_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) Order_Shipping_Query (IN  CHAR(64)    profileHandle,
				              CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(inclRetInfo, "N")
      %INCLUDE "OrderEntryTabs.icl"
      <div class="quickLinksTop">
          <a href="javascript:check(document.Chg)">$(acceptImageLrg)</a>
      </div>

      <form class="formClass" METHOD=POST name="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(d2wVarBase)&amp;recCount=@dtw_rurlescseq($(sql_Record_Count))&amp;allowOverShip=@dtw_rurlescseq(allowOverShip)">
          <table $(contentTable)>
              <tr><th class="colhdr">$(optionHeading)</th>
                  <td class="colhdr">Ln</td>
                  <td class="colhdr">Rel</td>
                  <td class="colhdr">Item<br>Number</td>
                  %if (oe_sec_10 == "Y")
                      <th class="colhdr">Whs</th>
                  %endif
                  <td class="colhdr">Description</td>
                  <td class="colhdr">Quantity<br>Open</td>
                  <td class="colhdr">Quantity<br>Shipped</td>
              </tr>

              %ROW{
                  @dtw_assign(rowNbr, $(ROW_NUM))
                  %while(@dtw_rlength(rowNbr) != "3")   {@dtw_insert("0", rowNbr, rowNbr) %}

                  @Format_Nbr("@dtw_rsubtract(V_O1QORD, V_O1QSTD)", qtyOpen, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                  @RtvFldDesc("O4OCTL=$(orderControlNumber) and O4ORL#=$(V_O1ORL#)", "OECMWK", "char(count(*))", cmtCount)
                  %INCLUDE "SetRowClass.icl"
      	
                  %if (V_O1BOAL == "Y")
                      @dtw_assign(selected, "CHECKED")
                  %else
                      @dtw_assign(selected, "")
                  %endif

                  <tr class="$(rowClass)">
                     <td class="opticon">
                          %if (oe_sec_02 == "Y")
                              <a href="$(homeURL)$(cGIPath)OrderEntryDetail.d2w/DETAIL$(d2wVarBase)&amp;lineNumber=@dtw_rurlescseq(V_O1ORL#)&amp;releaseNumber=@dtw_rurlescseq(V_O1BLN#)" title="Update Detail Line">$(changeImageSml)</a>
                          %endif
                          %if (cmtCount > "0")
                              <a href="$(homeURL)$(cGIPath)OrderEntryComments.d2w/COMMENTS$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(V_O1ITEM)&amp;itemDescription=@dtw_rurlescseq(V_O1IMDS)&amp;commentLine=@dtw_rurlescseq(V_O1ORL#)">$(commentExistImage)</a>
                          %else
                              <a href="$(homeURL)$(cGIPath)OrderEntryComments.d2w/COMMENTS$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(V_O1ITEM)&amp;itemDescription=@dtw_rurlescseq(V_O1IMDS)&amp;commentLine=@dtw_rurlescseq(V_O1ORL#)">$(commentImage)</a>
                          %endif
                          %if (V_O1KIT == "F")
                              <a href="$(homeURL)$(cGIPath)SelectOrderFeatureOption.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(H1SHTO)&amp;customerName=@dtw_rurlescseq(shipToName)&amp;orderNumber=@dtw_rurlescseq(H1ORD#)&amp;lineNumber=@dtw_rurlescseq(V_O1ORL#)" onclick="$(inquiryWinVar)">$(cfgItemImage)</a>
                          %endif
                          %if (V_O1KIT == "K" && V_O1KTRL == "O")
                              <a href="$(homeURL)$(cGIPath)OrderEntryKitOption.d2w/DISPLAY$(d2wVarBase)&amp;lineNumber=@dtw_rurlescseq(V_O1ORL#)&amp;orderTypeDesc=@dtw_rurlescseq(orderTypeDesc)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))" onclick="$(orderEntryWinVar)" title="Click here to update kit options">$(kitOptionImage)</a>
                          %endif
                          %if (V_O1UDEF == "Y")
						      @dtw_assign(smUTitle, "Maintain User-Defined")
                              <a href="$(homeURL)$(cGIPath)OrderEntryUserDefinedDetail.d2w/REPORT$(d2wVarBase)&amp;lineNumber=@dtw_rurlescseq(V_O1ORL#)" onclick="$(commentWinVar)">$(smU)</a>
                          %elif (V_O1UDEF == "E")
						      @dtw_assign(smUTitle, "Maintain User-Defined")
                              <a href="$(homeURL)$(cGIPath)OrderEntryUserDefinedDetail.d2w/REPORT$(d2wVarBase)&amp;lineNumber=@dtw_rurlescseq(V_O1ORL#)" onclick="$(commentWinVar)">$(smU)</a>
                          %endif
                      </td>
                      %if (V_O1BLN# !="0")
                          <td>&nbsp;</td>
                      %else
                          <td class="colnmbr">%if (V_O1SGEN == "Y") ($(V_O1SGBL)) &nbsp; %endif $(V_O1ORL#)</td>
                      %endif
                      <td class="colnmbr">$(V_O1BLN#)</td>
                      %if (V_O1OREC != "N")
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemInquiry.d2w/DISPLAY$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq($(V_O1ITEM))" onclick="$(inquiryWinVar)" title="Item Quickview">$(V_O1ITEM)</a></td>
                      %else
                          <td class="colalph">$(V_O1ITEM)</td>
                      %endif
                      %if (oe_sec_10 == "Y")
                          @RtvFldDesc("WHWHS=$(V_O1WH)", "HDWHSM", "WHWHNM", whsName)
                          <td class="colnmbr" $(helpCursor)><span title="$(whsName)">$(V_O1WH)</span></td>
                      %endif
                      <td class="colalph">$(V_O1IMDS)</td>
                      <td class="colnmbr">$(qtyOpen)</td>
                      %if (V_O1BLKT !="Y")
                          <td class="inputnmbr"><input type="text" name="qty$(rowNbr)" value="$(V_O1QSTC)" size="10" maxlength="15"></td>		
                      %else
                          <td class="inputnmbr"><input type="hidden" name="qty$(rowNbr)" value="$(V_O1QSTC)"></td>		
                      %endif

                      %if (allowOverShip == "Y")
                          @dtw_assign(openQty, @dtw_rsubtract(V_O1QORD, V_O1QSTD))
                          @dtw_add(openQty, @dtw_rmultiply(openQty, overShipPct), openQty)
                      %else
                          @dtw_assign(openQty, @dtw_rsubtract(V_O1QORD, V_O1QSTD))
                      %endif

                      <td class="colicon">
                          <input type="hidden" name="lin$(rowNbr)" value="$(V_O1ORL#)">		
                          <input type="hidden" name="rel$(rowNbr)" value="$(V_O1BLN#)">		
                          <input type="hidden" name="opn$(rowNbr)" value="$(openQty)">		
                          <input type="hidden" name="pct$(rowNbr)" value="@dtw_rmultiply(overShipPct, "100")">		
                          <input type="hidden" name="row$(rowNbr)" value="@dtw_radd(@dtw_rsubtract(sql_Record_Count, START_ROW_NUM), "1")">
                      </td>
                  </tr>
                  %if (V_O1GNPO == "Y")
                      %if (V_CEOEPO == "S")
                          @RtvFldDesc("PSORD#=$(H1ORD#) and PSORL#=$(V_O1ORL#)", "POSGPO", "char(count(*))", poCount)
                          %if (poCount == "0")
                              @RtvFldDesc("PDPO=$(V_O1PO#) and PDPOL#=$(V_O1POL#) and PDPORL=$(V_O1PORL) and PDSTAT='O'", "POPOMD", "char(count(*))", poCount)
                          %endif
                          %if (poCount > "0")
                              <tr class="$(rowClass)"><td colspan="3"><input type="hidden" name="unl$(rowNbr)" value="Y">&nbsp;</td><td class="error" colspan="5">Shipping will remove link to Suggested P/O</td></tr>
                          %endif
                      %elseif (V_O1PO# > "0")
                          @RtvFldDesc("PDPO=$(V_O1PO#) and PDPOL#=$(V_O1POL#) and PDPORL=$(V_O1PORL) and PDSTAT='O'", "POPOMD", "char(count(*))", poCount)
                          %if (poCount > "0")
                              <tr class="$(rowClass)"><td colspan="3"><input type="hidden" name="unl$(rowNbr)" value="Y">&nbsp;</td><td class="error" colspan="5">Shipping will remove link to Purchase Order $(V_O1PO#)</td></tr>
                          %endif
                      %endif
                  %endif
                  %if (V_O1UDEF == "E")    %{ User-Defined Detail Error %}
                      <tr class="$(rowClass)">
                          <td colspan="2">&nbsp;</td>
                          <td class="error" colspan="12">
							  @dtw_assign(smCTitle, "Maintain User-Defined")
                              <a href="$(homeURL)$(cGIPath)OrderEntryUserDefinedDetail.d2w/REPORT$(d2wVarBase)&amp;lineNumber=@dtw_rurlescseq(V_O1ORL#)" onclick="$(commentWinVar)">User-Defined information must be completed - click here to update</a>
                          </td>
       	              </tr>
                  %endif
                  %if (V_O1KTRL == "D" || V_O1KTRL == "E")
                      <tr class="$(rowClass)">
                          <td class="error" colspan="15"><a href="$(homeURL)$(cGIPath)OrderEntryKitOption.d2w/DISPLAY$(d2wVarBase)&amp;lineNumber=@dtw_rurlescseq(V_O1ORL#)&amp;orderTypeDesc=@dtw_rurlescseq(orderTypeDesc)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))" onclick="$(orderEntryWinVar)">Click here to verify kit options</a></td>
                      </tr>
                  %endif
              %}
          </table>
          %if (sql_Record_Count > "15")
              <div><a href="javascript:check(document.Chg)">$(acceptImageLrg)</a></div>
          %endif
      </form>
      %INCLUDE "EndTabs.icl"
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HOEOSU_W.PGM %}
%}

%HTML(UPDATE){
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @Concat_Field("@@octl", orderControlNumber)
  @Concat_Field("@@rcnt", recCount)
  @Concat_Field("@@aovs", allowOverShip)
  @dtw_assign(ux, "1")
  %while(ux <= recCount){
      @dtw_assign(recNbr, ux)
      %while(@dtw_rlength(recNbr) != "3")   {@dtw_insert("0", recNbr, recNbr) %}
      @dtw_assign(lin,  @dtw_rStrip($(lin$(recNbr))))
      @dtw_assign(rel,  @dtw_rStrip($(rel$(recNbr))))
      @dtw_assign(qty,  @dtw_rStrip($(qty$(recNbr))))
      @dtw_assign(unl,  @dtw_rStrip($(unl$(recNbr))))

      %if (boa != "Y")
          @dtw_assign(boa, "N")
      %endif
      @Concat_Field("@@l$(recNbr)", lin)
      @Concat_Field("@@r$(recNbr)", rel)
      @Concat_Field("@@q$(recNbr)", qty)
      @Concat_Field("@@u$(recNbr)", unl)

      @dtw_add(ux, "1", ux)
  %}

  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, errFound, edtVar, errVar)
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}