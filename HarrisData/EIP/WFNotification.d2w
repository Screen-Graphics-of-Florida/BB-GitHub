%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Notification"
  d2wName                 = "WFNotification.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfProcess=@dtw_rurlescseq(wfProcess)&amp;passedWfPoint=@dtw_rurlescseq(passedWfPoint)&amp;passedWfSequence=@dtw_rurlescseq(passedWfSequence)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HWFNFM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  noMsg                   = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              function validate(searchForm) {
                  if (editNum(document.Search.srchPoint, 4, 3))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "WFNOTIFICATION")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select WFPRNF.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(a.PDDESC,' ') as a_PDDESC, coalesce(a.PDDESCU,' ') as a_PDDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(a.PDRATE,0) as PDRATE,  ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(e.USDESC,NFPART) as USDESC, coalesce(e.USDESCU,NFPART) as USDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(b.PDDESC,' ') as b_PDDESC, coalesce(b.PDDESCU,' ') as b_PDDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(c.FLDESC,' ') as c_FLDESC, upper(coalesce(c.FLDESC,' ')) as c_FLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(MSDESC,' ') as MSDESC, coalesce(MSDESCU,' ') as MSDESCU, ", stmtSQL)
                      %if (formatToPrint == "Y")
                         @dtw_concat(stmtSQL, " coalesce(f.USDESC,CUUSER) as f_USDESC, coalesce(f.USDESCU,CUUSER) as f_USDESCU, ", stmtSQL)
                         @dtw_concat(stmtSQL, " SYCUSF.*, ", stmtSQL)
                      %endif
                      @dtw_concat(stmtSQL, " coalesce(d.FLDESC,' ') as d_FLDESC, upper(coalesce(d.FLDESC,' ')) as d_FLDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " WFPRNF  ", fileSQL)
                      @dtw_concat(fileSQL, " left join WFPRDT a on a.PDPROC=NFPROC and a.PDPONT=NFPONT and a.PDSEQ=NFSEQ", fileSQL)
                      %if (formatToPrint == "Y")
                          @dtw_concat(fileSQL, " left join SYCUSF on CUCUSR=NFPART and (a.PDRATE=0 or ((CUFRAT=0 or a.PDRATE>=CUFRAT) and (CUTRAT=0 or a.PDRATE<=CUTRAT))) ", fileSQL)
                          @dtw_concat(fileSQL, " left join SYUSER f on f.USUSER=CUUSER", fileSQL)
                      %endif
                      @dtw_concat(fileSQL, " left join SYUSER e on e.USUSER=NFPART", fileSQL)
                      @dtw_concat(fileSQL, " left join WFPRDT b on b.PDPROC=NFPROC and b.PDPONT=NFNPNT and b.PDSEQ=NFNSEQ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG c on c.FLTYPE='WFINSTPART' and c.FLVALU=NFINPT ", fileSQL)
                      @dtw_concat(fileSQL, " left join WFMSGT on MSMSID=NFMSID", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG d on d.FLTYPE='WFSEND' and d.FLVALU=NFSEND ", fileSQL)
                      @dtw_concat(selectSQL, " NFPROC='$(wfProcess)' ", selectSQL)
                      %if (passedWfPoint != "")
                          @dtw_concat(selectSQL, " and NFPONT=$(passedWfPoint) and NFSEQ=$(passedWfSequence) ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %if (formatToPrint == "Y")
                          @dtw_concat(stmtSQL, ", f_USDESC ", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)WFNotificationMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      <table $(contentTable)>
          @RtvFldDesc("PRPROC='$(wfProcess)'", "WFPRHD", "PRDESC", V_PRDESC)
          @Format_Header_URL("Process", $(V_PRDESC), $(wfProcess), "$(homeURL)$(cGIPath)WFProcessSelect.d2w/REPORT$(d2wVarBase)")

          %if (passedWfPoint != "")
              @RtvFldDesc("PDPROC='$(wfProcess)' and PDPONT=$(passedWfPoint) and PDSEQ=$(passedWfSequence)", "WFPRDT", "PDDESC", V_PDDESC)
              @Format_Header_URL("Detail Point", $(V_PDDESC), "$(passedWfPoint)-$(passedWfSequence)", "$(homeURL)$(cGIPath)WFDetailSelect.d2w/REPORT$(d2wVarBase)")
          %endif
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint == "")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Detail Point Description</th>
                      <th class="colhdr">Point</th>
                      <th class="colhdr">Participant</th>
                      <th class="colhdr">Message ID</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="15" maxlength="50">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchPoint" size="8" maxlength="8">
                          <input type="hidden" name="operPoint" value="=">
                      </td>
                      <td><input type="text" class="inputalph" name="srchUser" size="15" maxlength="30">
                          <input type="hidden" name="operUser" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchMessageId" size="15" maxlength="30">
                          <input type="hidden" name="operMessageId" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("a_PDDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DetailPoint"         title="Sequence By Detail Point Description, Detail Point">Detail Point Description</a></th>
              @OrderBy_Sort("NFPONT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Point"               title="Sequence By Detail Point">Detail Point</a></th>
              @OrderBy_Sort("PDRATE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ComplexRate"         title="Sequence By Detail Point Complexity Rating, Detail Point">Detail Point<br>Complexity Rating</a></th>
              @OrderBy_Sort("USDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Participant"         title="Sequence By Participant, Detail Point">Participant</a></th>
              @OrderBy_Sort("c_FLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=InstanceParticipant" title="Sequence By Participant, Detail Point">Instance Participant</a></th>
              @OrderBy_Sort("b_PDDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=NotifyPoint"         title="Sequence By Notify Detail Point, Detail Point">Notify Detail Point</a></th>
              @OrderBy_Sort("MSDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MessageId"           title="Sequence By Message ID, Detail Point">Message ID</a></th>
              %if (formatToPrint == "Y")
                  <th class="colhdr">User Profile</th>
                  <th class="colhdr">From Complexity Rating</th>
                  <th class="colhdr">To Complexity Rating</th>
              %endif
          </tr>

          %INCLUDE "NoRecordsFound.icl"
          @dtw_assign(test_NFPONT, "")
          @dtw_assign(test_NFSEQ, "")
          @dtw_assign(test_NFNFID, "")

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;wfPoint=@dtw_rurlescseq(V_NFPONT)&amp;wfSequence=@dtw_rurlescseq(V_NFSEQ)&amp;wfNotificationId=@dtw_rurlescseq(V_NFNFID)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;updRecNbr=@dtw_rurlescseq(START_ROW_NUM)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc("$(V_a_PDDESC)-$(V_USDESC)", "$(V_NFPONT)-$(V_NFSEQ)-$(NFPART)", "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)WFNotificationMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)WFNotificationMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromPoint=@dtw_rurlescseq(V_NFPONT)&amp;fromSequence=@dtw_rurlescseq(V_NFSEQ)&amp;fromNotificationId=@dtw_rurlescseq(V_NFNFID)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)WFNotificationMaintain.d2w/EDIT_DATA$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  %if (test_NFPONT!=V_NFPONT || test_NFSEQ!=V_NFSEQ || test_NFNFID!=V_NFNFID)
                      @dtw_assign(test_NFPONT, V_NFPONT)
                      @dtw_assign(test_NFSEQ, V_NFSEQ)
                      @dtw_assign(test_NFNFID, V_NFNFID)
                      <td class="colalph">$(V_a_PDDESC)</td>
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)WFDetailSelect.d2w/REPORT$(d2wVarBase)&amp;passedWfPoint=@dtw_rurlescseq(V_NFPONT)&amp;passedWfSequence=@dtw_rurlescseq(V_NFSEQ)" title="View Detail Point">$(V_NFPONT)-$(V_NFSEQ)</a></td>
                      <td class="colnmbr">$(V_PDRATE)</td>                                      	
                      @RtvFldDesc("CUCUSR='$(V_NFPART)'", "SYCUSF", "Char(Count(*))", RecCount)
                      %if (RecCount>"0")
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)CommonUserInquiry.d2w/REPORT$(d2wVarBase)&amp;commonUser=@dtw_rurlescseq(V_NFPART)&amp;complexityRating=@dtw_rurlescseq(V_PDRATE)" title="Common User Quickview" onclick="$(inquiryWinVar)">$(V_USDESC)</a></td>
                      %else
                          <td class="colalph" $(helpCursor)><span title="$(V_NFPART)">$(V_USDESC)</span></td>
                      %endif
                      <td class="colalph" $(helpCursor)><span title="$(V_NFINPT)">$(V_c_FLDESC)</span></td>
                      <td class="colalph" $(helpCursor)><span title="$(V_NFNPNT)-$(V_NFNSEQ)">$(V_b_PDDESC)</span></td>
                      <td class="colalph" $(helpCursor)><span title="$(V_NFMSID)">$(V_MSDESC)</span></td>
                  %else
                      <td class="colalph">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>                                      	
                      <td class="colnmbr">&nbsp;</td>                                      	
                      <td class="colalph">&nbsp;</td>
                      <td class="colalph">&nbsp;</td>
                      <td class="colalph">&nbsp;</td>
                      <td class="colalph">&nbsp;</td>
                  %endif
                  %if (formatToPrint == "Y")
                      <td class="colalph">$(V_f_USDESC)</td>                                      	
                      <td class="colnmbr">$(V_CUFRAT)</td>                                      	
                      <td class="colnmbr">$(V_CUTRAT)</td>                                      	
                  %endif
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select WFPRNF.*, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(a.PDDESC,' ') as a_PDDESC, coalesce(a.PDDESCU,' ') as a_PDDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(a.PDRATE,0) as PDRATE,  ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(USDESC,NFPART) as USDESC, coalesce(USDESCU,NFPART) as USDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(b.PDDESC,' ') as b_PDDESC, coalesce(b.PDDESCU,' ') as b_PDDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(c.FLDESC,' ') as c_FLDESC, upper(coalesce(c.FLDESC,' ')) as c_FLDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(MSDESC,' ') as MSDESC, coalesce(MSDESCU,' ') as MSDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(d.FLDESC,' ') as d_FLDESC, upper(coalesce(d.FLDESC,' ')) as d_FLDESCU ", stmtSQL)
  @dtw_concat(fileSQL, " WFPRNF  ", fileSQL)
  @dtw_concat(fileSQL, " left join WFPRDT a on a.PDPROC=NFPROC and a.PDPONT=NFPONT and a.PDSEQ=NFSEQ", fileSQL)
  @dtw_concat(fileSQL, " left join SYUSER on USUSER=NFPART", fileSQL)
  @dtw_concat(fileSQL, " left join WFPRDT b on b.PDPROC=NFPROC and b.PDPONT=NFNPNT and b.PDSEQ=NFNSEQ", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG c on c.FLTYPE='WFINSTPART' and c.FLVALU=NFINPT ", fileSQL)
  @dtw_concat(fileSQL, " left join WFMSGT on MSMSID=NFMSID", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG d on d.FLTYPE='WFSEND' and d.FLVALU=NFSEND ", fileSQL)
  @dtw_concat(selectSQL, " NFPROC='$(wfProcess)' ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_XMLQuery (IN  CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("WFNotificationList")
          %ROW{
              @XMLIDTag("$(V_NFPROC)-$(V_NFPONT)-$(V_NFSEQ)-$(V_NFNFID)", "Notification ID")
                  @XMLTag(V_NFPROC, "Process")
                  @XMLTag(V_NFPONT, "Point")
                  @XMLTag(V_NFSEQ, "Sequence")
                  @XMLTag(V_NFNFID, "NotificationId")
                  @XMLTag(V_NFMSID, "MessageId")
                  @XMLTag(V_NFDELG, "AllowDelegation")
                  @XMLTag(V_NFPART, "Participant")
                  @XMLTag(V_NFMEDM, "Medium")
                  @XMLTag(V_NFPGM, "Program")
                  @XMLTag(V_NFLIST, "WorkListLink")
                  @XMLTag(V_NFHIST, "HistoryLink")
              @XMLEndTag("Notification")
          %}
      @XMLEndTag("WFNotificationList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "a_PDDESCU,NFPONT,NFSEQ")
          @DTW_ASSIGN(orderByDisplay, "Detail Point Description, Detail Point")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %if (updRecNbr > "0")
      @dtw_assign(START_ROW_NUM, updRecNbr)
      @dtw_assign(updRecNbr, "")
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "DetailPoint")
      %if (orderBy == "a_PDDESCU,NFPONT,NFSEQ")
          @DTW_ASSIGN(orderBy, "a_PDDESCU DESC,NFPONT,NFSEQ")
          @DTW_ASSIGN(orderByDisplay, "Detail Point Description (descending), Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "a_PDDESCU,NFPONT,NFSEQ")
          @DTW_ASSIGN(orderByDisplay, "Detail Point Description, Detail Point")
      %endif
  %elif (sequence == "Point")
      %if (orderBy == "NFPONT,NFSEQ")
          @DTW_ASSIGN(orderBy, "NFPONT DESC,NFSEQ DESC")
          @DTW_ASSIGN(orderByDisplay, "Detail Point (descending)")
      %else
          @DTW_ASSIGN(orderBy, "NFPONT,NFSEQ")
          @DTW_ASSIGN(orderByDisplay, "Detail Point")
      %endif
 %elif (sequence == "Participant")
      %if (orderBy == "USDESCU,NFPONT,NFSEQ")
          @DTW_ASSIGN(orderBy, "USDESCU DESC,NFPONT,NFSEQ")
          @DTW_ASSIGN(orderByDisplay, "Participant (descending), Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "USDESCU,NFPONT,NFSEQ")
          @DTW_ASSIGN(orderByDisplay, "Participant, Detail Point")
      %endif
 %elif (sequence == "ComplexRate")
      %if (orderBy == "PDRATE,NFPONT,NFSEQ")
          @DTW_ASSIGN(orderBy, "PDRATE DESC,NFPONT,NFSEQ")
          @DTW_ASSIGN(orderByDisplay, "Detail Point Complexity Rating (descending), Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "PDRATE,NFPONT,NFSEQ")
          @DTW_ASSIGN(orderByDisplay, "Detail Point Complexity Rating, Detail Point")
      %endif
  %elif (sequence == "InstanceParticipant")
      %if (orderBy == "c_FLDESCU,NFPONT,NFSEQ")
          @DTW_ASSIGN(orderBy, "c_FLDESCU DESC,NFPONT,NFSEQ")
          @DTW_ASSIGN(orderByDisplay, "Instance Participant (descending), Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "c_FLDESCU,NFPONT,NFSEQ")
          @DTW_ASSIGN(orderByDisplay, "Instance Participant, Detail Point")
      %endif
 %elif (sequence == "NotifyPoint")
      %if (orderBy == "b_PDDESCU,NFPONT,NFSEQ")
          @DTW_ASSIGN(orderBy, "b_PDDESCU DESC,NFPONT,NFSEQ")
          @DTW_ASSIGN(orderByDisplay, "Point Process (descending), Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "b_PDDESCU,NFPONT,NFSEQ")
          @DTW_ASSIGN(orderByDisplay, "Point Process, Detail Point")
      %endif
 %elif (sequence == "MessageId")
      %if (orderBy == "MSDESCU,NFPONT,NFSEQ")
          @DTW_ASSIGN(orderBy, "MSDESCU DESC,NFPONT,NFSEQ")
          @DTW_ASSIGN(orderByDisplay, "Message ID (descending), Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "MSDESCU,NFPONT,NFSEQ")
          @DTW_ASSIGN(orderByDisplay, "Message ID, Detail Point")
      %endif
  %endif
	
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchPoint, 4, 3) &&
                      editNum(document.Search.srchSequence, 4, 3))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFNOTIFICATIONSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Detail Point Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Point</td>
                              @dtw_assign(operNbr, "operPoint")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchPoint" size="8" maxlength="8"></td>
                          </tr>

                          <tr><td class="dsphdr">Sequence</td>
                              @dtw_assign(operNbr, "operSequence")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchSequence" size="8" maxlength="8"></td>
                          </tr>

                          <tr><td class="dsphdr">Participant</td>
                              @dtw_assign(operNbr, "operUser")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchUser" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Instance Participant</td>
                              @dtw_assign(operNbr, "operInstanceParticipant")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchInstanceParticipant" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Notify Detail Point</td>
                              @dtw_assign(operNbr, "operNotifyPoint")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchNotifyPoint" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Message ID</td>
                              @dtw_assign(operNbr, "operMessageId")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchMessageId" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Program</td>
                              @dtw_assign(operNbr, "operProgram")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchProgram" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Send Notification</td>
                              @dtw_assign(operNbr, "operSend")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchSend" size="15" maxlength="30"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDesc.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("a.PDDESCU", "Detail Point Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("NFPONT",  "Point", $(srchPoint), "", operPoint, "N")
  @Build_WildCard ("NFSEQ",   "Sequence", $(srchSequence), "", operSequence, "N")
  @Build_WildCard ("coalesce(USDESCU,NFPART)", "Participant", $(srchUser), "U", operUser, "A")
  @Build_WildCard ("upper(coalesce(c.FLDESC,' '))", "Instance Participant", $(srchInstanceParticipant), "U", operInstanceParticipant, "A")
  @Build_WildCard ("coalesce(b.PDDESCU,' ')", "Notify Detail Point", $(srchNotifyPoint), "U", operNotifyPoint, "A")
  @Build_WildCard ("coalesce(MSDESCU,' ')", "Message ID", $(srchMessageId), "U", operMessageId, "A")
  @Build_WildCard ("NFPGM",   "Program", $(srchProgram), "U", operProgram, "A")
  @Build_WildCard ("upper(coalesce(d.FLDESC,' '))", "Send Notification", $(srchSend), "U", operSend, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}