%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "ItemMaintain.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"
%INCLUDE "YNFlagTable.icl"

%Define {	
  page_title              = "Item"
  d2wName                 = "Item.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;plantName=@dtw_rurlescseq(plantName)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;warehouseName=@dtw_rurlescseq(warehouseName)&amp;inclActive=@dtw_rurlescseq(inclActive)&amp;inclInactive=@dtw_rurlescseq(inclInactive)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  imageExists             = ""
  inclActive              = ""
  inclInactive            = ""
  d2wNameExt              = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
  @dtw_replace(workURL, "@@customerNumber", "@dtw_rurlescseq(customerNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@customerName", "@dtw_rurlescseq(customerName)", "1", "a", workURL)
  @dtw_replace(workURL, "@@itemNumber", "@dtw_rurlescseq(itemNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@plantNumber", "@dtw_rurlescseq(plantNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@plantName", "@dtw_rurlescseq(plantName)", "1", "a", workURL)
  @dtw_replace(workURL, "@@warehouseNumber", "@dtw_rurlescseq(warehouseNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@warehouseName", "@dtw_rurlescseq(warehouseName)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @dtw_assign(d2wNameExt, "(Item)")
  %if (customerNumber != "")
      @CustomerUserView(profileHandle, dataBaseID, userPass, customerNumber, " ")
  %elseif (plantNumber != "")
      @dtw_assign(d2wNameExt, "(Plant)")
      @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %elseif (warehouseNumber != "")
      @dtw_assign(d2wNameExt, "(Warehouse)")
      @WarehouseUserView(profileHandle, dataBaseID, userPass, warehouseNumber)
  %else
      @dtw_assign(userPass, "Y")
  %endif

  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
                  %INCLUDE "CheckEnterSearch.icl"
                  %INCLUDE "NoFormValidate.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                          %if (plantNumber != "")
                              @dtw_assign(pageID, "ITEMFORPLANT")
                          %elseif (warehouseNumber != "")
                              @dtw_assign(pageID, "ITEMFORWAREHOUSE")
                          %else
                              @dtw_assign(pageID, "ITEM")
                          %endif
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif

                      <td class="content">
                          @dtw_assign(uv_ProductClassName, "IMPCLS")
                          %if (plantNumber != "")
                              @dtw_assign(uv_PlantName, "IPPLT")
                              @dtw_assign(uv_PltPartTypeName, "IPPTYP")
                              @dtw_assign(uv_PltInventoryTypeName, "IPITC")
                              @dtw_assign(uv_PartClassName, "IPCLAS")
                              @dtw_assign(uv_VendorName, "IPVEND")
                              @dtw_assign(uv_BuyerName, "IPBAC")
                          %elseif (warehouseNumber != "")
                              @dtw_assign(uv_WarehouseName, "IWWHS")
                              @dtw_assign(uv_ProductGroupName, "IWPGRP")
                              @dtw_assign(uv_ProdInventoryTypeName, "IMITC")
                              @dtw_assign(uv_ProdPartTypeName, "IMPTYP")
                          %else
                              @dtw_assign(uv_ProdInventoryTypeName, "IMITC")
                              @dtw_assign(uv_ProdPartTypeName, "IMPTYP")
                          %endif
                          %INCLUDE "userview.icl"

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select HDIMST.*,  ", stmtSQL)
                          @dtw_concat(stmtSQL, " PCPCDS,b.FLDESC as kitFLDESC, ", stmtSQL)
                          @dtw_concat(stmtSQL, " a.FLDESC as partTypeFLDESC  ", stmtSQL)
                          %if (plantNumber != "")
                              @dtw_concat(stmtSQL, ", IPPTYP  ", stmtSQL)
                          %endif

                          @dtw_concat(fileSQL, " HDIMST ", fileSQL)
                          %if (customerNumber != "")
                              @dtw_concat(fileSQL, " inner join HDVCIT on VCITEM=IMITEM ", fileSQL)
                          %elseif (plantNumber != "")
                              @dtw_concat(fileSQL, " inner join HDIPLT on IPITEM=IMITEM ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYFLAG a on a.FLTYPE='PARTTYPE' and a.FLVALU=IPPTYP ", fileSQL)
                          %elseif (warehouseNumber != "")
                              @dtw_concat(fileSQL, " inner join HDIWHS on IWITEM=IMITEM ", fileSQL)
                          %endif
                          %if (plantNumber == "")
                              @dtw_concat(fileSQL, " left join SYFLAG a on a.FLTYPE='PARTTYPE' and a.FLVALU=IMPTYP ", fileSQL)
                          %endif
                          @dtw_concat(fileSQL, " left join HDPCLS on PCPCLS=IMPCLS ", fileSQL)
                          @dtw_concat(fileSQL, " left join SYFLAG b on b.FLTYPE='KIT' and b.FLVALU=IMKIT ", fileSQL)

                          %if (customerNumber != "")
                              @dtw_concat(selectSQL, "VCVCF='C' and VCVNCS=$(customerNumber) ", selectSQL)
                          %elseif (plantNumber != "")
                              @dtw_concat(selectSQL, "IPPLT=$(plantNumber) ", selectSQL)
                          %elseif (warehouseNumber != "")
                              @dtw_concat(selectSQL, "IWWHS=$(warehouseNumber) ", selectSQL)
                          %else
                              @dtw_concat(selectSQL, "IMITEM>' ' ", selectSQL)
                          %endif

                          %if ((inclActive == "Y") && (inclInactive != "Y"))
                              @dtw_concat(selectSQL, "  and IMIMAC=' '", selectSQL)
                          %elseif ((inclActive != "Y") && (inclInactive == "Y"))
                              @dtw_concat(selectSQL, "  and IMIMAC> ' '", selectSQL)
                          %elseif ((inclActive != "Y") && (inclInactive != "Y"))
                              @dtw_concat(selectSQL, "  and IMIMAC=' ' and IMIMAC> ' '", selectSQL)
                          %endif

                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Item_List(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Item_List (IN CHAR(64)    profileHandle,
                                 CHAR(2)     dataBaseID,
                                 CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  %if (plantNumber != "")
                      @dtw_assign(programName, "HHDIPU")
                  %elseif (warehouseNumber != "")
                      @dtw_assign(programName, "HHDIWU")
                  %else
                      @dtw_assign(programName, "HHDIMU")
                  %endif
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)

                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          %if (plantNumber != "")
                              <a href="$(homeURL)$(cGIPath)ItemPlantMaintain.d2w/ADD$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                          %elseif (warehouseNumber != "")
                              <a href="$(homeURL)$(cGIPath)ItemWarehouseMaintain.d2w/ADD$(genericVarBase)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                          %else
                              <a href="$(homeURL)$(cGIPath)ItemMaintain.d2w/MAINTAIN$(genericVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                          %endif
                      %endif

                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      <table $(contentTable)>
          %if (customerNumber != "")
              @Format_Header_URL("Customer", $(customerName), $(customerNumber), "$(homeURL)$(cGIPath)CustomerSelect.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)")
          %elseif (plantNumber != "")
              @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
              @Format_Header_URL("Plant", $(plantName), $(plantNumber), "$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;plantName=@dtw_rurlescseq(plantName)")
          %elseif (warehouseNumber != "")
              @Format_Header_URL("Warehouse", $(warehouseName), $(warehouseNumber), "$(homeURL)$(cGIPath)WarehouseSelect.d2w/REPORT$(genericVarBase)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;warehouseName=@dtw_rurlescseq(warehouseName)")
          %endif
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)
			
      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Item Number</th>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">Product<br>Class</th>
                  </tr>
                  <tr>
                      <td class="inputalph">
                          <input type="text" name="srchItem" size="15" maxlength="15">
                          <input type="hidden" name="operItem" value="LIKE">
                      </td>
                      <td class="inputalph">
                          <input type="text" name="srchDesc" size="15" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td class="inputalph">
                          <input type="text" name="srchProdClass" size="5" maxlength="4">
                          <input type="hidden" name="operProdClass" value="LIKE">
                      </td>

                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchItem.focus();
              </script>
          </form>
	
          %if (inclActive == "Y")
              @dtw_assign(activeChecked, "CHECKED")
          %else
              @dtw_assign(activeChecked, "")
          %endif

          %if (inclInactive == "Y")
              @dtw_assign(inactiveChecked, "CHECKED")
          %else
              @dtw_assign(inactiveChecked, "")
          %endif

          @dtw_assign(viewCheckBox, "ItemActive")
          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y")
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("IMITEM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=itemNumber" title="Sequence By Item Number">Item Number</a></th>
              @OrderBy_Sort("IMIMDSU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=description" title="Sequence By Description, Item Number">Description</a></th>
              @OrderBy_Sort("IMPCLS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=productClass" title="Sequence By Product Class, Item Number">Product<br>Class</a></th>
              @OrderBy_Sort("IMKIT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=kit" title="Sequence By Kit/Featured Item/Configurable, Item Number">KFC</a></th>
              %if (V_CILTUS == "Y")
                  @OrderBy_Sort("IMLOT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=lot" title="Sequence By Lot Controlled, Item Number"> Lot </a></th>
              %endif
              %if (V_HDPDRL > "0")
                  %if (plantNumber == "")
                      @OrderBy_Sort("IMPTYP", sortVar)
                  %else
                      @OrderBy_Sort("IPPTYP", sortVar)
                  %endif
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=partType" title="Sequence By Part Type, Item Number">Part<br>Type</a></th>
              %endif
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_IMITEM)&amp;itemDescription=@dtw_rurlescseq(V_IMIMDS)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_IMIMDS), $(V_IMITEM), "", "", "", "", confirmDesc)

              @RtvFldDesc("IXITEM='$(V_IMITEM)'", "HDIMXD", "char(count(*))", cmtCount)
              @dtw_assign(itemImage, "$(V_IMITEM)$(itemImageExt)")
              @dtwf_exists(itemImage, imageExists)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y")
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              %if (plantNumber != "")
                                  <a href="$(homeURL)$(cGIPath)ItemPlantMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromItemNumber=@dtw_rurlescseq(V_IMITEM)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;fromPlant=@dtw_rurlescseq(plantNumber)&amp;maintenanceCode=C">$(changeImageSml)</a>
                              %elseif (warehouseNumber != "")
                                  <a href="$(homeURL)$(cGIPath)ItemWarehouseMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromItemNumber=@dtw_rurlescseq(V_IMITEM)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;fromWarehouse=@dtw_rurlescseq(warehouseNumber)&amp;maintenanceCode=C">$(changeImageSml)</a>
                              %else
                                  <a href="$(homeURL)$(cGIPath)ItemMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                              %endif
                          %endif
                          %if (sec_04 == "Y")
                             %if (plantNumber != "")
                                 <a href="$(homeURL)$(cGIPath)ItemPlantMaintain.d2w/ADD$(maintainVar)&amp;fromItemNumber=@dtw_rurlescseq(V_IMITEM)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;fromPlant=@dtw_rurlescseq(plantNumber)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                             %elseif (warehouseNumber != "")
                                 <a href="$(homeURL)$(cGIPath)ItemWarehouseMaintain.d2w/ADD$(maintainVar)&amp;fromItemNumber=@dtw_rurlescseq(V_IMITEM)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;fromWarehouse=@dtw_rurlescseq(warehouseNumber)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                             %else
                                 <a href="$(homeURL)$(cGIPath)ItemMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                             %endif
    		           %endif
                          %if (sec_03 == "Y")
                             %if (plantNumber != "")
                                  <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)ItemPlantMaintain.d2w/Edit_Data$(maintainVar)&amp;fromItemNumber=@dtw_rurlescseq(V_IMITEM)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;fromPlant=@dtw_rurlescseq(plantNumber)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                             %elseif (warehouseNumber != "")
                                  <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)ItemWarehouseMaintain.d2w/Edit_Data$(maintainVar)&amp;fromItemNumber=@dtw_rurlescseq(V_IMITEM)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;fromWarehouse=@dtw_rurlescseq(warehouseNumber)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                             %else
                                  <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)ItemMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                             %endif
                          %endif
                          <a href="$(homeURL)$(cGIPath)ItemWarehouse.d2w/REPORT$(maintainVar)">$(whsImageSml)</a>
                          %if (V_HDPDRL > "0")
                              <a href="$(homeURL)$(cGIPath)ItemPlant.d2w/REPORT$(maintainVar)">$(pltImageSml)</a>
                          %endif
    		           %if (cmtCount > "0" && sec_02 == "Y")
                              <a href="$(homeURL)$(cGIPath)ItemExtCmt.d2w/REPORT$(maintainVar)&amp;backHome=@dtw_rurlescseq(d2wName)/REPORT">$(commentExistImage)</a>
    		           %elseif (cmtCount > "0")
                              <a href="$(homeURL)$(cGIPath)ItemExtCmt.d2w/REPORT$(maintainVar)&amp;inquiryOnly=Y&amp;backHome=@dtw_rurlescseq(d2wName)/REPORT">$(commentExistImage)</a>
                          %elseif (sec_02 == "Y")
                              <a href="$(homeURL)$(cGIPath)ItemExtCmt.d2w/REPORT$(maintainVar)&amp;backHome=@dtw_rurlescseq(d2wName)/REPORT">$(commentImage)</a>
                          %endif
    		           %if (imageExists == "Y" && formatToPrint != "Y")
                              <a href="$(homeURL)$(cGIPath)imageDisplay.d2w/DISPLAY$(genericVarBase)&amp;imageDisplayPath=$(homeURL)$(itemImage)&amp;imageDesc=@dtw_rurlescseq(V_IMIMDS)" onclick="$(itemImageWinVar)">$(foundImage)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_IMITEM)</td>
                  %if (plantNumber != "")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemPlantSelect.d2w/REPORT$(maintainVar)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;plantName=@dtw_rurlescseq(plantName)" title="View Item Plant">$(V_IMIMDS)</a></td>
                  %elseif (warehouseNumber != "")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemWarehouseSelect.d2w/REPORT$(maintainVar)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;warehouseName=@dtw_rurlescseq(warehouseName)" title="View Item Warehouse">$(V_IMIMDS)</a></td>
                  %else
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemSelect.d2w/REPORT$(maintainVar)" title="View Item">$(V_IMIMDS)</a></td>
                  %endif
                  <td class="colalph" $(helpCursor)><span title="$(V_PCPCDS)">$(V_IMPCLS)</span></td>
                  <td class="colcode" $(helpCursor)><span title="$(V_kitFLDESC )">$(V_IMKIT)</span></td>
                  %if (V_CILTUS == "Y")
                      @RtvFldDesc("FLTYPE='LOT' and FLVALU='$(V_IMLOT)'", "SYFLAG", "FLDESC", lotCtrlDesc)
                      <td class="colcode" $(helpCursor)><span title="$(lotCtrlDesc)">$(V_IMLOT)</span></td>
                  %endif
                  %if (V_HDPDRL > "0")
                      %if (plantNumber == "")
                          <td class="colcode" $(helpCursor)><span title="$(V_partTypeFLDESC)">$(V_IMPTYP)</span></td>
                      %else
                          <td class="colcode" $(helpCursor)><span title="$(V_partTypeFLDESC)">$(V_IPPTYP)</span></td>
                      %endif
                  %endif
                  %if (V_IMIMAC == "I")
                      <td class="colicon">$(inactiveImageSml)</td>
                  %endif
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) { 	
  %if (customerNumber != "")
      @CustomerUserView(profileHandle, dataBaseID, userPass, customerNumber, " ")
  %elseif (plantNumber != "")
      @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %elseif (warehouseNumber != "")
      @WarehouseUserView(profileHandle, dataBaseID, userPass, warehouseNumber)
  %else
      @dtw_assign(userPass, "Y")
  %endif

  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      @dtw_assign(uv_ProductClassName, "IMPCLS")
      %if (plantNumber != "")
          @dtw_assign(uv_PlantName, "IPPLT")
          @dtw_assign(uv_PltPartTypeName, "IPPTYP")
          @dtw_assign(uv_PltInventoryTypeName, "IPITC")
          @dtw_assign(uv_PartClassName, "IPCLAS")
          @dtw_assign(uv_VendorName, "IPVEND")
          @dtw_assign(uv_BuyerName, "IPBAC")
      %elseif (warehouseNumber != "")
          @dtw_assign(uv_WarehouseName, "IWWHS")
          @dtw_assign(uv_ProductGroupName, "IWPGRP")
          @dtw_assign(uv_ProdInventoryTypeName, "IMITC")
          @dtw_assign(uv_ProdPartTypeName, "IMPTYP")
      %else
          @dtw_assign(uv_ProdInventoryTypeName, "IMITC")
          @dtw_assign(uv_ProdPartTypeName, "IMPTYP")
      %endif
      %INCLUDE "userview.icl"

      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Select HDIMST.* ", stmtSQL)
      %if (plantNumber != "")
          @dtw_concat(stmtSQL, ", IPPTYP  ", stmtSQL)
      %endif
      @dtw_concat(fileSQL, " HDIMST ", fileSQL)
      %if (customerNumber != "")
          @dtw_concat(fileSQL, " inner join HDVCIT on VCITEM=IMITEM ", fileSQL)
          @dtw_concat(selectSQL, "VCVCF='C' and VCVNCS=$(customerNumber) ", selectSQL)
      %elseif (plantNumber != "")
          @dtw_concat(fileSQL, " inner join HDIPLT on IPITEM=IMITEM ", fileSQL)
          @dtw_concat(selectSQL, "IPPLT=$(plantNumber) ", selectSQL)
      %elseif (warehouseNumber != "")
          @dtw_concat(fileSQL, " inner join HDIWHS on IWITEM=IMITEM ", fileSQL)
          @dtw_concat(selectSQL, "IWWHS=$(warehouseNumber) ", selectSQL)
      %else
          @dtw_concat(selectSQL, "IMITEM>' ' ", selectSQL)
      %endif

      %if ((inclActive == "Y") && (inclInactive != "Y"))
          @dtw_concat(selectSQL, "  and IMIMAC=' '", selectSQL)
      %elseif ((inclActive != "Y") && (inclInactive == "Y"))
          @dtw_concat(selectSQL, "  and IMIMAC>' '", selectSQL)
      %elseif ((inclActive != "Y") && (inclInactive != "Y"))
          @dtw_concat(selectSQL, "  and IMIMAC=' ' and IMIMAC>' '", selectSQL)
      %endif

      %INCLUDE "stmtSQLSelect.icl"
      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
      %INCLUDE "stmtSQLEnd.icl"
      @Item_List_XMLQuery(profileHandle, dataBaseID, stmtSQL)
  %endif
%}

%FUNCTION(dtw_sql) Item_List_XMLQuery (IN CHAR(64)    profileHandle,
				           CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("ItemList")		
          %ROW{
              @XMLIDTag(V_IMITEM, "Item ID")
                  @XMLTag(V_IMITEM, "Item")
                  @XMLTag(V_IMPCLS, "ProductClass")
                  @XMLTag(V_IMIMWG, "Weight")
                  @XMLTag(V_IMIMDS, "Description")
                  @XMLTag(V_IMITC, "InventoryType")
              @XMLEndTag("Item")
	       %}
      @XMLEndTag("ItemList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "IMIMDSU,IMITEM")
          @DTW_ASSIGN(orderByDisplay, "Description, Item Number")
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %elseif (chgActive == "Y" && inclActive == "Y")
          @dtw_assign(inclActive, "")
      %elseif (chgActive == "Y")
          @dtw_assign(inclActive, "Y")
      %elseif (chgInactive == "Y" && inclInactive == "Y")
          @dtw_assign(inclInactive, "")
      %elseif (chgInactive == "Y")
          @dtw_assign(inclInactive, "Y")
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %if (inclActive == "" && inclInactive == "" && chgActive != "Y" && chgInactive != "Y")
      @dtw_assign(inclActive, "Y")
      @dtw_assign(inclInactive, "")
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit ()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "itemNumber")
      %if (orderBy == "IMITEM")
          @DTW_ASSIGN(orderBy, "IMITEM DESC")
          @DTW_ASSIGN(orderByDisplay, "Item Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "IMITEM")
          @DTW_ASSIGN(orderByDisplay, "Item Number")
      %endif
  %elseif (sequence == "description")
      %if (orderBy == "IMIMDSU,IMITEM")
          @DTW_ASSIGN(orderBy, "IMIMDSU DESC,IMITEM")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Item Number")
      %else
          @DTW_ASSIGN(orderBy, "IMIMDSU,IMITEM")
          @DTW_ASSIGN(orderByDisplay, "Description, Item Number")
      %endif
  %elseif (sequence == "productClass")
      %if (orderBy == "IMPCLS,IMITEM")
          @DTW_ASSIGN(orderBy, "IMPCLS DESC,IMITEM")
          @DTW_ASSIGN(orderByDisplay, "Product Class (descending), Item Number")
      %else
          @DTW_ASSIGN(orderBy, "IMPCLS,IMITEM")
          @DTW_ASSIGN(orderByDisplay, "Product Class, Item Number")
      %endif
  %elseif (sequence == "kit")
      %if (orderBy == "IMKIT,IMITEM")
          @DTW_ASSIGN(orderBy, "IMKIT DESC,IMITEM")
          @DTW_ASSIGN(orderByDisplay, "Kit/Featured Item/Configurable (descending), Item Number")
      %else
          @DTW_ASSIGN(orderBy, "IMKIT,IMITEM")
          @DTW_ASSIGN(orderByDisplay, "Kit/Featured Item/Configurable, Item Number")
      %endif
  %elseif (sequence == "lot")
      %if (orderBy == "IMLOT,IMITEM")
          @DTW_ASSIGN(orderBy, "IMLOT DESC,IMITEM")
          @DTW_ASSIGN(orderByDisplay, "Lot Controlled (descending), Item Number")
      %else
          @DTW_ASSIGN(orderBy, "IMLOT,IMITEM")
          @DTW_ASSIGN(orderByDisplay, "Lot Controlled, Item Number")
      %endif
  %elseif (sequence == "partType" && plantNumber == "")
      %if (orderBy == "IMPTYP,IMITEM")
          @DTW_ASSIGN(orderBy, "IMPTYP DESC,IMITEM")
          @DTW_ASSIGN(orderByDisplay, "Part Type (descending), Item Number")
      %else
          @DTW_ASSIGN(orderBy, "IMPTYP,IMITEM")
          @DTW_ASSIGN(orderByDisplay, "Part Type, Item Number")
      %endif
  %elseif (sequence == "partType")
      %if (orderBy == "IPPTYP,IMITEM")
          @DTW_ASSIGN(orderBy, "IPPTYP DESC,IMITEM")
          @DTW_ASSIGN(orderByDisplay, "Part Type (descending), Item Number")
      %else
          @DTW_ASSIGN(orderBy, "IPPTYP,IMITEM")
          @DTW_ASSIGN(orderByDisplay, "Part Type, Item Number")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchUPC, 13, 0)
                      %if (V_CIINS1 != "")	
                         && editNum(document.Search.srchNumeric1, 8, 5)
                      %endif
                      %if (V_CIINS2 != "")	
                         && editNum(document.Search.srchNumeric2, 8, 5)
                      %endif
                      %if (V_CIINS3 != "")	
                         && editNum(document.Search.srchNumeric3, 8, 5)
                      %endif
                      %if (V_CIINS4 != "")	
                         && editNum(document.Search.srchNumeric4, 8, 5)
                      %endif
                      %if (V_CIINS5 != "")	
                         && editNum(document.Search.srchNumeric5, 8, 5)
                      %endif
                  )
                  return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ITEMSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Item Number</td>
                              @dtw_assign(operNbr, "operItem")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchItem" type="text" size="15" maxlength="15">$(V_IMITEM)</td>
                          </tr>
        			
                          <tr><td class="dsphdr">Item Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchDesc" type="text" size="30" maxlength="30"></td>
                          </tr>
        			
                          <tr><td class="dsphdr">Product Class</td>
                              @dtw_assign(operNbr, "operProdClass")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchProdClass" type="text" size="4" maxlength="4"><a href="$(homeURL)$(cGIPath)prodclasssearch.d2w/ENTRY$(genericVarBase)&amp;docName=Search&amp;fldName=srchProdClass&amp;fldDesc=productClassDescH" onclick="$(searchWinVar)"> $(searchImage) </a><input name="productClassDescH" type="text" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Kit Item / Featured Item / Cfg</td>
                              @dtw_assign(operNbr, "operKit")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchKit" type="text" size="1" maxlength="1"></td>
                          </tr>

                          %if (V_CILTUS == "Y")
                              <tr><td class="dsphdr">Lot Controlled</td>
                                  @dtw_assign(operNbr, "operLot")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input name="srchLot" type="text" size="1" maxlength="1"></td>
                              </tr>
                          %endif

                          %if (V_HDPDRL > "0")
                              <tr><td class="dsphdr">Part Type</td>
                                  @dtw_assign(operNbr, "operPartType")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input name="srchPartType" type="text" size="1" maxlength="1"></td>
                              </tr>
                          %endif

                          <tr><td class="dsphdr">Catalog Number</td>
                              @dtw_assign(operNbr, "operCatalog")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchCatalog" type="text" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">U.P.C. Number</td>
                              @dtw_assign(operNbr, "operUPC")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputnmbr"><input name="srchUPC" type="text" size="13" maxlength="13"></td>
                          </tr>

                          %if (V_CIIAS1 != "")		
                              <tr><td class="dsphdr">$(V_CIIAS1)</td>
                                  @dtw_assign(operNbr, "operAlpha1")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchAlpha1" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIIAS2 != "")		
                              <tr><td class="dsphdr">$(V_CIIAS2)</td>
                                  @dtw_assign(operNbr, "operAlpha2")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchAlpha2" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIIAS3 != "")		
                              <tr><td class="dsphdr">$(V_CIIAS3)</td>
                                  @dtw_assign(operNbr, "operAlpha3")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchAlpha3" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIIAS4 != "")		
                              <tr><td class="dsphdr">$(V_CIIAS4)</td>
                                  @dtw_assign(operNbr, "operAlpha4")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchAlpha4" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIIAS5 != "")		
                              <tr><td class="dsphdr">$(V_CIIAS5)</td>
                                  @dtw_assign(operNbr, "operAlpha5")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchAlpha5" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIINS1 != "")		
                              <tr><td class="dsphdr">$(V_CIINS1)</td>
                                  @dtw_assign(operNbr, "operNumeric1")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchNumeric1" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIINS2 != "")		
                              <tr><td class="dsphdr">$(V_CIINS2)</td>
                                  @dtw_assign(operNbr, "operNumeric2")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchNumeric2" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIINS3 != "")		
                              <tr><td class="dsphdr">$(V_CIINS3)</td>
                                  @dtw_assign(operNbr, "operNumeric3")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchNumeric3" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIINS4 != "")		
                              <tr><td class="dsphdr">$(V_CIINS4)</td>
                                  @dtw_assign(operNbr, "operNumeric4")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchNumeric4" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIINS5 != "")		
                              <tr><td class="dsphdr">$(V_CIINS5)</td>
                                  @dtw_assign(operNbr, "operNumeric5")
                                 <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchNumeric5" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchItem.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("IMITEM", "Item Number", $(srchItem), "U", operItem, "A")
  @Build_WildCard ("IMIMDSU", "Item Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("IMPCLS", "Product Class", $(srchProdClass), "U", operProdClass, "A")
  @Build_WildCard ("IMKIT",  "Kit Item / Featured Item / Cfg", $(srchKit), "U", operKit, "A")
  @Build_WildCard ("IMLOT",  "Lot Controlled", $(srchLot), "U", operLot, "A")
  %if (plantNumber == "")
      @Build_WildCard ("IMPTYP", "Part Type", $(srchPartType), "U", operPartType, "A")
  %else
      @Build_WildCard ("IPPTYP", "Part Type", $(srchPartType), "U", operPartType, "A")
  %endif
  @Build_WildCard ("IMCATN", "Catalog Number", $(srchCatalog), "U", operCatalog, "A")
  @Build_WildCard ("IMUPC", "U.P.C. Number", $(srchUPC), "", operUPC, "N")
  @Build_WildCard ("IMUDA1", "$(V_CIIAS1)", $(srchAlpha1), "U", operAlpha1, "A")
  @Build_WildCard ("IMUDA2", "$(V_CIIAS2)", $(srchAlpha2), "U", operAlpha2, "A")
  @Build_WildCard ("IMUDA3", "$(V_CIIAS3)", $(srchAlpha3), "U", operAlpha3, "A")
  @Build_WildCard ("IMUDA4", "$(V_CIIAS4)", $(srchAlpha4), "U", operAlpha4, "A")
  @Build_WildCard ("IMUDA5", "$(V_CIIAS5)", $(srchAlpha5), "U", operAlpha5, "A")
  @Build_WildCard ("IMUDN1", "$(V_CIINS1)", $(srchNumeric1), "", operNumeric1, "N")
  @Build_WildCard ("IMUDN2", "$(V_CIINS2)", $(srchNumeric2), "", operNumeric2, "N")
  @Build_WildCard ("IMUDN3", "$(V_CIINS3)", $(srchNumeric3), "", operNumeric3, "N")
  @Build_WildCard ("IMUDN4", "$(V_CIINS4)", $(srchNumeric4), "", operNumeric4, "N")
  @Build_WildCard ("IMUDN5", "$(V_CIINS5)", $(srchNumeric5), "", operNumeric5, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}