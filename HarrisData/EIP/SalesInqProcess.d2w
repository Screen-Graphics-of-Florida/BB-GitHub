%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Sales Inquiry For $(selectedDesc)"
  d2wName                 = "SalesInqProcess.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;selectedDesc=@dtw_rurlescseq(selectedDesc)&amp;userSQL=@dtw_rurlescseq(userSQL)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  selectName              = "SALESINQ"
  advanceSearch           = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select SLUSER, SLDESC, upper(SLDESC) as SLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " USDESCU, USDESC ", stmtSQL)
                      @dtw_concat(fileSQL, " SYUSLM ", fileSQL)
                      @dtw_concat(fileSQL, " inner join SYUSER on USUSER=SLUSER ", fileSQL)
                      @dtw_concat(selectSQL, "SLNAME='SALESINQ' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Customer_Sales_Inq_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Customer_Sales_Inq_Query (IN  CHAR(64)    profileHandle,
                                                 CHAR(2)     dataBaseID,
                                                 CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"

      $(inquiryhrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST name="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">User</th>
                      <th class="colhdr">Description</th>
                  </tr>
                  <tr>
                      <td><input type="text" class="inputalph" name="user" size="10" maxlength="10">
                          <input type="hidden" name="operUser" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="desc" size="20" maxlength="50">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.desc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("USDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=User" title="Sequence By User"> User</a></th>
              @OrderBy_Sort("SLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description"> Description</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;selectUser=@dtw_rurlescseq(V_SLUSER)&amp;selectDesc=@dtw_rurlescseq(V_SLDESC)&amp;allUsers=&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_SLDESC), "", "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  <td class="colalph">$(V_USDESC)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)$(d2wName)/PROCESS$(maintainVar)" title="Submit Selection" target="_blank">$(V_SLDESC)</a></td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(inquiryhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Update_User_Selection(INOUT CHAR(64) profileHandle,
                                                INOUT CHAR(2)  dataBaseID,
                                                INOUT CHAR(1)  maintCode,
                                                INOUT CHAR(10) userProfile,
                                                INOUT CHAR(10) selectName,
                                                INOUT DEC(5,0) selectSequence,
                                                INOUT CHAR(50) selectDesc,
                                                INOUT CHAR(10) selectTotals,
                                                INOUT CHAR(500) selectGroupBy,
                                                INOUT CHAR(3000) selectCriteria)
{%EXEC {HSYUSL_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "USDESCU, SLDESCU")
          @DTW_ASSIGN(orderByDisplay, "User, Description")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(PROCESS) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(maintCode, "S")
  @Update_User_Selection(profileHandle, dataBaseID, maintCode, selectUser, selectName, selectSequence, selectDesc, selectTotals, selectGroupBy, selectCriteria)

  %if (selectGroupBy != "")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)salesinqgroupby.d2w/PROCESS$(genericVarBase)&amp;downloadProfileHandle=@dtw_rurlescseq(profileHandle)&amp;selectSequence=@dtw_rurlescseq(selectSequence)&amp;userSQL=@dtw_rurlescseq(userSQL)&amp;grpFldLvl=1&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %else
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)salesinqdisplay.d2w/PROCESS$(genericVarBase)&amp;downloadProfileHandle=@dtw_rurlescseq(profileHandle)&amp;selectSequence=@dtw_rurlescseq(selectSequence)&amp;userSQL=@dtw_rurlescseq(userSQL)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "User")
      %if (orderBy == "USDESCU, SLDESCU")
          @DTW_ASSIGN(orderBy, "USDESCU DESC, SLDESCU")
          @DTW_ASSIGN(orderByDisplay, "User (descending), Description")
      %else
          @DTW_ASSIGN(orderBy, "USDESCU, SLDESCU")
          @DTW_ASSIGN(orderByDisplay, "User, Description")
      %endif
  %elif (sequence == "Desc")
      %if (orderBy == "SLDESCU, USDESCU")
          @DTW_ASSIGN(orderBy, "SLDESCU DESC, USDESCU")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), User")
      %else
          @DTW_ASSIGN(orderBy, "SLDESCU, USDESCU")
          @DTW_ASSIGN(orderByDisplay, "Description, User")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("USDESCU", "User", $(user), "U", operUser, "A")
  @Build_WildCard ("upper(SLDESC)", "Description", $(desc), "U", operDesc, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}