              @OrderBy_Sort("JSTCHR", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TCHR"  title="Sequence By Table Reference Characters, Application ID, User, Workstation, Program Name, Printer File">Table Reference Characters</a></th>
              @OrderBy_Sort("JSUSDB", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=USDB"  title="Sequence By User Specified DBCS Data, Application ID, User, Workstation, Program Name, Printer File">User Specified DBCS Data</a></th>
              @OrderBy_Sort("JSDBEX", sortVar)
