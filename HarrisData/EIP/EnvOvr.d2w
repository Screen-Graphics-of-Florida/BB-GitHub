              @OrderBy_Sort("JSDBFP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DBFP"  title="Sequence By DBCS Coded Font Point Size, Application ID, User, Workstation, Program Name, Printer File">DBCS Coded Font Point Size</a></th>
              @OrderBy_Sort("JSNSUP", sortVar)
