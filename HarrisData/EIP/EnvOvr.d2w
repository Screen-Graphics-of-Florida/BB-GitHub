              @OrderBy_Sort("JSCDPG", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CDPG"  title="Sequence By Font Code Page, Application ID, User, Workstation, Program Name, Printer File">Font Character Set: Code Page</a></th>
              @OrderBy_Sort("JSCDPL", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CDPL"  title="Sequence By Font Code Page Library, Application ID, User, Workstation, Program Name, Printer File">Font Character Set: Code Page Library</a></th>
              @OrderBy_Sort("JSCDFT", sortVar)
