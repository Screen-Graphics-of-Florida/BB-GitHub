%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchCOPY, 3, 0) &&
                      editNum(document.Search.srchPGLN, 3, 3) &&
                      editNum(document.Search.srchPGWD, 3, 3) &&
                      editNum(document.Search.srchOVFL, 3, 0) &&
                      editNum(document.Search.srchLPI , 2, 1) &&
                      editNum(document.Search.srchCPI , 2, 1) &&
                      editNum(document.Search.srchFRDW, 2, 3) &&
                      editNum(document.Search.srchFRAC, 2, 3) &&
                      editNum(document.Search.srchBCDW, 2, 3) &&
                      editNum(document.Search.srchBCAC, 2, 3) &&
                      editNum(document.Search.srchFTPS, 3, 1))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ENVOVRSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Application ID</td>
                              @dtw_assign(operNbr, "operAPID")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchAPID" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">User Profile</td>
                              @dtw_assign(operNbr, "operUSER")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchUSER" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Workstation</td>
                              @dtw_assign(operNbr, "operWS")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchWS" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Program Name</td>
                              @dtw_assign(operNbr, "operPGID")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchPGID" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Printer File</td>
                              @dtw_assign(operNbr, "operPRTF")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchPRTF" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Allow Update In Upgrade</td>
                              @dtw_assign(operNbr, "operUPDT")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchUPDT" size="1" maxlength="1"></td>
                          </tr>
                          <tr><td class="dsphdr">Job Name</td>
                              @dtw_assign(operNbr, "operJNAM")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchJNAM" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Job Description</td>
                              @dtw_assign(operNbr, "operJOBD")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchJOBD" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Job Queue</td>
                              @dtw_assign(operNbr, "operJOBQ")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchJOBQ" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Job Priority (On JOBQ)</td>
                              @dtw_assign(operNbr, "operJOBP")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchJOBP" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">Log CL Program Commands</td>
                              @dtw_assign(operNbr, "operLOGC")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchLOGC" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">Hold On Job Queue</td>
                              @dtw_assign(operNbr, "operHLJQ")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchHLJQ" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">Output Queue</td>
                              @dtw_assign(operNbr, "operOUTQ")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchOUTQ" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Output Priority (On Outq)</td>
                              @dtw_assign(operNbr, "operPRTY")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchPRTY" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Copies</td>
                              @dtw_assign(operNbr, "operCOPY")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchCOPY" size="3" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Hold Spooled File</td>
                              @dtw_assign(operNbr, "operHOLD")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchHOLD" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Save Spooled File</td>
                              @dtw_assign(operNbr, "operSAVE")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchSAVE" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Max Spooled Output Records</td>
