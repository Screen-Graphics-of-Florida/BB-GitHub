          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(genericVarBase)&amp;EnvOvrApId=@dtw_rurlescseq(V_JSAPID)&amp;EnvOvrUser=@dtw_rurlescseq(V_JSUSER)&amp;EnvOvrWS=@dtw_rurlescseq(V_JSWS)&amp;EnvOvrPgm=@dtw_rurlescseq(V_JSPGID)&amp;EnvOvrPrtf=@dtw_rurlescseq(V_JSPRTF)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc("$(V_JSAPID)-$(V_JSUSER)-$(V_JSWS)-$(V_JSPGID)-$(V_JSPRTF)", "", "", "", "", "", confirmDesc)
              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)EnvOvrMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_04 == "Y")
                              <a href="$(homeURL)$(cGIPath)EnvOvrMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)EnvOvrMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_JSAPID)</td>
                  <td class="colalph"><span $(helpCursor) title="$(V_USDESC)">$(V_JSUSER)</span></td>                                      	
                  <td class="colalph">$(V_JSWS)  </td>
