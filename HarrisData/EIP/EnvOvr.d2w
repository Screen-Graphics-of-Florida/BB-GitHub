                              <td class="inputalph"><input type="text" name="srchDBCP" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">DBCS SO/SI Spacing</td>
                              @dtw_assign(operNbr, "operDBSO")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDBSO" size="6" maxlength="6"></td>
                          </tr>

                          <tr><td class="dsphdr">DBCS Coded Font</td>
                              @dtw_assign(operNbr, "operDBFT")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDBFT" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">DBCS Coded Font Library</td>
                              @dtw_assign(operNbr, "operDBFL")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDBFL" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">DBCS Coded Font Point Size</td>
                              @dtw_assign(operNbr, "operDBFP")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDBFP" size="6" maxlength="6"></td>
                          </tr>

                          <tr><td class="dsphdr">Non Supported Override</td>
                              @dtw_assign(operNbr, "operNSUP")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchNSUP" size="20" maxlength="50"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchAPID.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

