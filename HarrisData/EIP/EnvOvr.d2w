              @OrderBy_Sort("JSCHST", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CHST"  title="Sequence By Font Character Set, Application ID, User, Workstation, Program Name, Printer File">Font Character Set</a></th>
              @OrderBy_Sort("JSCHSL", sortVar)
