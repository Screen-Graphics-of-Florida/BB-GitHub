%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select HDJSBO.*,  ", stmtSQL)
  @dtw_concat(stmtSQL, " ifnull(USDESC,' ') as USDESC  ", stmtSQL)
  @dtw_concat(fileSQL, " HDJSBO ", fileSQL)
  @dtw_concat(fileSQL, " left join SYUSER on USUSER=JSUSER ", fileSQL)
  %if (wildCardSearch!="")
      @dtw_concat(selectSQL, "JSAPID<>'0' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @Page_XMLQuery(profileHandle, dataBaseID, stmtSQL)

%}

%FUNCTION(dtw_sql) Page_XMLQuery (IN  CHAR(64)    profileHandle,
			               CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("EnvOvrList")
		
          %ROW{
              @XMLIDTag(V_BKBANK, "EnvOvr ID")
                  @XMLTag(V_JSAPID, "ApplicationID")
                  @XMLTag(V_JSUSER, "UserProfile")
                  @XMLTag(V_JSWS,   "WorkstationID")
                  @XMLTag(V_JSPGID, "ProgramName")
                  @XMLTag(V_JSPRTF, "PrinterFile")
                  @XMLTag(V_JSUPDT, "AllowUpdateInUpgrade")
                  @XMLTag(V_JSJNAM, "JobName")
                  @XMLTag(V_JSJOBD, "JobDescription")
                  @XMLTag(V_JSJOBQ, "JobQueue")
                  @XMLTag(V_JSJOBP, "JobPriority")
                  @XMLTag(V_JSLOGC, "LogCLProgramCommands")
                  @XMLTag(V_JSHLJQ, "HoldOnJobQueue")
                  @XMLTag(V_JSOUTQ, "OutputQueue")
                  @XMLTag(V_JSPRTY, "OutputPriority")
                  @XMLTag(V_JSCOPY, "Copies")
                  @XMLTag(V_JSHOLD, "HoldSpooledFile")
                  @XMLTag(V_JSSAVE, "SaveSpooledFile")
                  @XMLTag(V_JSMXRC, "MaxSpooledOutputRecords")
                  @XMLTag(V_JSUDTA, "UserData")
                  @XMLTag(V_JSSPNM, "SpoolFileName")
                  @XMLTag(V_JSUSDF, "UserDefinedData")
                  @XMLTag(V_JSPGLN, "PageLength")
                  @XMLTag(V_JSPGWD, "PageWidth")
                  @XMLTag(V_JSOVFL, "OverflowLineNumber")
                  @XMLTag(V_JSLPI,  "LinesPerInch")
                  @XMLTag(V_JSCPI,  "CharactersPerInch")
                  @XMLTag(V_JSALPG, "AlignPage")
                  @XMLTag(V_JSFORM, "FormType")
                  @XMLTag(V_JSDEVT, "PrinterDeviceType")
                  @XMLTag(V_JSCVLD, "ConvertLineData")
                  @XMLTag(V_JSDGPR, "DegreeOfPageRotation")
                  @XMLTag(V_JSFROV, "FrontSideOverlay")
                  @XMLTag(V_JSFRLB, "FrontSideOverlayLibrary")
                  @XMLTag(V_JSFRDW, "FrontSideOffsetDown")
                  @XMLTag(V_JSFRAC, "FrontSideOffsetAcross")
                  @XMLTag(V_JSBCOV, "BackSideOverlay")
                  @XMLTag(V_JSBCLB, "BackSideOverlayLibrary")
                  @XMLTag(V_JSBCDW, "BackSideOffsetDown")
                  @XMLTag(V_JSBCAC, "BackSideOffsetAcross")
                  @XMLTag(V_JSBCCB, "BackSideConstantBack ")
                  @XMLTag(V_JSPGDF, "PageDefinition")
                  @XMLTag(V_JSPGLB, "PageDefinitionLibrary")
                  @XMLTag(V_JSFMDF, "FormDefinition")
                  @XMLTag(V_JSFMLB, "FormDefinitionLibrary")
                  @XMLTag(V_JSUOM,  "UnitOfMeasure")
                  @XMLTag(V_JSFRMD, "FrontMarginOffsetDown")
                  @XMLTag(V_JSFRMA, "FrontMarginOffsetAcross")
                  @XMLTag(V_JSBKMD, "BackMarginOffsetDown")
                  @XMLTag(V_JSBKMA, "BackMarginOffsetAcross")
                  @XMLTag(V_JSPRQL, "PrintQuality")
                  @XMLTag(V_JSDFWR, "DeferWrite")
                  @XMLTag(V_JSSPDT, "SpoolTheData")
                  @XMLTag(V_JSREDC, "ReduceOutput")
                  @XMLTag(V_JSPRSD, "PrintOnBothSides")
                  @XMLTag(V_JSPGSD, "PagesPerSide")
                  @XMLTag(V_JSSCDR, "SourceDrawer")
                  @XMLTag(V_JSOBIN, "OutputBin")
                  @XMLTag(V_JSFEED, "FormFeed")
                  @XMLTag(V_JSCNRS, "CornerStaple")
                  @XMLTag(V_JSJUST, "HardwareJustification")
                  @XMLTag(V_JSRCL1, "UserResourceLibrary1")
                  @XMLTag(V_JSRCL2, "UserResourceLibrary2")
                  @XMLTag(V_JSRCL3, "UserResourceLibrary3")
                  @XMLTag(V_JSRCL4, "UserResourceLibrary4")
                  @XMLTag(V_JSERFE, "EdgeStitchReferenceEdge")
                  @XMLTag(V_JSERFO, "EdgeStitchReferenceEdgeOffset")
                  @XMLTag(V_JSESTP, "EdgeStitchNumberOfStaples")
                  @XMLTag(V_JSESO1, "EdgeStitchStapleOffset1")
                  @XMLTag(V_JSESO2, "EdgeStitchStapleOffset2")
                  @XMLTag(V_JSESO3, "EdgeStitchStapleOffset3")
                  @XMLTag(V_JSESO4, "EdgeStitchStapleOffset4")
                  @XMLTag(V_JSSRFE, "SaddleStitchReferenceEdge")
