%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Environment Override"
  d2wName                 = "EnvOvr.d2w"
  d2wVarBase              = "$(genericVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HHDJSU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script type="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
           </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "ENVOVR")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select HDJSBO.*,  ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(USDESC,' ') as USDESC  ", stmtSQL)
                      @dtw_concat(fileSQL, " HDJSBO ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYUSER on USUSER=JSUSER ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, "RRN(HDJSBO)>0 ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Page_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Page_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)EnvOvrMaintain.d2w/MAINTAIN$(genericVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Ap ID</th>
                      <th class="colhdr">User Profile</th>
                      <th class="colhdr">Workstation</th>
                      <th class="colhdr">Program Name</th>
                      <th class="colhdr">Job Name</th>
                      <th class="colhdr">Output Queue</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchAPID" size="2" maxlength="2">
                          <input type="hidden" name="operAPID" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchUSER" size="10" maxlength="10">
                          <input type="hidden" name="operUSER" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchWS" size="10" maxlength="10">
                          <input type="hidden" name="operWS" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchPGID" size="10" maxlength="10">
                          <input type="hidden" name="operPGID" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchJNAM" size="10" maxlength="10">
                          <input type="hidden" name="operJNAM" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchOUTQ" size="10" maxlength="10">
                          <input type="hidden" name="operOUTQ" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchAPID.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("JSAPID", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=APID" title="Sequence By Application ID, User, Workstation, Program Name, Printer File">Ap ID</a></th>
              @OrderBy_Sort("JSUSER", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=USER" title="Sequence By User, Application ID, Workstation, Program Name, Printer File">User Profile</a></th>
              @OrderBy_Sort("JSWS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=WS"   title="Sequence By Workstation, Application ID, User, Program Name, Printer File">Workstation</a></th>
              @OrderBy_Sort("JSPGID", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PGID" title="Sequence By Program Name, Printer File, Application ID, User, Workstation">Program Name</a></th>
              @OrderBy_Sort("JSPRTF", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PRTF" title="Sequence By Printer File, Program Name, Application ID, User, Workstation ">Printer File</a></th>
              @OrderBy_Sort("JSUPDT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=UPDT" title="Sequence By Allow Update In Upgrade, Application ID, User, Workstation, Program Name, Printer File">Allow Update In Upgrade</a></th>
              @OrderBy_Sort("JSJNAM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=JOBN" title="Sequence By Job Name, Application ID, User, Workstation, Program Name, Printer File">Job Name</a></th>
              @OrderBy_Sort("JSJOBD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=JOBD" title="Sequence By Job Description, Application ID, User, Workstation, Program Name, Printer File">Job Description</a></th>
              @OrderBy_Sort("JSJOBQ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=JOBQ" title="Sequence By Job Queue, Application ID, User, Workstation, Program Name, Printer File">Job Queue</a></th>
              @OrderBy_Sort("JSJOBP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=JOBP" title="Sequence By Job Priority, Application ID, User, Workstation, Program Name, Printer File">Job Priority</a></th>
              @OrderBy_Sort("JSLOGC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=LOGC" title="Sequence By Log CL Program Commands, Application ID, User, Workstation, Program Name, Printer File">Log CL Program Commands</a></th>
              @OrderBy_Sort("JSHLJQ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=HLJQ" title="Sequence By Hold On Job Queue, Application ID, User, Workstation, Program Name, Printer File">Hold On Job Queue</a></th>
              @OrderBy_Sort("JSOUTQ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=OUTQ" title="Sequence By Output Queue, Application ID, User, Workstation, Program Name, Printer File">Output Queue</a></th>
              @OrderBy_Sort("JSPRTY", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PRTY" title="Sequence By Output Priority, Application ID, User, Workstation, Program Name, Printer File">Output Priority</a></th>
              @OrderBy_Sort("JSCOPY", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=COPY" title="Sequence By Copies, Application ID, User, Workstation, Program Name, Printer File">Copies</a></th>
              @OrderBy_Sort("JSHOLD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=HOLD" title="Sequence By Hold Spooled File, Application ID, User, Workstation, Program Name, Printer File">Hold Spooled File</a></th>
              @OrderBy_Sort("JSSAVE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SAVE" title="Sequence By Save Spooled File, Application ID, User, Workstation, Program Name, Printer File">Save Spooled File</a></th>
              @OrderBy_Sort("JSMXRC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MXRC" title="Sequence By Max Spooled Output Records, Application ID, User, Workstation, Program Name, Printer File">Max Spooled Output Records</a></th>
              @OrderBy_Sort("JSUDTA", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=UDTA" title="Sequence By User Data, Application ID, User, Workstation, Program Name, Printer File">User Data</a></th>
              @OrderBy_Sort("JSSPNM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SPNM" title="Sequence By Spool File Name, Application ID, User, Workstation, Program Name, Printer File">Spool File Name</a></th>
              @OrderBy_Sort("JSUSDF", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=USDF" title="Sequence By User Defined Data, Application ID, User, Workstation, Program Name, Printer File">User Defined Data</a></th>
              @OrderBy_Sort("JSPGLN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PGLN" title="Sequence By Page Size: Page Length, Application ID, User, Workstation, Program Name, Printer File">Page Size: Page Length</a></th>
              @OrderBy_Sort("JSPGWD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PGWD" title="Sequence By Page Size: Page Width, Application ID, User, Workstation, Program Name, Printer File">Page Size: Page Width</a></th>
              @OrderBy_Sort("JSOVFL", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=OVFL" title="Sequence By Overflow Line Number, Application ID, User, Workstation, Program Name, Printer File">Overflow Line Number</a></th>
              @OrderBy_Sort("JSLPI", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=LPI"  title="Sequence By Lines Per Inch, Application ID, User, Workstation, Program Name, Printer File">Lines Per Inch</a></th>
              @OrderBy_Sort("JSCPI", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CPI"  title="Sequence By Characters Per Inch, Application ID, User, Workstation, Program Name, Printer File">Characters Per Inch</a></th>
              @OrderBy_Sort("JSALPG", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ALPG"  title="Sequence By Align Page, Application ID, User, Workstation, Program Name, Printer File">Align Page</a></th>
              @OrderBy_Sort("JSFORM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FORM"  title="Sequence By Form Type, Application ID, User, Workstation, Program Name, Printer File">Form Type</a></th>
              @OrderBy_Sort("JSDEVT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DEVT"  title="Sequence By Printer Device Type, Application ID, User, Workstation, Program Name, Printer File">Printer Device Type</a></th>
              @OrderBy_Sort("JSCVLD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CVLD"  title="Sequence By Convert Line Data, Application ID, User, Workstation, Program Name, Printer File">Convert Line Data</a></th>
              @OrderBy_Sort("JSDGPR", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DGPR"  title="Sequence By Degree Of Page Rotation, Application ID, User, Workstation, Program Name, Printer File">Degree Of Page Rotation</a></th>
              @OrderBy_Sort("JSFROV", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FROV"  title="Sequence By Front Side Overlay, Application ID, User, Workstation, Program Name, Printer File">Front Side Overlay</a></th>
              @OrderBy_Sort("JSFRLB", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FRLB"  title="Sequence By Front Side Overlay Library, Application ID, User, Workstation, Program Name, Printer File">Front Side Overlay Library</a></th>
              @OrderBy_Sort("JSFRDW", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FRDW"  title="Sequence By Front Side Overlay Offset Down, Application ID, User, Workstation, Program Name, Printer File">Front Side Overlay Offset Down</a></th>
              @OrderBy_Sort("JSFRAC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FRAC"  title="Sequence By Front Side Overlay Offset Across, Application ID, User, Workstation, Program Name, Printer File">Front Side Overlay Offset Across</a></th>
              @OrderBy_Sort("JSBCOV", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BCOV"  title="Sequence By Back Side Overlay, Application ID, User, Workstation, Program Name, Printer File">Back Side Overlay</a></th>
              @OrderBy_Sort("JSBCLB", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BCLB"  title="Sequence By Back Side Overlay Library, Application ID, User, Workstation, Program Name, Printer File">Back Side Overlay Library</a></th>
              @OrderBy_Sort("JSBCDW", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BCDW"  title="Sequence By Back Side Overlay Offset Down, Application ID, User, Workstation, Program Name, Printer File">Back Side Overlay Offset Down</a></th>
              @OrderBy_Sort("JSBCAC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BCAC"  title="Sequence By Back Side Overlay Offset Across, Application ID, User, Workstation, Program Name, Printer File">Back Side Overlay Offset Across</a></th>
              @OrderBy_Sort("JSBCCB", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BCCB"  title="Sequence By Back Side Overlay Constant Back, Application ID, User, Workstation, Program Name, Printer File">Back Side Overlay Constant Back</a></th>
              @OrderBy_Sort("JSPGDF", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PGDF"  title="Sequence By Page Definition, Application ID, User, Workstation, Program Name, Printer File">Page Definition</a></th>
              @OrderBy_Sort("JSPGLB", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PGLB"  title="Sequence By Page Definition Library, Application ID, User, Workstation, Program Name, Printer File">Page Definition Library</a></th>
              @OrderBy_Sort("JSFMDF", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FMDF"  title="Sequence By Form Definition, Application ID, User, Workstation, Program Name, Printer File">Form Definition</a></th>
              @OrderBy_Sort("JSFMLB", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FMLB"  title="Sequence By Form Definition Library, Application ID, User, Workstation, Program Name, Printer File">Form Definition Library</a></th>
              @OrderBy_Sort("JSUOM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=UOM"  title="Sequence By Unit Of Measure, Application ID, User, Workstation, Program Name, Printer File">Unit Of Measure</a></th>
              @OrderBy_Sort("JSFRMD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FRMD"  title="Sequence By Front Margin Offset Down, Application ID, User, Workstation, Program Name, Printer File">Front Margin Offset Down</a></th>
              @OrderBy_Sort("JSFRMA", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FRMA"  title="Sequence By Front Margin Offset Across, Application ID, User, Workstation, Program Name, Printer File">Front Margin Offset Across</a></th>
              @OrderBy_Sort("JSBKMD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BKMD"  title="Sequence By Back Margin Offset Down, Application ID, User, Workstation, Program Name, Printer File">Back Margin Offset Down</a></th>
              @OrderBy_Sort("JSBKMA", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BKMA"  title="Sequence By Back Margin Offset Across, Application ID, User, Workstation, Program Name, Printer File">Back Margin Offset Across</a></th>
              @OrderBy_Sort("JSPRQL", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PRQL"  title="Sequence By Print Quality, Application ID, User, Workstation, Program Name, Printer File">Print Quality</a></th>
              @OrderBy_Sort("JSDFWR", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DFWR"  title="Sequence By Defer Write, Application ID, User, Workstation, Program Name, Printer File">Defer Write</a></th>
              @OrderBy_Sort("JSSPDT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SPDT"  title="Sequence By Spool The Data, Application ID, User, Workstation, Program Name, Printer File">Spool The Data</a></th>
              @OrderBy_Sort("JSREDC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=REDC"  title="Sequence By Reduce Output, Application ID, User, Workstation, Program Name, Printer File">Reduce Output</a></th>
              @OrderBy_Sort("JSPRSD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PRSD"  title="Sequence By Print On Both Sides, Application ID, User, Workstation, Program Name, Printer File">Print On Both Sides</a></th>
              @OrderBy_Sort("JSPGSD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PGSD"  title="Sequence By Pages Per Side, Application ID, User, Workstation, Program Name, Printer File">Pages Per Side</a></th>
              @OrderBy_Sort("JSSCDR", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SCDR"  title="Sequence By Source Drawer, Application ID, User, Workstation, Program Name, Printer File">Source Drawer</a></th>
              @OrderBy_Sort("JSOBIN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=OBIN"  title="Sequence By Output Bin, Application ID, User, Workstation, Program Name, Printer File">Output Bin</a></th>
              @OrderBy_Sort("JSFEED", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FEED"  title="Sequence By Form Feed, Application ID, User, Workstation, Program Name, Printer File">Form Feed</a></th>
              @OrderBy_Sort("JSCNRS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CNRS"  title="Sequence By Corner Staple, Application ID, User, Workstation, Program Name, Printer File">Corner Staple</a></th>
              @OrderBy_Sort("JSJUST", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=JUST"  title="Sequence By Hardware Justification, Application ID, User, Workstation, Program Name, Printer File">Hardware Justification</a></th>
              @OrderBy_Sort("JSRCL1", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RCL1"  title="Sequence By User Resource Library 1, Application ID, User, Workstation, Program Name, Printer File">User Resource Library 1</a></th>
              @OrderBy_Sort("JSRCL2", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RCL2"  title="Sequence By User Resource Library 2, Application ID, User, Workstation, Program Name, Printer File">User Resource Library 2</a></th>
              @OrderBy_Sort("JSRCL3", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RCL3"  title="Sequence By User Resource Library 3, Application ID, User, Workstation, Program Name, Printer File">User Resource Library 3</a></th>
              @OrderBy_Sort("JSRCL4", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RCL4"  title="Sequence By User Resource Library 4, Application ID, User, Workstation, Program Name, Printer File">User Resource Library 4</a></th>
              @OrderBy_Sort("JSERFE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ERFE"  title="Sequence By Edge Stitch: Reference Edge, Application ID, User, Workstation, Program Name, Printer File">Edge Stitch: Reference Edge </a></th>
              @OrderBy_Sort("JSERFO", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ERFO"  title="Sequence By Edge Stitch: Reference Edge Offset, Application ID, User, Workstation, Program Name, Printer File">Edge Stitch: Reference Edge Offset</a></th>
              @OrderBy_Sort("JSESTP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ESTP"  title="Sequence By Edge Stitch: Number Of Staples, Application ID, User, Workstation, Program Name, Printer File">Edge Stitch: Number Of Staples</a></th>
              @OrderBy_Sort("JSESO1", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ESO1"  title="Sequence By Edge Stitch: Staple Offset 1, Application ID, User, Workstation, Program Name, Printer File">Edge Stitch: Staple Offset 1</a></th>
              @OrderBy_Sort("JSESO2", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ESO2"  title="Sequence By Edge Stitch: Staple Offset 2, Application ID, User, Workstation, Program Name, Printer File">Edge Stitch: Staple Offset 2</a></th>
              @OrderBy_Sort("JSESO3", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ESO3"  title="Sequence By Edge Stitch: Staple Offset 3, Application ID, User, Workstation, Program Name, Printer File">Edge Stitch: Staple Offset 3</a></th>
              @OrderBy_Sort("JSESO4", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ESO4"  title="Sequence By Edge Stitch: Staple Offset 4, Application ID, User, Workstation, Program Name, Printer File">Edge Stitch: Staple Offset 4</a></th>
              @OrderBy_Sort("JSSRFE", sortVar)
