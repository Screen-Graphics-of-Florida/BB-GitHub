%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Company/Facility"
  d2wName                 = "CoFacSelect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;companyNumber=@dtw_rurlescseq(companyNumber)&amp;facilityNumber=@dtw_rurlescseq(facilityNumber)&amp;coFacName=@dtw_rurlescseq(coFacName)&amp;fromSel=Y"
  programName             = "HHDCFU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@coFacName", "@dtw_rurlescseq(coFacName)", "1", "a", workURL)
  @dtw_replace(workURL, "@@companyNumber", "@dtw_rurlescseq(companyNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@facilityNumber", "@dtw_rurlescseq(facilityNumber)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @CoFacUserView(profileHandle, dataBaseID, userPass, companyNumber, facilityNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
                  <!-- Start Of Trailer Code -->
                  %INCLUDE "banner.icl"
                  <!-- End Of Trailer Code -->
                          <table $(baseTable)>
                              <tr valign="top">
                                  %if (formatToPrint == "")
                                       @dtw_assign(pageID, "COFACSELECT")
                                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                                  %endif
                                  <td class="content">
                                      %INCLUDE "stmtSQLClear.icl"
                                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                      @dtw_concat(fileSQL, " HDCFAC ", fileSQL)
                                      @dtw_concat(selectSQL, "CFCO# = $(companyNumber) and CFFAC# = $(facilityNumber) ", selectSQL)
                                      %INCLUDE "stmtSQLSelect.icl"
                                      %INCLUDE "stmtSQLEnd.icl"
                                      @CoFacSelect_Query(profileHandle, dataBaseID, stmtSQL)
                                  </td>
                              </tr>
                          </table>
                  <!-- Start Of Trailer Code -->
                  %INCLUDE "trailer.icl"
                  <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) CoFacSelect_Query (IN  CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;fromD2w=")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (backHome != "$(d2wName)/report" && backHome != "")
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)" title="Back Home">$(portalHome)</a>
                      %endif
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)CoFacMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (sec_01=="Y" && sec_04=="Y")
                          <a href="$(homeURL)$(cGIPath)CoFacMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageLrg)</a>
                      %endif
                      %if (sec_02 == "Y" || sec_03 == "Y")
                          <a href="$(homeURL)$(cGIPath)CoFacMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageLrg)</a>
                      %endif
                      %if (sec_03 == "Y")
                          @Format_CoFac("$(companyNumber)", "$(facilityNumber)", "", F_CoFac)
                          @Format_Confirm_Desc($(coFacName), $(F_CoFac), "", "", "", "", confirmDesc)
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)CoFacMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      <table $(contentTable)>
          <colgroup>
              <col width="60%">
              <col width="20%">
	   		
          %ROW {
              @Format_CoFac("$(V_CFCO#)", "$(V_CFFAC#)", "", F_CoFac)
              @Format_Date(V_CFDTES, "H", F_CFDTES)
              @Format_Date(V_CFDTDE, "H", F_CFDTDE)
              <tr><td class="dspalph">$(V_CFCFNM)</td>
                  <td class="dsphdr">Company/Facility</td>
                  <td class="dspnmbr">$(F_CoFac)</td>
              </tr>

              <tr><td class="dspalph">$(V_CFTIN#)</td>
                  <td class="dsphdr">Date Established</td>
                  <td class="dspdate">$(F_CFDTES)</td>
              </tr>

              <tr><td class="dspalph"></td>
                  <td class="dsphdr">Date Deactivated</td>
                  <td class="dspdate">$(F_CFDTDE)</td>
              </tr>

              %if (V_HDMCRL > "0")
                  <tr><td class="dspalph"></td>
                      <td class="dsphdr">Currency Type</td>
                      <td class="dspalph">$(V_CFCURT)</td>
                  </tr>
              %endif
          %}
      </table>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}
