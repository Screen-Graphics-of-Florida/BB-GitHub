%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "QuickLink.icl"

%Define {
  page_title              = "Detail Point"
  d2wName                 = "WFDetailSelect.d2w"
  attachFolder            = "WorkFlowDetail"
  d2wVarBase              = "$(genericVarBase)&amp;wfProcess=@dtw_rurlescseq(wfProcess)&amp;passedWfPoint=@dtw_rurlescseq(passedWfPoint)&amp;passedWfSequence=@dtw_rurlescseq(passedWfSequence)"
  programName             = "HWFDTM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
  V_PRDESC                = ""	
  quickLinkByUser         = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_assign(backHome, "$(d2wName)/REPORT")
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          @RtvFldDesc("PRPROC='$(wfProcess)'", "WFPRHD", "PRDESC", V_PRDESC)
          @Format_Code(wfProcess, F_wfProcess)
          @dtw_assign(title, "$(V_PRDESC) $(F_wfProcess)")
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "WFDETAILSELECT")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif

                  <td class="content">

%{ QuickLink Table %}     %INCLUDE "QuickLinkTable.icl"

%{ QuickLink By User %}   %INCLUDE "QuickLinkByUser.icl"

%{ Heading %}
                      @dtw_assign(RPT_MAX_ROWS, "99")
                      @dtw_assign(dspMaxRows, "10")
                      @dtw_assign(wildCardSearch, "")  %{ No wildCardSearch %}
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select WFPRDT.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(PRDESC,' ') as PRDESC, coalesce(PRDESCU,' ') as PRDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " WFPRDT ", fileSQL)
                      @dtw_concat(fileSQL, " left join WFPRHD on PRPROC=PDPROC ", fileSQL)
                      @dtw_concat(selectSQL, " PDPROC='$(wfProcess)' and PDPONT=$(passedWfPoint) and PDSEQ=$(passedWfSequence)", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Select_Header(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Begin %}     %INCLUDE "QuickLinkBegLoop.icl"

    %{ Activity %}
                          %if (quicklinkRef == "activity")
                              %INCLUDE "QuickLinkClear.icl"
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, "Select WFPRDT.*,WFPRAC.*, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(FLDESC,' ') as FLDESC, upper(coalesce(FLDESC,' ')) as FLDESCU ", stmtSQL)
                              @dtw_concat(fileSQL, " WFPRDT ", fileSQL)
                              @dtw_concat(fileSQL, " inner join WFPRAC on ATPROC=PDPPRC and ATACTV=PDPACT ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYFLAG on FLTYPE='WFMODE' and FLVALU=ATMODE ", fileSQL)
                              @dtw_concat(selectSQL, " PDPROC='$(wfProcess)' and PDPONT=$(passedWfPoint) and PDSEQ=$(passedWfSequence)", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @Select_Activity(profileHandle, dataBaseID, stmtSQL)

    %{ Definition %}
                          %elif (quicklinkRef == "definition")
                              %INCLUDE "QuickLinkClear.icl"
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                              @dtw_concat(fileSQL, " WFPRDF", fileSQL)
                              @dtw_concat(selectSQL, " PPPROC='$(wfProcess)' and PPPONT=$(passedWfPoint) ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @Select_Definition(profileHandle, dataBaseID, stmtSQL)

    %{ Participant %}
                          %elif (quicklinkRef == "participant")
                              %INCLUDE "QuickLinkClear.icl"
                              @Retrieve_WebReg(userProfile, "", "WFParticipant.d2w", wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select WFPRPT.*, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(PDDESC,' ') as PDDESC, coalesce(PDDESCU,' ') as PDDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(PDRATE,0) as PDRATE, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(USDESC,PAPART) as USDESC, coalesce(USDESCU,PAPART) as USDESCU ", stmtSQL)
                              @dtw_concat(fileSQL, " WFPRPT ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFPRDT on PDPROC=PAPROC and PDPONT=PAPONT and PDSEQ=PASEQ ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYUSER on USUSER=PAPART ", fileSQL)
                              @dtw_concat(selectSQL, " PAPROC='$(wfProcess)' and PAPONT=$(passedWfPoint) and PASEQ=$(passedWfSequence) ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %if (orderBy == "")
                                  @dtw_assign(orderBy, "PAPONT, PASEQ")
                                  @dtw_assign(orderByDisplay, "Detail Point")
                              %endif
                              @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @Select_Participant(profileHandle, dataBaseID, stmtSQL)

    %{ Notification %}
                          %elif (quicklinkRef == "notification")
                              %INCLUDE "QuickLinkClear.icl"
                              @Retrieve_WebReg(userProfile, "", "WFNotification.d2w", wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select WFPRNF.*, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(a.PDDESC,' ') as a_PDDESC, coalesce(a.PDDESCU,' ') as a_PDDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(a.PDRATE,0) as PDRATE,  ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(USDESC,NFPART) as USDESC, coalesce(USDESCU,NFPART) as USDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(b.PDDESC,' ') as b_PDDESC, coalesce(b.PDDESCU,' ') as b_PDDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(c.FLDESC,' ') as c_FLDESC, upper(coalesce(c.FLDESC,' ')) as c_FLDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(MSDESC,' ') as MSDESC, coalesce(MSDESCU,' ') as MSDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(d.FLDESC,' ') as d_FLDESC, upper(coalesce(d.FLDESC,' ')) as d_FLDESCU ", stmtSQL)
                              @dtw_concat(fileSQL, " WFPRNF  ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFPRDT a on a.PDPROC=NFPROC and a.PDPONT=NFPONT and a.PDSEQ=NFSEQ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYUSER on USUSER=NFPART", fileSQL)
                              @dtw_concat(fileSQL, " left join WFPRDT b on b.PDPROC=NFPROC and b.PDPONT=NFNPNT and b.PDSEQ=NFNSEQ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYFLAG c on c.FLTYPE='WFINSTPART' and c.FLVALU=NFINPT ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFMSGT on MSMSID=NFMSID", fileSQL)
                              @dtw_concat(fileSQL, " left join SYFLAG d on d.FLTYPE='WFSEND' and d.FLVALU=NFSEND ", fileSQL)
                              @dtw_concat(selectSQL, " NFPROC='$(wfProcess)'  and NFPONT=$(passedWfPoint) and NFSEQ=$(passedWfSequence) ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %if (orderBy == "")
                                  @dtw_assign(orderBy, "NFPONT, NFSEQ")
                                  @dtw_assign(orderByDisplay, "Detail Point")
                              %endif
                              @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @Select_Notification(profileHandle, dataBaseID, stmtSQL)

    %{ Transitions Coming To This Detail Point  %}
                          %elif (quicklinkRef == "transitiontopoint")
                              %INCLUDE "QuickLinkClear.icl"
                              @dtw_assign(wildCardSearch, "")
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select WFPRTR.*, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(a.PDDESC,'(Any Previous Detail Point)') as PDDESC_FR, coalesce(a.PDDESCU,' ') as PDDESCU_FR, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(PDDESC,'(Any Previous Detail Point)') as PDDESC, coalesce(PDDESCU,' ') as PDDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(CMDESC,' ') as CMDESC, coalesce(CMDESCU,' ') as CMDESCU,  ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(VIDESC,' ') as VIDESC, coalesce(VIDESCU,' ') as VIDESCU  ", stmtSQL)
                              @dtw_concat(fileSQL, " WFPRTR ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFPRDT a on PDPROC=TRPROC and PDPONT=TRFPNT and PDSEQ=TRFSEQ ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFCNDM on CMCOND=TRCOND ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFVLID on VIVPGM=TRVPGM and VIVLID=TRVLID ", fileSQL)
                              @dtw_concat(selectSQL, " TRPROC='$(wfProcess)' and TRTPNT=$(passedWfPoint) and TRTSEQ=$(passedWfSequence) ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              @dtw_concat(stmtSQL, " Order By TRFAIL,TRFPNT,TRFSEQ,TRLEVL ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @To_Transition(profileHandle, dataBaseID, stmtSQL)

    %{ Transition Going From This Detail Point  %}
                          %elif (quicklinkRef == "transitionfrompoint")
                              %INCLUDE "QuickLinkClear.icl"
                              @dtw_assign(wildCardSearch, "")
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select WFPRTR.*, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(a.PDDESC,'(Any Previous Detail Point)') as PDDESC_FR, coalesce(a.PDDESCU,' ') as PDDESCU_FR, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(PDDESC,'(Any Previous Detail Point)') as PDDESC, coalesce(PDDESCU,' ') as PDDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(CMDESC,' ') as CMDESC, coalesce(CMDESCU,' ') as CMDESCU,  ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(VIDESC,' ') as VIDESC, coalesce(VIDESCU,' ') as VIDESCU  ", stmtSQL)
                              @dtw_concat(fileSQL, " WFPRTR ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFPRDT a on PDPROC=TRPROC and PDPONT=TRTPNT and PDSEQ=TRTSEQ ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFCNDM on CMCOND=TRCOND ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFVLID on VIVPGM=TRVPGM and VIVLID=TRVLID ", fileSQL)
                              @dtw_concat(selectSQL, " TRPROC='$(wfProcess)' and TRFPNT=$(passedWfPoint) and TRFSEQ=$(passedWfSequence) ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              @dtw_concat(stmtSQL, " Order By TRFAIL,TRLEVL,TRTPNT,TRTSEQ ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @From_Transition(profileHandle, dataBaseID, stmtSQL)
                          %endif


    %{ Attachments %}     %INCLUDE "AttachmentSQL.icl"

%{ Quicklink End %}       %INCLUDE "QuickLinkEndLoop.icl"

                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Select_Header (IN CHAR(64)    profileHandle,
                                     CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              @RtvFldDesc("PDPROC='$(wfProcess)' and PDPONT=$(passedWfPoint) and PDSEQ=$(passedWfSequence)", "WFPRDT", "PDDESC", V_PDDESC)
              @dtw_assign(attach_PDPONT, @dtw_rReplace(passedWfPoint, ".", "")) %while(@dtw_rlength(attach_PDPONT)<"7") {@dtw_insert("0", attach_PDPONT, attach_PDPONT)%}
              @dtw_assign(attach_PDSEQ,  @dtw_rReplace(passedWfSequence, ".", ""))  %while(@dtw_rlength(attach_PDSEQ)<"7")  {@dtw_insert("0", attach_PDSEQ, attach_PDSEQ)%}
              @dtw_assign(attachVarKey, "$(wfProcess)_$(attach_PDPONT)_$(attach_PDSEQ)")
              @dtw_assign(attachForDesc, V_PDDESC)
              @dtw_assign(attachPrg1, "WFPRDT Where (PDPROC,PDPONT,PDSEQ)=('$(wfProcess)',$(passedWfPoint),$(passedWfSequence)) ")
              %if (formatToPrint != "Y")
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;wfPoint=@dtw_rurlescseq(passedWfPoint)&amp;wfSequence=@dtw_rurlescseq(passedWfSequence)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
                  <td class="toolbar">
                      %INCLUDE "Attachment.icl"
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)WFDetailMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (sec_01=="Y" && sec_04=="Y")
                          <a href="$(homeURL)$(cGIPath)WFDetailMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromPoint=@dtw_rurlescseq(passedWfPoint)&amp;fromSequence=@dtw_rurlescseq(passedWfSequence)&amp;maintenanceCode=Z">$(copyImageLrg)</a>
                      %endif
                      %if (sec_02 == "Y" || sec_03 == "Y")
                          <a href="$(homeURL)$(cGIPath)WFDetailMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageLrg)</a>
                      %endif
                      %if (sec_03 == "Y")
                          @Format_Confirm_Desc($(V_PDDESC), "$(passedWfPoint)-$(passedWfSequence)", "", "", "", "", confirmDesc)
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)WFDetailMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      <table $(contentTable)>
          @RtvFldDesc("PRPROC='$(wfProcess)'", "WFPRHD", "PRDESC", V_PRDESC)
          @Format_Header_URL("Process", $(V_PRDESC), $(wfProcess), "$(homeURL)$(cGIPath)WFProcessSelect.d2w/REPORT$(d2wVarBase)")
      </table>

      $(hrTagAttr)

      %ROW{
          <table $(contentTable)>

              <tr><td class="dsphdr">Detail Point</td>
                  @Format_Code("$(V_PDPONT)-$(V_PDSEQ)", F_PDPONT)
                  <td class="dspalph">$(V_PDDESC) $(F_PDPONT)</td>
              </tr>

              @RtvFldDesc("PRPROC='$(V_PDPPRC)'", "WFPRHD", "PRDESC", V_PRDESC)
              <tr><td class="dsphdr">Detail Point Process</td>
                  @Format_Code(V_PDPPRC, F_PDPPRC)
                  <td class="dspalph">$(V_PRDESC) $(F_PDPPRC)</td>
              </tr>

              @RtvFldDesc("ATPROC='$(V_PDPPRC)' and ATACTV='$(V_PDPACT)'", "WFPRAC", "ATDESC", V_ATDESC)
              <tr><td class="dsphdr">Detail Point Activity</td>
                  @Format_Code(V_PDPACT, F_PDPACT)
                  <td class="dspalph">$(V_ATDESC) $(F_PDPACT)</td>
              </tr>

              <tr><td class="dsphdr">Complexity Rating</td>
                  <td class="dspnmbr">$(V_PDRATE)</td>
              </tr>
          </table>

          $(hrTagAttr)

          %INCLUDE "QuickLinkDisplay.icl"
      %}
  %}
%}

%FUNCTION(dtw_sql) Select_Activity (IN CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="activity"></a>
      @RtvFldDesc("PDPROC='$(wfProcess)' and PDPONT=$(passedWfPoint) and PDSEQ=$(passedWfSequence) ", "WFPRDT", "PDPPRC", V_PDPPRC)
      %if (V_PDPPRC != wfProcess)
          @dtw_assign(moreURL, "")
      %else
          @dtw_assign(moreURL, "$(homeURL)$(cGIPath)WFActivity.d2w/REPORT$(d2wVarBase)")
      %endif
      %INCLUDE "QuickLinkTopOfForm.icl"

      %if (sql_Record_Count == "0")
          <table $(contentTable)>
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          </table>
      %endif

      %ROW{
          <table $(contentTable)>
              <tr><td class="dsphdr">Activity</td>
                  @Format_Code(V_ATACTV, F_ATACTV)
                  <td class="dspalph">$(V_ATDESC) $(F_ATACTV)</td>
              </tr>

              @RtvFldDesc("FLTYPE='WFMODE' and FLVALU='$(V_ATMODE)'", "SYFLAG", "FLDESC", fieldDesc)
              <tr><td class="dsphdr">Start Mode</td>
                  @Format_Code(V_ATMODE, F_ATMODE)
                  <td class="dspalph">$(fieldDesc) $(F_ATMODE)</td>
              </tr>

              <tr><td class="dsphdr">Priority</td>
                  <td class="dspalph">$(V_ATPRTY)</td>
              </tr>
          </table>

          %if (V_ATMODE == "M")
              <table $(contentTable)>
                  <tr><td class="dsphdr">&nbsp;</td></tr>
                  <tr><td class="dsphdr">Manual:</td></tr>
              </table>

              <table $(contentTable)>
                  <tr><td class="dsphdr">Script To Process</td>
                      <td class="dspalph">$(V_ATD2W)</td>
                  </tr>
	      			
                  @RtvFldDesc("FLTYPE='BY' and FLVALU='$(V_ATDELG)'", "SYFLAG", "FLDESC", fieldDesc)
                  <tr><td class="dsphdr">Allow Delegation</td>
                      @Format_Code(V_ATDELG, F_ATDELG)
                      <td class="dspalph">$(fieldDesc) $(F_ATDELG)</td>
                  </tr>

                  @RtvFldDesc("FLTYPE='BY' and FLVALU='$(V_ATPRTA)'", "SYFLAG", "FLDESC", fieldDesc)
                  <tr><td class="dsphdr">All Participants Required</td>
                      @Format_Code(V_ATPRTA, F_ATPRTA)
                      <td class="dspalph">$(fieldDesc) $(F_ATPRTA)</td>
                  </tr>

                  <tr><td class="dsphdr">Number Of Participants Required</td>
                      <td class="dspalph">$(V_ATPRTR)</td>
                  </tr>

                  <tr><td class="dsphdr">Expiration Date</td>
                      @Format_Date(V_ATEXDT, "D", F_ATEXDT)
                      <td class="dspalph">$(F_ATEXDT)</td>
                  </tr>

                  <tr><td class="dsphdr">Expire In Number Of Days</td>
                      <td class="dspalph">$(V_ATEXDY)</td>
                  </tr>
              </table>

              <table $(contentTable)>
                  <tr><td class="dsphdr">Day Of The Month</td>
                      <td class="colhdr">From Day</td>
                      <td class="colhdr">Through Day</td>
                      <td class="colhdr">Expiration Day</td>
                      <td class="colhdr">Month Increment</td>
                  </tr>

                  <tr><td class="dsphdr">&nbsp;</td>
                      <td class="dspnmbr">$(V_ATFDY1)</td>
                      <td class="dspnmbr">$(V_ATTDY1)</td>
                      <td class="dspnmbr">$(V_ATDUE1)</td>
                      <td class="dspnmbr">$(V_ATINC1)</td>
                  </tr>

                  <tr><td class="dsphdr">&nbsp;</td>
                      <td class="dspnmbr">$(V_ATFDY2)</td>
                      <td class="dspnmbr">$(V_ATTDY2)</td>
                      <td class="dspnmbr">$(V_ATDUE2)</td>
                      <td class="dspnmbr">$(V_ATINC2)</td>
                  </tr>

                  <tr><td class="dsphdr">&nbsp;</td>
                      <td class="dspnmbr">$(V_ATFDY3)</td>
                      <td class="dspnmbr">$(V_ATTDY3)</td>
                      <td class="dspnmbr">$(V_ATDUE3)</td>
                      <td class="dspnmbr">$(V_ATINC3)</td>
                  </tr>

                  <tr><td class="dsphdr">&nbsp;</td>
                      <td class="dspnmbr">$(V_ATFDY4)</td>
                      <td class="dspnmbr">$(V_ATTDY4)</td>
                      <td class="dspnmbr">$(V_ATDUE4)</td>
                      <td class="dspnmbr">$(V_ATINC4)</td>
                  </tr>

                  <tr><td class="dsphdr">&nbsp;</td>
                      <td class="dspnmbr">$(V_ATFDY5)</td>
                      <td class="dspnmbr">$(V_ATTDY5)</td>
                      <td class="dspnmbr">$(V_ATDUE5)</td>
                      <td class="dspnmbr">$(V_ATINC5)</td>
                  </tr>
              </table>
          %endif

          %if (V_ATMODE == "A")
              <table $(contentTable)>
                  <tr><td class="dsphdr">&nbsp;</td></tr>
                  <tr><td class="dsphdr">Automatic:</td></tr>
              </table>

              <table $(contentTable)>
                  <tr><td class="dsphdr">&nbsp;</td>
                      <td class="colhdr">Program</td>
                      <td class="colhdr">Validation Program/ID</td>
                  </tr>

                  @RtvFldDesc("VIVPGM='$(V_ATPGMP)' and VIVLID=$(V_ATPGMV) ", "WFVLID", "VIDESC", fieldDesc)
                  @Format_Code("$(V_ATPGMP)-$(V_ATPGMV)", F_ATPGMV)
                  <tr><td class="dsphdr">Activity</td>
                      <td class="dspalph">$(V_ATPGM)</td>
                      <td class="dspalph">$(fieldDesc) $(F_ATPGMV)</td>
                  </tr>

                  @RtvFldDesc("VIVPGM='$(V_ATEX1P)' and VIVLID=$(V_ATEX1V) ", "WFVLID", "VIDESC", fieldDesc)
                  %if (V_ATEX1P != "")
                      @Format_Code("$(V_ATEX1P)-$(V_ATEX1V)", F_ATEX1V)
                  %else
                      @dtw_assign(F_ATEX1V, "")
                  %endif
                  <tr><td class="dsphdr">Exit Point Before</td>
                      <td class="dspalph">$(V_ATEX1)</td>
                      <td class="dspalph">$(fieldDesc) $(F_ATEX1V)</td>
                  </tr>

                  @RtvFldDesc("VIVPGM='$(V_ATEX2P)' and VIVLID=$(V_ATEX2V) ", "WFVLID", "VIDESC", fieldDesc)
                  %if (V_ATEX2P != "")
                      @Format_Code("$(V_ATEX2P)-$(V_ATEX2V)", F_ATEX2V)
                  %else
                      @dtw_assign(F_ATEX1V, "")
                  %endif
                  <tr><td class="dsphdr">Exit Point After</td>
                      <td class="dspalph">$(V_ATEX2)</td>
                      <td class="dspalph">$(fieldDesc) $(F_ATEX2V)</td>
                  </tr>
              </table>
          %endif
      %}
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Select_Definition (IN CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="definition"></a>
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)WFDefinition.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      %if (sql_Record_Count == "0")
          <table $(contentTable)>
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          </table>
      %endif

      %ROW{
          <table $(contentTable)>
              <tr><td class="dsphdr">Point</td>
                  @Format_Code(V_PPPONT, F_PPPONT)
                  <td class="dspalph">$(V_PPDESC) $(F_PPPONT)</td>
              </tr>

              @RtvFldDesc("FLTYPE='BY' and FLVALU='$(V_PPJOIN)'", "SYFLAG", "FLDESC", fieldDesc)
              <tr><td class="dsphdr"><span $(textOvr)>And Join</span></td>
                  @Format_Code(V_PPJOIN, F_PPJOIN)
                  <td class="dspalph">$(fieldDesc) $(F_PPJOIN)</td>
              </tr>
          </table>
      %}
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Select_Participant (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="participant"></a>
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)WFParticipant.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("PDRATE", "Detail Point<br>Complexity Rating")
                  @Format_Column_Header("USDESCU", "Participant")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"

              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_PDRATE)</td>
                  @RtvFldDesc("CUCUSR='$(V_PAPART)'", "SYCUSF", "Char(Count(*))", RecCount)
                  %if (RecCount>"0")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)CommonUserInquiry.d2w/REPORT$(d2wVarBase)&amp;commonUser=@dtw_rurlescseq(V_PAPART)&amp;complexityRating=@dtw_rurlescseq(V_PDRATE)" title="Common User Quickview" onclick="$(inquiryWinVar)">$(V_USDESC)</a></td>
                  %else
                      <td class="colalph" $(helpCursor)><span title="$(V_PAPART)">$(V_USDESC)</span></td>
                  %endif
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Select_Notification (IN CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="notification"></a>
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)WFNotification.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("PDRATE", "Detail Point<br>Complexity Rating")
                  @Format_Column_Header("USDESCU", "Participant")
                  @Format_Column_Header("c_FLDESCU", "Instance Participant")
                  @Format_Column_Header("b_PDDESCU", "Notify Detail Point")
                  @Format_Column_Header("MSDESCU", "Message ID")
                  @Format_Column_Header("MSDESCU", "Send Notification")
            </tr>
          %endif
          %ROW{
              %INCLUDE "SetRowClass.icl"

              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_PDRATE)</td>
                  @RtvFldDesc("CUCUSR='$(V_NFPART)'", "SYCUSF", "Char(Count(*))", RecCount)
                  %if (RecCount>"0")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)CommonUserInquiry.d2w/REPORT$(d2wVarBase)&amp;commonUser=@dtw_rurlescseq(V_NFPART)&amp;complexityRating=@dtw_rurlescseq(V_PDRATE)" title="Common User Quickview" onclick="$(inquiryWinVar)">$(V_USDESC)</a></td>
                  %else
                      <td class="colalph" $(helpCursor)><span title="$(V_NFPART)">$(V_USDESC)</span></td>
                  %endif
                  <td class="colalph" $(helpCursor)><span title="$(V_NFINPT)">$(V_c_FLDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_NFNPNT)-$(V_NFNSEQ)">$(V_b_PDDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_NFMSID)">$(V_MSDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_NFSEND)">$(V_d_FLDESC)</span></td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) To_Transition (IN CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="transitiontopoint"></a>
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)WFTransition.d2w/REPORT$(d2wVarBase)&amp;passedWFFromTo=T")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("PDDESCU", "From Detail Point Description")
                  @Format_Column_Header("TRFAIL", "Pass/<br>Fail")
                  @Format_Column_Header("TRLEVL", "And Split")
                  @Format_Column_Header("TROPT", "Opt")
                  @Format_Column_Header("CMDESCU", "Condition")
                  @Format_Column_Header("VIDESCU", "Validation")
                  @Format_Column_Header("TRFPNT", "From Detail Point")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @RtvFldDesc("FLTYPE='WFPASSFAIL' and FLVALU='$(V_TRFAIL)'", "SYFLAG", "FLDESC", failDesc)
              @RtvFldDesc("FLTYPE='WFOPTTRANS' and FLVALU='$(V_TROPT)'", "SYFLAG", "FLDESC", optDesc)
              <tr class="$(rowClass)">
                  <td class="colalph">$(V_PDDESC)</td>
                  <td class="colcode" $(helpCursor)><span title="$(failDesc)">$(V_TRFAIL)</span></td>
                  <td class="colalph">$(V_TRLEVL)</td>
                  <td class="colcode" $(helpCursor)><span title="$(optDesc)">$(V_TROPT)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_TRCOND)">$(V_CMDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_TRVPGM)-$(V_TRVLID)">$(V_VIDESC)</span></td>
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)WFDetailSelect.d2w/REPORT$(d2wVarBase)&amp;overridePoint=@dtw_rurlescseq(V_TRFPNT)&amp;overrideSequence=@dtw_rurlescseq(V_TRFSEQ)" title="View Detail Point">$(V_TRFPNT)-$(V_TRFSEQ)</a></td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) From_Transition (IN CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="transitionfrompoint"></a>
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)WFTransition.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("TRFAIL", "Pass/<br>Fail")
                  @Format_Column_Header("TRLEVL", "And Split")
                  @Format_Column_Header("TROPT", "Opt")
                  @Format_Column_Header("PDDESCU", "To Detail Point Description")
                  @Format_Column_Header("CMDESCU", "Condition")
                  @Format_Column_Header("VIDESCU", "Validation")
                  @Format_Column_Header("TRTPNT", "To Detail Point")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @RtvFldDesc("FLTYPE='WFPASSFAIL' and FLVALU='$(V_TRFAIL)'", "SYFLAG", "FLDESC", failDesc)
              @RtvFldDesc("FLTYPE='WFOPTTRANS' and FLVALU='$(V_TROPT)'", "SYFLAG", "FLDESC", optDesc)
              <tr class="$(rowClass)">
                  <td class="colcode" $(helpCursor)><span title="$(failDesc)">$(V_TRFAIL)</span></td>
                  <td class="colalph">$(V_TRLEVL)</td>
                  <td class="colcode" $(helpCursor)><span title="$(optDesc)">$(V_TROPT)</span></td>
                  <td class="colalph">$(V_PDDESC)</td>
                  <td class="colalph" $(helpCursor)><span title="$(V_TRCOND)">$(V_CMDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_TRVPGM)-$(V_TRVLID)">$(V_VIDESC)</span></td>
                  %if (V_TRTPNT>"0")
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)WFDetailSelect.d2w/REPORT$(d2wVarBase)&amp;overridePoint=@dtw_rurlescseq(V_TRTPNT)&amp;overrideSequence=@dtw_rurlescseq(V_TRTSEQ)" title="View Detail Point">$(V_TRTPNT)-$(V_TRTSEQ)</a></td>
                  %else
                      <td class="colnmbr">&nbsp;</td>
                  %endif
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%INCLUDE "AttachmentSelect.icl"

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %if (overridePoint>"0")
      @dtw_assign(passedWfPoint, overridePoint)
  %endif
  %if (overrideSequence>"0")
      @dtw_assign(passedWfSequence, overrideSequence)
  %endif
  @Set_SQL(stmtSQL)
%}