%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Payment Type Maintenance"
  d2wName                 = "PaymentTypeMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;paymentType=@dtw_rurlescseq(paymentType)&amp;paymentTypeDesc=@dtw_rurlescseq(paymentTypeDesc)&amp;maintenanceCode=D"
  programName             = "HOEPYM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.paymentType.value =="" ||
                      document.Chg.paymentTypeDesc.value =="")
                         {alert("$(reqFieldError)"); return false;}
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PAYMENTTYPEMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From OEPYMT Where OMPC='$(paymentType)'", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=110")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" NAME="Chg" METHOD=POST ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "paymentType")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@pc@@", "paymentType")          @dtw_assign(Err_OMPC, fieldValue)
                          @DecatErr_Field("@@pd@@", "paymentTypeDesc")      @dtw_assign(Err_OMPD, fieldValue)
                          @DecatErr_Field("@@sbcd", "paymentSubCode")       @dtw_assign(Err_OMSBCD, fieldValue)
                      %endif

                      @Decat_Field("@@pc@@")   @dtw_assign(V_OMPC, fieldValue)
                      @Decat_Field("@@pd@@")   @dtw_assign(V_OMPD, fieldValue)
                      @Decat_Field("@@sbcd")   @dtw_assign(V_OMSBCD, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "paymentType")
                      %endif
                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_OMPC, "")
                      @dtw_assign(focusField, "paymentType")
                  %else
                      @dtw_assign(focusField, "paymentTypeDesc")
                  %endif

                  @SetTextOvr(Err_OMPC)
                  <tr><td class="dsphdr"><span $(textOvr)>Payment Type</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="paymentType" type="text" value="$(V_OMPC)" size="3" maxlength="1"> $(reqFieldChar) </td>
                      %else
                          <td class="inputalph"><input name="paymentType" type="hidden" value="$(V_OMPC)">$(V_OMPC)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_OMPC)

                  @SetTextOvr(Err_OMPD)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="paymentTypeDesc" type="text" value="$(V_OMPD)" size="30" maxlength="20"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_OMPD)

                  %if (V_HDARRL > "0")
                      @RtvFldDesc("PSSBCD='$(V_OMSBCD)'", "ARPYSB", "PSDESC", fldDesc)
                      @SetTextOvr(Err_OMSBCD)
                      <tr><td class="dsphdr"><span $(textOvr)>Payment Sub Code</span></td>
                          <td class="inputnmbr"><input name="paymentSubCode" value="$(V_OMSBCD)" type="text" size="4" maxlength="4">
                                                <a href="$(homeURL)$(phpPath)ARPmtSubCodeSearch.php$(altVarBase)&amp;docName=Chg&amp;specificPmtType=C&amp;fldName=paymentSubCode&amp;fldDesc=paySubDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                                                <input disabled name="paySubDesc" value="$(fldDesc)"  type="text" size="35"></td>

                      </tr>
                      @DspErrMsg(Err_OMSBCD)
                  %endif
              %}
          </table>
	
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HOEPYM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(paymentType)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@pc@@", paymentType)
  @Concat_Field("@@pd@@", paymentTypeDesc)
  %if (V_HDARRL > "0")
      @dtw_mUPPERCASE(paymentSubCode)
      @Concat_Field("@@sbcd", paymentSubCode)
  %endif
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(paymentTypeDesc), $(paymentType), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@pc@@", "paymentType")
          @Format_ConfMsg_Desc("", $(paymentTypeDesc), $(paymentType), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=110&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;paymentType=@dtw_rurlescseq(paymentType)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
