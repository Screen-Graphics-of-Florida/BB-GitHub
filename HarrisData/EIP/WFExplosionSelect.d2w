%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Explosion Of Process"
  d2wName                 = "WFExplosionSelect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfProcess=@dtw_rurlescseq(wfProcess)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
  dspMaxRows              = "$(dspMaxRowsDft)"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %{Process Header %}
                      @dtw_assign(START_ROW_NUM, "1")
                      @dtw_assign(RPT_MAX_ROWS, "9999")
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "SELECT * ", stmtSQL)
                      @dtw_concat(fileSQL, " WFPRHD ", fileSQL)
                      @dtw_concat(selectSQL, " PRPROC='$(wfProcess)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      @List_Process_Query(profileHandle, dataBaseID, stmtSQL)

                      %{Definition  %}
                      @RtvFldDesc("PPPROC='$(wfProcess)'", "WFPRDF", "Char(Count(*))", RecCount)
                      %if (RecCount>")")
                          @dtw_assign(START_ROW_NUM, "1")
                          @dtw_assign(RPT_MAX_ROWS, "9999")
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, "SELECT WFPRDF.*,WFPRDT.* ", stmtSQL)
                          @dtw_concat(fileSQL, " WFPRDF ", fileSQL)
                          @dtw_concat(fileSQL, " left join WFPRDT on PDPROC=PPPROC and PDPONT=PPPONT ", fileSQL)
                          @dtw_concat(selectSQL, " PPPROC='$(wfProcess)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " order by PPPROC,PPPONT,PDSEQ  ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @List_Point_Query(profileHandle, dataBaseID, stmtSQL)
                      %endif

                      $(inquiryhrTagAttr)
                      %INCLUDE "CloseWindow.icl"
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) List_Process_Query (IN  CHAR(64) profileHandle,
                                          CHAR(2)   dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(displayCloseIcon, "Y")
      %INCLUDE "PageTitle.icl"
      $(inquiryhrTagAttr)

      <table $(contentTable)>
          %ROW{
              <tr><td class="dsphdr">Process</td>
                  @Format_Code(V_PRPROC, F_PRPROC)
                  <td class="dspalph">$(V_PRDESC) $(F_PRPROC)</td>
              </tr>

              @RtvFldDesc("USUSER='$(V_PRPART)'", "SYUSER", "USDESC", V_USDESC)
              <tr><td class="dsphdr">Participant In Charge</td>
                  @Format_Code(V_PRPART, F_PRPART)
                  <td class="dspalph">$(V_USDESC) $(F_PRPART)</td>
              </tr>

              @RtvFldDesc("PDPROC='$(wfProcess)' and PDPONT=$(V_PRPSPT) and PDSEQ=$(V_PRPSSQ)", "WFPRDT", "PDDESC", V_PDDESC)
              <tr><td class="dsphdr">Completion Detail Point</td>
                  @Format_Code("$(V_PRPSPT)-$(V_PRPSSQ)", F_PRPSPT)
                  <td class="dspalph">$(V_PDDESC) $(F_PRPSPT)</td>
              </tr>

              @RtvFldDesc("VIVPGM='$(V_PRMXVP)' and VIVLID=$(V_PRMXVL)", "WFVLID", "VIDESC", V_VIDESC)
              @RtvFldDesc("PDPROC='$(wfProcess)' and PDPONT=$(V_PRMXPT) and PDSEQ=$(V_PRMXSQ) ", "WFPRDT", "PDDESC", V_PDDESC)
              <tr><td class="dsphdr">Maximum Work Item</td>
                  @Format_Code(V_PRMXVL, F_PRMXVL)
                  @Format_Code("$(V_PRMXPT)-$(V_PRMXSQ)", F_PRMXPT)
                  <td class="dspalph">$(V_VIDESC) $(F_PRMXVL) $(V_PDDESC) $(F_PRMXPT)</td>
              </tr>
          %}
      </table>
  %}
%}

%FUNCTION(dtw_sql) List_Point_Query (IN  CHAR(64) profileHandle,
                                         CHAR(2)   dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <tr>
              <th class="colhdr"><a href="$(homeURL)$(cGIPath)WFDefinition.d2w/REPORT$(d2wVarBase)" title="More Information">Point</a></th>
              <th class="colhdr"><a href="$(homeURL)$(cGIPath)WFDetail.d2w/REPORT$(d2wVarBase)" title="More Information">Detail Point</a></th>
              <th class="colhdr"><a href="$(homeURL)$(cGIPath)WFParticipant.d2w/REPORT$(d2wVarBase)" title="More Information">Participant</a></th>
              <th class="colhdr"><a href="$(homeURL)$(cGIPath)WFNotification.d2w/REPORT$(d2wVarBase)" title="More Information">Notification</a></th>
              <th class="colhdr"><a href="$(homeURL)$(cGIPath)WFTransition.d2w/REPORT$(d2wVarBase)" title="More Information">Transition</a></th>
          </tr>

          @dtw_assign(Check_PPPONT, "")
          @dtw_assign(Check_PDSEQ, "")

          %ROW{

              %if (V_PPPONT!=Check_PPPONT)
                  @dtw_assign(Check_PPPONT, V_PPPONT)
                  @dtw_assign(Check_PDSEQ, "")
                  @Format_Code(V_PPPONT, F_PPPONT)
                  @dtw_assign(F_Point, "$(V_PPDESC) $(F_PPPONT)")
              %else
                  @dtw_assign(F_Point, "&nbsp;")
              %endif

              %if (V_PDSEQ!=Check_PDSEQ || Check_PDSEQ=="")
                  @dtw_assign(Check_PDSEQ, V_PDSEQ)
                  @Format_Code(V_PDSEQ, F_PDSEQ)
                  %if (V_PDDESC!="")
                      @dtw_assign(F_DetailPoint, "$(V_PDDESC) $(F_PDSEQ)")
                  %else
                      @dtw_assign(F_DetailPoint, F_PDSEQ)
                  %endif
                  <tr><td class="colalph" colspan="5">$(inquiryhrTagAttr)</td></tr>
              %else
                  @dtw_assign(F_DetailPoint, "&nbsp;")
              %endif

              <tr valign="top">
                  <td class="colalph">$(F_Point)</td>
                  <td class="colalph">$(F_DetailPoint)</td>

                  %{Participants %}
                  <td class="colalph">
                      @dtw_assign(START_ROW_NUM, "1")
                      @dtw_assign(RPT_MAX_ROWS, "9999")
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select WFPRPT.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(PDRATE,0) as PDRATE,  ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(USDESC,PAPART) as USDESC, coalesce(USDESCU,PAPART) as USDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " WFPRPT  ", fileSQL)
                      @dtw_concat(fileSQL, " left join WFPRDT on PDPROC=PAPROC and PDPONT=PAPONT and PDSEQ=PASEQ ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYUSER on USUSER=PAPART", fileSQL)
                      @dtw_concat(selectSQL, " PAPROC='$(wfProcess)' and PAPONT=$(V_PPPONT) and PASEQ=$(V_PDSEQ) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " order by PAPROC,PAPONT,USDESCU ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @List_Participant_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>

                  %{Notifications %}
                  <td class="colalph">
                      @dtw_assign(START_ROW_NUM, "1")
                      @dtw_assign(RPT_MAX_ROWS, "9999")
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select WFPRNF.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(PDRATE,0) as PDRATE,  ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(USDESC,NFPART) as USDESC, coalesce(USDESCU,NFPART) as USDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(MSDESC,' ') as MSDESC, coalesce(MSDESCU,' ') as MSDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " WFPRNF  ", fileSQL)
                      @dtw_concat(fileSQL, " left join WFPRDT on PDPROC=NFPROC and PDPONT=NFPONT and PDSEQ=NFSEQ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYUSER on USUSER=NFPART", fileSQL)
                      @dtw_concat(fileSQL, " left join WFMSGT on MSMSID=NFMSID", fileSQL)
                      @dtw_concat(selectSQL, " NFPROC='$(wfProcess)' and NFPONT=$(V_PPPONT) and NFSEQ=$(V_PDSEQ) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " order by NFPROC,NFPONT,USDESCU ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @List_Notification_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>

                  %{Transitions %}
                  <td class="colalph">
                      @DateTodayCYMD(systemDate)

                      @dtw_assign(START_ROW_NUM, "1")
                      @dtw_assign(RPT_MAX_ROWS, "9999")
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "SELECT WFPRTR.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(CMDESC,' ') as CMDESC,  ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(VIDESC,' ') as VIDESC  ", stmtSQL)
                      @dtw_concat(fileSQL, " WFPRTR ", fileSQL)
                      @dtw_concat(fileSQL, " left join WFCNDM on CMCOND=TRCOND ", fileSQL)
                      @dtw_concat(fileSQL, " left join WFVLID on VIVPGM=TRVPGM and VIVLID=TRVLID ", fileSQL)
                      @dtw_concat(selectSQL, " TRPROC='$(wfProcess)' and TRFPNT=$(V_PPPONT) and TRFSEQ=$(V_PDSEQ) and (TRETDT=0 or TRETDT>=$(systemDate)) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " order by TRPROC,TRFPNT,TRFSEQ,TRFAIL desc,TRLEVL ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @List_Transition_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          %}
      </table>
  %}
%}

%FUNCTION(dtw_sql) List_Transition_Query (IN  CHAR(64) profileHandle,
                                          CHAR(2)   dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(Check_TRLEVL, "First")

      <table $(contentTable)>
          %ROW{
              %if (V_TRLEVL!=Check_TRLEVL)
                  %if (Check_TRLEVL!="First")
                      <tr><td class="colalph">$(inquiryhrTagAttr)</td></tr>
                  %endif
                  @dtw_assign(Check_TRLEVL, V_TRLEVL)
              %endif

              %if (V_TRCOND!="0")
                  @dtw_assign(F_Condition, "when $(V_CMDESC)")
              %elif (V_TRVLID!="0")
                  @dtw_assign(F_Condition, "when $(V_VIDESC)")
              %else
                  @dtw_assign(F_Condition, "")
              %endif
              %if (V_TRFAIL=="P")
                  @dtw_assign(F_TRFAIL, "Pass")
              %else
                  @dtw_assign(F_TRFAIL, "Fail")
              %endif

              @dtw_assign(F_TREFDT, "")
              %if (V_TREFDT>"0")
                  @Format_Date(V_TREFDT, "D", F_TREFDT)
                  @dtw_assign(F_TREFDT, "Starting $(F_TREFDT) ")
              %endif
              %if (V_TRETDT>"0")
                  @Format_Date(V_TRETDT, "D", F_TRETDT)
                  @dtw_assign(F_TREFDT, "$(F_TREFDT) Ending $(F_TRETDT) ")
              %endif
              @RtvFldDesc("PDPROC='$(wfProcess)' and PDPONT=$(V_TRTPNT) and PDSEQ=$(V_TRTSEQ) ", "WFPRDT", "PDDESC", V_PDDESC)
              @Format_Code("$(V_TRTPNT)-$(V_TRTSEQ)", F_TRTPNT)
              %if (V_TROPT=="O" && V_TRTPNT<="0")
                  <tr><td class="colalph">If $(F_TRFAIL), optionally go to any previous detail point $(V_PDDESC) $(F_TRTPNT) $(F_Condition) $(F_TREFDT)</td></tr>
              %elif (V_TROPT=="O")
                  <tr><td class="colalph">If $(F_TRFAIL), optionally go to $(V_PDDESC) $(F_TRTPNT) $(F_Condition) $(F_TREFDT)</td></tr>
              %else
                  <tr><td class="colalph">If $(F_TRFAIL), go to $(V_PDDESC) $(F_TRTPNT) $(F_Condition) $(F_TREFDT)</td></tr>
              %endif
          %}
      </table>
  %}
%}

%FUNCTION(dtw_sql) List_Participant_Query (IN  CHAR(64) profileHandle,
                                               CHAR(2)   dataBaseID,
                                               CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          %ROW{
              <tr>
                  @RtvFldDesc("CUCUSR='$(V_PAPART)'", "SYCUSF", "Char(Count(*))", RecCount)
                  %if (RecCount>"0")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)CommonUserInquiry.d2w/REPORT$(d2wVarBase)&amp;commonUser=@dtw_rurlescseq(V_PAPART)&amp;complexityRating=@dtw_rurlescseq(V_PDRATE)" title="Common User Quickview" onclick="$(inquiryWinVar)">$(V_USDESC)</a></td>
                  %else
                      <td class="colalph" $(helpCursor)><span title="$(V_PAPART)">$(V_USDESC)</span></td>
                  %endif
              </tr>
          %}
      </table>
  %}
%}

%FUNCTION(dtw_sql) List_Notification_Query (IN  CHAR(64) profileHandle,
                                                CHAR(2)   dataBaseID,
                                                CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          %ROW{
              %if (V_NFPART!="")
                  <tr>
                      @RtvFldDesc("CUCUSR='$(V_NFPART)'", "SYCUSF", "Char(Count(*))", RecCount)
                      %if (RecCount>"0")
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)CommonUserInquiry.d2w/REPORT$(d2wVarBase)&amp;commonUser=@dtw_rurlescseq(V_NFPART)&amp;complexityRating=@dtw_rurlescseq(V_PDRATE)" title="Common User Quickview" onclick="$(inquiryWinVar)">$(V_USDESC)</a> gets a message for $(V_MSDESC)</td>
                      %else
                          <td class="colalph"><span $(helpCursor) title="$(V_NFPART)">$(V_USDESC)</span> gets a message for $(V_MSDESC)</td>
                      %endif
                  </tr>
              %endif
              %if (V_NFINPT!="")
                  <tr>
                      @RtvFldDesc("FLTYPE='WFINSTPART' and FLVALU='$(V_NFINPT)'", "SYFLAG", "FLDESC", V_FLDESC)
                      <td class="colalph"><span $(helpCursor) title="$(V_NFINPT)">$(V_FLDESC)</span> gets a message for $(V_MSDESC)</td>
                  </tr>
              %endif
              %if (V_NFNPNT>"0" || V_NFNSEQ>"0")
                  <tr>
                      @RtvFldDesc("PDPROC='$(wfProcess)' and PDPONT=$(V_NFNPNT) and PDSEQ=$(V_NFNSEQ) ", "WFPRDT", "PDDESC", V_PDDESC)
                      <td class="colalph"><span $(helpCursor) title="$(V_NFNPNT)-$(V_NFNSEQ)">$(V_PDDESC)</span> gets a message for $(V_MSDESC)</td>
                  </tr>
              %endif
          %}
      </table>
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}