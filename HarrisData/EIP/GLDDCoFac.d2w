%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "G/L Drill Down Company/Facilities"
  d2wName                 = "GLDDCoFac.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;ddReport=@dtw_rurlescseq(ddReport)&amp;ddDescr=@dtw_rurlescseq(ddDescr)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchCo, 2, 0) &&
                      editNum(document.Search.srchFac, 4, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "GLDDCOFAC")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      @dtw_assign(uv_CompanyName, "DHCO")
                      @dtw_assign(uv_FacilityName, "DHFAC")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "SELECT DHGRSN, DHCO, DHFAC, DHCFNM, DHDTDE, DHCFCN, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(DHCFNM) as DHCFNMU " , stmtSQL)
                      @dtw_concat(fileSQL, " GLDDHD ", fileSQL)
                      @dtw_concat(selectSQL, " DHGRSN ='$(ddReport)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64) profileHandle,
                                   CHAR(2)   dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(ddDescr)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      <a href="$(homeURL)$(cGIPath)$(d2wName)/ENTRY$(d2wVarBase)&amp;formatToPrint=Y" target=_blank>$(formatPrintDesc)</a>
                  </td>
              %endif
          </tr>
      </table>

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST name="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Name</th>
                      <th class="colhdr">Co</th>
                      <th class="colhdr">Fac</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchName" size="30" maxlength="30">
                          <input type="hidden" name="operName" value="LIKE">
                      </td>
                      <td><input type="text" class="inputnmbr" name="srchCo" size="2" maxlength="2">
                          <input type="hidden" name="operCo" value="=">
                      </td>
                      <td><input type="text" class="inputnmbr" name="srchFac" size="4" maxlength="4">
                          <input type="hidden" name="operFac" value="=">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchName.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              @OrderBy_Sort("DHCO", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Co" title="Sequence By Company, Facility"> Co</a></th>
              @OrderBy_Sort("DHFAC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Fac" title="Sequence By Facility, Company"> Fac</a></th>
              @OrderBy_Sort("DHCFNMU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Name" title="Sequence By Name, Company, Facility"> Name</a></th>
              @OrderBy_Sort("DHDTDE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DateDeactivated" title="Sequence By Date Deactivated, Company, Facility"> Date<br>Deactivated</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"

              @Format_Date(V_DHDTDE, "D", F_DHDTDE)

              <tr class="$(rowClass)">
                  %if (V_DHCFCN == "Y")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)GLCoFacConsolidation.d2w/ENTRY$(genericVarBase)&amp;companyNumber=@dtw_rurlescseq(V_DHCO)&amp;facilityNumber=@dtw_rurlescseq(V_DHFAC)&amp;coFacName=@dtw_rurlescseq(V_DHCFNM)" onclick="$(drillDownWinVar)" title="View Company/Facility Consolidation">$(V_DHCO)</a></td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)GLCoFacConsolidation.d2w/ENTRY$(genericVarBase)&amp;companyNumber=@dtw_rurlescseq(V_DHCO)&amp;facilityNumber=@dtw_rurlescseq(V_DHFAC)&amp;coFacName=@dtw_rurlescseq(V_DHCFNM)" onclick="$(drillDownWinVar)" title="View Company/Facility Consolidation">$(V_DHFAC)</a></td>
                  %else
                      <td class="colalph">$(V_DHCO)</td>
                      <td class="colalph">$(V_DHFAC)</td>
                  %endif
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)GLDDReport.d2w/REPORT$(genericVarBase)&amp;ddReport=@dtw_rurlescseq(ddReport)&amp;ddDescr=@dtw_rurlescseq(ddDescr)&amp;ddCompany=@dtw_rurlescseq(V_DHCO)&amp;ddFacility=@dtw_rurlescseq(V_DHFAC)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))" title="View Drill Down Report" target="_blank">$(V_DHCFNM)</a></td>
                  <td class="coldate">$(F_DHDTDE)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint == "Y")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "DHCFNMU,DHCO,DHFAC")
          @DTW_ASSIGN(orderByDisplay, "Name, Company, Facility")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Co")
      %if (orderBy == "DHCO,DHFAC")
          @DTW_ASSIGN(orderBy, "DHCO DESC,DHFAC DESC")
          @DTW_ASSIGN(orderByDisplay, "Company (descending), Facility (descending)")
      %else
          @DTW_ASSIGN(orderBy, "DHCO,DHFAC")
          @DTW_ASSIGN(orderByDisplay, "Company, Facility")
      %endif
  %elif (sequence == "Fac")
      %if (orderBy == "DHFAC,DHCO")
          @DTW_ASSIGN(orderBy, "DHFAC DESC,DHCO DESC")
          @DTW_ASSIGN(orderByDisplay, "Facility (descending), Company (descending)")
      %else
          @DTW_ASSIGN(orderBy, "DHFAC,DHCO")
          @DTW_ASSIGN(orderByDisplay, "Facility, Company")
      %endif
  %elif (sequence == "Name")
      %if (orderBy == "DHCFNMU,DHCO,DHFAC")
          @DTW_ASSIGN(orderBy, "DHCFNMU DESC,DHCO,DHFAC")
          @DTW_ASSIGN(orderByDisplay, "Name (descending), Company, Facility")
      %else
          @DTW_ASSIGN(orderBy, "DHCFNMU,DHCO,DHFAC")
          @DTW_ASSIGN(orderByDisplay, "Name, Company, Facility")
      %endif
  %elif (sequence == "DateDeactivated")
      %if (orderBy == "DHDTDE,DHCO,DHFAC")
          @DTW_ASSIGN(orderBy, "DHDTDE DESC,DHCO,DHFAC")
          @DTW_ASSIGN(orderByDisplay, "Date Deactivated (descending), Company, Facility")
      %else
          @DTW_ASSIGN(orderBy, "DHDTDE,DHCO,DHFAC")
          @DTW_ASSIGN(orderByDisplay, "Date Deactivated, Company, Facility")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchCo, 2, 0) &&
                      editNum(document.Search.srchFac, 4, 0) &&
                      editdate(document.Search.srchDate))
                      return true;
              }

          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "GLDDCOFACSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(page_title, $(ddDescr))
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Name</td>
                              @dtw_assign(operNbr, "operName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchName" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Wildcard Company</td>
                              @dtw_assign(operNbr, "operAlphCo")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchAlphaCo" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Wildcard Facility</td>
                              @dtw_assign(operNbr, "operAlphFac")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchAlphaFac" size="4" maxlength="4"></td></tr>	

                          <tr><td class="dsphdr">Company</td>
                              @dtw_assign(operNbr, "operCo")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchCo" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Facility</td>
                              @dtw_assign(operNbr, "operFac")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchFac" size="4" maxlength="4"></td></tr>	

                          @dtw_assign(operNbr, "operDate")
                          <tr><td class="dsphdr">Date Deactivated</td>
                              @dtw_assign(operNbr, "operDeactivated")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchDate" size="6" maxlength="6"> <a href="javascript:calWindow('srchDate');">$(calendarImage)</a></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchName.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("upper(DHCFNM)", "Name", $(srchName), "U", $(operName), "A")
  @Build_WildCard ("DHCO", "Company", $(srchCo), "", $(operCo), "N")
  @Build_WildCard ("DHFAC", "Facility", $(srchFac), "", $(operFac), "N")
  @Build_WildCard ("DHACO", "Wildcard Company", $(srchAlphaCo), "U", $(operAlphCo), "A")
  @Build_WildCard ("DHAFAC", "Wildcard Facility", $(srchAlphaFac), "U", $(operAlphFac), "A")
  @Build_WildCard ("DHDTDE", "Deactivated Date", $(srchDate), "", $(operDeactivated), "D")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
