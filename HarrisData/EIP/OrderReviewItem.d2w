%INCLUDE "$(baseVar)"
%INCLUDE "BrowserType.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Order Review"
  d2wName                 = "OrderReviewItem.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;orderType=@dtw_rurlescseq(orderType)&amp;orderTypeDesc=@dtw_rurlescseq(orderTypeDesc)"
  currentURL              = "$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)"
  programName             = "HOEWRT"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
  commentTable            = %table
  documentType            = "INT"
  header                  = "H"
  shipTo                  = ""
  shipToName              = ""
  blankItem               = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "OrderEntryProgOpt.icl"
          <script TYPE="text/javascript">
              %INCLUDE "AJAXRequest.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "SaveCurrentURL.icl"
              %INCLUDE "NewWindowOpen.icl"
              %INCLUDE "OrderEntryConfirm.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                          @dtw_assign(pageID, "ORDERREVIEW")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " OEHDWK ", fileSQL)
                          @dtw_concat(selectSQL, " H1OCTL=$(orderControlNumber) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @OrderHeader_Query(profileHandle, dataBaseID, stmtSQL)

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select OEDTWK.*, coalesce(IMITEM,' ') as IMITEM, coalesce(SPPART,O1IMDS) as SPPART ", stmtSQL)
                          @dtw_concat(fileSQL, " OEDTWK left join HDIMST on O1ITEM=IMITEM ", fileSQL)
                          @dtw_concat(fileSQL, "        left join OESPWK on O1OCTL=SPOCTL and O1ORL#=SPORL# ", fileSQL)
                          @dtw_concat(selectSQL, " O1OCTL=$(orderControlNumber) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By O1OCTL,O1ORL#,O1BLN# ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @OrderDetail_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) OrderHeader_Query (IN CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "OrderEntryRetInfo.icl"
      <table $(contentTable)>
          <colgroup>
              <col width="20%">
              <col width="10%">
              <col width="15%">
              <col width="10%">
              <col width="15%">
              <col width="25%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="hdrtitl">Order Number:</td>
              <td class="hdrdata"><a onClick="saveCurrentURL();" href="$(homeURL)$(cGIPath)OrderEntryOrderReview.d2w/DISPLAY$(d2wVarBase)&amp;customerNumber=@dtw_rurlescseq(H1SHTO)&amp;customerName=@dtw_rurlescseq(shipToName)&amp;orderControlNumber=@dtw_rurlescseq(V_H1OCTL)" title="View Order Detail">$(orderNumber)</a></td>
              <td class="hdrtitl">Order Type:</td>
              @Format_Code(H1ORTY, F_H1ORTY)
              <td class="hdrdata"><a href="$(homeURL)$(cGIPath)OrderEntryOrderType.d2w/ENTRY$(d2wVarBase)&amp;customerNumber=@dtw_rurlescseq(H1SHTO)&amp;customerName=@dtw_rurlescseq(shipToName)&amp;orderControlNumber=@dtw_rurlescseq(V_H1OCTL)" onclick="$(searchWinVar)" title="Change Order Type">$(orderTypeDesc) &nbsp; $(F_H1ORTY) &nbsp;</a></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      @RtvFldDesc("O1OCTL=$(orderControlNumber) and O1RVST='Y' ", "OEDTWK", "char(count(*))", rvwCount)
                      %if (rvwCount == "0")
                          <a onClick="return confirmAccept()" href="$(homeURL)$(cGIPath)OrderReviewItem.d2w/ACCEPT$(d2wVarBase)">$(releaseImage)</a>
                      %endif
                      <a href="$(homeURL)$(cGIPath)OrderReview.d2w/REPORT$(genericVarBase)" title="Back Home">$(portalHome)</a>
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      $(hrTagAttr)
      %INCLUDE "OrderEntryNameAddress.icl"

          <table $(contentTable)>
              <tr><th class="colhdr">Terms</th>
                  <th class="colhdr">Salesman</th>
                  %if (H1CONT > "0")
                      <th class="colhdr">Contact</th>
                  %endif
                  <th class="colhdr">Ordered</th>
                  <th class="colhdr">Required</th>
                  <th class="colhdr">Reference Number</th>
                  <th class="colhdr">Ship Via</th>
              </tr>
      %ROW {
              @RtvFldDesc("SMSLSM=$(V_H1SLSM)", "HDSLSM", "SMSNA1", salesmanName)
              @RtvFldDesc("TMCTRM='$(V_H1CTRM)'", "HDTRMS", "TMCTDS", termsDescription)
              @Format_Date(V_H1RQDT, "D", F_H1RQDT)
              @Format_Date(V_H1BDTE, "D", F_H1BDTE)
              @dtw_assign(shipTo, V_H1SHTO)

              <tr class="oddrow">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)TermsCodeInquiry.d2w/DISPLAY$(genericVarBase)&amp;termsCode=@dtw_rurlescseq($(V_H1CTRM))" onclick="$(inquiryWinVar)" title="Terms Quickview">$(termsDescription)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)SalesmanInquiry.d2w/DISPLAY$(genericVarBase)&amp;salesmanNumber=@dtw_rurlescseq($(V_H1SLSM))" onclick="$(inquiryWinVar)" title="Salesman Quickview">$(salesmanName)</a></td>
                  %if (H1CONT > "0")
                      <td class="colalph">$(contactName)</td>
                  %endif
                  <td class="coldate">$(F_H1BDTE)</td>
                  <td class="coldate">$(F_H1RQDT)</td>
                  <td class="colalph">$(V_H1ORRF)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ShipViaInquiry.d2w/DISPLAY$(genericVarBase)&amp;shipVia=@dtw_rurlescseq($(V_H1SVSV))" onclick="$(inquiryWinVar)" title="Ship Via Quickview">$(V_H1SVDS)</a></td>
              </tr>
      %}
      </table>
  %}
%}

%FUNCTION(dtw_sql) OrderDetail_Query (IN CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <tr>%if (formatToPrint == "")
                  <th class="colhdr">$(optionHeading)</th>
	       %endif
              <th class="colhdr">Ln</th>
              %if (custItemFlag == "Y")
                  <th class="colhdr">Customer<br>Item Number</th>
              %endif
              <th class="colhdr">Item<br>Number</th>
              %if (oe_sec_10 == "Y")
                  <th class="colhdr">Whs</th>
              %endif
              <th class="colhdr">Description</th>
              %if (displaySynonyms == "Y")
                  <th class="colhdr">Synonym</th>
              %endif
              <th class="colhdr">Required<br>Date</th>
              <th class="colhdr">Quantity<br>Ordered</th>
              <th class="colhdr">Price</th>
              <th class="colhdr">Extended<br>Price</th>
              %if (H1ORTY != "C" && H1ORTY != "I")
                  <th class="colhdr">B</th>
              %endif
          </tr>

          @dtw_assign(cmtSpanCnt, "2")
          %if (formatToPrint == "")
              @dtw_add(cmtSpanCnt, "1", cmtSpanCnt)
          %endif
          %if (custItemFlag == "Y")
              @dtw_add(cmtSpanCnt, "1", cmtSpanCnt)
          %endif
          %if (oe_sec_10 == "Y")
              @dtw_add(cmtSpanCnt, "1", cmtSpanCnt)
          %endif
          @dtw_assign(cmtHdrCnt, cmtSpanCnt)
          %if (formatToPrint == "")
              @dtw_subtract(cmtHdrCnt, "1", cmtHdrCnt)
          %endif

          @dtw_assign(cmtVar, "&amp;detailLine=000&amp;documentType=INT&amp;docDescription=Internal&amp;customerNumber=@dtw_rurlescseq(shipTo)&amp;customerName=@dtw_rurlescseq(shipToName)")
          @dtw_assign(type, "O")
          @dtw_assign(lineNumber, "000")
          @Order_Comments_Query(documentType, orderControlNumber, lineNumber, commentTable)
          @dtw_tb_rows(commentTable, rows)
          %if (rows > "0")
              @dtw_assign(dspCmt, "")
              @dtw_assign(x, "1")
              %while(x <= rows){@dtw_tb_getv(commentTable, x, "1", cmt)
                  %if (cmt == "")
                      @dtw_assign(cmt, "&nbsp;")
                  %endif
                  @dtw_concat(dspCmt, "$(cmt)<br>", dspCmt)
                  @dtw_add(x, "1", x)
              %}
              <tr>
                  %if (formatToPrint == "")
                      <td class="opticon">
                          %if (type == "O")
                              <a href="$(homeURL)$(cGIPath)OrderEntryCommentsMaintain.d2w/MAINTAIN$(d2wVarBase)$(cmtVar)" onclick="$(commentWinVar)">$(commentExistImage)</a>
                              @Format_Confirm_Desc("Order Header Comments", "", "", "", "", "", confirmDesc)
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)$(d2wName)/DELETE$(d2wVarBase)&amp;detailLine=000">$(deleteImageSml)</a>
                          %else
                              <a href="$(homeURL)$(cGIPath)OrderEntryCommentsMaintain.d2w/ACCEPT$(d2wVarBase)$(cmtVar)&amp;cmtSelection=Y&amp;clearOnClose=Y" onclick="$(commentWinVar)">$(commentExistImage)</a>
                          %endif
                      </td>
                  %endif
                  <td colspan="$(cmtHdrCnt)">&nbsp;</td>
                  <td class="cmtdsp" colspan="7">
                      %if (type == "O")
                          <a href="$(homeURL)$(cGIPath)OrderEntryCommentsMaintain.d2w/MAINTAIN$(d2wVarBase)$(cmtVar)" title="Maintain Order Header Comments" onclick="$(commentWinVar)">$(dspCmt)</a>
                      %else
                          <a href="$(homeURL)$(cGIPath)OrderEntryCommentsMaintain.d2w/ACCEPT$(d2wVarBase)$(cmtVar)&amp;cmtSelection=Y&amp;clearOnClose=Y" title="Copy $(begEndDesc) to Order Header Comments" onclick="$(commentWinVar)">$(dspCmt)</a>
                      %endif
                  </td>
              </tr>
          %else
              <tr>
                  <td class="colicon"><a href="$(homeURL)$(cGIPath)OrderEntryCommentsMaintain.d2w/MAINTAIN$(d2wVarBase)$(cmtVar)" title="Maintain Order Header Comments" onclick="$(commentWinVar)">$(commentImage)</a></td>
                  <td colspan="$(cmtHdrCnt)">&nbsp;</td>
                  <td class="cmtnone" colspan="7"><a href="$(homeURL)$(cGIPath)OrderEntryCommentsMaintain.d2w/MAINTAIN$(d2wVarBase)$(cmtVar)" title="Maintain Order Header Comments" onclick="$(commentWinVar)">No Comments Found</a></td>
              </tr>
          %endif

          %ROW {
              %if (V_O1RVST == "Y" || V_O1RVST == "R")
                  @dtw_assign(rowClass, "selrow")
              %else
                  %INCLUDE "SetRowClass.icl"
              %endif
              @dtw_assign(workPrice, @dtw_rformat(@dtw_rdivide(@dtw_rmultiply(@dtw_rsubtract(V_O1QORD, V_O1QSTD), V_O1SLPR), V_O1ORUF), "21", "2", "0", "", "23"))
              @Format_Nbr(workPrice, ExtendedPrice, "2", $(amtEditCode), "Y", "", "")
              @DTW_ADD(subTotal, workPrice, "15", subTotal)
              @Format_Nbr("@dtw_rsubtract(V_O1QORD, V_O1QSTD)", qtyOpen, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_O1SLPR, F_O1SLPR, $(prcNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Date(V_O1RQDT, "D", F_O1RQDT)
              @RtvFldDesc("O4OCTL=$(orderControlNumber) and O4ORL#=$(V_O1ORL#)", "OECMWK", "char(count(*))", cmtCount)

              @dtw_assign(qtyClass, "colnmbr")
              %if (V_O1KIT == "" && V_O1OREC != "N")
                  @dtw_assign(qtyAvailable, "0")
                  @Get_Qty_Avail(profileHandle, dataBaseID, V_O1ITEM, V_O1WH, qtyAvailable)
                  @dtw_assign(W_O1QORD, V_O1QORD)
                  %while(@dtw_rlength(W_O1QORD) != "16") {@dtw_insert("0", W_O1QORD, W_O1QORD)%}
                  %while(@dtw_rlength(qtyAvailable) != "16") {@dtw_insert("0", qtyAvailable, qtyAvailable)%}
                  %if (W_O1QORD > qtyAvailable)
                      @dtw_assign(qtyClass, "oepriceover")
                  %endif
              %endif

              %if (V_O1RVST == "Y")
                  @dtw_assign(chgIcon, "$(changeImageSml)")
              %else
                  @dtw_assign(chgIcon, "$(approvedImage)")
              %endif
              <tr class="$(rowClass)">
                  %if (formatToPrint == "")
                      <td class="opticon">
                          %if (V_O1RVST == "")
                              &nbsp;
                          %else
                              <a href="$(homeURL)$(cGIPath)OrderReviewMakeBuy.d2w/REPORT$(d2wVarBase)&amp;lineNumber=@dtw_rurlescseq(V_O1ORL#)&amp;featuredItem=@dtw_rurlescseq(V_O1KIT)" title="Maintain Buy/Make for this detail line">$(chgIcon)</a>
                              %if (cmtCount > "0")
                                  <a href="$(homeURL)$(cGIPath)OrderEntryCommentsMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;detailLine=@dtw_rurlescseq(V_O1ORL#)&amp;documentType=INT&amp;docDescription=Internal" title="Maintain Document" onclick="$(commentWinVar)">$(commentExistImage)</a>
                              %else
                                  <a href="$(homeURL)$(cGIPath)OrderEntryCommentsMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;detailLine=@dtw_rurlescseq(V_O1ORL#)&amp;documentType=INT&amp;docDescription=Internal" title="Maintain Document" onclick="$(commentWinVar)">$(commentImage)</a>
                              %endif
                          %endif
                      </td>
                  %endif
                  <td class="colnmbr">$(V_O1ORL#)</td>
                  %if (custItemFlag == "Y")
                      <td class="colalph">$(V_O1ORCS)</td>
                  %endif
                  %if (V_O1OREC != "N" && V_IMITEM != "")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemInquiry.d2w/DISPLAY$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq($(V_O1ITEM))" onclick="$(inquiryWinVar)" title="Item Quickview">$(V_O1ITEM)</a></td>
                  %else
                      <td class="colalph">$(V_O1ITEM)</td>
                  %endif
                  %if (oe_sec_10 == "Y")
                      @RtvFldDesc("WHWHS=$(V_O1WH)", "HDWHSM", "WHWHNM", whsName)
                      <td class="colnmbr" $(helpCursor)><span title="$(whsName)">$(V_O1WH)</span></td>
                  %endif
                  <td class="colalph">
                     %INCLUDE "SmartPartDisplay.icl"
                  </td>
                  %if (displaySynonyms == "Y")
                       @RtvFldDesc("SYITEM='$(V_O1ITEM)'", "HDSITM", "SYSYNM", synonym)
                       <td class="colalph">$(synonym)</td>
                  %endif
                  <td class="coldate">$(F_O1RQDT)</td>
                  <td class="$(qtyClass)">$(qtyOpen)</td>
                  %if ((V_O1OREC == "S" || V_O1OREC == "X") && (V_O1KIT == "" || (V_O1KIT == "K" && V_O1KTPR == "K")))
                      %if (V_O1LPOV == "Y")
                          <td class="oepriceover"><a href="$(homeURL)$(cGIPath)PricingInquiry.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;itemNumber=@dtw_rurlescseq(V_O1ITEM)&amp;itemDescription=@dtw_rurlescseq(V_O1IMDS)&amp;warehouseNumber=@dtw_rurlescseq(V_O1WH)&amp;productClass=@dtw_rurlescseq(V_O1PCLS)&amp;productGroup=@dtw_rurlescseq(V_O1PGRP)&amp;quantity=@dtw_rurlescseq(V_O1QORD)&amp;orderDate=@dtw_rurlescseq(orderDate)&amp;overridePrice=@dtw_rurlescseq(V_O1SLPR)" onclick="$(inquiryWinVar)" title="Price has been overridden - View Pricing">$(F_O1SLPR)</a></td>
                      %else
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)PricingInquiry.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;itemNumber=@dtw_rurlescseq(V_O1ITEM)&amp;itemDescription=@dtw_rurlescseq(V_O1IMDS)&amp;warehouseNumber=@dtw_rurlescseq(V_O1WH)&amp;productClass=@dtw_rurlescseq(V_O1PCLS)&amp;productGroup=@dtw_rurlescseq(V_O1PGRP)&amp;quantity=@dtw_rurlescseq(V_O1QORD)&amp;orderDate=@dtw_rurlescseq(orderDate)" onclick="$(inquiryWinVar)" title="View Pricing">$(F_O1SLPR)</a></td>
                      %endif
                  %else
                      %if (V_O1LPOV == "Y")
                          <td class="oepriceover" $(helpCursor)><span title="Price has been overridden">$(F_O1SLPR)</span></td>
                      %else
                          <td class="colnmbr">$(F_O1SLPR)</td>
                      %endif
                  %endif
                  <td class="colnmbr">$(ExtendedPrice)</td>
                  %if (H1ORTY != "C" && H1ORTY != "I")
                      <td class="colalph">$(V_O1BLKT)</td>
                  %endif
              </tr>
          %}
      </table>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(DELETE) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Delete From OECMWK Where O4OCTL=$(orderControlNumber) and O4ORL#=$(detailLine) ", stmtSQL)
  @dtw_concat(stmtSQL, "  and O4DOCT='$(documentType)' @@endsql ", stmtSQL)
  @SQL_Update(stmtSQL, status)
  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)">
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(maintenanceCode, "R")
  @Process_Order (profileHandle, dataBaseID, orderControlNumber, orderNumber, maintenanceCode)
  @dtw_assign(confMessage, "Confirm Release Of Order Number $(orderNumber)")
  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)OrderReview.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
%}
