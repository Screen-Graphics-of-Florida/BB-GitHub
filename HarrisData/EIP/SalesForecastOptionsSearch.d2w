%INCLUDE "$(baseVar)"
%INCLUDE "BrowserType.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Sales Forecast Options Search"
  d2wName                 = "SalesForecastOptionsSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;type=@dtw_rurlescseq(type)&amp;reference=@dtw_rurlescseq(reference)&amp;year=@dtw_rurlescseq(year)&amp;fdky=@dtw_rurlescseq(fdky)&amp;cust=@dtw_rurlescseq(cust)&amp;FDCUST=@dtw_rurlescseq(FDCUST)&amp;ccls=@dtw_rurlescseq(ccls)&amp;FDCCLS=@dtw_rurlescseq(FDCCLS)&amp;creg=@dtw_rurlescseq(creg)&amp;FDCRGN=@dtw_rurlescseq(FDCRGN)&amp;loc=@dtw_rurlescseq(loc)&amp;FDLOC=@dtw_rurlescseq(FDLOC#)&amp;slmn=@dtw_rurlescseq(slmn)&amp;FDSLSM=@dtw_rurlescseq(FDSLSM)&amp;pcls=@dtw_rurlescseq(pcls)&amp;FDPCLS=@dtw_rurlescseq(FDPCLS)&amp;bac=@dtw_rurlescseq(bac)&amp;FDBAC=@dtw_rurlescseq(FDBAC)&amp;ptyp=@dtw_rurlescseq(ptyp)&amp;FDPTYP=@dtw_rurlescseq(FDPTYP)&amp;plant=@dtw_rurlescseq(plant)&amp;item=@dtw_rurlescseq(item)&amp;parttype=@dtw_rurlescseq(parttype)&amp;periodFormat=@dtw_rurlescseq(periodFormat)&amp;quantityFormat=@dtw_rurlescseq(quantityFormat)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  d2wVarBaseA              = "$(genericVarBase)&amp;type=@dtw_rurlescseq(type)&amp;reference=@dtw_rurlescseq(reference)&amp;year=@dtw_rurlescseq(year)&amp;plant=@dtw_rurlescseq(plant)&amp;item=@dtw_rurlescseq(item)&amp;ptyp=@dtw_rurlescseq(ptyp)&amp;periodFormat=@dtw_rurlescseq(periodFormat)&amp;quantityFormat=@dtw_rurlescseq(quantityFormat)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  advanceSearch           = "N"
%}
	
%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                      <td class="toolbar">
                          <a href="javascript:check(document.Search)">$(acceptImageMed)</a>
                          <a href="javascript:window.close()">$(closeImageMed)</a>
                      </td>
              </tr>
          </table>
          $(searchhrTagAttr)

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)">
                          <table $(quickSearchTable)>
                              %if (periodFormat == "01")
                                      @dtw_assign(weekly, "CHECKED")
                                      @dtw_assign(monthly, "")
                                      @dtw_assign(quarterly, "")
                              %elif (periodFormat == "02")
                                      @dtw_assign(weekly, "")
                                      @dtw_assign(monthly, "CHECKED")
                                      @dtw_assign(quarterly, "")
                              %elif (periodFormat == "03")
                                      @dtw_assign(weekly, "")
                                      @dtw_assign(monthly, "")
                                      @dtw_assign(quarterly, "CHECKED")
                              %endif

                              %if (quantityFormat == "01")
                                      @dtw_assign(units, "CHECKED")
                                      @dtw_assign(currentlist, "")
                                      @dtw_assign(standardcost, "")
                                      @dtw_assign(currentcost, "")
                                      @dtw_assign(futurecost, "")
                                      @dtw_assign(averagecost, "")
                              %elif (quantityFormat == "02")
                                      @dtw_assign(units, "")
                                      @dtw_assign(currentlist, "CHECKED")
                                      @dtw_assign(standardcost, "")
                                      @dtw_assign(currentcost, "")
                                      @dtw_assign(futurecost, "")
                                      @dtw_assign(averagecost, "")
                              %elif (quantityFormat == "03")
                                      @dtw_assign(units, "")
                                      @dtw_assign(currentlist, "")
                                      @dtw_assign(standardcost, "CHECKED")
                                      @dtw_assign(currentcost, "")
                                      @dtw_assign(futurecost, "")
                                      @dtw_assign(averagecost, "")
                              %elif (quantityFormat == "04")
                                      @dtw_assign(units, "")
                                      @dtw_assign(currentlist, "")
                                      @dtw_assign(standardcost, "")
                                      @dtw_assign(currentcost, "CHECKED")
                                      @dtw_assign(futurecost, "")
                                      @dtw_assign(averagecost, "")
                              %elif (quantityFormat == "05")
                                      @dtw_assign(units, "")
                                      @dtw_assign(currentlist, "")
                                      @dtw_assign(standardcost, "")
                                      @dtw_assign(currentcost, "")
                                      @dtw_assign(futurecost, "CHECKED")
                                      @dtw_assign(averagecost, "")
                               %elif (quantityFormat == "06")
                                      @dtw_assign(units, "")
                                      @dtw_assign(currentlist, "")
                                      @dtw_assign(standardcost, "")
                                      @dtw_assign(currentcost, "")
                                      @dtw_assign(futurecost, "")
                                      @dtw_assign(averagecost, "CHECKED")
                              %endif

                              <tr><td class="dsphdr">Select Period Format</td>
                                  <td class="inputnmbr"><input name="period" type="radio" VALUE='01' $(weekly)>Weekly</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="period" type="radio" VALUE='02' $(monthly)>Monthly</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="period" type="radio" VALUE='03' $(quarterly)>Quarterly</td>
                              </tr>

                              <tr><td>&nbsp;</td></tr>

                              <tr><td class="dsphdr">Select Display Format</td>
                                  <td class="inputnmbr"><input name="quantity" type="radio" VALUE='01' $(units)>Units</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="quantity" type="radio" VALUE='02' $(currentlist)>Current List</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="quantity" type="radio" VALUE='03' $(standardcost)>Standard Cost</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="quantity" type="radio" VALUE='04' $(currentcost)>Current Cost</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="quantity" type="radio" VALUE='05' $(futurecost)>Future Cost</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="quantity" type="radio" VALUE='06' $(averagecost)>Average Cost</td>
                              </tr>
                          </table>
                      </form>	

                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(ACCEPT) {
  @dtw_assign(goto, "")
  @dtw_assign(caller, "")
  @dtw_assign(callerBase, "")
  %if (period != periodFormat || quantity != quantityFormat)
      @dtw_assign(goto, "LOAD")
      @dtw_assign(periodFormat,period)
      @dtw_assign(quantityFormat,quantity)
  %else
      @dtw_assign(goto, "REPORT")
  %endif
  %if (type == "001")
      @dtw_assign(caller, "SalesForecastInquiryA.d2w")
      @dtw_assign(callerBase, $(d2wVarBaseA))
  %else
      @dtw_assign(caller, "SalesForecastInquiry8.d2w")
      @dtw_assign(callerBase, $(d2wVarBase))
  %endif
  @BrowserType(browserCode)
  %if (browserCode == "IE")
      <script TYPE="text/javascript">
          opener.location.href='$(homeURL)$(cGIPath)$(caller)/$(goto)$(callerBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))';
          window.close();
      </script>
  %else
      <meta http-equiv="refresh" content="0; URL=javascript:opener.document.location='$(homeURL)$(cGIPath)$(caller)/$(goto)$(callerBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))';self.close();">
  %endif
%}

%HTML(CLOSE) {
  <script TYPE="text/javascript">
      window.close();
  </script>
%}