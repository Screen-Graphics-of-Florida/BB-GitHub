%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Payroll Tax Liability"
  d2wName                 = "PayrollTaxLiability.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPRTPI"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "NewWindowOpen.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editdate(document.Search.srchCheckDate))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "TAXLIABILITY")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      @dtw_assign(uv_FederalEINName, "XDFEIN")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "SELECT * ", stmtSQL)
                      @dtw_concat(fileSQL, " PRTXDT ", fileSQL)
                      %if (wildCardSearch!="" || uv_Sql!="")
                          @dtw_concat(selectSQL, "XDFEIN > 0 ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @TaxLiability_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) TaxLiability_Query (IN  CHAR(64) profileHandle,
                                           CHAR(2)   dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count != "1")
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1> $(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/report") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Bach Home">$(portalHome)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"

          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Tax<br>ID</th>
                          <th class="colhdr">Check<br>Date</th></tr>
                      <tr><td><input type="text" class="inputalph" name="srchTaxId" size="2" maxlength="2">
                              <input type="hidden" name="operTaxId" value="LIKE">
                          </td>
                          <td><input type="text" class="inputnmbr" name="srchCheckDate" size="6" maxlength="6">
                              <input type="hidden" name="operCheckDate" value="=">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchTaxId.focus();
                  </script>
              </form>

              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("XDFEIN", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FedEin" title="Sequence By Federal EIN, Tax Type, Tax ID, Check Date (Descending)">Federal<br>EIN</a></th>
                  @OrderBy_Sort("XDSEIN", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=OtherEin" title="Sequence By State, SUI Or Local EIN, Tax Type, Tax ID, Check Date (Descending)">State, SUI Or<br>Local EIN</a></th>
                  @OrderBy_Sort("XDTYPE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TaxType" title="Sequence By Tax Type, Tax ID, Check Date (Descending)">Tax<br>Type</a></th>
                  <th class="colhdr">Tax Type<br>Description</th>
                  @OrderBy_Sort("XDTXID", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TaxId" title="Sequence By Tax ID, Tax Type, Check Date (Descending)">Tax<br>ID</a></th>
                  @OrderBy_Sort("XDDATE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CheckDate" title="Sequence By Check Date, Tax ID, Tax Type">Check<br>Date</a></th>
                  <th class="colhdr">Wages</th>
                  @OrderBy_Sort("XDRAMT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=EmployerTax" title="Sequence By Employer Tax">Employer<br>Tax</a></th>
                  @OrderBy_Sort("XDEAMT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=EmployeeTax" title="Sequence By Employee Tax">Employee<br>Tax</a></th>
                  @OrderBy_Sort("XDDUE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DueDate" title="Sequence By Payment Due Date, Tax ID, Tax Type">Payment<br>Due Date</a></th>
                  @OrderBy_Sort("XDPAID", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DatePaid" title="Sequence By Date Paid, Tax ID, Tax Type">Date<br>Paid</a></th>
                  <th class="colhdr">Selected For<br>Processing</th>
              </tr>
          %INCLUDE "NoRecordsFound.icl"
      %endif

          %ROW{
              %if ((V_XDTYPE == "2") || (V_XDTTPE == "12"))
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;federalEin=@dtw_rurlescseq(V_XDFEIN)&amp;otherEin=@dtw_rurlescseq(V_XDSEIN)&amp;taxId=@dtw_rurlescseq(V_XDTXID)&amp;taxType=1&amp;detailTaxType=@dtw_rurlescseq(V_XDTYPE)&amp;checkDate=@dtw_rurlescseq(V_XDDATE)&amp;datePaid=@dtw_rurlescseq(V_XDPAID)&amp;checkNumber=@dtw_rurlescseq(V_XDCKNO)&amp;sequenceNumber=@dtw_rurlescseq(V_XDSEQ)")
              %else
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;federalEin=@dtw_rurlescseq(V_XDFEIN)&amp;otherEin=@dtw_rurlescseq(V_XDSEIN)&amp;taxId=@dtw_rurlescseq(V_XDTXID)&amp;taxType=@dtw_rurlescseq(V_XDTYPE)&amp;detailTaxType=@dtw_rurlescseq(V_XDTYPE)&amp;checkDate=@dtw_rurlescseq(V_XDDATE)&amp;datePaid=@dtw_rurlescseq(V_XDPAID)&amp;checkNumber=@dtw_rurlescseq(V_XDCKNO)&amp;sequenceNumber=@dtw_rurlescseq(V_XDSEQ)")
              %endif
              %if (sql_Record_Count == "1")
                  @Save_WebReg(webRegCurFile, profileHandle, d2wName, "", orderBy, orderByDisplay, "")
                  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)PayrollTaxDtlSelect.d2w/REPORT$(maintainVar)">
              %else
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colnmbr">$(V_XDFEIN)</td>
                      <td class="colalph">$(V_XDSEIN)</td>
                      <td class="colcode">$(V_XDTYPE)</td>
                      @RtvFldDesc("XTTYPE=$(V_XDTYPE)", "PRTXTY", "XTDESC", taxTypeDesc)
                      <td class="colalph">$(taxTypeDesc)</td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)PayrollTaxDtlSelect.d2w/REPORT$(maintainVar)" title="View Payroll Tax Liability Detail">$(V_XDTXID)</a></td>
                      @Format_Date(V_XDDATE, "D", F_XDDATE)
                      <td class="colalph">$(F_XDDATE)</td>
                      %if ((V_XDTYPE == "5") || (V_XDTYPE == "6") || (V_XDTYPE == "15") || (V_XDTYPE == "16"))
                          @Format_Nbr($(V_XDTWG2), F_XDTWG2, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_XDTWG2)</td>
                      %else
                          @Format_Nbr($(V_XDTWG1), F_XDTWG1, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(V_XDTWG1)</td>
                      %endif
                      @Format_Nbr($(V_XDRAMT), F_XDRAMT, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(V_XDRAMT)</td>
                      @Format_Nbr($(V_XDEAMT), F_XDEAMT, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(V_XDEAMT)</td>
                      @Format_Date(V_XDDUE, "D", F_XDDUE)
                      <td class="colalph">$(F_XDDUE)</td>
                      %if(V_XDPAID != "0")
                          @Format_Date(V_XDPAID, "D", F_XDPAID)
                          %if(V_XDDPSR == "P")
                              <td class="colnmbr"><a href="$(homeURL)$(cGIPath)PayrollTaxPaySelect.d2w/REPORT$(maintainVar)&amp;paymentSequence=@dtw_rurlescseq(V_XDDPSQ)" title="View Payroll Tax Payment">$(F_XDPAID)</a></td>
                          %else
                              <td class="colnmbr">$(F_XDPAID)</td>
                          %endif
                      %else
                          <td class="colalph">&nbsp;</td>
                      %endif
                      %if((V_XDPAID == "0") || (V_XDPAID != "0" && V_XDSLCT != "N"))
                          @RtvFldDesc("FLTYPE='PAYSELECT' and FLVALU='$(V_XDSLCT)'", "SYFLAG", "FLDESC", syFlagDesc)
                          <td class="colcode">$(syFlagDesc)</td>
                      %else
                          <td class="colalph">&nbsp;</td>
                      %endif
                  </tr>
              %endif
          %}
          </table>
          %if (sql_Record_Count != "1")
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  @dtw_assign(uv_FederalEINName, "XDFEIN")
  %INCLUDE "userview.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "SELECT * ", stmtSQL)
  @dtw_concat(fileSQL, " PRTXDT ", fileSQL)
  %if (wildCardSearch!="" || uv_Sql!="")
      @dtw_concat(selectSQL, "XDFEIN > 0 ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @TaxLiability_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) TaxLiability_XMLQuery (IN CHAR(64) profileHandle,
				            CHAR(2)   dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("TaxLiabilityList")
          %ROW{
              @RtvFldDesc("XTTYPE=$(V_XDTYPE)", "PRTXTY", "XTDESC", taxTypeDesc)
              @DateFromCYMD(V_XDDATE)
              @DateFromCYMD(V_XDDUE)
              @DateFromCYMD(V_XDPAID)

	       @XMLIDTag(@DTW_rCONCAT(V_XDFEIN, @DTW_rCONCAT("/", @DTW_rCONCAT(V_XDSEIN, @DTW_rCONCAT("/", V_XDTXID)))), "TaxLiability ID")
                  @XMLTag(V_XDFEIN, "FederalEIN")
                  @XMLTag(V_XDSEIN, "StateOrOtherEIN")
                  @XMLTag(V_XDTXID, "TaxID")
                  @XMLTag(taxTypeDesc, "TaxType")
                  @XMLTag(V_XDDATE, "CheckDate")
                  %if ((V_XDTYPE == "5") || (V_XDTYPE == "6") || (V_XDTYPE == "15") || (V_XDTYPE == "16"))
                      @XMLTag(V_XDTWG2, "TaxableWages")
                  %else
                      @XMLTag(V_XDTWG1, "TaxableWages")
                  %endif
                  @XMLTag(V_XDRAMT, "EmployerTax")
                  @XMLTag(V_XDEAMT, "EmployeeTax")
                  %if(V_XDTXID == "FD" && (V_XDTYPE == "1" || V_XDTYPE == "11"))
                      @XMLTag(V_XDEIC, "EarnedIncomeCredit")
                  %endif
                  @XMLTag(V_XDDUE, "PaymentDueDate")
                  @XMLTag(V_XDPAID, "DatePaid")
                  %if(V_XDPAID != "0")
                      @XMLTag(V_XDPAMT, "AmountPaid")
                      %if(V_XDCKNO != "0")
                          @XMLTag(V_XDCKNO, "CheckNumber")
                      %else
                          @XMLTag("EFT", "CheckNumber")
                      %endif
                  @XMLTag(V_XDBKNO, "BankNumber")
                  %endif
                  @XMLTag(V_XDCMN1, "CommentOne")
                  @XMLTag(V_XDCMN2, "CommentTwo")
              @XMLEndTag("TaxLiability")
		%}
      @XMLEndTag("TaxLiabilityList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "XDFEIN,XDTYPE,XDTXID,XDDATE DESC")
              @DTW_ASSIGN(orderByDisplay, "Federal EIN, Tax Type, Tax ID, Check Date (Descending)")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      %INCLUDE "SearchReturn.icl"
  %endif
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"

  %if (sequence == "FedEin")
      %if (orderBy == "XDFEIN,XDTYPE,XDTXID,XDDATE DESC")
          @DTW_ASSIGN(orderBy, "XDFEIN DESC,XDTYPE,XDTXID,XDDATE DESC")
          @DTW_ASSIGN(orderByDisplay, "Federal EIN (descending), Tax Type, Tax ID, Check Date (Descending)")
      %else
          @DTW_ASSIGN(orderBy, "XDFEIN,XDTYPE,XDTXID,XDDATE DESC")
          @DTW_ASSIGN(orderByDisplay, "Federal EIN, Tax Type, Tax ID, Check Date (Descending)")
      %endif
  %elif (sequence == "OtherEin")
      %if (orderBy == "XDSEIN,XDTYPE,XDTXID,XDDATE DESC")
          @DTW_ASSIGN(orderBy, "XDSEIN DESC,XDTYPE,XDTXID,XDDATE DESC")
          @DTW_ASSIGN(orderByDisplay, "State, SUI Or Local EIN (descending), Tax Type, Tax ID, Check Date (Descending)")
      %else
          @DTW_ASSIGN(orderBy, "XDSEIN,XDTYPE,XDTXID,XDDATE DESC")
          @DTW_ASSIGN(orderByDisplay, "State, SUI Or Local EIN, Tax Type, Tax ID, Check Date (Descending)")
      %endif
  %elif (sequence == "TaxType")
      %if (orderBy == "XDTYPE,XDTXID,XDDATE DESC")
          @DTW_ASSIGN(orderBy, "XDTYPE DESC,XDTXID,XDDATE DESC")
          @DTW_ASSIGN(orderByDisplay, "Tax Type (descending), Tax ID, Check Date (Descending)")
      %else
          @DTW_ASSIGN(orderBy, "XDTYPE,XDTXID,XDDATE DESC")
          @DTW_ASSIGN(orderByDisplay, "Tax Type, Tax ID, Check Date (Descending)")
      %endif
  %elif (sequence == "TaxId")
      %if (orderBy == "XDTXID,XDTYPE,XDDATE DESC")
          @DTW_ASSIGN(orderBy, "XDTXID DESC,XDTYPE,XDDATE DESC")
          @DTW_ASSIGN(orderByDisplay, "Tax ID (descending), Tax Type, Check Date (Descending)")
      %else
          @DTW_ASSIGN(orderBy, "XDTXID,XDTYPE,XDDATE DESC")
          @DTW_ASSIGN(orderByDisplay, "Tax ID, Tax Type, Check Date (Descending)")
      %endif
  %elif (sequence == "DueDate")
      %if (orderBy == "XDDUE,XDTYPE,XDTXID")
          @DTW_ASSIGN(orderBy, "XDDUE DESC,XDTYPE,XDTXID")
          @DTW_ASSIGN(orderByDisplay, "Due Date (descending), Tax Type, Tax ID")
      %else
          @DTW_ASSIGN(orderBy, "XDDUE,XDTYPE,XDTXID")
          @DTW_ASSIGN(orderByDisplay, "Due Date, Tax Type, Tax ID")
      %endif
  %elif (sequence == "CheckDate")
      %if (orderBy == "XDDATE,XDTYPE,XDTXID")
          @DTW_ASSIGN(orderBy, "XDDATE DESC,XDTYPE,XDTXID")
          @DTW_ASSIGN(orderByDisplay, "Due Date (descending), Tax Type, Tax ID")
      %else
          @DTW_ASSIGN(orderBy, "XDDATE,XDTYPE,XDTXID")
          @DTW_ASSIGN(orderByDisplay, "Due Date, Tax Type, Tax ID")
      %endif
  %elif (sequence == "EmployerTax")
      %if (orderBy == "XDRAMT")
          @DTW_ASSIGN(orderBy, "XDRAMT DESC")
          @DTW_ASSIGN(orderByDisplay, "Due Date (descending), Tax Type, Tax ID")
      %else
          @DTW_ASSIGN(orderBy, "XDRAMT")
          @DTW_ASSIGN(orderByDisplay, "Due Date, Tax Type, Tax ID")
      %endif
  %elif (sequence == "EmployeeTax")
      %if (orderBy == "XDEAMT")
          @DTW_ASSIGN(orderBy, "XDEAMT DESC")
          @DTW_ASSIGN(orderByDisplay, "Due Date (descending), Tax Type, Tax ID")
      %else
          @DTW_ASSIGN(orderBy, "XDEAMT")
          @DTW_ASSIGN(orderByDisplay, "Due Date, Tax Type, Tax ID")
      %endif
  %elif (sequence == "DatePaid")
      %if (orderBy == "XDPAID,XDTYPE,XDTXID")
          @DTW_ASSIGN(orderBy, "XDPAID DESC,XDTYPE,XDTXID")
          @DTW_ASSIGN(orderByDisplay, "Date Paid (descending), Tax Type, Tax ID")
      %else
          @DTW_ASSIGN(orderBy, "XDPAID,XDTYPE,XDTXID")
          @DTW_ASSIGN(orderByDisplay, "Date Paid, Tax Type, Tax ID")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchEIN, 9, 0) &&
                      editdate(document.Search.srchCheckDate) &&
                      editNum(document.Search.srchEmprTax, 11, 2) &&
                      editNum(document.Search.srchEmpeTax, 11, 2) &&
                      editdate(document.Search.srchDueDate) &&
                      editdate(document.Search.srchDatePaid))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "TAXLIABSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Federal EIN</td>
                              @dtw_assign(operNbr, "operEIN")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputalph"><input name="srchEIN" type="text" size="9" maxlength="9"> <a href="$(homeURL)$(cGIPath)EINSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Search&amp;fldName=srchEIN&amp;fldDesc=einDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="einDesc" value="$(EINName)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">State, SUI Or Local EIN</td>
                              @dtw_assign(operNbr, "operOein")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchOein" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Tax ID</td>
                              @dtw_assign(operNbr, "operTaxId")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchTaxId" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Check Date</td>
                              @dtw_assign(operNbr, "operCheckDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchCheckDate" size="6" maxlength="6"> 		
                                  <a href="javascript:calWindow('srchCheckDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Employer Tax</td>
                              @dtw_assign(operNbr, "operEmprTax")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchEmprTax" size="11" maxlength="11"> 		
                          </tr>

                          <tr><td class="dsphdr">Employee Tax</td>
                              @dtw_assign(operNbr, "operEmpeTax")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchEmpeTax" size="11" maxlength="11"> 		
                          </tr>

                          <tr><td class="dsphdr">Payment Due Date</td>
                              @dtw_assign(operNbr, "operDueDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchDueDate" size="6" maxlength="6"> 		
                                  <a href="javascript:calWindow('srchDueDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Date Paid</td>
                              @dtw_assign(operNbr, "operDatePaid")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchDatePaid" size="6" maxlength="6"> 		
                                  <a href="javascript:calWindow('srchDatePaid');">$(calendarImage)</a></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchEIN.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("XDFEIN", "Federal EIN", $(srchEIN), "", operEIN, "N")
  @Build_WildCard ("XDSEIN", "State, SUI Or Local EIN", $(srchOein), "U", operOein, "A")
  @Build_WildCard ("XDTXID", "Tax ID", $(srchTaxId), "U", operTaxId, "A")
  @Build_WildCard ("XDDATE", "Check Paid", $(srchCheckDate), "", operCheckDate, "D")
  @Build_WildCard ("XDRAMT", "Employer Tax", $(srchEmprTax), "", operEmprTax, "N")
  @Build_WildCard ("XDEAMT", "Employee Tax", $(srchEmpeTax), "", operEmpeTax, "N")
  @Build_WildCard ("XDDUE", "Due Date", $(srchDueDate), "", operDueDate, "D")
  @Build_WildCard ("XDPAID", "Date Paid", $(srchDatePaid), "", operDatePaid, "D")
  @Build_WildCard ("XDPAMT", "Amount Paid", $(srchAmount), "", operAmount, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}