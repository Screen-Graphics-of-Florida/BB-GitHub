%FUNCTION(dtw_sql) BenefitExtension (IN CHAR(64)    profileHandle,
                                             CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="benefitextension"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  <th class="colhdr">Effective<br>Date</th>
                  <th class="colhdr">Expiration<br>Date</th>
                  <th class="colhdr">Employer Cost of<br>Coverage - Monthly</th>
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  @Format_Date(V_CEECEF, "D", F_CEECEF)
                  <td class="dspdate">$(F_CEECEF)</td>
                  @Format_Date(V_CEECEX, "D", F_CEECEX)
                  <td class="dspdate">$(F_CEECEX)</td>
                  <td class="colcode">$(V_CECSTM)</td>
              </tr>
          %}	
      </table>
      </fieldset>
  %}
%}

