%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"

%Define {	
  page_title              = "Item Extended Description"
  d2wName                 = "ItemExtCmtInquiry.d2w"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "999"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}
	
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onLoad="window.focus()" onBlur="window.close()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->

          %INCLUDE "PageTitle.icl"

          <table $(contentTable)>
              @Format_Header("Item", $(itemDescription), $(itemNumber))
              @Format_Header("Document", $(docDescription), $(documentType))
          </table>
          $(inquiryhrTagAttr)

          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select IXDESC ", stmtSQL)
                      @dtw_concat(fileSQL, " HDIMXD ", fileSQL)
                      @dtw_concat(selectSQL, "IXITEM='$(itemNumber)' and IXDOCT='$(documentType)'", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By IXSEQ# ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Item_ExtDesc_Inquiry(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>

          $(inquiryhrTagAttr)
          %INCLUDE "Copyright.icl"

          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Item_ExtDesc_Inquiry (IN CHAR(64)    profileHandle,
				             CHAR(2)     dataBaseID,
                                            CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>

          %ROW{
              %if (V_IXDESC == "")
                  @dtw_assign(V_IXDESC, "&nbsp;")
              %endif
              <tr><td class="colalph">$(V_IXDESC)</td></tr>
          %}
      </table>
  %}
%}


%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}