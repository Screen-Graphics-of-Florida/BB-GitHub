%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "StoredProcedureVariables.icl"

%Define {
  page_title              = "Customer Demand Inquiry"
  d2wName                 = "SalesForecastInquiryCustomerDemand.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;type=@dtw_rurlescseq(type)&amp;reference=@dtw_rurlescseq(reference)&amp;year=@dtw_rurlescseq(year)&amp;fdky=@dtw_rurlescseq(fdky)&amp;cust=@dtw_rurlescseq(cust)&amp;FDCUST=@dtw_rurlescseq(FDCUST)&amp;ccls=@dtw_rurlescseq(ccls)&amp;FDCCLS=@dtw_rurlescseq(FDCCLS)&amp;creg=@dtw_rurlescseq(creg)&amp;FDCRGN=@dtw_rurlescseq(FDCRGN)&amp;loc=@dtw_rurlescseq(loc)&amp;FDLOC=@dtw_rurlescseq(FDLOC#)&amp;slmn=@dtw_rurlescseq(slmn)&amp;FDSLSM=@dtw_rurlescseq(FDSLSM)&amp;pcls=@dtw_rurlescseq(pcls)&amp;FDPCLS=@dtw_rurlescseq(FDPCLS)&amp;bac=@dtw_rurlescseq(bac)&amp;FDBAC=@dtw_rurlescseq(FDBAC)&amp;ptyp=@dtw_rurlescseq(ptyp)&amp;FDPTYP=@dtw_rurlescseq(FDPTYP)&amp;plant=@dtw_rurlescseq(plant)&amp;item=@dtw_rurlescseq(item)&amp;periodFormat=@dtw_rurlescseq(periodFormat)&amp;quantityFormat=@dtw_rurlescseq(quantityFormat)&amp;IQBDAT=@dtw_rurlescseq(IQBDAT)&amp;IQEDAT=@dtw_rurlescseq(IQEDAT)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
%}


%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@type", "@dtw_rurlescseq(type)", "1", "a", workURL)
  @dtw_replace(workURL, "@@reference", "@dtw_rurlescseq(reference)", "1", "a", workURL)
  @dtw_replace(workURL, "@@year", "@dtw_rurlescseq(year)", "1", "a", workURL)
  @dtw_replace(workURL, "@@fdky", "@dtw_rurlescseq(fdky)", "1", "a", workURL)
  @dtw_replace(workURL, "@@cust", "@dtw_rurlescseq(cust)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "SALESFORECASTINQUIRYCUSTOMERDEMAND")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif

                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select DMORD#, DMORL#, DMOREC, DMSHTO, DMRQDT, DMQTYO, DMTKFG, DMSHPF, CMCNA1", stmtSQL)
                      @dtw_concat(fileSQL, " WKDMND join HDCUST ON DMSHTO=CMCUST ", fileSQL)
                      @dtw_concat(selectSQL, " DMXHND='$(profileHandle)' ", selectSQL)
                      @dtw_concat(selectSQL, " and (DMRQDT>='$(IQBDAT)' and DMRQDT<='$(IQEDAT)') ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>

              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td>&nbsp;</td>
                  <td class="toolbar">
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      <table $(contentTable)>
          %if (cust == "1")
              @RtvFldDesc("CMCUST=$(FDCUST)", "HDCUST", "CMCNA1", fieldDesc)
              @Format_Header_URL("Customer", $(fieldDesc), $(FDCUST), "")
          %elif (ccls == "1")
              @RtvFldDesc("CCCCLS='$(FDCCLS)' ", "HDCCLS", "CCCCDS", fieldDesc)
              @Format_Header_URL("Customer Class", $(fieldDesc), $(FDCCLS), "")
          %elif (creg == "1")
              @RtvFldDesc("RGCRGN='$(FDCRGN)' ", "HDCRGN", "RGCRDS", fieldDesc)
              @Format_Header_URL("Customer Region", $(fieldDesc), $(FDCRGN), "")
          %elif (loc == "1")
              @RtvFldDesc("LOLO#=$(FDLOC#)", "HDLCTN", "LOLNA1", fieldDesc)
              @Format_Header_URL("Location", $(fieldDesc), $(FDLOC#), "")
          %elif (slmn == "1")
              @RtvFldDesc("SMSLSM=$(FDSLSM)", "HDSLSM", "SMSNA1", fieldDesc)
              @Format_Header_URL("Salesman", $(fieldDesc), $(FDSLSM), "")
          %elif (pcls == "1")
              @RtvFldDesc("PCPCLS='$(FDPCLS)' ", "HDPCLS", "PCPCDS", fieldDesc)
              @Format_Header_URL("Product Class", $(fieldDesc), $(FDPCLS), "")
          %elif (bac == "1")
              @RtvFldDesc("BMBUYR=$(FDBAC)", "HDBUYR", "BMBNA1", fieldDesc)
              @Format_Header_URL("Buyer/Analyst", $(fieldDesc), $(FDBAC), "")
          %elif (ptyp == "1")
              @Format_Header_URL("Part Type", $(FDPTYP), "", "")
          %endif
          %if (cust == "2")
              @RtvFldDesc("CMCUST=$(FDCUST)", "HDCUST", "CMCNA1", fieldDesc)
              @Format_Header_URL("Customer", $(fieldDesc), $(FDCUST), "")
          %elif (ccls == "2")
              @RtvFldDesc("CCCCLS='$(FDCCLS)' ", "HDCCLS", "CCCCDS", fieldDesc)
              @Format_Header_URL("Customer Class", $(fieldDesc), $(FDCCLS), "")
          %elif (creg == "2")
              @RtvFldDesc("RGCRGN='$(FDCRGN)' ", "HDCRGN", "RGCRGN", fieldDesc)
              @Format_Header_URL("Customer Region", $(fieldDesc), $(FDCRGN), "")
          %elif (loc == "2")
              @RtvFldDesc("LOLO#=$(FDLOC#)", "HDLCTN", "LOLNA1", fieldDesc)
              @Format_Header_URL("Location", $(fieldDesc), $(FDLOC#), "")
          %elif (slmn == "2")
              @RtvFldDesc("SMSLSM=$(FDSLSM)", "HDSLSM", "SMSNA1", fieldDesc)
              @Format_Header_URL("Salesman", $(fieldDesc), $(FDSLSM), "")
          %elif (pcls == "2")
              @RtvFldDesc("PCPCLS='$(FDPCLS)' ", "HDPCLS", "PCPCDS", fieldDesc)
              @Format_Header_URL("Product Class", $(fieldDesc), $(FDPCLS), "")
          %elif (bac == "2")
              @RtvFldDesc("BMBUYR=$(FDBAC)", "HDBUYR", "BMBNA1", fieldDesc)
              @Format_Header_URL("Buyer/Analyst", $(fieldDesc), $(FDBAC), "")
          %elif (ptyp == "2")
              @Format_Header_URL("Part Type", $(FDPTYP), "", "")
          %endif
          %if (cust == "3")
              @RtvFldDesc("CMCUST=$(FDCUST)", "HDCUST", "CMCNA1", fieldDesc)
              @Format_Header_URL("Customer", $(fieldDesc), $(FDCUST), "")
          %elif (ccls == "3")
              @RtvFldDesc("CCCCLS='$(FDCCLS)' ", "HDCCLS", "CCCCDS", fieldDesc)
              @Format_Header_URL("Customer Class", $(fieldDesc), $(FDCCLS), "")
          %elif (creg == "3")
              @RtvFldDesc("RGCRGN='$(FDCRGN)' ", "HDCRGN", "RGCRGN", fieldDesc)
              @Format_Header_URL("Customer Region", $(fieldDesc), $(FDCRGN), "")
          %elif (loc == "3")
              @RtvFldDesc("LOLO#=$(FDLOC#)", "HDLCTN", "LOLNA1", fieldDesc)
              @Format_Header_URL("Location", $(fieldDesc), $(FDLOC#), "")
          %elif (slmn == "3")
              @RtvFldDesc("SMSLSM=$(FDSLSM)", "HDSLSM", "SMSNA1", fieldDesc)
              @Format_Header_URL("Salesman", $(fieldDesc), $(FDSLSM), "")
          %elif (pcls == "3")
              @RtvFldDesc("PCPCLS='$(FDPCLS)' ", "HDPCLS", "PCPCDS", fieldDesc)
              @Format_Header_URL("Product Class", $(fieldDesc), $(FDPCLS), "")
          %elif (bac == "3")
              @RtvFldDesc("BMBUYR=$(FDBAC)", "HDBUYR", "BMBNA1", fieldDesc)
              @Format_Header_URL("Buyer/Analyst", $(fieldDesc), $(FDBAC), "")
          %elif (ptyp == "3")
              @Format_Header_URL("Part Type", $(FDPTYP), "", "")
          %endif
          @RtvFldDesc("PLPLNT=$(plant)", "HDPLNT", "PLNAME", plantName)
          @Format_Header_URL("Plant Number", $(plantName), $(plant), "")
          @RtvFldDesc("IMITEM='$(item)'", "HDIMST", "IMIMDS", itemDescription)
          @Format_Header_URL("Item Number", $(itemDescription), $(item), "")
          @Format_Date(IQEDAT, "1", F_IQEDAT)
          @Format_Header_URL("Period End", $(F_IQEDAT),"", "")
      </table>
      $(hrTagAttr)

      %if (formatToPrint != "Y")
              <table $(contentTable)>
                  <tr><td> %INCLUDE "AssignPageValue.icl" </td>
                      <td>&nbsp;</td>

                  </tr>
              </table>
          %endif
      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              @OrderBy_Sort("DMORD#", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=order" title="Sequence By Order Number, Line">Order<br>Number</a></th>
              @OrderBy_Sort("DMORL#", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=line" title="Sequence By Line">Line</a></th>
              @OrderBy_Sort("DMOREC", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=entryCode" title="Sequence By  Entry Code">Entry<br>Code</a></th>
              @OrderBy_Sort("DMSHTO", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=shipTo" title="Sequence By Ship To">Ship-<br>To</a></th>
              @OrderBy_Sort("CMCNA1", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=customerName" title="Sequence By Customer Name">Customer Name</a></th>
              @OrderBy_Sort("DMRQDT", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=requiredDate" title="Sequence By Required Date">Required<br>Date</a></th>
              @OrderBy_Sort("DMQTYO", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=quantity" title="Sequence By Quantity Open">Quantity<br>Open</a></th>
              @OrderBy_Sort("DMTKFG", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=picked" title="Sequence By Picked">Picked</a></th>
              @OrderBy_Sort("DMSHPF", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=shipped" title="Sequence By Shipped">Shipped</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Nbr(V_DMORD#, F_DMORD#, "0", "Z", "", "", "")
              @Format_Nbr(V_DMORL#, F_DMORL#, "0", "Z", "", "", "")
              @Format_Nbr(V_DMSHTO, F_DMSHTO, "0", "Z", "", "", "")
              @Format_Date(V_DMRQDT, "1", F_DMRQDT)
              @Format_Nbr(V_DMQTYO, F_DMQTYO, "2", "M", "", "", "")
              %if (quantityFormat == "01")
                  @Format_Nbr(V_DMQTYO, F_DMQTYO, "0", "Z", "", "", "")
              %else
                  @Format_Nbr(V_DMQTYO, F_DMQTYO, "2", "M", "Y", "", "")
              %endif

              <tr class="$(rowClass)">
                  <td class="colnmbr">$(F_DMORD#)</td>
                  <td class="colnmbr">$(F_DMORL#)</td>
                  <td class="colalph">$(V_DMOREC)</td>
                  <td class="colnmbr">$(F_DMSHTO)</td>
                  <td class="colalph">$(V_CMCNA1)</td>
                  <td class="colnmbr">$(F_DMRQDT)</td>
                  <td class="colnmbr">$(F_DMQTYO)</td>
                  <td class="colalph">$(V_DMTKFG)</td>
                  <td class="colalph">$(V_DMSHPF)</td>
              </tr>

          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}


%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"

  %if (formatToPrint == "Y")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else

      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "DMRQDT")
          @DTW_ASSIGN(orderByDisplay, "Required Date")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif

  %INCLUDE "SearchReturn.icl"
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"

  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "DMRQDT")
          @DTW_ASSIGN(orderByDisplay, "Required Date")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "order")
      %if (orderBy == "DMORD#,DMORL#")
          @DTW_ASSIGN(orderBy, "DMORD# DESC,DMORL# DESC")
          @DTW_ASSIGN(orderByDisplay, "Order Number (descending), Line Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "DMORD#,DMORL#")
          @DTW_ASSIGN(orderByDisplay, "Order Number, Line Number")
      %endif
  %elif (sequence == "line")
      %if (orderBy == "DMORL#")
          @DTW_ASSIGN(orderBy, "DMORL# DESC")
          @DTW_ASSIGN(orderByDisplay, "Line Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "DMORL#")
          @DTW_ASSIGN(orderByDisplay, "Line Number")
      %endif
  %elif (sequence == "entryCode")
      %if (orderBy == "DMOREC, DMORD#, DMORL#")
          @DTW_ASSIGN(orderBy, "DMOREC DESC, DMORD# DESC, DMORL# DESC")
          @DTW_ASSIGN(orderByDisplay, "Entry Code (descending), Order Number (descending), Line Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "DMOREC, DMORD#, DMORL#")
          @DTW_ASSIGN(orderByDisplay, "Entry Code,  Order Number, Line Number")
      %endif
  %elif (sequence == "shipTo")
      %if (orderBy == "DMSHTO")
          @DTW_ASSIGN(orderBy, "DMSHTO DESC")
          @DTW_ASSIGN(orderByDisplay, "Ship To (descending)")
      %else
          @DTW_ASSIGN(orderBy, "DMSHTO")
          @DTW_ASSIGN(orderByDisplay, "Ship To")
      %endif
  %elif (sequence == "customerName")
      %if (orderBy == "CMCNA1")
          @DTW_ASSIGN(orderBy, "CMCNA1 DESC")
          @DTW_ASSIGN(orderByDisplay, "Customer Name (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CMCNA1")
          @DTW_ASSIGN(orderByDisplay, "Customer Name")
      %endif
  %elif (sequence == "requiredDate")
      %if (orderBy == "DMRQDT")
          @DTW_ASSIGN(orderBy, "DMRQDT DESC")
          @DTW_ASSIGN(orderByDisplay, "Required Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "DMRQDT")
          @DTW_ASSIGN(orderByDisplay, "Required Date")
      %endif
  %elif (sequence == "quantity")
      %if (orderBy == "DMQTYO")
          @DTW_ASSIGN(orderBy, "DMQTYO DESC")
          @DTW_ASSIGN(orderByDisplay, "Quantity Open (descending)")
      %else
          @DTW_ASSIGN(orderBy, "DMQTYO")
          @DTW_ASSIGN(orderByDisplay, "Quantity Open")
      %endif
  %elif (sequence == "picked")
      %if (orderBy == "DMTKFG")
          @DTW_ASSIGN(orderBy, "DMTKFG DESC")
          @DTW_ASSIGN(orderByDisplay, "Picked (descending)")
      %else
          @DTW_ASSIGN(orderBy, "DMTKFG")
          @DTW_ASSIGN(orderByDisplay, "Picked")
      %endif
  %elif (sequence == "shipped")
      %if (orderBy == "DMSHPF")
          @DTW_ASSIGN(orderBy, "DMSHPF DESC")
          @DTW_ASSIGN(orderByDisplay, "Shipped (descending)")
      %else
          @DTW_ASSIGN(orderBy, "DMSHPF")
          @DTW_ASSIGN(orderByDisplay, "Shipped")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}