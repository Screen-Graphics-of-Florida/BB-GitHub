%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Mobile Order Review"
  d2wName                 = "MbOrderReview.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;customerCity=@dtw_rurlescseq(customerCity)&amp;customerState=@dtw_rurlescseq(customerState)&amp;customerWhs=@dtw_rurlescseq(customerWhs)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
  RPT_MAX_ROWS            = "1000"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "MbHead.icl"
          <script TYPE="text/javascript">
              function confirmCancel() {return confirm("Confirm Cancel Of Order")}
              function confirmDelete(text) {return confirm("$(delRecordConf)" + text);}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "MbBanner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "SELECT OEDTWK.*, digits(IMUPC) as IMUPC ", stmtSQL)
                      @dtw_concat(fileSQL, " OEDTWK inner join HDIMST on O1ITEM=IMITEM ", fileSQL)
                      @dtw_concat(selectSQL, "O1OCTL=$(orderControlNumber) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By O1ORL# ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Mobile_Order_Review(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "MbTrailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Mobile_Order_Review (IN CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <tr>
              <td class="hdrdata"><h2>$(customerName)</h2>$(customerCity), $(customerState)</td>
              <td class="hdrdata">$(mbLogo)</td>
          </tr>
      </table>

      <a href="$(homeURL)$(cGIPath)MbOrderEntry.d2w/ENTRY$(d2wVarBase)&amp;maintenanceCode=A&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">$(mbOrderBack)</a>
      <a href="$(homeURL)$(cGIPath)MbOrderAccept.d2w/REPORT$(d2wVarBase)">$(mbOrderContinue)</a>
      <a onClick="return confirmCancel()" href="$(homeURL)$(cGIPath)MbOrderAccept.d2w/CANCEL$(d2wVarBase)">$(mbOrderCancel)</a>

      <table $(contentTable)>
          <tr>
              <th class="colhdr">$(optionHeading)</th>
              <th class="colhdr">UPC</th>
              <th class="colhdr">QTY</th>
          </tr>

          %ROW {
              %INCLUDE "SetRowClass.icl"
              @Format_Nbr(V_O1QORD, F_O1QORD, "0", $(qtyEditCode), "Y", "", "")

              <tr class="$(rowClass)">
                  <td class=colicon>
                      @Format_Confirm_Desc($(V_IMUPC), "", "", "", "", "", confirmDesc)
                      <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)$(d2wName)/REMOVELINE$(d2wVarBase)&amp;lineNumber=@dtw_rurlescseq(V_O1ORL#)">$(deleteImageSml)</a>
                  </td>
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)MbOrderEntry.d2w/ENTRY$(d2wVarBase)&amp;lineNumber=@dtw_rurlescseq(V_O1ORL#)&amp;maintenanceCode=C" title="Change Qty">$(V_IMUPC)</a></td>
                  <td class="colnmbr">$(F_O1QORD)</td>
              </tr>
          %}
      </table>
      <a href="$(homeURL)$(cGIPath)MbOrderEntry.d2w/ENTRY$(d2wVarBase)&amp;maintenanceCode=A&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">$(mbOrderBack)</a>
      <a href="$(homeURL)$(cGIPath)MbOrderAccept.d2w/REPORT$(d2wVarBase)">$(mbOrderContinue)</a>
      <a onClick="return confirmCancel()" href="$(homeURL)$(cGIPath)MbOrderAccept.d2w/CANCEL$(d2wVarBase)">$(mbOrderCancel)</a>
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(updateTotal, "Y")
  @Update_Misc_Charges (profileHandle, dataBaseID, orderControlNumber, freightCharge, specialCharge, updateTotal)
  @Set_SQL(stmtSQL)
%}

%HTML(REMOVELINE) {
  %INCLUDE "setLibraryList.icl"
  @Remove_Line (profileHandle, dataBaseID, orderControlNumber, lineNumber)
  @DTW_ASSIGN(updateTotal, "Y")
  @Update_Misc_Charges (profileHandle, dataBaseID, orderControlNumber, freightCharge, specialCharge, updateTotal)
  @RtvFldDesc("O1OCTL=$(orderControlNumber) and O1BLN#=0", "OEDTWK", " char(count(O1ITEM))", numberOfItems)
  %if (numberOfItems > "0")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)">
  %else
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)MbOrderEntry.d2w/ENTRY$(d2wVarBase)&amp;maintenanceCode=A&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}