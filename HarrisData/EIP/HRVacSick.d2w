%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Vacation And Sick Accrual Rates"
  d2wName                 = "HRVacSick.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPRVSM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "VACSICKACCR")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select VSVSAC, VSSVMO, VSVMXA, VSVMXR, VSSMXA, VSSMXR, VSVHRS, VSSHRS ", stmtSQL)
                      @dtw_concat(fileSQL, " PRACVS ", fileSQL)
                      %if (wildCardSearch!="" || uv_Sql!="")
                          @dtw_concat(selectSQL, "VSVSAC<>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Accrual_Inquiry(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Accrual_Inquiry (IN CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count != "1")
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1> $(page_title) </h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if ((backHome != "")  && (backHome != "$(d2wName)/report"))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"
          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Accrual<br>Code</th></tr>
                      <tr><td><input type="text" class="inputalph" name="srchAccrual" size="2" maxlength="2">
                              <input type="hidden" name="operAccrual" value="LIKE">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchAccrual.focus();
                  </script>
              </form>

              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("VSVSAC", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=AccrCode" title="Sequence By Accrual Code, Months Of Service">Accrual<br>Code</a></th>
                  @OrderBy_Sort("VSSVMO", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MonthsOfService" title="Sequence By Months Of Service, Accrual Code">Months Of<br>Service</a></th>
                  <th class="colhdr">Vacation Annual<br>Maximum Hours</th>
                  <th class="colhdr">Vacation<br>Max Rollover</th>
                  <th class="colhdr">Sick Annual<br>Maximum Hours</th>
                  <th class="colhdr">Sick<br>Max Rollover</th>
              </tr>
          %INCLUDE "NoRecordsFound.icl"
      %endif

              %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;accrualCode=@dtw_rurlescseq(V_VSVSAC)&amp;accrualMonths=@dtw_rurlescseq(V_VSSVMO)")
                  %if (sql_Record_Count == "1")
                      @Save_WebReg(webRegCurFile, profileHandle, d2wName, "", orderBy, orderByDisplay, "")
                      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)HRVacSickSelect.d2w/REPORT$(maintainVar)">
                  %else
                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          <td class="colcode"><a href="$(homeURL)$(cGIPath)HRVacSickSelect.d2w/REPORT$(maintainVar)" title="View Vacation/Sick Accrual Rates">$(V_VSVSAC)</a></td>
                          <td class="colcode">$(V_VSSVMO)</td>
                          @Format_Nbr($(V_VSVMXA), F_VSVMXA, "2", $(hrsEditCode), "", "", "")
                          <td class="colnmbr">$(F_VSVMXA)</td>
                          %if (V_VSVMXR == ".00")
                              @dtw_assign(V_VSVMXR, "")
                              <td class="colnmbr">$(V_VSVMXR)</td>
                          %else
                              @Format_Nbr($(V_VSVMXR), F_VSVMXR, "2", $(hrsEditCode), "", "", "")
                              <td class="colnmbr">$(F_VSVMXR)</td>
                          %endif
                          @Format_Nbr($(V_VSSMXA), F_VSSMXA, "2", $(hrsEditCode), "", "", "")
                          <td class="colnmbr">$(F_VSSMXA)</td>
                          %if (V_VSSMXR == ".00")
                              @dtw_assign(V_VSSMXR, "")
                              <td class="colnmbr">$(V_VSSMXR)</td>
                          %else
                              @Format_Nbr($(V_VSSMXR), F_VSSMXR, "2", $(hrsEditCode), "", "", "")
                              <td class="colnmbr">$(F_VSSMXR)</td>
                          %endif
                      </tr>
                  %endif
              %}
          </table>
          %if (sql_Record_Count != "1")
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "Select * ", stmtSQL)
  @dtw_concat(fileSQL, " PRACVS ", fileSQL)
  %if (wildCardSearch!="" || uv_Sql!="")
      @dtw_concat(selectSQL, "VSVSAC<>' ' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @Accrual_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) Accrual_XMLQuery (IN CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("AccrualRateList")
          %ROW{

               @XMLIDTag(V_VSVSAC, "Accrual ID")
                   @XMLTag(V_VSVSAC, "VacSickAccrualCode")
                   @XMLTag(V_VSSVMO, "VacSickMonthsOfService")
                   @XMLTag(V_VSVHRS, "VacationPayPeriodAccrualHrs")
                   @XMLTag(V_VSVFAC, "VacationHrlyAccrualFactor")
                   @XMLTag(V_VSVMXA, "VacationAnnualMaximumHrs")
                   @XMLTag(V_VSVMXR, "VacationMaximumRolloverHrs")
                   @XMLTag(V_VSVYR,  "VacationCalendarOrFiscalYear")
                   @XMLTag(V_VSVBAL, "VacationBalanceOption")
                   @XMLTag(V_VSSHRS, "SickPayPeriodAccrualHrs")
                   @XMLTag(V_VSSFAC, "SickHrlyAccrualFactor")
                   @XMLTag(V_VSSMXA, "SickAnnualMaximumHrs")
                   @XMLTag(V_VSSMXR, "SickMaximumRolloverHrs")
                   @XMLTag(V_VSSYR,  "SickCalendarOrFiscalYear")
                   @XMLTag(V_VSSBAL, "SickBalanceOption")
               @XMLEndTag("Accrual")
	   %}
      @XMLEndTag("AccrualRateList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (sec_05 == "N")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)progOptSecError.d2w/DISPLAY$(genericVarBase)&amp;page_title=@dtw_rurlescseq(page_title)">
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "VSVSAC,VSSVMO")
              @DTW_ASSIGN(orderByDisplay, "Accrual Code, Months Of Service")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "AccrCode")
      %if (orderBy == "VSVSAC,VSSVMO")
          @DTW_ASSIGN(orderBy, "VSVSAC DESC,VSSVMO")
          @DTW_ASSIGN(orderByDisplay, "Accrual Code (descending), Months Of Service")
      %else
          @DTW_ASSIGN(orderBy, "VSVSAC,VSSVMO")
          @DTW_ASSIGN(orderByDisplay, "Accrual Code, Months Of Service")
      %endif
  %elseif (sequence == "MonthsOfService")
      %if (orderBy == "VSSVMO,VSVSAC")
          @DTW_ASSIGN(orderBy, "VSSVMO DESC,VSVSAC")
          @DTW_ASSIGN(orderByDisplay, "Months Of Service (descending), Accrual Code")
      %else
          @DTW_ASSIGN(orderBy, "VSSVMO,VSVSAC")
          @DTW_ASSIGN(orderByDisplay, "Months Of Service, Accrual Code")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("upper(VSVSAC)", "Accrual Code", $(srchAccrual), "U", operAccrual, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}