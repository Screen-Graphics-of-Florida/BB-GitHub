                         <td class="inputalph"><input type="text" name="itemUserDefNumHdg52" value="$(V_CIIN52)" size="15" maxlength="8"></td>
                     </tr>
                     @DspErrMsg(Err_CIINS5)

                     @SetTextOvr(Err_CIWAS1)
