                         <td class="inputalph"><input type="text" name="whsUserDefAlphScrDesc1" value="$(V_CIWAS1)" size="30" maxlength="23"></td>
                         <td class="inputalph"><input type="text" name="whsUserDefAlphHdg11" value="$(V_CIWA11)" size="15" maxlength="8"></td>
