              %}	

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HIVCTU_W.PGM %}
%}

%FUNCTION(dtw_directcall) Write_InvCtl_File (IN CHAR(50)  homePath,
                                             IN CHAR(50)  includePath,
                                             IN CHAR(50)  fileName)
{%EXEC {HIVCTL_I.PGM %}  	
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"

  @RtvFldDesc("", "IVCTRL", "Char(Count(*))", RecCount)
  %if (RecCount>"0")
      @dtw_assign(maintenanceCode,"C")
  %else
      @dtw_assign(maintenanceCode,"A")
  %endif

  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if ((sec_02 == "N" && sec_03 == "N" && maintenanceCode != "A") || (sec_01 == "N" && maintenanceCode == "A") || (sec_04 == "N" && maintenanceCode == "Z"))
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)progOptSecError.d2w/DISPLAY$(genericVarBase)&amp;page_title=@dtw_rurlescseq(page_title)">
  %else
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @yn02_Table_Query(profileHandle, dataBaseID, "YORN      ", yn02Table)
      @yn03_Table_Query(profileHandle, dataBaseID, "YORN      ", yn03Table)
      @yn04_Table_Query(profileHandle, dataBaseID, "YORN      ", yn04Table)
      @yn05_Table_Query(profileHandle, dataBaseID, "YORN      ", yn05Table)
      @yn06_Table_Query(profileHandle, dataBaseID, "YORN      ", yn06Table)
      @yn07_Table_Query(profileHandle, dataBaseID, "YORN      ", yn07Table)
      @yn08_Table_Query(profileHandle, dataBaseID, "YORN      ", yn08Table)
      @yn09_Table_Query(profileHandle, dataBaseID, "YORN      ", yn09Table)
      @yn10_Table_Query(profileHandle, dataBaseID, "YORN      ", yn10Table)

      @Set_SQL(stmtSQL)
  %endif
%}


%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(reclaimResourceLevel)
  @dtw_mUPPERCASE(glDistributionFeed)
  @dtw_mUPPERCASE(lotRelief)
  @dtw_mUPPERCASE(autoLotRelief)
  @dtw_mUPPERCASE(startingLotNumber)
  @dtw_mUPPERCASE(autoRcvMfgOrder)
  @dtw_mUPPERCASE(useSmartPart)
  @dtw_mUPPERCASE(useCatalog)
  @dtw_mUPPERCASE(allowSubstitutes)
  @dtw_mUPPERCASE(transferStockroom)
  @dtw_mUPPERCASE(transferAisle)
  @dtw_mUPPERCASE(transferLoc)

  @dtw_assign(accountNumber,@dtw_rstrip(accountNumber))
  @dtw_assign(subaccountNumber,@dtw_rstrip(subaccountNumber))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@rioa", refreshInvOffsetAcct)
  @Concat_Field("@@ivgl", feedIVToGL)
  @Concat_Field("@@intc", genInterCoTrans)
  @Concat_Field("@@auto", restoreIVFeedIfErrors)
  @Concat_Field("@@per@", ivDistributionPeriod)
  @Concat_Field("@@ivaa", accountNumber)
  @Concat_Field("@@ivas", subaccountNumber)
  @Concat_Field("@@ltus", lotControlActive)
  @Concat_Field("@@lcse", lotCostValToBeActual)
  @Concat_Field("@@slt@", startingLotNumber)
  @Concat_Field("@@ltrl", lotRelief)
  @Concat_Field("@@lrlf", autoLotRelief)
  @Concat_Field("@@almi", allowMulItemsPerLot)
  @Concat_Field("@@lus1", lotUserDefScrDesc1)
  @Concat_Field("@@lus2", lotUserDefScrDesc2)
  @Concat_Field("@@lus3", lotUserDefScrDesc3)
  @Concat_Field("@@lu11", lotUserDefinedHeading11)
  @Concat_Field("@@lu12", lotUserDefinedHeading12)
  @Concat_Field("@@lu21", lotUserDefinedHeading21)
  @Concat_Field("@@lu22", lotUserDefinedHeading22)
  @Concat_Field("@@lu31", lotUserDefinedHeading31)
  @Concat_Field("@@lu32", lotUserDefinedHeading32)
  @Concat_Field("@@feds", glDistributionFeed)
  @Concat_Field("@@stkl", stockLocatorActive)
  @Concat_Field("@@tags", allowTagsToBeReused)
  @Concat_Field("@@ooia", includeOnOrderQty)
  @Concat_Field("@@ias1", itemUserDefAlphScrDesc1)
  @Concat_Field("@@ias2", itemUserDefAlphScrDesc2)
  @Concat_Field("@@ias3", itemUserDefAlphScrDesc3)
  @Concat_Field("@@ias4", itemUserDefAlphScrDesc4)
  @Concat_Field("@@ias5", itemUserDefAlphScrDesc5)
  @Concat_Field("@@ia11", itemUserDefAlphHdg11)
  @Concat_Field("@@ia12", itemUserDefAlphHdg12)
  @Concat_Field("@@ia21", itemUserDefAlphHdg21)
  @Concat_Field("@@ia22", itemUserDefAlphHdg22)
  @Concat_Field("@@ia31", itemUserDefAlphHdg31)
  @Concat_Field("@@ia32", itemUserDefAlphHdg32)
  @Concat_Field("@@ia41", itemUserDefAlphHdg41)
  @Concat_Field("@@ia42", itemUserDefAlphHdg42)
  @Concat_Field("@@ia51", itemUserDefAlphHdg51)
  @Concat_Field("@@ia52", itemUserDefAlphHdg52)
  @Concat_Field("@@ins1", itemUserDefNumScrDesc1)
  @Concat_Field("@@ins2", itemUserDefNumScrDesc2)
  @Concat_Field("@@ins3", itemUserDefNumScrDesc3)
  @Concat_Field("@@ins4", itemUserDefNumScrDesc4)
  @Concat_Field("@@ins5", itemUserDefNumScrDesc5)
  @Concat_Field("@@in11", itemUserDefNumHdg11)
  @Concat_Field("@@in12", itemUserDefNumHdg12)
  @Concat_Field("@@in21", itemUserDefNumHdg21)
  @Concat_Field("@@in22", itemUserDefNumHdg22)
  @Concat_Field("@@in31", itemUserDefNumHdg31)
  @Concat_Field("@@in32", itemUserDefNumHdg32)
  @Concat_Field("@@in41", itemUserDefNumHdg41)
  @Concat_Field("@@in42", itemUserDefNumHdg42)
  @Concat_Field("@@in51", itemUserDefNumHdg51)
  @Concat_Field("@@in52", itemUserDefNumHdg52)
  @Concat_Field("@@was1", whsUserDefAlphScrDesc1)
  @Concat_Field("@@was2", whsUserDefAlphScrDesc2)
  @Concat_Field("@@was3", whsUserDefAlphScrDesc3)
  @Concat_Field("@@wa11", whsUserDefAlphHdg11)
  @Concat_Field("@@wa12", whsUserDefAlphHdg12)
  @Concat_Field("@@wa21", whsUserDefAlphHdg21)
  @Concat_Field("@@wa22", whsUserDefAlphHdg22)
  @Concat_Field("@@wa31", whsUserDefAlphHdg31)
  @Concat_Field("@@wa32", whsUserDefAlphHdg32)
  @Concat_Field("@@wns1", whsUserDefNumScrDesc1)
  @Concat_Field("@@wns2", whsUserDefNumScrDesc2)
  @Concat_Field("@@wns3", whsUserDefNumScrDesc3)
  @Concat_Field("@@wn11", whsUserDefNumHdg11)
  @Concat_Field("@@wn12", whsUserDefNumHdg12)
  @Concat_Field("@@wn21", whsUserDefNumHdg21)
  @Concat_Field("@@wn22", whsUserDefNumHdg22)
  @Concat_Field("@@wn31", whsUserDefNumHdg31)
  @Concat_Field("@@wn32", whsUserDefNumHdg32)
  @Concat_Field("@@rclr", reclaimResourceLevel)
  @Concat_Field("@@tstp", originalTimeStamp)
  @Concat_Field("@@itm1", lastCfgItemNumber)
  @Concat_Field("@@itm2", lastNonCfgItemNumber)
  @Concat_Field("@@armo", autoRcvMfgOrder)
  @Concat_Field("@@usmp", useSmartPart)
  @Concat_Field("@@uvct", useCatalog)
  @Concat_Field("@@asub", allowSubstitutes)
  @Concat_Field("@@trsr", transferStockroom)
  @Concat_Field("@@trai", transferAisle)
  @Concat_Field("@@trlc", transferLoc)
  @Concat_Field("@@cwhs", corporateWhs)
  @Concat_Field("@@ltrt", lastTransferNumber)
  %if (itemExtCat1 != "" || itemExtCat2 != "" || itemExtCat3 != "" || itemExtCat4 != "" || itemExtCat5 != "")
      @Concat_Field("@@trud", transCat)
  %endif
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @dtw_assign(fileName, "InventoryControl$(dataBaseID).icl")
      @Write_InvCtl_File(homePath, includePath, fileName)
      @Format_ConfMsg_Desc(maintenanceCode, "I/V Control", "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(backHome)$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}