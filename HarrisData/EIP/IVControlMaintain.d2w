%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "I/V Control Maintenance"
  d2wName                 = "IVControlMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName             = "HIVCTU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "dateedit.icl"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.ivDistributionPeriod.value =="" ||
                      document.Chg.reclaimResourceLevel.value =="" ||
                      document.Chg.glDistributionFeed.value =="")
                         {alert("$(reqFieldError)"); return false;}
                  %if (V_HDVLCH=="Y")
                      if (document.Chg.accountNumber.value =="" &&
                          document.Chg.subaccountNumber.value =="")
                             {alert("$(reqFieldError)");
                             document.Chg.accountNumber.focus();
                             document.Chg.accountNumber();
                             return false;}
                  %endif
                  if (editNum(document.Chg.ivDistributionPeriod, 4, 0) &&
                      editNum(document.Chg.accountNumber, 4, 0) &&
                      editNum(document.Chg.subaccountNumber, 4, 0) &&
                      editNum(document.Chg.lastCfgItemNumber, 15, 0) &&
                      editNum(document.Chg.lastNonCfgItemNumber, 15, 0) &&
                      editNum(document.Chg.corporateWhs, 3, 0) &&
                      editNum(document.Chg.lastTransferNumber, 8, 0))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
	             %INCLUDE "numedit.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "IVCONTROLMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, " Select IVCTRL.*, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(CXITM1,0) as CXITM1, coalesce(CXITM2,0) as CXITM2, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(CXARMO,' ') as CXARMO, coalesce(CXUSMP,' ') as CXUSMP, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(CXUVCT,' ') as CXUVCT, coalesce(CXASUB,' ') as CXASUB, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(CXTRSR,' ') as CXTRSR, coalesce(CXTRAI,' ') as CXTRAI, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(CXTRLC,' ') as CXTRLC, coalesce(CXLTRT,0) as CXLTRT, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(CXCWHS,0) as CXCWHS, coalesce(CXTRUD,0) as CXTRUD ", stmtSQL)
                          @dtw_concat(fileSQL, " IVCTRL left join IVCTRX on rrn(IVCTRX)=1 ", fileSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
   </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN  CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @dtw_assign(sec_03, "N")
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "ivDistributionPeriod")
                      %else
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@tstp", "ivDistributionPeriod")    @dtw_assign(Err_CITSTP, fieldValue)
                          @DecatErr_Field("@@rioa", "refreshInvOffsetAcct")    @dtw_assign(Err_CIRIOA, fieldValue)
                          @DecatErr_Field("@@ivgl", "feedIVToGL")              @dtw_assign(Err_CIIVGL, fieldValue)
                          @DecatErr_Field("@@intc", "genInterCoTrans")         @dtw_assign(Err_CIINTC, fieldValue)
                          @DecatErr_Field("@@auto", "restoreIVFeedIfErrors")   @dtw_assign(Err_CIAUTO, fieldValue)
                          @DecatErr_Field("@@per@", "ivDistributionPeriod")    @dtw_assign(Err_CIPER#, fieldValue)
                          @DecatErr_Field("@@ivaa", "accountNumber")           @dtw_assign(Err_CIIVAA, fieldValue)
                          @DecatErr_Field("@@ivas", "subaccountNumber")        @dtw_assign(Err_CIIVAS, fieldValue)
                          @DecatErr_Field("@@ltus", "lotControlActive")        @dtw_assign(Err_CILTUS, fieldValue)
                          @DecatErr_Field("@@lcse", "lotCostValToBeActual")    @dtw_assign(Err_CILCSE, fieldValue)
                          @DecatErr_Field("@@slt@", "startingLotNumber")       @dtw_assign(Err_CISLT#, fieldValue)
                          @DecatErr_Field("@@ltrl", "lotRelief")               @dtw_assign(Err_CILTRL, fieldValue)
                          @DecatErr_Field("@@lrlf", "autoLotRelief")           @dtw_assign(Err_CILRLF, fieldValue)
                          @DecatErr_Field("@@almi", "allowMulItemsPerLot")     @dtw_assign(Err_CIALMI, fieldValue)
                          @DecatErr_Field("@@lus1", "lotUserDefScrDesc1")      @dtw_assign(Err_CILUS1, fieldValue)
                          @DecatErr_Field("@@lus2", "lotUserDefScrDesc2")      @dtw_assign(Err_CILUS2, fieldValue)
                          @DecatErr_Field("@@lus3", "lotUserDefScrDesc3")      @dtw_assign(Err_CILUS3, fieldValue)
                          @DecatErr_Field("@@lu11", "lotUserDefinedHeading11") @dtw_assign(Err_CILU11, fieldValue)
                          @DecatErr_Field("@@lu12", "lotUserDefinedHeading12") @dtw_assign(Err_CILU12, fieldValue)
                          @DecatErr_Field("@@lu21", "lotUserDefinedHeading21") @dtw_assign(Err_CILU21, fieldValue)
                          @DecatErr_Field("@@lu22", "lotUserDefinedHeading22") @dtw_assign(Err_CILU22, fieldValue)
                          @DecatErr_Field("@@lu31", "lotUserDefinedHeading31") @dtw_assign(Err_CILU31, fieldValue)
                          @DecatErr_Field("@@lu32", "lotUserDefinedHeading32") @dtw_assign(Err_CILU32, fieldValue)
                          @DecatErr_Field("@@feds", "glDistributionFeed")      @dtw_assign(Err_CIFEDS, fieldValue)
                          @DecatErr_Field("@@stkl", "stockLocatorActive")      @dtw_assign(Err_CISTKL, fieldValue)
                          @DecatErr_Field("@@tags", "allowTagsToBeReused")     @dtw_assign(Err_CITAGS, fieldValue)
                          @DecatErr_Field("@@ooia", "includeOnOrderQty")       @dtw_assign(Err_CIOOIA, fieldValue)
                          @DecatErr_Field("@@ias1", "itemUserDefAlphScrDesc1") @dtw_assign(Err_CIIAS1, fieldValue)
                          @DecatErr_Field("@@ias2", "itemUserDefAlphScrDesc2") @dtw_assign(Err_CIIAS2, fieldValue)
                          @DecatErr_Field("@@ias3", "itemUserDefAlphScrDesc3") @dtw_assign(Err_CIIAS3, fieldValue)
                          @DecatErr_Field("@@ias4", "itemUserDefAlphScrDesc4") @dtw_assign(Err_CIIAS4, fieldValue)
                          @DecatErr_Field("@@ias5", "itemUserDefAlphScrDesc5") @dtw_assign(Err_CIIAS5, fieldValue)
                          @DecatErr_Field("@@ia11", "itemUserDefAlphHdg11")    @dtw_assign(Err_CIIA11, fieldValue)
                          @DecatErr_Field("@@ia12", "itemUserDefAlphHdg12")    @dtw_assign(Err_CIIA12, fieldValue)
                          @DecatErr_Field("@@ia21", "itemUserDefAlphHdg21")    @dtw_assign(Err_CIIA21, fieldValue)
                          @DecatErr_Field("@@ia22", "itemUserDefAlphHdg22")    @dtw_assign(Err_CIIA22, fieldValue)
                          @DecatErr_Field("@@ia31", "itemUserDefAlphHdg31")    @dtw_assign(Err_CIIA31, fieldValue)
                          @DecatErr_Field("@@ia32", "itemUserDefAlphHdg32")    @dtw_assign(Err_CIIA32, fieldValue)
                          @DecatErr_Field("@@ia41", "itemUserDefAlphHdg41")    @dtw_assign(Err_CIIA41, fieldValue)
                          @DecatErr_Field("@@ia42", "itemUserDefAlphHdg42")    @dtw_assign(Err_CIIA42, fieldValue)
                          @DecatErr_Field("@@ia51", "itemUserDefAlphHdg51")    @dtw_assign(Err_CIIA51, fieldValue)
                          @DecatErr_Field("@@ia52", "itemUserDefAlphHdg52")    @dtw_assign(Err_CIIA52, fieldValue)
                          @DecatErr_Field("@@ins1", "itemUserDefNumScrDesc1")  @dtw_assign(Err_CIINS1, fieldValue)
                          @DecatErr_Field("@@ins2", "itemUserDefNumScrDesc2")  @dtw_assign(Err_CIINS2, fieldValue)
                          @DecatErr_Field("@@ins3", "itemUserDefNumScrDesc3")  @dtw_assign(Err_CIINS3, fieldValue)
                          @DecatErr_Field("@@ins4", "itemUserDefNumScrDesc4")  @dtw_assign(Err_CIINS4, fieldValue)
                          @DecatErr_Field("@@ins5", "itemUserDefNumScrDesc5")  @dtw_assign(Err_CIINS5, fieldValue)
                          @DecatErr_Field("@@in11", "itemUserDefNumHdg11")     @dtw_assign(Err_CIIN11, fieldValue)
                          @DecatErr_Field("@@in12", "itemUserDefNumHdg12")     @dtw_assign(Err_CIIN12, fieldValue)
                          @DecatErr_Field("@@in21", "itemUserDefNumHdg21")     @dtw_assign(Err_CIIN21, fieldValue)
                          @DecatErr_Field("@@in22", "itemUserDefNumHdg22")     @dtw_assign(Err_CIIN22, fieldValue)
                          @DecatErr_Field("@@in31", "itemUserDefNumHdg31")     @dtw_assign(Err_CIIN31, fieldValue)
                          @DecatErr_Field("@@in32", "itemUserDefNumHdg32")     @dtw_assign(Err_CIIN32, fieldValue)
                          @DecatErr_Field("@@in41", "itemUserDefNumHdg41")     @dtw_assign(Err_CIIN41, fieldValue)
                          @DecatErr_Field("@@in42", "itemUserDefNumHdg42")     @dtw_assign(Err_CIIN42, fieldValue)
                          @DecatErr_Field("@@in51", "itemUserDefNumHdg51")     @dtw_assign(Err_CIIN51, fieldValue)
                          @DecatErr_Field("@@in52", "itemUserDefNumHdg52")     @dtw_assign(Err_CIIN52, fieldValue)
                          @DecatErr_Field("@@was1", "whsUserDefAlphScrDesc1")  @dtw_assign(Err_CIWAS1, fieldValue)
                          @DecatErr_Field("@@was2", "whsUserDefAlphScrDesc2")  @dtw_assign(Err_CIWAS2, fieldValue)
                          @DecatErr_Field("@@was3", "whsUserDefAlphScrDesc3")  @dtw_assign(Err_CIWAS3, fieldValue)
                          @DecatErr_Field("@@wa11", "whsUserDefAlphHdg11")     @dtw_assign(Err_CIWA11, fieldValue)
                          @DecatErr_Field("@@wa12", "whsUserDefAlphHdg12")     @dtw_assign(Err_CIWA12, fieldValue)
                          @DecatErr_Field("@@wa21", "whsUserDefAlphHdg21")     @dtw_assign(Err_CIWA21, fieldValue)
                          @DecatErr_Field("@@wa22", "whsUserDefAlphHdg22")     @dtw_assign(Err_CIWA22, fieldValue)
                          @DecatErr_Field("@@wa31", "whsUserDefAlphHdg31")     @dtw_assign(Err_CIWA31, fieldValue)
                          @DecatErr_Field("@@wa32", "whsUserDefAlphHdg32")     @dtw_assign(Err_CIWA32, fieldValue)
                          @DecatErr_Field("@@wn11", "whsUserDefNumHdg11")      @dtw_assign(Err_CIWN11, fieldValue)
                          @DecatErr_Field("@@wn12", "whsUserDefNumHdg12")      @dtw_assign(Err_CIWN12, fieldValue)
                          @DecatErr_Field("@@wn21", "whsUserDefNumHdg21")      @dtw_assign(Err_CIWN21, fieldValue)
                          @DecatErr_Field("@@wn22", "whsUserDefNumHdg22")      @dtw_assign(Err_CIWN12, fieldValue)
                          @DecatErr_Field("@@wn31", "whsUserDefNumHdg31")      @dtw_assign(Err_CIWN31, fieldValue)
                          @DecatErr_Field("@@wn32", "whsUserDefNumHdg32")      @dtw_assign(Err_CIWN32, fieldValue)
                          @DecatErr_Field("@@rclr", "reclaimResourceLevel")    @dtw_assign(Err_CIRCLR, fieldValue)
                          @DecatErr_Field("@@itm1", "lastCfgItemNumber")       @dtw_assign(Err_CXITM1, fieldValue)
                          @DecatErr_Field("@@itm2", "lastNonCfgItemNumber")    @dtw_assign(Err_CXITM2, fieldValue)
                          @DecatErr_Field("@@armo", "autoRcvMfgOrder")         @dtw_assign(Err_CXARMO, fieldValue)
                          @DecatErr_Field("@@usmp", "useSmartPart")            @dtw_assign(Err_CXUSMP, fieldValue)
                          @DecatErr_Field("@@uvct", "useCatalog")              @dtw_assign(Err_CXUVCT, fieldValue)
                          @DecatErr_Field("@@asub", "allowSubstitutes")        @dtw_assign(Err_CXASUB, fieldValue)
                          @DecatErr_Field("@@trsr", "transferStockroom")       @dtw_assign(Err_CXTRSR, fieldValue)
                          @DecatErr_Field("@@cwhs", "corporateWhs")            @dtw_assign(Err_CXCWHS, fieldValue)
                          @DecatErr_Field("@@ltrt", "lastTransferNumber")      @dtw_assign(Err_CXLTRT, fieldValue)
                      %endif

                      @Decat_Field("@@rioa")   @dtw_assign(V_CIRIOA, fieldValue)
                      @Decat_Field("@@ivgl")   @dtw_assign(V_CIIVGL, fieldValue)
                      @Decat_Field("@@intc")   @dtw_assign(V_CIINTC, fieldValue)
                      @Decat_Field("@@auto")   @dtw_assign(V_CIAUTO, fieldValue)
                      @Decat_Field("@@per@")   @dtw_assign(V_CIPER#, fieldValue)
                      @Decat_Field("@@ivaa")   @dtw_assign(V_CIIVAA, fieldValue)
                      @Decat_Field("@@ivas")   @dtw_assign(V_CIIVAS, fieldValue)
                      @Decat_Field("@@ltus")   @dtw_assign(V_CILTUS, fieldValue)
                      @Decat_Field("@@lcse")   @dtw_assign(V_CILCSE, fieldValue)
                      @Decat_Field("@@slt@")   @dtw_assign(V_CISLT#, fieldValue)
                      @Decat_Field("@@ltrl")   @dtw_assign(V_CILTRL, fieldValue)
                      @Decat_Field("@@lrlf")   @dtw_assign(V_CILRLF, fieldValue)
                      @Decat_Field("@@almi")   @dtw_assign(V_CIALMI, fieldValue)
                      @Decat_Field("@@lus1")   @dtw_assign(V_CILUS1, fieldValue)
                      @Decat_Field("@@lus2")   @dtw_assign(V_CILUS2, fieldValue)
                      @Decat_Field("@@lus3")   @dtw_assign(V_CILUS3, fieldValue)
                      @Decat_Field("@@lu11")   @dtw_assign(V_CILU11, fieldValue)
                      @Decat_Field("@@lu12")   @dtw_assign(V_CILU12, fieldValue)
                      @Decat_Field("@@lu21")   @dtw_assign(V_CILU21, fieldValue)
                      @Decat_Field("@@lu22")   @dtw_assign(V_CILU22, fieldValue)
                      @Decat_Field("@@lu31")   @dtw_assign(V_CILU31, fieldValue)
                      @Decat_Field("@@lu32")   @dtw_assign(V_CILU32, fieldValue)
                      @Decat_Field("@@feds")   @dtw_assign(V_CIFEDS, fieldValue)
                      @Decat_Field("@@stkl")   @dtw_assign(V_CISTKL, fieldValue)
                      @Decat_Field("@@tags")   @dtw_assign(V_CITAGS, fieldValue)
                      @Decat_Field("@@ooia")   @dtw_assign(V_CIOOIA, fieldValue)
                      @Decat_Field("@@ias1")   @dtw_assign(V_CIIAS1, fieldValue)
                      @Decat_Field("@@ias2")   @dtw_assign(V_CIIAS2, fieldValue)
                      @Decat_Field("@@ias3")   @dtw_assign(V_CIIAS3, fieldValue)
                      @Decat_Field("@@ias4")   @dtw_assign(V_CIIAS4, fieldValue)
                      @Decat_Field("@@ias5")   @dtw_assign(V_CIIAS5, fieldValue)
                      @Decat_Field("@@ia11")   @dtw_assign(V_CIIA11, fieldValue)
                      @Decat_Field("@@ia12")   @dtw_assign(V_CIIA12, fieldValue)
                      @Decat_Field("@@ia21")   @dtw_assign(V_CIIA21, fieldValue)
                      @Decat_Field("@@ia22")   @dtw_assign(V_CIIA22, fieldValue)
                      @Decat_Field("@@ia31")   @dtw_assign(V_CIIA31, fieldValue)
                      @Decat_Field("@@ia32")   @dtw_assign(V_CIIA32, fieldValue)
                      @Decat_Field("@@ia41")   @dtw_assign(V_CIIA41, fieldValue)
                      @Decat_Field("@@ia42")   @dtw_assign(V_CIIA42, fieldValue)
                      @Decat_Field("@@ia51")   @dtw_assign(V_CIIA51, fieldValue)
                      @Decat_Field("@@ia52")   @dtw_assign(V_CIIA52, fieldValue)
                      @Decat_Field("@@ins1")   @dtw_assign(V_CIINS1, fieldValue)
                      @Decat_Field("@@ins2")   @dtw_assign(V_CIINS2, fieldValue)
                      @Decat_Field("@@ins3")   @dtw_assign(V_CIINS3, fieldValue)
                      @Decat_Field("@@ins4")   @dtw_assign(V_CIINS4, fieldValue)
                      @Decat_Field("@@ins5")   @dtw_assign(V_CIINS5, fieldValue)
                      @Decat_Field("@@in11")   @dtw_assign(V_CIIN11, fieldValue)
                      @Decat_Field("@@in12")   @dtw_assign(V_CIIN12, fieldValue)
                      @Decat_Field("@@in21")   @dtw_assign(V_CIIN21, fieldValue)
                      @Decat_Field("@@in22")   @dtw_assign(V_CIIN22, fieldValue)
                      @Decat_Field("@@in31")   @dtw_assign(V_CIIN31, fieldValue)
                      @Decat_Field("@@in32")   @dtw_assign(V_CIIN32, fieldValue)
                      @Decat_Field("@@in41")   @dtw_assign(V_CIIN41, fieldValue)
                      @Decat_Field("@@in51")   @dtw_assign(V_CIIN51, fieldValue)
                      @Decat_Field("@@in52")   @dtw_assign(V_CIIN52, fieldValue)
                      @Decat_Field("@@was1")   @dtw_assign(V_CIWAS1, fieldValue)
                      @Decat_Field("@@was2")   @dtw_assign(V_CIWAS2, fieldValue)
                      @Decat_Field("@@was3")   @dtw_assign(V_CIWAS3, fieldValue)
                      @Decat_Field("@@wa11")   @dtw_assign(V_CIWA11, fieldValue)
                      @Decat_Field("@@wa12")   @dtw_assign(V_CIWA12, fieldValue)
                      @Decat_Field("@@wa21")   @dtw_assign(V_CIWA21, fieldValue)
                      @Decat_Field("@@wa22")   @dtw_assign(V_CIWA22, fieldValue)
                      @Decat_Field("@@wa31")   @dtw_assign(V_CIWA31, fieldValue)
                      @Decat_Field("@@wa32")   @dtw_assign(V_CIWA32, fieldValue)
                      @Decat_Field("@@wns1")   @dtw_assign(V_CIWNS1, fieldValue)
                      @Decat_Field("@@wns2")   @dtw_assign(V_CIWNS2, fieldValue)
                      @Decat_Field("@@wns3")   @dtw_assign(V_CIWNS3, fieldValue)
                      @Decat_Field("@@wn11")   @dtw_assign(V_CIWN11, fieldValue)
                      @Decat_Field("@@wn12")   @dtw_assign(V_CIWN12, fieldValue)
                      @Decat_Field("@@wn21")   @dtw_assign(V_CIWN21, fieldValue)
                      @Decat_Field("@@wn22")   @dtw_assign(V_CIWN22, fieldValue)
                      @Decat_Field("@@wn31")   @dtw_assign(V_CIWN31, fieldValue)
                      @Decat_Field("@@wn32")   @dtw_assign(V_CIWN32, fieldValue)
                      @Decat_Field("@@rclr")   @dtw_assign(V_CIRCLR, fieldValue)
                      @Decat_Field("@@tstp")   @dtw_assign(V_CITSTP, fieldValue)
                      @Decat_Field("@@itm1")   @dtw_assign(V_CXITM1, fieldValue)
                      @Decat_Field("@@itm2")   @dtw_assign(V_CXITM2, fieldValue)
                      @Decat_Field("@@armo")   @dtw_assign(V_CXARMO, fieldValue)
                      @Decat_Field("@@usmp")   @dtw_assign(V_CXUSMP, fieldValue)
                      @Decat_Field("@@uvct")   @dtw_assign(V_CXUVCT, fieldValue)
                      @Decat_Field("@@asub")   @dtw_assign(V_CXASUB, fieldValue)
                      @Decat_Field("@@trsr")   @dtw_assign(V_CXTRSR, fieldValue)
                      @Decat_Field("@@trai")   @dtw_assign(V_CXTRAI, fieldValue)
                      @Decat_Field("@@trlc")   @dtw_assign(V_CXTRLC, fieldValue)
                      @Decat_Field("@@cwhs")   @dtw_assign(V_CXCWHS, fieldValue)
                      @Decat_Field("@@ltrt")   @dtw_assign(V_CXLTRT, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "ivDistributionPeriod")
                          @dtw_assign(V_CIRCLR, "O")
                          @dtw_assign(V_CIRIOA, "N")
                          @dtw_assign(V_CIIVGL, "N")
                          @dtw_assign(V_CIAUTO, "Y")
                          @dtw_assign(V_CIINTC, "N")
                          @dtw_assign(V_CILTUS, "N")
                          @dtw_assign(V_CILCSE, "N")
                          @dtw_assign(V_CIFEDS, "D")
                      %endif

                      @dtw_assign(errFound, "")

                  %else
                      @dtw_assign(focusField, "ivDistributionPeriod")
                      @PeriodInputFromCYP(V_CIPER#)
                  %endif

                  <table $(contentTable)>
                      @SetTextOvr(Err_CITSTP)
                      <tr><td class="dsphdr"><span $(textOvr)>I/V Release Version</span></td>
                              <td class="inputnmbr"><input name="ivReleaseVersion" type="hidden" value="$(V_HDINRL)" size="5" maxlength="5">$(V_HDINRL)</td>
                      </tr>
                      @DspErrMsg(Err_CITSTP)

                      @SetTextOvr(Err_HDINLL)
                      <tr><td class="dsphdr"><span $(textOvr)>I/V Library Level</span></td>
                              <td class="inputnmbr"><input name="ivLibraryLevel" type="hidden" value="$(V_HDINLL)" size="3" maxlength="3">$(V_HDINLL)</td>
                      </tr>
