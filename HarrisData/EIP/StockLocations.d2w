%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Stock Locations"
  d2wName                 = "StockLocations.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;forWhs=@dtw_rurlescseq(forWhs)&amp;forItemNumber=@dtw_rurlescseq(forItemNumber)&amp;fldStkr=@dtw_rurlescseq(fldStkr)&amp;fldAisle=@dtw_rurlescseq(fldAisle)&amp;fldLoc=@dtw_rurlescseq(fldLoc)&amp;fldStkID=@dtw_rurlescseq(fldStkID)&amp;fldLotNumber=@dtw_rurlescseq(fldLotNumber)&amp;inclInclZero=@dtw_rurlescseq(inclInclZero)&amp;fldLotControlled=@dtw_rurlescseq(fldLotControlled)&amp;touchScreen=@dtw_rurlescseq(touchScreen)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  novcf                   = ""
  docName                 = ""
  forItemNumber           = ""
  fldStkr                 = ""
  fldAisle                = ""
  fldLoc                  = ""
  fldStkID                = ""
  fldLotNumber            = ""
  inclInclZero                = ""
  fldLotControlled        = "$(fldLotControlled)"
  saveSQL                 = ""
  advanceSearch           = "N"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
           
              <script TYPE="text/javascript">
                                      
                  function selectStkLoc(stockRoom, aisle, location, stockID){
                  	  window.opener.document.$(docName).$(fldStkr).value = stockRoom;
                      window.opener.document.$(docName).$(fldAisle).value = aisle;
                      window.opener.document.$(docName).$(fldLoc).value = location;
                      window.opener.document.$(docName).$(fldStkID).value = stockID;
                      %if (touchScreen != "Y")
                          window.opener.document.$(docName).$(fldStkr).focus();
                      %endif
                      window.close();
                  }
                  function selectStkLocLot(stockRoom, aisle, location, stockID, lotNumber){
                  	  window.opener.document.$(docName).$(fldStkr).value = stockRoom;
                      window.opener.document.$(docName).$(fldAisle).value = aisle;
                      window.opener.document.$(docName).$(fldLoc).value = location;
                      window.opener.document.$(docName).$(fldStkID).value = stockID;
                      window.opener.document.$(docName).$(fldLotNumber).value = lotNumber;
                      %if (touchScreen != "Y")
                          window.opener.document.$(docName).$(fldStkr).focus();
                      %endif
                      window.close();
                  }
                                    
    	          %INCLUDE "NumEdit.icl"
                  %INCLUDE "CheckEnterSearch.icl"
                  function validate(searchForm) {
                      if (%if (forWhs > "0")
                              editNum(document.Search.srchWhs, 3, 0) &&
                          %endif
                          editNum(document.Search.srchPriority, 1, 0)
                  		 )
                      return true;
                  }
                  
                            
                  %if (touchScreen == "Y")
                      %INCLUDE "KeyboardFunctionsTS.icl"
                  %endif
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "$(searchBanner)"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " HDITSL ", fileSQL)
                          @dtw_concat(selectSQL, "ISITEM='$(forItemNumber)'", selectSQL)
                          %if (inclInclZero != "Y")
                              @dtw_concat(selectSQL, " and ISQOH<>0 ", selectSQL)
                          %endif
                          %if (forWhs > "0")
                              @dtw_concat(selectSQL, "  and ISWHS=$(forWhs) ", selectSQL)
                          %elif (wildCardSearch!="")
                              @dtw_concat(selectSQL, " and ISWHS<>0 ", selectSQL)
                          %endif
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @dtw_assign(saveSQL, stmtSQL)
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @StockLoc_Search(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "$(searchTrailer)"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) StockLoc_Search (IN CHAR(64)    profileHandle,
     	                                CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
  	  %if (touchScreen == "Y")
          @dtw_assign(displayCloseIcon, "Y")
      %endif
      %INCLUDE "PageTitle.icl"
            
      %if (forWhs > "0")
          @RtvFldDesc("WHWHS=$(forWhs)", "HDWHSM", "WHWHNM", warehouseName)
          <table $(contentTable)>
              @Format_Header("Warehouse", $(warehouseName), $(forWhs))
          </table>
      %endif
      <table $(contentTable)>
      
      @RtvFldDesc("IMITEM='$(forItemNumber)'", "HDIMST", "IMIMDS", itemDescription)
              @Format_Code($(forItemNumber), F_itemNumber)
              	<tr><td class="hdrtitl">Item:</td>
                  <td class="hdrdata">$(itemDescription) &nbsp; $(F_itemNumber)</td>
              </tr>
      </table>
      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                
      
       
                  <tr>
                      %if (forWhs == "")
                          <th class="colhdr">Whs</th>
                      %endif
                      <th class="colhdr" colspan="3">Stock Location</th>
                      <th class="colhdr">Priority</th>
                      %if (fldLotControlled != "N")
                      <th class="colhdr">Lot</th>
                      %endif
                  </tr>
                  <tr>
                      %if (forWhs == "")
                          <td class="inputalph">
                          	  %if (touchScreen == "Y")
                                  <input class="input" id="srchWhs" onfocus="kbActive(this, 'numericKeyboard');" name="srchWhs" type="text" size="3" maxlength="3">
                                  <input type="hidden" id="submitSearch">
                              %else
                              <input type="text" name="srchWhs" size="3" maxlength="3">
                              %endif
                              <input type="hidden" name="operWhs" value="=">
                          </td>
                      %endif
                      <td class="inputalph">
                      	  %if (touchScreen == "Y")
                              <input class="input" id="srchStkr" onfocus="kbActive(this, 'keyboard');" name="srchStkr" type="text" size="3" maxlength="3">
                          %else
                          <input type="text" name="srchStkr" size="3" maxlength="3">
                          %endif
                          <input type="hidden" name="operStkr" value="LIKE">
                      </td>
                      <td class="inputalph">
                      	  %if (touchScreen == "Y")
                              <input class="input" id="srchAisle" onfocus="kbActive(this, 'keyboard');" name="srchAisle" type="text" size="4" maxlength="4">
                          %else
                          <input type="text" name="srchAisle" size="4" maxlength="4">
                          %endif
                          <input type="hidden" name="operAisle" value="LIKE">
                      </td>
                      <td class="inputalph">
                      %if (touchScreen == "Y")
                              <input class="input" id="srchLoc" onfocus="kbActive(this, 'keyboard');" name="srchLoc" type="text" size="8" maxlength="8">
                          %else
                          <input type="text" name="srchLoc" size="8" maxlength="8">
                          %endif
                          <input type="hidden" name="operLoc" value="LIKE">
                      </td>
                      
                      <td>
                      	  %if (touchScreen == "Y")
                              <input class="input" id="srchPriority" onfocus="kbActive(this, 'numericKeyboard');" name="srchLoc" type="text" size="5" maxlength="1">
                          %else
                      		  <input type="text" class="inputalph" name="srchPriority" size="5" maxlength="1">
                      	  %endif	  
                          <input type="hidden" name="operPriority" value="=">
                      </td>
                      %if (fldLotControlled != "N")
                      <td class="inputalph">
                      	  %if (touchScreen == "Y")
                              <input class="input" id="srchLot" onfocus="kbActive(this, 'keyboard');" name="srchLot" type="text" size="15" maxlength="15">
                          %else
                          <input type="text" name="srchLot" size="15" maxlength="15">
                          %endif
                          <input type="hidden" name="operLot" value="LIKE">
                      </td>
                      %endif
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
                  
              </table>
              %if (touchScreen != "Y")
              <script TYPE="text/javascript">
                  %if (forWhs == "")
                      document.Search.srchWhs.focus();
                  %else
                      document.Search.srchStkr.focus();
                  %endif
              </script>
              %endif
                                   
          </form>
          
                   
		  %if (touchScreen == "Y")
		     @dtw_assign(pageSelectList, "N")
             @dtw_assign(wildCardDefault, "N")
             @dtw_assign(advanceSearch, "N")
          %endif
          
          
          	%if (inclInclZero == "Y")
      			@dtw_assign(inclInclZeroChecked, "CHECKED")
  			%else
      			@dtw_assign(inclInclZeroChecked, "")
  			%endif

  			  			
          @dtw_assign(viewCheckBox, "StockLocations")
          %INCLUDE "WildCardPage.icl"
         

          <table $(contentTable)>
          
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
               
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  %if (forWhs == "")
                      @OrderBy_Sort("ISWHS", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=warehouse" title="Sequence By Warehouse, Stock Location"> Whs</a></th>
                  %endif
                  @OrderBy_Sort("ISSTKR", sortVar)
                  <th class="colhdr$(sortVar)" colspan="3"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=stockLoc" title="Sequence By Stock Location"> Stock Location</a></th>
                  @OrderBy_Sort("ISRATE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=rate" title="Sequence By Priority, Stock Location"> Priority</a></th>
                  @OrderBy_Sort("ISQOH", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=qty" title="Sequence By Quantity, Stock Location"> Quantity</a></th>
                  %if (fldLotControlled != "N")
                  @OrderBy_Sort("ISLOT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=lot" title="Sequence By Lot, Stock Location"> Lot</a></th>
                  %endif
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %else
          <table $(contentTable)>
      %endif		

              %ROW{
                  %INCLUDE "SetRowClass.icl"
                  @Format_Quote(V_ISSTKR, F_ISSTKR)
                  @Format_Quote(V_ISAILE, F_ISAILE)
                  @Format_Quote(V_ISSLOC, F_ISSLOC)
                  @Format_Quote(V_ISLOT, F_ISLOT)
             

                  <tr class="$(rowClass)">
                      %if (forWhs == "")
                          <td class="colnmbr">$(V_ISWHS)</td>
                      %endif
                      %if (fldLotControlled != "N")
                      	<td class="colalph"><a href="javascript:selectStkLocLot('$(F_ISSTKR)','$(F_ISAILE)','$(F_ISSLOC)',$(V_ISSID#),'$(V_ISLOT)')" title="Select Stock Location">$(V_ISSTKR)</a></td>
                      	<td class="colalph"><a href="javascript:selectStkLocLot('$(F_ISSTKR)','$(F_ISAILE)','$(F_ISSLOC)',$(V_ISSID#),'$(V_ISLOT)')" title="Select Stock Location">$(V_ISAILE)</a></td>
                      	<td class="colalph"><a href="javascript:selectStkLocLot('$(F_ISSTKR)','$(F_ISAILE)','$(F_ISSLOC)',$(V_ISSID#),'$(V_ISLOT)')" title="Select Stock Location">$(V_ISSLOC)</a></td>
                      %else
                      	<td class="colalph"><a href="javascript:selectStkLoc('$(F_ISSTKR)','$(F_ISAILE)','$(F_ISSLOC)',$(V_ISSID#))" title="Select Stock Location">$(V_ISSTKR)</a></td>
                      	<td class="colalph"><a href="javascript:selectStkLoc('$(F_ISSTKR)','$(F_ISAILE)','$(F_ISSLOC)',$(V_ISSID#))" title="Select Stock Location">$(V_ISAILE)</a></td>
                      	<td class="colalph"><a href="javascript:selectStkLoc('$(F_ISSTKR)','$(F_ISAILE)','$(F_ISSLOC)',$(V_ISSID#))" title="Select Stock Location">$(V_ISSLOC)</a></td>
                      %endif
                      <td class="colcode">$(V_ISRATE)</td>
                      <td class="colnmbr">$(V_ISQOH)</td>
                      %if (fldLotControlled != "N")
                      <td class="colalph">$(V_ISLOT)</td>
                      %endif
                     
                  </tr>
              %}
          </table>
           
               
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
      %if (touchScreen == "Y")
         %INCLUDE "KeyboardTS.icl"
      %endif
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "ISWHS,ISSTKR,ISAILE,ISSLOC,ISLOT")
      @DTW_ASSIGN(orderByDisplay, "Warehouse, Stockroom, Aisle, Location, Lot")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %elif (chgInclZero == "Y" && inclInclZero == "Y")
              @dtw_assign(inclInclZero, "")
  %elif (chgInclZero == "Y")
              @dtw_assign(inclInclZero, "Y")
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  
  
  
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY)
{
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "warehouse")
      %if (orderBy == "ISWHS,ISSTKR,ISAILE,ISSLOC,ISLOT")
          @DTW_ASSIGN(orderBy, "ISWHS DESC,ISSTKR,ISAILE,ISSLOC,ISLOT")
          @DTW_ASSIGN(orderByDisplay, "Warehouse (descending), Stock Location")
      %else
          @DTW_ASSIGN(orderBy, "ISWHS,ISSTKR,ISAILE,ISSLOC,ISLOT")
          @DTW_ASSIGN(orderByDisplay, "Warehouse, Stock Location")
      %endif
  %elif (sequence == "stockLoc")
      %if (orderBy == "ISSTKR,ISAILE,ISSLOC,ISLOT")
          @DTW_ASSIGN(orderBy, "ISSTKR DESC,ISAILE,ISSLOC,ISLOT")
          @DTW_ASSIGN(orderByDisplay, "Stock Location (descending), Lot")
      %else
          @DTW_ASSIGN(orderBy, "ISSTKR,ISAILE,ISSLOC,ISLOT")
          @DTW_ASSIGN(orderByDisplay, "Stock Location, Lot")
      %endif
  %elif (sequence == "rate")
      %if (orderBy == "ISRATE,ISSTKR,ISAILE,ISSLOC,ISLOT")
          @DTW_ASSIGN(orderBy, "ISRATE DESC,ISSTKR,ISAILE,ISSLOC,ISLOT")
          @DTW_ASSIGN(orderByDisplay, "Priority (descending), Stock Location")
      %else
          @DTW_ASSIGN(orderBy, "ISRATE,ISSTKR,ISAILE,ISSLOC,ISLOT")
          @DTW_ASSIGN(orderByDisplay, "Priority, Stock Location")
      %endif
  %elif (sequence == "qty")
      %if (orderBy == "ISQOH,ISRATE,ISSTKR,ISAILE,ISSLOC,ISLOT")
          @DTW_ASSIGN(orderBy, "ISQOH DESC,ISRATE,ISSTKR,ISAILE,ISSLOC,ISLOT")
          @DTW_ASSIGN(orderByDisplay, "Quantity (descending), Priority")
      %else
          @DTW_ASSIGN(orderBy, "ISQOH,ISRATE,ISSTKR,ISAILE,ISSLOC,ISLOT")
          @DTW_ASSIGN(orderByDisplay, "Quantity, Priority")
      %endif    
  %elif (sequence == "lot")
      %if (orderBy == "ISLOT,ISRATE,ISSTKR,ISAILE,ISSLOC")
          @DTW_ASSIGN(orderBy, "ISLOT DESC,ISRATE,ISSTKR,ISAILE,ISSLOC")
          @DTW_ASSIGN(orderByDisplay, "Lot Number (descending), Priority")
      %else
          @DTW_ASSIGN(orderBy, "ISLOT,ISRATE,ISSTKR,ISAILE,ISSLOC")
          @DTW_ASSIGN(orderByDisplay, "Lot Number, Priority")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD)
{
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("ISWHS", "Warehouse", $(srchWhs), "", operWhs, "N")
  @Build_WildCard ("ISSTKR", "Stockroom", $(srchStkr), "U", operStkr, "A")
  @Build_WildCard ("ISAILE", "Aisle", $(srchAisle), "U", operAisle, "A")
  @Build_WildCard ("ISSLOC", "Location", $(srchLoc), "U", operLoc, "A")
  @Build_WildCard ("ISRATE", "Priority", $(srchPriority), "", operPriority, "N")
  
  %if (fldLotControlled != "N")
  @Build_WildCard ("ISLOT", "Lot", $(srchLot), "U", operLot, "A")
  %endif

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}