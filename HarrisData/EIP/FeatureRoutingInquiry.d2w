%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Feature Routing"
  d2wName                 = "FeatureRoutingInquiry.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;fromD2W=@dtw_rurlescseq(fromD2W)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "1000"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "1000"
  prtMaxRows              = "1000"
  rowIndexNext            = "1"
  totalPages              = "0"
  popUpWin                = "Y"
  sddesc                  = ""
  backGround              = ""
%}
	
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select FRSEQN, FRDEPT, FRWC, FRSON, FRRTYP, ", stmtSQL)
                      @dtw_concat(stmtSQL, " FRALTC, FRMPON, FRMHRS, FRMHRC, ' ' as MAHO, ", stmtSQL)
                      @dtw_concat(stmtSQL, " FRSUHR, FRSURC, FRMTD, FRMACH, FRRTGT, ", stmtSQL)
                      @dtw_concat(stmtSQL, " SAOPTN as FRFEAT, SAFEAT as FRFITM, ", stmtSQL)
                      @dtw_concat(stmtSQL, " substring(concat('Option/Feature: ',concat(trim (t from SAOPTN),concat('/',SAFEAT))) from 1 for 60) as ORIGIN, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce((select 'Error' from HDMRTM where RTPLT=$(plantNumber) and RTPN='$(itemNumber)' and RTSEQN=b.FRSEQN), '     ') as OVERLAY ", stmtSQL)
                      @dtw_concat(stmtSQL, " From HDFOPW a inner join HDMFRM b ", stmtSQL)
                      @dtw_concat(stmtSQL, " on a.SAOPTN=b.FRFEAT and a.SAFEAT=b.FRFITM and a.SAXHND='$(profileHandle)' and a.SAMNCD<>' ' and b.FRPLT=$(plantNumber) ", stmtSQL)

                      @dtw_concat(stmtSQL, " Union All ", stmtSQL)
                      @dtw_concat(stmtSQL, " Select FRSEQN, FRDEPT, FRWC, FRSON, FRRTYP, ", stmtSQL)
                      @dtw_concat(stmtSQL, " FRALTC, FRMPON, FRMHRS, FRMHRC, ' ' as MAHO, ", stmtSQL)
                      @dtw_concat(stmtSQL, " FRSUHR, FRSURC, FRMTD, FRMACH, FRRTGT, ", stmtSQL)
                      @dtw_concat(stmtSQL, " SAOPTN as FRFEAT, ' ' as FRFITM, ", stmtSQL)
                      @dtw_concat(stmtSQL, " substring(concat('Option: ', SAOPTN) from 1 for 60) as ORIGIN, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce((select 'Error' from HDMRTM where RTPLT=$(plantNumber) and RTPN='$(itemNumber)' and RTSEQN=d.FRSEQN), '     ') as OVERLAY ", stmtSQL)
                      @dtw_concat(stmtSQL, " From HDFOPW c inner join HDMFRM d ", stmtSQL)
                      @dtw_concat(stmtSQL, " on c.SAOPTN=d.FRFEAT and ' '=d.FRFITM and c.SAXHND='$(profileHandle)' and c.SAMNCD<>' ' and d.FRPLT=$(plantNumber) ", stmtSQL)
                      @dtw_concat(stmtSQL, " Where d.FRSEQN not in ", stmtSQL)
                      @dtw_concat(stmtSQL, "   (select f.FRSEQN from HDFOPW e inner join HDMFRM f on e.SAOPTN=f.FRFEAT and e.SAFEAT=f.FRFITM and e.SAXHND='$(profileHandle)' and e.SAMNCD<>' ' and f.FRPLT=$(plantNumber)) ", stmtSQL)

                      @dtw_concat(stmtSQL, " Union All ", stmtSQL)
                      @dtw_concat(stmtSQL, " Select FRSEQN, FRDEPT, FRWC, FRSON, FRRTYP, ", stmtSQL)
                      @dtw_concat(stmtSQL, " FRALTC, FRMPON, FRMHRS, FRMHRC, ' ' as MAHO, ", stmtSQL)
                      @dtw_concat(stmtSQL, " FRSUHR, FRSURC, FRMTD, FRMACH, FRRTGT, ", stmtSQL)
                      @dtw_concat(stmtSQL, " FRFEAT, FRFITM, ", stmtSQL)
                      @dtw_concat(stmtSQL, " substring(concat('Feature/Featured Item: ',concat(trim (t from SAFEAT),concat('/',coalesce(DGIGRP,'$(itemNumber)')))) from 1 for 60) as ORIGIN, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce((select 'Error' from HDMRTM where RTPLT=$(plantNumber) and RTPN='$(itemNumber)' and RTSEQN=h.FRSEQN), '     ') as OVERLAY ", stmtSQL)
                      @dtw_concat(stmtSQL, " From HDFOPW g inner join (HDMFRM h left join HDIGPD hh on 'F'=DGTYPE and FRFITM=DGIGRP and FRPLT=DGPLT) ", stmtSQL)
                      @dtw_concat(stmtSQL, " on g.SAFEAT=h.FRFEAT and ('$(itemNumber)'=h.FRFITM or '$(itemNumber)'=hh.DGITEM) and g.SAXHND='$(profileHandle)' and g.SAMNCD<>' ' and h.FRPLT=$(plantNumber) ", stmtSQL)
                      @dtw_concat(stmtSQL, " Where h.FRSEQN not in ", stmtSQL)
                      @dtw_concat(stmtSQL, "   (select j.FRSEQN from HDFOPW i inner join HDMFRM j on i.SAOPTN=j.FRFEAT and i.SAFEAT=j.FRFITM and i.SAXHND='$(profileHandle)' and i.SAMNCD<>' ' and j.FRPLT=$(plantNumber)) ", stmtSQL)
                      @dtw_concat(stmtSQL, "   and h.FRSEQN not in ", stmtSQL)
                      @dtw_concat(stmtSQL, "   (select l.FRSEQN from HDFOPW k inner join HDMFRM l on k.SAOPTN=l.FRFEAT and ' '=l.FRFITM and k.SAXHND='$(profileHandle)' and k.SAMNCD<>' ' and l.FRPLT=$(plantNumber)) ", stmtSQL)

                      @dtw_concat(stmtSQL, " Union All ", stmtSQL)
                      @dtw_concat(stmtSQL, " Select FRSEQN, FRDEPT, FRWC, FRSON, FRRTYP, ", stmtSQL)
                      @dtw_concat(stmtSQL, " FRALTC, FRMPON, FRMHRS, FRMHRC, ' ' as MAHO, ", stmtSQL)
                      @dtw_concat(stmtSQL, " FRSUHR, FRSURC, FRMTD, FRMACH, FRRTGT, ", stmtSQL)
                      @dtw_concat(stmtSQL, " FRFEAT, FRFITM, ", stmtSQL)
                      @dtw_concat(stmtSQL, " substring(concat('Feature: ', SAFEAT) from 1 for 60) as ORIGIN, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce((select 'Error' from HDMRTM where RTPLT=$(plantNumber) and RTPN='$(itemNumber)' and RTSEQN=n.FRSEQN), '     ') as OVERLAY ", stmtSQL)
                      @dtw_concat(stmtSQL, " From HDFOPW m inner join HDMFRM n ", stmtSQL)
                      @dtw_concat(stmtSQL, " on m.SAFEAT=n.FRFEAT and ' '=n.FRFITM and m.SAXHND='$(profileHandle)' and m.SAMNCD<>' ' and n.FRPLT=$(plantNumber) ", stmtSQL)
                      @dtw_concat(stmtSQL, " Where n.FRSEQN not in ", stmtSQL)
                      @dtw_concat(stmtSQL, "   (select p.FRSEQN from HDFOPW o inner join HDMFRM p on o.SAOPTN=p.FRFEAT and o.SAFEAT=p.FRFITM and o.SAXHND='$(profileHandle)' and o.SAMNCD<>' ' and p.FRPLT=$(plantNumber)) ", stmtSQL)
                      @dtw_concat(stmtSQL, "   and n.FRSEQN not in ", stmtSQL)
                      @dtw_concat(stmtSQL, "   (select r.FRSEQN from HDFOPW q inner join HDMFRM r on q.SAOPTN=r.FRFEAT and ' '=r.FRFITM and q.SAXHND='$(profileHandle)' and q.SAMNCD<>' ' and r.FRPLT=$(plantNumber)) ", stmtSQL)
                      @dtw_concat(stmtSQL, "   and n.FRSEQN not in ", stmtSQL)
                      @dtw_concat(stmtSQL, "   (select t.FRSEQN from HDFOPW s inner join (HDMFRM t left join HDIGPD hh on 'F'=DGTYPE and FRFITM=DGIGRP and FRPLT=DGPLT) on s.SAFEAT=t.FRFEAT and ('$(itemNumber)'=t.FRFITM or '$(itemNumber)'=hh.DGITEM) and s.SAXHND='$(profileHandle)' and s.SAMNCD<>' ' and t.FRPLT=$(plantNumber)) ", stmtSQL)

                      @dtw_concat(stmtSQL, " Union All ", stmtSQL)
                      @dtw_concat(stmtSQL, " Select RTSEQN as FRSEQN, RTDEPT as FRDEPT, RTWC as FRWC, RTSON as FRSON, RTRTYP as FRRTYP, ", stmtSQL)
                      @dtw_concat(stmtSQL, " RTALTC as FRALTC, RTMPON as FRMPON, RTMHRS as FRMHRS, RTMHRC as FRMHRC, RTMAHO as MAHO, ", stmtSQL)
                      @dtw_concat(stmtSQL, " RTSUHR as FRSUHR, RTSURC as FRSURC, RTMTD as FRMTD, RTMACH as FRMACH, 'S' as FRRTGT, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ' ' as FRFEAT, ' ' as FRFITM, ", stmtSQL)
                      @dtw_concat(stmtSQL, " 'Standard' as ORIGIN, ", stmtSQL)
                      @dtw_concat(stmtSQL, " '     ' as OVERLAY ", stmtSQL)
                      @dtw_concat(stmtSQL, " From HDMRTM ", stmtSQL)
                      @dtw_concat(stmtSQL, " Where RTPLT=$(plantNumber) and RTPN='$(itemNumber)' ", stmtSQL)

                      @dtw_concat(stmtSQL, " Order By FRSEQN, OVERLAY ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @FeatureRtg_Inquiry(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) FeatureRtg_Inquiry (IN CHAR(64)    profileHandle,
				           CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
  	       <col width="80%">
  	       <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  %INCLUDE "HelpPage.icl"
                  &nbsp;<a href="$(homeURL)$(cGIPath)$(fromD2W)/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;featuredItem=@dtw_rurlescseq(itemNumber)">$(closeImageMed)</a>
              </td>
          </tr>
      </table>

      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDesc)
      <table $(contentTable)>
          @Format_Header("Plant", $(plantName), $(plantNumber))
          @Format_Header("Item", $(itemDesc), $(itemNumber))
      </table>

      $(inquiryhrTagAttr)

      <table $(contentTable)>
          <tr>
              <th class="colhdr">Rtg<br>Seq</th>
              <th class="colhdr">Dept</th>
              <th class="colhdr">W/C</th>
              <th class="colhdr">Oper#</th>
              <th class="colhdr">R<br>T</th>
              <th class="colhdr">A<br>L</th>
              <th class="colhdr">Origin</th>
              <th class="colhdr">Crew<br>Size</th>
              <th class="colhdr" colspan="2">Measured<br>Hours</th>
              <th class="colhdr">Mach<br>Only</th>
              <th class="colhdr">Pcs/<br>Hour</th>
              <th class="colhdr" colspan="2">Setup<br>Hours</th>
              <th class="colhdr">Trn<br>Days</th>
              <th class="colhdr">Mach</th>
          </tr>

          %ROW{
              @Format_Nbr($(V_FRMPON), F_FRMPON, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_FRMHRS), F_FRMHRS, "4", $(hrsEditCode), "", "", "")
              @dtw_assign(W_PPHRS, "")
              %if (V_FRMHRS != "0")
                  %if (V_FRMHRC== "P")
                      @DTW_DIVIDE("1", V_FRMHRS, W_PPHRS)
                  %endif
                  %if (V_FRMHRC== "H")
                      @DTW_DIVIDE("100", V_FRMHRS, W_PPHRS)
                  %endif
                  %if (V_FRMHRC== "M")
                      @DTW_DIVIDE("1000", V_FRMHRS, W_PPHRS)
                  %endif
              %endif
              @Format_Nbr($(W_PPHRS), F_PPHRS, "0", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_FRSUHR), F_FRSUHR, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_FRMTD), F_FRMTD, "1", $(amtEditCode), "", "", "")
              <tr class="evenrow">
                 <td class="colnmbr">$(V_FRSEQN)</td>
                 <td class="colalph">$(V_FRDEPT)</td>
                 <td class="colalph">$(V_FRWC)</td>
                 <td class="colalph">$(V_FRSON)</td>
                 <td class="colcode">$(V_FRRTYP)</td>
                 <td class="colcode">$(V_FRALTC)</td>
                 <td class="colcode" $(helpCursor)><span title="$(V_ORIGIN)">$(V_FRRTGT)</span></td>
                 <td class="colnmbr">$(F_FRMPON)</td>
                 <td class="colnmbr">$(F_FRMHRS)</td>
                 <td class="colcode">$(V_FRMHRC)</td>
                 <td class="colcode">$(V_MAHO)</td>
                 <td class="colnmbr">$(F_PPHRS)</td>
                 <td class="colnmbr">$(F_FRSUHR)</td>
                 <td class="colcode">$(V_FRSURC)</td>
                 <td class="colnmbr">$(F_FRMTD)</td>
                 <td class="colalph">$(V_FRMACH)</td>
                 <td class="colalph">$(V_OVERLAY)</td>
              </tr>
              %if (V_FRSON != "")
                 @RtvFldDesc("SDSON='$(V_FRSON)'", "HDMSDM", "SDDESC", sddesc)
                 <tr><td>&nbsp;</td>
                     <td>&nbsp;</td>
                     <td>&nbsp;</td>
                     <td class="colalph" colspan="10">$(sddesc)</td>
                 </tr>
              %endif

              %INCLUDE "stmtSQLClear.icl"
              @dtw_concat(stmtSQL, " Select ODDOCT, ODLINE, ODDESC ", stmtSQL)
              %if (V_FRRTGT == "S")
                  @dtw_concat(fileSQL, " HDMODM ", fileSQL)
                  @dtw_concat(selectSQL, " ODPLT=$(plantNumber) and ODPN='$(itemNumber)' and ODSEQN=$(V_FRSEQN) ", selectSQL)
              %else
                  @dtw_concat(fileSQL, " HDMFOD ", fileSQL)
                  @dtw_concat(selectSQL, " ODPLT=$(plantNumber) and ODFEAT='$(V_FRFEAT)' and ODFITM='$(V_FRFITM)' and ODSEQN=$(V_FRSEQN) ", selectSQL)
              %endif
              %INCLUDE "stmtSQLSelect.icl"
              @dtw_concat(stmtSQL, " Order By ODDOCT, ODLINE ", stmtSQL)
              %INCLUDE "stmtSQLEnd.icl"
              @RtgNotes_Inquiry(profileHandle, dataBaseID, stmtSQL)

          %}
      </table>
      $(inquiryhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_sql) RtgNotes_Inquiry (IN CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @dtw_assign(first, "Y")
         %ROW{
            %if (first == "Y")
               @dtw_assign(first, "")
               <tr><td class="colalph" colspan=14  >&nbsp; &nbsp; &nbsp; Notes:</td></tr>
            %endif
            <tr><td class="colalph" colspan=14  >&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; $(V_ODDESC)</td></tr>
         %}
  %}
%}

%FUNCTION(dtw_directcall) Load_Feature_Option (INOUT CHAR(64)  profileHandle,
                                               INOUT CHAR(32000) edtVar,
                                               INOUT CHAR(32000) errVar,
                                               INOUT CHAR(1)     errFound)

{%EXEC {HSCFOP_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@item", itemNumber)
  @Concat_Field("@@mncd", "L")
  @dtw_concat(edtVar, "}{", edtVar)

  @Load_Feature_Option(profileHandle, edtVar, errVar, errFound)

  @Set_SQL(stmtSQL)
%}