                                  @Build_Sort_Select("sortRoutingSequence", "$(V_SEQSQ)")
                                  <td align=center ><input name="totalRoutingSequence" type="checkbox" $(checkedRoutingSequenceTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_SEQSQ)

