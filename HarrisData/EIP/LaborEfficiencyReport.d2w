                                  <td class="inputnmbr"><input name="fromEmployeeNumber" value="$(V_TREM1)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)EmployeeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=prCompany&amp;fldFacl=prFacility&amp;fldEmpl=fromEmployeeNumber&amp;fldHRCo=hrCompany&amp;fldHREmpl=hrEmployee&amp;fldEmplName=prName&amp;fldCoName=coFacDescription" onclick="$(searchWinVar)">$(searchImage)</a><input name="prCompany" type="hidden"><input name="prFacility" type="hidden"><input name="hrEmployee" type="hidden"><input name="hrCompany"  type="hidden"><input name="prName"  type="hidden"><input name="coFacDescription"  type="hidden"></td>
                                  <td class="inputnmbr"><input name="toEmployeeNumber" value="$(V_TREM2)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)EmployeeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=prCompany&amp;fldFacl=prFacility&amp;fldEmpl=toEmployeeNumber&amp;fldHRCo=hrCompany&amp;fldHREmpl=hrEmployee&amp;fldEmplName=prName&amp;fldCoName=coFacDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="prCompany" type="hidden"><input name="prFacility" type="hidden"><input name="hrEmployee" type="hidden"><input name="hrCompany" type="hidden"><input name="prName"  type="hidden"><input name="coFacDescription"  type="hidden"></td>
                                  <td class="inputalph"><input name="allEmployeeNumber" value='ALL' $(checkedallEmployeeNumber) type="checkbox" onClick="if (this.checked) this.form.fromEmployeeNumber.value='', this.form.toEmployeeNumber.value='';"></td>
                                  @Build_Sort_Select("sortEmployeeNumber", "$(V_SEQEM)")
                                  <td align=center ><input name="totalEmployeeNumber" type="checkbox" $(checkedEmployeeNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_SEQEM)

