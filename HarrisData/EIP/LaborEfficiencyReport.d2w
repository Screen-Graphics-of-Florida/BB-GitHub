                                  @Decat_Field("@@srtg")  @dtw_assign(V_SEQSQ,  fieldValue)
                                  @Decat_Field("@@prtg")  @dtw_assign(V_TRPSQ,  fieldValue)

                                  @Decat_Field("@@ftyp")  @dtw_assign(V_TRLT1,  fieldValue)
                                  @Decat_Field("@@ttyp")  @dtw_assign(V_TRLT2,  fieldValue)
                                  @Decat_Field("@@atyp")  @dtw_assign(V_ALLLT,  fieldValue)
                                  @Decat_Field("@@styp")  @dtw_assign(V_SEQLT,  fieldValue)
                                  @Decat_Field("@@ptyp")  @dtw_assign(V_TRPLT,  fieldValue)

                                  @Decat_Field("@@flc@")  @dtw_assign(V_TRLC1,  fieldValue)
                                  @Decat_Field("@@tlc@")  @dtw_assign(V_TRLC2,  fieldValue)
                                  @Decat_Field("@@alc@")  @dtw_assign(V_ALLLC,  fieldValue)
                                  @Decat_Field("@@slc@")  @dtw_assign(V_SEQLC,  fieldValue)
                                  @Decat_Field("@@plc@")  @dtw_assign(V_TRPLC,  fieldValue)

                                  @Decat_Field("@@fsc@")  @dtw_assign(V_TRSC1,  fieldValue)
                                  @Decat_Field("@@tsc@")  @dtw_assign(V_TRSC2,  fieldValue)
                                  @Decat_Field("@@asc@")  @dtw_assign(V_ALLSC,  fieldValue)
                                  @Decat_Field("@@ssc@")  @dtw_assign(V_SEQSC,  fieldValue)
                                  @Decat_Field("@@psc@")  @dtw_assign(V_TRPSC,  fieldValue)

                                  @Decat_Field("@@evdo")  @dtw_assign(V_TREVDO,  fieldValue)
                                  @Decat_Field("@@evdu")  @dtw_assign(V_TREVDU,  fieldValue)

                                  @Decat_Field("@@evpo")  @dtw_assign(V_TREVPO,  fieldValue)
                                  @Decat_Field("@@evpu")  @dtw_assign(V_TREVPU,  fieldValue)

                                  @Decat_Field("@@scpo")  @dtw_assign(V_TRSCPO,  fieldValue)
                                  @Decat_Field("@@scpu")  @dtw_assign(V_TRSCPU,  fieldValue)

                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries
 Values %}
                                  %if (V_N1OPT == "02")
                                      @dtw_assign(detail, "")
                                      @dtw_assign(summary, "CHECKED")
                                  %else
                                      @dtw_assign(detail, "CHECKED")
                                      @dtw_assign(summary, "")
                                  %endif
                                  %if (V_N2OPT == "02")
                                      @dtw_assign(labor, "")
                                      @dtw_assign(machine, "CHECKED")
                                  %else
                                      @dtw_assign(labor, "CHECKED")
                                      @dtw_assign(machine, "")
                                  %endif
                                  %if (V_N3APLT == "ALL")
