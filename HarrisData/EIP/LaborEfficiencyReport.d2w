                                  <td class="inputalph"><input name="toLaborType" value="$(V_TRLT2)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="allLaborType" value='ALL' $(checkedallLaborType) type="checkbox" onClick="if (this.checked) this.form.fromLaborType.value='', this.form.toLaborType.value='';"></td>
                                  @Build_Sort_Select("sortLaborType", "$(V_SEQLT)")
                                  <td align=center ><input name="totalLaborType" type="checkbox" $(checkedLaborTypeTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_SEQLT)

                              @SetTextOvr(Err_SEQLC)
                              <tr><td class="dsphdr"><span $(textOvr)>Labor Code</span></td>
                                  <td class="inputalph"><input name="fromLaborCode" value="$(V_TRLC1)" type="text" size="2" maxlength="2"></td>
                                  <td class="inputalph"><input name="toLaborCode" value="$(V_TRLC2)" type="text" size="2" maxlength="2"></td>
                                  <td class="inputalph"><input name="allLaborCode" value='ALL' $(checkedallLaborCode) type="checkbox" onClick="if (this.checked) this.form.fromLaborCode.value='', this.form.toLaborCode.value='';"></td>
                                  @Build_Sort_Select("sortLaborCode", "$(V_SEQLC)")
                                  <td align=center ><input name="totalLaborCode" type="checkbox" $(checkedLaborCodeTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_SEQLC)

                              @SetTextOvr(Err_SEQSC)
                              <tr><td class="dsphdr"><span $(textOvr)>Scrap Code</span></td>
                                  <td class="inputalph"><input name="fromScrapCode" value="$(V_TRSC1)" type="text" size="2" maxlength="2"></td>
                                  <td class="inputalph"><input name="toScrapCode" value="$(V_TRSC2)" type="text" size="2" maxlength="2"></td>
                                  <td class="inputalph"><input name="allScrapCode" value='ALL' $(checkedallScrapCode) type="checkbox" onClick="if (this.checked) this.form.fromScrapCode.value='', this.form.toScrapCode.value='';"></td>
                                  @Build_Sort_Select("sortScrapCode", "$(V_SEQSC)")
                                  <td align=center ><input name="totalScrapCode" type="checkbox" $(checkedScrapCodeTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_SEQSC)

                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">Over</td>
                                  <td class="colhdr">Under</td>
                              </tr>

                              @SetTextOvr(Err_TREVDO)
                              %if (textOvr == "") @SetTextOvr(Err_TREVDU) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Labor Efficiency Var $</span></td>
                                  <td class="inputnmbr"><input name="amtOver" value="$(V_TREVDO)" type="text" size="8" maxlength="8"></td>
                                  <td class="inputnmbr"><input name="amtUnder" value="$(V_TREVDU)" type="text" size="8" maxlength="8"></td>
                              </tr>
                              @DspErrMsg(Err_TREVDO)
                              @DspErrMsg(Err_TREVDU)

                              @SetTextOvr(Err_TREVPO)
