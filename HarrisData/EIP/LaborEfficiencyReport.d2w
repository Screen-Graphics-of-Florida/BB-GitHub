                                  <td class="inputalph"><input name="toWorkCenter" value="$(V_TRWC2)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=toDepartment&amp;fldWC=toWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="allWorkCenter" value='ALL' $(checkedallWorkCenter) type="checkbox" onClick="if (this.checked) this.form.fromWorkCenter.value='', this.form.toWorkCenter.value='';"></td>
                                  @Build_Sort_Select("sortWorkCenter", "$(V_SEQWC)")
                                  <td align=center ><input name="totalWorkCenter" type="checkbox" $(checkedWorkCenterTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_SEQWC)

                              @SetTextOvr(Err_SEQMA)
                              <tr><td class="dsphdr"><span $(textOvr)>Machine Number</span></td>
                                  <td class="inputalph"><input name="fromMachineNumber" value="$(V_TRMA1)" type="text" size="5" maxlength="5"></td>
