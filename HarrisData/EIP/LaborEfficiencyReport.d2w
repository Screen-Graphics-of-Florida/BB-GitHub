                                  <td class="inputnmbr"><input name="percentOver" value="$(V_TREVPO)" type="text" size="8" maxlength="8"></td>
                                  <td class="inputnmbr"><input name="percentUnder" value="$(V_TREVPU)" type="text" size="8" maxlength="8"></td>
                              </tr>
