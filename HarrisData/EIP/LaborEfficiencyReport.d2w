                              <tr><td class="dsphdr"><span $(textOvr)>Scrap Percent</span></td>
                                  <td class="inputnmbr"><input name="scrapOver" value="$(V_TRSCPO)" type="text" size="8" maxlength="8"></td>
                                  <td class="inputnmbr"><input name="scrapUnder" value="$(V_TRSCPU)" type="text" size="8" maxlength="8"></td>
                              </tr>
                              @DspErrMsg(Err_TRSCPO)
                              @DspErrMsg(Err_TRSCPU)

                          </table>

                          @dtw_assign(envProgram, "HSI312")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSI912_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allPlantNumber)
  @dtw_mUPPERCASE(fromDepartment)
  @dtw_mUPPERCASE(toDepartment)
  @dtw_mUPPERCASE(allDepartment)
  @dtw_mUPPERCASE(fromWorkCenter)
  @dtw_mUPPERCASE(toWorkCenter)
  @dtw_mUPPERCASE(allWorkCenter)
  @dtw_mUPPERCASE(fromMachineNumber)
  @dtw_mUPPERCASE(toMachineNumber)
  @dtw_mUPPERCASE(allMachineNumber)
  @dtw_mUPPERCASE(allDateWorked)
  @dtw_mUPPERCASE(allShiftWorked)
  @dtw_mUPPERCASE(allEmployeeNumber)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(fromOrderNumber)
  @dtw_mUPPERCASE(toOrderNumber)
  @dtw_mUPPERCASE(allOrderNumber)
  @dtw_mUPPERCASE(allRoutingSequence)
  @dtw_mUPPERCASE(fromLaborType)
  @dtw_mUPPERCASE(toLaborType)
  @dtw_mUPPERCASE(allLaborType)
  @dtw_mUPPERCASE(fromLaborCode)
  @dtw_mUPPERCASE(toLaborCode)
  @dtw_mUPPERCASE(allLaborCode)
  @dtw_mUPPERCASE(fromScrapCode)
  @dtw_mUPPERCASE(toScrapCode)
  @dtw_mUPPERCASE(allScrapCode)

  @dtw_assign(fromPlantNumber,@dtw_rstrip(fromPlantNumber))
  @dtw_assign(toPlantNumber,@dtw_rstrip(toPlantNumber))
  @dtw_assign(sortPlantNumber,@dtw_rstrip(sortPlantNumber))
  @dtw_assign(sortDepartment,@dtw_rstrip(sortDepartment))
  @dtw_assign(sortWorkCenter,@dtw_rstrip(sortWorkCenter))
  @dtw_assign(sortMachineNumber,@dtw_rstrip(sortMachineNumber))
  @dtw_assign(fromDateWorked,@dtw_rstrip(fromDateWorked))
  @dtw_assign(toDateWorked,@dtw_rstrip(toDateWorked))
  @dtw_assign(sortDateWorked,@dtw_rstrip(sortDateWorked))
  @dtw_assign(fromShiftWorked,@dtw_rstrip(fromShiftWorked))
  @dtw_assign(toShiftWorked,@dtw_rstrip(toShiftWorked))
  @dtw_assign(sortShiftWorked,@dtw_rstrip(sortShiftWorked))
  @dtw_assign(fromEmployeeNumber,@dtw_rstrip(fromEmployeeNumber))
  @dtw_assign(toEmployeeNumber,@dtw_rstrip(toEmployeeNumber))
  @dtw_assign(sortEmployeeNumber,@dtw_rstrip(sortEmployeeNumber))
  @dtw_assign(sortItemNumber,@dtw_rstrip(sortItemNumber))
  @dtw_assign(sortOrderNumber,@dtw_rstrip(sortOrderNumber))
  @dtw_assign(fromRoutingSequence,@dtw_rstrip(fromRoutingSequence))
  @dtw_assign(toRoutingSequence,@dtw_rstrip(toRoutingSequence))
  @dtw_assign(sortRoutingSequence,@dtw_rstrip(sortRoutingSequence))
  @dtw_assign(sortLaborType,@dtw_rstrip(sortLaborType))
  @dtw_assign(sortLaborCode,@dtw_rstrip(sortLaborCode))
  @dtw_assign(sortScrapCode,@dtw_rstrip(sortScrapCode))
  @dtw_assign(amtOver,@dtw_rstrip(amtOver))
  @dtw_assign(amtUnder,@dtw_rstrip(amtUnder))
  @dtw_assign(percentOver,@dtw_rstrip(percentOver))
  @dtw_assign(percentUnder,@dtw_rstrip(percentUnder))
  @dtw_assign(scrapOver,@dtw_rstrip(scrapOver))
  @dtw_assign(scrapUnder,@dtw_rstrip(scrapUnder))

  %if (allPlantNumber != "ALL")
      @dtw_assign(allPlantNumber, "")
  %endif
  %if (allDepartment != "ALL")
      @dtw_assign(allDepartment, "")
  %endif
  %if (allWorkCenter != "ALL")
      @dtw_assign(allWorkCenter, "")
  %endif
  %if (allMachineNumber != "ALL")
      @dtw_assign(allMachineNumber, "")
  %endif
  %if (allDateWorked != "ALL")
      @dtw_assign(allDateWorked, "")
  %endif
  %if (allShiftWorked != "ALL")
      @dtw_assign(allShiftWorked, "")
  %endif
  %if (allEmployeeNumber != "ALL")
      @dtw_assign(allEmployeeNumber, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allOrderNumber != "ALL")
      @dtw_assign(allOrderNumber, "")
  %endif
  %if (allRoutingSequence != "ALL")
      @dtw_assign(allRoutingSequence, "")
  %endif
  %if (allLaborType != "ALL")
      @dtw_assign(allLaborType, "")
  %endif
  %if (allLaborCode != "ALL")
      @dtw_assign(allLaborCode, "")
  %endif
  %if (allScrapCode != "ALL")
      @dtw_assign(allScrapCode, "")
  %endif

  @dtw_assign(totalPlantNumber, "Y")

  %if (totalDepartment != "Y")
      @dtw_assign(totalDepartment, "N")
  %endif
  %if (totalWorkCenter != "Y")
      @dtw_assign(totalWorkCenter, "N")
  %endif
  %if (totalMachineNumber != "Y")
      @dtw_assign(totalMachineNumber, "N")
  %endif
  %if (totalDateWorked != "Y")
      @dtw_assign(totalDateWorked, "N")
  %endif
  %if (totalShiftWorked != "Y")
      @dtw_assign(totalShiftWorked, "N")
  %endif
  %if (totalEmployeeNumber != "Y")
      @dtw_assign(totalEmployeeNumber, "N")
  %endif
  %if (totalItemNumber != "Y")
      @dtw_assign(totalItemNumber, "N")
  %endif
  %if (totalOrderNumber != "Y")
      @dtw_assign(totalOrderNumber, "N")
  %endif
  %if (totalRoutingSequence != "Y")
      @dtw_assign(totalRoutingSequence, "N")
  %endif
  %if (totalLaborType != "Y")
      @dtw_assign(totalLaborType, "N")
  %endif
  %if (totalLaborCode != "Y")
      @dtw_assign(totalLaborCode, "N")
  %endif
  %if (totalScrapCode != "Y")
      @dtw_assign(totalScrapCode, "N")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@opt1", reportSelection)
  @Concat_Field("@@opt2", efficiencySelection)

  @Concat_Field("@@fplt", fromPlantNumber)
  @Concat_Field("@@tplt", toPlantNumber)
  @Concat_Field("@@aplt", allPlantNumber)
  @Concat_Field("@@splt", sortPlantNumber)
  @Concat_Field("@@pplt", totalPlantNumber)

  @Concat_Field("@@fdpt", fromDepartment)
  @Concat_Field("@@tdpt", toDepartment)
  @Concat_Field("@@adpt", allDepartment)
  @Concat_Field("@@sdpt", sortDepartment)
  @Concat_Field("@@pdpt", totalDepartment)

  @Concat_Field("@@fwc@", fromWorkCenter)
