                                      @dtw_assign(checkedallLaborCode, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallLaborCode, "")
                                  %endif
                                  %if (V_ALLSC == "ALL")
                                      @dtw_assign(checkedallScrapCode, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallScrapCode, "")
                                  %endif

                                  %if (V_N3PPLT == "Y")
                                      @dtw_assign(checkedPlantNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedPlantNumberTotals, "")
                                  %endif
                                  %if (V_TRPDP == "Y")
                                      @dtw_assign(checkedDepartmentTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedDepartmentTotals, "")
                                  %endif
                                  %if (V_TRPWC == "Y")
                                      @dtw_assign(checkedWorkCenterTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedWorkCenterTotals, "")
                                  %endif
                                  %if (V_TRPMA == "Y")
                                      @dtw_assign(checkedMachineNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedMachineNumberTotals, "")
                                  %endif
                                  %if (V_TRPLD == "Y")
                                      @dtw_assign(checkedDateWorkedTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedDateWorkedTotals, "")
                                  %endif
                                  %if (V_TRPSF == "Y")
                                      @dtw_assign(checkedShiftWorkedTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedShiftWorkedTotals, "")
                                  %endif
                                  %if (V_TRPEM == "Y")
                                      @dtw_assign(checkedEmployeeNumberTotals, "CHECKED")
                                  %else
