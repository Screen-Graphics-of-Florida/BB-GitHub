%Define {
  page_title              = "Labor Efficiency Report"
  d2wName                 = "LaborEfficiencyReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  forPlant                = ""
  sortSeqMax              = "13"
  sortPlantNumber         = "1"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromPlantNumber, 3, 0) &&
                      editNum(document.Chg.toPlantNumber, 3, 0) &&
                      editdate(document.Chg.fromDateWorked) &&
                      editdate(document.Chg.toDateWorked) &&
                      editNum(document.Chg.fromShiftWorked, 1, 0) &&
                      editNum(document.Chg.toShiftWorked, 1, 0) &&
                      editNum(document.Chg.fromEmployeeNumber, 5, 0) &&
                      editNum(document.Chg.toEmployeeNumber, 5, 0) &&
                      editNum(document.Chg.fromRoutingSequence, 3, 0) &&
                      editNum(document.Chg.toRoutingSequence, 3, 0) &&
                      editNum(document.Chg.amtOver, 6, 2) &&
                      editNum(document.Chg.amtUnder, 6, 2) &&
                      editNum(document.Chg.percentOver, 6, 2) &&
                      editNum(document.Chg.percentUnder, 6, 2) &&
                      editNum(document.Chg.scrapOver, 6, 2) &&
                      editNum(document.Chg.scrapUnder, 6, 2) &&
                      editFromToAll(document.Chg.fromPlantNumber, document.Chg.toPlantNumber, document.Chg.allPlantNumber, 3) &&
                      editFromToAll(document.Chg.fromDepartment, document.Chg.toDepartment, document.Chg.allDepartment, "A") &&
                      editFromToAll(document.Chg.fromWorkCenter, document.Chg.toWorkCenter, document.Chg.allWorkCenter, "A") &&
                      editFromToAll(document.Chg.fromMachineNumber, document.Chg.toMachineNumber, document.Chg.allMachineNumber, "A") &&
                      editFromToAll(document.Chg.fromDateWorked, document.Chg.toDateWorked, document.Chg.allDateWorked, "D") &&
                      editFromToAll(document.Chg.fromShiftWorked, document.Chg.toShiftWorked, document.Chg.allShiftWorked, 1) &&
                      editFromToAll(document.Chg.fromEmployeeNumber, document.Chg.toEmployeeNumber, document.Chg.allEmployeeNumber, 5) &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromOrderNumber, document.Chg.toOrderNumber, document.Chg.allOrderNumber, "A") &&
                      editFromToAll(document.Chg.fromRoutingSequence, document.Chg.toRoutingSequence, document.Chg.allRoutingSequence, 3) &&
                      editFromToAll(document.Chg.fromLaborType, document.Chg.toLaborType, document.Chg.allLaborType, "A") &&
                      editFromToAll(document.Chg.fromLaborCode, document.Chg.toLaborCode, document.Chg.allLaborCode, "A") &&
                      editFromToAll(document.Chg.fromScrapCode, document.Chg.toScrapCode, document.Chg.allScrapCode, "A")
                      )

                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "LABOREFFICIENCYREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromPlantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@fplt", "fromPlantNumber")        @dtw_assign(Err_N3FPLT,  fieldValue)
                                  @DecatErr_Field("@@splt", "sortPlantNumber")        @dtw_assign(Err_N3SPLT,  fieldValue)
                                  @DecatErr_Field("@@sdpt", "sortDepartment")        @dtw_assign(Err_SEQDP,  fieldValue)
                                  @DecatErr_Field("@@swc@", "sortWorkCenter")        @dtw_assign(Err_SEQWC,  fieldValue)
                                  @DecatErr_Field("@@smch", "sortMachineNumber")        @dtw_assign(Err_SEQMA,  fieldValue)
                                  @DecatErr_Field("@@sdat", "sortDateWorked")        @dtw_assign(Err_SEQLD,  fieldValue)
                                  @DecatErr_Field("@@ssfw", "sortShiftWorked")        @dtw_assign(Err_SEQSF,  fieldValue)
                                  @DecatErr_Field("@@semp", "sortEmployeeNumber")        @dtw_assign(Err_SEQEM,  fieldValue)
                                  @DecatErr_Field("@@sitm", "sortItemNumber")        @dtw_assign(Err_SEQPN,  fieldValue)
                                  @DecatErr_Field("@@sord", "sortOrderNumber")        @dtw_assign(Err_SEQOR,  fieldValue)
                                  @DecatErr_Field("@@srtg", "sortRoutingSequence")        @dtw_assign(Err_SEQSQ,  fieldValue)
                                  @DecatErr_Field("@@styp", "sortLaborType")        @dtw_assign(Err_SEQLT,  fieldValue)
                                  @DecatErr_Field("@@slc@", "sortLaborCode")        @dtw_assign(Err_SEQLC,  fieldValue)
                                  @DecatErr_Field("@@ssc@", "sortScrapCode")        @dtw_assign(Err_SEQSC,  fieldValue)
                                  @DecatErr_Field("@@evdo", "amtOver")        @dtw_assign(Err_TREVDO,  fieldValue)
                                  @DecatErr_Field("@@evdu", "amtUnder")        @dtw_assign(Err_TREVDU,  fieldValue)
                                  @DecatErr_Field("@@evpo", "percentOver")        @dtw_assign(Err_TREVPO,  fieldValue)
                                  @DecatErr_Field("@@evpu", "percentUnder")        @dtw_assign(Err_TREVPU,  fieldValue)
                                  @DecatErr_Field("@@scpo", "scrapOver")        @dtw_assign(Err_TRSCPO,  fieldValue)
                                  @DecatErr_Field("@@scpu", "scrapUnder")        @dtw_assign(Err_TRSCPU,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@opt1")  @dtw_assign(V_N1OPT,  fieldValue)
                                  @Decat_Field("@@opt2")  @dtw_assign(V_N2OPT,  fieldValue)

                                  @Decat_Field("@@fplt")  @dtw_assign(V_N3FPLT,  fieldValue)
                                  @Decat_Field("@@tplt")  @dtw_assign(V_N3TPLT,  fieldValue)
                                  @Decat_Field("@@aplt")  @dtw_assign(V_N3APLT,  fieldValue)
                                  @Decat_Field("@@splt")  @dtw_assign(V_N3SPLT,  fieldValue)
                                  @Decat_Field("@@pplt")  @dtw_assign(V_N3PPLT,  fieldValue)

                                  @Decat_Field("@@fdpt")  @dtw_assign(V_TRDP1,  fieldValue)
                                  @Decat_Field("@@tdpt")  @dtw_assign(V_TRDP2,  fieldValue)
                                  @Decat_Field("@@adpt")  @dtw_assign(V_ALLDP,  fieldValue)
                                  @Decat_Field("@@sdpt")  @dtw_assign(V_SEQDP,  fieldValue)
                                  @Decat_Field("@@pdpt")  @dtw_assign(V_TRPDP,  fieldValue)

                                  @Decat_Field("@@fwc@")  @dtw_assign(V_TRWC1,  fieldValue)
                                  @Decat_Field("@@twc@")  @dtw_assign(V_TRWC2,  fieldValue)
                                  @Decat_Field("@@awc@")  @dtw_assign(V_ALLWC,  fieldValue)
                                  @Decat_Field("@@swc@")  @dtw_assign(V_SEQWC,  fieldValue)
                                  @Decat_Field("@@pwc@")  @dtw_assign(V_TRPWC,  fieldValue)

                                  @Decat_Field("@@fmch")  @dtw_assign(V_TRMA1,  fieldValue)
                                  @Decat_Field("@@tmch")  @dtw_assign(V_TRMA2,  fieldValue)
                                  @Decat_Field("@@amch")  @dtw_assign(V_ALLMA,  fieldValue)
                                  @Decat_Field("@@smch")  @dtw_assign(V_SEQMA,  fieldValue)
                                  @Decat_Field("@@pmch")  @dtw_assign(V_TRPMA,  fieldValue)

                                  @Decat_Field("@@fdat")  @dtw_assign(V_TRLD1, fieldValue)
                                  @Decat_Field("@@tdat")  @dtw_assign(V_TRLD2, fieldValue)
                                  @Decat_Field("@@adat")  @dtw_assign(V_ALLLD, fieldValue)
                                  @Decat_Field("@@sdat")  @dtw_assign(V_SEQLD, fieldValue)
                                  @Decat_Field("@@pdat")  @dtw_assign(V_TRPLD, fieldValue)

                                  @Decat_Field("@@fsfw")  @dtw_assign(V_TRSF1, fieldValue)
                                  @Decat_Field("@@tsfw")  @dtw_assign(V_TRSF2, fieldValue)
                                  @Decat_Field("@@asfw")  @dtw_assign(V_ALLSF, fieldValue)
                                  @Decat_Field("@@ssfw")  @dtw_assign(V_SEQSF, fieldValue)
                                  @Decat_Field("@@psfw")  @dtw_assign(V_TRPSF, fieldValue)

                                  @Decat_Field("@@femp")  @dtw_assign(V_TREM1, fieldValue)
                                  @Decat_Field("@@temp")  @dtw_assign(V_TREM2, fieldValue)
                                  @Decat_Field("@@aemp")  @dtw_assign(V_ALLEM, fieldValue)
                                  @Decat_Field("@@semp")  @dtw_assign(V_SEQEM, fieldValue)
                                  @Decat_Field("@@pemp")  @dtw_assign(V_TRPEM, fieldValue)

                                  @Decat_Field("@@fitm")  @dtw_assign(V_TRPN1, fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_TRPN2, fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_ALLPN, fieldValue)
                                  @Decat_Field("@@sitm")  @dtw_assign(V_SEQPN, fieldValue)
                                  @Decat_Field("@@pitm")  @dtw_assign(V_TRPPN, fieldValue)

                                  @Decat_Field("@@ford")  @dtw_assign(V_TROR1,  fieldValue)
                                  @Decat_Field("@@tord")  @dtw_assign(V_TROR2,  fieldValue)
                                  @Decat_Field("@@aord")  @dtw_assign(V_ALLOR,  fieldValue)
                                  @Decat_Field("@@sord")  @dtw_assign(V_SEQOR,  fieldValue)
                                  @Decat_Field("@@pord")  @dtw_assign(V_TRPOR,  fieldValue)

                                  @Decat_Field("@@frtg")  @dtw_assign(V_TRSQ1,  fieldValue)
