%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "QuickLink.icl"

%Define {
  page_title           = "Welcome Page"
  d2wName              = "WelcomePage.d2w"
  d2wVarBase           = "$(genericVarBase)"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  DTW_SET_TOTAL_ROWS   = "YES"
  RPT_MAX_ROWS	        = "99"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  prUserPass           = ""
  rowIndexNext	        = "1"
  showError            = "N"
  totalPages	        = "0"	
  CMN_05               = ""
  EMU_06               = ""
  EMU_07               = ""
  PTE_05               = ""
  SDU_05               = ""
  ECU_05               = ""
  EDM_05               = ""
  EDM_06               = ""
  EDM_07               = ""
  systemDate           = ""

%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {

%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
      %INCLUDE "$(docType)"
      <html>
          <head>  	
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
	
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "WELCOMEPAGE")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
		   <td>
                      <h1>Welcome, $(profileName), to the $(title)</h1>
                      @dtw_DATE("U", systemDate) @Date_MDY_ISO(@dtw_rReplace(systemDate,"/",""), systemDate)
		
%{ quicklinkSeqTable %}
                          @dtw_assign(RPT_MAX_ROWS, "99")
                          @dtw_assign(dspMaxRows, "99")
                          @QuicklinkSequence(profileHandle, dataBaseID, d2wName, quicklinkSeqTable)
                          @dtw_tb_rows(quicklinkSeqTable,quicklinkCount)
                          %if (quicklinkCount == "0" || quicklinkCount == "")
                              @dtw_assign(quicklinkCount, "0")
                          %endif


%{ Quicklink Display Loop %}
                          @dtw_assign(x, "1")
                      %while(x <= quicklinkCount) {

                              @dtw_tb_getv(quicklinkSeqTable, x, "1", quicklinkRef)
                              @dtw_lowercase(quicklinkRef,quicklinkRef)
                              @dtw_tb_getv(quicklinkSeqTable, x, "2", quicklinkTitle)
                              @dtw_tb_getv(quicklinkSeqTable, x, "3", quicklinkMaxRows)
                              %if (quicklinkMaxRows == "0" || quicklinkMaxRows == "" )
                                  @dtw_assign(quicklinkMaxRows, dspMaxRowsDft)
                              %endif
                              @dtw_assign(RPT_MAX_ROWS, quicklinkMaxRows)
                              @dtw_assign(dspMaxRows, quicklinkMaxRows)

%{Work List %}
			   %if (quicklinkRef == "worklist")
                             @dtw_assign(START_ROW_NUM, "1")
                             @dtw_assign(stmtSQL, "")
                             @dtw_concat(stmtSQL, " Select WFWITM.*,WFWIPT.*,INDESC,  ", stmtSQL)
                             @dtw_concat(stmtSQL, " ifnull(ATD2W,' ') as ATD2W  ", stmtSQL)
                             @dtw_concat(stmtSQL, " From WFWITM ", stmtSQL)
                             @dtw_concat(stmtSQL, " inner join WFWIPT on WPINST=WIINST and WPINDT=WIINDT and WPWITM=WIWITM and WPWISQ=WIWISQ ", stmtSQL)
                             @dtw_concat(stmtSQL, " inner join WFINST on ININST=WIINST and ININDT=WIINDT ", stmtSQL)
                             @dtw_concat(stmtSQL, " left join WFPRAC on ATPROC=WIPROC and ATACTV=WIACTV ", stmtSQL)
                             @dtw_concat(stmtSQL, " Where WIMODE='M'  ", stmtSQL)
                             @dtw_concat(stmtSQL, " and WPPART='$(userProfile)' and (WPRVWS='Y' or WPRVWS=' ') ", stmtSQL)
                             @dtw_concat(stmtSQL, " Order By WPEXDT,WPPRTY ", stmtSQL)
                             %INCLUDE "stmtSQLEnd.icl"
                             @WorkList_Query(profileHandle, dataBaseID, stmtSQL)
                          %endif

%{My Work Item %}
			   %if (quicklinkRef == "workitem")
                             @dtw_assign(START_ROW_NUM, "1")
                             @dtw_assign(stmtSQL, "")
                             @dtw_concat(stmtSQL, " Select WFWITM.*,WFINST.*,WFWIPT.*,  ", stmtSQL)
                             @dtw_concat(stmtSQL, " ifnull(USDESC,WPPART) as USDESC  ", stmtSQL)
                             @dtw_concat(stmtSQL, " From WFWITM ", stmtSQL)
                             @dtw_concat(stmtSQL, " inner join WFINST on ININST=WIINST and ININDT=WIINDT ", stmtSQL)
                             @dtw_concat(stmtSQL, " inner join WFWIPT on WPINST=WIINST and WPINDT=WIINDT and WPWITM=WIWITM and WPWISQ=WIWISQ and WPPART<>INIUSR ", stmtSQL)
                             @dtw_concat(stmtSQL, " left join SYUSER on USUSER=WPPART ", stmtSQL)
                             @dtw_concat(stmtSQL, " Where WIMODE='M' ", stmtSQL)
                             @dtw_concat(stmtSQL, " and INIUSR='$(userProfile)' ", stmtSQL)
                             @dtw_concat(stmtSQL, " and (WPRVWS='Y' or WPRVWS=' ') ", stmtSQL)
                             @dtw_concat(stmtSQL, " Order By WPEXDT,WPPRTY ", stmtSQL)
                             %INCLUDE "stmtSQLEnd.icl"
                             @MyWorkItemList_Query(profileHandle, dataBaseID, stmtSQL)
			   %endif

%{Delegated %}
		           %if (quicklinkRef == "delegated")
                             @dtw_assign(START_ROW_NUM, "1")
                             @dtw_assign(stmtSQL, "")
                             @dtw_concat(stmtSQL, " Select WFWITM.*,WFWIPT.*,INDESC, ", stmtSQL)
                             @dtw_concat(stmtSQL, " ifnull(USDESC,WPPART) as USDESC  ", stmtSQL)
                             @dtw_concat(stmtSQL, " From WFWITM ", stmtSQL)
                             @dtw_concat(stmtSQL, " inner join WFWIPT on WPINST=WIINST and WPINDT=WIINDT and WPWITM=WIWITM and WPWISQ=WIWISQ and WPPART<>WPIPRT ", stmtSQL)
                             @dtw_concat(stmtSQL, " inner join WFINST on ININST=WIINST and ININDT=WIINDT ", stmtSQL)
                             @dtw_concat(stmtSQL, " left join SYUSER on USUSER=WPPART ", stmtSQL)
                             @dtw_concat(stmtSQL, " Where WIMODE='M'  ", stmtSQL)
                             @dtw_concat(stmtSQL, " and WPIPRT='$(userProfile)' and (WPRVWS='Y' or WPRVWS=' ') ", stmtSQL)
                             @dtw_concat(stmtSQL, " Order By WPEXDT,WPPRTY,WPPART ", stmtSQL)
                             %INCLUDE "stmtSQLEnd.icl"
                             @DelegatedItem_Query(profileHandle, dataBaseID, stmtSQL)
			   %endif

%{Customer %}
		        %if (quicklinkRef == "customer")
			   @dtw_assign(START_ROW_NUM, "1")
 		  	   @dtw_assign(uv_CustomerName, "CMCUST")
                 	   @dtw_assign(uv_CustomerClassName, "CMCCLS")
                      	   @dtw_assign(uv_RegionName, "CMCRGN")
                      	   @dtw_assign(uv_BillingLocationName, "CMLOC#")
                      	   @dtw_assign(uv_SalesmanName, "CMSLSM")
                      	   @dtw_assign(uv_WarehouseName, "CMWH#")
                      	   %INCLUDE "userview.icl"
                          @dtw_assign(stmtSQL, "")
                      	   @dtw_concat(stmtSQL, " Select * From HDCUST Where CMCUST<>0 ", stmtSQL)
                      	   %if (uv_Sql != "")
                             @dtw_concat(stmtSQL, " and ($(uv_Sql))", stmtSQL)
                      	   %endif
                      	
                          %INCLUDE "stmtSQLEnd.icl"
                      	   @Customer_Query(profileHandle, dataBaseID, stmtSQL)
                       %endif
%{Reports%}
		        %if (quicklinkRef == "myreport")
  			@dtw_assign(START_ROW_NUM, "1")
		        @dtw_assign(stmtSQL, "")
                      	@dtw_concat(stmtSQL, " Select SYD2WR.*, ", stmtSQL)
                      	@dtw_concat(stmtSQL, " ifnull(b.DRDESC,' ') as RSDESC, ifnull(b.DRDESCU,' ') as RSDESCU ", stmtSQL)
                      	@dtw_concat(stmtSQL, " From SYD2WR ", stmtSQL)
                      	@dtw_concat(stmtSQL, " left join SYDOCR b on upper(b.DRPGNM)=DRD2WN ", stmtSQL)
                      	@dtw_concat(stmtSQL, " Where DRUSER='$(userProfile)' and DRD2WN<>'EVENTCALENDARSELECT.D2W' ", stmtSQL)
                      	@dtw_concat(stmtSQL, " $(wildCardSearch) ", stmtSQL)
                      	%INCLUDE "stmtSQLEnd.icl"
                      	@MyReports_Query(profileHandle, dataBaseID, stmtSQL)
			%endif

%{ Attachments %}      %INCLUDE "AttachmentSQL.icl"

                              @dtw_add(x, "1", x)
                          %}
%{ Quicklink Display Loop END %}

                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              %INCLUDE "AlertMessageDisplay.icl"
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>

%}


%FUNCTION(dtw_sql) WorkList_Query (IN  CHAR(64) profileHandle,
                                       CHAR(2)   dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
 	<a name="worklist"></a>
      	@dtw_assign(displayMaxRowsMsg, "N")
      	@dtw_assign(moreURL, "")
      	%INCLUDE "QuickLinkTopOfForm.icl"

      	<table $(contentTable)>
          @RtvFldDesc("WIMODE='M' and WPPART='$(userProfile)' and (WPRVWS='Y' or WPRVWS=' ') ",                         "WFWITM inner join WFWIPT on WPINST=WIINST and WPINDT=WIINDT and WPWITM=WIWITM and WPWISQ=WIWISQ", "CHAR(COUNT(*))", requestOwn)
          @RtvFldDesc("WIMODE='M' and WPPART='$(userProfile)' and (WPRVWS='Y' or WPRVWS=' ') and DATE(WPEXDT)<'$(systemDate)' ", "WFWITM inner join WFWIPT on WPINST=WIINST and WPINDT=WIINDT and WPWITM=WIWITM and WPWISQ=WIWISQ", "CHAR(COUNT(*))", requestExpire)
          <tr><td class="dspalph"><a href="$(homeURL)$(cGIPath)WFWorkList.D2w/REPORT$(d2wVarBase)">I have $(requestOwn) items in my Work List. </a>
                                     <a href="$(homeURL)$(cGIPath)WFWorkList.D2w/REPORT$(d2wVarBase)&amp;expireDate=@dtw_rurlescseq(systemDate)">$(requestExpire) are overdue. </a>
          </td></tr>
      </table>


      <table $(contentTable)>
          <tr><td><h3>To view the Work List, click on the description above.</h3></td></tr>
      </table>

      <table $(contentTable)>
          @dtw_assign(headOnce, "")

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;wfInstance=@dtw_rurlescseq(V_WIINST)&amp;wfInstanceDate=@dtw_rurlescseq(V_WIINDT)&amp;wfWorkItem=@dtw_rurlescseq(V_WIWITM)&amp;wfWorkItemSequence=@dtw_rurlescseq(V_WIWISQ)&amp;wfParticipantId=@dtw_rurlescseq(V_WPPTID)")
              %if (headOnce == "")
                  @dtw_assign(headOnce, "Y")
                  <tr>
                      <th class="colhdr">Oldest 5 items in my Work List</th>
                </tr>
              %endif

              %INCLUDE "SetRowClass.icl"
              @TimeStamp_CYMD(V_WPEXDT, V_WPEXDT) @Format_Date(V_WPEXDT, "D", F_WPEXDT)

              <tr class="$(rowClass)">
                  @dtw_assign(wfPath, "$(V_ATD2W)$(maintainVar)")
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)WFActiveWorkItemCheck.d2w/REPORT$(maintainVar)&amp;wfPath=@dtw_rurlescseq(wfPath)" title="View Work Item [$(V_ATD2W)]">$(V_INDESC)</a> with a priority of $(V_WPPRTY) expires on $(F_WPEXDT) ($(V_PDDESC)).  </td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) MyWorkItemList_Query (IN  CHAR(64) profileHandle,
                                             CHAR(2)   dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

	<a name="workitem"></a>
      	@dtw_assign(displayMaxRowsMsg, "N")
      	@dtw_assign(moreURL, "")
      	%INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          @RtvFldDesc("WIMODE='M' and INIUSR='$(userProfile)' and (WPRVWS='Y' or WPRVWS=' ') ",                          "WFWITM inner join WFINST on ININST=WIINST and ININDT=WIINDT inner join WFWIPT on WPINST=WIINST and WPINDT=WIINDT and WPWITM=WIWITM and WPWISQ=WIWISQ and WPPART<>INIUSR ", "CHAR(COUNT(*))", requestInit)
          @RtvFldDesc("WIMODE='M' and INIUSR='$(userProfile)' and (WPRVWS='Y' or WPRVWS=' ') and DATE(WPEXDT)<'$(systemDate)' ", "WFWITM inner join WFINST on ININST=WIINST and ININDT=WIINDT inner join WFWIPT on WPINST=WIINST and WPINDT=WIINDT and WPWITM=WIWITM and WPWISQ=WIWISQ and WPPART<>INIUSR ", "CHAR(COUNT(*))", requestExpInit)
          <tr><td class="dspalph"><a href="$(homeURL)$(cGIPath)WFMyWorkItem.D2w/REPORT$(d2wVarBase)">I have initiated $(requestInit) items that are currently on another Work List. </a>
                                            <a href="$(homeURL)$(cGIPath)WFMyWorkItem.D2w/REPORT$(d2wVarBase)&amp;expireDate=@dtw_rurlescseq(systemDate)">$(requestExpInit) are overdue. </a></td>
          </tr>
      </table>

      <table $(contentTable)>
          <tr><td><h3>To view the Work Items, click on the description above.</h3></td></tr>
      </table>

      <table $(contentTable)>
          @dtw_assign(headOnce, "")

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;wfInstance=@dtw_rurlescseq(V_WIINST)&amp;wfInstanceDate=@dtw_rurlescseq(V_WIINDT)&amp;wfWorkItem=@dtw_rurlescseq(V_WIWITM)&amp;wfWorkItemSequence=@dtw_rurlescseq(V_WIWISQ)")
              %if (headOnce == "")
                  @dtw_assign(headOnce, "Y")
                  <tr>
                      <th class="colhdr">Oldest 5 items I initiated on another Work List.</th>
                 </tr>
              %endif

              %INCLUDE "SetRowClass.icl"
              @TimeStamp_CYMD(V_WPEXDT, V_WPEXDT) @Format_Date(V_WPEXDT, "D", F_WPEXDT)

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)WFHistorySelect.d2w/REPORT$(maintainVar)&amp;fromD2w=@dtw_rurlescseq(d2wName)" title="View Work Item History">$(V_INDESC)</a> is on $(V_USDESC) Work List with a priority of $(V_WPPRTY). It expires on $(F_WPEXDT).  </td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) DelegatedItem_Query (IN  CHAR(64) profileHandle,
                                            CHAR(2)   dataBaseID,
                                            CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

<a name="delegated"></a>
      	@dtw_assign(displayMaxRowsMsg, "N")
      	@dtw_assign(moreURL, "")
      	%INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          @RtvFldDesc("WIMODE='M' and WPIPRT='$(userProfile)' and (WPRVWS='Y' or WPRVWS=' ')",                           "WFWITM inner join WFWIPT on WPINST=WIINST and WPINDT=WIINDT and WPWITM=WIWITM and WPWISQ=WIWISQ and WPPART<>WPIPRT ", "CHAR(COUNT(*))", requestDelegate)
          @RtvFldDesc("WIMODE='M' and WPIPRT='$(userProfile)' and (WPRVWS='Y' or WPRVWS=' ') and DATE(WPEXDT)<'$(systemDate)' ", "WFWITM inner join WFWIPT on WPINST=WIINST and WPINDT=WIINDT and WPWITM=WIWITM and WPWISQ=WIWISQ and WPPART<>WPIPRT ", "CHAR(COUNT(*))", requestExpDelegate)
          <tr><td class="dspalph"><a href="$(homeURL)$(cGIPath)WFWorkItemDelegate.D2w/REPORT$(d2wVarBase)">I delegated $(requestDelegate) items that have not been addressed. </a>
                                     <a href="$(homeURL)$(cGIPath)WFWorkItemDelegate.D2w/REPORT$(d2wVarBase)&amp;expireDate=@dtw_rurlescseq(systemDate)">$(requestExpDelegate) are overdue. </a></td>
          </tr>
      </table>

      <table $(contentTable)>
          <tr><td><h3>To view the Work Items, click on the description above.</h3></td></tr>
      </table>

      <table $(contentTable)>
          @dtw_assign(headOnce, "")

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;wfInstance=@dtw_rurlescseq(V_WIINST)&amp;wfInstanceDate=@dtw_rurlescseq(V_WIINDT)&amp;wfWorkItem=@dtw_rurlescseq(V_WIWITM)&amp;wfWorkItemSequence=@dtw_rurlescseq(V_INDESC)")
              %if (headOnce == "")
                  @dtw_assign(headOnce, "Y")
                  <tr>
                      <th class="colhdr">Oldest 5 items I delegated to another Work List.</th>
                 </tr>
              %endif

              %INCLUDE "SetRowClass.icl"
              @TimeStamp_CYMD(V_WPEXDT, V_WPEXDT) @Format_Date(V_WPEXDT, "D", F_WPEXDT)

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)WFHistorySelect.d2w/REPORT$(maintainVar)&amp;fromD2w=@dtw_rurlescseq(d2wName)" title="View Work Item History">$(V_INDESC)</a> is on $(V_USDESC) Work List with a priority of $(V_WPPRTY). It expires on $(F_WPEXDT).  </td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}
%FUNCTION(dtw_sql) Customer_Query (IN  CHAR(64)    profileHandle,
				                    CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

	<a name="customer"></a>
      	@dtw_assign(displayMaxRowsMsg, "N")
      	@dtw_assign(moreURL, "")
      	%INCLUDE "QuickLinkTopOfForm.icl"

      %if (TOTAL_ROWS != "1")

          %INCLUDE "WildCardPage.icl"

          @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)

          <table $(contentTable)>
              <tr>
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y" || sec_05 == "Y"))
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("CMCUST", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Number"  title="Sequence By Customer Number"> Number</a></th>
                  @OrderBy_Sort("CMCNA1U", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Name"    title="Sequence By Name"> Name</a></th>
                  @OrderBy_Sort("CMCNA2U", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Address" title="Sequence By Address"> Address</a></th>
                  @OrderBy_Sort("CMCCTYU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=City"    title="Sequence By City, Name"> City</a></th>
                  @OrderBy_Sort("CMST", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=State"   title="Sequence By State, Name"> State</a></th>
                  @OrderBy_Sort("CMZIP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Zip"     title="Sequence By Zip, Name"> Zip</a></th>
                  @OrderBy_Sort("CMPHON", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Phone"   title="Sequence By Phone Number"> Phone Number</a></th>
              </tr>
      %endif

              %ROW{
                  %if (TOTAL_ROWS == "1")
                      @Save_WebReg(webRegCurFile, profileHandle, d2wName, "", orderBy, orderByDisplay, "")
                      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)CustomerSelect.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(V_CMCUST)&amp;customerName=@dtw_rurlescseq(V_CMCNA1)">
                  %else
                      @dtw_assign(maintainVar, "$(d2wVarBase)&amp;customerNumber=@dtw_rurlescseq(V_CMCUST)&amp;customerName=@dtw_rurlescseq(V_CMCNA1)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
                      @EditPhoneNumber(V_CMPHON)
                      %INCLUDE "SetRowClass.icl"

                      <tr class="$(rowClass)">
                          %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y" || sec_05 == "Y"))
                              <td class="opticon">
                                  %if (sec_05 == "Y" && sec_02 != "Y")
                                      <a href="$(homeURL)$(cGIPath)CustomerMaintainBasic.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                                  %elseif (sec_02 == "Y" || sec_03 == "Y")
                                      <a href="$(homeURL)$(cGIPath)CustomerMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                                  %endif
                                  %if (sec_04 == "Y")
                                      <a href="$(homeURL)$(cGIPath)CustomerMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromCustomer=@dtw_rurlescseq(V_CMCUST)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                                  %endif
                                  %if (sec_03 == "Y")
                                      <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)customermaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                                  %endif
                              </td>
                          %endif
                          <td class="colnmbr">$(V_CMCUST)</td>                                      	
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)CustomerSelect.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(V_CMCUST)&amp;customerName=@dtw_rurlescseq(V_CMCNA1)" title="View Customer">$(V_CMCNA1)</a></td>
                          <td class="colalph">$(V_CMCNA2)</td>
                          <td class="colalph">$(V_CMCCTY)</td>
                          <td class="colcode">$(V_CMST)</td>
                          <td class="colalph">$(V_CMZIP)</td>
                          <td class="colnmbr">$(V_CMPHON)</td>
                      </tr>
                  %endif
              %}
          </table>
      </fieldset>
  %}
%}
%FUNCTION(dtw_sql) MyReports_Query (IN CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

	<a name="customer"></a>
      	@dtw_assign(displayMaxRowsMsg, "N")
      	@dtw_assign(moreURL, "")
      	%INCLUDE "QuickLinkTopOfForm.icl"

      	   <table $(contentTable)>
            <tr>
              %if (formatToPrint != "Y")
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("RSDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Report" title="Sequence By Report"> Report</a></th>
              @OrderBy_Sort("DRDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description, Report"> Description</a></th>
            </tr>

          %ROW{

              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;reportSelD2W=@dtw_rurlescseq(V_DRD2WN)&amp;reportSelUser=@dtw_rurlescseq(V_DRUSER)&amp;reportSelSeq=@dtw_rurlescseq(V_DRSEQN)&amp;reportSelDesc=@dtw_rurlescseq(V_DRDESC)")
              %INCLUDE "SetRowClass.icl"

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y")
                      <td class="opticon">
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                      </td>
                  %endif
                  <td class="colalph">$(V_RSDESC)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(maintainVar)&amp;maintenanceCode=R" title="Click here retrieve report selection">$(V_DRDESC)</a></td>
              </tr>
          %}
      </table>
      </fieldset>	

  %}
%}
%FUNCTION(dtw_directcall) Check_WebReg_Authority (IN    CHAR(10) webreglib,
						         CHAR(10) current,
				                         CHAR(10) userProfile,
				                   INOUT CHAR(1)  fileFound)
{%EXEC {CSYWRA_W.PGM %}  	
%}


%INCLUDE "AttachmentSelect.icl"


%HTML(WELCOME) {

  %INCLUDE "setLibraryList.icl"
  @retrieveUserRole(profileHandle, dataBaseID, userProfile, userCustomer, userVendor, userSalesman, userBadge, userCatalog, newsLink, profileName)
  @dtw_assign(fileFound, "Y")
  @Check_WebReg_Authority(webRegLibrary, webRegCurFile, userProfile, fileFound)

  %if (fileFound == "N")
      @dtw_assign(fileFound, "")
      @dtwr_createreg("$(webRegPath)$(webRegCurFile).file",  "*RWX, *RWX, *R")
      @dtwr_createreg("$(webRegPath)$(userProfile).file",  "*RWX, *RWX, *R")
      @Check_WebReg_Authority(webRegLibrary, webRegCurFile, userProfile, fileFound)
  %endif

  @dtwr_openreg("$(webRegPath)$(webRegCurFile).file")
  @dtwr_openreg("$(webRegPath)$(userProfile).file")
  @Set_SQL(stmtSQL)

%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) reportSelVar)
{%EXEC {HSYD2R_W.PGM %}
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @dtw_assign(edtVar, "")
  @dtw_assign(reportSelVar, "")
  @Concat_Field("@@d2wn", reportSelD2W)
  @Concat_Field("@@user", reportSelUser)
  @Concat_Field("@@seqn", reportSelSeq)
  @Concat_Field("@@desc", reportSelDesc)
  @dtw_concat(edtVar, "}{", edtVar)

  %if (maintenanceCode == "A" || maintenanceCode == "C")
      @EdtVarErr(profileHandle, typeValue, reportSelVar)
  %endif

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, reportSelVar)

  %if (maintenanceCode == "D")
      @Set_SQL(stmtSQL)
  %else
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(reportSelD2W)/REPORT$(genericVarBase)&amp;backHome=@dtw_rurlescseq(d2wName)/WELCOME&amp;errFound=Y&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif

%}
