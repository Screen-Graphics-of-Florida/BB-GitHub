%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Detail Point Maintenance"
  d2wName                 = "WFDetailMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfProcess=@dtw_rurlescseq(wfProcess)&amp;passedWfPoint=@dtw_rurlescseq(passedWfPoint)&amp;passedWfSequence=@dtw_rurlescseq(passedWfSequence)&amp;fromPoint=@dtw_rurlescseq(fromPoint)&amp;fromSequence=@dtw_rurlescseq(fromSequence)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;updRecNbr=@dtw_rurlescseq(updRecNbr)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;wfPoint=@dtw_rurlescseq(wfPoint)&amp;wfSequence=@dtw_rurlescseq(wfSequence)&amp;maintenanceCode=D"
  programName             = "HWFDTM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function confirmDelete() {return confirm("$(delRecordConf)")}
              function validate(chgForm) {
                  if (document.Chg.wfPoint.value =="" ||
                      document.Chg.wfSequence.value =="")
                         {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.wfPoint, 4, 3) &&
                      editNum(document.Chg.wfSequence, 4, 3) &&
                      editNum(document.Chg.complexityRating, 3, 0)
                      )
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFDETAILMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " WFPRDT ", fileSQL)
                          @dtw_concat(selectSQL, " PDPROC='$(wfProcess)' and PDPONT=$(wfPoint) and PDSEQ=$(wfSequence) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          @RtvFldDesc("PRPROC='$(wfProcess)'", "WFPRHD", "PRDESC", wfProcessDescription)
          @Format_Header("", $(wfProcessDescription), $(wfProcess))
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          %ROW {
              %if (errFound != "" || maintenanceCode == "A")
                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(edtVar, "")
                      @dtw_assign(focusField, "wfPoint")
                  %else
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@pont", "wfPoint")                @dtw_assign(Err_PDPONT, fieldValue)
                      @DecatErr_Field("@@seq@", "wfSequence")             @dtw_assign(Err_PDSEQ, fieldValue)
                      @DecatErr_Field("@@desc", "wfDetailDescription")    @dtw_assign(Err_PDDESC, fieldValue)
                      @DecatErr_Field("@@pprc", "pointProcess")           @dtw_assign(Err_PDPPRC, fieldValue)
                      @DecatErr_Field("@@pact", "pointActivity")          @dtw_assign(Err_PDPACT, fieldValue)
                      @DecatErr_Field("@@rate", "complexityRating")       @dtw_assign(Err_PDRATE, fieldValue)
                  %endif

                  @Decat_Field("@@pont")   @dtw_assign(V_PDPONT, fieldValue)
                  @Decat_Field("@@seq@")   @dtw_assign(V_PDSEQ, fieldValue)
                  @Decat_Field("@@desc")   @dtw_assign(V_PDDESC, fieldValue)
                  @Decat_Field("@@pprc")   @dtw_assign(V_PDPPRC, fieldValue)
                  @Decat_Field("@@pact")   @dtw_assign(V_PDPACT, fieldValue)
                  @Decat_Field("@@rate")   @dtw_assign(V_PDRATE, fieldValue)

                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(focusField, "wfPoint")
                      @dtw_assign(V_PDPONT, "0")
                  %endif

                  @dtw_assign(errFound, "")

              %elif (maintenanceCode == "Z")
                  @dtw_assign(focusField, "wfPoint")
              %else
                  @dtw_assign(focusField, "wfDetailDescription")
              %endif

              <table $(contentTable)>
                  @SetTextOvr(Err_PDPONT)
                  @RtvFldDesc("PPPROC='$(V_PDPROC)' and PPPONT=$(V_PDPONT)", "WFPRDF", "PPDESC", fieldDesc)
                  <tr><td class="dsphdr"><span $(textOvr)>Point</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="wfPoint" type="text" value="$(V_PDPONT)" size="8" maxlength="8"><a href="$(homeURL)$(cGIPath)WFDefinitionSearch.d2w/REPORT$(genericVarBase)&amp;docName=Chg&amp;wfProcess=@dtw_rurlescseq(wfProcess)&amp;fldName=wfPoint&amp;fldDesc=wfPointDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage)</a>
                                                <input name="wfPointDesc" value="$(fieldDesc)" type="text" size="30" disabled></td>
                      %else
                          <td class="inputnmbr"><input name="wfPoint" type="hidden" value="$(V_PDPONT)">$(V_PDPONT) $(fieldDesc)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_PDPONT)

                  @SetTextOvr(Err_PDSEQ)
                  <tr><td class="dsphdr"><span $(textOvr)>Sequence</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="wfSequence" type="text" value="$(V_PDSEQ)" size="8" maxlength="8"> $(reqFieldChar) </td>
                      %else
                          <td class="inputnmbr"><input name="wfSequence" type="hidden" value="$(V_PDSEQ)">$(V_PDSEQ)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_PDSEQ)

                  @SetTextOvr(Err_PDDESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="wfDetailDescription" type="text" value="$(V_PDDESC)" size="50" maxlength="50"> </td>
                  </tr>
                  @DspErrMsg(Err_PDDESC)

                  @RtvFldDesc("PRPROC='$(V_PDPPRC)'", "WFPRHD", "PRDESC", fieldDesc)
                  @SetTextOvr(Err_PDPPRC)
                  <tr><td class="dsphdr"><span $(textOvr)>Detail Point Process</span></td>
                      <td class="inputalph"><input name="pointProcess" type="text" value="$(V_PDPPRC)" size="30" maxlength="30">
                                            <input name="pointProcessDesc" value="$(fieldDesc)" type="text" size="30" disabled></td>
                  </tr>
                  @DspErrMsg(Err_PDPPRC)

                  @RtvFldDesc("ATPROC='$(V_PDPPRC)' and ATACTV='$(V_PDPACT)'", "WFPRAC", "ATDESC", fieldDesc)
                  @SetTextOvr(Err_PDPACT)
                  <tr><td class="dsphdr"><span $(textOvr)>Detail Point Activity</span></td>
                      <td class="inputalph"><input name="pointActivity" type="text" value="$(V_PDPACT)" size="30" maxlength="30">
                                            <a href="$(homeURL)$(cGIPath)WFActivitySearch.d2w/REPORT$(genericVarBase)&amp;docName=Chg&amp;fldProc=pointProcess&amp;fldProcDesc=pointProcessDesc&amp;fldActivity=pointActivity&amp;fldDesc=pointActivityDesc" onclick="$(searchWinVar)"> $(searchImage)</a>
                                            <input name="pointActivityDesc" value="$(fieldDesc)" type="text" size="30" disabled></td>
                  </tr>
                  @DspErrMsg(Err_PDPACT)

                  @SetTextOvr(Err_PDRATE)
                  <tr><td class="dsphdr"><span $(textOvr)>Complexity Rating</span></td>
                      <td class="inputnmbr"><input name="complexityRating" type="text" value="$(V_PDRATE)" size="3" maxlength="3"></td>
                  </tr>
                  @DspErrMsg(Err_PDRATE)
              </table>
          %}

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HWFDTM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  %if (wfDetailDescription == "")
      @RtvFldDesc("PDPROC='$(wfProcess)' and PDPONT=$(wfPoint) and PDSEQ=$(wfSequence)", "WFPRDT", "PDDESC", wfDetailDescription)
  %endif

  @dtw_mUPPERCASE(wfProcess)
  @dtw_mUPPERCASE(pointProcess)
  @dtw_mUPPERCASE(pointActivity)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@frm1", fromPoint)
  @Concat_Field("@@frm2", fromSequence)
  @Concat_Field("@@proc", wfProcess)
  @Concat_Field("@@pont", wfPoint)
  @Concat_Field("@@seq@", wfSequence)
  @Concat_Field("@@desc", wfDetailDescription)
  @Concat_Field("@@pprc", pointProcess)
  @Concat_Field("@@pact", pointActivity)
  @Concat_Field("@@rate", complexityRating)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @dtw_assign(passedWfPoint, wfPoint)
      @dtw_assign(passedWfSequence, wfSequence)
      @Format_ConfMsg_Desc(maintenanceCode, $(wfDetailDescription), "$(wfPoint)-$(wfSequence)", "", "", "", "", confMessage)
      %if (maintenanceCode == "D")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)WFDetail.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@pont", "wfPoint")
      @Format_ConfMsg_Desc("", $(wfDetailDescription), "$(wfPoint)-$(wfSequence)", "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)WFDetail.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;wfPoint=@dtw_rurlescseq(wfPoint)&amp;wfSequence=@dtw_rurlescseq(wfSequence)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
