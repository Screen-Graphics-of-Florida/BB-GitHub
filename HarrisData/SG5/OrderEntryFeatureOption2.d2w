%}

%INCLUDE "$(baseVar)"
%if (catalogVarName != "")
    %INCLUDE "$(catalogVarName)"
    @dtw_assign(bannerName, "$(catBanner)")
    @dtw_assign(trailerName, "$(catTrailer)")
%else
    @dtw_assign(bannerName, "banner.icl")
    @dtw_assign(trailerName, "trailer.icl")
%endif
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Product Configuration"
  d2wName                 = "OrderEntryFeatureOption2.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;lineNumber=@dtw_rurlescseq(lineNumber)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;vendCustItemsFound=@dtw_rurlescseq(vendCustItemsFound)&amp;reliefCode=@dtw_rurlescseq(reliefCode)&amp;addToOrder=@dtw_rurlescseq(addToOrder)&amp;price=@dtw_rurlescseq(price)&amp;orderTypeDesc=@dtw_rurlescseq(orderTypeDesc)&amp;catalogVarName=@dtw_rurlescseq(catalogVarName)"
  programName             = "HOEOEM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "1000"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "1000"
  prtMaxRows              = "1000"
  rowIndexNext            = "1"
  totalPages              = "0"
  errFound                = ""
  imageExists             = ""
  itemNumber              = ""
  itemDesc                = ""
  releaseNumber           = "000"
  qtyOrdered              = "0"
  qtyShipped              = "0"
  price                   = "0"
  qtyOpen                 = "0"
  relQty                  = "0"
  relErr                  = ""
  maintCode               = ""
  mandatory               = ""
  allowMultiple           = ""
  variableQty             = ""
  linkVariable            = ""
  popUpWin                = "Y"
  V_SPPART                = ""
  whsNumber               = ""
  plantNumber             = ""
  promptsExist            = ""
  sec_07                  = ""
  O1LPOV                  = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@customerName", "@dtw_rurlescseq(customerName)", "1", "a", workURL)
  @dtw_replace(workURL, "@@customerNumber", "@dtw_rurlescseq(customerNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@orderControlNumber", "@dtw_rurlescseq(orderControlNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@lineNumber", "@dtw_rurlescseq(lineNumber)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
          @Get_Detail_Line(profileHandle, dataBaseID, orderControlNumber, lineNumber, dropShipNumber, itemNumber, itemDesc, qtyOrdered, qtyShippped, pricedByKit, qtyOpen, relQty, relErr, maintCode)
          %if (displayQtyAvail != "N")
              @RtvFldDesc("O1OCTL=$(orderControlNumber) and O1ORL#=$(lineNumber)", "OEDTWK", "char(O1WH)", whsNumber)
          %endif
          @RtvFldDesc("O1OCTL=$(orderControlNumber) and O1ORL#=$(lineNumber)", "OEDTWK", "char(O1PLT)", plantNumber)
          @RtvFldDesc("O1OCTL=$(orderControlNumber) and O1ORL#=$(lineNumber)", "OEDTWK", "O1LPOV", O1LPOV)
          %if (O1LPOV == "Y")
              @dtw_assign(sec_07, "N")
          %endif
          <script TYPE="text/javascript">
              var optionWin;
              %INCLUDE "numedit.icl"
              %INCLUDE "NewWindowOpen.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "$(bannerName)"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      <table $(contentTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1>$(page_title)</h1></td>
                              %if (formatToPrint == "")
                                  <td class="toolbar">
                                      <a href="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)&amp;maintenanceCode=U">$(acceptImageLrg)</a>
                                      <a href="$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)&amp;formatToPrint=Y" target=_blank>$(formatPrintMed)</a>
                                      @dtw_assign(medIcon, "Y")
                                      %INCLUDE "HelpPage.icl"
                                  </td>
                              %endif
                          </tr>
                          %if (formatToPrint == "Y")
                              <tr><td><h2>$(customerName)</h2></td></tr>
                          %endif
                      </table>

                      $(hrTagAttr)

                      <table $(contentTable)>
                          <tr>
                              <td class="colhdr">Item Number</td>
                              <td class="colhdr">Description</td>
                              <td class="colhdr">Quantity</td>
                              <td class="colhdr">Total Price</td>
                              <td class="colhdr">Extended Price</td>
                          </tr>
                          %INCLUDE "SetRowClass.icl"
                          <tr class="$(rowClass)">
                              <td class="colalph">$(itemNumber)</td>		
                              <td class="colalph">$(itemDesc)</td>		
                              @Format_Nbr(qtyOrdered, F_qtyOrdered, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                              <td class="colnmbr">$(F_qtyOrdered)</td>
                              @Format_Nbr(price, F_price, $(prcNbrDec), $(amtEditCode), "Y", "", "")
                              %if (O1LPOV == "Y")
                                  <td class="oepriceover" $(helpCursor)><span title="Price has been overridden">$(F_price)</span></td>
                              %else
                                  <td class="colnmbr">$(F_price)</td>
                              %endif
                              @RtvFldDesc("O1OCTL=$(orderControlNumber) and O1ORL#=$(lineNumber)", "OEDTWK", "O1ORUF", O1ORUF)
                              @Format_Nbr("@dtw_rdivide(@dtw_rmultiply(qtyOrdered, price), O1ORUF)", ExtendedPrice, "2", $(amtEditCode), "Y", "$", "")
                              <td class="colnmbr">$(ExtendedPrice)</td>
                              %if (formatToPrint == "" && catalogVarName == "")
                                  @RtvFldDesc("O4OCTL=$(orderControlNumber) and O4ORL#=$(lineNumber)", "OECMWK", "char(count(*))", cmtCount)
                    		      %if (cmtCount > "0")
                                      <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)&amp;maintenanceCode=U&amp;updateComments=Y">$(commentExistImage)</a></td>
                                  %else
                                      <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)&amp;maintenanceCode=U&amp;updateComments=Y">$(commentImage)</a></td>
                                  %endif
                              %endif
                          </tr>
                      </table>&nbsp;

                      %if (V_CIUSMP == "Y")
                          <fieldset class="legendBodyFO"><legend class="legendTitleFO">Smart Part</legend>
                          <table $(contentTable)>
                          @dtw_assign(UpdSP, "")
                          @Features_Options_Update(orderControlNumber, lineNumber, UpdSP, V_CIUVCT, smartPart)
                          <tr class="$(rowClass)"><td>$(smartPart) <br></td></tr>
                          </table>
                          </fieldset>
                          <br>
                      %endif

                      %if (formatToPrint == "")
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select e.SADESC as SAFDSC, e.SARSEQ as SAFSEQ, e.SAMAND as SAFMAN, e.SAMULT as SAFMUL, e.SAVARQ as SAFVAR, e.SAER# as SAFER#, a.* ", stmtSQL)
                          @dtw_concat(fileSQL, " HDOPWW a join HDOPWW e on a.SAOCTL=e.SAOCTL and a.SAFEAT=e.SAFEAT and ' '=e.SAOPTN and ' '=e.SABLVL and 'Y'<>e.SASELC ", fileSQL)
                          @dtw_concat(selectSQL, " a.SAOCTL=$(orderControlNumber) and e.SAMAND='Y' and a.SASELC<>'Y' ", selectSQL)
                          @dtw_concat(selectSQL, " and ( ", selectSQL)
                          @dtw_concat(selectSQL, " (a.SAOPTN=' ' and a.SABLVL=' ' and not exists (Select b.SAOPTN from HDOPWW b where b.SAOCTL=$(orderControlNumber) and b.SAFEAT=a.SAFEAT and b.SAOPTN<>' ' and b.SAMNCD='S')) ", selectSQL)
                          @dtw_concat(selectSQL, " or ", selectSQL)
                          @dtw_concat(selectSQL, " (a.SAOPTN<>' ' and a.SAMNCD='S') ", selectSQL)
                          @dtw_concat(selectSQL, " ) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By SAFSEQ, Upper(SAFDSC) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Required_Feature_Query(profileHandle, dataBaseID, stmtSQL)

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_assign(distinctSQL, "SAIGRP,IGDESC")
                          @dtw_concat(stmtSQL, " Select SAIGRP, IGDESC ", stmtSQL)
                          @dtw_concat(fileSQL, " HDOPWW inner join HDIGPH on 'G'=IGTYPE and SAIGRP=IGIGRP and $(plantNumber)=IGPLT ", fileSQL)
                          @dtw_concat(selectSQL, "SAOCTL=$(orderControlNumber) and SAFEAT>' ' and SAOPTN=' ' and SABLVL=' ' and SASELC<>'Y' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Group by SAIGRP,IGDESC ", stmtSQL)
                          @dtw_concat(stmtSQL, " Order By Upper(IGDESC) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Feature_Group_Query(profileHandle, dataBaseID, stmtSQL)
                      %endif

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select e.SADESC as SAFDSC, e.SARSEQ as SAFSEQ, e.SAMAND as SAFMAN, e.SAMULT as SAFMUL, e.SAVARQ as SAFVAR, a.* ", stmtSQL)
                      @dtw_concat(fileSQL, " HDOPWW  a join HDOPWW e on a.SAOCTL=e.SAOCTL and a.SAFEAT=e.SAFEAT and ' '=e.SAOPTN and ' '=e.SABLVL and 'Y'<>e.SASELC ", fileSQL)
                      @dtw_concat(selectSQL, "a.SAOCTL=$(orderControlNumber) and a.SAOPTN<>' ' and a.SAMNCD='S' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By SAFSEQ, Upper(SAFDSC) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      %if (formatToPrint == "Y")
                          @Feature_Item_Print(profileHandle, dataBaseID, stmtSQL)
                      %else
                          @Feature_Item_Query(profileHandle, dataBaseID, stmtSQL)
                      %endif

                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
              %INCLUDE "$(trailerName)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Required_Feature_Query (IN CHAR(64)    profileHandle,
                                              CHAR(2)     dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <fieldset class="legendBodyFO"><legend class="legendTitleFO">Required Feature</legend>
          <table $(contentTable)>
              <tr>
                  <td class="colhdr">$(optionHeading)</td>
                  <td class="colhdr">Feature</td>
                  <td class="colhdr">Option</td>
                  <td class="colhdr">Price</td>
                  <td class="colhdr">Extra<br>Charge</td>
                  <td class="colhdr">Extended Price</td>
                  <td class="colhdr">Quantity</td>
                  <td class="colhdr">Quantity<br>Available</td>
              </tr>
              %if (sql_Record_Count == "0")
                  <tr>
                      <td class="confMsg" colspan="10">No Required Features Found</td>
                  </tr>                	
              %endif

              %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;feature=@dtw_rurlescseq(V_SAFEAT)&amp;featureDesc=@dtw_rurlescseq(V_SAFDSC)&amp;option=@dtw_rurlescseq(V_SAOPTN)&amp;optionDesc=@dtw_rurlescseq(V_SADESC)")
                  @Format_Confirm_Desc($(V_SAFDSC), $(V_SADESC), "", "", "", "", confirmDesc)
                  <tr>
                      <td class="opticon">
                          %if (V_SAMNCD == "S")
                              %if (sec_07 == "Y")
                                  <a href="$(homeURL)$(cGIPath)OrderEntryFeatureOptionPriceOverride.d2w/MAINTAIN$(maintainVar)&amp;biLevel=@dtw_rurlescseq(V_SABLVL)" onclick="$(smallPromptWinVar)">$(changeImageSml)</a>
                              %endif
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                      @dtw_assign(fromD2w, "$(d2wName)/DISPLAY")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)OrderEntryOptionSearch.d2w/LOAD$(d2wVarBase)&amp;feature=@dtw_rurlescseq(V_SAFEAT)&amp;featureDesc=@dtw_rurlescseq(V_SAFDSC)&amp;maintenanceCode=L&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))" onclick="$(searchWinVar)" title="Search">$(V_SAFDSC)</a></td>
                      %if (V_SAFER# == "" && V_SAER# != "")
                          @dtw_assign(V_SAFER#, V_SAER#)
                      %endif
                      %if (V_SAFER# != "")
                          @Ret_Error_Msg(profileHandle, dataBaseID, $(V_SAFER#), errorMessage)
                          <td class="error" colspan="4">$(errorMessage)</td>
                      %endif
                      %if (V_SAMNCD == "S" && V_SAFER# == "")
                          <td class="colalph"><span title="Item $(V_SAOPTN)">$(V_SADESC)</span></td>
                          %if (V_SALPOV == "Y" && O1LPOV != "Y")
                              @Format_Nbr(V_SASLPR, F_SASLPR, $(prcNbrDec), "3", "Y", "", "")
                              <td class="oepriceover" $(helpCursor)><span title="Price has been overridden">$(F_SASLPR)</span></td>
                          %else
                              @Format_Nbr(V_SASLPR, F_SASLPR, $(prcNbrDec), "4", "Y", "", "")
                              <td class="colnmbr">$(F_SASLPR)</td>
                          %endif
                          @Format_Nbr(V_SAXCHG, F_SAXCHG, $(prcNbrDec), "4", "Y", "", "")
                          <td class="colnmbr">$(F_SAXCHG)</td>
                          %if (V_SAPCPP == ".0000")
                              @dtw_assign(V_SAPCPP, "1")
                          %endif
                          @dtw_assign(extPrice, @dtw_radd(@dtw_rdivide(@dtw_rmultiply(V_SAOQTY, V_SASLPR), V_SAPCPP), V_SAXCHG))
                          @Format_Nbr(extPrice, ExtendedPrice, $(prcNbrDec), $(amtEditCode), "Y", "", "")
                          <td class="colnmbr">$(ExtendedPrice)</td>
                          @Format_Nbr(V_SAOQTY, F_SAOQTY, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                          %if (V_SAFVAR == "Y")
                               @dtw_assign(columnId, "$(V_SAFEAT)$(V_SAOPTN)")
                               <td class="colnmbr"><a href="$(homeURL)$(cGIPath)OrderEntryOptionQuantity.d2w/MAINTAIN$(maintainVar)&amp;columnId=@dtw_rurlescseq(columnId)&amp;fromD2w=@dtw_rurlescseq(fromD2w)" onclick="$(smallPromptWinVar)" title="Change Quantity"><span id="req$(columnId)">$(F_SAOQTY)</span></a></td>
                          %else
                              <td class="colnmbr">$(F_SAOQTY)</td>
                          %endif
                          %if ((displayQtyAvail == "Y" || displayQtyAvail == "Z") && V_SAVCAT != "Y")
                              @dtw_assign(qtyAvailable, "0")
                              @Get_Qty_Avail(profileHandle, dataBaseID, V_SAOPTN, whsNumber, qtyAvailable)
                              %if (displayQtyAvail == "Z" && qtyAvailable < "0")
                                  @dtw_assign(qtyAvailable, "0")
                              %endif
                              @Format_Nbr(qtyAvailable, F_qtyAvailable, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                              <td class="colnmbr"><a href="$(homeURL)$(cGIPath)OrderEntryItemWhsQty.d2w/REPORT$(genericVarBase)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;itemNumber=@dtw_rurlescseq(V_SAOPTN)&amp;warehouseNumber=@dtw_rurlescseq(whsNumber)&amp;atpPlant=@dtw_rurlescseq(plantNumber)&amp;inquiryOnly=Y" onclick="$(inquiryWinVar)" title="View Item/Whs Quantities">$(F_qtyAvailable)</a></td>
                          %elif (displayQtyAvail == "Y" || displayQtyAvail == "Z")
                              <td>&nbsp;</td>
                          %endif
                          @Check_Item_Comments(profileHandle, dataBaseID, V_SAOPTN, "", customerNumber, "WEB", headerTrailer, itemComments)
                          @dtw_assign(itemImage, "$(V_SAOPTN)$(itemImageExt)")
                          @dtwf_exists(itemImage, imageExists)
                          <td class="colicon">
                              @dtw_assign(commentVar, "$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(V_SAOPTN)&amp;vendCustItemNumber=&amp;itemDesc=@dtw_rurlescseq(V_SADESC)&amp;vendCustNumber=@dtw_rurlescseq(customerNumber)&amp;vendCustFlag=C")
                              %if (itemComments == "Y")
                                  <a href="$(homeURL)$(cGIPath)ItemComments.d2w/REPORT$(commentVar)" onclick="$(commentWinVar)">$(commentExistImage)</a>
                              %elif (itemComments != "")
                                  <a href="$(homeURL)$(cGIPath)VendCustItemComments.d2w/REPORT$(commentVar)" onclick="$(commentWinVar)">$(commentExistImage)</a>
                              %endif
                              %if (imageExists == "Y")
                                  <a href="$(homeURL)$(cGIPath)ImageDisplay.d2w/DISPLAY$(genericVarBase)&amp;imageDisplayPath=$(homeURL)$(itemImage)&amp;imageDesc=@dtw_rurlescseq(V_SADESC)" onclick="$(itemImageWinVar)">$(foundImage)</a>
                              %endif
                          </td>
                      %endif
                  </tr>
              %}

          </table>
      </fieldset>&nbsp;
  %}
%}

%FUNCTION(dtw_sql) Feature_Group_Query (IN CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <fieldset class="legendBodyFO"><legend class="legendTitleFO">Feature Group</legend>
          <table $(contentTable)>
              %if (sql_Record_Count == "0")
                  <tr>
                      <td class="confMsg" colspan="10">No Feature Groups Found</td>
                  </tr>                	
              %endif

              %ROW{
                  <tr>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)OrderEntryFeatureGroup.d2w/REPORT$(d2wVarBase)&amp;featureGroup=@dtw_rurlescseq(V_SAIGRP)&amp;featureGroupDesc=@dtw_rurlescseq(V_IGDESC)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">$(V_IGDESC)</a></td>
                  </tr>
              %}

          </table>
      </fieldset>&nbsp;
  %}
%}

%FUNCTION(dtw_sql) Feature_Item_Query (IN  CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <fieldset class="legendBodyFO"><legend class="legendTitleFO">Selected Options</legend>
          <table $(contentTable)>
              <tr>
                  <td class="colhdr">$(optionHeading)</td>
                  <td class="colhdr">Feature</td>
                  <td class="colhdr">Option</td>
                  <td class="colhdr">Price</td>
                  <td class="colhdr">Extra<br>Charge</td>
                  <td class="colhdr">Extended Price</td>
                  <td class="colhdr">Quantity</td>
                  <td class="colhdr">Quantity<br>Available</td>
              </tr>
              %if (sql_Record_Count == "0")
                  <tr>
                      <td class="confMsg" colspan="10">No Selected Options Found</td>
                  </tr>                	
              %endif
              @dtw_assign(optionTotal, "0")
		
              %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;feature=@dtw_rurlescseq(V_SAFEAT)&amp;featureDesc=@dtw_rurlescseq(V_SAFDSC)&amp;option=@dtw_rurlescseq(V_SAOPTN)&amp;optionDesc=@dtw_rurlescseq(V_SADESC)")
                  @Format_Confirm_Desc($(V_SAFDSC), $(V_SADESC), "", "", "", "", confirmDesc)
                  @Check_Item_Comments(profileHandle, dataBaseID, V_SAOPTN, "", customerNumber, "WEB", headerTrailer, itemComments)
                  @dtw_assign(itemImage, "$(V_SAOPTN)$(itemImageExt)")
                  @dtwf_exists(itemImage, imageExists)
                  <tr>
                      <td class="opticon">
                          %if (sec_07 == "Y")
                              <a href="$(homeURL)$(cGIPath)OrderEntryFeatureOptionPriceOverride.d2w/MAINTAIN$(maintainVar)&amp;biLevel=@dtw_rurlescseq(V_SABLVL)" onclick="$(smallPromptWinVar)">$(changeImageSml)</a>
                          %endif
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                      </td>
                      @dtw_assign(fromD2w, "$(d2wName)/DISPLAY")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)OrderEntryOptionSearch.d2w/LOAD$(d2wVarBase)&amp;feature=@dtw_rurlescseq(V_SAFEAT)&amp;featureDesc=@dtw_rurlescseq(V_SAFDSC)&amp;maintenanceCode=L&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))" onclick="$(searchWinVar)" title="Search">$(V_SAFDSC)</a></td>
                      <td class="colalph"><span title="Item $(V_SAOPTN)">$(V_SADESC)</span></td>
                      %if (V_SALPOV == "Y" && O1LPOV != "Y")
                          @Format_Nbr(V_SASLPR, F_SASLPR, $(prcNbrDec), "3", "Y", "", "")
                          <td class="oepriceover" $(helpCursor)><span title="Price has been overridden">$(F_SASLPR)</span></td>
                      %else
                          @Format_Nbr(V_SASLPR, F_SASLPR, $(prcNbrDec), "4", "Y", "", "")
                          <td class="colnmbr">$(F_SASLPR)</td>
                      %endif
                      @Format_Nbr(V_SAXCHG, F_SAXCHG, $(prcNbrDec), "4", "Y", "", "")
                      <td class="colnmbr">$(F_SAXCHG)</td>
                      %if (V_SAPCPP == ".0000")
                          @dtw_assign(V_SAPCPP, "1")
                      %endif
                      @dtw_assign(extPrice, @dtw_radd(@dtw_rdivide(@dtw_rmultiply(V_SAOQTY, V_SASLPR), V_SAPCPP), V_SAXCHG))
                      @dtw_add(optionTotal, @dtw_radd(@dtw_rdivide(@dtw_rmultiply(V_SAOQTY, V_SASLPR), V_SAPCPP), V_SAXCHG), "15", optionTotal)
                      @Format_Nbr(extPrice, ExtendedPrice, $(prcNbrDec), $(amtEditCode), "Y", "", "")
                      <td class="colnmbr">$(ExtendedPrice)</td>
                      @Format_Nbr(V_SAOQTY, F_SAOQTY, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                      %if (V_SAFVAR == "Y")
                          @dtw_assign(columnId, "$(V_SAFEAT)$(V_SAOPTN)")
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)OrderEntryOptionQuantity.d2w/MAINTAIN$(maintainVar)&amp;columnId=@dtw_rurlescseq(columnId)&amp;fromD2w=@dtw_rurlescseq(fromD2w)" onclick="$(smallPromptWinVar)" title="Change Quantity"><span id="sel$(columnId)">$(F_SAOQTY)</span></a></td>
                      %else
                          <td class="colnmbr">$(F_SAOQTY)</td>
                      %endif
                      %if ((displayQtyAvail == "Y" || displayQtyAvail == "Z") && V_SAVCAT != "Y")
                          @dtw_assign(qtyAvailable, "0")
                          @Get_Qty_Avail(profileHandle, dataBaseID, V_SAOPTN, whsNumber, qtyAvailable)
                          %if (displayQtyAvail == "Z" && qtyAvailable < "0")
                              @dtw_assign(qtyAvailable, "0")
                          %endif
                          @Format_Nbr(qtyAvailable, F_qtyAvailable, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)OrderEntryItemWhsQty.d2w/REPORT$(genericVarBase)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;itemNumber=@dtw_rurlescseq(V_SAOPTN)&amp;warehouseNumber=@dtw_rurlescseq(whsNumber)&amp;atpPlant=@dtw_rurlescseq(plantNumber)&amp;inquiryOnly=Y" onclick="$(inquiryWinVar)" title="View Item/Whs Quantities">$(F_qtyAvailable)</a></td>
                      %elif (displayQtyAvail == "Y" || displayQtyAvail == "Z")
                          <td>&nbsp;</td>
                      %endif
                      <td class="colicon">
                          @dtw_assign(commentVar, "$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(V_SAOPTN)&amp;vendCustItemNumber=&amp;itemDesc=@dtw_rurlescseq(V_SADESC)&amp;vendCustNumber=@dtw_rurlescseq(customerNumber)&amp;vendCustFlag=C")
                          %if (itemComments == "Y")
                              <a href="$(homeURL)$(cGIPath)ItemComments.d2w/REPORT$(commentVar)" onclick="$(commentWinVar)">$(commentExistImage)</a>
                          %elif (itemComments != "")
                              <a href="$(homeURL)$(cGIPath)VendCustItemComments.d2w/REPORT$(commentVar)" onclick="$(commentWinVar)">$(commentExistImage)</a>
                          %endif
                          %if (imageExists == "Y")
                              <a href="$(homeURL)$(cGIPath)ImageDisplay.d2w/DISPLAY$(genericVarBase)&amp;imageDisplayPath=$(homeURL)$(itemImage)&amp;imageDesc=@dtw_rurlescseq(V_SADESC)" onclick="$(itemImageWinVar)">$(foundImage)</a>
                          %endif
                      </td>
                  </tr>
              %}
              @Format_Nbr(optionTotal, F_optionTotal, $(prcNbrDec), $(amtEditCode), "Y", "", "")
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colnmbr" colspan="5">Option Total</td>
                  <td class="coltotal">$(F_optionTotal)</td>
              </tr>
              @dtw_subtract(price, optionTotal, itemPrice)
              @Format_Nbr(itemPrice, F_itemPrice, $(prcNbrDec), $(amtEditCode), "Y", "", "")
              <tr class="$(rowClass)">
                  <td class="colnmbr" colspan="5">Base Item Price</td>
                  <td class="colnmbr">$(F_itemPrice)</td>
              </tr>
              @Format_Nbr(price, F_price, $(prcNbrDec), $(amtEditCode), "Y", "", "")
              <tr class="$(rowClass)">
                  <td class="colnmbr" colspan="5">Total Price</td>
                  <td class="coltotal">$(F_price)</td>
              </tr>
          </table>
      </fieldset>
  <a href="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)&amp;maintenanceCode=U">$(acceptImageLrg)</a>
  <a href="$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)&amp;formatToPrint=Y" target=_blank>$(formatPrintMed)</a>
  @dtw_assign(medIcon, "Y")
  %INCLUDE "HelpPage.icl"
  $(hrTagAttr)
  %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_sql) Feature_Item_Print (IN  CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <tr>
              <td class="colhdr">Feature</td>
              <td class="colhdr">Option</td>
              <td class="colhdr">Description</td>
              <td class="colhdr">Quantity</td>
              <td class="colhdr">Price</td>
              <td class="colhdr">Extra Charge</td>
              <td class="colhdr">Extended Price</td>
          </tr>
          @dtw_assign(saveFeature, "")
          @dtw_assign(optionTotal, "0")
		
          %ROW{
              %if (saveFeature != V_SAFEAT)
                  %INCLUDE "SetRowClass.icl"
                  @dtw_assign(saveFeature, V_SAFEAT)
                  @dtw_assign(newFeature, V_SAFEAT)
              %else
                  @dtw_assign(newFeature, "")
              %endif
              %if (V_SAPCPP == ".0000")
                  @dtw_assign(V_SAPCPP, "1")
              %endif
              @dtw_assign(extPrice, @dtw_radd(@dtw_rdivide(@dtw_rmultiply(V_SAOQTY, V_SASLPR), V_SAPCPP), V_SAXCHG))
              @dtw_add(optionTotal, @dtw_radd(@dtw_rdivide(@dtw_rmultiply(V_SAOQTY, V_SASLPR), V_SAPCPP), V_SAXCHG), "15", optionTotal)
              @Format_Nbr(extPrice, ExtendedPrice, $(prcNbrDec), $(amtEditCode), "Y", "", "")
              <tr class="$(rowClass)">
                  <td class="colalph">$(newFeature)</td>
                  <td class="colalph">$(V_SAOPTN)</td>
                  <td class="colalph">$(V_SADESC)</td>
                  @Format_Nbr(V_SAOQTY, F_SAOQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  <td class="colnmbr">$(F_SAOQTY)</td>
                  @Format_Nbr(V_SASLPR, F_SASLPR, $(prcNbrDec), "4", "", "", "")
                  <td class="colnmbr">$(F_SASLPR)</td>
                  @Format_Nbr(V_SAXCHG, F_SAXCHG, $(prcNbrDec), "4", "", "", "")
                  <td class="colnmbr">$(F_SAXCHG)</td>
                  <td class="colnmbr">$(ExtendedPrice)</td>
              </tr>
          %}
          @Format_Nbr(optionTotal, F_optionTotal, $(prcNbrDec), $(amtEditCode), "Y", "", "")
          %INCLUDE "SetRowClass.icl"
          <tr class="$(rowClass)">
              <td class="colnmbr" colspan="6">Option Total</td>
              <td class="coltotal">$(F_optionTotal)</td>
          </tr>
          @dtw_subtract(price, optionTotal, itemPrice)
          @Format_Nbr(itemPrice, F_itemPrice, $(prcNbrDec), $(amtEditCode), "Y", "", "")
          <tr class="$(rowClass)">
              <td class="colnmbr" colspan="6">Base Item Price</td>
              <td class="colnmbr">$(F_itemPrice)</td>
          </tr>
          @Format_Nbr(price, F_price, $(prcNbrDec), $(amtEditCode), "Y", "", "")
          <tr class="$(rowClass)">
              <td class="colnmbr" colspan="6">Total Price</td>
              <td class="coltotal">$(F_price)</td>
          </tr>
      </table>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(DTW_directcall) Get_Detail_Line (INOUT CHAR(64)  profileHandle,
                                                 CHAR(2)   dataBaseID,
                                                 DEC(8,0)  orderControlNumber,
                                                 DEC(3,0)  lineNumber,
                                                 DEC(7,0)  dropShipNumber,
                                                 CHAR(15)  itemNumber,
                                                 CHAR(30)  itemDesc,
                                                 DEC(13,4) qtyOrdered,
                                                 DEC(13,4) qtyShipped,
                                                 CHAR(1)   pricedByKit,
                                                 DEC(13,4) qtyOpen,
                                                 DEC(13,4) relQty,
                                                 CHAR(1)   relErr,
                                                 CHAR(1)   maintCode)
{%EXEC {HOEDWR_W.PGM %}
%}

%FUNCTION(dtw_directcall) Update_Feature_Option (INOUT CHAR(64)    profileHandle,
                                                 INOUT CHAR(32000) edtVar,
                                                 INOUT CHAR(32000) errVar,
                                                 INOUT CHAR(1)     errFound,
                                                 INOUT DEC(13,5)   price)
{%EXEC {HHDFO2_W.PGM %}
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @Concat_Field("@@xhnd", profileHandle)
  @Concat_Field("@@octl", orderControlNumber)
  @Concat_Field("@@orl#", lineNumber)
  @Concat_Field("@@mncd", maintenanceCode)
  @Concat_Field("@@ucat", productCfgOptionDesc)
  %if (maintenanceCode != "U")
      @Concat_Field("@@feat", feature)
      @Concat_Field("@@optn", option)
  %endif

  @dtw_concat(edtVar, "}{", edtVar)
  @Update_Feature_Option(profileHandle, edtVar, errVar, errFound, price)

  @Decat_Field("@@mfgr") @dtw_assign(mfgReview, fieldValue)
  %if (mfgReview != "")
      %if (prtActivity == "N")
          @RtvFldDesc("H1OCTL=$(orderControlNumber)", "OEHDWK", "char(H1ORD#)", orderNumber)
          %INCLUDE "stmtSQLClear.icl"
          @dtw_concat(stmtSQL, " Update WKVMOC Set MOPRT=' ' ", stmtSQL)
          @dtw_concat(stmtSQL, " Where MOOCTL=$(orderControlNumber) and MOORD#=$(orderNumber) and MOORL#=$(lineNumber) @@endsql ", stmtSQL)
          @SQL_Update(stmtSQL, status)
      %endif
  %endif
  %if (errFound == "" && updateComments == "Y")
      @dtw_assign(fromD2w, "$(d2wName)/INPUT")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)OrderEntryComments.d2w/COMMENTS$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;itemDescription=@dtw_rurlescseq(itemDesc)&amp;lineNumber=@dtw_rurlescseq(lineNumber)&amp;fromD2w=@dtw_rurlescseq(fromD2w)">
  %elif (errFound == "Y" || maintenanceCode != "U")
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)">
  %else
      %if (V_CIUSMP == "Y")
          @dtw_assign(UpdSP, "Y")
          @Features_Options_Update(orderControlNumber, lineNumber, UpdSP, V_CIUVCT, smartPart)
      %endif
      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Update OEORVW Set RVMPTY=$(priority) ", stmtSQL)
      @dtw_concat(stmtSQL, " Where RVOCTL=$(orderControlNumber) @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)

      @DTW_ASSIGN(updateTotal, "Y")
      @Update_Misc_Charges (profileHandle, dataBaseID, orderControlNumber, freightCharge, specialCharge, updateTotal)
      <script TYPE="text/javascript">
          opener.location.href=opener.location.href;
          window.close()
      </script>
  %endif
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("O1OCTL=$(orderControlNumber) and O1ORL#=$(lineNumber)", "OEDTWK inner join HDOPWD on O1PLT=SAPLT and O1ITEM=SAFPRT", "char(count(*))", dftCount)
  %if (dftCount > "0")
      @dtw_assign(omitDft, "")
      @RtvFldDesc("OPOCTL=$(orderControlNumber) and OPORL#=$(lineNumber)", "OEOPWK", "char(count(*))", cfgCount)
      %if (cfgCount > "0")
           @dtw_assign(omitDft, " and SAMNCD<>'S' ")
      %endif

      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Delete From HDOPWW Where SAOCTL=$(orderControlNumber) @@endsql", stmtSQL)
      @SQL_Update(stmtSQL, status)

      @RtvFldDesc("O1OCTL=$(orderControlNumber) and O1ORL#=$(lineNumber)", "OEDTWK", "O1PLT", fPlt)
      @RtvFldDesc("O1OCTL=$(orderControlNumber) and O1ORL#=$(lineNumber)", "OEDTWK", "O1ITEM", fItem)

      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Insert Into HDOPWW (SAOCTL,SARSEQ,SAFPRT,SAFEAT,SABLVL,SABLDS,SAMNCD,SAOPTN,SADESC,SAMAND,SAMULT,SAXCHG, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     SAIMQT,SAVARQ,SAFQTY,SAOQTY,SASLPR,SAPCPP,SALPOV,SASLFT,SAER#,SASELC,SAVCAT, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     SASEG1,SASPC1,SASEG2,SASPC2,SASEG3,SASPC3,SASEG4,SASPC4,SASEG5,SASPC5, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     SASCRP,SASCRV,SADSPC,SAIAVO,SARBLV,SAROPT,SANAME,SAVALU,SAINDX,SAIGRP) ", stmtSQL)
      @dtw_concat(stmtSQL, " Select $(orderControlNumber),SARSEQ,'$(fItem)',SAFEAT,SABLVL,SABLDS,SAMNCD,SAOPTN,SADESC,SAMAND,SAMULT,SAXCHG, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     SAIMQT,SAVARQ,SAFQTY,SAOQTY,SASLPR,SAPCPP,SALPOV,SASLFT,SAER#,SASELC,SAVCAT, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     SASEG1,SASPC1,SASEG2,SASPC2,SASEG3,SASPC3,SASEG4,SASPC4,SASEG5,SASPC5, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     SASCRP,SASCRV,SADSPC,SAIAVO,SARBLV,SAROPT,SANAME,SAVALU,SAINDX,SAIGRP ", stmtSQL)
      @dtw_concat(stmtSQL, " From HDOPWD Where SAPLT=$(fPlt) and SAFPRT='$(fItem)' $(omitDft) @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)

      %if (cfgCount > "0")
          %INCLUDE "stmtSQLClear.icl"
          @dtw_concat(stmtSQL, " Update OEOPWK Set OPDESC=(Select IMIMDS From HDIMST Where IMITEM=OPOPTN) ", stmtSQL)
          @dtw_concat(stmtSQL, " Where OPOCTL=$(orderControlNumber) and OPORL#=$(lineNumber)  @@endsql ", stmtSQL)
          @SQL_Update(stmtSQL, status)

          %if (productCfgOptionDesc == "C")
              %INCLUDE "stmtSQLClear.icl"
              @dtw_concat(stmtSQL, " Update OEOPWK Set OPDESC=coalesce((Select substr(IXCTDS,1,length(OPDESC)) From HDIMSX where IXITEM=OPOPTN and IXCTDS<>' '),OPDESC)  ", stmtSQL)
              @dtw_concat(stmtSQL, " Where OPOCTL=$(orderControlNumber) and OPORL#=$(lineNumber)  @@endsql ", stmtSQL)
              @SQL_Update(stmtSQL, status)
          %endif

          %INCLUDE "stmtSQLClear.icl"
          @dtw_concat(stmtSQL, " Insert Into HDOPWW (SAOCTL,SARSEQ,SAFPRT,SAFEAT,SABLVL,SABLDS,SAMNCD,SAOPTN,SADESC,SAMAND,SAMULT,SAXCHG, ", stmtSQL)
          @dtw_concat(stmtSQL, "                     SAIMQT,SAVARQ,SAFQTY,SAOQTY,SASLPR,SAPCPP,SALPOV,SASLFT,SAER#,SASELC,SAVCAT, ", stmtSQL)
          @dtw_concat(stmtSQL, "                     SASEG1,SASPC1,SASEG2,SASPC2,SASEG3,SASPC3,SASEG4,SASPC4,SASEG5,SASPC5, ", stmtSQL)
          @dtw_concat(stmtSQL, "                     SASCRP,SASCRV,SADSPC,SAIAVO,SARBLV,SAROPT,SANAME,SAVALU,SAINDX,SAIGRP) ", stmtSQL)
          @dtw_concat(stmtSQL, " Select $(orderControlNumber),0,'$(fItem)',OPFEAT,OPBLVL,' ','S',OPOPTN,OPDESC,' ',' ',OPXCHG, ", stmtSQL)
          @dtw_concat(stmtSQL, "                     OPIMQT,' ',OPIMQT,OPQORD,OPSLPR,0,OPLPOV,' ',' ',' ',' ', ", stmtSQL)
          @dtw_concat(stmtSQL, "                     OPSEG1,OPSPC1,OPSEG2,OPSPC2,OPSEG3,OPSPC3,OPSEG4,OPSPC4,OPSEG5,OPSPC5, ", stmtSQL)
          @dtw_concat(stmtSQL, "                     ' ',' ',' ',OPIAVO,' ',' ',' ',' ',0,' ' ", stmtSQL)
          @dtw_concat(stmtSQL, " From OEOPWK Where OPOCTL=$(orderControlNumber) and OPORL#=$(lineNumber) and OPPLT=$(fPlt) and OPFPRT='$(fItem)'  @@endsql ", stmtSQL)
          @SQL_Update(stmtSQL, status)
      %endif

      @dtw_assign(edtVar, "")
      @Concat_Field("@@octl", orderControlNumber)
      @Concat_Field("@@orl#", lineNumber)
      @dtw_assign(maintenanceCode, "P")
      @Concat_Field("@@mncd", maintenanceCode)
      @Concat_Field("@@ucat", productCfgOptionDesc)
      @dtw_concat(edtVar, "}{", edtVar)

      @Update_Feature_Option(profileHandle, edtVar, errVar, errFound, price)
  %else
      @dtw_assign(edtVar, "")
      @Concat_Field("@@octl", orderControlNumber)
      @Concat_Field("@@orl#", lineNumber)
      @Concat_Field("@@mncd", maintenanceCode)
      @Concat_Field("@@ucat", productCfgOptionDesc)
      @dtw_concat(edtVar, "}{", edtVar)

      @Update_Feature_Option(profileHandle, edtVar, errVar, errFound, price)
  %endif
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)&amp;updateRowNum=@dtw_rurlescseq(updateRowNum)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(PRICE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @Concat_Field("@@octl", orderControlNumber)
  @Concat_Field("@@orl#", lineNumber)
  @Concat_Field("@@mncd", maintenanceCode)
  @Concat_Field("@@ucat", productCfgOptionDesc)
  @Concat_Field("@@feat", feature)
  @Concat_Field("@@optn", option)
  @dtw_concat(edtVar, "}{", edtVar)

  @Update_Feature_Option(profileHandle, edtVar, errVar, errFound, price)
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)&amp;updateRowNum=@dtw_rurlescseq(updateRowNum)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  %if (updateRowNum > "0")
      @dtw_assign(START_ROW_NUM,  "$(updateRowNum)")
  %endif
  @Set_SQL(stmtSQL)
%}