%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Manufacturing Order Summary Report"
  d2wName                 = "MfgOrderSummaryReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  forPlant                = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.fromQuantity.value < "0" &&
                      document.Chg.fromQuantity.value != "")
                      {alert("Negative from quantity not allowed");
                      document.Chg.fromQuantity.focus();
                      document.Chg.fromQuantity();
                      return false;}
                  if (document.Chg.toQuantity.value < "0" &&
                      document.Chg.toQuantity.value != "")
                      {alert("Negative to quantity not allowed");
                      document.Chg.toQuantity.focus();
                      document.Chg.toQuantity();
                      return false;}
                  if (editNum(document.Chg.fromPlantNumber, 3, 0) &&
                      editNum(document.Chg.toPlantNumber, 3, 0) &&
                      editdate(document.Chg.fromCloseDate) &&
                      editdate(document.Chg.toCloseDate) &&
                      editNum(document.Chg.fromQuantity, 9, 4) &&
                      editNum(document.Chg.toQuantity, 9, 4) &&
                      editFromToAll(document.Chg.fromPlantNumber, document.Chg.toPlantNumber, document.Chg.allPlantNumber, 3) &&
                      editFromToAll(document.Chg.fromCloseDate, document.Chg.toCloseDate, document.Chg.allCloseDate, "D") &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromOrderNumber, document.Chg.toOrderNumber, document.Chg.allOrderNumber, "A") &&
                      editFromToAll(document.Chg.fromReferenceNumber, document.Chg.toReferenceNumber, document.Chg.allReferenceNumber, "A") &&
                      editFromToAll(document.Chg.fromQuantity, document.Chg.toQuantity, document.Chg.allQuantity, 13)
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "MFGORDERSUMMARYREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromPlantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@fplt", "fromPlantNumber")        @dtw_assign(Err_TRPLT1,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@incz")  @dtw_assign(V_TRINCZ,  fieldValue)

                                  @Decat_Field("@@fplt")  @dtw_assign(V_TRPLT1,  fieldValue)
                                  @Decat_Field("@@tplt")  @dtw_assign(V_TRPLT2,  fieldValue)
                                  @Decat_Field("@@aplt")  @dtw_assign(V_PLTALL,  fieldValue)

                                  @Decat_Field("@@fdat")  @dtw_assign(V_TRCDT1, fieldValue)
                                  @Decat_Field("@@tdat")  @dtw_assign(V_TRCDT2, fieldValue)
                                  @Decat_Field("@@adat")  @dtw_assign(V_CDTALL, fieldValue)

                                  @Decat_Field("@@fitm")  @dtw_assign(V_TRPRT1, fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_TRPRT2, fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_PRTALL, fieldValue)

                                  @Decat_Field("@@ford")  @dtw_assign(V_TRORD1,  fieldValue)
                                  @Decat_Field("@@tord")  @dtw_assign(V_TRORD2,  fieldValue)
                                  @Decat_Field("@@aord")  @dtw_assign(V_ORDALL,  fieldValue)

                                  @Decat_Field("@@fref")  @dtw_assign(V_TRROR1,  fieldValue)
                                  @Decat_Field("@@tref")  @dtw_assign(V_TRROR2,  fieldValue)
                                  @Decat_Field("@@aref")  @dtw_assign(V_RORALL,  fieldValue)

                                  @Decat_Field("@@fqty")  @dtw_assign(V_TRQTY1,  fieldValue)
                                  @Decat_Field("@@tqty")  @dtw_assign(V_TRQTY2,  fieldValue)
                                  @Decat_Field("@@aqty")  @dtw_assign(V_QTYALL,  fieldValue)

                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries
 Values %}
                                  %if (V_TRINCZ == "02")
                                      @dtw_assign(no, "")
                                      @dtw_assign(yes, "CHECKED")
                                  %else
                                      @dtw_assign(no, "CHECKED")
                                      @dtw_assign(yes, "")
                                  %endif
                                  %if (V_PLTALL == "ALL")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPlantNumber, "")
                                  %endif
                                  %if (V_CDTALL == "ALL")
                                      @dtw_assign(checkedallCloseDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallCloseDate, "")
                                  %endif
                                  %if (V_PRTALL == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_ORDALL == "ALL")
                                      @dtw_assign(checkedallOrderNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallOrderNumber, "")
                                  %endif
                                  %if (V_RORALL == "ALL")
                                      @dtw_assign(checkedallReferenceNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallReferenceNumber, "")
                                  %endif
                                  %if (V_QTYALL == "ALL")
                                      @dtw_assign(checkedallQuantity, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallQuantity, "")
                                  %endif

                              %else
                                  @dtw_assign(no, "CHECKED")
                                  @dtw_assign(yes, "")
                                  @RtvDftPlant(plantNumber, plantName)
                                  %if (plantNumber == "0")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(V_TRPLT1, plantNumber)
                                      @dtw_assign(V_TRPLT2, plantNumber)
                                      @dtw_assign(checkedallPlantNumber, "")
                                      @dtw_assign(focusField, "fromCloseDate")
                                  %endif
                                  @dtw_assign(checkedallCloseDate, "CHECKED")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallOrderNumber, "CHECKED")
                                  @dtw_assign(checkedallReferenceNumber, "CHECKED")
                                  @dtw_assign(checkedallQuantity, "CHECKED")
                              %endif

                          <tr><td class="dsphdr"><span $(textOvr)>Include Orders With Zero Quantity Received</span></td>
                                  <td class="inputnmbr"><input name="zeroQtyReceived" type="radio" VALUE='01' $(no)>No</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="zeroQtyReceived" type="radio" VALUE='02' $(yes)>Yes</td>
                              </tr>

                          </table>

                          <table $(contentTable)>

                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_TRPLT1)
                              <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                  <td class="inputnmbr"><input name="fromPlantNumber" value="$(V_TRPLT1)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromPlantNumber&amp;fldDesc=fplantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fplantName"  type="hidden"></td>
                                  <td class="inputnmbr"><input name="toPlantNumber" value="$(V_TRPLT2)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toPlantNumber&amp;fldDesc=tplantName" onclick="$(searchWinVar)">  $(searchImage) </a><input name="tplantName"  type="hidden"></td>
                                  <td class="inputalph"><input name="allPlantNumber" value='ALL' $(checkedallPlantNumber) type="checkbox" onClick="if (this.checked) this.form.fromPlantNumber.value='', this.form.toPlantNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_TRPLT1)

                              <tr><td class="dsphdr">Close Date</td>
                                  <td class="inputnmbr"><input name="fromCloseDate" value="$(V_TRCDT1)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromCloseDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toCloseDate" value="$(V_TRCDT2)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toCloseDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allCloseDate" value='ALL' $(checkedallCloseDate) type="checkbox" onClick="if (this.checked) this.form.fromCloseDate.value='', this.form.toCloseDate.value='';"></td>
                              </tr>

                              <tr><td class="dsphdr">Item Number</td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_TRPRT1)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_TRPRT2)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                              </tr>

                              <tr><td class="dsphdr">Order Number</td>
                                  <td class="inputalph"><input name="fromOrderNumber" value="$(V_TRORD1)" type="text" size="15" maxlength="9"><a href="$(homeURL)$(cGIPath)MfgOrderSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;forPlant=$(forPlant)&amp;fldorder=fromOrderNumber" onclick="$(searchWinVar)">  $(searchImage) </a></td>
                                  <td class="inputalph"><input name="toOrderNumber" value="$(V_TRORD2)" type="text" size="15" maxlength="9"><a href="$(homeURL)$(cGIPath)MfgOrderSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;forPlant=$(forPlant)&amp;fldorder=toOrderNumber" onclick="$(searchWinVar)">  $(searchImage) </a></td>
                                  <td class="inputalph"><input name="allOrderNumber" value='ALL' $(checkedallOrderNumber) type="checkbox" onClick="if (this.checked) this.form.fromOrderNumber.value='', this.form.toOrderNumber.value='';"></td>
                              </tr>

                              <tr><td class="dsphdr">Reference Number</td>
                                  <td class="inputalph"><input name="fromReferenceNumber" value="$(V_TRROR1)" type="text" size="25" maxlength="20"></td>
                                  <td class="inputalph"><input name="toReferenceNumber" value="$(V_TRROR2)" type="text" size="25" maxlength="20"></td>
                                  <td class="inputalph"><input name="allReferenceNumber" value='ALL' $(checkedallReferenceNumber) type="checkbox" onClick="if (this.checked) this.form.fromReferenceNumber.value='', this.form.toReferenceNumber.value='';"></td>
                              </tr>

                              <tr><td class="dsphdr">Quantity</td>
                                  <td class="inputnmbr"><input name="fromQuantity" value="$(V_TRQTY1)" type="text" size="13" maxlength="13"></td>
                                  <td class="inputnmbr"><input name="toQuantity" value="$(V_TRQTY2)" type="text" size="13" maxlength="13"></td>
                                  <td class="inputalph"><input name="allQuantity" value='ALL' $(checkedallQuantity) type="checkbox" onClick="if (this.checked) this.form.fromQuantity.value='', this.form.toQuantity.value='';"></td>
                              </tr>

                          </table>

                          @dtw_assign(envProgram, "HSI233")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSI901_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allPlantNumber)
  @dtw_mUPPERCASE(allCloseDate)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(fromOrderNumber)
  @dtw_mUPPERCASE(toOrderNumber)
  @dtw_mUPPERCASE(allOrderNumber)
  @dtw_mUPPERCASE(fromReferenceNumber)
  @dtw_mUPPERCASE(toReferenceNumber)
  @dtw_mUPPERCASE(allReferenceNumber)
  @dtw_mUPPERCASE(allQuantity)

  @dtw_assign(fromPlantNumber,@dtw_rstrip(fromPlantNumber))
  @dtw_assign(toPlantNumber,@dtw_rstrip(toPlantNumber))
  @dtw_assign(fromCloseDate,@dtw_rstrip(fromCloseDate))
  @dtw_assign(toCloseDate,@dtw_rstrip(toCloseDate))
  @dtw_assign(fromQuantity,@dtw_rstrip(fromQuantity))
  @dtw_assign(toQuantity,@dtw_rstrip(toQuantity))

  %if (allPlantNumber != "ALL")
      @dtw_assign(allPlantNumber, "")
  %endif
  %if (allCloseDate != "ALL")
      @dtw_assign(allCloseDate, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allOrderNumber != "ALL")
      @dtw_assign(allOrderNumber, "")
  %endif
  %if (allReferenceNumber != "ALL")
      @dtw_assign(allReferenceNumber, "")
  %endif
  %if (allQuantity != "ALL")
      @dtw_assign(allQuantity, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@incz", zeroQtyReceived)
  @Concat_Field("@@fplt", fromPlantNumber)
  @Concat_Field("@@tplt", toPlantNumber)
  @Concat_Field("@@aplt", allPlantNumber)
  @Concat_Field("@@fdat", fromCloseDate)
  @Concat_Field("@@tdat", toCloseDate)
  @Concat_Field("@@adat", allCloseDate)
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@ford", fromOrderNumber)
  @Concat_Field("@@tord", toOrderNumber)
  @Concat_Field("@@aord", allOrderNumber)
  @Concat_Field("@@fref", fromReferenceNumber)
  @Concat_Field("@@tref", toReferenceNumber)
  @Concat_Field("@@aref", allReferenceNumber)
  @Concat_Field("@@fqty", fromQuantity)
  @Concat_Field("@@tqty", toQuantity)
  @Concat_Field("@@aqty", allQuantity)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}