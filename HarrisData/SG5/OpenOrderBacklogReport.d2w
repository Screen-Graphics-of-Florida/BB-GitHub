%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Open Order Backlog Report"
  d2wName                 = "OpenOrderBacklogReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "02"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromCustomer, 7, 0) &&
                      editNum(document.Chg.toCustomer, 7, 0) &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromCustomer, document.Chg.toCustomer, document.Chg.allCustomer, 7))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "OPENORDERBACKLOGREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromItemNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@fitm", "fromItemNumber")          @dtw_assign(Err_FITEM,  fieldValue)
                                  @DecatErr_Field("@@titm", "toItemNumber")            @dtw_assign(Err_TITEM,  fieldValue)
                                  @DecatErr_Field("@@aitm", "allItemNumber")           @dtw_assign(Err_AITEM,  fieldValue)
                                  @DecatErr_Field("@@sitm", "sortItemNumber")           @dtw_assign(Err_SITEM,  fieldValue)
                                  @DecatErr_Field("@@fcus", "fromCustomer")      @dtw_assign(Err_FCUST,  fieldValue)
                                  @DecatErr_Field("@@tcus", "toCustomer")        @dtw_assign(Err_TCUST,  fieldValue)
                                  @DecatErr_Field("@@acus", "allCustomer")       @dtw_assign(Err_ACUST,  fieldValue)
                                  @DecatErr_Field("@@scus", "sortCustomer")      @dtw_assign(Err_SCUST,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}

                                  @Decat_Field("@@fitm")   @dtw_assign(V_FITEM,  fieldValue)
                                  @Decat_Field("@@titm")   @dtw_assign(V_TITEM,  fieldValue)
                                  @Decat_Field("@@aitm")   @dtw_assign(V_AITEM,  fieldValue)
                                  @Decat_Field("@@sitm")   @dtw_assign(V_SITEM,  fieldValue)
                                  @Decat_Field("@@fcus")   @dtw_assign(V_FCUST,  fieldValue)
                                  @Decat_Field("@@tcus")   @dtw_assign(V_TCUST,  fieldValue)
                                  @Decat_Field("@@acus")   @dtw_assign(V_ACUST,  fieldValue)
                                  @Decat_Field("@@scus")   @dtw_assign(V_SCUST,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}

                                  %if (V_AITEM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_ACUST == "ALL")
                                      @dtw_assign(checkedallCustomer, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallCustomer, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallCustomer, "CHECKED")
                              %endif

                          </table>
                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                              </tr>

                              @SetTextOvr(Err_FITEM)
                              %if (textOvr == "") @SetTextOvr(Err_TITEM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_AITEM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SITEM) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputnmbr"><input name="fromItemNumber" value="$(V_FITEM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=itemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="itemDescription" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toItemNumber" value="$(V_TITEM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=itemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="itemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                                  @Build_Sort_Select("sortItemNumber", "$(V_SITEM)")
                              </tr>
                              @DspErrMsg(Err_FITEM)
                              @DspErrMsg(Err_TITEM)
                              @DspErrMsg(Err_AITEM)
                              @DspErrMsg(Err_SITEM)

                              @SetTextOvr(Err_FCUST)
                              %if (textOvr == "") @SetTextOvr(Err_TCUST) %endif
                              %if (textOvr == "") @SetTextOvr(Err_ACUST) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SCUST) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Customer  Number</span></td>
                                  <td class="inputnmbr"><input name="fromCustomer" value="$(V_FCUST)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromCustomer&amp;fldDesc=fcustomerName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="fcustomerName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toCustomer" value="$(V_TCUST)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toCustomer&amp;fldDesc=tcustomerName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="tcustomerName" type="hidden"></td>
                                  <td class="inputalph"><input name="allCustomer" value='ALL' $(checkedallCustomer) type="checkbox" onClick="if (this.checked) this.form.fromCustomer.value='', this.form.toCustomer.value='';"></td>
                                  @Build_Sort_Select("sortCustomer", "$(V_SCUST)")
                              </tr>
                              @DspErrMsg(Err_FCUST)
                              @DspErrMsg(Err_TCUST)
                              @DspErrMsg(Err_ACUST)
                              @DspErrMsg(Err_SCUST)
                          </table>

                          @dtw_assign(envProgram, "HOEBOI")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HOESBL_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(allCustomer)

  @dtw_assign(sortItemNumber,@dtw_rstrip(sortItemNumber))
  @dtw_assign(fromCustomer,@dtw_rstrip(fromCustomer))
  @dtw_assign(toCustomer,@dtw_rstrip(toCustomer))
  @dtw_assign(sortCustomer,@dtw_rstrip(sortCustomer))


  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allCustomer != "ALL")
      @dtw_assign(allCustomer, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@sitm", sortItemNumber)
  @Concat_Field("@@fcus", fromCustomer)
  @Concat_Field("@@tcus", toCustomer)
  @Concat_Field("@@acus", allCustomer)
  @Concat_Field("@@scus", sortCustomer)
  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}