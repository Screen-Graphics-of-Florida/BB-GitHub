%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Document Type"
  d2wName                 = "DocumentType.d2w"
  d2wVarBase              = "$(genericVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HHDDTM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "DOCUMENTTYPE")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select DODOCT, DODESC, DOPGID, DORESD, DOAPID, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(DODESC) as DODESCU " , stmtSQL)
                      @dtw_concat(fileSQL, " HDDOCT ", fileSQL)
                      @dtw_concat(selectSQL, "  ((DOAPID=' ' or DORESD<>'Y') ", selectSQL)
                      @dtw_concat(selectSQL, "or (DOAPID='CP' and $(V_HDCLRL)>0) ", selectSQL)
                      @dtw_concat(selectSQL, "or (DOAPID='AP' and $(V_HDAPRL)>0) ", selectSQL)
                      @dtw_concat(selectSQL, "or (DOAPID='AR' and $(V_HDARRL)>0) ", selectSQL)
                      @dtw_concat(selectSQL, "or (DOAPID='ED' and $(V_HDEDRL)>0) ", selectSQL)
                      @dtw_concat(selectSQL, "or (DOAPID='FA' and $(V_HDFARL)>0) ", selectSQL)
                      @dtw_concat(selectSQL, "or (DOAPID='GL' and $(V_HDGLRL)>0) ", selectSQL)
                      @dtw_concat(selectSQL, "or (DOAPID='IV' and $(V_HDINRL)>0) ", selectSQL)
                      @dtw_concat(selectSQL, "or (DOAPID='MC' and $(V_HDMCRL)>0) ", selectSQL)
                      @dtw_concat(selectSQL, "or (DOAPID='ME' and $(V_HDMERL)>0) ", selectSQL)
                      @dtw_concat(selectSQL, "or (DOAPID='ET' and $(V_HDMERL)>0) ", selectSQL)
                      @dtw_concat(selectSQL, "or (DOAPID='OE' and $(V_HDOERL)>0) ", selectSQL)
                      @dtw_concat(selectSQL, "or (DOAPID='PD' and $(V_HDPDRL)>0) ", selectSQL)
                      @dtw_concat(selectSQL, "or (DOAPID='PE' and $(V_HDPERL)>0) ", selectSQL)
                      @dtw_concat(selectSQL, "or (DOAPID='PO' and $(V_HDPORL)>0) ", selectSQL)
                      @dtw_concat(selectSQL, "or (DOAPID='PR' and $(V_HDPRRL)>0) ", selectSQL)
                      @dtw_concat(selectSQL, "or (DOAPID='SC' and $(V_HDSCRL)>0) ", selectSQL)
                      @dtw_concat(selectSQL, "or (DOAPID='TA' and $(V_HDTARL)>0))", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @DocType_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) DocType_Query (IN CHAR(64) profileHandle,
                                     CHAR(2)   dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)DocumentTypeMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Description</th>
                      <th class="colhdr">Document</th>
                  </tr>
                  <tr align=center>
                      <td><input type="text" class="inputalph" name="srchDesc" size="30" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchDoc" size="7" maxlength="3">
                          <input type="hidden" name="operDoc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
                  <th class="colhdr">Header<br>Comments</th>
                  <th class="colhdr">Trailer<br>Comments</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("DOAPID", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplID" title="Sequence By Application ID, Document">APID</a></th>
              @OrderBy_Sort("DODOCT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Document" title="Sequence By Document"> Document</a></th>
              @OrderBy_Sort("DODESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Description, Document"> Description</a></th>
              @OrderBy_Sort("DOPGID", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Program" title="Sequence By Program Name, Document"> Program<br>Name</a></th>
              @OrderBy_Sort("DORESD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Reserved" title="Sequence By Reserved Flag, Document"> Reserved</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;documentType=@dtw_rurlescseq(V_DODOCT)&amp;documentApplication=@dtw_rurlescseq(V_DOAPID)&amp;description=@dtw_rurlescseq(V_DODESC)&amp;fromAPID=@dtw_rurlescseq(V_DOAPID)&amp;fromDocType=@dtw_rurlescseq(V_DODOCT)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"
              @RtvFldDesc("AIAPID='$(V_DOAPID)'", "SYAPID", "AIAPDS", apidDesc)
              %if (V_DOAPID != "")
                  @Format_Confirm_Desc($(apidDesc), $(V_DOAPID), $(V_DODESC), $(V_DODOCT), "", "", confirmDesc)
              %else
                  @Format_Confirm_Desc($(V_DODESC), $(V_DODOCT), "", "", "", "", confirmDesc)
              %endif
              @RtvFldDesc("DCAPID='$(V_DOAPID)' and DCDOCT='$(V_DODOCT)' and DCHT='H' ", "HDDCMT", "char(count(*))", hdrCount)
              @RtvFldDesc("DCAPID='$(V_DOAPID)' and DCDOCT='$(V_DODOCT)' and DCHT='T' ", "HDDCMT", "char(count(*))", trlCount)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)DocumentTypeMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_04 == "Y")
                              <a href="$(homeURL)$(cGIPath)DocumentTypeMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y" && V_DORESD != "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)DocumentTypeMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                      <td class="colcode">
    		           %if (hdrCount > "0")
                              <a href="$(homeURL)$(cGIPath)DocumentCommentMaintain.d2w/MAINTAIN$(maintainVar)&amp;headerTrailer=H" onclick="$(commentWinVar)">$(commentExistImage)</a>
                          %else
                              <a href="$(homeURL)$(cGIPath)DocumentCommentMaintain.d2w/MAINTAIN$(maintainVar)&amp;headerTrailer=H" onclick="$(commentWinVar)">$(commentImage)</a>
                          %endif
                      </td>
                      <td class="colcode">
    		           %if (trlCount > "0")
                              <a href="$(homeURL)$(cGIPath)DocumentCommentMaintain.d2w/MAINTAIN$(maintainVar)&amp;headerTrailer=T" onclick="$(commentWinVar)">$(commentExistImage)</a>
                          %else
                              <a href="$(homeURL)$(cGIPath)DocumentCommentMaintain.d2w/MAINTAIN$(maintainVar)&amp;headerTrailer=T" onclick="$(commentWinVar)">$(commentImage)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph" $(helpCursor)><span title="$(apidDesc)">$(V_DOAPID)</span></td>
                  <td class="colalph">$(V_DODOCT)</td>
                  <td class="colalph">$(V_DODESC)</td>
                  <td class="colalph">$(V_DOPGID)</td>
                  <td class="colcode">$(V_DORESD)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select DODOCT, DODESC, DOPGID, DORESD, DOAPID, ", stmtSQL)
  @dtw_concat(stmtSQL, " upper(DODESC) as DODESCU " , stmtSQL)
  @dtw_concat(fileSQL, " HDDOCT ", fileSQL)
  @dtw_concat(selectSQL, "(DOAPID=' ' or DOAPID='$(apId)') ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @DocType_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) DocType_XMLQuery (IN CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("DocumentTypeList")
          %ROW{
	       @XMLIDTag(V_DODOCT, "DocumentType ID")
                  @XMLTag(V_DOAPID, "ApplicationID")
                  @XMLTag(V_DODOCT, "DocumentType")
                  @XMLTag(V_DODESC, "Description")
                  @XMLTag(V_DOPGID, "ProgramName")
              @XMLEndTag("DocumentType")
          %}
      @XMLEndTag("DocumentTypeList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "DODESCU,DODOCT")
          @DTW_ASSIGN(orderByDisplay, "Description, Document")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "ApplID")
      %if (orderBy == "DOAPID,DODOCT")
          @DTW_ASSIGN(orderBy, "DOAPID DESC, DODOCT")
          @DTW_ASSIGN(orderByDisplay, "Application ID (descending), Document")
      %else
          @DTW_ASSIGN(orderBy, "DOAPID,DODOCT")
          @DTW_ASSIGN(orderByDisplay, "Application ID, Document")
      %endif
  %elseif (sequence == "Document")
      %if (orderBy == "DODOCT")
          @DTW_ASSIGN(orderBy, "DODOCT DESC")
          @DTW_ASSIGN(orderByDisplay, "Document (descending)")
      %else
          @DTW_ASSIGN(orderBy, "DODOCT")
          @DTW_ASSIGN(orderByDisplay, "Document")
      %endif
  %elseif (sequence == "Description")
      %if (orderBy == "DODESCU,DODOCT")
          @DTW_ASSIGN(orderBy, "DODESCU DESC,DODOCT")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Document")
      %else
          @DTW_ASSIGN(orderBy, "DODESCU,DODOCT")
          @DTW_ASSIGN(orderByDisplay, "Description, Document")
      %endif
  %elseif (sequence == "Program")
      %if (orderBy == "DOPGID,DODOCT")
          @DTW_ASSIGN(orderBy, "DOPGID DESC,DODOCT")
          @DTW_ASSIGN(orderByDisplay, "Program Name (descending), Document")
      %else
          @DTW_ASSIGN(orderBy, "DOPGID,DODOCT")
          @DTW_ASSIGN(orderByDisplay, "Program Name, Document")
      %endif
  %elseif (sequence == "Reserved")
      %if (orderBy == "DORESD,DODOCT")
          @DTW_ASSIGN(orderBy, "DORESD DESC,DODOCT")
          @DTW_ASSIGN(orderByDisplay, "Reserved Flag (descending), Document")
      %else
          @DTW_ASSIGN(orderBy, "DORESD,DODOCT")
          @DTW_ASSIGN(orderByDisplay, "Reserved Flag, Document")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "DOCUMENTTYPE")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Document</td>
                              @dtw_assign(operNbr, "operDoc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDoc" size="10" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Application ID</td>
                              @dtw_assign(operNbr, "operAPID")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchAPID" size="10" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Program Name</td>
                              @dtw_assign(operNbr, "operProg")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchProg" size="10" maxlength="10"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDesc.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("DODOCT", "Document", $(srchDoc), "U", operDoc, "A")
  @Build_WildCard ("upper(DODESC)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("DOAPID", "Application ID", $(srchAPID), "U", operAPID, "A")
  @Build_WildCard ("DOPGID", "Program Name", $(srchProg), "U", operProg, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
