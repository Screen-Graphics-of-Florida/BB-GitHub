%INCLUDE "baseconfiguration.icl"
%INCLUDE "Graph.icl"

%Define
  {	
    	page_title 	        = "Graph"
    	DATABASE                = "*LOCAL"
  %}

%HTML(REPORT)
  {
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>

              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->

               @dtw_assign(addRow1, "124,138,216,143,256,302")
		@dtw_assign(addRow2, "201,234,340,210,314,320")
		@dtw_assign(addRow3, " ")
		@dtw_assign(addRow4, " ")
		@dtw_assign(scale, "50")
		@dtw_assign(graphTitle, "My New Graph Page ")
		@dtw_assign(xLabel, "Date ")
		@dtw_assign(yLabel, "Hits ")
		@dtw_assign(legend, "'Fly Fishing', 'Sport Fishing' ")
		@Plot_Graph(addRow1, addRow2, addRow3, addRow4, scale, graphTitle, xLabel, yLabel, legend)

              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->

          </body>
      </html>
  %}