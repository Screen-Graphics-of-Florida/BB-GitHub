%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Alternate Product Structure"
  d2wName                 = "AltProductStructure.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;configurationType=@dtw_rurlescseq(configurationType)&amp;configurationID=@dtw_rurlescseq(configurationID)&amp;plrsf=@dtw_rurlescseq(plrsf)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPD025"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@plantNumber", "@dtw_rurlescseq(plantNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@itemNumber", "@dtw_rurlescseq(itemNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@configurationType", "@dtw_rurlescseq(configurationType)", "1", "a", workURL)
  @dtw_replace(workURL, "@@configurationID", "@dtw_rurlescseq(configurationID)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @ItemPlantUserView(profileHandle, dataBaseID, userPass, plantNumber, itemNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
                  %INCLUDE "Menu.js"
                  %INCLUDE "NumEdit.icl"
                  %INCLUDE "CheckEnterSearch.icl"
                  %if (plrsf == "Y")
                      function validate(searchForm) {
                              if (editNum(document.Search.srchseq, 3, 0))
                                  return true;
                          }
                  %endif
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "ALTPRODUCTSTRUCTURE")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select PAPPLT, PAPPN, PACFGT, PACFGI, PASEQN, PACPN, PAREFN,  PAQPER, PAFSTK, PASCPP, PASTDT, PADSDT, IMITEM, IMIMDS, IMIMDSU, IPITEM, IPECDP ", stmtSQL)
                          @dtw_concat(fileSQL, " HDMAPS Left Outer Join (HDIPLT Join HDIMST on IPITEM=IMITEM) on PAPPLT=IPPLT and PACPN=IPITEM ", fileSQL)
                          @dtw_concat(selectSQL, " PAPPLT=$(plantNumber) and PAPPN='$(itemNumber)' and PACFGT='$(configurationType)' and PACFGI='$(configurationID)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy)", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @AltProductStructure_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) AltProductStructure_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
      @RtvFldDesc("CHPLT=$(plantNumber) and CHITEM='$(itemNumber)' and CHCFGT='$(configurationType)' and CHCFGI='$(configurationID)' ", "HDCFGH", "CHCDSC", ConfigTypeDescription)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      <a href="$(homeURL)$(cGIPath)ItemPlantSelect.d2w/REPORT$(d2wVarBase)" title="BackHome">$(portalHome)</a>
                      <a href="$(homeURL)$(cGIPath)ReferenceRoutingInquiry.d2w/DISPLAY$(d2wVarBase)" onclick="$(inquiryWinVar)">$(refRtgImageLrg)</a>
                      <a href="$(homeURL)$(cGIPath)ProductStructureInquiry.d2w/DISPLAY$(d2wVarBase)" onclick="$(inquiryWinVar)">$(prodStrImageLrg)</a>
                      <a href="$(homeURL)$(cGIPath)AltReferenceRoutingInquiry.d2w/DISPLAY$(d2wVarBase)" onclick="$(inquiryWinVar)">$(altRefRtgImageLrg)</a>
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)AltProductStructureMaintain.d2w/REPORT$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (sec_01=="Y" && sec_04=="Y" && sql_Record_Count != "0")
                          <a href="$(homeURL)$(cGIPath)AltProductStructureMaintain.d2w/COPYALL$(d2wVarBase)&amp;plantName=@dtw_rurlescseq(plantName)&amp;itemDescription=@dtw_rurlescseq(itemDescription)&amp;maintenanceCode=Z">$(copyAllImageLrg)</a>
                      %endif
                      %if (sec_03 == "Y" && sql_Record_Count != "0")
                          @Format_Confirm_Desc("All Product Structure", "", "", "", "", "", confirmDesc)
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)AltProductStructureMaintain.d2w/SRS4Del$(d2wVarBase)&amp;maintenanceCode=D">$(deleteAllImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      <table $(contentTable)>
          @Format_Header_URL("Plant", $(plantName), $(plantNumber), "$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(d2wVarBase)")
          @Format_Header_URL("Item", $(itemDescription), $(itemNumber), "$(homeURL)$(cGIPath)ItemSelect.d2w/REPORT$(d2wVarBase)&amp;itemDescription=@dtw_rurlescseq(itemDescription)")
          @Format_Header_URL("Type/ID", $(ConfigTypeDescription), "$(configurationType)/$(configurationID)", "")
      </table>
      %INCLUDE "ConfMessageDisplay.icl"
	
      $(hrTagAttr)	

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      %if (plrsf == "Y")
                          <th class="colhdr">Rtg<br>Seq</th>
                      %endif
                      <th class="colhdr">Component<br>Item</th>
                      <th class="colhdr">Engineering<br>Reference</th>
                  </tr>

                  <tr>
                      %if (plrsf == "Y")
                          <td><input type="text" class="inputnum" name="srchseq" size="3" maxlength="3">
                              <input type="hidden" name="operseq" value="=">
                          </td>
                      %endif
                      <td><input type="text" class="inputalph" name="srchcomponent" size="15" maxlength="15">
                          <input type="hidden" name="opercomponent" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchengref" size="8" maxlength="8">
                          <input type="hidden" name="operengref" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  %if (plrsf == "Y")
                      document.Search.srchseq.focus();
                  %else
                      document.Search.srchcomponent.focus();
                  %endif
              </script>
          </form>
	
          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              %if (plrsf == "Y")
                  @OrderBy_Sort("PASEQN", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SEQN" title="Sequence By Routing Sequence Number"> Rtg<br>Seq</a></th>
              %endif
              @OrderBy_Sort("PACPN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CPN" title="Sequence By Component Item)"> Component<br>Item</a></th>	
              @OrderBy_Sort("IMIMDS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=IMDS" title="Sequence By Component Item Description)"> Component<br>Description</a></th>	
              @OrderBy_Sort("PAREFN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=REFN" title="Sequence By Engineering Reference"> Engineering<br>Reference</a></th>
              @OrderBy_Sort("PAQPER", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=QPER" title="Sequence By Quantity Per">Quantity<br>Per</a></th>
              @OrderBy_Sort("PAFSTK", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FSTK" title="Sequence By Backflush Code">Bkf<br>Code</a></th>
              @OrderBy_Sort("PASCPP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SCPP" title="Sequence By Scrap Percent">Scrap<br>%</a></th>
              @OrderBy_Sort("IPECDP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ECDP" title="Sequence By ECN Component Disposition">C<br>D</a></th>
              @OrderBy_Sort("PASTDT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=STDT" title="Sequence By Effectivity Start Date">Effectivity<br>Start Date</a></th>
              @OrderBy_Sort("PADSDT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DSDT" title="Sequence By Effectivity Stop Date">Effectivity<br>Stop Date</a></th>
          </tr>		
          %INCLUDE "NoRecordsFound.icl"

      %ROW{
              %INCLUDE "SetRowClass.icl"
              %if (plrsf == "Y")
                  @Format_Confirm_Desc("Sequence Number", $(V_PASEQN), "Component Number", $(V_PACPN), "", "", confirmDesc)
              %else
                  @Format_Confirm_Desc("Component Number", $(V_PACPN), "", "", "", "", confirmDesc)
              %endif
              @dtw_replace(confirmDesc, "'", "\'", "1", "a", confirmDesc)
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;sequenceNumber=@dtw_rurlescseq(V_PASEQN)&amp;componentNumber=@dtw_rurlescseq(V_PACPN)&amp;engineeringReference=@dtw_rurlescseq(V_PAREFN)")
	       <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)AltProductStructureMaintain.d2w/REPORT$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)AltProductStructureMaintain.d2w/REPORT$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href=$(homeURL)$(cGIPath)AltProductStructureMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D>$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  @Format_Nbr($(V_PAQPER), F_PAQPER, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @Format_Nbr($(V_PASCPP), F_PASCPP, "2", $(pctEditCode), "", "", "")
                  @Format_Date(V_PASTDT, "D", F_PASTDT)
                  @Format_Date(V_PADSDT, "D", F_PADSDT)
                  @RtvFldDesc("(FLTYPE='BACKFLUSH' and FLVALU='$(V_PAFSTK)')", "SYFLAG", "FLDESC", backFlushDesc)
                  %if (V_IMIMDS == "")
                      @dtw_assign(V_IMIMDS, "Not In Item")
                  %endif
                  %if (plrsf == "Y")
                      <td class="colnmbr">$(V_PASEQN)</td>
                  %endif
                  <td class="colalph">$(V_PACPN)</td>
                  <td class="colalph">$(V_IMIMDS)</td>
                  <td class="colalph">$(V_PAREFN)</td>
                  <td class="colnmbr">$(F_PAQPER)</td>
                  <td class="colcode" $(helpCursor)><span title="$(backFlushDesc)">$(V_PAFSTK)</span></td>
                  <td class="colnmbr">$(F_PASCPP)</td>
                  <td class="colalph">$(V_IPECDP)</td>
                  <td class="colnmbr">$(F_PASTDT)</td>
                  <td class="colnmbr">$(F_PADSDT)</td>
	       </tr>
	   %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
      %INCLUDE "WebReg.icl"
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLRSF", plrsf)
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              %if (plrsf == "Y")
                  @DTW_ASSIGN(orderBy, "PASEQN, PACPN")
                  @DTW_ASSIGN(orderByDisplay, "Sequence Number, Component Item Number")
              %else
                  @DTW_ASSIGN(orderBy, "PACPN")
                  @DTW_ASSIGN(orderByDisplay, "Component Item Number")
              %endif
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "SEQN")
      %if (orderBy == "PASEQN, PACPN")
          @DTW_ASSIGN(orderBy, "PASEQN DESC, PACPN")
          @DTW_ASSIGN(orderByDisplay, "Sequence Number (descending), Component Number")
      %else
          @DTW_ASSIGN(orderBy, "PASEQN, PACPN")
          @DTW_ASSIGN(orderByDisplay, "Sequence Number, Component Number")
      %endif
  %elif (sequence == "CPN")
      %if (orderBy == "PACPN")
          @DTW_ASSIGN(orderBy, "PACPN DESC")
          @DTW_ASSIGN(orderByDisplay, "Component Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PACPN")
          @DTW_ASSIGN(orderByDisplay, "Component Number")
      %endif
  %elif (sequence == "IMDS")
      %if (orderBy == "IMIMDSU")
          @DTW_ASSIGN(orderBy, "IMIMDSU DESC")
          @DTW_ASSIGN(orderByDisplay, "Component Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "IMIMDSU")
          @DTW_ASSIGN(orderByDisplay, "Component Description")
      %endif
  %elif (sequence == "REFN")
      %if (orderBy == "PAREFN")
          @DTW_ASSIGN(orderBy, "PAREFN DESC")
          @DTW_ASSIGN(orderByDisplay, "Engineering Reference (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PAREFN")
          @DTW_ASSIGN(orderByDisplay, "Engineering Reference")
      %endif
  %elif (sequence == "QPER")
      %if (orderBy == "PAQPER")
          @DTW_ASSIGN(orderBy, "PAQPER DESC")
          @DTW_ASSIGN(orderByDisplay, "Quantity Per (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PAQPER")
          @DTW_ASSIGN(orderByDisplay, "Quantity Per")
      %endif
  %elif (sequence == "FSTK")
      %if (orderBy == "PAFSTK")
          @DTW_ASSIGN(orderBy, "PAFSTK DESC")
          @DTW_ASSIGN(orderByDisplay, "Backflush Code (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PAFSTK")
          @DTW_ASSIGN(orderByDisplay, "Backflush Code")
      %endif
  %elif (sequence == "SCPP")
      %if (orderBy == "PASCPP")
          @DTW_ASSIGN(orderBy, "PASCPP DESC")
          @DTW_ASSIGN(orderByDisplay, "Scrap Percent (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PASCPP")
          @DTW_ASSIGN(orderByDisplay, "Scrap Percent")
      %endif
  %elif (sequence == "ECDP")
      %if (orderBy == "IPECDP")
          @DTW_ASSIGN(orderBy, "IPECDP DESC")
          @DTW_ASSIGN(orderByDisplay, "ECN Component Disposition (descending)")
      %else
          @DTW_ASSIGN(orderBy, "IPECDP")
          @DTW_ASSIGN(orderByDisplay, "ECN Component Disposition")
      %endif
  %elif (sequence == "STDT")
      %if (orderBy == "PASTDT")
          @DTW_ASSIGN(orderBy, "PASTDT DESC")
          @DTW_ASSIGN(orderByDisplay, "Effectivity Start Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PASTDT")
          @DTW_ASSIGN(orderByDisplay, "Effectivity Start Date")
      %endif
  %elif (sequence == "DSDT")
      %if (orderBy == "PADSDT")
          @DTW_ASSIGN(orderBy, "PADSDT DESC")
          @DTW_ASSIGN(orderByDisplay, "Effectivity Stop Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PADSDT")
          @DTW_ASSIGN(orderByDisplay, "Effectivity Stop Date")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %if (plrsf == "Y")
                  function validate(searchForm) {
                      if (editNum(document.Search.srchseq, 3, 0))
                          return true;
                  }
              %endif
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PRODUCTSTRUCTURESEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"
                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          %if (plrsf == "Y")
                              <tr><td class="dsphdr">Routing Sequence</td>
                                  @dtw_assign(operNbr, "operseq")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchseq" size="3" maxlength="3"></td>
                              </tr>
                          %endif

                          <tr><td class="dsphdr">Component Item</td>
                              @dtw_assign(operNbr, "opercomponent")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchcomponent" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">Engineering Reference</td>
                              @dtw_assign(operNbr, "operengref")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchengref" size="8" maxlength="8"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                             %if (plrsf == "Y")
                                 document.Search.srchseq.focus();
                             %else
                                 document.Search.srchcomponent.focus();
                             %endif
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  %if (plrsf == "Y")
      @Build_WildCard ("PASEQN", "Sequence Number", $(srchseq), "", operseq, "N")
  %endif
  @Build_WildCard ("PACPN", "Component Item", $(srchcomponent), "U", opercomponent, "A")
  @Build_WildCard ("PAREFN", "Engineering Reference", $(srchengref), "U", operengref, "A")
		
  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}