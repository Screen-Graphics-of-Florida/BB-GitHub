%INCLUDE "$(baseVar)"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Department Expense Accounts"
  d2wName                 = "HRDeptExp.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPREAM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "HRDEPTEXPACCT")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select EADEPT, EANAME, upper(EANAME) as EANAMEU ", stmtSQL)
                      @dtw_concat(fileSQL, " PREXAC ", fileSQL)
                      %if (wildCardSearch!="" || uv_Sql!="")
                          @dtw_concat(selectSQL, "EADEPT<>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Department_Inquiry(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Department_Inquiry (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count != "1")
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if ((backHome != "")  && (backHome != "$(d2wName)/report"))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"
          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Dept</th>
                          <th class="colhdr">Name</th>
                      </tr>
                      <tr><td><input type="text" class="inputalph" name="srchDept" size="5" maxlength="5">
                              <input type="hidden" name="operDept" value="LIKE">
                          </td>
                          <td><input type="text" class="inputalph" name="srchName" size="20" maxlength="20">
                              <input type="hidden" name="operName" value="LIKE">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchDept.focus();
                  </script>
              </form>

              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("EADEPT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DeptNumber" title="Sequence By Department">Dept</a></th>
                  @OrderBy_Sort("EANAMEU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DeptName" title="Sequence By Name">Name</a></th>
              </tr>
          %INCLUDE "NoRecordsFound.icl"
      %endif

              %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;deptNumber=@dtw_rurlescseq(V_EADEPT)")
                  %if (sql_Record_Count == "1")
                      @Save_WebReg(webRegCurFile, profileHandle, d2wName, "", orderBy, orderByDisplay, "")
                      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)HRDeptSelect.d2w/REPORT$(maintainVar)">
                  %else
                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          <td class="colalph">$(V_EADEPT)</td>
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)HRDeptSelect.d2w/REPORT$(maintainVar)" title="View Department Expense Accounts">$(V_EANAME)</a></td>
                      </tr>
                  %endif
              %}
          </table>
          %if (sql_Record_Count != "1")
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "Select EADEPT, EANAME, upper(EANAME) as EANAMEU ", stmtSQL)
  @dtw_concat(fileSQL, " PREXAC ", fileSQL)
  %if (wildCardSearch!="" || uv_Sql!="")
      @dtw_concat(selectSQL, "EADEPT<>' ' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @Department_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) Department_XMLQuery (IN CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{  @XMLBeginTag("DepartmentList")
      %ROW{

	        @XMLIDTag(V_EADEPT, "Department ID")
               @XMLTag(V_EADEPT, "DepartmentNumber")
               @XMLTag(V_EANAME, "DepartmentName")
               @XMLTag(V_EARWCO, "WagesCompany")
               @XMLTag(V_EARWFA, "WagesFacility")
               @XMLTag(V_EARWAC, "RegularAccount")
               @XMLTag(V_EARWSB, "RegularSubaccount")
               @XMLTag(V_EAOVAC, "OvertimeAccount")
               @XMLTag(V_EAOVSB, "OvertimeSubaccount")
               @XMLTag(V_EAOTPO, "OvertimePremiumOnly")
               @XMLTag(V_EADTAC, "DoubletimeAccount")
               @XMLTag(V_EADTSB, "DoubletimeSubaccount")
               @XMLTag(V_EADTPO, "DoubletimePremiumOnly")
               @XMLTag(V_EAVCAC, "VacationAccount")
               @XMLTag(V_EAVCSB, "VacationSubaccount")
               @XMLTag(V_EAHOAC, "HolidayAccount")
               @XMLTag(V_EAHOSB, "HolidaySubaccount")
               @XMLTag(V_EASIAC, "SickAccount")
               @XMLTag(V_EASISB, "SickSubaccount")
               @XMLTag(V_EAOTAC, "OthertaxableSccount")
               @XMLTag(V_EAOTSB, "OthertaxableSubaccount")
               @XMLTag(V_EAONAC, "NontaxableAccount")
               @XMLTag(V_EAONSB, "NontaxableSubaccount")
               @XMLTag(V_EACMAC, "CommissionAccount")
               @XMLTag(V_EACMSB, "CommissionSubaccount")
               @XMLTag(V_EABOAC, "BonusAccount")
               @XMLTag(V_EABOSB, "BonusSubaccount")
               @XMLTag(V_EATXCO, "TaxCompany")
               @XMLTag(V_EATXFA, "TaxFacility")
               @XMLTag(V_EAFIAC, "FicaAccount")
               @XMLTag(V_EAFISB, "FicaSubaccout")
               @XMLTag(V_EAFUAC, "FuiAccount")
               @XMLTag(V_EAFUSB, "FuiSubaccout")
               @XMLTag(V_EASUAC, "SuiAccount")
               @XMLTag(V_EASUSB, "SuiSubaccout")
               @XMLTag(V_EASDAC, "SdiAccount")
               @XMLTag(V_EASDSB, "SdiSubaccout")
               @XMLTag(V_EASWAC, "SwcAccount")
               @XMLTag(V_EASWSB, "SwcSubaccout")
               @XMLTag(V_EALIAC, "LocalAccount")
               @XMLTag(V_EALISB, "LocalSubaccout")
           @XMLEndTag("Department")
      %}
      @XMLEndTag("DepartmentList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (sec_05 == "N")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)progOptSecError.d2w/DISPLAY$(genericVarBase)&amp;page_title=@dtw_rurlescseq(page_title)">
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "EANAMEU")
              @DTW_ASSIGN(orderByDisplay, "Department Name")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "DeptNumber")
      %if (orderBy == "EADEPT")
          @DTW_ASSIGN(orderBy, "EADEPT DESC")
          @DTW_ASSIGN(orderByDisplay, "Department (descending)")
      %else
          @DTW_ASSIGN(orderBy, "EADEPT")
          @DTW_ASSIGN(orderByDisplay, "Department")
      %endif
  %elseif (sequence == "DeptName")
      %if (orderBy == "EANAMEU")
          @DTW_ASSIGN(orderBy, "EANAMEU DESC")
          @DTW_ASSIGN(orderByDisplay, "Name (descending)")
      %else
          @DTW_ASSIGN(orderBy, "EANAMEU")
          @DTW_ASSIGN(orderByDisplay, "Name")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("EADEPT", "Department", $(srchDept), "U", operDept, "A")
  @Build_WildCard ("upper(EANAME)", "Name", $(srchName), "U", operName, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}