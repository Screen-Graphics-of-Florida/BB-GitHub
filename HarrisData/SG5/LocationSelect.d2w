%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Location"
  d2wName                 = "LocationSelect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;locationNumber=@dtw_rurlescseq(locationNumber)&amp;locationName=@dtw_rurlescseq(locationName)&amp;noMenu=@dtw_rurlescseq(noMenu)&amp;fromSel=Y"
  programName             = "HHDLCU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@locationName", "@dtw_rurlescseq(locationName)", "1", "a", workURL)
  @dtw_replace(workURL, "@@locationNumber", "@dtw_rurlescseq(locationNumber)", "1", "a", workURL)
%}
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @LocationUserView(profileHandle, dataBaseID, userPass, locationNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %if (noMenu =="Y")
                  %INCLUDE "$(inquiryBanner)"
              %else
                  %INCLUDE "banner.icl"
              %endif
              <!-- End Of Banner Code -->
                  <table $(baseTable)>
                      <tr valign="top">
                          %if (formatToPrint == "" && noMenu !="Y")
                              @dtw_assign(pageID, "LOCATIONSELECT")
                              <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                          %endif
                          <td class="content">
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select LOLNA1, LOLNA2, LOLNA3, LOLNA4, LOLCTY, LOST, LOZIP, LOLOC#, LOPHON", stmtSQL)
                              @dtw_concat(fileSQL, " HDLCTN ", fileSQL)
                              @dtw_concat(selectSQL, "LOLOC#=$(locationNumber) ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %INCLUDE "stmtSQLEnd.icl"
                              @Location_Query(profileHandle, dataBaseID, stmtSQL)
                          </td>
                      </tr>
                  </table>
              <!-- Start Of Trailer Code -->
              %if (noMenu =="Y")
                  %INCLUDE "$(inquiryTrailer)"
              %else
                  %INCLUDE "trailer.icl"
              %endif
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Location_Query (IN  CHAR(64)    profileHandle,
				        CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y" && noMenu !="Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)LocationMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (sec_01=="Y" && sec_04=="Y")
                          <a href="$(homeURL)$(cGIPath)LocationMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=Z">$(copyImageLrg)</a>
                      %endif
                      %if (sec_02 == "Y" || sec_03 == "Y")
                          <a href="$(homeURL)$(cGIPath)LocationMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=C">$(changeImageLrg)</a>
                      %endif
                      %if (sec_03 == "Y")
                          @Format_Confirm_Desc($(locationName), $(locationNumber), "", "", "", "", confirmDesc)
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)LocationMaintain.d2w/Edit_Data$(d2wVarBase)&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"
	
      %if (noMenu =="Y")
          $(inquiryhrTagAttr)
      %else
          $(hrTagAttr)
      %endif

      <table $(contentTable)>
          <colgroup>
              <col width="60%">
    	       <col width="20%">
	   	
          %ROW {
              @EditPhoneNumber(V_LOPHON)
              <tr><td rowspan="5" class="dspalph"> $(V_LOLNA1) <br>
                   %if (V_LOLNA2 != "")
                       $(V_LOLNA2) <br>
                   %endif
                   %if (V_LOLNA3 != "")
                       $(V_LOLNA3) <br>
                   %endif
                   %if (V_LOLNA4 != "")
                       $(V_LOLNA4) <br>
                   %endif

                   $(V_LOLCTY), $(V_LOST) $(V_LOZIP)
                  </td>

                  <td class="dsphdr">Location Number</td>
                  <td class="dspnmbr">$(V_LOLOC#)</td>
              </tr>

              <tr>
                  <td class="dsphdr">Phone Number</td>
                  <td class="dspnmbr">$(V_LOPHON)</td>
              </tr>
          %}	
      </table>
      %if (noMenu =="Y")
          $(inquiryhrTagAttr)
      %else
          $(hrTagAttr)
      %endif
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}