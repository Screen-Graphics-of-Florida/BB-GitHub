%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Recurring Journal"
  d2wName                 = "GLRecurJrnl.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  noMsg                   = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "DateEdit.icl"
              %INCLUDE "Menu.js"
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editdate(document.Search.srchDate))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "GLRECURJRNL")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select GLRCJL.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(a.FLDESC,' ') as statusFLDESC, upper(coalesce(a.FLDESC,' ')) as statusFLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(b.FLDESC,' ') as transFLDESC, upper(coalesce(b.FLDESC,' ')) as transFLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(USDESC,' ') as USDESC, coalesce(USDESCU,' ') as USDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " GLRCJL ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG a on a.FLTYPE='GLTRANSTAT' and a.FLVALU=RJSTAT ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG b on b.FLTYPE='GLTRANTYP' and b.FLVALU=RJTTYP ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYUSER on USUSER=RJUSER ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, "RJJRNL<>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64) profileHandle,
                                   CHAR(2)   dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      $(hrTagAttr)

      %if (formatToPrint == "")
          <form class="formClass" METHOD=POST name="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Journal</th>
                      <th class="colhdr">Type</th>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">Date Last Posted</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchJrnl" size="6" maxlength="6">
                          <input type="hidden" name="operJrnl" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchType" size="2" maxlength="2">
                          <input type="hidden" name="operType" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchDesc" size="20" maxlength="20">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputnmbr"  name="srchDate" size="6" maxlength="6">
                          <input type="hidden" name="operDate" value="=">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchJrnl.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
     %endif

      <table $(contentTable)>
          <tr>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("RJJRNL", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Journal" title="Sequence By Journal, Date">Journal</a></th>
              @OrderBy_Sort("RJDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Description, Date, Journal">Description</a></th>
              @OrderBy_Sort("RJPDAT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Date" title="Sequence By Date Last Posted, Journal">Date Last Posted</a></th>
              @OrderBy_Sort("statusFLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Status" title="Sequence By Status, Date, Journal">Status</a></th>
              @OrderBy_Sort("transFLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Type" title="Sequence By Transaction Type, Date, Journal">Transaction Type</a></th>
              @OrderBy_Sort("USDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=User" title="Sequence By User, Date, Journal">User</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"

              @Format_Date(V_RJPDAT, "D", F_RJPDAT)
              <tr class="$(rowClass)">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)GLRecurJrnlEntry.d2w/ENTRY$(genericVarBase)&amp;glJrnl=@dtw_rurlescseq(V_RJJRNL)" title="View Recurring Journal">$(V_RJJRNL)</a></td>
                  <td class="colalph">$(V_RJDESC)</td>
                  <td class="colnmbr">$(F_RJPDAT)</td>
                  <td class="colalph" $(helpCursor)><span title="$(V_RJSTAT)">$(V_statusFLDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_RJTTYP)">$(V_transFLDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_RJUSER)">$(V_USDESC)</span></td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select GLRCJL.*, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(a.FLDESC,' ') as statusFLDESC, upper(coalesce(a.FLDESC,' ')) as statusFLDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(b.FLDESC,' ') as transFLDESC, upper(coalesce(b.FLDESC,' ')) as transFLDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(USDESC,' ') as USDESC, coalesce(USDESCU,' ') as USDESCU ", stmtSQL)
  @dtw_concat(fileSQL, " GLRCJL ", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG a on a.FLTYPE='GLTRANSTAT' and a.FLVALU=RJSTAT ", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG b on b.FLTYPE='GLTRANTYP' and b.FLVALU=RJTTYP ", fileSQL)
  @dtw_concat(fileSQL, " left join SYUSER on USUSER=RJUSER ", fileSQL)
  %if (wildCardSearch!="")
      @dtw_concat(selectSQL, "RJJRNL<>' ' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_XMLQuery (IN  CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("RecurJournalList")
          %ROW{
              @XMLIDTag(V_RJJRNL, "RecurJournal ID")
                  @XMLTag(V_RJJRNL, "Journal")
                  @XMLTag(V_RJTTYP, "TransactionType")
                  @XMLTag(V_RJCLRA, "ClearAmountsAfterPosting")
                  @XMLTag(V_RJMPST, "MultiplePostingPerPeriod")
                  @XMLTag(V_RJFCUR, "CurrencyType")
                  @XMLTag(V_RJSTAT, "Status")
                  @XMLTag(V_RJDESC, "Description")
                  @XMLTag(V_RJHMS,  "TimeUpdated")
                  @XMLTag(V_RJMDY,  "DateUpdated")
                  @XMLTag(V_RJUSER, "UserProfile")
                  @XMLTag(V_RJWSID, "Workstation")
                  @XMLTag(V_RJPDAT, "DateLastPosted")
              @XMLEndTag("RecurJournal")
          %}
      @XMLEndTag("RecurJournalList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "RJJRNL")
          @DTW_ASSIGN(orderByDisplay, "Journal")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Journal")
      %if (orderBy == "RJJRNL")
          @DTW_ASSIGN(orderBy, "RJJRNL DESC")
          @DTW_ASSIGN(orderByDisplay, "Journal (descending)")
      %else
          @DTW_ASSIGN(orderBy, "RJJRNL")
          @DTW_ASSIGN(orderByDisplay, "Journal")
      %endif
  %elif (sequence == "Description")
      %if (orderBy == "RJDESCU,RJJRNL")
          @DTW_ASSIGN(orderBy, "RJDESCU DESC,RJJRNL")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Journal")
      %else
          @DTW_ASSIGN(orderBy, "RJDESCU,RJJRNL")
          @DTW_ASSIGN(orderByDisplay, "Description, Journal")
      %endif
  %elif (sequence == "Date")
      %if (orderBy == "RJPDAT,RJJRNL")
          @DTW_ASSIGN(orderBy, "RJPDAT DESC,RJJRNL")
          @DTW_ASSIGN(orderByDisplay, "Date (descending), Journal")
      %else
          @DTW_ASSIGN(orderBy, "RJPDAT,RJJRNL")
          @DTW_ASSIGN(orderByDisplay, "Date, Journal")
      %endif
  %elif (sequence == "Status")
      %if (orderBy == "statusFLDESCU,RJJRNL")
          @DTW_ASSIGN(orderBy, "statusFLDESCU DESC,RJJRNL")
          @DTW_ASSIGN(orderByDisplay, "Status (descending), Journal")
      %else
          @DTW_ASSIGN(orderBy, "statusFLDESCU,RJJRNL")
          @DTW_ASSIGN(orderByDisplay, "Status, Journal")
      %endif
  %elif (sequence == "Type")
      %if (orderBy == "transFLDESCU,RJJRNL")
          @DTW_ASSIGN(orderBy, "transFLDESCU DESC,RJJRNL")
          @DTW_ASSIGN(orderByDisplay, "Transaction Type (descending), Journal")
      %else
          @DTW_ASSIGN(orderBy, "transFLDESCU,RJJRNL")
          @DTW_ASSIGN(orderByDisplay, "Transaction Type, Journal")
      %endif
  %elif (sequence == "User")
      %if (orderBy == "USDESCU,RJJRNL")
          @DTW_ASSIGN(orderBy, "USDESCU DESC,RJJRNL")
          @DTW_ASSIGN(orderByDisplay, "User (descending), Journal")
      %else
          @DTW_ASSIGN(orderBy, "USDESCU,RJJRNL")
          @DTW_ASSIGN(orderByDisplay, "User, Journal")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          @dtw_assign(formName, "Search")
          %INCLUDE "$(headInclude)"
          <link rel=stylesheet type="text/css" href="$(homeURL)$(homePath)$(GLDDStyleSheet)">
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editdate(document.Search.srchDate))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "GLUNPOSTJRNLSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Journal</td>
                              @dtw_assign(operNbr, "operJrnl")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchJrnl" size="6" maxlength="6"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Date Last Posted</td>
                              @dtw_assign(operNbr, "operDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchDate" size="6" maxlength="6"><a href="javascript:calWindow('srchDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Status</td>
                              @dtw_assign(operNbr, "operStatus")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchStatus" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">User</td>
                              @dtw_assign(operNbr, "operUser")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchUser" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Transaction Type</td>
                              @dtw_assign(operNbr, "operType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchType" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Clear Amounts After Posting</td>
                              @dtw_assign(operNbr, "operClearAmt")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchClearAmt" size="1" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Clear Amounts After Posting</td>
                              @dtw_assign(operNbr, "operClearAmt")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchClearAmt" size="1" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Multiple Posting Per Period</td>
                              @dtw_assign(operNbr, "operMultPost")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchMultPost" size="1" maxlength="1"></td>
                          </tr>

                          %if (V_HDMCRL>"0")
                              <tr><td class="dsphdr">Currency Type</td>
                                  @dtw_assign(operNbr, "operCurrency")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchCurrency" size="3" maxlength="3"></td>
                              </tr>
                          %endif

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchJrnl.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("RJJRNL", "Journal", $(srchJrnl), "U", operJrnl, "A")
  @Build_WildCard ("RJDESCU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("RJPDAT", "Date Last Posted", $(srchDate), "", operDate, "D")
  @Build_WildCard ("upper(coalesce(a.FLDESC,' '))", "Status", $(srchStatus), "U", operStatus, "A")
  @Build_WildCard ("coalesce(USDESCU,' ')", "User", $(srchUser), "U", operUser, "A")
  @Build_WildCard ("upper(coalesce(b.FLDESC,' ')", "Transaction Type", $(srchType), "U", operType, "A")
  @Build_WildCard ("RJCLRA", "Clear Amounts After Posting", $(srchClearAmt), "U", operClearAmt, "A")
  @Build_WildCard ("RJMPST", "Multiple Posting Per Period", $(srchMultPost), "U", operMultPost, "A")
  @Build_WildCard ("TJFCUR", "Currency Type", $(srchCurrency), "U", operCurrency, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}