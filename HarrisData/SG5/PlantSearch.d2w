%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "PlantMaintain.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Plant Search"
  d2wName                 = "PlantSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName      	     = ""
  fldName      	     = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              function selectPlant(plant, desc){
                  window.opener.document.$(docName).$(fldName).value = plant;
                  window.opener.document.$(docName).$(fldDesc).value = desc;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchPlant, 3, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(uv_PlantName, "PLPLNT")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select HDPLNT.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(PLNAME) as PLNAMEU, " , stmtSQL)
                      @dtw_concat(stmtSQL, " upper(PLADR1) as PLADR1U, " , stmtSQL)
                      @dtw_concat(stmtSQL, " upper(PLCITY) as PLCITYU " , stmtSQL)
                      @dtw_concat(fileSQL, " HDPLNT ", fileSQL)
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, " PLPLNT=$(plantNumber)", selectSQL)
                      %elseif (wildCardSearch!="" || uv_Sql!="")
                          @dtw_concat(selectSQL, " PLPLNT<>0 ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Plant_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) Plant_Search (IN  CHAR(64)    profileHandle,
                                     CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a NAME="top"></a>
      %INCLUDE "PageTitle.icl"

      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr"> Plant</th>
                      <th class="colhdr"> Name</th>
                  </tr>
                  <tr><td class="inputnmbr">
                          <input type="text" name="srchPlant" size="3" maxlength="3">
                          <input type="hidden" name="operPlant" value="=">
                      </td>
                      <td class="inputalph">
                          <input type="text" name="srchName" size="26" maxlength="26">
                          <input type="hidden" name="operName" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchPlant.focus();
              </script>
          </form>
	
          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("PLPLNT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=number" title="Sequence By Plant"> Plant</a></th>
                  @OrderBy_Sort("PLNAMEU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=name"  title="Sequence By Name, Plant" onmouseover="status='$(homeURL)$(cGIPath)plant.d2w/ORDERBY...';return true" onmouseout="window.status=' ';return true"> Name</a></th>
                  @OrderBy_Sort("PLCO#", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=coFac" title="Sequence By Company/Facility, Name, Plant"> Co/Fac</a></th>
                  @OrderBy_Sort("PLADR1U", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=address" title="Sequence By Address, Name, Plant"> Address</a></th>
                  @OrderBy_Sort("PLCITYU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=city" title="Sequence By City, Name, Plant"> City</a></th>
                  @OrderBy_Sort("PLST", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=state" title="Sequence By State, Name, Plant"> State</a></th>
                  @OrderBy_Sort("PLZIP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=zipCode" title="Sequence By Zip, Name, Plant"> Zip</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %else
          <table $(contentTable)>
      %endif		

          %ROW{

              @Format_Quote(V_PLNAME, F_PLNAME)
              @Format_CoFac("$(V_PLCO#)", "$(V_PLFAC#)", "", F_CoFac)

	       %if (moreInfo != "Y")	
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colnmbr">$(V_PLPLNT)</td>                                      	
                      <td class="colalph"><a href="javascript:selectPlant($(V_PLPLNT),'$(F_PLNAME)')" title="Select Plant">$(V_PLNAME)</a></td>
                      <td class="colalph">$(F_CoFac)</td>
                      <td class="colalph">$(V_PLADR1)</td>
                      <td class="colalph">$(V_PLCITY)</td>
                      <td class="colcode">$(V_PLST)</td>
                      <td class="colalph">$(V_PLZIP)</td>
                      <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)$(wildCardVarBase)&amp;plantNumber=@dtw_rurlescseq(V_PLPLNT)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                  </tr>

              %else
                  %{ More Information Screen %}

                  <tr><td><a href="javascript:selectPlant($(V_PLPLNT),'$(F_PLNAME)')" title="Select Plant">$(selectImageLrg)</a>
                  </td></tr>
                  </table>

                  <table $(quickLinkTable)>
                      <tr>
                          <td class="quickLinkTabs"><a href="#generalData">General Data</a></td>
                          <td class="quickLinkTabs"><a href="#productDataBase">Product Data Base</a></td>
                          <td class="quickLinkTabs"><a href="#costManagement">Cost Management</a></td>
                          <td class="quickLinkTabs"><a href="#MPSMRP">MPS/MRP</a></td>
                      </tr>
                      <tr>
                          <td class="quickLinkTabs"><a href="#shopFloor">Shop Floor Control</a></td>
                          <td class="quickLinkTabs"><a href="#cycleCount">Cycle Count</a></td>
                          <td class="quickLinkTabs"><a href="#accountNumbers">Accounts</a></td>
                          <td class="quickLinkTabs"><a href="#userDefined">User-Defined</a></td>
                      </tr>
                  </table>

                  <a name="generalData"></a>
                  <fieldset class="legendBody">
                      <legend class="legendTitle">General Data</legend>
                      <table $(contentTable)>
                          <tr><td><a href="#top">$(topOfFormImage)</a></td></tr>
                      </table>
                      <table $(contentTable)>
                      <tr><td class="dsphdr">Plant Number</td>
                          <td class="dspalph">$(V_PLPLNT)</td>
                      </tr>
    	   		
                      <tr><td class="dsphdr">Plant Name</td>
                          <td class="dspalph">$(V_PLNAME)</td>
                      </tr>
    	   	
    	               @RtvFldDesc("CFCO#=$(V_PLCO#) and CFFAC#=$(V_PLFAC#)", "HDCFAC", "CFCFNM", fieldDesc)
                      <tr><td class="dsphdr">Company/Facility</td>
                          <td class="dspalph">$(fieldDesc)</td></tr>


                      %if (V_PLADR1!="")		
                          <tr><td class="dsphdr">Address Line One</td>
                              <td class="dspalph">$(V_PLADR1)</td></tr>
                      %endif

                      %if (V_PLADR2!="")		
                          <tr><td class="dsphdr">Address Line Two</td>
                              <td class="dspalph">$(V_PLADR2)</td></tr>
                      %endif
        				
                      %if (V_PLCITY!="")		
                          <tr><td class="dsphdr">City</td>
                              <td class="dspalph">$(V_PLCITY)</td></tr>
                      %endif

                      %if (V_PLST!="")
    		       @RtvFldDesc("STID='$(V_PLST)'", "HDSTID", "STDESC", fieldDesc)
                          <tr><td class="dsphdr">State</td>
                              <td class="dspalph">$(fieldDesc)</td></tr>
                      %endif

                      %if (V_PLZIP!="")		
                          <tr><td class="dsphdr">Zip</td>
                              <td class="dspalph">$(V_PLZIP)</td></tr>
                      %endif

                      %if (V_PLCTRY!="")
    		       @RtvFldDesc("CNCTCD='$(V_PLCTRY)'", "HDCTRY", "CNCDES", fieldDesc)
                          <tr><td class="dsphdr">Country</td>
                              <td class="dspalph">$(fieldDesc)</td></tr>			
                      %endif

                      %if (V_PLCTRY!="")		
                          <tr><td class="dsphdr">Alpha Sequence</td>
                              <td class="dspalph">$(V_PLALPH)</td> </tr>
                      %endif
        			
                      %if (V_PLSCHD!="")
    		       @RtvFldDesc("SMSCHD=$(V_PLSCHD)", "HDSCHM", "SMDESC", fieldDesc)
                          <tr><td class="dsphdr">Schedule</td>
                              <td class="dspalph">$(fieldDesc)</td></tr>
                      %endif
                      </table>
                  </fieldset>

                  <a name="productDataBase"></a>
                  <fieldset class="legendBody">
                      <legend class="legendTitle">Product Data Base</legend>
                      <table $(contentTable)>
                          <tr><td><a href="#top">$(topOfFormImage)</a></td></tr>
                      </table>
                      <table $(contentTable)>

                      %if (V_PLRSEQ!="0")		
                          <tr><td class="dsphdr">Default Product Structure Routing Sequence</td>
                              <td class="dspnmbr">$(V_PLRSEQ)</td></tr>
                      %endif
    	   		        		
                      %if (V_PLRSF!="")
                          @RtvYNDesc($(V_PLRSF), fieldDesc)
                          <tr><td class="dsphdr">Product Structure Interfaces With Routing Master</td>
                              <td class="dspalph">$(fieldDesc)</td></tr>
                      %endif
                      </table>
                  </fieldset>

                  <a name="costManagement"></a>
                  <fieldset class="legendBody">
                      <legend class="legendTitle">Cost Management</legend>
                      %if (V_HDSCRL>"0")		
                          <table $(contentTable)>
                              <tr><td><a href="#top">$(topOfFormImage)</a></td></tr>
                          </table>
                          <table $(contentTable)>
                              %if (V_PLCC1D!="" || V_PLC1LD!="" || V_PLCC2D!="" || V_PLC2LD!="" || V_PLCC3D!="" || V_PLC3LD!="" || V_PLCC4D!="" || V_PLC4LD!="" || V_PLCC5D!="" || V_PLC5LD!="")		
                                  <tr><td class="dsphdr">Cost Category:</td>
                                      <td class="dsphdr">Short Description</td>
                                      <td class="dsphdr">Long Description</td></tr>
                              %endif

                              %if (V_PLCC1D!="" || V_PLC1LD!="")		
                                  <tr><td class="dsphdr">One</td>
                                      <td class="dspalph">$(V_PLCC1D)</td>
                                      <td class="dspalph">$(V_PLC1LD)</td></tr>
                              %endif

                              %if (V_PLCC2D!="" || V_PLC2LD!="")		
                                  <tr><td class="dsphdr">Two</td>
                                      <td class="dspalph">$(V_PLCC2D)</td>
                                      <td class="dspalph">$(V_PLC2LD)</td></tr>
                              %endif

                              %if (V_PLCC3D!="" || V_PLC3LD!="")		
                                  <tr><td class="dsphdr">Three</td>
                                      <td class="dspalph">$(V_PLCC3D)</td>
                                      <td class="dspalph">$(V_PLC3LD)</td></tr>
                              %endif

                              %if (V_PLCC4D!="" || V_PLC4LD!="")		
                                  <tr><td class="dsphdr">Four</td>
                                      <td class="dspalph">$(V_PLCC4D)</td>
                                      <td class="dspalph">$(V_PLC4LD)</td></tr>
                              %endif

                              %if (V_PLCC5D!="" || V_PLC5LD!="")		
                                  <tr><td class="dsphdr">Five</td>
                                      <td class="dspalph">$(V_PLCC5D)</td>
                                      <td class="dspalph">$(V_PLC5LD)</td></tr>
                              %endif
                          </table>

                          <table $(contentTable)>
                              %if (V_PLDOL1!="" || V_PLDOL2!="" || V_PLPCT1!="" || V_PLPCA1!=".00" || V_PLPCT2!="" || V_PLPCA2!=".00" || V_PLPCT3!="" || V_PLPCA3!=".00" || V_PLPCT4!="" || V_PLPCA4!=".00" || V_PLSPCT!=".00" || V_PLGPCT!=".00")		
                                  <tr><td class="dsphdr">Cost Simulation Variables:</td>
                                      <td class="dsphdr"></td>
                                      <td class="dsphdr">% Value</td></tr>
                              %endif

                              %if (V_PLDOL1!="")		
                                  <tr><td class="dsphdr">Dollar One</td>
                                      <td class="dspalph">$(V_PLDOL1)</td>
                              %endif

                              %if (V_PLDOL2!="")		
                                  <tr><td class="dsphdr">Dollar Two</td>
                                      <td class="dspalph">$(V_PLDOL2)</td>
                              %endif

                              %if (V_PLPCT1!="" || V_PLPCA1!=".00")		
                                  <tr><td class="dsphdr">Percent One</td>
                                      <td class="dspalph">$(V_PLPCT1)</td>
                                      <td class="dspnmbr">$(V_PLPCA1)</td></tr>
                              %endif

                              %if (V_PLPCT2!="" || V_PLPCA2!=".00")		
                                  <tr><td class="dsphdr">Percent Two</td>
                                      <td class="dspalph">$(V_PLPCT2)</td>
                                      <td class="dspnmbr">$(V_PLPCA2)</td></tr>
                              %endif

                              %if (V_PLPCT3!="" || V_PLPCA3!=".00")		
                                  <tr><td class="dsphdr">Percent Three</td>
                                      <td class="dspalph">$(V_PLPCT3)</td>
                                      <td class="dspnmbr">$(V_PLPCA3)</td></tr>
                              %endif

                              %if (V_PLPCT4!="" || V_PLPCA4!=".00")		
                                  <tr><td class="dsphdr">Percent Four</td>
                                      <td class="dspalph">$(V_PLPCT4)</td>
                                      <td class="dspnmbr">$(V_PLPCA4)</td></tr>
                              %endif

                              %if (V_PLSPCT!=".00")		
                                  <tr><td class="dsphdr">S&M % Mfg Cost</td>
                                      <td class="dspalph"></td>
                                      <td class="dspnmbr">$(V_PLSPCT)</td></tr>
                              %endif

                              %if (V_PLGPCT!=".00")		
                                  <tr><td class="dsphdr">G&A % Mfg Cost</td>
                                      <td class="dspalph"></td>
                                      <td class="dspnmbr">$(V_PLGPCT)</td></tr>
                              %endif

                              %if (V_PLFXEL!="")		
    		               @RtvFldDesc("FLTYPE='FIXOVERHD' and FLVALU='$(V_PLFXEL)'", "SYFLAG", "FLDESC", fieldDesc)
                                  <tr><td class="dsphdr">Fixed Overhead Category</td>
                                      <td class="dspalph">$(fieldDesc)</td></tr>
                              %endif
                          </table>
                      %endif
                  </fieldset>

                  <a name="MPSMRP"></a>
                  <fieldset class="legendBody">
                      <legend class="legendTitle">MPS/MRP</legend>
                      %if (V_HDMPRL>"0")		
                          <table $(contentTable)>
                              <tr><td><a href="#top">$(topOfFormImage)</a></td></tr>
                          </table>
                          <table $(contentTable)>
                              %if (V_PLDCP > "0")
                                  @Format_Date_ISO(V_PLDCP, "H", F_PLDCP)
                                  <tr><td class="dsphdr">Planning Horizon Date</td>
                                      <td class="dspdate">$(F_PLDCP)</td></tr>
                              %endif

                              %if (V_PLFCM > "0")
                                  @PeriodFromCYP(V_PLFCM)
                                  <tr><td class="dsphdr">Current Fiscal Period</td>
                                  <td class="dspnmbr">$(V_PLFCM)</td></tr> 		
                              %endif

                              %if (V_PL#WDD!="0")		
                                  <tr><td class="dsphdr"># Weeks Of Daily Periods</td>
                                      <td class="dspnmbr">$(V_PL#WDD)</td></tr>
                              %endif

                              %if (V_PL#WWD!="0")		
                                  <tr><td class="dsphdr"># Weeks Of Weekly Periods</td>
                                      <td class="dspnmbr">$(V_PL#WWD)</td></tr>
                              %endif

                              %if (V_PLSHR!=".00")		
                                  <tr><td class="dsphdr">Standard Hours/Day</td>
                                      <td class="dspnmbr">$(V_PLSHR)</td></tr>
                              %endif

                              %if (V_PLPL!="0")		
                                  <tr><td class="dsphdr">Period Length In Days</td>
                                      <td class="dspnmbr">$(V_PLPL)</td></tr>
                              %endif

                              %if (V_PLNTP!="0")		
                                  <tr><td class="dsphdr">Fixed Time Periods Weeks</td>
                                      <td class="dspnmbr">$(V_PLNTP)</td></tr>
                              %endif

                              %if (V_PLSSS!="")
                                  @RtvYNDesc($(V_PLSSS), fieldDesc)
                                  <tr><td class="dsphdr">Include Safety Stock</td>
                                      <td class="dspalph">$(fieldDesc)</td></tr>
                              %endif

                              %if (V_PLSCS!="")
                                  @RtvYNDesc($(V_PLSCS), fieldDesc)
                                  <tr><td class="dsphdr">Include Scrap Percent</td>
                                      <td class="dspalph">$(fieldDesc)</td></tr>
                              %endif

                              %if (V_PLSPS!="")
                                  @RtvYNDesc($(V_PLSPS), fieldDesc)
                                  <tr><td class="dsphdr">Increase Order Quantities By Shrinkage Percentage</td>
                                      <td class="dspalph">$(fieldDesc)</td></tr>
                              %endif

                              %if (V_PLPEGR!="")
                                  @RtvYNDesc($(V_PLPEGR), fieldDesc)
                                  <tr><td class="dsphdr">Create Pegged Requirements For Non MRP Items</td>
                                      <td class="dspalph">$(fieldDesc)</td></tr>
                              %endif

                          </table>

                          <table $(contentTable)>
                              %if (V_PLMOA!="0" || V_PLPOA!="0" || V_PLMDD!="0" || V_PLPDD!="0")		
                                  <tr><td class="dsphdr"></td>
                                      <td class="dsphdr">Mfg</td>
                                      <td class="dsphdr">Purchasing</td></tr>
                              %endif

                              %if (V_PLMOA!="0" || V_PLPOA!="0")		
                                  <tr><td class="dsphdr">Order Action Periods</td>
                                      <td class="dspnmbr">$(V_PLMOA)</td>
                                      <td class="dspnmbr">$(V_PLPOA)</td></tr>
                              %endif

                              %if (V_PLMDD!="0" || V_PLPDD!="0")		
                                  <tr><td class="dsphdr">Defer Damper Periods</td>
                                      <td class="dspnmbr">$(V_PLMDD)</td>
                                      <td class="dspnmbr">$(V_PLPDD)</td></tr>
                              %endif
                          </table>

                          <table $(contentTable)>

                              %if (V_PLMRPF!="")
                                  @RtvYNDesc($(V_PLMRPF), fieldDesc)
                                  <tr><td class="dsphdr">Use Prod Plan As MRP Input</td>
                                      <td class="dspalph">$(fieldDesc)</td></tr>
                              %endif

                              %if (V_PLFDTF!="")
                              @RtvFldDesc("FLTYPE='FORECASTDF' AND FLVALU='$(V_PLFDTF)'", "SYFLAG", "FLDESC", fieldDesc)
                                  <tr><td class="dsphdr">Forecast Date Format</td>
                                  <td class="dspalph">$(fieldDesc)</td></tr>
                              %endif

                              %if (V_PLFSPR!="")
                              @RtvFldDesc("FLTYPE='FORECASTSP' AND FLVALU='$(V_PLFSPR)'", "SYFLAG", "FLDESC", fieldDesc)
                                  <tr><td class="dsphdr">Forecast Spreaders</td>
                                      <td class="dspalph">$(fieldDesc)</td></tr>
                              %endif

                              %if (V_PLTFND!="")
                              @RtvFldDesc("TFDEF='$(V_PLTFND)'", "HDMTFM", "TFDESC", fieldDesc)
                                  <tr><td class="dsphdr">Time Fence Definition</td>
                                      <td class="dspalph">$(fieldDesc)</td></tr>
                              %endif

                              %if (V_PLPFCT!="")
                                  <tr><td class="dsphdr">Periods To Retain Forecast</td>
                                      <td class="dspalph">$(V_PLPFCT)</td></tr>
                              %endif

                              %if (V_PLCFCT!="")
                                  <tr><td class="dsphdr">Periods To Consume Forecast</td>
                                      <td class="dspalph">$(V_PLCFCT)</td></tr>
                              %endif
                          </table>
                      %endif
                  </fieldset>

                  <a name="shopFloor"></a>
                  <fieldset class="legendBody">
                      <legend class="legendTitle">Shop Floor Control</legend>
                      <table $(contentTable)>
                          <tr><td><a href="#top">$(topOfFormImage)</a></td></tr>
                      </table>
                      <table $(contentTable)>
                          %if (V_PLBKOP!="")		
                              @RtvYNDesc($(V_PLBKOP), fieldDesc)
                              <tr><td class="dsphdr">Backflush Components By Operation</td>
                                  <td class="dspalph">$(fieldDesc)</td></tr>
                          %endif

                          %if (V_PLLESQ!="0")		
                              <tr><td class="dsphdr">Next Labor Sequence</td>
                                  <td class="dspnmbr">$(V_PLLESQ)</td></tr>
                          %endif

                          %if (V_PLNMO!="0")		
                              <tr><td class="dsphdr">Last Mfg Order Number</td>
                                  <td class="dspnmbr">$(V_PLNMO)</td></tr>
                          %endif

                          %if (V_PLORCL!="")		
                              @RtvYNDesc($(V_PLORCL), fieldDesc)
                              <tr><td class="dsphdr">Close Orders At Receipt Entry (OR)</td>
                                  <td class="dspalph">$(fieldDesc)</td></tr>
                          %endif

