%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_titlef              = "Feature Options"
  page_titleb              = "Bi-Level Options"
  d2wName                 = "FeatureOption.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;selectPlant=@dtw_rurlescseq(selectPlant)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;feature=@dtw_rurlescseq(feature)&amp;featuredItem=@dtw_rurlescseq(featuredItem)&amp;featureDesc=@dtw_rurlescseq(featureDesc)&amp;maintenanceCodeFB=@dtw_rurlescseq(maintenanceCodeFB)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPDFOM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
             %INCLUDE "$(headInclude)"
             <script TYPE="text/javascript">
                 function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
                 %INCLUDE "CheckEnterSearch.icl"
                 %INCLUDE "Menu.js"
                 %INCLUDE "NoFormValidate.icl"
             </script>
             %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
             <!-- Start Of Banner Code -->
             %INCLUDE "banner.icl"
             <!-- End Of Banner Code -->
             <table $(baseTable)>
                 <tr valign="top">
                     %if (formatToPrint == "")
                         @dtw_assign(pageID, "FEATUREOPTION")
                         <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                     %endif
                     <td class="content">
                         %INCLUDE "stmtSQLClear.icl"
                         @dtw_concat(stmtSQL, " Select WKXHND, WKSSEQ, WKOPTN, WKDFLT, WKXCHG, WKXFLG, WKODSC, WKBLOP, ", stmtSQL)
                         @dtw_concat(stmtSQL, "WKDBLO, upper(WKODSC) as WKODSCU " , stmtSQL)
                         @dtw_concat(fileSQL, " HDMFOW", fileSQL)
                         @dtw_concat(selectSQL, " WKPLT=$(plantNumber) and WKFPRT='$(featuredItem)' and WKFEAT='$(feature)' and WKXHND='$(profileHandle)' ", selectSQL)
                         %INCLUDE "stmtSQLSelect.icl"
                         @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                         %INCLUDE "stmtSQLEnd.icl"
                         %INCLUDE "stmtSQLTotalRows.icl"
                         @FeatureOption_Query(profileHandle, dataBaseID, stmtSQL)
                     </td>
                 </tr>
             </table>
             <!-- Start Of Trailer Code -->
             %INCLUDE "trailer.icl"
             <!-- End Of Trailer Code -->
        </body>
     </html>
  %endif
%}

%FUNCTION(dtw_sql) FeatureOption_Query (IN CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("FOPLT=$(plantNumber) and FOOPTN='$(feature)'", "HDMFOP","FOBLOP", biLevel)
      %if (featuredItem != "")
          @RtvFldDesc("FIPLT=$(plantNumber) and FIFEAT='$(feature)' and FIFPRT='$(featuredItem)'", "HDMFIT","CHAR(COUNT(FIFEAT))", featureAssigned)
      %else
          @RtvFldDesc("FIPLT=$(plantNumber) and FIFEAT='$(feature)'", "HDMFIT","CHAR(COUNT(FIFEAT))", featureAssigned)
      %endif
      @RtvFldDesc("WKPLT=$(plantNumber) and WKFPRT='$(featuredItem)' and WKFEAT='$(feature)' and WKXHND='$(profileHandle)'", "HDMFOW","CHAR(COUNT(WKOPTN))", recordsExist)

      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr>
              %if (biLevel == "Y")
                  <td><h1>$(page_titleb)</h1></td>
              %else
                  <td><h1>$(page_titlef)</h1></td>
              %endif
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                         <a href="$(homeURL)$(cGIPath)FeatureOptionMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (recordsExist > "0" || (recordsExist == "0" && biLevel != "Y" && featureAssigned == "0" && maintenanceCodeFB != "A" && maintenanceCodeFB != "Z"))
                          <a href="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)&amp;biLevel=@dtw_rurlescseq(biLevel)">$(saveImageLrg  )</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>

      </table>

      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      <table $(contentTable)>
          @Format_Header_URL("Plant", $(plantName), $(plantNumber), "$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(d2wVarBase)")
          %if (biLevel == "Y")
              @Format_Header("Bi-Level", $(featureDesc), $(feature))
          %else
              @Format_Header("Feature", $(featureDesc), $(feature))
          %endif
          %if (featuredItem !="")
              @dtw_assign(itemDesc, "")
              @RtvFldDesc("IMITEM='$(featuredItem)'", "HDIMST", "IMIMDS", itemDesc)
              %if (itemDesc =="")
                  @RtvFldDesc("IGTYPE='F' and IGIGRP='$(featuredItem)' and IGPLT=$(plantNumber)", "HDIGPH", "IGDESC", itemDesc)
              %endif
              @Format_Header("Featured Item/Family", $(itemDesc), $(featuredItem))
          %endif
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <table $(contentTable)>
              <tr><td> %INCLUDE "AssignPageValue.icl" </td>
              </tr>
          </table>
      %endif

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @OrderBy_Sort("WKOPTN", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=optionItem" title="Sequence By Option"> Option</a></th>
              @OrderBy_Sort("WKDFLT", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=defaultOption" title="Sequence By Default"> Default</a></th>
              <th class="colhdr">Extra Charge</th>
              <th class="colhdr">Percent</th>
              @OrderBy_Sort("WKODSCU", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=optionDesc" title="Sequence By Description"> Description</a></th>
              %if (biLevel != "Y")
                  <th class="colhdr">B/L</th>
                  <th class="colhdr">Bi-Level<br>Option</th>
              %endif
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;optionItem=@dtw_rurlescseq(V_WKOPTN)&amp;subSequence=@dtw_rurlescseq(V_WKSSEQ)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_WKOPTN), "", "", "", "", "", confirmDesc)
              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)FeatureOptionMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)FeatureOptionMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)FeatureOptionMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_WKOPTN)</td>
                  <td class="colcode">$(V_WKDFLT)</td>
                  <td class="colnmbr">$(V_WKXCHG)</td>
                  <td class="colcode">$(V_WKXFLG)</td>
                  <td class="colalph">$(V_WKODSC)</td>
                  %if (biLevel != "Y")
                      <td class="colcode">$(V_WKBLOP)</td>
                      <td class="colalph">$(V_WKDBLO)</td>
                  %endif
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "WKOPTN")
          @DTW_ASSIGN(orderByDisplay, "optionItem")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%FUNCTION(DTW_directcall) Option_Workfile(INOUT CHAR(64)    profileHandle,
			                   INOUT CHAR(2)     dataBaseID,
                                          INOUT CHAR(1)     maintenanceCodeFB,
                                          INOUT CHAR(1)     errFound,
                                          INOUT CHAR(32000) edtVar,                             	
                                          INOUT CHAR(32000) errVar,
                                          INOUT CHAR(10)    SUBR)
{%EXEC {HPDFOM_W.PGM %}
%}

%HTML(BUILD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(feature)
  @dtw_mUPPERCASE(featuredItem)
  @dtw_mUPPERCASE(fromFeature)
  @dtw_mUPPERCASE(fromFeaturedItem)

  @dtw_assign(plantNumber,@dtw_rstrip(plantNumber))
  @dtw_assign(fromPlant,@dtw_rstrip(fromPlant))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@fprt", featuredItem)
  @Concat_Field("@@feat", feature)
  @Concat_Field("@@fdsc", featureDesc)
  %if (maintenanceCodeFB == "Z")
      @Concat_Field("@@fplt", fromPlant)
      @Concat_Field("@@ffpr", fromFeaturedItem)
      @Concat_Field("@@ffea", fromFeature)
  %endif

  @dtw_concat(edtVar, "}{", edtVar)

  @dtw_assign(SUBR, "SRWORK")

  @Option_Workfile(profileHandle, dataBaseID, maintenanceCodeFB, errFound, edtVar, errVar, SUBR)
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)">
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(feature)
  @dtw_mUPPERCASE(featuredItem)

  @dtw_assign(plantNumber,@dtw_rstrip(plantNumber))

  %if (maintenanceCodeFB == "Z")
      @dtw_assign(maintenanceCodeFB, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@fprt", featuredItem)
  @Concat_Field("@@feat", feature)
  @Concat_Field("@@fdsc", featureDesc)
  @dtw_concat(edtVar, "}{", edtVar)

  @dtw_assign(SUBR, "ACCEPT")

  @Option_Workfile(profileHandle, dataBaseID, maintenanceCodeFB, errFound, edtVar, errVar, SUBR)

  %if (errFound == "")
      @dtw_assign(maintenanceCode, "$(maintenanceCodeFB)")
      %if (biLevel == "Y" && featuredItem != "")
          @Format_ConfMsg_Desc(maintenanceCode, "Bi-Level", $(feature), "Featured Item/Family", $(featuredItem), "", "", confMessage)
      %elif (biLevel == "Y")
          @Format_ConfMsg_Desc(maintenanceCode, "Bi-Level", $(feature), "", "", "", "", confMessage)
      %elif (featuredItem != "")
          @Format_ConfMsg_Desc(maintenanceCode, "Feature", $(feature), "Featured Item/Family", $(featuredItem), "", "", confMessage)
      %else
          @Format_ConfMsg_Desc(maintenanceCode, "Feature", $(feature), "", "", "", "", confMessage)
      %endif
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)FeatureBiLevel.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(selectPlant)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @DecatErr_Field("@@plt@", "plantNumber")
      %if (fieldValue == "")
          @DecatErr_Field("@@feat", "feature")
          %if (fieldValue == "")
              @DecatErr_Field("@@fprt", "featuredItem")
              %if (fieldValue == "")
                  @DecatErr_Field("@@optn", "optionItem")
                  %if (fieldValue == "")
                      @DecatErr_Field("@@blop", "bilevelOption")
                  %endif
              %endif
          %endif
      %endif
      %if (biLevel == "Y" && featuredItem != "")
          @Format_ConfMsg_Desc(maintenanceCodeFB, "Bi-Level", $(feature), "Featured Item/Family", $(featuredItem), "<br>$(fieldValue)", "", confMessage)
      %elif (biLevel == "Y")
          @Format_ConfMsg_Desc(maintenanceCodeFB, "Bi-Level", $(feature), "<br>$(fieldValue)", "", "", "", confMessage)
      %elif (featuredItem != "")
          @Format_ConfMsg_Desc(maintenanceCodeFB, "Feature", $(feature), "Featured Item/Family", $(featuredItem), "<br>$(fieldValue)", "", confMessage)
      %else
          @Format_ConfMsg_Desc(maintenanceCodeFB, "Feature", $(feature), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      %if (maintenanceCodeFB == "D")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)FeatureBiLevel.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(selectPlant)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %endif
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "optionItem")
      %if (orderBy == "WKOPTN")
          @DTW_ASSIGN(orderBy, "WKOPTN DESC")
          @DTW_ASSIGN(orderByDisplay, "Option (descending)")
      %else
          @DTW_ASSIGN(orderBy, "WKOPTN")
          @DTW_ASSIGN(orderByDisplay, "Option")
      %endif
  %elif (sequence == "defaultOption")
      %if (orderBy == "WKDFLT, WKOPTN")
          @DTW_ASSIGN(orderBy, "WKDFLT DESC, WKOPTN")
          @DTW_ASSIGN(orderByDisplay, "Default (descending)")
      %else
          @DTW_ASSIGN(orderBy, "WKDFLT, WKOPTN")
          @DTW_ASSIGN(orderByDisplay, "Default")
      %endif
  %elif (sequence == "optionDesc")
      %if (orderBy == "WKODSCU, WKOPTN")
          @DTW_ASSIGN(orderBy, "WKODSCU DESC, WKOPTN")
          @DTW_ASSIGN(orderByDisplay, "Option Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "WKODSCU, WKOPTN")
          @DTW_ASSIGN(orderByDisplay, "Option Description")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
