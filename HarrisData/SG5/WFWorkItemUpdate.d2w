%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Update Work Item Expiration or Priority"
  d2wName                 = "WFWorkItemUpdate.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfInstance=@dtw_rurlescseq(wfInstance)&amp;wfInstanceDate=@dtw_rurlescseq(wfInstanceDate)&amp;wfWorkItem=@dtw_rurlescseq(wfWorkItem)&amp;wfWorkItemSequence=@dtw_rurlescseq(wfWorkItemSequence)&amp;wfParticipantId=@dtw_rurlescseq(wfParticipantId)&amp;expireDate=@dtw_rurlescseq(expireDate)&amp;specWfInstance=@dtw_rurlescseq(specWfInstance)&amp;specWfInstanceDate=@dtw_rurlescseq(specWfInstanceDate)&amp;specWfWorkItem=@dtw_rurlescseq(specWfWorkItem)&amp;specWfWorkItemSequence=@dtw_rurlescseq(specWfWorkItemSequence)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function confirmDelete() {return confirm("$(delRecordConf)")}
              function validate(chgForm) {
                  if (document.Chg.priority.value =="" ||
                      document.Chg.reqExpireDate.value =="")
                         {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.priority, 2, 0) &&
                      editdate(document.Chg.reqExpireDate))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFWORKITEMUPDATE")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " WFWIPT ", fileSQL)
                      @dtw_concat(selectSQL, " WPINST=$(wfInstance) and WPINDT=$(wfInstanceDate) and WPWITM=$(wfWorkItem) and WPWISQ=$(wfWorkItemSequence) and WPPTID=$(wfParticipantId)", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td align="justify"><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  <a href="javascript:check(document.Chg)">$(changeImageLrg)</a>
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
          @RtvFldDesc("ININST=$(wfInstance) and ININDT=$(wfInstanceDate)", "WFINST", "INDESC", V_INDESC)
          <tr><td><h2> $(V_INDESC)</h2></td></tr>
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
          %ROW {
              %if (errFound != "")
                  @dtw_assign(focusField, "")
                  @EdtVarErr(profileHandle, typeValue, edtVar)
                  @ErrVarErr(profileHandle, typeError, errVar)
                  @DecatErr_Field("@@prty", "priority")            @dtw_assign(Err_WPPRTY, fieldValue)
                  @DecatErr_Field("@@exdt", "reqExpireDate")       @dtw_assign(Err_WPEXDT, fieldValue)
                  @DecatErr_Field("@@emal", "wfEmail")             @dtw_assign(Err_WPEMAL, fieldValue)
                  @DecatErr_Field("@@list", "workListLink")        @dtw_assign(Err_NFLIST, fieldValue)
                  @DecatErr_Field("@@hist", "workHistLink")        @dtw_assign(Err_NFHIST, fieldValue)

                  @Decat_Field("@@prty")   @dtw_assign(V_WPPRTY, fieldValue)
                  @Decat_Field("@@exdt")   @dtw_assign(V_WPEXDT, fieldValue)
                  @Decat_Field("@@emal")   @dtw_assign(V_WPEMAL, fieldValue)
                  @Decat_Field("@@list")   @dtw_assign(V_NFLIST, fieldValue)
                  @Decat_Field("@@hist")   @dtw_assign(V_NFHIST, fieldValue)
                  @Decat_Field("@@pcmt")   @dtw_assign(participantComments, fieldValue)
                  @Decat_Field("@@ucmt")   @dtw_assign(userComments, fieldValue)
                  @Decat_Field("@@ecmt")   @dtw_assign(emailComments, fieldValue)

                  @dtw_assign(errFound, "")
              %else
                  @dtw_assign(focusField, "priority")
                  @TimeStamp_CYMD(V_WPEXDT, V_WPEXDT)
                  @DateInputFromCYMD(V_WPEXDT)
                  @dtw_assign(V_NFLIST, "N")
                  @dtw_assign(V_NFHIST, "Y")
              %endif

              <table $(contentTable)>
                  @SetTextOvr(Err_WPPRTY)
                  <tr><td class="dsphdr"><span $(textOvr)>Priority</span></td>
                      <td class="inputnmbr"><input type="text" name="priority" value="$(V_WPPRTY)" size="2" maxlength="2">$(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_WPPRTY)

                  @SetTextOvr(Err_WPEXDT)
                  <tr><td class="dsphdr"><span $(textOvr)>Expiration Date</span></td>
                      <td class="inputnmbr"><input type="text" name="reqExpireDate" value="$(V_WPEXDT)" size="6" maxlength="6">$(reqFieldChar) 		
                                            <a href="javascript:calWindow('reqExpireDate');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_WPEXDT)

                  @RtvYNDesc($(V_NFLIST), fieldDesc)
                  @SetTextOvr(Err_NFLIST)
                  <tr><td class="dsphdr"><span $(textOvr)>Work List Link</span></td>
                      <td class="inputalph"><input type="text" name="workListLink" value="$(V_NFLIST)" size="1" maxlength="1">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=YORN&amp;flagSrchHdr=@dtw_rurlescseq("Work List Link")&amp;docName=Chg&amp;fldName=workListLink&amp;fldDesc=workListLinkDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                            <input type="text" disabled name="workListLinkDesc" value="$(fieldDesc)" size="20"></td>
                  </tr>
                  @DspErrMsg(Err_NFLIST)

                  @RtvYNDesc($(V_NFHIST), fieldDesc)
                  @SetTextOvr(Err_NFHIST)
                  <tr><td class="dsphdr"><span $(textOvr)>Work Item History Link</span></td>
                      <td class="inputalph"><input type="text" name="workHistLink" value="$(V_NFHIST)" size="1" maxlength="1">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=YORN&amp;flagSrchHdr=@dtw_rurlescseq("Work Item History Link")&amp;docName=Chg&amp;fldName=workHistLink&amp;fldDesc=workHistLinkDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                            <input type="text" disabled name="workHistLinkDesc" value="$(fieldDesc)" size="20"></td>
                  </tr>
                  @DspErrMsg(Err_NFHIST)
              </table>

              <table $(contentTable)>
                  <tr>
                      <td class="dsphdr" colspan="3">Notification To Participant:</td>
                  </tr>
                  <tr>
                      <td>
                          %if ("$(participantComments)" != "")
                               @dtw_assign(comment, participantComments)
                               <textarea name="participantComments" ROWS=5 COLS=60 WRAP="hard">$(comment)</textarea>
                          %else
            	                <textarea name="participantComments" ROWS=5 COLS=60 WRAP="hard"></textarea>
                          %endif
                      </td>
                  </tr>
              </table>

              <table $(contentTable)>
                  <tr>
                      <td class="dsphdr" colspan="3">Notification To Initial User:</td>
                  </tr>
                  <tr>
                      <td>
                          %if ("$(userComments)" != "")
                               @dtw_assign(comment, userComments)
                               <textarea name="userComments" ROWS=5 COLS=60 WRAP="hard">$(comment)</textarea>
                          %else
            	                <textarea name="userComments" ROWS=5 COLS=60 WRAP="hard"></textarea>
                          %endif
                      </td>
                  </tr>
              </table>

              <table $(contentTable)>
                  <tr>
                      <td class="dsphdr">Additional Email:</td>
                  </tr>
              </table>

              <table $(contentTable)>
                  @SetTextOvr(Err_WPEMAL)
                  <tr><td class="dsphdr"><span $(textOvr)>Email Address</span></td>
                      <td class="inputalph"><input type="text" name="wfEmail" value="$(V_WPEMAL)" size="30" maxlength="256"></td>
                  </tr>
                  @DspErrMsg(Err_WPEMAL)
              </table>

              <table $(contentTable)>
                  <tr>
                      <td>
                          %if ("$(emailComments)" != "")
                               @dtw_assign(comment, emailComments)
                               <textarea name="emailComments" ROWS=5 COLS=60 WRAP="hard">$(comment)</textarea>
                          %else
            	                <textarea name="emailComments" ROWS=5 COLS=60 WRAP="hard"></textarea>
                          %endif
                      </td>
                  </tr>
              </table>
          %}

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      <table $(contentTable)>
          <tr><td><a href="javascript:check(document.Chg)">$(changeImageLrg)</a></td></tr>
      </table>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HWFWIU_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("WIINST=$(wfInstance) and WIINDT=$(wfInstanceDate) and WIWITM=$(wfWorkItem) and WIWISQ=$(wfWorkItemSequence)", "WFWITM", "Char(Count(*))", RecCount)
  %if (RecCount >"0")
      @Set_SQL(stmtSQL)
  %else
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)WFWorkList.d2w/REPORT$(d2wVarBase)">
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @dtw_mUPPERCASE(workListLink)
  @dtw_mUPPERCASE(workHistLink)

  @dtw_assign(edtVar, "")
  @Concat_Field("@@inst", wfInstance)
  @Concat_Field("@@indt", wfInstanceDate)
  @Concat_Field("@@witm", wfWorkItem)
  @Concat_Field("@@wisq", wfWorkItemSequence)
  @Concat_Field("@@ptid", wfParticipantId)
  @Concat_Field("@@prty", priority)
  @Concat_Field("@@exdt", reqExpireDate)
  @Concat_Field("@@list", workListLink)
  @Concat_Field("@@hist", workHistLink)
  @Concat_Field("@@emal", wfEmail)
  @Concat_Field("@@pcmt", participantComments)
  @Concat_Field("@@ucmt", userComments)
  @Concat_Field("@@ecmt", emailComments)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, errFound, edtVar, errVar)

  %if (errFound == "")
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)WFWorkList.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
