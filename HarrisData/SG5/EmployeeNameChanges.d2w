%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Employee Name Changes"
  d2wName                 = "EmployeeNameChanges.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;inclActive=@dtw_rurlescseq(inclActive)&amp;inclTerminated=@dtw_rurlescseq(inclTerminated)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(d2wName)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HHREMU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"
  inclActive           = ""
  inclTerminated       = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchEmployee, 5, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                       @dtw_assign(pageID, "NAMECHANGE")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">

                      %INCLUDE "UserViewEmpl.icl"
    	               %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "SELECT NCCOMP, NCFACL, NCPREM, NCPECP, NCSD#, NCPEEM, NCSEQ, NCPLST, NCPFRS, NCPMID, NCDATE, NCRESN, EMCOMP, EMFACL, EMEMPL, EMPECP, EMPEMP, EMRNAM, EMLNAM, EMFNAM, EMMIDI, EMLNAMU, EMFNAMU, EMTRCD,", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(NCPLST) as NCPLSTU,", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(NCPFRS) as NCPFRSU,", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(NCRESN) as NCRESNU ", stmtSQL)
                      @dtw_concat(fileSQL, " HRNMCH inner join HREMPL on EMCOMP=NCCOMP and EMFACL=NCFACL and EMEMPL=NCPREM ", fileSQL)
                      @dtw_concat(selectSQL, " NCSD# = 0 ", selectSQL)
                      %INCLUDE "activeTerminatedEmplSQL.icl"
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Name_Change_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Name_Change_Query (IN  CHAR(64) profileHandle,
				           CHAR(2)   dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %if (sql_Record_Count != "1")
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                          %endif
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"

          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Previous<br>Last Name</th>
                          <th class="colhdr">Employee<br>Number</th>
                      </tr>
                      <tr><td class="inputalph"><input type="text" name="srchLast" size="18" maxlength="18">
                              <input type="hidden" name="operLast" value="LIKE">
                          </td>
                          <td class="inputnmbr"><input type="text" name="srchEmployee" size="5" maxlength="5">
                              <input type="hidden" name="operEmployee" value="=">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchLast.focus();
                  </script>
              </form>

              %INCLUDE "ActiveTerminatedChecked.icl"
              @dtw_assign(viewCheckBox, "HR")
              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y"))
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @OrderBy_Sort("NCCOMP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CoFac" title="Sequence By Company/Facility, Employee Number">Co/Fac</a></th>
                  @OrderBy_Sort("NCPREM", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PayrollNumber" title="Sequence By Employee Number">Employee<br>Number</a></th>
                  @OrderBy_Sort("NCPFRSU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PreviousFirst" title="Sequence By Previous First Name, Previous Last Name">Previous First Name</a></th>
                  @OrderBy_Sort("NCPLSTU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PreviousLast" title="Sequence By Previous Last Name, Previous First Name">Previous Last Name</a></th>
                  @OrderBy_Sort("NCDATE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ChangeDate" title="Sequence Name Change Date, Previous Last Name, Previous First Name">Name Change Date</a></th>
                  <th class="colhdr">Reason For Name Change</th>
                  @OrderBy_Sort("EMLNAMU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CurrentName" title="Sequence By Current Last Name, Current First Name">Current Name</a></th>
                  @OrderBy_Sort("NCPECP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=HrComp" title="Sequence By H/R Company, H/R Employee">H/R<br>Company</a></th>
                  @OrderBy_Sort("EMPEMP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=HrEmpl" title="Sequence By H/R Employee">H/R<br>Employee</a></th>
              </tr>
          %INCLUDE "NoRecordsFound.icl"
      %endif
              %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;prCompany=@dtw_rurlescseq(V_EMCOMP)&amp;prFacility=@dtw_rurlescseq(V_EMFACL)&amp;prEmployee=@dtw_rurlescseq(V_EMEMPL)&amp;hrCompany=@dtw_rurlescseq(V_EMPECP)&amp;hrEmployee=@dtw_rurlescseq(V_EMPEMP)&amp;nameChangeSequence=@dtw_rurlescseq(V_NCSEQ)")
                  %if (sql_Record_Count == "1")
                      @Save_WebReg(webRegCurFile, profileHandle, d2wName, "", orderBy, orderByDisplay, "")
                      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)EmployeeNameChanges2.d2w/REPORT$(maintainVar)">
                  %else
                      @Format_HRCoFac(V_NCCOMP, V_NCFACL, "N", F_CoFac)
                      @Format_EmplName(V_EMFNAM, V_EMLNAM, V_EMMIDI, V_EMRNAM, V_EMTRCD, "D", F_EmpName)
                      @Format_Date(V_NCDATE, "D", F_NCDATE)
                      @Format_Confirm_Desc($(F_EmpName),"Name Change", $(F_NCDATE), "", "", "", confirmDesc)
                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y"))
                              <td class="opticon">
                                  %if (sec_02 == "Y" || sec_03 == "Y")
                                      <a href="$(homeURL)$(cGIPath)EmplMaintainNameChg.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                                  %endif
                                  %if (sec_03 == "Y")
                                      <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)EmplMaintainNameChg.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                                  %endif
                              </td>
                          %endif
                          <td class="colnmbr">$(F_CoFac)</td>                                      	
                          <td class="colnmbr">$(V_NCPREM)</td>
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)EmployeeNameChanges2.d2w/REPORT$(maintainVar)" title="View All Name Changes For This Employee">$(V_NCPFRS)</a></td>
                          <td class="colalph">$(V_NCPLST)</td>
                          <td class="coldate">$(F_NCDATE)</td>
                          <td class="colalph">$(V_NCRESN)</td>
                          <td class="colalph">$(F_EmpName)</td>
                          <td class="colnmbr">$(V_NCPECP)</td>
                          <td class="colnmbr">$(V_NCPEEM)</td>
                      </tr>
                  %endif
              %}
          </table>
          %if (sql_Record_Count != "1")
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (sec_05 == "N")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)progOptSecError.d2w/DISPLAY$(genericVarBase)&amp;page_title=@dtw_rurlescseq(page_title)">
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint == "Y")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "NCPLSTU,NCPFRSU")
              @DTW_ASSIGN(orderByDisplay, "Previous Last Name, Previous First Name")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %elseif (chgActive == "Y" && inclActive == "Y")
              @dtw_assign(inclActive, "")
          %elseif (chgActive == "Y")
              @dtw_assign(inclActive, "Y")
          %elseif (chgTerminated == "Y" && inclTerminated == "Y")
              @dtw_assign(inclTerminated, "")
          %elseif (chgTerminated == "Y")
              @dtw_assign(inclTerminated, "Y")
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      %if (inclActive == "" && inclTerminated == "" && chgActive != "Y" && chgTerminated != "Y")
          @dtw_assign(inclActive, activeEmpl)
          @dtw_assign(inclTerminated, terminatedEmpl)
      %endif
      %INCLUDE "SearchReturn.icl"
  %endif
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "CoFac")
      %if (orderBy == "NCCOMP,NCFACL,NCPREM")
          @DTW_ASSIGN(orderBy, "NCCOMP DESC,NCFACL DESC,NCPREM DESC")
          @DTW_ASSIGN(orderByDisplay, "Company/Facility (descending), Payroll Employee Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "NCCOMP,NCFACL,NCPREM")
          @DTW_ASSIGN(orderByDisplay, "Company/Facility, Payroll Employee Number")
      %endif
  %elseif (sequence == "PayrollNumber")
      %if (orderBy == "NCPREM")
          @DTW_ASSIGN(orderBy, "NCPREM DESC")
          @DTW_ASSIGN(orderByDisplay, "Payroll Employee Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "NCPREM")
          @DTW_ASSIGN(orderByDisplay, "Payroll Employee Number")
      %endif
  %elseif (sequence == "PreviousFirst")
      %if (orderBy == "NCPFRSU,NCPLSTU")
          @DTW_ASSIGN(orderBy, "NCPFRSU DESC,NCPLSTU")
          @DTW_ASSIGN(orderByDisplay, "Previous First Name (descending), Previous Last Name")
      %else
          @DTW_ASSIGN(orderBy, "NCPFRSU,NCPLSTU")
          @DTW_ASSIGN(orderByDisplay, "Previous First Name, Previous Last Name")
      %endif
  %elseif (sequence == "PreviousLast")
      %if (orderBy == "NCPLSTU,NCPFRSU")
          @DTW_ASSIGN(orderBy, "NCPLSTU DESC,NCPFRSU")
          @DTW_ASSIGN(orderByDisplay, "Previous Last Name (descending), Previous First Name")
      %else
          @DTW_ASSIGN(orderBy, "NCPLSTU,NCPFRSU")
          @DTW_ASSIGN(orderByDisplay, "Previous Last Name, Previous First Name")
      %endif
  %elseif (sequence == "ChangeDate")
      %if (orderBy == "NCDATE,NCPLSTU,NCPFRSU")
          @DTW_ASSIGN(orderBy, "NCDATE DESC,NCPLSTU,NCPFRSU")
          @DTW_ASSIGN(orderByDisplay, "Date Name Changed (descending), Previous Last Name, Previous First Name")
      %else
          @DTW_ASSIGN(orderBy, "NCDATE,NCPLSTU,NCPFRSU")
          @DTW_ASSIGN(orderByDisplay, "Date Name Changed, Previous Last Name, Previous First Name")
      %endif
  %elseif (sequence == "CurrentName")
      %if (orderBy == "EMLNAMU,EMFNAMU")
          @DTW_ASSIGN(orderBy, "EMLNAMU DESC,EMFNAMU")
          @DTW_ASSIGN(orderByDisplay, "Current Last Name (descending), Current First Name")
      %else
          @DTW_ASSIGN(orderBy, "EMLNAMU,EMFNAMU")
          @DTW_ASSIGN(orderByDisplay, "Current Last Name, Current First Name")
      %endif
  %elseif (sequence == "HrComp")
      %if (orderBy == "NCPECP,NCPEEM")
          @DTW_ASSIGN(orderBy, "NCPECP DESC,NCPEEM")
          @DTW_ASSIGN(orderByDisplay, "H/R Company (descending), H/R Employee")
      %else
          @DTW_ASSIGN(orderBy, "NCPECP,NCPEEM")
          @DTW_ASSIGN(orderByDisplay, "H/R Company, H/R Employee")
      %endif
  %elseif (sequence == "HrEmpl")
      %if (orderBy == "EMPEMP")
          @DTW_ASSIGN(orderBy, "EMPEMP DESC")
          @DTW_ASSIGN(orderByDisplay, "H/R Employee (descending)")
      %else
          @DTW_ASSIGN(orderBy, "EMPEMP")
          @DTW_ASSIGN(orderByDisplay, "H/R Employee")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script type="text/javascript">
              %INCLUDE "numedit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchCompany, 2, 0) &&
                      editNum(document.Search.srchFacility, 4, 0) &&
                      editNum(document.Search.srchEmployee, 9, 0) &&
                      editdate(document.Search.srchChangeDate))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->

          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "NAMECHGSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Company Number</td>
                              @dtw_assign(operNbr, "operCompany")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchCompany" size="2" maxlength="2"></td>
                          </tr>	

                          <tr><td class="dsphdr">Facility Number</td>
                              @dtw_assign(operNbr, "operFacility")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchFacility" size="4" maxlength="4"></td>
                          </tr>	

                          <tr><td class="dsphdr">Employee Number</td>
                              @dtw_assign(operNbr, "operEmployee")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchEmployee" size="5" maxlength="5"></td>
                          </tr>	

                          <tr><td class="dsphdr">Previous First Name</td>
                              @dtw_assign(operNbr, "operFirst")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchFirst" size="18" maxlength="18"></td>
                          </tr>	

                          <tr><td class="dsphdr">Previous Last Name</td>
                              @dtw_assign(operNbr, "operLast")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchLast" size="18" maxlength="18"></td>
                          </tr>	

                          <tr><td class="dsphdr">Date Name Changed</td>
                              @dtw_assign(operNbr, "operChangeDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchChangeDate" size="6" maxlength="6">
                                  <a href="javascript:calWindow('srchChangeDate');">$(calendarImage)</a></td>
                          </tr>	

                          <tr><td class="dsphdr">Reason For Name Change</td>
                              @dtw_assign(operNbr, "operReason")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchReason" size="23" maxlength="23"></td>
                          </tr>	

                          <tr><td class="dsphdr">Current First Name</td>
                              @dtw_assign(operNbr, "operCurFirst")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchCurFirst" size="18" maxlength="18"></td>
                          </tr>	

                          <tr><td class="dsphdr">Current Last Name</td>
                              @dtw_assign(operNbr, "operCurLast")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCurLast" size="18" maxlength="18"></td>
                          </tr>	

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchCompany.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("NCCOMP", "Company Number", $(srchCompany), "", operCompany, "N")
  @Build_WildCard ("NCFACL", "Facility Number", $(srchFacility), "", operFacility, "N")
  @Build_WildCard ("NCPREM", "Employee Number", $(srchEmployee), "", operEmployee, "N")
  @Build_WildCard ("upper(NCPLST)", "Previous Last Name", $(srchLast), "U", operLast, "A")
  @Build_WildCard ("upper(NCPFRS)", "Previous First Name", $(srchFirst), "U", operFirst, "A")
  @Build_WildCard ("NCDATE", "Date Of Name Change", $(srchChangeDate), "", operChangeDate, "D")
  @Build_WildCard ("NCRESN", "Reason For Name Change", $(srchReason), "U", operReason, "A")
  @Build_WildCard ("EMLNAMU", "Current Last Name", $(srchCurLast), "U", operCurLast, "A")
  @Build_WildCard ("EMFNAMU", "Current First Name", $(srchCurFirst), "U", operCurFirst, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
