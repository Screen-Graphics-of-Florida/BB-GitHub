%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "Employee.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Add New Employee"
  d2wName                 = "EmployeeAdd.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  programName             = "HHREMU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PAD_PGM_PARMS    = "YES"
  SCRS                    = ""
  DLIN                    = ""
  applComp                = ""
  orgComp                 = ""
  defaultPrEmpl           = ""
  defaultHrEmpl           = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
  @dtw_replace(workURL, "@@fromD2w", "@dtw_rurlescseq(fromD2w)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.prCompany.value =="" ||
                      document.Chg.prFacility.value =="")
                      {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.prCompany, 2, 0) &&
                      editNum(document.Chg.prFacility, 4, 0) &&
                      editNum(document.Chg.prEmployee, 5, 0) &&
                      editNum(document.Chg.hrEmployee, 9, 0) &&
                      editNum(document.Chg.applSeq, 4, 0) &&
                      editNum(document.Chg.orgLevel, 1, 0) &&
                      editNum(document.Chg.orgSeq, 5, 0) &&
                      editdate(document.Chg.applDate))
                  return true;
              }
	       %INCLUDE "numedit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ADDEMPLOYEE")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %INCLUDE "AddRecordSQL.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      @AddEmployee_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) AddEmployee_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"		

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=A&amp;orgComp=@dtw_rurlescseq(orgComp)&amp;applComp=@dtw_rurlescseq(applComp)&amp;defaultPrEmpl=@dtw_rurlescseq(defaultPrEmpl)&amp;defaultHrEmpl=@dtw_rurlescseq(defaultHrEmpl)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "")
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@comp", "prCompany")      @dtw_assign(Err_EMCOMP, fieldValue)
                      @DecatErr_Field("@@facl", "prFacility")     @dtw_assign(Err_EMFACL, fieldValue)
                      @DecatErr_Field("@@empl", "prEmployee")     @dtw_assign(Err_EMEMPL, fieldValue)
                      @DecatErr_Field("@@pemp", "hrEmployee")     @dtw_assign(Err_EMPEMP, fieldValue)
                      @DecatErr_Field("@@apdt", "applDate")       @dtw_assign(Err_APDT, fieldValue)
                      @DecatErr_Field("@@apsq", "applSeq")        @dtw_assign(Err_APSQ, fieldValue)
                      @DecatErr_Field("@@levl", "orgLevel")       @dtw_assign(Err_LEVL, fieldValue)
                      @DecatErr_Field("@@oseq", "orgSeq")         @dtw_assign(Err_OSEQ, fieldValue)

                      @Decat_Field("@@comp")    @dtw_assign(V_EMCOMP, fieldValue)
                      @Decat_Field("@@facl")    @dtw_assign(V_EMFACL, fieldValue)
                      @Decat_Field("@@empl")    @dtw_assign(V_EMEMPL, fieldValue)
                      @Decat_Field("@@pemp")    @dtw_assign(V_EMPEMP, fieldValue)
                      @Decat_Field("@@apco")    @dtw_assign(applComp, fieldValue)
                      @Decat_Field("@@apdt")    @dtw_assign(applDate, fieldValue)
                      @Decat_Field("@@apsq")    @dtw_assign(applSeq, fieldValue)
                      @Decat_Field("@@orco")    @dtw_assign(orgComp, fieldValue)
                      @Decat_Field("@@levl")    @dtw_assign(orgLevel, fieldValue)
                      @Decat_Field("@@oseq")    @dtw_assign(orgSeq, fieldValue)

                      @dtw_assign(errFound, "")

                  %else
                      @dtw_assign(focusField, "prCompany")
                      @dtw_assign(defaultPrEmpl, "")
                      @dtw_assign(defaultHrEmpl, "")
                  %endif

                  %if(V_EMCOMP != "")
                      @RtvFldDesc("CFCOMP=$(V_EMCOMP) and CFFACL=$(V_EMFACL)", "HRCOFC", "CFNAME", fieldDesc)
                  %else
                      @dtw_assign(fieldDesc, "")
                  %endif
                  @SetTextOvr(Err_EMCOMP)
                  <tr><td class="dsphdr"><span $(textOvr)>Company/Facility</span></td>
                      <td class="inputnmbr"><input name="prCompany" value="$(V_EMCOMP)" type="text" size="4" maxlength="2"> / <input name="prFacility" value="$(V_EMFACL)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(cGIPath)CoFacSearchHr.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldCo=prCompany&amp;fldFac=prFacility&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="coFacDesc" value="$(fieldDesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_EMCOMP)

                  @SetTextOvr(Err_EMEMPL)
                  <tr><td class="dsphdr"><span $(textOvr)>Employee Number</span></td>
                      <td class="inputnmbr"><input name="prEmployee" type="text" value="$(defaultPrEmpl)" size="5" maxlength="5"></td>
                  </tr>
                  @DspErrMsg(Err_EMEMPL)

                  @SetTextOvr(Err_EMPEMP)
                  <tr><td class="dsphdr"><span $(textOvr)>H/R Employee Number</span></td>
                      <td class="inputnmbr"><input name="hrEmployee" type="text" value="$(defaultHrEmpl)" size="9" maxlength="9"></td>
                  </tr>
                  @DspErrMsg(Err_EMPEMP)

                  @dtw_assign(applName, "")
                  @SetTextOvr(Err_APDT)

                  %if(applDate != "")
                      @dtw_assign(applDateCYMD, applDate)
                      @DateToCYMD(applDateCYMD)
                      @RtvFldDesc("APCOMP=$(applComp) and APAPDT=$(applDateCYMD) and APAPSQ=$(applSeq) ", "PEAPPL", "APLNAM", applLastName)
                      @RtvFldDesc("APCOMP=$(applComp) and APAPDT=$(applDateCYMD) and APAPSQ=$(applSeq) ", "PEAPPL", "APFNAM", applFirstName)
                      @RtvFldDesc("APCOMP=$(applComp) and APAPDT=$(applDateCYMD) and APAPSQ=$(applSeq) ", "PEAPPL", "APMIDI", applMiddle)
                      @RtvFldDesc("APCOMP=$(applComp) and APAPDT=$(applDateCYMD) and APAPSQ=$(applSeq) ", "PEAPPL", "APRNAM", applReportName)
                      @Format_EmplName(applFirstName, applLastName, applMiddle, applReportName, "", "D", applName)
                  %endif
                  <tr><td class="dsphdr"><span $(textOvr)>Applicant Date/Sequence</span></td>
                      <td class="inputnmbr"><input name="applDate" value="$(applDate)" type="text" size="6" maxlength="6"> / <input name="applSeq" value="$(applSeq)" type="text" size="4" maxlength="4"> <input name="applComp" value="$(applComp)" type="hidden" size="2" maxlength="2">  <a href="$(homeURL)$(cGIPath)applicantSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldDate=applDate&amp;fldSeq=applSeq&amp;fldDesc=applDesc&amp;fldComp=applComp" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="applDesc" value="$(applName)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_APDT)

                  @dtw_assign(posTitle, "")
                  @SetTextOvr(Err_LEVL)
                  %if(orgLevel != "")
                      @RtvFldDesc("ORCOMP=$(orgComp) and ORLEVL=$(orgLevel) and ORSEQ=$(orgSeq) ", "PEORG", "ORTITL", posTitle)
                  %endif
                  <tr><td class="dsphdr"><span $(textOvr)>Company Position Level/Sequence</span></td>
                      <td class="inputnmbr"><input name="orgLevel" value="$(orgLevel)" type="text" size="1" maxlength="1"> / <input name="orgSeq" value="$(orgSeq)" type="text" size="5" maxlength="5"> <input name="orgComp" value="$(orgComp)" type="hidden" size="2" maxlength="2"> <a href="$(homeURL)$(cGIPath)OpenPositionSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldLevel=orgLevel&amp;fldSeq=orgSeq&amp;fldDesc=positionDesc&amp;fldComp=orgComp" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="positionDesc" value="$(posTitle)"  type="text" size="20" maxlength="20"></td>
                  </tr>
                  @DspErrMsg(Err_LEVL)
              %}
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>

      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar,
                                        INOUT CHAR(5)     defaultPrEmpl,
                                        INOUT CHAR(9)     defaultHrEmpl)
{%EXEC {HHREMN_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (sec_01 == "N")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  %if (errFound == "")
      @RtvFldDesc("CFCOMP=$(prCompany) and CFFACL=$(prFacility)", "HRCOFC", "CHAR(CFHRXR)", hrCompany)
  %endif
  %if (orgComp == "")
      @dtw_assign(orgComp,hrCompany)
  %endif

  @dtw_assign(prCompany,@dtw_rstrip(prCompany))
  @dtw_assign(prFacility,@dtw_rstrip(prFacility))
  @dtw_assign(prEmployee,@dtw_rstrip(prEmployee))
  @dtw_assign(hrCompany,@dtw_rstrip(hrCompany))
  @dtw_assign(hrEmployee,@dtw_rstrip(hrEmployee))
  @dtw_assign(applComp,@dtw_rstrip(applComp))
  @dtw_assign(applDate,@dtw_rstrip(applDate))
  @dtw_assign(applSeq,@dtw_rstrip(applSeq))
  @dtw_assign(orgComp,@dtw_rstrip(orgComp))
  @dtw_assign(orgLevel,@dtw_rstrip(orgLevel))
  @dtw_assign(orgSeq,@dtw_rstrip(orgSeq))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@comp", prCompany)
  @Concat_Field("@@facl", prFacility)
  @Concat_Field("@@empl", prEmployee)
  @Concat_Field("@@pecp", hrCompany)
  @Concat_Field("@@pemp", hrEmployee)
  @Concat_Field("@@apco", applComp)
  @Concat_Field("@@apdt", applDate)
  @Concat_Field("@@apsq", applSeq)
  @Concat_Field("@@orco", orgComp)
  @Concat_Field("@@levl", orgLevel)
  @Concat_Field("@@oseq", orgSeq)

  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar, defaultPrEmpl, defaultHrEmpl)

  %if (errFound == "")
      %if (prEmployee == "" || prEmployee == "0")
          @dtw_assign(prEmployee, $(defaultPrEmpl))
      %endif
      %if (hrEmployee == "" || hrEmployee == "0")
          @dtw_assign(hrEmployee, $(defaultHrEmpl))
      %endif
      @Format_ConfMsg_Desc(maintenanceCode, "Default Rows Have Been Added", "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)EmplMaintainDem.d2w/REPORT$(d2wVarBase)&amp;prCompany=@dtw_rurlescseq(prCompany)&amp;prFacility=@dtw_rurlescseq(prFacility)&amp;prEmployee=@dtw_rurlescseq(prEmployee)&amp;hrCompany=@dtw_rurlescseq(hrCompany)&amp;hrEmployee=@dtw_rurlescseq(hrEmployee)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;defaultPrEmpl=@dtw_rurlescseq(defaultPrEmpl)&amp;defaultHrEmpl=@dtw_rurlescseq(defaultHrEmpl)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}