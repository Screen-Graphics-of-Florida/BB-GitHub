%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"

%Define {
  page_title              = "Company/Facility Consolidation"
  d2wName                 = "GLCoFacConsolidation.d2w"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  DTW_PAD_PGM_PARMS       = "YES"
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64) profileHandle,
                                   CHAR(2)   dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "headcmt.icl"
          </head>

          <body $(bodyTagAttr) onLoad="window.focus()" onBlur="window.close()">
              <!-- Start Of Banner Code -->
              %INCLUDE "$(inquiryBanner)"
              <!-- End Of Banner Code -->

              @dtw_assign(displayCloseIcon, "Y")
              %INCLUDE "PageTitle.icl"

              <table $(contentTable)>
                  @Format_CoFac("$(companyNumber)", "$(facilityNumber)", "", F_CoFac)
                  @RtvFldDesc("CFCO#=$(companyNumber) and CFFAC#=$(facilityNumber)", "HDCFAC", "CFCFNM", V_CFCFNM)
                  @Format_Header("Company/Facility", $(V_CFCFNM), $(F_CoFac))
              </table>
              $(inquiryhrTagAttr)

              <table $(contentTable)>
                  <tr><th class="colhdr"> Co/Fac</th>
                      <th class="colhdr"> Name</th>
                      <th class="colhdr"> Date<br>Deactivated</th>
                  </tr>

                  %ROW{
                      @Format_Date(V_CCDTDE, "D", F_CCDTDE)
                      @Default_Zero(V_CCFCO#)
                      @Default_Zero(V_CCFFAC)
                      @RtvFldDesc("DIGITS(CFCO#)='$(V_CCFCO#)' and DIGITS(CFFAC#)='$(V_CCFFAC)'", "HDCFAC", "CFCFNM", V_CFCFNM)
                      @Format_CoFac("$(V_CCFCO#)", "$(V_CCFFAC)", "", F_CoFac)
                      %if (V_CFCFNM=="")
                          @dtw_assign(V_CFCFNM, "Wildcard")
                      %endif

                      <tr><td class="colalph">$(F_CoFac)</td>
                          <td class="colalph">$(V_CFCFNM)</td>
                          <td class="coldate">$(F_CCDTDE)</td>
                      </tr>
                  %}
              </table>
              $(inquiryhrTagAttr)
              <!-- Start Of Trailer Code -->
              %INCLUDE "$(inquiryTrailer)"
              %INCLUDE "CloseWindow.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "SELECT * ", stmtSQL)
  @dtw_concat(fileSQL, " GLCFCN ", fileSQL)
  @dtw_concat(selectSQL, " CCTCO#=$(companyNumber) and CCTFAC=$(facilityNumber) ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " order by CCTCO#,CCTFAC,CCFCO#,CCFFAC ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_Query(profileHandle, dataBaseID, stmtSQL)
%}