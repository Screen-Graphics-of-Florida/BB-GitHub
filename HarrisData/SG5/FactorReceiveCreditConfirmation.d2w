%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "$(procDesc)"
  d2wVarBase              = "$(genericVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(alertMessage, "")
  @RtvFldDesc("CCDATA>' '", "HDFFCC", "CHAR(COUNT(*))", crConfCnt)
  %if (crConfCnt == "0")
      @Rtv_Error_Desc("HAR0093", alertMessage)
  %endif
  %if (alertMessage != "")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)FactorProcess.d2w/REPORT$(d2wVarBase)&amp;alertMessage=@dtw_rurlescseq(alertMessage)">
  %endif
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)SubmitJob.d2w/REPORT$(d2wVarBase)&amp;submitPageTitle=@dtw_rurlescseq(submitPageTitle)&amp;submitCallProgram=@dtw_rurlescseq(submitCallProgram)&amp;submitEnvProgram=@dtw_rurlescseq(submitEnvProgram)&amp;submitEnvPrinter=@dtw_rurlescseq(submitEnvPrinter)&amp;apid=@dtw_rurlescseq(apid)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}
