%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Kanban List"
  d2wName                 = "KanbanList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;PDRL=@dtw_rurlescseq(PDRL)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if  (editNum(document.Chg.fromPlantNumber, 3, 0) &&
                      editNum(document.Chg.toPlantNumber, 3, 0) &&
                      editNum(document.Chg.fromAnalystNumber, 7, 0) &&
                      editNum(document.Chg.toAnalystNumber, 7, 0) &&
                      editNum(document.Chg.fromVendorNumber, 7, 0) &&
                      editNum(document.Chg.toVendorNumber, 7, 0) &&
                      editdate(document.Chg.fromLastActivity) &&
                      editdate(document.Chg.toLastActivity) &&
                      editFromToAll(document.Chg.fromPlantNumber, document.Chg.toPlantNumber, document.Chg.allPlantNumber, 3) &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromAnalystNumber, document.Chg.toAnalystNumber, document.Chg.allAnalystNumber, 7) &&
                      editFromToAll(document.Chg.fromVendorNumber, document.Chg.toVendorNumber, document.Chg.allVendorNumber, 7) &&
                      editFromToAll(document.Chg.fromKanbanPolicyCode, document.Chg.toKanbanPolicyCode, document.Chg.allKanbanPolicyCode, "A") &&
                      editFromToAll(document.Chg.fromLastActivity, document.Chg.toLastActivity, document.Chg.allLastActivity, "D"))
                      return true;

              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "KANBANLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromPlantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb") @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@prcm", "printComments")     @dtw_assign(Err_N1PRCM,  fieldValue)
                                  @DecatErr_Field("@@iadj", "containerAdjustmentsOnly")     @dtw_assign(Err_N1IADJ,  fieldValue)
                                  @DecatErr_Field("@@fplt", "fromPlantNumber")        @dtw_assign(Err_N1FPLT,  fieldValue)
                                  @DecatErr_Field("@@tplt", "toPlantNumber")        @dtw_assign(Err_N1TPLT,  fieldValue)
                                  @DecatErr_Field("@@aplt", "allPlantNumber")        @dtw_assign(Err_N1APLT,  fieldValue)
                                  @DecatErr_Field("@@fitm", "fromItemNumber")        @dtw_assign(Err_N1FITM,  fieldValue)
                                  @DecatErr_Field("@@titm", "toItemNumber")        @dtw_assign(Err_N1TITM,  fieldValue)
                                  @DecatErr_Field("@@aitm", "allItemNumber")        @dtw_assign(Err_N1AITM,  fieldValue)
                                  @DecatErr_Field("@@fbac", "fromAnalystNumber")        @dtw_assign(Err_N1FBAC,  fieldValue)
                                  @DecatErr_Field("@@tbac", "toAnalystNumber")        @dtw_assign(Err_N1TBAC,  fieldValue)
                                  @DecatErr_Field("@@abac", "allAnalystNumber")        @dtw_assign(Err_N1ABAC,  fieldValue)
                                  @DecatErr_Field("@@fvnd", "fromVendorNumber")        @dtw_assign(Err_N1FVND,  fieldValue)
                                  @DecatErr_Field("@@tvnd", "toVendorNumber")        @dtw_assign(Err_N1TVND,  fieldValue)
                                  @DecatErr_Field("@@avnd", "allVendorNumber")        @dtw_assign(Err_N1AVND,  fieldValue)
                                  @DecatErr_Field("@@fkpc", "fromKanbanPolicyCode")        @dtw_assign(Err_N1FKPC,  fieldValue)
                                  @DecatErr_Field("@@tkpc", "toKanbanPolicyCode")        @dtw_assign(Err_N1TKPC,  fieldValue)
                                  @DecatErr_Field("@@akpc", "allKanbanPolicyCode")        @dtw_assign(Err_N1AKPC,  fieldValue)
                                  @DecatErr_Field("@@fdat", "fromLastActivity")      @dtw_assign(Err_N1FDAT,  fieldValue)
                                  @DecatErr_Field("@@tdat", "toLastActivity")        @dtw_assign(Err_N1TDAT,  fieldValue)
                                  @DecatErr_Field("@@adat", "allLastActivity")       @dtw_assign(Err_N1ADAT,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@prcm")  @dtw_assign(V_N1PRCM,  fieldValue)
                                  @Decat_Field("@@iadj")  @dtw_assign(V_N1IADJ,  fieldValue)
                                  @Decat_Field("@@fplt")  @dtw_assign(V_N1FPLT,  fieldValue)
                                  @Decat_Field("@@tplt")  @dtw_assign(V_N1TPLT,  fieldValue)
                                  @Decat_Field("@@aplt")  @dtw_assign(V_N1APLT,  fieldValue)
                                  @Decat_Field("@@fitm")  @dtw_assign(V_N1FITM,  fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N1TITM,  fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N1AITM,  fieldValue)
                                  @Decat_Field("@@fbac")  @dtw_assign(V_N1FBAC,  fieldValue)
                                  @Decat_Field("@@tbac")  @dtw_assign(V_N1TBAC,  fieldValue)
                                  @Decat_Field("@@abac")  @dtw_assign(V_N1ABAC,  fieldValue)
                                  @Decat_Field("@@fvnd")  @dtw_assign(V_N1FVND,  fieldValue)
                                  @Decat_Field("@@tvnd")  @dtw_assign(V_N1TVND,  fieldValue)
                                  @Decat_Field("@@avnd")  @dtw_assign(V_N1AVND,  fieldValue)
                                  @Decat_Field("@@fkpc")  @dtw_assign(V_N1FKPC,  fieldValue)
                                  @Decat_Field("@@tkpc")  @dtw_assign(V_N1TKPC,  fieldValue)
                                  @Decat_Field("@@akpc")  @dtw_assign(V_N1AKPC,  fieldValue)
                                  @Decat_Field("@@fdat")  @dtw_assign(V_N1FDAT,  fieldValue)
                                  @Decat_Field("@@tdat")  @dtw_assign(V_N1TDAT,  fieldValue)
                                  @Decat_Field("@@adat")  @dtw_assign(V_N1ADAT,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1PRCM == "02")
                                      @dtw_assign(printCommentsNo, "")
                                      @dtw_assign(printCommentsYes, "CHECKED")
                                  %else
                                      @dtw_assign(printCommentsNo, "CHECKED")
                                      @dtw_assign(printCommentsYes, "")
                                  %endif

                                  %if (V_N1IADJ == "02")
                                      @dtw_assign(containerAdjustmentsOnlyNo, "")
                                      @dtw_assign(containerAdjustmentsOnlyYes, "CHECKED")
                                  %else
                                      @dtw_assign(containerAdjustmentsOnlyNo, "CHECKED")
                                      @dtw_assign(containerAdjustmentsOnlyYes, "")
                                  %endif

                                  %if (V_N1APLT == "ALL")
                                      @dtw_assign(checkedAllPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllPlantNumber, "")
                                  %endif
                                  %if (V_N1AITM == "ALL")
                                      @dtw_assign(checkedAllItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllItemNumber, "")
                                  %endif
                                  %if (V_N1ABAC == "ALL")
                                      @dtw_assign(checkedAllAnalystNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllAnalystNumber, "")
                                  %endif
                                  %if (V_N1AVND == "ALL")
                                      @dtw_assign(checkedAllVendorNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllVendorNumber, "")
                                  %endif
                                  %if (V_N1AKPC == "ALL")
                                      @dtw_assign(checkedAllKanbanPolicyCode, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllKanbanPolicyCode, "")
                                  %endif
                                  %if (V_N1ADAT == "ALL")
                                      @dtw_assign(checkedAllLastActivity, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllLastActivity, "")
                                  %endif
                              %else
                                  @dtw_assign(printCommentsNo, "CHECKED")
                                  @dtw_assign(printCommentsYes, "")
                                  @dtw_assign(containerAdjustmentsOnlyNo, "CHECKED")
                                  @dtw_assign(containerAdjustmentsOnlyYes, "")
                                  @RtvDftPlant(plantNumber, plantName)
                                  %if (plantNumber == "0")
                                      @dtw_assign(checkedAllPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(V_N1FPLT, plantNumber)
                                      @dtw_assign(V_N1TPLT, plantNumber)
                                      @dtw_assign(checkedAllPlantNumber, "")
                                  %endif
                                  @dtw_assign(checkedAllItemNumber, "CHECKED")
                                  @dtw_assign(checkedAllAnalystNumber, "CHECKED")
                                  @dtw_assign(checkedAllVendorNumber, "CHECKED")
                                  @dtw_assign(checkedAllKanbanPolicyCode, "CHECKED")
                                  @dtw_assign(checkedAllLastActivity, "CHECKED")
                              %endif

                              @SetTextOvr(Err_N1PRCM)
                              <tr><td  class="dsphdr"><span $(textOvr)>Print Comments</span></td>
                                  <td class="inputnmbr"><input name="printComments" type="radio" VALUE='01' $(printCommentsNo)>No</td>
                              </tr>
                              @DspErrMsg(Err_N1PRCM)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="printComments" type="radio" VALUE='02' $(printCommentsYes)>Yes</td>
                              </tr>

                              @SetTextOvr(Err_N1IADJ)
                              <tr><td class="dsphdr"><span $(textOvr)>Container Adjustments Only</span></td>
                                  <td class="inputnmbr"><input name="containerAdjustmentsOnly" type="radio" VALUE='01' $(containerAdjustmentsOnlyNo)>No</td>
                              </tr>
                              @DspErrMsg(Err_N1IADJ)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="containerAdjustmentsOnly" type="radio" VALUE='02' $(containerAdjustmentsOnlyYes)>Yes</td>
                              </tr>
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_N1FPLT)
                              %if (textOvr == "") @SetTextOvr(Err_N1TPLT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1APLT) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                      <td class="inputnmbr"><input name="fromPlantNumber" value="$(V_N1FPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromPlantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toPlantNumber" value="$(V_N1TPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toPlantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName" type="hidden"></td>
                                  <td class="inputalph"><input name="allPlantNumber" value='ALL' $(checkedAllPlantNumber) type="checkbox" onClick="if (this.checked) this.form.fromPlantNumber.value='', this.form.toPlantNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FPLT)
                              @DspErrMsg(Err_N1TPLT)
                              @DspErrMsg(Err_N1APLT)

                              @SetTextOvr(Err_N1FITM)
                              %if (textOvr == "") @SetTextOvr(Err_N1TITM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AITM) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N1FITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N1TITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedAllItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FITM)
                              @DspErrMsg(Err_N1TITM)
                              @DspErrMsg(Err_N1AITM)

                              @SetTextOvr(Err_N1FBAC)
                              %if (textOvr == "") @SetTextOvr(Err_N1TBAC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ABAC) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Analyst Number</span></td>
                                  <td class="inputnmbr"><input name="fromAnalystNumber" value="$(V_N1FBAC)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)BuyerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromAnalystNumber&amp;fldDesc=analystName&amp;buyerAnalyst=Analyst" onclick="$(searchWinVar)"> $(searchImage) </a><input name="analystName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toAnalystNumber" value="$(V_N1TBAC)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)BuyerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toAnalystNumber&amp;fldDesc=analystName&amp;buyerAnalyst=Analyst" onclick="$(searchWinVar)"> $(searchImage) </a><input name="analystName" type="hidden"></td>
                                  <td class="inputalph"><input name="allAnalystNumber" value='ALL' $(checkedAllAnalystNumber) type="checkbox" onClick="if (this.checked) this.form.fromAnalystNumber.value='', this.form.toAnalystNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FBAC)
                              @DspErrMsg(Err_N1TBAC)
                              @DspErrMsg(Err_N1ABAC)

                              @SetTextOvr(Err_N1FVND)
                              %if (textOvr == "") @SetTextOvr(Err_N1TVND) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AVND) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Vendor Number</span></td>
                                  <td class="inputnmbr"><input name="fromVendorNumber" value="$(V_N1FVND)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="vendorName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toVendorNumber" value="$(V_N1TVND)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="vendorName" type="hidden"></td>
                                  <td class="inputalph"><input name="allVendorNumber" value='ALL' $(checkedAllVendorNumber) type="checkbox" onClick="if (this.checked) this.form.fromVendorNumber.value='', this.form.toVendorNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FVND)
                              @DspErrMsg(Err_N1TVND)
                              @DspErrMsg(Err_N1AVND)

                              @SetTextOvr(Err_N1FKPC)
                              %if (textOvr == "") @SetTextOvr(Err_N1TKPC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AKPC) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Kanban Policy Code</span></td>
                                  <td class="inputalph"><input name="fromKanbanPolicyCode" value="$(V_N1FKPC)" type="text" size="2" maxlength="1"></td>
                                  <td class="inputalph"><input name="toKanbanPolicyCode" value="$(V_N1TKPC)" type="text" size="2" maxlength="1"></td>
                                  <td class="inputalph"><input name="allKanbanPolicyCode" value='ALL' $(checkedAllKanbanPolicyCode) type="checkbox" onClick="if (this.checked) this.form.fromKanbanPolicyCode.value='', this.form.toKanbanPolicyCode.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FKPC)
                              @DspErrMsg(Err_N1TKPC)
                              @DspErrMsg(Err_N1AKPC)

                              @SetTextOvr(Err_N1FDAT)
                              %if (textOvr == "") @SetTextOvr(Err_N1TDAT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ADAT) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Last Activity</span></td>
                                  <td class="inputnmbr"><input name="fromLastActivity" value="$(V_N1FDAT)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromLastActivity');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toLastActivity" value="$(V_N1TDAT)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toLastActivity');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allLastActivity" value='ALL' $(checkedAllLastActivity) type="checkbox" onClick="if (this.checked) this.form.fromLastActivity.value='', this.form.toLastActivity.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FDAT)
                              @DspErrMsg(Err_N1TDAT)
                              @DspErrMsg(Err_N1ADAT)

                          </table>

                          @dtw_assign(envProgram, "HSIKBL")
                          @dtw_assign(envPrinter, "HSIKBLPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSIKBS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allPlantNumber)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(allAnalystNumber)
  @dtw_mUPPERCASE(allVendorNumber)
  @dtw_mUPPERCASE(fromKanbanPolicyCode)
  @dtw_mUPPERCASE(toKanbanPolicyCode)
  @dtw_mUPPERCASE(allKanbanPolicyCode)
  @dtw_mUPPERCASE(allLastActivity)

  @dtw_assign(fromPlantNumber,@dtw_rstrip(fromPlantNumber))
  @dtw_assign(toPlantNumber,@dtw_rstrip(toPlantNumber))
  @dtw_assign(fromAnalystNumber,@dtw_rstrip(fromAnalystNumber))
  @dtw_assign(toAnalystNumber,@dtw_rstrip(toAnalystNumber))
  @dtw_assign(fromVendorNumber,@dtw_rstrip(fromVendorNumber))
  @dtw_assign(toVendorNumber,@dtw_rstrip(toVendorNumber))
  @dtw_assign(fromLastActivity,@dtw_rstrip(fromLastActivity))
  @dtw_assign(toLastActivity,@dtw_rstrip(toLastActivity))


  %if (allPlantNumber != "ALL")
      @dtw_assign(allPlantNumber, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allAnalystNumber != "ALL")
      @dtw_assign(allAnalystNumber, "")
  %endif
  %if (allVendorNumber != "ALL")
      @dtw_assign(allVendorNumber, "")
  %endif
  %if (allKanbanPolicyCode != "ALL")
      @dtw_assign(allKanbanPolicyCode, "")
  %endif
  %if (allLastActivity != "ALL")
      @dtw_assign(allLastActivity, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@prcm", printComments)
  @Concat_Field("@@iadj", containerAdjustmentsOnly)
  @Concat_Field("@@fplt", fromPlantNumber)
  @Concat_Field("@@tplt", toPlantNumber)
  @Concat_Field("@@aplt", allPlantNumber)
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@fbac", fromAnalystNumber)
  @Concat_Field("@@tbac", toAnalystNumber)
  @Concat_Field("@@abac", allAnalystNumber)
  @Concat_Field("@@fvnd", fromVendorNumber)
  @Concat_Field("@@tvnd", toVendorNumber)
  @Concat_Field("@@avnd", allVendorNumber)
  @Concat_Field("@@fkpc", fromKanbanPolicyCode)
  @Concat_Field("@@tkpc", toKanbanPolicyCode)
  @Concat_Field("@@akpc", allKanbanPolicyCode)
  @Concat_Field("@@fdat", fromLastActivity)
  @Concat_Field("@@tdat", toLastActivity)
  @Concat_Field("@@adat", allLastActivity)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}