%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title 	           = "Benefits"
  d2wName                 = "HRBenefits.d2w"
  d2wVarBase              = "$(genericVarBase)$(hrCoFacVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(d2wName)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPECVU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "HrCoFacURL.icl"
  @dtw_replace(workURL, "@@fromD2w", "@dtw_rurlescseq(fromD2w)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "HRBENEFITS")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      @dtw_assign(uv_CompanyName, "CVCOMP")
                      @dtw_assign(uv_FacilityName, "CVFACL")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select CVCOMP, CVFACL, CVCOVR, CVPLAN, CVDESC, CVDESCU, CCDESC, CVCARR, CVPOLC, CVNPI, CVEFFD, CVEXPD, CVADMN, CVDAGE, CVSAGE, CVDEDN, CVTYPE, CVDDCT, CVCOP1, CVCOP2, CVCOP3, CVPCKI, CVPCKF, CVAMTE, CVAMTD, CVELGD, CVELGM, CVELGH, CVELGA, CVURLI, CVIMG, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(CCDESC) as CCDESCU", stmtSQL)
                      @dtw_concat(fileSQL, " CBCOVR inner join CBCODE on CVPLAN=CCCODE ", fileSQL)
                      @dtw_concat(selectSQL, " CVCOMP=$(prCompany) and CVFACL=$(prFacility)", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Benefit_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Benefit_Query (IN CHAR(64)    profileHandle,
                                     CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count != "1")
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/report") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Return To Company/Facility">$(portalHome)</a>
                          %endif
                          %if (sec_01 == "Y")
                              <a href="$(homeURL)$(cGIPath)HRBenefitsMaintain.d2w/HRBENEFITS$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>

              @RetHrCompNam(profileHandle, dataBaseID, prCompany, prFacility, coFacName)
              <tr><td><h2>$(coFacName)</h2></td></tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"
          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Benefit Description</th></tr>
                      <tr><td><input type="text" class="inputalph" name="srchBenefit" size="15" maxlength="15">
                              <input type="hidden" name="operBenefit" value="LIKE">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchBenefit.focus();
                  </script>
              </form>

              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              <tr>
                  %if (formatToPrint != "Y" && ((sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y") || V_CVURLI != ""))
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("CVCOVR", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BenefitCode" title="Sequence By Benefit Code, Plan Code">Benefit<br>Code</a></th>
                  @OrderBy_Sort("CVDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BenefitDesc" title="Sequence By Benefit Description, Plan Description">Benefit Description</a></th>
                  @OrderBy_Sort("CVPLAN", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlanCode" title="Sequence By Plan Code, Benefit Code">Plan<br>Code</a></th>
                  @OrderBy_Sort("CCDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlanDesc" title="Sequence By Plan Description, Benefit Description"> Plan Description</a></th>
              </tr>
          %INCLUDE "NoRecordsFound.icl"
      %endif

              %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;benefitCode=@dtw_rurlescseq(V_CVCOVR)&amp;benefitDesc=@dtw_rurlescseq(V_CVDESC)&amp;planCode=@dtw_rurlescseq(V_CVPLAN)&amp;planDesc=@dtw_rurlescseq(V_CCDESC)")
                  @RtvFldDesc("BCCOMP=$(V_CVCOMP) AND BCFACL=$(V_CVFACL) AND BCCOVR='$(V_CVCOVR)' AND BCPLAN='$(V_CVPLAN)' ", "HRBCMN", "char(count(*))", cmtCount)
                  @RtvFldDesc("CECOMP=$(V_CVCOMP) AND CEFACL=$(V_CVFACL) AND CECOVR='$(V_CVCOVR)' AND CEPLAN='$(V_CVPLAN)' ", "CBCOVE", "char(count(*))", extensionCount)

                  %if (sql_Record_Count == "1")
                      @Save_WebReg(webRegCurFile, profileHandle, d2wName, "", orderBy, orderByDisplay, "")
                      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)HRBenefitSelect.d2w/REPORT$(maintainVar)">
                  %else
                      @dtw_assign(imageExists, "")
                      %if (V_CVIMG != "")
                          @dtw_assign(fileImage, "$(V_CVIMG)")
                          @dtwf_exists(fileImage, imageExists)
                      %endif
                      %INCLUDE "SetRowClass.icl"
                      @Format_Confirm_Desc($(V_CVDESC), $(V_CVCOVR), $(V_CCDESC), $(V_CVPLAN), "", "", confirmDesc)
                      <tr class="$(rowClass)">
                          %if (formatToPrint != "Y" && ((sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y") || V_CVURLI != ""))
                              <td class="opticon">
                                  %if (sec_02 == "Y" || sec_03 == "Y")
                                      <a href="$(homeURL)$(cGIPath)HRBenefitsMaintain.d2w/HRBENEFITS$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                                  %endif
                                  %if (sec_04 == "Y")
                                      <a href="$(homeURL)$(cGIPath)HRBenefitsMaintain.d2w/HRBENEFITS$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                                  %endif
                                  %if (sec_03 == "Y")
                                      <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)HRBenefitsMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                                  %endif
        		                  %if (cmtCount > "0")
                                      <a href="$(homeURL)$(cGIPath)HRBenefitsMaintainComments.d2w/MAINTAIN$(maintainVar)"onclick="$(commentWinVar)">$(commentExistImage)</a>
                                  %else
                                      <a href="$(homeURL)$(cGIPath)HRBenefitsMaintainComments.d2w/MAINTAIN$(maintainVar)"onclick="$(commentWinVar)">$(commentImage)</a>
                                  %endif
                                  %if (sec_02 == "Y" || sec_03 == "Y")
                                      %if (V_CVTYPE == "W2HC")
                                          %if (extensionCount > "0")
                                              <a href="$(homeURL)$(cGIPath)HRBenefitsExtension.d2w/REPORT$(maintainVar)&amp;maintenanceCode=C">$(changeImageMed)</a>
                                          %else
                                              <a href="$(homeURL)$(cGIPath)HRBenefitsExtension.d2w/REPORT$(maintainVar)&amp;maintenanceCode=C">$(addMoreImage)</a>
                                          %endif
                                      %endif
                                  %endif
                                  %if (V_CVURLI != "")
                                      <a href="$(V_CVURLI)">
                                          %if (imageExists == "Y")
                                              <img src="$(homeURL)$(fileImage)">
                                          %else
                                              $(planDocImage)
                                          %endif
                                      </a>
                                  %endif
                              </td>
                          %endif
                          <td class="colcode">$(V_CVCOVR)</td>
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)HRBenefitSelect.d2w/REPORT$(maintainVar)" title="View Benefit">$(V_CVDESC)</a></td>
                          <td class="colcode">$(V_CVPLAN)</td>
                          <td class="colalph">$(V_CCDESC)</td>
                      </tr>
                  %endif
              %}
          </table>
          %if (sql_Record_Count != "1")
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  @dtw_assign(uv_CompanyName, "CVCOMP")
  @dtw_assign(uv_FacilityName, "CVFACL")
  %INCLUDE "userview.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select CVCOMP, CVFACL, CVCOVR, CVPLAN, CVDESC, CVDESCU, CCDESC, CVCARR, CVPOLC, CVNPI, CVEFFD, CVEXPD, CVADMN, CVDAGE, CVSAGE, CVDEDN, CVDDCT, CVCOP1, CVCOP2, CVCOP3, CVPCKI, CVPCKF, CVAMTE, CVAMTD, CVELGD, CVELGM, CVELGH, CVELGA, CVURLI, CVIMG, ", stmtSQL)
  @dtw_concat(stmtSQL, " upper(CCDESC) as CCDESCU", stmtSQL)
  @dtw_concat(fileSQL, " CBCOVR inner join CBCODE on CVPLAN=CCCODE ", fileSQL)
  @dtw_concat(selectSQL, " CVCOMP=$(prCompany) and CVFACL=$(prFacility)", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @Benefit_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) Benefit_XMLQuery (IN CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("BenefitList")
          %ROW{
              @RtvFldDesc("CRCODE='$(V_CVCARR)'", "CBCARR", "CRNAME", providerDesc)
              @DateFromCYMD(V_CVEFFD)
              @DateFromCYMD(V_CVEXPD)

              @XMLIDTag(@DTW_rCONCAT(prCompany, @DTW_rCONCAT("/", @DTW_rCONCAT(prFacility, @DTW_rCONCAT("/", @DTW_rCONCAT(V_CVCOVR, @DTW_rCONCAT("/", V_CVPLAN)))))), "Benefit ID")
                  @XMLTag(prCompany, "CompanyNumber")
                  @XMLTag(prFacility, "FacilityNumber")
                  @XMLTag(V_CVCOVR, "BenefitCode")
                  @XMLTag(V_CVDESC, "BenefitDescription")
                  @XMLTag(V_CVPLAN,  "PlanCode")
                  @XMLTag(V_CCDESC,  "PlanDescription")
                  @XMLTag(providerDesc,  "BenefitProvider")
                  @XMLTag(V_CVPOLC, "PolicyNumber")
                  @XMLTag(V_CVNPI, "NationalProviderID")
                  @XMLTag(V_CVEFFD,  "EffectiveDate")
                  @XMLTag(V_CVEXPD, "ExpirationDate")
                  @XMLTag(V_CVADMN, "PlanAdministrator")
                  @XMLTag(V_CVDAGE, "DependentAgeLimit")
                  @XMLTag(V_CVSAGE, "StudentAgeLimit")
                  @XMLTag(V_CVDEDN, "PayrollDeductionNumber")
                  @XMLTag(V_CVDDCT, "Deductible")
                  @XMLTag(V_CVCOP1,  "CoPaymentAmount1")
                  @XMLTag(V_CVCOP2,  "CoPaymentAmount2")
                  @XMLTag(V_CVCOP3,  "CoPaymentAmount3")
                  @XMLTag(V_CVPCKI,  "MaxOutOfPocketIndividual")
                  @XMLTag(V_CVPCKF,  "MaxOutOfPocketFamily")
                  @XMLTag(V_CVAMTE,  "CoverageAmountPerEmployee")
                  @XMLTag(V_CVAMTD,  "CoverageAmountPerDependent")
                  @XMLBeginTag("BenefitEligibility")
                      @XMLTag(V_CVELGD,  "DaysOfService")
                      @XMLTag(V_CVELGM,  "MonthsOfService")
                      @XMLTag(V_CVELGH,  "HoursOfService")
                      @XMLTag(V_CVELGA,  "Age")
                  @XMLEndTag("BenefitEligibility")
              @XMLEndTag("Benefit")
	   %}
      @XMLEndTag("BenefitList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "CVDESCU")
              @DTW_ASSIGN(orderByDisplay, "Benefit Description, Plan Description")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      %INCLUDE "SearchReturn.icl"
  %endif
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "BenefitCode")
      %if (orderBy == "CVCOVR,CVPLAN")
          @DTW_ASSIGN(orderBy, "CVCOVR DESC,CVPLAN")
          @DTW_ASSIGN(orderByDisplay, "Benefit Code (descending), Plan Code")
      %else
          @DTW_ASSIGN(orderBy, "CVCOVR,CVPLAN")
          @DTW_ASSIGN(orderByDisplay, "Benefit Code, Plan Code")
      %endif
  %elif (sequence == "BenefitDesc")
      %if (orderBy == "CVDESCU,CCDESCU")
          @DTW_ASSIGN(orderBy, "CVDESCU DESC,CCDESCU")
          @DTW_ASSIGN(orderByDisplay, "Benefit Description (descending), Plan Description")
      %else
          @DTW_ASSIGN(orderBy, "CVDESCU,CCDESCU")
          @DTW_ASSIGN(orderByDisplay, "Benefit Description, Plan Description")
      %endif
  %elif (sequence == "PlanCode")
      %if (orderBy == "CVPLAN,CVCOVR")
          @DTW_ASSIGN(orderBy, "CVPLAN DESC,CVCOVR")
          @DTW_ASSIGN(orderByDisplay, "Plan Code (descending), Benefit Code")
      %else
          @DTW_ASSIGN(orderBy, "CVPLAN,CVCOVR")
          @DTW_ASSIGN(orderByDisplay, "Plan Code, Benefit Code")
      %endif
  %elif (sequence == "PlanDesc")
      %if (orderBy == "CCDESCU,CVDESCU")
          @DTW_ASSIGN(orderBy, "CCDESCU DESC,CVDESCU")
          @DTW_ASSIGN(orderByDisplay, "Plan Description (descending), Benefit Description")
      %else
          @DTW_ASSIGN(orderBy, "CCDESCU,CVDESCU")
          @DTW_ASSIGN(orderByDisplay, "Plan Description, Benefit Description")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchDeduction, 3, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "BENEFITSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      @RetHrCompNam(profileHandle, dataBaseID, prCompany, prFacility, coFacName)
                      <h2>$(coFacName) </h2>
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Benefit Code</td>
                              @dtw_assign(operNbr, "operBenCode")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchBenCode" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Benefit Description</td>
                              @dtw_assign(operNbr, "operBenefit")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchBenefit" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">Plan Code</td>
                              @dtw_assign(operNbr, "operPlanCode")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchPlanCode" type="text" size="3" maxlength="3"> <a href="$(homeURL)$(cGIPath)BenefitPlanSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Search&amp;fldName=srchPlanCode&amp;fldDesc=planDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="planDesc" value="$(planDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Plan Description</td>
                              @dtw_assign(operNbr, "operPlan")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchPlan" size="30" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">Deduction Number</td>
                              @dtw_assign(operNbr, "operDeduction")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input name="srchDeduction" type="text" size="3" maxlength="3"> <a href="$(homeURL)$(cGIPath)DeductionSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Search&amp;fldName=srchDeduction&amp;fldDesc=dedDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="dedDesc" value="$(dedDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchBenCode.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("CVCOVR", "Benefit Code", $(srchBenCode), "U", operBenCode, "A")
  @Build_WildCard ("CVDESCU", "Benefit Description", $(srchBenefit), "U", operBenefit, "A")
  @Build_WildCard ("CVPLAN", "Plan Code", $(srchPlanCode), "U", operPlanCode, "A")
  @Build_WildCard ("upper(CCDESC)", "Plan Description", $(srchPlan), "U", operPlan, "A")
  @Build_WildCard ("CVDEDN", "Payroll Deduction Number", $(srchDeduction), "", operDeduction, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}