%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"

%Define {
  page_title              = "Sales Forecast Inquiry - Consolidated Forecast Detail"
  d2wName                 = "SalesForecastInquiryE.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;type=@dtw_rurlescseq(type)&amp;reference=@dtw_rurlescseq(reference)&amp;year=@dtw_rurlescseq(year)&amp;fdky=@dtw_rurlescseq(fdky)&amp;plant=@dtw_rurlescseq(plant)&amp;item=@dtw_rurlescseq(item)&amp;ptyp=@dtw_rurlescseq(ptyp)&amp;periodFormat=@dtw_rurlescseq(periodFormat)&amp;quantityFormat=@dtw_rurlescseq(quantityFormat)&amp;IQBDAT=@dtw_rurlescseq(IQBDAT)&amp;IQEDAT=@dtw_rurlescseq(IQEDAT)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
  smallPromptWinPctH      = "50"
%}


%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@plant", "@dtw_rurlescseq(plant)", "1", "a", workURL)
  @dtw_replace(workURL, "@@item", "@dtw_rurlescseq(item)", "1", "a", workURL)
  @dtw_replace(workURL, "@@ptyp", "@dtw_rurlescseq(ptyp)", "1", "a", workURL)
  @dtw_replace(workURL, "@@periodFormat", "@dtw_rurlescseq(periodFormat)", "1", "a", workURL)
  @dtw_replace(workURL, "@@quantityFormat", "@dtw_rurlescseq(quantityFormat)", "1", "a", workURL)
  @dtw_replace(workURL, "@@IQBDAT", "@dtw_rurlescseq(IQBDAT)", "1", "a", workURL)
  @dtw_replace(workURL, "@@IQEDAT", "@dtw_rurlescseq(IQEDAT)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "SALESFORECASTINQUIRYE")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select CFFTYP, CFREFN, CFYEAR, CFFDKY, CFPLT, CFITEM, CFPRNT, CFFCSD, upper(CFFCSD) as CFFCSDU, CFKTXT, CFFQTY, CFDATE, CFS ", stmtSQL)
                      @dtw_concat(fileSQL, " WKMCFD ", fileSQL)
                      @dtw_concat(selectSQL, " CFXHND='$(profileHandle)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td>&nbsp;</td>
                  <td class="toolbar">
                      <a href="$(homeURL)$(cGIPath)SalesForecastInquiryNotes.d2w/REPORT$(d2wVarBase) " alt="View Comments">$(commentExistImageLrg)</a>
                  </td>
                  <td class="toolbar">
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      <table $(contentTable)>
          @RtvFldDesc("PLPLNT=$(plant)", "HDPLNT", "PLNAME", plantName)
          @Format_Header_URL("Plant Number", $(plantName), $(plant), "")
          @RtvFldDesc("IMITEM='$(item)'", "HDIMST", "IMIMDS", itemDescription)
          @Format_Header_URL("Item Number", $(itemDescription), $(item), "")
          @Format_Header_URL("Part Type", $(ptyp),"", "")
          @Format_Date(IQEDAT, "1", F_IQEDAT)
          @Format_Header_URL("Period End", $(F_IQEDAT),"", "")
      </table>
      $(hrTagAttr)
      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST name="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr"> Item Number</th></tr>
                  <tr><td><input type="text" class="inputalph" name="srchItem" size="15" maxlength="15">
                          <input type="hidden" name="operItem" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchItem.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif
      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")

          <tr>
              @OrderBy_Sort("CFPRNT", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=item" title="Sequence By Item Number, Type"> Item Number</a></th>
              @OrderBy_Sort("CFS", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=partType" title="Sequence By Part Type"> S</a></th>
              @OrderBy_Sort("CFFTYP", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=type" title="Sequence By Forecast Type, Reference, Year"> Forecast<br>Type</a></th>
              @OrderBy_Sort("CFFCSD", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=description" title="Sequence By Description"> Description</a></th>
              @OrderBy_Sort("CFFDKY", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=key" title="Sequence By Forecast Type Key"> Forecast<br>Type Key</a></th>
              @OrderBy_Sort("CFFQTY", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=quantity" title="Sequence By Quantity"> Quantity</a></th>
              @OrderBy_Sort("CFDATE", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=date" title="Sequence By Date Last Maintained, Item Number, Type"> Date Last<br>Maintained</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
                  @Format_Nbr(V_CFFTYP, F_CFFTYP, "0", "Z", "", "", "")
                  @Format_Nbr(V_CFFQTY, F_CFFQTY, "0", "M", "", "", "")
                  @Format_Date(V_CFDATE, "1", F_CFDATE)

              <tr class="$(rowClass)">
                  <td class="colalph">$(V_CFPRNT)</td>
                  <td class="colalph">$(V_CFS)</td>
                  <td class="colnmbr">$(F_CFFTYP)</td>
                  <td class="colalph">$(V_CFFCSD)</td>
                  <td class="colalph">$(V_CFFDKY)</td>
                  <td class="colnmbr">$(F_CFFQTY)</td>
                  <td class="colnmbr">$(F_CFDATE)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Forecast_Inquiry (IN CHAR(64) profileHandle,
			                            IN CHAR(2)  dataBaseID,
                                            IN DEC(3, 0) plant,
                                            IN CHAR(15) item,
			                            IN CHAR(1)  ptyp,
                                            IN DEC(7, 0) IQBDAT,
                                            IN DEC(7, 0) IQEDAT)


  {%EXEC {HMS435_A.PGM %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"

  %if (formatToPrint == "Y")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else

      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "CFPRNT,CFFTYP")
          @DTW_ASSIGN(orderByDisplay, "Item Number, Forecast Type")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif

  %INCLUDE "SearchReturn.icl"
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"

  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "CFFTYP,CFREFN,CFYEAR")
          @DTW_ASSIGN(orderByDisplay, "Forecast Type, Reference Number, Forecast Year")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(LOAD)  {
  %INCLUDE "setLibraryList.icl"
  @Forecast_Inquiry(profileHandle, dataBaseID, plant, item, ptyp, IQBDAT, IQEDAT)
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/ENTRY$(d2wVarBase)">
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "item")
      %if (orderBy == "CFPRNT,CFFTYP")
          @DTW_ASSIGN(orderBy, "CFPRNT DESC,CFFTYP DESC")
          @DTW_ASSIGN(orderByDisplay, "Item Number (descending), Forecast Type (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CFPRNT,CFFTYP")
          @DTW_ASSIGN(orderByDisplay, "Item Number, Forecast Type")
      %endif
  %elif (sequence == "partType")
      %if (orderBy == "CFS")
          @DTW_ASSIGN(orderBy, "CFS DESC")
          @DTW_ASSIGN(orderByDisplay, "Part Type (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CFS")
          @DTW_ASSIGN(orderByDisplay, "Part Type")
      %endif
  %elif (sequence == "type")
      %if (orderBy == "CFFTYP,CFREFN,CFYEAR")
          @DTW_ASSIGN(orderBy, "CFFTYP DESC,CFREFN DESC,CFYEAR DESC")
          @DTW_ASSIGN(orderByDisplay, "Type (descending), Reference (descending), Year (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CFFTYP,CFREFN,CFYEAR")
          @DTW_ASSIGN(orderByDisplay, "Type, Reference, Year")
      %endif
  %elif (sequence == "description")
      %if (orderBy == "CFFCSDU")
          @DTW_ASSIGN(orderBy, "CFFCSDU DESC")
          @DTW_ASSIGN(orderByDisplay, "Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CFFCSDU")
          @DTW_ASSIGN(orderByDisplay, "Description")
      %endif
  %elif (sequence == "key")
      %if (orderBy == "CFFDKY")
          @DTW_ASSIGN(orderBy, "CFFDKY DESC")
          @DTW_ASSIGN(orderByDisplay, "Forecast Type Key (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CFFDKY")
          @DTW_ASSIGN(orderByDisplay, "Forecast Type Key ")
      %endif
  %elif (sequence == "quantity")
      %if (orderBy == "CFFQTY")
          @DTW_ASSIGN(orderBy, "CFFQTY DESC")
          @DTW_ASSIGN(orderByDisplay, "Quantity (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CFFQTY")
          @DTW_ASSIGN(orderByDisplay, "Quantity")
      %endif
  %elif (sequence == "date")
      %if (orderBy == "CFDATE")
          @DTW_ASSIGN(orderBy, "CFDATE DESC")
          @DTW_ASSIGN(orderByDisplay, "Date Last Maintained (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CFDATE")
          @DTW_ASSIGN(orderByDisplay, "Date Last Maintained")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("CFPRNT", "Item", $(srchItem), "U", operItem, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}