%INCLUDE "$(baseVar)"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Participant Inquiry"
  d2wName                 = "WFParticipantInquiry.d2w"
  d2wVarBase              = "$(genericVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "WFPARTICIPANTINQUIRY")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "SELECT SYUSER.*,upper(USEMAL) as USEMALU ", stmtSQL)
                      @dtw_concat(fileSQL, " SYUSER ", fileSQL)
                      @dtw_concat(selectSQL, " (Exists (Select * from WFPRPT left join SYCUSF on CUCUSR=PAPART where PAPART=USUSER or CUUSER=USUSER) ", selectSQL)
                      @dtw_concat(selectSQL, " or Exists (Select * from WFDELG where DLDPRT=USUSER or DLPART=USUSER)) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitleWithPrint.icl"
      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">User</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchUser" size="15" maxlength="30">
                          <input type="hidden" name="operUser" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchUser.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("USDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=User" title="Sequence By User">User</a></th>
              @OrderBy_Sort("USEMALU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Email" title="Sequence By E-mail Address, User"> E-mail Address</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)WFParticipantInquiryList.d2w/REPORT$(d2wVarBase)&amp;wfParticipant=@dtw_rurlescseq(V_USUSER)" title="View Participant">$(V_USDESC)</a></td>
                  <td class="colalph">$(V_USEMAL)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "USDESCU")
          @DTW_ASSIGN(orderByDisplay, "User")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "User")
      %if (orderBy == "USDESCU")
          @DTW_ASSIGN(orderBy, "USDESCU DESC")
          @DTW_ASSIGN(orderByDisplay, "User (descending)")
      %else
          @DTW_ASSIGN(orderBy, "USDESCU")
          @DTW_ASSIGN(orderByDisplay, "User")
      %endif
  %elif (sequence == "Email")
      %if (orderBy == "USEMALU,USDESCU")
          @DTW_ASSIGN(orderBy, "USEMALU DESC,USDESCU")
          @DTW_ASSIGN(orderByDisplay, "E-mail Address (descending), User")
      %else
          @DTW_ASSIGN(orderBy, "USEMALU,USDESCU")
          @DTW_ASSIGN(orderByDisplay, "E-mail Address, User")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchCust, 7, 0) &&
                      editNum(document.Search.srchVend, 7, 0) &&
                      editNum(document.Search.srchSlsm, 3, 0) &&
                      editNum(document.Search.srchPlant, 3, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "USERMASTERSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">User</td>
                              @dtw_assign(operNbr, "operUser")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchUser" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">User Profile</td>
                              @dtw_assign(operNbr, "operUserProfile")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchUserProfile" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Role</td>
                              @dtw_assign(operNbr, "operRole")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchRole" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Customer</td>
                              @dtw_assign(operNbr, "operCust")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchCust" size="7" maxlength="7"></td>
                          </tr>

                          <tr><td class="dsphdr">Vendor</td>
                              @dtw_assign(operNbr, "operVend")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchVend" size="7" maxlength="7"></td>
                          </tr>

                          <tr><td class="dsphdr">Salesman</td>
                              @dtw_assign(operNbr, "operSlsm")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchSlsm" size="3" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Default Plant</td>
                              @dtw_assign(operNbr, "operPlant")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchPlant" size="3" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Badge</td>
                              @dtw_assign(operNbr, "operBadge")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchBadge" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Catalog</td>
                              @dtw_assign(operNbr, "operCatalog")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchCatalog" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">News Category URL</td>
                              @dtw_assign(operNbr, "operNews")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchNews" size="15" maxlength="256"></td>
                          </tr>

                          <tr><td class="dsphdr">E-Mail Address</td>
                              @dtw_assign(operNbr, "operEmail")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchEmail" size="15" maxlength="256"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchUser.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("USDESCU", "User", $(srchUser), "U", operUser, "A")
  @Build_WildCard ("USUSER",  "User Profile", $(srchUserProfile), "U", operUserProfile, "A")
  @Build_WildCard ("USROLE",  "Role", $(srchRole), "U", operRole, "A")
  @Build_WildCard ("USCUST",  "Customer", $(srchCust), "", operCust, "N")
  @Build_WildCard ("USVEND",  "Vendor", $(srchVend), "", operVend, "N")
  @Build_WildCard ("USSLSM",  "Salesman", $(srchSlsm), "", operSlsm, "N")
  @Build_WildCard ("USDPLT",  "Default Plant", $(srchPlant), "", operPlant, "N")
  @Build_WildCard ("USCLCK",  "Badge", $(srchBadge), "U", operBadge, "A")
  @Build_WildCard ("USCATN",  "Catalog", $(srchCatalog), "U", operCatalog, "A")
  @Build_WildCard ("upper(USNEWS)", "News Category URL", $(srchNews), "U", operNews, "A")
  @Build_WildCard ("upper(USEMAL)", "E-Mail Address", $(srchEmail), "U", operEmail, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
