%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "ProgSecurity.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Program Option Security By User"
  d2wName                 = "ProgramOptionByUser.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  programName             = "HSYPSU"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
              function confirmDelete(text) {return confirm("Confirm delete of all Program Option Security for this user" + "\n" + "\n" + text);}
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "PROGOPTIONBYUSER")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(distinctSQL, "SPUSER ", distinctSQL)
                      @dtw_concat(stmtSQL, " Select distinct SPUSER, coalesce(USDESC,' ') as USDESC, coalesce(USDESCU,' ') as USDESCU, coalesce(USROLE,' ') as USROLE ", stmtSQL)
                      @dtw_concat(fileSQL, " SYPGMS left join SYUSER on SPUSER=USUSER ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, " SPUSER>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Program_Option_ByUser_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Program_Option_ByUser_Query (IN CHAR(64)    profileHandle,
                                                   CHAR(2)     dataBaseID,
                                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      <a href="$(homeURL)$(cGIPath)$(d2wName)/COPY$(genericVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">User Profile</th>
                      <th class="colhdr">Name</th>
                      <th class="colhdr">Role</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchUser" size="10" maxlength="10">
                          <input type="hidden" name="operUser" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchName" size="10" maxlength="20">
                          <input type="hidden" name="operName" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchRole" size="10" maxlength="10">
                          <input type="hidden" name="operRole" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchUser.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y")
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("SPUSER", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=User" title="Sequence By User Profile, Name">User Profile</a></th>
              @OrderBy_Sort("USDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Name" title="Sequence By Name, User Profile">Name</a></th>
              @OrderBy_Sort("USROLE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Role" title="Sequence By Role, User Profile">Role</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;progOptUser=@dtw_rurlescseq(V_SPUSER)&amp;progOptUserName=@dtw_rurlescseq(V_USDESC)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_USDESC), $(V_SPUSER), "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y")
                      <td class="opticon">
                          <a href="$(homeURL)$(cGIPath)$(d2wName)/COPY$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)$(d2wName)/DELETE$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                      </td>
                  %endif
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ProgramOption.d2w/REPORT$(d2wVarBase)&amp;forUserProfile=@dtw_rurlescseq(V_SPUSER)" title="Click here to view program option security">$(V_SPUSER)</a></td>
                  <td class="colalph">$(V_USDESC)</td>
                  <td class="colalph">$(V_USROLE)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "SPUSER,USDESCU")
              @DTW_ASSIGN(orderByDisplay, "Role, Name")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      %INCLUDE "SearchReturn.icl"
  %endif
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "User")
      %if (orderBy == "SPUSER,USDESCU")
          @DTW_ASSIGN(orderBy, "SPUSER DESC,USDESCU")
          @DTW_ASSIGN(orderByDisplay, "User Profile (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "SPUSER,USDESCU")
          @DTW_ASSIGN(orderByDisplay, "User Profile, Name")
      %endif
  %elif (sequence == "Name")
      %if (orderBy == "USDESCU,SPUSER")
          @DTW_ASSIGN(orderBy, "USDESCU DESC,SPUSER")
          @DTW_ASSIGN(orderByDisplay, "Name (descending), User Profile")
      %else
          @DTW_ASSIGN(orderBy, "USDESCU,SPUSER")
          @DTW_ASSIGN(orderByDisplay, "Name, User Profile")
      %endif
  %elif (sequence == "Role")
      %if (orderBy == "USROLE,SPUSER")
          @DTW_ASSIGN(orderBy, "USROLE DESC,SPUSER")
          @DTW_ASSIGN(orderByDisplay, "Role (descending), User Profile")
      %else
          @DTW_ASSIGN(orderBy, "USROLE,SPUSER")
          @DTW_ASSIGN(orderByDisplay, "Role, User Profile")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          @dtw_assign(formName, "Search")
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PROGOPTIONBYUSER")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">User Profile</td>
                              @dtw_assign(operNbr, "operUser")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchUser" type="text" size="15" maxlength="10"><a href="$(homeURL)$(phpPath)UserSearch.php$(altVarBase)&amp;docName=Search&amp;userFld=srchUser&amp;descFld=srchUserName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="srchUserName" type="text" size="30" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Name</td>
                              @dtw_assign(operNbr, "operName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchName" type="text" size="15" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Role</td>
                              @dtw_assign(operNbr, "operRole")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchRole" type="text" size="15" maxlength="10"><a href="$(homeURL)$(phpPath)RoleSearch.php$(altVarBase)&amp;docName=Search&amp;roleFld=srchRole&amp;descFld=srchRoleDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="srchRoleDesc"  type="text" size="30" disabled></td>
                          </tr>
                          %INCLUDE "SearchBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("SPUSER", "User Profile", $(srchUser), "U", $(operUser), "A")
  @Build_WildCard ("upper(USDESC)", "Name", $(srchName), "U", $(operName), "A")
  @Build_WildCard ("USROLE", "Role", $(srchRole), "U", $(operRole), "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}

%HTML(DELETE) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Delete From SYPGMS Where SPUSER='$(progOptUser)' @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)

  @Format_ConfMsg_Desc(maintenanceCode, $(progOptUserName), $(progOptUser), "", "", "", "", confMessage)
  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
%}

%HTML(COPY) {
  %INCLUDE "setLibraryList.icl"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.toUser.value =="" )
                     {alert("$(reqFieldError)"); return false;}
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PROGOPTIONBYUSERCOPY")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(copyAdd, "Copy")
                      %if (progOptUser == "")
                          @dtw_assign(copyAdd, "Add")
                      %endif
                      <table $(contentTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td align="justify"><h1>$(copyAdd) Program Option Security By User</h1></td>
                              <td class="toolbar">
                                  %INCLUDE "MaintainTopNoTable.icl"
                              </td>
                          </tr>
                      </table>

                      @dtw_assign(copyHdr, "")
                      %if (progOptUser != "")
                          @dtw_assign(copyHdr, "To")
                          <table $(contentTable)>
                              @Format_Header("From User Profile", $(progOptUserName), $(progOptUser))
                          </table>
                      %endif

                      $(hrTagAttr)
                      %INCLUDE "RequiredField.icl"
                      %INCLUDE "ErrorDisplay.icl"

                      <form class="formClass" METHOD=POST name=Chg ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;progOptUser=@dtw_rurlescseq(progOptUser)&amp;progOptUserName=@dtw_rurlescseq(progOptUserName)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
                          <table $(contentTable)>
                              %if (errFound != "")
                                  %if (errFound == "")
                                      @dtw_assign(edtVar, "")
                                  %else
                                      @EdtVarErr(profileHandle, typeValue, edtVar)
                                      @ErrVarErr(profileHandle, typeError, errVar)
                                      @DecatErr_Field("@@tusr", "toUser")    @dtw_assign(Err_TUSER,  fieldValue)
                                  %endif

                                  @dtw_assign(V_TUSER,  toUser)

                              %endif

                              @RtvFldDesc("USUSER='$(V_TUSER)' ", "SYUSER", "USDESC", userName)
                              @SetTextOvr(Err_TUSER)
                              <tr><td class="dsphdr"><span $(textOvr)>$(copyHdr) User Profile</span></td>
                                  <td class="inputalph"><input name="toUser" type="text" value="$(V_TUSER)" size="15" maxlength="10"><a href="$(homeURL)$(phpPath)UserSearch.php$(altVarBase)&amp;docName=Chg&amp;userFld=toUser&amp;descFld=toUserName" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage)</a>
                                                        <input name="toUserName" value="$(userName)" type="text" size="30" disabled></td>
                              </tr>
                              %if (errFound != "")
                                  <tr><td>&nbsp;</td><td class="error" colspan="10">INVALID USER PROFILE</td></tr>
                              %endif
                          </table>

                          <script TYPE="text/javascript">
                              document.Chg.toUser.focus();
                          </script>

                      </form>
                      %INCLUDE "MaintainBottom.icl"
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%{ Validate Object %}
%FUNCTION(dtw_directcall) VldObject (IN  CHAR(10) objName,
                                         CHAR(10) objType,
                                     OUT CHAR(1)  objValid)
  {%EXEC {HSYOBJ_W.PGM %}
  %}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(toUser)
  @dtw_assign(objType, "*USRPRF")
  @VldObject(toUser, objType, objValid)
  %if (objValid != "Y")
      @dtw_assign(errFound, "Y")
  %endif

  %if (errFound == "")
      %if (progOptUser == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ProgramOption.d2w/REPORT$(d2wVarBase)&amp;forUserProfile=@dtw_rurlescseq(toUser)">
      %else
          %INCLUDE "stmtSQLClear.icl"
          @dtw_concat(stmtSQL, " Insert Into SYPGMS (SPUSER,SPPGID,SPOP01,SPOP02,SPOP03,SPOP04,SPOP05,SPOP06,SPOP07, ", stmtSQL)
          @dtw_concat(stmtSQL, "                     SPOP08,SPOP09,SPOP10,SPOP11,SPOP12,SPOP13,SPOP14,SPOP15) ", stmtSQL)
          @dtw_concat(stmtSQL, " Select         '$(toUser)',SPPGID,SPOP01,SPOP02,SPOP03,SPOP04,SPOP05,SPOP06,SPOP07, ", stmtSQL)
          @dtw_concat(stmtSQL, "                     SPOP08,SPOP09,SPOP10,SPOP11,SPOP12,SPOP13,SPOP14,SPOP15 ", stmtSQL)
          @dtw_concat(stmtSQL, " From SYPGMS a ", stmtSQL)
          @dtw_concat(stmtSQL, " Where a.SPUSER='$(progOptUser)' and not exists ", stmtSQL)
          @dtw_concat(stmtSQL, " (Select * from SYPGMS b Where b.SPUSER='$(toUser)' and a.SPPGID=b.SPPGID)  @@endsql", stmtSQL)
          @SQL_Update(stmtSQL, status)

          @Format_ConfMsg_Desc(maintenanceCode, "$(userName)", "$(toUser)", "", "", "", "", confMessage)
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/COPY$(d2wVarBase)&amp;toUser=@dtw_rurlescseq(toUser)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
