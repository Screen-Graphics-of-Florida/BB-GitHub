%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Schedule Exceptions Report"
  d2wName                 = "ScheduleExceptionsReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;apid=@dtw_rurlescseq(apid)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "2"
  sortSchedule            = "1"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {

                  if (document.Chg.fromExceptionDate.value == "" ||
                     document.Chg.toExceptionDate.value == "")
                     {alert("From And To Exception Dates Must Be Entered");
                     document.Chg.fromExceptionDate.focus();
                     return false;}

                  if (document.Chg.fromExceptionDate.value == "0" ||
                     document.Chg.toExceptionDate.value == "0" )
                     {alert("From And To Exception Dates Must Be Entered");
                     document.Chg.fromExceptionDate.focus();
                     return false;}

                  if (document.Chg.sortCompanyNumber.value == "0" &&
                     document.Chg.sortHRCompanyNumber.value == "0" &&
                     document.Chg.sortPlantNumber.value == "0")
                     {alert("Sort Sequence 2 Must Be Assigned");
                     document.Chg.sortCompanyNumber.focus();
                     return false;}

                  if (document.Chg.sortCompanyNumber.value != "0" &&
                     document.Chg.sortCompanyNumber.value != "2")
                     {alert("Invalid Sort Sequence - Must Be 2");
                     document.Chg.sortCompanyNumber.focus();
                     return false;}

                  %if (V_HDPERL > "0")
                      if (document.Chg.sortCompanyNumber.value == "2" &&
                          document.Chg.sortHRCompanyNumber.value == "2")
                          {alert("Sort Sequence Has Already Been Selected");
                          document.Chg.sortHRCompanyNumber.focus();
                          return false;}
                      if (document.Chg.sortHRCompanyNumber.value != "0" &&
                          document.Chg.sortHRCompanyNumber.value != "2")
                          {alert("Invalid Sort Sequence - Must Be 2");
                          document.Chg.sortHRCompanyNumber.focus();
                          return false;}
                  %endif

                  %if (apid == "ME")
                      if (document.Chg.sortPlantNumber.value == "2" &&
                          (document.Chg.sortCompanyNumber.value == "2" ||
                           document.Chg.sortHRCompanyNumber.value == "2"))
                          {alert("Sort Sequence Has Already Been Selected");
                          document.Chg.sortPlantNumber.focus();
                          return false;}
                      if (document.Chg.sortPlantNumber.value != "0" &&
                          document.Chg.sortPlantNumber.value != "2")
                          {alert("Invalid Sort Sequence - Must Be 2");
                          document.Chg.sortPlantNumber.focus();
                          return false;}
                  %endif

                  if (editNum(document.Chg.fromSchedule, 3, 0) &&
                      editNum(document.Chg.toSchedule, 3, 0) &&
                      editdate(document.Chg.fromExceptionDate) &&
                      editdate(document.Chg.toExceptionDate) &&
                      editNum(document.Chg.fromCompanyNumber, 2, 0) &&
                      editNum(document.Chg.toCompanyNumber, 2, 0) &&
                      editNum(document.Chg.fromFacilityNumber, 4, 0) &&
                      editNum(document.Chg.toFacilityNumber, 4, 0) &&
                      editNum(document.Chg.fromEmployeeNumber, 5, 0) &&
                      editNum(document.Chg.toEmployeeNumber, 5, 0) &&
                      editFromToAll(document.Chg.fromSchedule, document.Chg.toSchedule, document.Chg.allSchedule, 3) &&
                      editFromTo(document.Chg.fromExceptionDate, document.Chg.toExceptionDate, "D") &&
                      editFromToAll(document.Chg.fromEventCode, document.Chg.toEventCode, document.Chg.allEventCode, 2) &&
                      editFromToAll(document.Chg.fromCompanyNumber, document.Chg.toCompanyNumber, document.Chg.allCompanyNumber, 2) &&
                      editFromToAll(document.Chg.fromFacilityNumber, document.Chg.toFacilityNumber, document.Chg.allFacilityNumber, 4) &&
                      editFromToAll(document.Chg.fromDepartment, document.Chg.toDepartment, document.Chg.allDepartment, "A") &&
                      editFromToAll(document.Chg.fromEmployeeNumber, document.Chg.toEmployeeNumber, document.Chg.allEmployeeNumber, 5)

                      %if (V_HDPERL > "0")
                          && editNum(document.Chg.fromHRCompanyNumber, 2, 0)
                          && editNum(document.Chg.toHRCompanyNumber, 2, 0)
                          && editNum(document.Chg.fromHREmployeeNumber, 9, 0)
                          && editNum(document.Chg.toHREmployeeNumber, 9, 0)
                          && editFromToAll(document.Chg.fromHRCompanyNumber, document.Chg.toHRCompanyNumber, document.Chg.allHRCompanyNumber, 2)
                          && editFromToAll(document.Chg.fromLocationCode, document.Chg.toLocationCode, document.Chg.allLocationCode, "A")
                          && editFromToAll(document.Chg.fromHREmployeeNumber, document.Chg.toHREmployeeNumber, document.Chg.allHREmployeeNumber, 9)
                      %endif

                      %if (apid == "ME")
                          && editNum(document.Chg.fromPlantNumber, 3, 0)
                          && editNum(document.Chg.toPlantNumber, 3, 0)
                          && editFromToAll(document.Chg.fromPlantNumber, document.Chg.toPlantNumber, document.Chg.allPlantNumber, 3)
                          && editFromToAll(document.Chg.fromMfgDepartment, document.Chg.toMfgDepartment, document.Chg.allMfgDepartment, "A")
                          && editFromToAll(document.Chg.fromWorkCenter, document.Chg.toWorkCenter, document.Chg.allWorkCenter, "A")
                      %endif
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "SCHEDULEEXCEPTIONSREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromSchedule")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@fscd", "fromSchedule")        @dtw_assign(Err_N1FSCD,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@sel@")  @dtw_assign(V_N1SEL,  fieldValue)
                                  @Decat_Field("@@fscd")  @dtw_assign(V_N2FSCD,  fieldValue)
                                  @Decat_Field("@@tscd")  @dtw_assign(V_N2TSCD,  fieldValue)
                                  @Decat_Field("@@ascd")  @dtw_assign(V_N2ASCD,  fieldValue)
                                  @Decat_Field("@@sseq")  @dtw_assign(V_N2SSEQ,  fieldValue)

                                  @Decat_Field("@@fexd")  @dtw_assign(V_N2FEXDT, fieldValue)
                                  @Decat_Field("@@texd")  @dtw_assign(V_N2TEXDT, fieldValue)

                                  @Decat_Field("@@fevc")  @dtw_assign(V_N2FEVCD, fieldValue)
                                  @Decat_Field("@@tevc")  @dtw_assign(V_N2TEVCD, fieldValue)
                                  @Decat_Field("@@aevc")  @dtw_assign(V_N2AEVCD, fieldValue)

                                  @Decat_Field("@@fcom")  @dtw_assign(V_N2FCOMP, fieldValue)
                                  @Decat_Field("@@tcom")  @dtw_assign(V_N2TCOMP, fieldValue)
                                  @Decat_Field("@@acom")  @dtw_assign(V_N2ACOMP, fieldValue)
                                  @Decat_Field("@@cseq")  @dtw_assign(V_N2CSEQ, fieldValue)

                                  @Decat_Field("@@ffac")  @dtw_assign(V_N2FFACL, fieldValue)
                                  @Decat_Field("@@tfac")  @dtw_assign(V_N2TFACL, fieldValue)
                                  @Decat_Field("@@afac")  @dtw_assign(V_N2AFACL, fieldValue)

                                  @Decat_Field("@@fdep")  @dtw_assign(V_N2FDEPT, fieldValue)
                                  @Decat_Field("@@tdep")  @dtw_assign(V_N2TDEPT, fieldValue)
                                  @Decat_Field("@@adep")  @dtw_assign(V_N2ADEPT, fieldValue)

                                  @Decat_Field("@@femp")  @dtw_assign(V_N2FEMPL, fieldValue)
                                  @Decat_Field("@@temp")  @dtw_assign(V_N2TEMPL, fieldValue)
                                  @Decat_Field("@@aemp")  @dtw_assign(V_N2AEMPL, fieldValue)

                                  %if (V_HDPERL > "0")
                                      @Decat_Field("@@fpec")  @dtw_assign(V_N2FPECP, fieldValue)
                                      @Decat_Field("@@tpec")  @dtw_assign(V_N2TPECP, fieldValue)
                                      @Decat_Field("@@apec")  @dtw_assign(V_N2APECP, fieldValue)
                                      @Decat_Field("@@hseq")  @dtw_assign(V_N2HSEQ, fieldValue)

                                      @Decat_Field("@@floc")  @dtw_assign(V_N2FLOC, fieldValue)
                                      @Decat_Field("@@tloc")  @dtw_assign(V_N2TLOC, fieldValue)
                                      @Decat_Field("@@aloc")  @dtw_assign(V_N2ALOC, fieldValue)

                                      @Decat_Field("@@fpem")  @dtw_assign(V_N2FPEMP, fieldValue)
                                      @Decat_Field("@@tpem")  @dtw_assign(V_N2TPEMP, fieldValue)
                                      @Decat_Field("@@apem")  @dtw_assign(V_N2APEMP, fieldValue)
                                  %endif

                                  %if (apid == "ME")
                                      @Decat_Field("@@fplt")  @dtw_assign(V_N2FPLT, fieldValue)
                                      @Decat_Field("@@tplt")  @dtw_assign(V_N2TPLT, fieldValue)
                                      @Decat_Field("@@aplt")  @dtw_assign(V_N2APLT, fieldValue)
                                      @Decat_Field("@@pseq")  @dtw_assign(V_N2PSEQ, fieldValue)

                                      @Decat_Field("@@fmfd")  @dtw_assign(V_N2FMFDP, fieldValue)
                                      @Decat_Field("@@tmfd")  @dtw_assign(V_N2TMFDP, fieldValue)
                                      @Decat_Field("@@amfd")  @dtw_assign(V_N2AMFDP, fieldValue)

                                      @Decat_Field("@@fwc@")  @dtw_assign(V_N2FWC, fieldValue)
                                      @Decat_Field("@@twc@")  @dtw_assign(V_N2TWC, fieldValue)
                                      @Decat_Field("@@awc@")  @dtw_assign(V_N2AWC, fieldValue)
                                  %endif

                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries
 Values %}

                                  %if (V_N1SEL == "02")
                                      @dtw_assign(printByEmployee, "")
                                      @dtw_assign(printByDate, "CHECKED")
                                  %else
                                      @dtw_assign(printByEmployee, "CHECKED")
                                      @dtw_assign(printByDate, "")
                                  %endif
                                  %if (V_N2ASCD == "ALL")
                                      @dtw_assign(checkedallSchedule, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallSchedule, "")
                                  %endif
                                  %if (V_N2AEVCD == "ALL")
                                      @dtw_assign(checkedallEventCode, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallEventCode, "")
                                  %endif
                                  %if (V_N2ACOMP == "ALL")
                                      @dtw_assign(checkedallCompanyNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallCompanyNumber, "")
                                  %endif
                                  %if (V_N2AFACL == "ALL")
                                      @dtw_assign(checkedallFacilityNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallFacilityNumber, "")
                                  %endif
                                  %if (V_N2ADEPT == "ALL")
                                      @dtw_assign(checkedallDepartment, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallDepartment, "")
                                  %endif
                                  %if (V_N2AEMPL == "ALL")
                                      @dtw_assign(checkedallEmployeeNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallEmployeeNumber, "")
                                  %endif

                                  %if (V_N2APECP == "ALL")
                                      @dtw_assign(checkedallHRCompanyNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallHRCompanyNumber, "")
                                  %endif
                                  %if (V_N2ALOC == "ALL")
                                      @dtw_assign(checkedallLocationCode, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallLocationCode, "")
                                  %endif
                                  %if (V_N2APEMP == "ALL")
                                      @dtw_assign(checkedallHREmployeeNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallHREmployeeNumber, "")
                                  %endif

                                  %if (V_N2APLT == "ALL")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPlantNumber, "")
                                  %endif
                                  %if (V_N2AMFDP == "ALL")
                                      @dtw_assign(checkedallMfgDepartment, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallMfgDepartment, "")
                                  %endif
                                  %if (V_N2AWC == "ALL")
                                      @dtw_assign(checkedallWorkCenter, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallWorkCenter, "")
                                  %endif

                              %else
                                  @dtw_assign(printByEmployee, "CHECKED")
                                  @dtw_assign(printByDate, "")
                                  @dtw_assign(checkedallSchedule, "CHECKED")
                                  @DateTodayCYMD(V_N2FEXDT)
                                  @DateInputFromCYMD(V_N2FEXDT)
                                  @DateTodayCYMD(V_N2TEXDT)
                                  @DateInputFromCYMD(V_N2TEXDT)
                                  @dtw_assign(checkedallEventCode, "CHECKED")
                                  @dtw_assign(checkedallCompanyNumber, "CHECKED")
                                  @dtw_assign(checkedallFacilityNumber, "CHECKED")
                                  @dtw_assign(checkedallDepartment, "CHECKED")
                                  @dtw_assign(checkedallEmployeeNumber, "CHECKED")

                                  @dtw_assign(checkedallHRCompanyNumber, "CHECKED")
                                  @dtw_assign(checkedallLocationCode, "CHECKED")
                                  @dtw_assign(checkedallHREmployeeNumber, "CHECKED")

                                  @RtvDftPlant(plantNumber, plantName)
                                  %if (plantNumber == "0")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(V_N2FPLT, plantNumber)
                                      @dtw_assign(V_N2TPLT, plantNumber)
                                      @dtw_assign(checkedallPlantNumber, "")
                                      @dtw_assign(V_N2PSEQ, "2")
                                  %endif
                                  @dtw_assign(checkedallMfgDepartment, "CHECKED")
                                  @dtw_assign(checkedallWorkCenter, "CHECKED")
                              %endif

                          </table>

                          <table $(contentTable)>
                              <tr><td class="colcode"><input name="perelease" type="hidden" VALUE=$(V_HDPERL)></td></tr>

                              <tr><td class="dsphdr"><span $(textOvr)>Report Content</span></td>
                                  <td class="inputnmbr"><input name="reportContent" type="radio" VALUE='01' $(printByEmployee)>Print By Employee</td>
                              </tr>

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="reportContent" type="radio" VALUE='02' $(printByDate)>Print By Date</td>
                              </tr>

                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                              </tr>

                              @SetTextOvr(Err_N2FSCD)
                              %if (textOvr == "") @SetTextOvr(Err_N2SSEQ) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Schedule</span></td>
                                  <td class="inputnmbr"><input name="fromSchedule" value="$(V_N2FSCD)" type="text" size="5" maxlength="3"><a href="$(homeURL)$(phpPath)ScheduleSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromSchedule&amp;fldDesc=fscheduleDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fscheduleDesc" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toSchedule" value="$(V_N2TSCD)" type="text" size="5" maxlength="3"><a href="$(homeURL)$(phpPath)ScheduleSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toSchedule&amp;fldDesc=tscheduleDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="tscheduleDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allSchedule" value='ALL' $(checkedallSchedule) type="checkbox" onClick="if (this.checked) this.form.fromSchedule.value='', this.form.toSchedule.value='';"></td>
                                  <td class="colcode"><input name="sortSchedule" type="hidden"  Value="$(sortSchedule)" size="1" maxlength="1">$(sortSchedule)</td>
                              </tr>
                              @DspErrMsg(Err_N2FSCD)
                              @DspErrMsg(Err_N2SSEQ)

                              <tr><td class="dsphdr">Exception Date</td>
                                  <td class="inputnmbr"><input name="fromExceptionDate" value="$(V_N2FEXDT)" type="text" size="5" maxlength="6"><a href="javascript:calWindow('fromExceptionDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toExceptionDate" value="$(V_N2TEXDT)" type="text" size="5" maxlength="6"><a href="javascript:calWindow('toExceptionDate');">$(calendarImage)</a></td>
                              </tr>

                              <tr><td class="dsphdr">Event Code</td>
                                  <td class="inputalph"><input name="fromEventCode" value="$(V_N2FEVCD)" type="text" size="5" maxlength="2"><a href="$(homeURL)$(phpPath)ETCodeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromEventCode&amp;fldDesc=feventDesc&amp;fldType=E"onclick="$(searchWinVar)"> $(searchImage) </a><input disabled name="feventDesc" value="$(feventDesc)"  type="hidden" size="30"></td>
                                  <td class="inputalph"><input name="toEventCode" value="$(V_N2TEVCD)" type="text" size="5" maxlength="2"><a href="$(homeURL)$(phpPath)ETCodeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toEventCode&amp;fldDesc=teventDesc&amp;fldType=E"onclick="$(searchWinVar)"> $(searchImage) </a><input disabled name="teventDesc" value="$(teventDesc)"  type="hidden" size="30"></td>
                                  <td class="inputalph"><input name="allEventCode" VALUE='ALL' $(checkedallEventCode) type="checkbox" onClick="if (this.checked) this.form.fromEventCode.value='', this.form.toEventCode.value='';"></td>
                              </tr>

                              @SetTextOvr(Err_N2CSEQ)
                              <tr><td class="dsphdr"><span $(textOvr)>Company Number</span></td>
                                  %if (V_HDPERL > "0" || V_HDPRRL > "0") 
                                      <td class="inputnmbr"><input name="fromCompanyNumber" value="$(V_N2FCOMP)" type="text" size="5" maxlength="2"> <a href="$(homeURL)$(phpPath)HRCoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=fromCompanyNumber&amp;fldFac=fromFacilityNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="coFacDesc" value="$(fieldDesc)"  type="hidden" size="30" maxlength="30"></td>
                                      <td class="inputnmbr"><input name="toCompanyNumber" value="$(V_N2TCOMP)" type="text" size="5" maxlength="2"> <a href="$(homeURL)$(phpPath)HRCoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=toCompanyNumber&amp;fldFac=toFacilityNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="coFacDesc" value="$(fieldDesc)"  type="hidden" size="30" maxlength="30"></td>
                                  %else
                                      <td class="inputnmbr"><input name="fromCompanyNumber" value="$(V_N2FCOMP)" type="text" size="5" maxlength="2"> <a href="$(homeURL)$(phpPath)CoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=fromCompanyNumber&amp;fldFac=fromFacilityNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="coFacDesc" value="$(fieldDesc)"  type="hidden" size="30" maxlength="30"></td>
                                      <td class="inputnmbr"><input name="toCompanyNumber" value="$(V_N2TCOMP)" type="text" size="5" maxlength="2"> <a href="$(homeURL)$(phpPath)CoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=toCompanyNumber&amp;fldFac=toFacilityNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="coFacDesc" value="$(fieldDesc)"  type="hidden" size="30" maxlength="30"></td>
                                  %endif
                                  <td class="inputalph"><input name="allCompanyNumber" VALUE='ALL' $(checkedallCompanyNumber) type="checkbox" onClick="if (this.checked) this.form.fromCompanyNumber.value='', this.form.toCompanyNumber.value='';"></td>
                                  @Build_Sort_Select("sortCompanyNumber", "$(V_N2CSEQ)")
                              </tr>
                              @DspErrMsg(Err_N2CSEQ)

                              <tr><td class="dsphdr">Facility Number</td>
                                  %if (V_HDPERL > "0" || V_HDPRRL > "0") 
                                      <td class="inputnmbr"><input name="fromFacilityNumber" value="$(V_N2FFACL)" type="text" size="5" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=fromCompanyNumber&amp;fldFac=fromFacilityNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="coFacDesc" value="$(fieldDesc)"  type="hidden" size="30" maxlength="30"></td>
                                      <td class="inputnmbr"><input name="toFacilityNumber" value="$(V_N2TFACL)" type="text" size="5" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=toCompanyNumber&amp;fldFac=toFacilityNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="coFacDesc" value="$(fieldDesc)"  type="hidden" size="30" maxlength="30"></td>
                                  %else
                                      <td class="inputnmbr"><input name="fromFacilityNumber" value="$(V_N2FFACL)" type="text" size="5" maxlength="4"> <a href="$(homeURL)$(phpPath)CoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=fromCompanyNumber&amp;fldFac=fromFacilityNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="coFacDesc" value="$(fieldDesc)"  type="hidden" size="30" maxlength="30"></td>
                                      <td class="inputnmbr"><input name="toFacilityNumber" value="$(V_N2TFACL)" type="text" size="5" maxlength="4"> <a href="$(homeURL)$(phpPath)CoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=toCompanyNumber&amp;fldFac=toFacilityNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="coFacDesc" value="$(fieldDesc)"  type="hidden" size="30" maxlength="30"></td>
                                  %endif
                                  <td class="inputalph"><input name="allFacilityNumber" VALUE='ALL' $(checkedallFacilityNumber) type="checkbox" onClick="if (this.checked) this.form.fromFacilityNumber.value='', this.form.toFacilityNumber.value='';"></td>
                              </tr>

                              <tr><td class="dsphdr">Department</td>
                                  %if (V_HDPERL == "0" && V_HDPRRL == "0")
                                      <td class="inputalph"><input name="fromDepartment" VALUE="$(V_N2FDEPT)" type="text" size="5" maxlength="5"></td>
                                      <td class="inputalph"><input name="toDepartment" VALUE="$(V_N2TDEPT)" type="text" size="5" maxlength="5"></td>
                                  %else
                                      <td class="inputalph"><input name="fromDepartment" value="$(V_N2FDEPT)" type="text" size="5" maxlength="5"> <a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromDepartment&amp;fldDesc=fromDeptDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input  name="fromDeptDesc" value="$(fromDeptDesc)"  type="hidden" size="20" maxlength="20"></td>
                                      <td class="inputalph"><input name="toDepartment"   value="$(V_N2TDEPT)" type="text" size="5" maxlength="5"> <a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toDepartment&amp;fldDesc=toDeptDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input  name="toDeptDesc" value="$(toDeptDesc)"  type="hidden" size="20" maxlength="20"></td>
                                  %endif
                                  <td class="inputalph"><input name="allDepartment" VALUE='ALL' $(checkedallDepartment) type="checkbox" onClick="if (this.checked) this.form.fromDepartment.value='', this.form.toDepartment.value='';"></td>
                              </tr>

                              <tr><td class="dsphdr">Employee Number</td>
                                  <td class="inputnmbr"><input name="fromEmployeeNumber" value="$(V_N2FEMPL)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)EmployeeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=prCompany&amp;fldFacl=prFacility&amp;fldEmpl=fromEmployeeNumber&amp;fldHRCo=hrCompany&amp;fldHREmpl=hrEmployee&amp;fldEmplName=prName&amp;fldCoName=coFacDescription" onclick="$(searchWinVar)"> $(searchImage)</a><input name="prCompany" type="hidden"><input name="prFacility" type="hidden"><input name="hrEmployee" type="hidden"><input name="hrCompany"  type="hidden"><input name="prName"  type="hidden"><input name="coFacDescription"  type="hidden"></td>
                                  <td class="inputnmbr"><input name="toEmployeeNumber" value="$(V_N2TEMPL)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)EmployeeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=prCompany&amp;fldFacl=prFacility&amp;fldEmpl=toEmployeeNumber&amp;fldHRCo=hrCompany&amp;fldHREmpl=hrEmployee&amp;fldEmplName=prName&amp;fldCoName=coFacDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="prCompany" type="hidden"><input name="prFacility" type="hidden"><input name="hrEmployee" type="hidden"><input name="hrCompany" type="hidden"><input name="prName"  type="hidden"><input name="coFacDescription"  type="hidden"></td>
                                  <td class="inputalph"><input name="allEmployeeNumber" value='ALL' $(checkedallEmployeeNumber) type="checkbox" onClick="if (this.checked) this.form.fromEmployeeNumber.value='', this.form.toEmployeeNumber.value='';"></td>
                              </tr>


                              %if (V_HDPERL > "0")
                                  @SetTextOvr(Err_N2HSEQ)
                                  <tr><td class="dsphdr">H/R Company Number</td>
                                      <td class="inputnmbr"><input name="fromHRCompanyNumber" value="$(V_N2FPECP)" type="text" size="5" maxlength="2"><a href="$(homeURL)$(phpPath)HRCompanySearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=fromHRCompanyNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="coFacDesc" value="$(fieldDesc)"  type="hidden" size="30" maxlength="30"></td>
                                      <td class="inputnmbr"><input name="toHRCompanyNumber" value="$(V_N2TPECP)" type="text" size="5" maxlength="2"><a href="$(homeURL)$(phpPath)HRCompanySearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=toHRCompanyNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="coFacDesc" value="$(fieldDesc)"  type="hidden" size="30" maxlength="30"></td>
                                      <td class="inputalph"><input name="allHRCompanyNumber" value='ALL' $(checkedallHRCompanyNumber) type="checkbox" onClick="if (this.checked) this.form.fromHRCompanyNumber.value='', this.form.toHRCompanyNumber.value='';"></td>
                                      @Build_Sort_Select("sortHRCompanyNumber", "$(V_N2HSEQ)")
                                  </tr>
                                  @DspErrMsg(Err_N2HSEQ)

                                  <tr><td class="dsphdr"><span $(textOvr)>Location Code</span></td>
                                      <td class="inputalph"><input name="fromLocationCode" VALUE="$(V_N2FLOC)"type="text" size="5" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Chg&amp;fldType=O&amp;fldName=fromLocationCode&amp;fldDesc=locCodeDesc2" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="locCodeDesc2" value="$(codeDesc)"  type="hidden" size="20" maxlength="20"></td>
                                      <td class="inputalph"><input name="toLocationCode" VALUE="$(V_N2TLOC)" type="text" size="5" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Chg&amp;fldType=O&amp;fldName=toLocationCode&amp;fldDesc=locCodeDesc2" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="locCodeDesc2" value="$(codeDesc)"  type="hidden" size="20" maxlength="20"></td>
                                      <td class="inputalph"><input name="allLocationCode" VALUE='ALL' $(checkedallLocationCode) type="checkbox" onClick="if (this.checked) this.form.fromLocationCode.value='', this.form.toLocationCode.value='';"></td>
                                  </tr>

                                  <tr><td class="dsphdr"><span $(textOvr)>H/R Employee Number</span></td>
                                      <td class="inputalph"><input name="fromHREmployeeNumber" VALUE="$(V_N2FPEMP)" type="text" size="5" maxlength="9"><a href="$(homeURL)$(phpPath)EmployeeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=prCompany&amp;fldFacl=prFacility&amp;fldHRCo=hrCompany&amp;fldHREmpl=fromHREmployeeNumber&amp;fldEmplName=prName&amp;fldCoName=coFacDescription" onclick="$(searchWinVar)"> $(searchImage)</a><input name="prCompany" type="hidden"><input name="prFacility" type="hidden"><input name="prEmployee" type="hidden"><input name="hrCompany"  type="hidden"><input name="prName"  type="hidden"><input name="coFacDescription"  type="hidden"> </td>
                                      <td class="inputalph"><input name="toHREmployeeNumber" VALUE="$(V_N2TPEMP)" type="text" size="5" maxlength="9"><a href="$(homeURL)$(phpPath)EmployeeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=prCompany&amp;fldFacl=prFacility&amp;fldHRCo=hrCompany&amp;fldHREmpl=toHREmployeeNumber&amp;fldEmplName=prName&amp;fldCoName=coFacDescription" onclick="$(searchWinVar)"> $(searchImage)</a><input name="prCompany" type="hidden"><input name="prFacility" type="hidden"><input name="prEmployee" type="hidden"><input name="hrCompany"  type="hidden"><input name="prName"  type="hidden"><input name="coFacDescription"  type="hidden"></td>
                                      <td class="inputalph"><input name="allHREmployeeNumber" VALUE='ALL' $(checkedallHREmployeeNumber) type="checkbox" onClick="if (this.checked) this.form.fromHREmployeeNumber.value='', this.form.toHREmployeeNumber.value='';"></td>
                                  </tr>

                              %else
                                  <tr><td class="colcode"><input name="sortHRCompanyNumber" type="hidden"  size="1" maxlength="1" VALUE="0"></td></tr>
                              %endif

                              %if (apid == "ME")
                                  @SetTextOvr(Err_N2PSEQ)
                                  <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                      <td class="inputnmbr"><input name="fromPlantNumber" value="$(V_N2FPLT)" type="text" size="5" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromPlantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName" type="hidden"></td>
                                      <td class="inputnmbr"><input name="toPlantNumber" value="$(V_N2TPLT)" type="text" size="5" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toPlantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName" type="hidden"></td>
                                      <td class="inputalph"><input name="allPlantNumber" value='ALL' $(checkedallPlantNumber) type="checkbox" onClick="if (this.checked) this.form.fromPlantNumber.value='', this.form.toPlantNumber.value='';"></td>
                                      @Build_Sort_Select("sortPlantNumber", "$(V_N2PSEQ)")
                                  </tr>

                                  <tr><td class="dsphdr">Mfg Department</td>
                                      <td class="inputalph"><input name="fromMfgDepartment" value="$(V_N2FMFDP)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=fromMfgDepartment&amp;fldWC=fromWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                      <td class="inputalph"><input name="toMfgDepartment" value="$(V_N2TMFDP)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=toMfgDepartment&amp;fldWC=toWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                      <td class="inputalph"><input name="allMfgDepartment" value='ALL' $(checkedallMfgDepartment) type="checkbox" onClick="if (this.checked) this.form.fromMfgDepartment.value='', this.form.toMfgDepartment.value='';"></td>
                                  </tr>

                                  <tr><td class="dsphdr">Work Center </td>
                                      <td class="inputalph"><input name="fromWorkCenter" value="$(V_N2FWC)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=fromMfgDepartment&amp;fldWC=fromWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                      <td class="inputalph"><input name="toWorkCenter" value="$(V_N2TWC)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=toMfgDepartment&amp;fldWC=toWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                      <td class="inputalph"><input name="allWorkCenter" value='ALL' $(checkedallWorkCenter) type="checkbox" onClick="if (this.checked) this.form.fromWorkCenter.value='', this.form.toWorkCenter.value='';"></td>
                                  </tr>
                              %else
                                  <tr><td class="colcode"><input name="sortPlantNumber" type="hidden"  size="1" maxlength="1" VALUE="0"></td></tr>
                              %endif

                          </table>

                          @dtw_assign(envProgram, "HETSE1")
                          @dtw_assign(envPrinter, "HETSE1PF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HETSES_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allSchedule)
  @dtw_mUPPERCASE(fromEventCode)
  @dtw_mUPPERCASE(toEventCode)
  @dtw_mUPPERCASE(allEventCode)
  @dtw_mUPPERCASE(allCompanyNumber)
  @dtw_mUPPERCASE(allFacilityNumber)
  @dtw_mUPPERCASE(fromDepartment)
  @dtw_mUPPERCASE(toDepartment)
  @dtw_mUPPERCASE(allDepartment)
  @dtw_mUPPERCASE(allEmployeeNumber)
  @dtw_mUPPERCASE(allHRCompanyNumber)
  @dtw_mUPPERCASE(fromLocationCode)
  @dtw_mUPPERCASE(toLocationCode)
  @dtw_mUPPERCASE(allLocationCode)
  @dtw_mUPPERCASE(allHREmployeeNumber)
  @dtw_mUPPERCASE(allPlantNumber)
  @dtw_mUPPERCASE(fromMfgDepartment)
  @dtw_mUPPERCASE(toMfgDepartment)
  @dtw_mUPPERCASE(allMfgDepartment)
  @dtw_mUPPERCASE(fromWorkCenter)
  @dtw_mUPPERCASE(toWorkCenter)
  @dtw_mUPPERCASE(allWorkCenter)

  @dtw_assign(fromSchedule,@dtw_rstrip(fromSchedule))
  @dtw_assign(toSchedule,@dtw_rstrip(toSchedule))
  @dtw_assign(sortSchedule,@dtw_rstrip(sortSchedule))
  @dtw_assign(fromExceptionDate,@dtw_rstrip(fromExceptionDate))
  @dtw_assign(toExceptionDate,@dtw_rstrip(toExceptionDate))
  @dtw_assign(fromCompanyNumber,@dtw_rstrip(fromCompanyNumber))
  @dtw_assign(toCompanyNumber,@dtw_rstrip(toCompanyNumber))
  @dtw_assign(sortCompanyNumber,@dtw_rstrip(sortCompanyNumber))
  @dtw_assign(fromFacilityNumber,@dtw_rstrip(fromFacilityNumber))
  @dtw_assign(toFacilityNumber,@dtw_rstrip(toFacilityNumber))
  @dtw_assign(fromEmployeeNumber,@dtw_rstrip(fromEmployeeNumber))
  @dtw_assign(toEmployeeNumber,@dtw_rstrip(toEmployeeNumber))
  @dtw_assign(fromHRCompanyNumber,@dtw_rstrip(fromHRCompanyNumber))
  @dtw_assign(toHRCompanyNumber,@dtw_rstrip(toHRCompanyNumber))
  @dtw_assign(sortHRCompanyNumber,@dtw_rstrip(sortHRCompanyNumber))
  @dtw_assign(fromHREmployeeNumber,@dtw_rstrip(fromHREmployeeNumber))
  @dtw_assign(toHREmployeeNumber,@dtw_rstrip(toHREmployeeNumber))
  @dtw_assign(fromPlantNumber,@dtw_rstrip(fromPlantNumber))
  @dtw_assign(toPlantNumber,@dtw_rstrip(toPlantNumber))
  @dtw_assign(sortPlantNumber,@dtw_rstrip(sortPlantNumber))

  %if (allSchedule != "ALL")
      @dtw_assign(allSchedule, "")
  %endif
  %if (allEventCode != "ALL")
      @dtw_assign(allEventCode, "")
  %endif
  %if (allCompanyNumber != "ALL")
      @dtw_assign(allCompanyNumber, "")
  %endif
  %if (allFacilityNumber != "ALL")
      @dtw_assign(allFacilityNumber, "")
  %endif
  %if (allDepartment != "ALL")
      @dtw_assign(allDepartment, "")
  %endif
  %if (allEmployeeNumber != "ALL")
      @dtw_assign(allEmployeeNumber, "")
  %endif
  %if (allHRCompanyNumber != "ALL")
      @dtw_assign(allHRCompanyNumber, "")
  %endif
  %if (allLocationCode != "ALL")
      @dtw_assign(allLocationCode, "")
  %endif
  %if (allHREmployeeNumber != "ALL")
      @dtw_assign(allHREmployeeNumber, "")
  %endif
  %if (allPlantNumber != "ALL")
      @dtw_assign(allPlantNumber, "")
  %endif
  %if (allMfgDepartment != "ALL")
      @dtw_assign(allMfgDepartment, "")
  %endif
  %if (allWorkCenter != "ALL")
      @dtw_assign(allWorkCenter, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@perl", perelease)
  @Concat_Field("@@apid", apid)
  @Concat_Field("@@sel@", reportContent)
  @Concat_Field("@@fscd", fromSchedule)
  @Concat_Field("@@tscd", toSchedule)
  @Concat_Field("@@ascd", allSchedule)
  @Concat_Field("@@sseq", sortSchedule)
  @Concat_Field("@@fexd", fromExceptionDate)
  @Concat_Field("@@texd", toExceptionDate)
  @Concat_Field("@@fevc", fromEventCode)
  @Concat_Field("@@tevc", toEventCode)
  @Concat_Field("@@aevc", allEventCode)
  @Concat_Field("@@fcom", fromCompanyNumber)
  @Concat_Field("@@tcom", toCompanyNumber)
  @Concat_Field("@@acom", allCompanyNumber)
  @Concat_Field("@@cseq", sortCompanyNumber)
  @Concat_Field("@@ffac", fromFacilityNumber)
  @Concat_Field("@@tfac", toFacilityNumber)
  @Concat_Field("@@afac", allFacilityNumber)
  @Concat_Field("@@fdep", fromDepartment)
  @Concat_Field("@@tdep", toDepartment)
  @Concat_Field("@@adep", allDepartment)
  @Concat_Field("@@femp", fromEmployeeNumber)
  @Concat_Field("@@temp", toEmployeeNumber)
  @Concat_Field("@@aemp", allEmployeeNumber)

  %if (perelease != "0")
      @Concat_Field("@@fpec", fromHRCompanyNumber)
      @Concat_Field("@@tpec", toHRCompanyNumber)
      @Concat_Field("@@apec", allHRCompanyNumber)
      @Concat_Field("@@hseq", sortHRCompanyNumber)
      @Concat_Field("@@floc", fromLocationCode)
      @Concat_Field("@@tloc", toLocationCode)
      @Concat_Field("@@aloc", allLocationCode)
      @Concat_Field("@@fpem", fromHREmployeeNumber)
      @Concat_Field("@@tpem", toHREmployeeNumber)
      @Concat_Field("@@apem", allHREmployeeNumber)
  %endif

  %if (apid == "ME")
      @Concat_Field("@@fplt", fromPlantNumber)
      @Concat_Field("@@tplt", toPlantNumber)
      @Concat_Field("@@aplt", allPlantNumber)
      @Concat_Field("@@pseq", sortPlantNumber)
      @Concat_Field("@@fmfd", fromMfgDepartment)
      @Concat_Field("@@tmfd", toMfgDepartment)
      @Concat_Field("@@amfd", allMfgDepartment)
      @Concat_Field("@@fwc@", fromWorkCenter)
      @Concat_Field("@@twc@", toWorkCenter)
      @Concat_Field("@@awc@", allWorkCenter)
  %endif

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}