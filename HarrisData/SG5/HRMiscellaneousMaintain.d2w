%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title 		   = "Miscellaneous Data Maintenance"
  d2wName                 = "HRMiscellaneousMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)$(employeeVarBase)&amp;sequenceNumber=@dtw_rurlescseq(sequenceNumber)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;miscellaneousCode=@dtw_rurlescseq(miscellaneousCode)&amp;miscellaneousName=@dtw_rurlescseq(miscellaneousName)&amp;maintenanceCode=D"
  programName             = "HPEMDU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  hrCodeType              = "K"
  updateError             = " "
  UVCo                    = "00"
  UVFAC                   = "0000"
  UVPREmpl                = "00000"
  applicationID           = "PE"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
  @dtw_replace(workURL, "@@sequenceNumber", "@dtw_rurlescseq(sequenceNumber)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
                  %INCLUDE "Menu.js"
                  %INCLUDE "numedit.icl"
                  %INCLUDE "dateedit.icl"
                  %INCLUDE "calendar.icl"
                  %INCLUDE "CheckEnterChg.icl"
                  function validate(chgForm) {
                      if (document.Chg.miscellaneousName.value =="" ||
                          document.Chg.effectiveDate.value =="" ||
                          document.Chg.miscellaneousCode.value =="")
                         {alert("$(reqFieldError)"); return false;}
                      if (editdate(document.Chg.effectiveDate) &&
                          editNum(document.Chg.premiumAmount, 5, 2) &&
                          editNum(document.Chg.amount, 7, 0))
                          return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "MISCMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "SELECT * FROM PEMISC WHERE MICOMP = $(hrCompany) AND MIEMPL = $(hrEmployee) AND MISEQ = $(sequenceNumber)", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
    %endif
  %}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)

{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
             
               <form class="formClass" METHOD=POST NAME="EmployeeCopyTo" ACTION="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;maintenanceCode=Z">
                     <input name="prCompanyCopyTo" type="hidden" size="2"><input name="prFacilityCopyTo" type="hidden" size="4"><input name="prEmployeeCopyTo" type="hidden" size="5"><input name="hrCompanyCopyTo" type="hidden" size="2"><input name="hrEmployeeCopyTo" type="hidden" size="9">
                </form>
    
                 %if (sec_01=="Y" && sec_04=="Y" && maintenanceCode != "A")
            
    			%endif
     
     
                       %INCLUDE "MaintainTopNoTable.icl"
              </td>
          </tr>
          %if (prCompanyCopyTo>"0")
              @dtw_assign(prCompany, prCompanyCopyTo)
              @dtw_assign(prFacility, prFacilityCopyTo)
              @dtw_assign(prEmployee, prEmployeeCopyTo)
              @dtw_assign(hrCompany, hrCompanyCopyTo)
              @dtw_assign(hrEmployee, hrEmployeeCopyTo)
          %endif
          @Ret_Format_EmplName(UVCo, UVFac, UVPREmpl, hrCompany, hrEmployee, "H", F_EmpName)
          <tr><td><h2>$(F_EmpName)</h2></td></tr>
      </table>

      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;F_EmpName=@dtw_rurlescseq(F_EmpName)">
          <table $(contentTable)>

             %ROW {
                
                %if (errFound != "" || maintenanceCode == "A")
                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(edtVar, "")
                      @dtw_assign(focusField, "miscellaneousCode")
                  %else
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@code", "miscellaneousCode")   @dtw_assign(Err_MICODE, fieldValue)
                      @DecatErr_Field("@@type", "miscellaneousName")   @dtw_assign(Err_MITYPE, fieldValue)
                      @DecatErr_Field("@@efdt", "effectiveDate")       @dtw_assign(Err_MIEFDT, fieldValue)
                      @DecatErr_Field("@@prem", "premiumAmount")       @dtw_assign(Err_MIPREM, fieldValue)
                      @DecatErr_Field("@@amt@", "amount")              @dtw_assign(Err_MIAMT, fieldValue)
                      @DecatErr_Field("@@benf", "beneficiary")         @dtw_assign(Err_MIBENF, fieldValue)
                      @DecatErr_Field("@@cmt1", "commentOne")          @dtw_assign(Err_MICMT1, fieldValue)
                      @DecatErr_Field("@@cmt2", "commentTwo")          @dtw_assign(Err_MICMT2, fieldValue)
                      @DecatErr_Field("@@tstp", "timeStamp")           @dtw_assign(Err_TSTP, fieldValue)
                  %endif

                  @Decat_Field("@@code")   @dtw_assign(V_MICODE, fieldValue)
                  @Decat_Field("@@type")   @dtw_assign(V_MITYPE, fieldValue)
                  @Decat_Field("@@efdt")   @dtw_assign(V_MIEFDT, fieldValue)
                  @Decat_Field("@@prem")   @dtw_assign(V_MIPREM, fieldValue)
                  @Decat_Field("@@amt@")   @dtw_assign(V_MIAMT, fieldValue)
                  @Decat_Field("@@benf")   @dtw_assign(V_MIBENF, fieldValue)
                  @Decat_Field("@@cmt1")   @dtw_assign(V_MICMT1, fieldValue)
                  @Decat_Field("@@cmt2")   @dtw_assign(V_MICMT2, fieldValue)
                  @Decat_Field("@@tstp")   @dtw_assign(V_MITSTP, fieldValue)

                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(V_MICOMP,   "00")
                      @dtw_assign(V_MIFACL,  "0000")
                      @dtw_assign(V_MIEMPL,  "000000000")
                      @dtw_assign(V_MISEQ,  "0000")
                      @dtw_assign(sequenceNumber, "0000")
                      @dtw_assign(V_MICODE, "    ")
                  %endif

                  @dtw_assign(errFound, "")

              %elif (maintenanceCode == "Z")
                  %if (prCompanyCopyTo<="0")
                      @dtw_assign(V_MICODE, "    ")
                  %endif
                  @dtw_assign(focusField, "miscellaneousName")
                  @DateInputFromCYMD(V_MIEFDT)
              %else
                  @dtw_assign(focusField, "miscellaneousName")
                  @DateInputFromCYMD(V_MIEFDT)
                  
              %endif

              	  @SetTextOvr(Err_TSTP)
                  <tr><td class="dsphdr"><span $(textOvr)>.</span></td>
                  	  <td><input name="timeStamp" type="hidden" value="$(V_MITSTP)"></td> 
                  </tr>
                  @DspErrMsg(Err_TSTP)
                  
                  @RtvFldDesc("ODCOMP=$(V_MICOMP) and ODTYPE='$(hrCodeType)' and ODCODE='$(V_MICODE)' ", "PECODE", "CHAR(ODDESC)", codeDesc)
                  @SetTextOvr(Err_MICODE)
                  <tr><td class="dsphdr"><span $(textOvr)>Miscellaneous Code</span></td>
                      <td class="inputalph"><input name="miscellaneousCode" type="text" value="$(V_MICODE)" size="4" maxlength="4"> $(reqFieldChar) <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Chg&amp;fldComp=@dtw_rurlescseq(hrCompany)&amp;fldType=K&amp;fldName=miscellaneousCode&amp;fldDesc=MiscellaneousCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="MiscellaneousCodeDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                  </tr>
                  @DspErrMsg(Err_MICODE)

                  @SetTextOvr(Err_MITYPE)
                  <tr><td class="dsphdr"><span $(textOvr)>Miscellaneous Name</span></td>
                      <td class="inputalph"><input name="miscellaneousName" type="text" value="$(V_MITYPE)" size="12" maxlength="12"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_MITYPE)

                  @SetTextOvr(Err_MIEFDT)
                  <tr><td class="dsphdr"><span $(textOvr)>Effective Date</span></td>
                      <td class="inputnmbr"><input name="effectiveDate" type="text" value="$(V_MIEFDT)" size="6" maxlength="6">
                          <a href="javascript:calWindow('effectiveDate');"> $(reqFieldChar) $(calendarImage) </a></td>
                  </tr>
                  @DspErrMsg(Err_MIEFDT)

                  @SetTextOvr(Err_MIPREM)
                  <tr><td class="dsphdr"><span $(textOvr)>Premium Amount</span></td>
                      <td class="inputnmbr"><input name="premiumAmount" type="text" value="$(V_MIPREM)" size="7" maxlength="7"></td>
                  </tr>
                  @DspErrMsg(Err_MIPREM)

                  @SetTextOvr(Err_MIAMT)
                  <tr><td class="dsphdr"><span $(textOvr)>Amount</span></td>
                      <td class="inputnmbr"><input name="amount" type="text" value="$(V_MIAMT)" size="7" maxlength="7"></td>
                  </tr>
                  @DspErrMsg(Err_MIAMT)

                  @SetTextOvr(Err_MIBENF)
                  <tr><td class="dsphdr"><span $(textOvr)>Beneficiary</span></td>
                      <td class="inputalph"><input name="beneficiary" type="text" value="$(V_MIBENF)" size="13" maxlength="13"></td>
                  </tr>
                  @DspErrMsg(Err_MIBENF)

                  @SetTextOvr(Err_MICMT1)
                  <tr><td class="dsphdr"><span $(textOvr)>Comment 1</span></td>
                      <td class="inputalph"><input name="commentOne" type="text" value="$(V_MICMT1)" size="50" maxlength="50"></td>
                  </tr>
                  @DspErrMsg(Err_MICMT1)

                  @SetTextOvr(Err_MICMT2)
                  <tr><td class="dsphdr"><span $(textOvr)>Comment 2</span></td>
                      <td class="inputalph"><input name="commentTwo" type="text" value="$(V_MICMT2)" size="50" maxlength="50"></td>
                  </tr>
                  @DspErrMsg(Err_MICMT2)
              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,
                                        INOUT CHAR(32000) errVar,
                                        INOUT DEC(4,0)    seq)
  {%EXEC {HPEMDU_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @hrCode_Query(profileHandle, dataBaseID, hrCompany, hrCodeType, hrCodeTable)	
	   @dtw_tb_insertrow(hrCodeTable, "0", "1")
          @dtw_tb_setv(hrCodeTable, "", "1", "1")
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  %if (miscellaneousName == "")
      @RtvFldDesc("MICOMP=$(hrCompany) and MIEMPL=$(hrEmployee) and MISEQ='$(sequenceNumber)' ", "PEMISC", "MITYPE", miscellaneousName)
  %endif

  @dtw_mUPPERCASE(miscellaneousName)
  @dtw_assign(updateError, " ")

  @dtw_assign(effectiveDate,@dtw_rstrip(effectiveDate))
  @dtw_assign(premiumAmount,@dtw_rstrip(premiumAmount))
  @dtw_assign(amount,@dtw_rstrip(amount))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
      @dtw_assign(sequenceNumber, "0")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@comp", hrCompany)
  @Concat_Field("@@empl", hrEmployee)
  @Concat_Field("@@seq@", sequenceNumber)
  @Concat_Field("@@code", miscellaneousCode)
  @Concat_Field("@@type", miscellaneousName)
  @Concat_Field("@@efdt", effectiveDate)
  @Concat_Field("@@prem", premiumAmount)
  @Concat_Field("@@amt@", amount)
  @Concat_Field("@@benf", beneficiary)
  @Concat_Field("@@cmt1", commentOne)
  @Concat_Field("@@cmt2", commentTwo)
  @Concat_Field("@@tstp", timeStamp)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar, seq)

  @RtvFldDesc("ODCOMP=$(hrCompany) and ODTYPE='K' and ODCODE='$(miscellaneousCode)' ", "PECODE", "ODDESC", HrCodeDesc)
  @DecatErr_Field("@@type", "miscellaneousName")  @dtw_assign(Err_MITYPE, fieldValue)

  %if (errFound == "")
      @dtw_assign(sequenceNumber, seq)
      @Format_ConfMsg_Desc(maintenanceCode, "Name ", "$(miscellaneousName)", $(HrCodeDesc), $(miscellaneousCode), "For $(F_EmpName)", "", confMessage)
      %if (maintenanceCode == "D")
          %if ((fromD2w != "") && (fromD2w != "HRMiscellaneousSelect.d2w"))
              <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %else
              <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)HRMiscellaneous.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %endif
      %elif (fromD2w != "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;miscellaneousCode=@dtw_rurlescseq(miscellaneousCode)&amp;miscellaneousName=@dtw_rurlescseq(miscellaneousName)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)HRMiscellaneous.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@type", "miscellaneousName")
      @Format_ConfMsg_Desc("", "Name ", "$(miscellaneousName)", $(HrCodeDesc), $(miscellaneousCode), "<br>$(fieldValue)", "", confMessage)
      %if (fromD2w != "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)HRMiscellaneous.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %elif ((maintenanceCode == "C" || maintenanceCode == "D") && errFound != "" && fieldValue != "")
      @Format_ConfMsg_Desc("E", "Name ", $(miscellaneousName), $(HrCodeDesc), $(miscellaneousCode), "<br>$(fieldValue)", "", confMessage)
      %if (fromD2w != "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)HRMiscellaneous.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;miscellaneousCode=@dtw_rurlescseq(miscellaneousCode)&amp;miscellaneousName=@dtw_rurlescseq(miscellaneousName)&amp;errFound=@dtw_rurlescseq(errFound)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif

%}