%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title 	        = "Employee Miscellaneous"
  d2wName              = "HRCompMiscellaneous.d2w"
  d2wVarBase           = "$(genericVarBase)&amp;hrCompany=@dtw_rurlescseq(hrCompany)&amp;inclActive=@dtw_rurlescseq(inclActive)&amp;inclTerminated=@dtw_rurlescseq(inclTerminated)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(d2wName)"
  nextPrevVar          = "$(d2wVarBase)"
  wildDftVar           = "REPORT$(d2wVarBase)"
  programName          = "HPEMDU"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  facilityZero         = "0000"
  inclActive           = ""
  inclTerminated       = ""
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext		= "1"
  totalPages		= "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@hrCompany", "@dtw_rurlescseq(hrCompany)", "1", "a", workURL)
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
  @dtw_replace(workURL, "@@fromD2w", "@dtw_rurlescseq(fromD2w)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchEmployee, 9, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                       @dtw_assign(pageID, "HRCOMPMISC")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "UserViewEmpl.icl"
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select MICOMP, MIEMPL,  MISEQ,  MITYPE, MIEFDT, MIPREM, MIAMT,  MIBENF, MICODE, ", stmtSQL)
                      @dtw_concat(stmtSQL, "       MICODE, MICMT1,  MICMT2, EMCOMP, EMFACL, EMEMPL, EMPECP, EMPEMP, EMLNAM, EMLNAMU, ", stmtSQL)
                      @dtw_concat(stmtSQL, "       EMFNAM, EMFNAMU, EMMIDI, EMRNAM, EMDEPT, EMLOC, EMTYPE, EMTRCD, ODDESC, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(MITYPE) as MITYPEU", stmtSQL)
                      @dtw_concat(fileSQL, " PEMISC inner join HREMPL on MICOMP=EMPECP and MIEMPL=EMPEMP ", fileSQL)
                      @dtw_concat(fileSQL, "        inner join PECODE on MICOMP=ODCOMP and MICODE=ODCODE and ODTYPE='K' ", fileSQL)
                      @dtw_concat(selectSQL, " MICOMP = $(hrCompany) ", selectSQL)
                      %INCLUDE "activeTerminatedEmplSQL.icl"
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @EmplMisc_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) EmplMisc_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count != "1")
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>

              @RetHrCompNam(profileHandle, dataBaseID, hrCompany, facilityZero, coFacName)
              <tr><td><h2>$(coFacName)</h2></td></tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"
          $(hrTagAttr)

          %if (formatToPrint != "Y")
	       <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Last<br>Name</th>
                          <th class="colhdr">Miscellaneous<br>Name</th>
                          <th class="colhdr">Employee<br>Number</th>
                      </tr>
                      <tr><td class="inputalph"><input type="text" name="srchLast" size="18" maxlength="18">
                              <input type="hidden" name="operLast" value="LIKE">
                          </td>
                          <td class="inputalph"><input type="text" name="srchMiscName" size="12" maxlength="12">
                              <input type="hidden" name="operMiscName" value="LIKE">
                          </td>
                          <td class="inputalph"><input type="text" name="srchEmployee" size="9" maxlength="9">
                              <input type="hidden" name="operEmployee" value="=">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchLast.focus();
                  </script>
              </form>

              %INCLUDE "ActiveTerminatedChecked.icl"
              @dtw_assign(viewCheckBox, "HR")
              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              <tr>
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("MIEMPL", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Employee" title="Sequence By Employee Number, Miscellaneous Name">Employee<br>Number</a></th>
                  @OrderBy_Sort("EMLNAMU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=LastName" title="Sequence By Employee Last Name, First Name, Miscellaneous Name">Name</a></th>
                  @OrderBy_Sort("MICODE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MiscCode" title="Sequence By Miscellaneous Type">Miscellaneous<br>Type</a></th>
                  @OrderBy_Sort("ODDESC", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CodeDesc" title="Sequence By Type Description">Type<br>Description</a></th>
                  @OrderBy_Sort("MITYPE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MiscName" title="Sequence By Miscellaneous Name">Miscellaneous<br>Name</a></th>
                  @OrderBy_Sort("MIEFDT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=EffectiveDate" title="Sequence By Effective Date, Miscellaneous Name">Effective<br>Date</a></th>
                  @OrderBy_Sort("MIPREM", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PremiumAmount" title="Sequence By Premium Amount">Premium<br>Amount</a></th>
                  @OrderBy_Sort("MIAMT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Amount" title="Sequence By Amount">Amount</a></th>
                  @OrderBy_Sort("MIBENF", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Beneficiary" title="Sequence By Beneficiary">Beneficiary</a></th>
              </tr>
          %INCLUDE "NoRecordsFound.icl"
      %endif

	       %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;prCompany=@dtw_rurlescseq(V_EMCOMP)&amp;prFacility=@dtw_rurlescseq(V_EMFACL)&amp;prEmployee=@dtw_rurlescseq(V_EMEMPL)&amp;hrEmployee=@dtw_rurlescseq(V_EMPEMP)&amp;sequenceNumber=@dtw_rurlescseq(V_MISEQ)&amp;miscellaneousCode=@dtw_rurlescseq(V_MICODE)&amp;miscellaneousName=@dtw_rurlescseq(V_MITYPE)")
                  %if (sql_Record_Count == "1")
                      @Save_WebReg(webRegCurFile, profileHandle, d2wName, "", orderBy, orderByDisplay, "")
                      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)HRMiscellaneousSelect.d2w/REPORT$(maintainVar)">
                  %else
                      @Format_Date(V_MIEFDT, "D", F_MIEFDT)
                      %if (V_MIPREM == ".00")
                          @dtw_assign(V_MIPREM, "")
                      %endif
                      %if (V_MIAMT == "0")
                          @dtw_assign(V_MIAMT, "")
                      %endif

                      @Format_Confirm_Desc($(V_MITYPE), "", $(V_ODDESC), $(V_MICODE), "", "", confirmDesc)

                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                              <td class="opticon">
                                  %if (sec_02 == "Y" || sec_03 == "Y")
                                      <a href="$(homeURL)$(cGIPath)HRMiscellaneousMaintain.d2w/REPORT$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                                  %endif
                                  %if (sec_01=="Y" && sec_04=="Y")
                                      <a href="$(homeURL)$(cGIPath)HRMiscellaneousMaintain.d2w/REPORT$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                                  %endif
                                  %if (sec_03 == "Y")
                                      <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)HRMiscellaneousMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                                  %endif
                              </td>
                          %endif
                          @Format_EmplName(V_EMFNAM, V_EMLNAM, V_EMMIDI, V_EMRNAM, V_EMTRCD, "D", F_EmpName)
                          <td class="colnmbr">$(V_MIEMPL)</td>
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)HRMiscellaneous.d2w/REPORT$(maintainVar)" title="View All Miscellaneous For This Employee">$(F_EmpName)</a></td>
                          <td class="colcode">$(V_MICODE)</td>
                          <td class="colalph">$(V_ODDESC)</td>
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)HRMiscellaneousSelect.d2w/REPORT$(maintainVar)" title="View Miscellaneous Row">$(V_MITYPE)</a></td>
                          <td class="coldate">$(F_MIEFDT)</td>
                          @Format_Nbr($(V_MIPREM), F_MIPREM, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_MIPREM)</td>
                          @Format_Nbr($(V_MIAMT), F_MIAMT, "0", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_MIAMT)</td>
                          <td class="colalph">$(V_MIBENF)</td>
                      </tr>
                  %endif
	       %}
	   </table>
          %if (sql_Record_Count != "1")
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "UserViewEmpl.icl"
  %INCLUDE "userview.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "Select MICOMP, MIEMPL,  MISEQ,  MITYPE, MIEFDT, MIPREM, MIAMT,  MIBENF, MICODE, ", stmtSQL)
  @dtw_concat(stmtSQL, "       MICODE, MICMT1,  MICMT2, EMCOMP, EMFACL, EMEMPL, EMPECP, EMPEMP, EMLNAM, EMLNAMU, ", stmtSQL)
  @dtw_concat(stmtSQL, "       EMFNAM, EMFNAMU, EMMIDI, EMRNAM, EMDEPT, EMLOC, EMTYPE, EMTRCD, ODDESC, ", stmtSQL)
  @dtw_concat(stmtSQL, " upper(MITYPE) as MITYPEU", stmtSQL)
  @dtw_concat(fileSQL, " PEMISC inner join HREMPL on MICOMP=EMPECP and MIEMPL=EMPEMP ", fileSQL)
  @dtw_concat(fileSQL, "        inner join PECODE on MICOMP=ODCOMP and MICODE=ODCODE and ODTYPE='K' ", fileSQL)
  @dtw_concat(selectSQL, " MICOMP = $(hrCompany) ", selectSQL)
  %INCLUDE "activeTerminatedEmplSQL.icl"
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @EmplMisc_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) EmplMisc_XMLQuery (IN CHAR(64)    profileHandle,
			                  CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("HRMiscellaneousList")
          %ROW{
               @DateFromCYMD(V_MIEFDT)

		    @XMLIDTag(@DTW_rCONCAT(V_MICOMP, @DTW_rCONCAT("/", @DTW_rCONCAT(V_MIEMPL, @DTW_rCONCAT("/", V_MISEQ)))), "EmployeeMiscellaneous ID")
                   @XMLTag(V_MICOMP, "CompanyNumber")
                   @XMLTag(V_MIEMPL, "EmployeeNumber")
                   @XMLBeginTag("PersonName")
                       @XMLTag(V_EMRNAM, "FormattedName")
                       @XMLTag(V_EMFNAM, "GivenName")
                       @XMLTag(V_EMMIDI, "MiddleName")
                       @XMLTag(V_EMLNAM, "FamilyName")
                   @XMLEndTag("PersonName")
                   @XMLTag(V_MITYPE, "MiscellaneousName")
                   @XMLTag(V_MICODE, "MiscellaneousCode")
                   @XMLTag(V_ODDESC, "CodeDescription")
                   @XMLTag(V_MIEFDT, "EffectiveDate")
                   @XMLTag(V_MIPREM, "PremiumAmount")
                   @XMLTag(V_MIAMT, "Amount")
                   @XMLTag(V_MIBENF, "Beneficiary")

               @XMLEndTag("EmployeeMiscellaneous")
          %}
      @XMLEndTag("HRMiscellaneousList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "MITYPEU")
              @DTW_ASSIGN(orderByDisplay, "Miscellaneous Name")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %elif (chgActive == "Y" && inclActive == "Y")
              @dtw_assign(inclActive, "")
          %elif (chgActive == "Y")
              @dtw_assign(inclActive, "Y")
          %elif (chgTerminated == "Y" && inclTerminated == "Y")
              @dtw_assign(inclTerminated, "")
          %elif (chgTerminated == "Y")
              @dtw_assign(inclTerminated, "Y")
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      %if (inclActive == "" && inclTerminated == "" && chgActive != "Y" && chgTerminated != "Y")
          @dtw_assign(inclActive, activeEmpl)
          @dtw_assign(inclTerminated, terminatedEmpl)
      %endif
      %INCLUDE "SearchReturn.icl"
  %endif
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "MiscName")
      %if (orderBy == "MITYPEU")
          @DTW_ASSIGN(orderBy, "MITYPEU DESC")
          @DTW_ASSIGN(orderByDisplay, "Miscellaneous Name (descending)")
      %else
          @DTW_ASSIGN(orderBy, "MITYPEU")
          @DTW_ASSIGN(orderByDisplay, "Miscellaneous Name")
      %endif
  %elif (sequence == "EffectiveDate")
      %if (orderBy == "MIEFDT,MITYPEU")
          @DTW_ASSIGN(orderBy, "MIEFDT DESC,MITYPEU")
          @DTW_ASSIGN(orderByDisplay, "Effective Date (descending), Miscellaneous Name")
      %else
          @DTW_ASSIGN(orderBy, "MIEFDT,MITYPEU")
          @DTW_ASSIGN(orderByDisplay, "Effective Date, Miscellaneous Name")
      %endif
  %elif (sequence == "PremiumAmount")
      %if (orderBy == "MIPREM")
          @DTW_ASSIGN(orderBy, "MIPREM DESC")
          @DTW_ASSIGN(orderByDisplay, "Premium Amount (descending)")
      %else
          @DTW_ASSIGN(orderBy, "MIPREM")
          @DTW_ASSIGN(orderByDisplay, "Premium Amount")
      %endif
  %elif (sequence == "Amount")
      %if (orderBy == "MIAMT")
          @DTW_ASSIGN(orderBy, "MIAMT DESC")
          @DTW_ASSIGN(orderByDisplay, "Amount (descending)")
      %else
          @DTW_ASSIGN(orderBy, "MIAMT")
          @DTW_ASSIGN(orderByDisplay, "Amount")
      %endif
  %elif (sequence == "Beneficiary")
      %if (orderBy == "MIBENF")
          @DTW_ASSIGN(orderBy, "MIBENF DESC")
          @DTW_ASSIGN(orderByDisplay, "Beneficiary (descending)")
      %else
          @DTW_ASSIGN(orderBy, "MIBENF")
          @DTW_ASSIGN(orderByDisplay, "Beneficiary")
      %endif
  %elif (sequence == "MiscCode")
      %if (orderBy == "MICODE")
          @DTW_ASSIGN(orderBy, "MICODE DESC")
          @DTW_ASSIGN(orderByDisplay, "Miscellaneous Type (descending)")
      %else
          @DTW_ASSIGN(orderBy, "MICODE")
          @DTW_ASSIGN(orderByDisplay, "Miscellaneous Type")
      %endif
  %elif (sequence == "CodeDesc")
      %if (orderBy == "ODDESC")
          @DTW_ASSIGN(orderBy, "ODDESC DESC")
          @DTW_ASSIGN(orderByDisplay, "Type Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "ODDESC")
          @DTW_ASSIGN(orderByDisplay, "Type Description")
      %endif
  %elif (sequence == "Employee")
      %if (orderBy == "MIEMPL,MITYPEU")
          @DTW_ASSIGN(orderBy, "MIEMPL DESC,MITYPEU")
          @DTW_ASSIGN(orderByDisplay, "Employee Number (descending), Miscellaneous Name")
      %else
          @DTW_ASSIGN(orderBy, "MIEMPL,MITYPEU")
          @DTW_ASSIGN(orderByDisplay, "Employee Number, Miscellaneous Name")
      %endif
  %elif (sequence == "LastName")
      %if (orderBy == "EMLNAMU,EMFNAMU,MITYPEU")
          @DTW_ASSIGN(orderBy, "EMLNAMU DESC,EMFNAMU,MITYPEU")
          @DTW_ASSIGN(orderByDisplay, "Last Name (descending), First Name, Miscellaneous Name")
      %else
          @DTW_ASSIGN(orderBy, "EMLNAMU,EMFNAMU,MITYPEU")
          @DTW_ASSIGN(orderByDisplay, "Last Name, First Name, Miscellaneous Name")
      %endif
  %endif
	
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              @dtw_assign(formName, "Search")
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editdate(document.Search.srchFromDate) &&
                      editdate(document.Search.srchToDate) &&
                      editNum(document.Search.srchPremium, 7, 2) &&
                      editNum(document.Search.srchAmount, 7, 0) &&
                      editNum(document.Search.srchEmployee, 9, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->

          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "COMPMISCSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      @RetHrCompNam(profileHandle, dataBaseID, hrCompany, facilityZero, coFacName)
                      <h2>$(coFacName)</h2>

                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><th class="dsphdr"> <br>Miscellaneous</th></tr>

                          <tr><td class="dsphdr"><br>Miscellaneous Type</td>
                              @dtw_assign(operNbr, "operType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchType" type="text" size="5" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Search&amp;fldComp=@dtw_rurlescseq(hrCompany)&amp;fldType=K&amp;fldName=srchType&amp;fldDesc=typeCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="typeCodeDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Miscellaneous Name</td>
                              @dtw_assign(operNbr, "operMiscName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchMiscName" size="12" maxlength="12"></td>
                          </tr>

                          <tr><td class="dsphdr">From Effective Date</td>
                              @dtw_assign(operNbr, "operFromDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchFromDate" size="6" maxlength="6"> 		
                                  <a href="javascript:calWindow('srchFromDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">To Effective Date</td>
                              @dtw_assign(operNbr, "operToDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchToDate" size="6" maxlength="6"> 		
                                  <a href="javascript:calWindow('srchToDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Premium</td>
                              @dtw_assign(operNbr, "operPremium")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchPremium" size="7" maxlength="7"></td>
                          </tr>

                          <tr><td class="dsphdr">Amount</td>
                              @dtw_assign(operNbr, "operAmount")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchAmount" size="7" maxlength="7"></td>
                          </tr>

                          <tr><td class="dsphdr">Beneficiary</td>
                              @dtw_assign(operNbr, "operBeneficiary")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchBeneficiary" size="13" maxlength="13"></td>
                          </tr>

                          <tr><th class="dsphdr"> <br>Employee</th></tr>

                          <tr><td class="dsphdr"><br>Number</td>
                              @dtw_assign(operNbr, "operEmployee")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchEmployee" size="9" maxlength="9"></td>
                          </tr>

                          <tr><td class="dsphdr">First Name</td>
                              @dtw_assign(operNbr, "operFirst")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchFirst" size="18" maxlength="18"></td>
                          </tr>

                          <tr><td class="dsphdr">Last Name</td>
                              @dtw_assign(operNbr, "operLast")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchLast" size="18" maxlength="18"></td>
                          </tr>

                          <tr><td class="dsphdr">Location</td>
                              @dtw_assign(operNbr, "operLoc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchLoc" type="text" size="5" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Search&amp;fldComp=@dtw_rurlescseq(hrCompany)&amp;fldType=O&amp;fldName=srchLoc&amp;fldDesc=locCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="locCodeDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Department</td>
                              @dtw_assign(operNbr, "operDept")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchDept" type="text" size="5" maxlength="5"> <a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Search&amp;fldName=srchDept&amp;fldDesc=deptDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="deptDesc" value="$(deptDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Job Code</td>
                              @dtw_assign(operNbr, "operJob")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchJob" type="text" size="5" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Search&amp;fldComp=@dtw_rurlescseq(hrCompany)&amp;fldType=J&amp;fldName=srchJob&amp;fldDesc=jobCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="jobCodeDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchMiscName.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("MICODE", "Miscellaneous Type", $(srchType), "U", operType, "A")
  @Build_WildCard ("upper(MITYPE)", "Miscellaneous Name", $(srchMiscName), "U", operMiscName, "A")
  @Build_WildCard ("MIEFDT", "From Effective Date", $(srchFromDate), "", operFromDate, "D")
  @Build_WildCard ("MIEFDT", "To Effective Date", $(srchToDate), "", operToDate, "D")
  @Build_WildCard ("MIPREM", "Premium Amount", $(srchPremium), "", operPremium, "N")
  @Build_WildCard ("MIAMT", "Amount", $(srchAmount), "", operAmount, "N")
  @Build_WildCard ("upper(MIBENF)", "Beneficiary", $(srchBeneficiary), "U", operBeneficiary, "A")
  @Build_WildCard ("MIEMPL", "Employee Number", $(srchEmployee), "", operEmployee, "N")
  @Build_WildCard ("EMFNAMU", "First Name", $(srchFirst), "U", operFirst, "A")
  @Build_WildCard ("EMLNAMU", "Last Name", $(srchLast), "U", operLast, "A")
  @Build_WildCard ("EMLOC", "Location", $(srchLoc), "U", operLoc, "A")
  @Build_WildCard ("EMDEPT", "Department", $(srchDept), "U", operDept, "A")
  @Build_WildCard ("EMJOB", "Job Code", $(srchJob), "U", operJob, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}