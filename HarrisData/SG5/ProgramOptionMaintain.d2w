%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Program Option Security Maintenance"
  d2wName                 = "ProgramOptionMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;progName=@dtw_rurlescseq(progName)&amp;progDesc=@dtw_rurlescseq(progDesc)&amp;forUserProfile=@dtw_rurlescseq(forUserProfile)"
  nextPrevVar             = "$(d2wVarBase)&amp;orderBy=@dtw_rurlescseq(orderBy)&amp;wildCardSearch=@dtw_rurlescseq(wildCardSearch)"
  wildDftVar              = "MAINTAIN$(d2wVarBase)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)&amp;maintenanceCode=D"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "9999"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  maintenanceCode         = "C"
  programName             = "HSYPSU"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          @dtw_assign(formName, "Search")
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
              function confirmAccept()      {return confirm("Confirm accept of changes");}
              function confirmDelete(text)  {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              function confirmDeselectAll() {return confirm("Confirm deselect all for current row selection");}
              function confirmSelectAll()   {return confirm("Confirm select all for current row selection");}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PROGRAMOPTIONMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " SYPGMW", fileSQL)
                      @dtw_concat(selectSQL, "SWXHND='$(profileHandle)' and SWPGID='$(progName)'", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  <a onClick="return confirmAccept()" href="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)">$(acceptImageLrg)</a>
                  <a onClick="return confirmSelectAll()" href="$(homeURL)$(cGIPath)$(d2wName)/UPDATEALL$(d2wVarBase)&amp;updateAll=S&amp;wildCardSearch=@dtw_rurlescseq(wildCardSearch)&amp;orderBy=@dtw_rurlescseq(orderBy)">$(selectAllImage)</a>
                  <a onClick="return confirmDeselectAll()" href="$(homeURL)$(cGIPath)$(d2wName)/UPDATEALL$(d2wVarBase)&amp;updateAll=C&amp;wildCardSearch=@dtw_rurlescseq(wildCardSearch)&amp;orderBy=@dtw_rurlescseq(orderBy)">$(deselectAllImage)</a>
                  <a href="$(homeURL)$(cGIPath)ProgramOptionUserSearch.d2w/REPORT$(d2wVarBase)" onclick="$(searchWinVar)">$(addImageMed)</a>
                  <a href="$(homeURL)$(cGIPath)ProgramOption.d2w/REPORT$(d2wVarBase)">$(cancelImageMed)</a>
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>

      <table $(contentTable)>
          @Format_Header("Program Name", $(progDesc), $(progName))
      </table>

      %INCLUDE "ConfMessageDisplay.icl"
      $(hrTagAttr)
      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">User<br>Profile</th>
                      <th class="colhdr">Name</th>
                      <th class="colhdr">Role</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchUser" size="10" maxlength="10">
                          <input type="hidden" name="operUser" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchName" size="10" maxlength="30">
                          <input type="hidden" name="operName" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchRole" size="10" maxlength="10">
                          <input type="hidden" name="operRole" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchUser.focus();
              </script>
          </form>
      %endif

      @RtvFldDesc("SOPGID='$(progName)' and SOMOPT=1", "SYPGMO", "SOMDES", optDesc01)
      @RtvFldDesc("SOPGID='$(progName)' and SOMOPT=2", "SYPGMO", "SOMDES", optDesc02)
      @RtvFldDesc("SOPGID='$(progName)' and SOMOPT=3", "SYPGMO", "SOMDES", optDesc03)
      @RtvFldDesc("SOPGID='$(progName)' and SOMOPT=4", "SYPGMO", "SOMDES", optDesc04)
      @RtvFldDesc("SOPGID='$(progName)' and SOMOPT=5", "SYPGMO", "SOMDES", optDesc05)
      @RtvFldDesc("SOPGID='$(progName)' and SOMOPT=6", "SYPGMO", "SOMDES", optDesc06)
      @RtvFldDesc("SOPGID='$(progName)' and SOMOPT=7", "SYPGMO", "SOMDES", optDesc07)
      @RtvFldDesc("SOPGID='$(progName)' and SOMOPT=8", "SYPGMO", "SOMDES", optDesc08)
      @RtvFldDesc("SOPGID='$(progName)' and SOMOPT=9", "SYPGMO", "SOMDES", optDesc09)
      @RtvFldDesc("SOPGID='$(progName)' and SOMOPT=10", "SYPGMO", "SOMDES", optDesc10)
      @RtvFldDesc("SOPGID='$(progName)' and SOMOPT=11", "SYPGMO", "SOMDES", optDesc11)
      @RtvFldDesc("SOPGID='$(progName)' and SOMOPT=12", "SYPGMO", "SOMDES", optDesc12)
      @RtvFldDesc("SOPGID='$(progName)' and SOMOPT=13", "SYPGMO", "SOMDES", optDesc13)
      @RtvFldDesc("SOPGID='$(progName)' and SOMOPT=14", "SYPGMO", "SOMDES", optDesc14)
      @RtvFldDesc("SOPGID='$(progName)' and SOMOPT=15", "SYPGMO", "SOMDES", optDesc15)

      %INCLUDE "WildCardPage.icl"

      <form class="formClass" METHOD=POST name="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)&amp;updateRowNum=@dtw_rurlescseq($(START_ROW_NUM))">
          <table $(contentTable)>
              <tr><th class="colhdr">$(optionHeading)</th>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)")
                  @OrderBy_Sort("SWUSER", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=User" title="Sequence By User Profile">User<br>Profile</a></th>
                  @OrderBy_Sort("SWDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Name" title="Sequence By Name">Name</a></th>
                  @OrderBy_Sort("SWROLE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Role" title="Sequence By Role, User Profile">Role</a></th>
                  %if (optDesc01 != "")
                      <td class="colhdr"><a href="$(homeURL)$(cGIPath)ProgramOptionRowCol.d2w/REPORT$(orderByVar)&amp;optNumber=01&amp;optDesc=@dtw_rurlescseq(optDesc01)" onclick="$(smallPromptWinVar)" title="Update column">$(optDesc01)</a></td>
                  %endif
                  %if (optDesc02 != "")
                      <td class="colhdr"><a href="$(homeURL)$(cGIPath)ProgramOptionRowCol.d2w/REPORT$(orderByVar)&amp;optNumber=02&amp;optDesc=@dtw_rurlescseq(optDesc02)" onclick="$(smallPromptWinVar)" title="Update column">$(optDesc02)</a></td>
                  %endif
                  %if (optDesc03 != "")
                      <td class="colhdr"><a href="$(homeURL)$(cGIPath)ProgramOptionRowCol.d2w/REPORT$(orderByVar)&amp;optNumber=03&amp;optDesc=@dtw_rurlescseq(optDesc03)" onclick="$(smallPromptWinVar)" title="Update column">$(optDesc03)</a></td>
                  %endif
                  %if (optDesc04 != "")
                      <td class="colhdr"><a href="$(homeURL)$(cGIPath)ProgramOptionRowCol.d2w/REPORT$(orderByVar)&amp;optNumber=04&amp;optDesc=@dtw_rurlescseq(optDesc04)" onclick="$(smallPromptWinVar)" title="Update column">$(optDesc04)</a></td>
                  %endif
                  %if (optDesc05 != "")
                      <td class="colhdr"><a href="$(homeURL)$(cGIPath)ProgramOptionRowCol.d2w/REPORT$(orderByVar)&amp;optNumber=05&amp;optDesc=@dtw_rurlescseq(optDesc05)" onclick="$(smallPromptWinVar)" title="Update column">$(optDesc05)</a></td>
                  %endif
                  %if (optDesc06 != "")
                      <td class="colhdr"><a href="$(homeURL)$(cGIPath)ProgramOptionRowCol.d2w/REPORT$(orderByVar)&amp;optNumber=06&amp;optDesc=@dtw_rurlescseq(optDesc06)" onclick="$(smallPromptWinVar)" title="Update column">$(optDesc06)</a></td>
                  %endif
                  %if (optDesc07 != "")
                      <td class="colhdr"><a href="$(homeURL)$(cGIPath)ProgramOptionRowCol.d2w/REPORT$(orderByVar)&amp;optNumber=07&amp;optDesc=@dtw_rurlescseq(optDesc07)" onclick="$(smallPromptWinVar)" title="Update column">$(optDesc07)</a></td>
                  %endif
                  %if (optDesc08 != "")
                      <td class="colhdr"><a href="$(homeURL)$(cGIPath)ProgramOptionRowCol.d2w/REPORT$(orderByVar)&amp;optNumber=08&amp;optDesc=@dtw_rurlescseq(optDesc08)" onclick="$(smallPromptWinVar)" title="Update column">$(optDesc08)</a></td>
                  %endif
                  %if (optDesc09 != "")
                      <td class="colhdr"><a href="$(homeURL)$(cGIPath)ProgramOptionRowCol.d2w/REPORT$(orderByVar)&amp;optNumber=09&amp;optDesc=@dtw_rurlescseq(optDesc09)" onclick="$(smallPromptWinVar)" title="Update column">$(optDesc09)</a></td>
                  %endif
                  %if (optDesc10 != "")
                      <td class="colhdr"><a href="$(homeURL)$(cGIPath)ProgramOptionRowCol.d2w/REPORT$(orderByVar)&amp;optNumber=10&amp;optDesc=@dtw_rurlescseq(optDesc10)" onclick="$(smallPromptWinVar)" title="Update column">$(optDesc10)</a></td>
                  %endif
                  %if (optDesc11 != "")
                      <td class="colhdr"><a href="$(homeURL)$(cGIPath)ProgramOptionRowCol.d2w/REPORT$(orderByVar)&amp;optNumber=11&amp;optDesc=@dtw_rurlescseq(optDesc11)" onclick="$(smallPromptWinVar)" title="Update column">$(optDesc11)</a></td>
                  %endif
                  %if (optDesc12 != "")
                      <td class="colhdr"><a href="$(homeURL)$(cGIPath)ProgramOptionRowCol.d2w/REPORT$(orderByVar)&amp;optNumber=12&amp;optDesc=@dtw_rurlescseq(optDesc12)" onclick="$(smallPromptWinVar)" title="Update column">$(optDesc12)</a></td>
                  %endif
                  %if (optDesc13 != "")
                      <td class="colhdr"><a href="$(homeURL)$(cGIPath)ProgramOptionRowCol.d2w/REPORT$(orderByVar)&amp;optNumber=13&amp;optDesc=@dtw_rurlescseq(optDesc13)" onclick="$(smallPromptWinVar)" title="Update column">$(optDesc13)</a></td>
                  %endif
                  %if (optDesc14 != "")
                      <td class="colhdr"><a href="$(homeURL)$(cGIPath)ProgramOptionRowCol.d2w/REPORT$(orderByVar)&amp;optNumber=14&amp;optDesc=@dtw_rurlescseq(optDesc14)" onclick="$(smallPromptWinVar)" title="Update column">$(optDesc14)</a></td>
                  %endif
                  %if (optDesc15 != "")
                      <td class="colhdr"><a href="$(homeURL)$(cGIPath)ProgramOptionRowCol.d2w/REPORT$(orderByVar)&amp;optNumber=15&amp;optDesc=@dtw_rurlescseq(optDesc15)" onclick="$(smallPromptWinVar)" title="Update column">$(optDesc15)</a></td>
                  %endif
              </tr>

              %INCLUDE "NoRecordsFound.icl"
    		
              %ROW{
                  %INCLUDE "SetRowClass.icl"
                  @Field_Checked(V_SWOP01, "Y", sel01)
                  @Field_Checked(V_SWOP02, "Y", sel02)
                  @Field_Checked(V_SWOP03, "Y", sel03)
                  @Field_Checked(V_SWOP04, "Y", sel04)
                  @Field_Checked(V_SWOP05, "Y", sel05)
                  @Field_Checked(V_SWOP06, "Y", sel06)
                  @Field_Checked(V_SWOP07, "Y", sel07)
                  @Field_Checked(V_SWOP08, "Y", sel08)
                  @Field_Checked(V_SWOP09, "Y", sel09)
                  @Field_Checked(V_SWOP10, "Y", sel10)
                  @Field_Checked(V_SWOP11, "Y", sel11)
                  @Field_Checked(V_SWOP12, "Y", sel12)
                  @Field_Checked(V_SWOP13, "Y", sel13)
                  @Field_Checked(V_SWOP14, "Y", sel14)
                  @Field_Checked(V_SWOP15, "Y", sel15)
                  @Format_Confirm_Desc($(V_SWDESC), $(V_SWUSER), "", "", "", "", confirmDesc)

                  @dtw_assign(maintainVar, "$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)&amp;updateRowNum=@dtw_rurlescseq($(START_ROW_NUM))")
                  <tr class="$(rowClass)">
                      <td class="colicon"><a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)$(d2wName)/DELETE$(maintainVar)&amp;user=@dtw_rurlescseq(V_SWUSER)">$(deleteImageSml)</a></td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)ProgramOptionRowCol.d2w/REPORT$(maintainVar)&amp;user=@dtw_rurlescseq(V_SWUSER)&amp;userName=@dtw_rurlescseq(V_SWDESC)" onclick="$(smallPromptWinVar)" title="Update row">$(V_SWUSER)</a></td>
                      <td class="colalph">$(V_SWDESC)</td>
                      <td class="colalph">$(V_SWROLE)</td>
                      %if (optDesc01 != "")
                          <td class="colcode"><input type="checkbox" name="option" $(sel01) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(maintainVar)&amp;optNumber=01&amp;user=@dtw_rurlescseq(V_SWUSER)&amp;selected=@dtw_rurlescseq(sel01)'"></td>
                      %endif
                      %if (optDesc02 != "")
                          <td class="colcode"><input type="checkbox" name="option" $(sel02) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(maintainVar)&amp;optNumber=02&amp;user=@dtw_rurlescseq(V_SWUSER)&amp;selected=@dtw_rurlescseq(sel02)'"></td>
                      %endif
                      %if (optDesc03 != "")
                          <td class="colcode"><input type="checkbox" name="option" $(sel03) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(maintainVar)&amp;optNumber=03&amp;user=@dtw_rurlescseq(V_SWUSER)&amp;selected=@dtw_rurlescseq(sel03)'"></td>
                      %endif
                      %if (optDesc04 != "")
                          <td class="colcode"><input type="checkbox" name="option" $(sel04) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(maintainVar)&amp;optNumber=04&amp;user=@dtw_rurlescseq(V_SWUSER)&amp;selected=@dtw_rurlescseq(sel04)'"></td>
                      %endif
                      %if (optDesc05 != "")
                          <td class="colcode"><input type="checkbox" name="option" $(sel05) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(maintainVar)&amp;optNumber=05&amp;user=@dtw_rurlescseq(V_SWUSER)&amp;selected=@dtw_rurlescseq(sel05)'"></td>
                      %endif
                      %if (optDesc06 != "")
                          <td class="colcode"><input type="checkbox" name="option" $(sel06) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(maintainVar)&amp;optNumber=06&amp;user=@dtw_rurlescseq(V_SWUSER)&amp;selected=@dtw_rurlescseq(sel06)'"></td>
                      %endif
                      %if (optDesc07 != "")
                          <td class="colcode"><input type="checkbox" name="option" $(sel07) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(maintainVar)&amp;optNumber=07&amp;user=@dtw_rurlescseq(V_SWUSER)&amp;selected=@dtw_rurlescseq(sel07)'"></td>
                      %endif
                      %if (optDesc08 != "")
                          <td class="colcode"><input type="checkbox" name="option" $(sel08) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(maintainVar)&amp;optNumber=08&amp;user=@dtw_rurlescseq(V_SWUSER)&amp;selected=@dtw_rurlescseq(sel08)'"></td>
                      %endif
                      %if (optDesc09 != "")
                          <td class="colcode"><input type="checkbox" name="option" $(sel09) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(maintainVar)&amp;optNumber=09&amp;user=@dtw_rurlescseq(V_SWUSER)&amp;selected=@dtw_rurlescseq(sel09)'"></td>
                      %endif
                      %if (optDesc10 != "")
                          <td class="colcode"><input type="checkbox" name="option" $(sel10) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(maintainVar)&amp;optNumber=10&amp;user=@dtw_rurlescseq(V_SWUSER)&amp;selected=@dtw_rurlescseq(sel10)'"></td>
                      %endif
                      %if (optDesc11 != "")
                          <td class="colcode"><input type="checkbox" name="option" $(sel11) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(maintainVar)&amp;optNumber=11&amp;user=@dtw_rurlescseq(V_SWUSER)&amp;selected=@dtw_rurlescseq(sel11)'"></td>
                      %endif
                      %if (optDesc12 != "")
                          <td class="colcode"><input type="checkbox" name="option" $(sel12) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(maintainVar)&amp;optNumber=12&amp;user=@dtw_rurlescseq(V_SWUSER)&amp;selected=@dtw_rurlescseq(sel12)'"></td>
                      %endif
                      %if (optDesc13 != "")
                          <td class="colcode"><input type="checkbox" name="option" $(sel13) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(maintainVar)&amp;optNumber=13&amp;user=@dtw_rurlescseq(V_SWUSER)&amp;selected=@dtw_rurlescseq(sel13)'"></td>
                      %endif
                      %if (optDesc14 != "")
                          <td class="colcode"><input type="checkbox" name="option" $(sel14) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(maintainVar)&amp;optNumber=14&amp;user=@dtw_rurlescseq(V_SWUSER)&amp;selected=@dtw_rurlescseq(sel14)'"></td>
                      %endif
                      %if (optDesc15 != "")
                          <td class="colcode"><input type="checkbox" name="option" $(sel15) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(maintainVar)&amp;optNumber=15&amp;user=@dtw_rurlescseq(V_SWUSER)&amp;selected=@dtw_rurlescseq(sel15)'"></td>
                      %endif
                  </tr>
              %}
          </table>
      </form>
      %INCLUDE "PageBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint == "Y")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "SWUSER")
              @DTW_ASSIGN(orderByDisplay, "User Profile")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      %INCLUDE "SearchReturn.icl"
  %endif
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "User")
      %if (orderBy == "SWUSER")
          @DTW_ASSIGN(orderBy, "SWUSER DESC")
          @DTW_ASSIGN(orderByDisplay, "User Profile (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SWUSER")
          @DTW_ASSIGN(orderByDisplay, "User Profile")
      %endif
  %elif (sequence == "Name")
      %if (orderBy == "SWDESCU,SWUSER")
          @DTW_ASSIGN(orderBy, "SWDESCU DESC,SWUSER")
          @DTW_ASSIGN(orderByDisplay, "Name (descending), User Profile")
      %else
          @DTW_ASSIGN(orderBy, "SWDESCU,SWUSER")
          @DTW_ASSIGN(orderByDisplay, "Name, User Profile")
      %endif
  %elif (sequence == "Role")
      %if (orderBy == "SWROLE,SWUSER")
          @DTW_ASSIGN(orderBy, "SWROLE DESC,SWUSER")
          @DTW_ASSIGN(orderByDisplay, "Role (descending), User Profile")
      %else
          @DTW_ASSIGN(orderBy, "SWROLE,SWUSER")
          @DTW_ASSIGN(orderByDisplay, "Role, User Profile")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(UPDATEALL) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  %if (updateAll == "C")
      @dtw_assign(updSel, "N")
  %else
      @dtw_assign(updSel, "Y")
  %endif
  @dtw_concat(stmtSQL, " Update SYPGMW Set SWOP01='$(updSel)', SWOP02='$(updSel)', SWOP03='$(updSel)', SWOP04='$(updSel)', SWOP05='$(updSel)',", stmtSQL)
  @dtw_concat(stmtSQL, "                   SWOP06='$(updSel)', SWOP07='$(updSel)', SWOP08='$(updSel)', SWOP09='$(updSel)', SWOP10='$(updSel)',", stmtSQL)
  @dtw_concat(stmtSQL, "                   SWOP11='$(updSel)', SWOP12='$(updSel)', SWOP13='$(updSel)', SWOP14='$(updSel)', SWOP15='$(updSel)' ", stmtSQL)
  @dtw_concat(stmtSQL, " Where SWXHND='$(profileHandle)' and SWPGID='$(progName)'", stmtSQL)
  %if (wildCardSearch!="")
      @dtw_concat(stmtSQL, " $(wildCardSearch) ", stmtSQL)
  %endif
  @dtw_concat(stmtSQL, " @@endsql", stmtSQL)

  @SQL_Update(stmtSQL, status)
  %if (updateRowNum=="")
      @dtw_assign(updateRowNum, "1")
  %endif
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/INPUT$(nextPrevVar)&amp;START_ROW_NUM=@dtw_rurlescseq(updateRowNum)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(UPDATE) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_assign(option, "Y")
  %if (selected == "CHECKED") @dtw_assign(option, "N") %endif
  @dtw_concat(stmtSQL, " Update SYPGMW Set SWOP$(optNumber)='$(option)' ", stmtSQL)
  @dtw_concat(stmtSQL, " Where SWXHND='$(profileHandle)' and SWPGID='$(progName)' and SWUSER='$(user)'", stmtSQL)
  @dtw_concat(stmtSQL, " @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)

  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/INPUT$(nextPrevVar)&amp;START_ROW_NUM=@dtw_rurlescseq(updateRowNum)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}


%HTML(DELETE) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Delete From SYPGMW Where SWXHND='$(profileHandle)' and SWPGID='$(progName)' and SWUSER='$(user)' @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)
  %if (updateRowNum=="")
      @dtw_assign(updateRowNum, "1")
  %endif
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/INPUT$(nextPrevVar)&amp;START_ROW_NUM=@dtw_rurlescseq(updateRowNum)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(LOAD) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Delete From SYPGMW Where SWXHND='$(profileHandle)' @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Insert Into SYPGMW (SWXHND,SWUSER,SWPGID,SWDESC,SWDESCU,SWROLE,SWOP01,SWOP02,SWOP03,SWOP04,SWOP05,SWOP06,SWOP07, ", stmtSQL)
  @dtw_concat(stmtSQL, "                     SWOP08,SWOP09,SWOP10,SWOP11,SWOP12,SWOP13,SWOP14,SWOP15) ", stmtSQL)
  @dtw_concat(stmtSQL, " Select '$(profileHandle)',SPUSER,SPPGID,coalesce(USDESC,' '),coalesce(USDESCU,' '),coalesce(USROLE,' '),SPOP01,SPOP02,SPOP03,SPOP04,SPOP05,SPOP06,SPOP07,", stmtSQL)
  @dtw_concat(stmtSQL, "                     SPOP08,SPOP09,SPOP10,SPOP11,SPOP12,SPOP13,SPOP14,SPOP15 ", stmtSQL)
  @dtw_concat(stmtSQL, " From SYPGMS left join SYUSER on SPUSER=USUSER Where SPPGID='$(progName)' @@endsql ", stmtSQL)
  @SQL_Update(stmtSQL, status)

  %if (forUserProfile != "")
      @RtvFldDesc("USUSER='$(forUserProfile)' ", "SYUSER", "USDESC", userName)
      %if (userName == "")
          %INCLUDE "stmtSQLClear.icl"
          @dtw_concat(stmtSQL, " Insert Into SYPGMW (SWXHND,SWUSER,SWPGID,SWDESC,SWDESCU,SWROLE,SWOP01,SWOP02,SWOP03,SWOP04,SWOP05,SWOP06,SWOP07, ", stmtSQL)
          @dtw_concat(stmtSQL, "                     SWOP08,SWOP09,SWOP10,SWOP11,SWOP12,SWOP13,SWOP14,SWOP15) ", stmtSQL)
          @dtw_concat(stmtSQL, " Values ('$(profileHandle)','$(forUserProfile)','$(progName)','','','',", stmtSQL)
          @dtw_concat(stmtSQL, "         'N','N','N','N','N','N','N','N','N','N','N','N','N','N','N')  @@endsql ", stmtSQL)
          @SQL_Update(stmtSQL, status)
      %else
          %INCLUDE "stmtSQLClear.icl"
          @dtw_concat(stmtSQL, " Insert Into SYPGMW (SWXHND,SWUSER,SWPGID,SWDESC,SWDESCU,SWROLE,SWOP01,SWOP02,SWOP03,SWOP04,SWOP05,SWOP06,SWOP07, ", stmtSQL)
          @dtw_concat(stmtSQL, "                     SWOP08,SWOP09,SWOP10,SWOP11,SWOP12,SWOP13,SWOP14,SWOP15) ", stmtSQL)
          @dtw_concat(stmtSQL, " Select '$(profileHandle)','$(forUserProfile)','$(progName)',USDESC,USDESCU,USROLE,", stmtSQL)
          @dtw_concat(stmtSQL, "         'N','N','N','N','N','N','N','N','N','N','N','N','N','N','N' ", stmtSQL)
          @dtw_concat(stmtSQL, " From SYUSER Where USUSER='$(forUserProfile)' and not exists (Select * From SYPGMW  ", stmtSQL)
          @dtw_concat(stmtSQL, " Where SWXHND='$(profileHandle)' and SWPGID='$(progName)' and SWUSER='$(forUserProfile)') @@endsql ", stmtSQL)
          @SQL_Update(stmtSQL, status)
      %endif
      @DTW_ASSIGN(orderBy, "SWUSER")
      @DTW_ASSIGN(orderByDisplay, "User Profile")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;srchUser=@dtw_rurlescseq(forUserProfile)&amp;operUser=LIKE&amp;wildCardSearch=">
  %endif

  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Delete From SYPGMS Where SPPGID='$(progName)' @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Insert Into SYPGMS (SPUSER,SPPGID,SPOP01,SPOP02,SPOP03,SPOP04,SPOP05,SPOP06,SPOP07, ", stmtSQL)
  @dtw_concat(stmtSQL, "                     SPOP08,SPOP09,SPOP10,SPOP11,SPOP12,SPOP13,SPOP14,SPOP15) ", stmtSQL)
  @dtw_concat(stmtSQL, " Select SWUSER,SWPGID,SWOP01,SWOP02,SWOP03,SWOP04,SWOP05,SWOP06,SWOP07,", stmtSQL)
  @dtw_concat(stmtSQL, "        SWOP08,SWOP09,SWOP10,SWOP11,SWOP12,SWOP13,SWOP14,SWOP15 ", stmtSQL)
  @dtw_concat(stmtSQL, " From SYPGMW Where SWXHND='$(profileHandle)' and SWPGID='$(progName)' @@endsql ", stmtSQL)
  @SQL_Update(stmtSQL, status)

  @Format_ConfMsg_Desc(maintenanceCode, $(progDesc), $(progName), "", "", "", "", confMessage)
  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ProgramOption.d2w/REPORT$(genericVarBase)&amp;forUserProfile=@dtw_rurlescseq(forUserProfile)&amp;confMessage=@dtw_rurlescseq(confMessage)">
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          @dtw_assign(formName, "Search")
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PROGRAMOPTIONMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">User Profile</td>
                              @dtw_assign(operNbr, "operUser")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchUser" type="text" size="10" maxlength="10"><a href="$(homeURL)$(phpPath)UserSearch.php$(altVarBase)&amp;docName=@dtw_rurlescseq(formName)&amp;userFld=srchUser&amp;descFld=srchUserName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="srchUserName" type="text" size="35" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Name</td>
                              @dtw_assign(operNbr, "operName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchName" type="text" size="10" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Role</td>
                              @dtw_assign(operNbr, "operRole")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchRole" type="text" size="10" maxlength="10"><a href="$(homeURL)$(phpPath)RoleSearch.php$(altVarBase)&amp;docName=@dtw_rurlescseq(formName)&amp;roleFld=srchRole&amp;descFld=srchRoleDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="srchRoleDesc" type="text" size="35" disabled></td>
                          </tr>
                          %INCLUDE "SearchBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
  @Build_WildCard ("SWUSER", "User Profile", $(srchUser), "U", $(operUser), "A")
  @Build_WildCard ("SWDESCU", "Name", $(srchName), "U", $(operName), "A")
  @Build_WildCard ("SWROLE", "Role", $(srchRole), "U", $(operRole), "A")
  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}