%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Configuration Header"
  d2wName                 = "ConfigurationHeaderSelect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(fromPlant)&amp;fromName=@dtw_rurlescseq(fromName)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;configurationType=@dtw_rurlescseq(configurationType)&amp;configurationID=@dtw_rurlescseq(configurationID)"
  programName             = "HPD023"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script type="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "CONFIGURATIONHEADERSELECT")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " HDCFGH ", fileSQL)
                      @dtw_concat(selectSQL, " CHPLT = $(plantNumber) and CHITEM = '$(itemNumber)' ", selectSQL)
                      @dtw_concat(selectSQL, " and CHCFGT = '$(configurationType)' and CHCFGI = '$(configurationID)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      @ConfigurationHeader_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) ConfigurationHeader_Query (IN  CHAR(64)    profileHandle,
                                                  CHAR(2)     dataBaseID,
                                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)configurationheadermaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (sec_01=="Y" && sec_04=="Y")
                          <a href="$(homeURL)$(cGIPath)configurationheadermaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=Z">$(copyImageLrg)</a>
                      %endif
                      %if (sec_02 == "Y" || sec_03 == "Y")
                          <a href="$(homeURL)$(cGIPath)configurationheadermaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=C">$(changeImageLrg)</a>
                      %endif
                      %if (sec_03 == "Y")
                          @Format_Confirm_Desc("Configuration Header", "$(itemNumber) / $(configurationType) / $(configurationID)", "", "", "", "", confirmDesc)
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)configurationheadermaintain.d2w/Edit_Data$(d2wVarBase)&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      <table $(contentTable)>
          %ROW {
              @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
              <tr><td class="dsphdr">Plant</td>
                  <td class="dspnmbr">$(V_CHPLT)</td>
                  <td class="dspalph">$(plantName)</td>
              </tr>

              <tr><td class="dsphdr">Item Number</td>
                  <td class="dspalph">$(V_CHITEM)</td>
              </tr>

              <tr><td class="dsphdr">Configuration Type</td>
                  <td class="dspalph">$(V_CHCFGT)</td>
              </tr>

              <tr><td class="dsphdr">Configuration ID</td>
                  <td class="dspalph">$(V_CHCFGI)</td>
              </tr>

              <tr><td class="dsphdr">Type Description</td>
                  <td class="dspalph">$(V_CHCDSC)</td>
              </tr>

              @Format_Date(V_CHDATI, "H", F_CHDATI)
              <tr><td class="dsphdr">Effectivity In Date</td>
                  <td class="dspdate">$(F_CHDATI)</td>
              </tr>

              @Format_Date(V_CHDATO, "H", F_CHDATO)
              <tr><td class="dsphdr">Effectivity Out Date</td>
                  <td class="dspdate">$(F_CHDATO)</td>
              </tr>

              @RtvYNDesc($(V_CHUPSM), fieldDesc)
              <tr><td class="dsphdr">Use Alternate Product Structure</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              @RtvYNDesc($(V_CHURTG), fieldDesc)
              <tr><td class="dsphdr">Use Alternate Routing</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              <tr><td class="dsphdr">Engineering Change Notice</td>
                  <td class="dspalph">$(V_CHECN)</td>
              </tr>

              <tr><td class="dsphdr">Drawing Number</td>
                  <td class="dspalph">$(V_CHDWGN)</td>
              </tr>

              @RtvFldDesc("FLTYPE='DSGNPHASE' and FLVALU='$(V_CHDSGP)'", "SYFLAG", "FLDESC", F_CHDSGP)
              <tr><td class="dsphdr">Design Phase</td>
                  <td class="dspalph">$(F_CHDSGP)</td>
              </tr>

              @Format_Date(V_CHAPDT, "H", F_CHAPDT)
              <tr><td class="dsphdr">Final Approval Date</td>
                  <td class="dspdate">$(F_CHAPDT)</td>
              </tr>

              <tr><td class="dsphdr">Approval Code</td>
                  <td class="dspalph">$(V_CHAPCD)</td>
              </tr>

              <tr><td class="dsphdr">Approved By</td>
                  <td class="dspalph">$(V_CHAPBY)</td>
              </tr>

              <tr><td class="dsphdr">ISO Code</td>
                  <td class="dspalph">$(V_CHISOC)</td>
              </tr>

              @RtvYNDesc($(V_CHREL), fieldDesc)
              <tr><td class="dsphdr">Released To Production</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              @Format_Date(V_CHRELD, "H", F_CHRELD)
              <tr><td class="dsphdr">Release Date</td>
                  <td class="dspdate">$(F_CHRELD)</td>
              </tr>

              @Format_Date(V_CHDATC, "H", F_CHDATC)
              <tr><td class="dsphdr">Date Created</td>
                  <td class="dspdate">$(F_CHDATC)</td>
              </tr>

              @Format_Date(V_CHDATU, "H", F_CHDATU)
              <tr><td class="dsphdr">Date Last Used</td>
                  <td class="dspdate">$(F_CHDATU)</td>
              </tr>

              @RtvFldDesc("CYPLT=$(V_CHPLT) and CYCFGT='$(V_CHCFGT)'", "HDCFGT", "CYAS11", alpha1Desc)
              %if (alpha1Desc != "")		
                  <tr><td class="dsphdr">$(alpha1Desc)</td>
                      <td class="dspalph">$(V_CHUDA1)</td>
                  </tr>
              %endif

              @RtvFldDesc("CYPLT=$(V_CHPLT) and CYCFGT='$(V_CHCFGT)'", "HDCFGT", "CYAS21", alpha2Desc)
              %if (alpha2Desc != "")		
                  <tr><td class="dsphdr">$(alpha2Desc)</td>
                      <td class="dspalph">$(V_CHUDA2)</td>
                  </tr>
              %endif

              @RtvFldDesc("CYPLT=$(V_CHPLT) and CYCFGT='$(V_CHCFGT)'", "HDCFGT", "CYAS31", alpha3Desc)
              %if (alpha3Desc != "")		
                  <tr><td class="dsphdr">$(alpha3Desc)</td>
                      <td class="dspalph">$(V_CHUDA3)</td>
                  </tr>
              %endif

              @RtvFldDesc("CYPLT=$(V_CHPLT) and CYCFGT='$(V_CHCFGT)'", "HDCFGT", "CYNS11", numeric1Desc)
              %if (numeric1Desc != "")		
                  <tr><td class="dsphdr">$(numeric1Desc)</td>
                      <td class="dspnmbr">$(V_CHUDN1)</td>
                  </tr>
              %endif

              @RtvFldDesc("CYPLT=$(V_CHPLT) and CYCFGT='$(V_CHCFGT)'", "HDCFGT", "CYNS21", numeric2Desc)
              %if (numeric2Desc != "")		
                  <tr><td class="dsphdr">$(numeric2Desc)</td>
                      <td class="dspnmbr">$(V_CHUDN2)</td>
                  </tr>
              %endif

              @RtvFldDesc("CYPLT=$(V_CHPLT) and CYCFGT='$(V_CHCFGT)'", "HDCFGT", "CYNS31", numeric3Desc)
              %if (numeric3Desc != "")		
                  <tr><td class="dsphdr">$(numeric3Desc)</td>
                      <td class="dspnmbr">$(V_CHUDN2)</td>
                  </tr>
              %endif

              @RtvFldDesc("CYPLT=$(V_CHPLT) and CYCFGT='$(V_CHCFGT)'", "HDCFGT", "CYDS11", date1Desc)
              %if (date1Desc != "")		
                  @Format_Date(V_CHUDD1, "H", F_CHUDD1)
                  <tr><td class="dsphdr">$(date1Desc)</td>
                      <td class="dspdate">$(F_CHUDD1)</td>
                  </tr>
              %endif

              @RtvFldDesc("CYPLT=$(V_CHPLT) and CYCFGT='$(V_CHCFGT)'", "HDCFGT", "CYDS21", date2Desc)
              %if (date2Desc != "")		
                  @Format_Date(V_CHUDD2, "H", F_CHUDD2)
                  <tr><td class="dsphdr">$(date2Desc)</td>
                      <td class="dspdate">$(F_CHUDD2)</td>
                  </tr>
              %endif

              @RtvFldDesc("CYPLT=$(V_CHPLT) and CYCFGT='$(V_CHCFGT)'", "HDCFGT", "CYDS31", date3Desc)
              %if (date3Desc != "")		
                  @Format_Date(V_CHUDD3, "H", F_CHUDD3)
                  <tr><td class="dsphdr">$(date3Desc)</td>
                      <td class="dspdate">$(F_CHUDD3)</td>
                  </tr>
              %endif
          %}
      </table>
      $(hrTagAttr)	
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}