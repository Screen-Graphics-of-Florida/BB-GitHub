%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Cost Simulation Variable Maintenance"
  d2wName                 = "CostSimulatorVariableMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(fromPlant)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)"
  programName             = "HSCSIM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  medIcon = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  function confirmClear() {return confirm("Confirm clear of entry fields");}
                  function validate(chgForm) {
                      if (document.Chg.costSet.value =="" ||
                          document.Chg.orderQuantity.value == "")
                             {alert("$(reqFieldError)");
                              return false;}
                      if (editNum(document.Chg.costSet, 2, 0) &&
                          editNum(document.Chg.customerNumber, 7, 0) &&
                          editdate(document.Chg.reqDate) &&
                          editNum(document.Chg.warehouse, 3, 0) &&
                          editNum(document.Chg.orderQuantity, 9, 4) &&
                          editNum(document.Chg.percentSM, 3, 2) &&
                          editNum(document.Chg.percentGA, 3, 2) &&
                          editNum(document.Chg.sellPrice, 8, 5) &&
                          editNum(document.Chg.addonTotal, 7, 2) &&
                          editNum(document.Chg.amountMiscTwo, 7, 2) &&
                          editNum(document.Chg.percentOne, 3, 2) &&
                          editNum(document.Chg.percentTwo, 3, 2) &&
                          editNum(document.Chg.percentThree, 3, 2) &&
                          editNum(document.Chg.percentFour, 3, 2))
                          return true;
                  }
	           %INCLUDE "numedit.icl"
               %INCLUDE "dateedit.icl"
               %INCLUDE "calendar.icl"
               %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "COSTSIMULATORVARIABLEMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          @dtw_concat(stmtSQL, "Select * From WRKSIM Where WKXHND='$(profileHandle)'", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLDOL1", V_PLDOL1)
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLDOL2", V_PLDOL2)
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLPCT1", V_PLPCT1)
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLPCT2", V_PLPCT2)
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLPCT3", V_PLPCT3)
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLPCT4", V_PLPCT4)

      <table $(contentTable)>
    	   <colgroup>
    	       <col width="80%">
    	       <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  <a href="javascript:check(document.Chg)">$(acceptImageMed)</a>
                  <a href="$(homeURL)$(cGIPath)CostSimulatorDisplay.d2w/REPORT$(d2wVarBase)">$(cancelImageMed)</a>
                  <a onClick="return confirmClear()" href="$(homeURL)$(cGIPath)$(d2wName)/BUILD$(d2wVarBase)">$(selectClearImage)</a>
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>

      <table $(contentTable)>
          @Format_Header("Plant", $(plantName), $(plantNumber))
          @Format_Header("Item", $(itemDescription), $(itemNumber))
      </table>

      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "")
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@cset", "costSet")        @dtw_assign(Err_WKCSET, fieldValue)
                      @DecatErr_Field("@@cust", "customerNumber") @dtw_assign(Err_WKCUST, fieldValue)
                      @DecatErr_Field("@@ccls", "customerClass")  @dtw_assign(Err_WKCCLS, fieldValue)
                      @DecatErr_Field("@@crgn", "region")         @dtw_assign(Err_WKCRGN, fieldValue)
                      @DecatErr_Field("@@rqdt", "reqDate")        @dtw_assign(Err_WKRQDT, fieldValue)
                      @DecatErr_Field("@@qty@", "orderQuantity")  @dtw_assign(Err_WKQTY,  fieldValue)
                      @DecatErr_Field("@@whs@", "warehouse")      @dtw_assign(Err_WKWHS,  fieldValue)
                      @DecatErr_Field("@@pcls", "prodClass")      @dtw_assign(Err_WKPCLS, fieldValue)
                      @DecatErr_Field("@@pgrp", "prodGroup")      @dtw_assign(Err_WKPGRP, fieldValue)
                      @DecatErr_Field("@@spct", "percentSM")      @dtw_assign(Err_WKSPCT, fieldValue)
                      @DecatErr_Field("@@gpct", "percentGA")      @dtw_assign(Err_WKGPCT, fieldValue)
                      @DecatErr_Field("@@sell", "sellPrice")      @dtw_assign(Err_WKSELL, fieldValue)
                      @DecatErr_Field("@@uda1", "addonTotal")     @dtw_assign(Err_WKUDA1, fieldValue)
                      @DecatErr_Field("@@uda2", "amountMiscTwo")  @dtw_assign(Err_WKUDA2, fieldValue)
                      @DecatErr_Field("@@pca1", "percentOne")     @dtw_assign(Err_WKPCA1, fieldValue)
                      @DecatErr_Field("@@pca2", "percentTwo")     @dtw_assign(Err_WKPCA2, fieldValue)
                      @DecatErr_Field("@@pca3", "percentThree")   @dtw_assign(Err_WKPCA3, fieldValue)
                      @DecatErr_Field("@@pca4", "percentFour")    @dtw_assign(Err_WKPCA4, fieldValue)

                      @Decat_Field("@@cset")   @dtw_assign(V_WKCSET, fieldValue)
                      @Decat_Field("@@cust")   @dtw_assign(V_WKCUST, fieldValue)
                      @Decat_Field("@@ccls")   @dtw_assign(V_WKCCLS, fieldValue)
                      @Decat_Field("@@crgn")   @dtw_assign(V_WKCRGN, fieldValue)
                      @Decat_Field("@@rqdt")   @dtw_assign(V_WKRQDT, fieldValue)
                      @Decat_Field("@@qty@")   @dtw_assign(V_WKQTY,  fieldValue)
                      @Decat_Field("@@whs@")   @dtw_assign(V_WKWHS,  fieldValue)
                      @Decat_Field("@@pcls")   @dtw_assign(V_WKPCLS, fieldValue)
                      @Decat_Field("@@pgrp")   @dtw_assign(V_WKPGRP, fieldValue)
                      @Decat_Field("@@spct")   @dtw_assign(V_WKSPCT, fieldValue)
                      @Decat_Field("@@gpct")   @dtw_assign(V_WKGPCT, fieldValue)
                      @Decat_Field("@@sell")   @dtw_assign(V_WKSELL, fieldValue)
                      @Decat_Field("@@uda1")   @dtw_assign(V_WKUDA1, fieldValue)
                      @Decat_Field("@@uda2")   @dtw_assign(V_WKUDA2, fieldValue)
                      @Decat_Field("@@pca1")   @dtw_assign(V_WKPCA1, fieldValue)
                      @Decat_Field("@@pca2")   @dtw_assign(V_WKPCA2, fieldValue)
                      @Decat_Field("@@pca3")   @dtw_assign(V_WKPCA3, fieldValue)
                      @Decat_Field("@@pca4")   @dtw_assign(V_WKPCA4, fieldValue)

                      @dtw_assign(errFound, "")
                  %else
                  	  @DateInputFromCYMD(V_WKRQDT)
                      @dtw_assign(focusField, "costSet")
                  %endif

                  @Default_Zero(V_WKCSET)
                  @dtw_assign(costSetDesc, "")
                  @RtvFldDesc("STCSET=$(V_WKCSET)", "SCMSTM", "STCSLD", costSetDesc)
                  @SetTextOvr(Err_WKCSET)
                  <tr><td class="dsphdr"><span $(textOvr)>Cost Set</span></td>
                      <td class="inputnmbr"><input name="costSet" type="text" value="$(V_WKCSET)" size="5" maxlength="2"> $(reqFieldChar) <a href="$(homeURL)$(cGIPath)CostSetDefinitionSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=costSet&amp;fldDesc=costSetDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="costSetDesc" value="$(costSetDesc)" type="text" size="25"></td>
                  </tr>
                  @DspErrMsg(Err_WKCSET)

                  @Default_Zero(V_WKCUST)
                  @dtw_assign(customerName, "")
                  @RtvFldDesc("CMCUST=$(V_WKCUST)", "HDCUST", "CMCNA1", customerName)
                  @SetTextOvr(Err_WKCUST)
                  <tr><td class="dsphdr"><span $(textOvr)>Customer Number</span></td>
                      <td class="inputnmbr"><input name="customerNumber" type="text" value="$(V_WKCUST)" size="6" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=customerNumber&amp;fldDesc=customerName" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="customerName" value="$(customerName)" type="text" size="26"></td>
                  </tr>
                  @DspErrMsg(Err_WKCUST)

                  @Default_Zero(V_WKQTY)
                  @SetTextOvr(Err_WKQTY)
                  <tr><td class="dsphdr"><span $(textOvr)>Quantity</span></td>
                      <td class="inputnmbr"><input name="orderQuantity" type="text" value="$(V_WKQTY)" size="14" maxlength="14"> $(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_WKQTY)
                  
                  @SetTextOvr(Err_WKRQDT)
                  <tr>
                      <td class="dsphdr"><span $(textOvr)>Date</span></td>
                      <td class="inputnmbr"><input type="text" name="reqDate" value="$(V_WKRQDT)" size="6" maxlength="6">
                          <a href="javascript:calWindow('reqDate');">$(calendarImage)</a>
                      </td>
                  </tr>
                  @DspErrMsg(Err_WKRQDT)
                  
                  @SetTextOvr(Err_WKWHS)
                  <tr>
                      <td class="dsphdr"><span $(textOvr)>Warehouse Number</span></td>
                      @Default_Zero(V_WKWHS)
                      @RtvFldDesc("WHWHS=$(V_WKWHS)", "HDWHSM", "WHWHNM", warehouseName)
                      <td class="inputnmbr"><input name="warehouse" type="text" value="$(V_WKWHS)" size="6" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=warehouse&amp;fldDesc=warehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="warehouseName" type="text" value="$(warehouseName)" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_WKWHS)
                  
                  @RtvFldDesc("CCCCLS='$(V_WKCCLSX)'", "HDCCLS", "CCCCDS", fieldDesc)
                  @SetTextOvr(Err_WKCCLS)
                  <tr><td class="dsphdr"><span $(textOvr)>Customer Class</span></td>
                      <td class="inputalph"><input name="customerClass" type="text" value="$(V_WKCCLSX)" size="6" maxlength="2"><a href="$(homeURL)$(phpPath)CustomerClassSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=customerClass&amp;fldDesc=customerClassDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="customerClassDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_WKCCLS)
                  
                  @RtvFldDesc("RGCRGN='$(V_WKCRGNX)'", "HDCRGN", "RGCRDS", fieldDesc)
                  @SetTextOvr(Err_WKCRGN)
                  <tr><td class="dsphdr"><span $(textOvr)>Region</span></td>
                      <td class="inputalph"><input name="region" type="text" value="$(V_WKCRGNX)" size="6" maxlength="5"><a href="$(homeURL)$(phpPath)RegionSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=region&amp;fldDesc=regionDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="regionDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_WKCRGN)
                  
                  @SetTextOvr(Err_WKPCLS)
                  <tr>
                      @RtvFldDesc("PCPCLS='$(V_WKPCLSX)'", "HDPCLS", "PCPCDS", fieldDesc)
		       		  <td class="dsphdr"><span $(textOvr)>Product Class</span></td>
                      <td class="inputalph"><input name="prodClass" value="$(V_WKPCLSX)" type="text" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)ProdClassSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=prodClass&amp;fldDesc=productClassDesc" onclick="$(searchWinVar)">
                          $(searchImage) </a><input name="productClassDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_WKPCLS)
                  
                  @SetTextOvr(Err_WKPGRP)
                  <tr>
                      @RtvFldDesc("PGPGRP='$(V_WKPGRPX)'", "HDPRGM", "PGDESC", fieldDesc)
        		      <td class="dsphdr"><span $(textOvr)>Product Group</span></td>
                      <td class="inputalph"><input name="prodGroup" type="text" value="$(V_WKPGRPX)" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)productgroupsearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=prodGroup&amp;fldDesc=prodGroupDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="prodGroupDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_WKPGRP)

                  @SetTextOvr(Err_WKSPCT)
                  <tr><td class="dsphdr"><span $(textOvr)>S&M % Mfg Cost</span></td>
                      <td class="inputnmbr"><input name="percentSM" type="text" value="$(V_WKSPCT)" size="11" maxlength="7"></td>
                  </tr>
                  @DspErrMsg(Err_WKSPCT)

                  @SetTextOvr(Err_WKGPCT)
                  <tr><td class="dsphdr"><span $(textOvr)>G&A % Mfg Cost</span></td>
                      <td class="inputnmbr"><input name="percentGA" type="text" value="$(V_WKGPCT)" size="11" maxlength="7"></td>
                  </tr>
                  @DspErrMsg(Err_WKGPCT)

                  @SetTextOvr(Err_WKSELL)
                  <tr><td class="dsphdr"><span $(textOvr)>Sell Price</span></td>
                      <td class="inputnmbr"><input name="sellPrice" type="text" value="$(V_WKSELL)" size="11" maxlength="14"></td>
                  </tr>
                  @DspErrMsg(Err_WKSELL)

                  @SetTextOvr(Err_WKUDA1)
                  <tr><td class="dsphdr"><span $(textOvr)>$(V_PLDOL1)</span></td>
                      <td class="inputnmbr"><input name="addonTotal" type="text" value="$(V_WKUDA1)" size="11" maxlength="11"></td>
                  </tr>
                  @DspErrMsg(Err_WKUDA1)

                  @SetTextOvr(Err_WKUDA2)
                  <tr><td class="dsphdr"><span $(textOvr)>$(V_PLDOL2)</span></td>
                      <td class="inputnmbr"><input name="amountMiscTwo" type="text" value="$(V_WKUDA2)" size="11" maxlength="11"></td>
                  </tr>
                  @DspErrMsg(Err_WKUDA2)

                  @SetTextOvr(Err_WKPCA1)
                  <tr><td class="dsphdr"><span $(textOvr)>$(V_PLPCT1) % Sell Price</span></td>
                      <td class="inputnmbr"><input name="percentOne" type="text" value="$(V_WKPCA1)" size="11" maxlength="7"></td>
                  </tr>
                  @DspErrMsg(Err_WKPCA1)

                  @SetTextOvr(Err_WKPCA2)
                  <tr><td class="dsphdr"><span $(textOvr)>$(V_PLPCT2) % Sell Price</span></td>
                      <td class="inputnmbr"><input name="percentTwo" type="text" value="$(V_WKPCA2)" size="11" maxlength="7"></td>
                  </tr>
                  @DspErrMsg(Err_WKPCA2)

                  @SetTextOvr(Err_WKPCA3)
                  <tr><td class="dsphdr"><span $(textOvr)>$(V_PLPCT3) % Sell Price</span></td>
                      <td class="inputnmbr"><input name="percentThree" type="text" value="$(V_WKPCA3)" size="11" maxlength="7"></td>
                  </tr>
                  @DspErrMsg(Err_WKPCA3)

                  @SetTextOvr(Err_WKPCA4)
                  <tr><td class="dsphdr"><span $(textOvr)>$(V_PLPCT4) % Sell Price</span></td>
                      <td class="inputnmbr"><input name="percentFour" type="text" value="$(V_WKPCA4)" size="11" maxlength="7"></td>
                  </tr>
                  @DspErrMsg(Err_WKPCA4)

              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>

      <table $(contentTable)>
          <tr>
              <td class="toolbar">
                  <a href="javascript:check(document.Chg)">$(acceptImageMed)</a>
                  <a href="$(homeURL)$(cGIPath)CostSimulatorDisplay.d2w/REPORT$(d2wVarBase)">$(cancelImageMed)</a>
                  <a onClick="return confirmClear()" href="$(homeURL)$(cGIPath)$(d2wName)/BUILD$(d2wVarBase)">$(selectClearImage)</a>
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)      profileHandle,
                                        INOUT CHAR(10)      callSubr,
                                        INOUT CHAR(1)       maintenanceCode,
                                        INOUT CHAR(32000)   edtVar,                             	
                                        INOUT CHAR(32000)   errVar,
                                        INOUT CHAR(1)       errFound)

{%EXEC {HSCSIM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(itemNumber)

  @dtw_assign(plantNumber,    @dtw_rstrip(plantNumber))
  @dtw_assign(costSet,        @dtw_rstrip(costSet))
  @dtw_assign(customerNumber, @dtw_rstrip(customerNumber))
  @dtw_assign(orderQuantity,  @dtw_rstrip(orderQuantity))
  @dtw_assign(warehouse,      @dtw_rstrip(warehouse))
  @dtw_assign(percentSM,      @dtw_rstrip(percentSM))
  @dtw_assign(percentGA,      @dtw_rstrip(percentGA))
  @dtw_assign(sellPrice,      @dtw_rstrip(sellPrice))
  @dtw_assign(addonTotal,     @dtw_rstrip(addonTotal))
  @dtw_assign(amountMiscTwo,  @dtw_rstrip(amountMiscTwo))
  @dtw_assign(percentOne,     @dtw_rstrip(percentOne))
  @dtw_assign(percentTwo,     @dtw_rstrip(percentTwo))
  @dtw_assign(percentThree,   @dtw_rstrip(percentThree))
  @dtw_assign(percentFour,    @dtw_rstrip(percentFour))
  %if (reqDate > "0")
     @DateToCYMD(reqDate)
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@item", itemNumber)
  @Concat_Field("@@cset", costSet)
  @Concat_Field("@@cust", customerNumber)
  @Concat_Field("@@ccls", customerClass)
  @Concat_Field("@@crgn", region)
  @Concat_Field("@@rqdt", reqDate)
  @Concat_Field("@@qty@", orderQuantity)
  @Concat_Field("@@whs@", warehouse)
  @Concat_Field("@@pcls", prodClass)
  @Concat_Field("@@pgrp", prodGroup)
  @Concat_Field("@@spct", percentSM)
  @Concat_Field("@@gpct", percentGA)
  @Concat_Field("@@sell", sellPrice)
  @Concat_Field("@@uda1", addonTotal)
  @Concat_Field("@@uda2", amountMiscTwo)
  @Concat_Field("@@pca1", percentOne)
  @Concat_Field("@@pca2", percentTwo)
  @Concat_Field("@@pca3", percentThree)
  @Concat_Field("@@pca4", percentFour)
  @dtw_concat(edtVar, "}{", edtVar)

  @dtw_assign(callSubr, "SRUSIM")

  @Validate_Data(profileHandle, callSubr, maintenanceCode, edtVar, errVar, errFound)

  %if (errFound == "")
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)CostSimulatorDisplay.d2w/REPORT$(d2wVarBase)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}

%HTML(BUILD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@item", itemNumber)
  @Concat_Field("@@pcfc", productCfgFormat)
  @dtw_concat(edtVar, "}{", edtVar)

  @dtw_assign(callSubr, "FILL")

  @Validate_Data (profileHandle, callSubr, maintenanceCode, edtVar, errVar, error)

  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;errFound=&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}