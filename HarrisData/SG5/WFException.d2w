%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Validation Exception"
  d2wName                 = "WFException.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfProcess=@dtw_rurlescseq(wfProcess)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HWFVEM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  noMsg                   = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "WFEXCEPTION")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select WFPRVE.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(VPDESC,' ') as VPDESC, coalesce(VPDESCU,' ') as VPDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(VIDESC,' ') as VIDESC, coalesce(VIDESCU,' ') as VIDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(RMDESC,' ') as RMDESC, coalesce(RMDESCU,' ') as RMDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(FLDESC,' ') as FLDESC, upper(coalesce(FLDESC,' ')) as FLDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " WFPRVE ", fileSQL)
                      @dtw_concat(fileSQL, " left join WFVLPG on VPVPGM=VEVPGM ", fileSQL)
                      @dtw_concat(fileSQL, " left join WFVLID on VIVPGM=VEVPGM and VIVLID=VEVLID ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYROLM on RMROLE=VEROLE ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG on FLTYPE='WFBYPASSVL' and FLVALU=VEBYPS ", fileSQL)
                      @dtw_concat(selectSQL, " VEPROC='$(wfProcess)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)WFExceptionMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      <table $(contentTable)>
          @RtvFldDesc("PRPROC='$(wfProcess)'", "WFPRHD", "PRDESC", V_PRDESC)
          @Format_Header_URL("Process", $(V_PRDESC), $(wfProcess), "$(homeURL)$(cGIPath)WFProcessSelect.d2w/REPORT$(d2wVarBase)")
      </table>

      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint == "")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">Role</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="15" maxlength="50">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchRole" size="15" maxlength="30">
                          <input type="hidden" name="operRole" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("VPDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Program"      title="Sequence By Program, Description, Validation ID">Program</a></th>
              @OrderBy_Sort("VIDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description"  title="Sequence By Description, Validation ID">Description</a></th>
              @OrderBy_Sort("RMDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Role"         title="Sequence By Role, Validation ID">Role</a></th>
              @OrderBy_Sort("FLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Bypass"       title="Sequence By Bypass Validation, Validation ID">Bypass Validation</a></th>
              @OrderBy_Sort("VEVLID", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=VldId"        title="Sequence By Validation ID">Validation ID</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;vldProgram=@dtw_rurlescseq(V_VEVPGM)&amp;validationId=@dtw_rurlescseq(V_VEVLID)&amp;role=@dtw_rurlescseq(V_VEROLE)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;updRecNbr=@dtw_rurlescseq(START_ROW_NUM)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc("$(V_VIDESC)-$(V_RMDESC)", $(V_VEVLID), "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)WFExceptionMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)WFExceptionMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromVldProgram=@dtw_rurlescseq(V_VEVPGM)&amp;fromValidationId=@dtw_rurlescseq(V_VEVLID)&amp;fromRole=@dtw_rurlescseq(V_VEROLE)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)WFExceptionMaintain.d2w/EDIT_DATA$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph" $(helpCursor)><span title="$(V_VEVPGM)">$(V_VPDESC)</span></td>                                      	
                  <td class="colalph">$(V_VIDESC)</td>                                      	
                  <td class="colcode" $(helpCursor)><span title="$(V_VEROLE)">$(V_RMDESC)</span></td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_VEBYPS)">$(V_FLDESC)</span></td>                                      	
                  <td class="colnmbr">$(V_VEVLID)</td>                                      	
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select WFPRVE.*, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(VPDESC,' ') as VPDESC, coalesce(VPDESCU,' ') as VPDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(VIDESC,' ') as VIDESC, coalesce(VIDESCU,' ') as VIDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(RMDESC,' ') as RMDESC, coalesce(RMDESCU,' ') as RMDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(FLDESC,' ') as FLDESC, upper(coalesce(FLDESC,' ')) as FLDESCU ", stmtSQL)
  @dtw_concat(fileSQL, " WFPRVE ", fileSQL)
  @dtw_concat(fileSQL, " left join WFVLPG on VPVPGM=VEVPGM ", fileSQL)
  @dtw_concat(fileSQL, " left join WFVLID on VIVPGM=VEVPGM and VIVLID=VEVLID ", fileSQL)
  @dtw_concat(fileSQL, " left join SYROLM on RMROLE=VEROLE ", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG on FLTYPE='WFBYPASSVL' and FLVALU=VEBYPS ", fileSQL)
  @dtw_concat(selectSQL, " VEPROC='$(wfProcess)' ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_XMLQuery (IN  CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("WFValidationList")
          %ROW{
              @XMLIDTag("$(V_VEPROC)-$(V_VEVPGM)-$(V_VEVLID)-$(V_VEROLE)", "Validation ID")
                  @XMLTag(V_VEPROC, "Process")
                  @XMLTag(V_VEVPGM, "ValidationProgram")
                  @XMLTag(V_VEVLID, "Validation")
                  @XMLTag(V_VEROLE, "Role")
                  @XMLTag(V_VEBYPS, "BypassValidation")
              @XMLEndTag("Validation")
          %}
      @XMLEndTag("WFValidationList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "VIDESCU,VEVLID,RMDESCU")
          @DTW_ASSIGN(orderByDisplay, "Description, Validation ID")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %if (updRecNbr > "0")
      @dtw_assign(START_ROW_NUM, updRecNbr)
      @dtw_assign(updRecNbr, "")
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Program")
      %if (orderBy == "VPDESCU,VIDESCU,VEVLID")
          @DTW_ASSIGN(orderBy, "VPDESCU DESC,VIDESCU,VEVLID")
          @DTW_ASSIGN(orderByDisplay, "Program (descending), Description, Validation ID")
      %else
          @DTW_ASSIGN(orderBy, "VPDESCU,VIDESCU,VEVLID")
          @DTW_ASSIGN(orderByDisplay, "Program, Description, Validation ID")
      %endif
  %elif (sequence == "Description")
      %if (orderBy == "VIDESCU,VEVLID,RMDESCU")
          @DTW_ASSIGN(orderBy, "VIDESCU DESC,VEVLID,RMDESCU")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Validation ID")
      %else
          @DTW_ASSIGN(orderBy, "VIDESCU,VEVLID,RMDESCU")
          @DTW_ASSIGN(orderByDisplay, "Description, Validation ID")
      %endif
  %elif (sequence == "Role")
      %if (orderBy == "RMDESCU,VEVLID")
          @DTW_ASSIGN(orderBy, "RMDESCU DESC,VEVLID")
          @DTW_ASSIGN(orderByDisplay, "Role (descending), Validation ID")
      %else
          @DTW_ASSIGN(orderBy, "RMDESCU,VEVLID")
          @DTW_ASSIGN(orderByDisplay, "Role, Validation ID")
      %endif
  %elif (sequence == "Bypass")
      %if (orderBy == "FLDESCU,VEVLID,RMDESCU")
          @DTW_ASSIGN(orderBy, "FLDESCU DESC,VEVLID,RMDESCU")
          @DTW_ASSIGN(orderByDisplay, "Bypass Validation (descending), Validation ID")
      %else
          @DTW_ASSIGN(orderBy, "FLDESCU,VEVLID,RMDESCU")
          @DTW_ASSIGN(orderByDisplay, "Bypass Validation, Validation ID")
      %endif
  %elif (sequence == "VldId")
      %if (orderBy == "VEVLID,RMDESCU")
          @DTW_ASSIGN(orderBy, "VEVLID DESC,RMDESCU DESC")
          @DTW_ASSIGN(orderByDisplay, "Validation ID (descending)")
      %else
          @DTW_ASSIGN(orderBy, "VEVLID,RMDESCU")
          @DTW_ASSIGN(orderByDisplay, "Validation ID")
      %endif
  %endif
	
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchVldId, 15, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFVALIDATIONSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                            %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Program</td>
                              @dtw_assign(operNbr, "operProgram")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchProgram" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Role</td>
                              @dtw_assign(operNbr, "operRole")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchRole" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Bypass Validation</td>
                              @dtw_assign(operNbr, "operBypass")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchBypass" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Validation ID</td>
                              @dtw_assign(operNbr, "operVldId")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchVldId" size="15" maxlength="15"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchProgram.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("VPDESCU", "Program", $(srchProgram), "U", operProgram, "A")
  @Build_WildCard ("VIDESCU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("coalesce(RMDESCU,' ')",  "Role", $(srchRole), "U", operRole, "A")
  @Build_WildCard ("upper(FLDESC)",   "Bypass Validation", $(srchBypass), "U", operBypass, "A")
  @Build_WildCard ("VEVLID",  "Validation ID", $(srchVldId), "", operVldId, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
