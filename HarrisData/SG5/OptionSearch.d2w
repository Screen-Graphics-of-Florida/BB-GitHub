%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Option Search"
  d2wName                 = "OptionSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;forPlant=@dtw_rurlescseq(forPlant)&amp;includeBiLevels=@dtw_rurlescseq(includeBiLevels)&amp;docName=@dtw_rurlescseq(docName)&amp;fldPlant=@dtw_rurlescseq(fldPlant)&amp;fldPltName=@dtw_rurlescseq(fldPltName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
  docName                 = ""
  fldPlant                = ""
  fldPltName              = ""
  fldName                 = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %if (forPlant == "")
                  function selectOption(plant, pltname, option, desc){
                      window.opener.document.$(docName).$(fldPlant).value = plant;
                      window.opener.document.$(docName).$(fldPltName).value = pltname;
                      window.opener.document.$(docName).$(fldName).value = option;
                      window.opener.document.$(docName).$(fldDesc).value = desc;
                      window.opener.document.$(docName).$(fldName).focus();
                      window.close();
                  }
              %else
                  function selectOption(option, desc){
                      window.opener.document.$(docName).$(fldName).value = option;
                      window.opener.document.$(docName).$(fldDesc).value = desc;
                      window.opener.document.$(docName).$(fldName).focus();
                      window.close();
                  }
              %endif
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  %if (forPlant == "")
                      if (editNum(document.Search.srchPlant, 3, 0))
                          return true;
                  %else
                      return true;
                  %endif
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(uv_PlantName, "FOPLT")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"

                      @dtw_assign(withSQL, " With Temp_HDMFOP as (Select a.FOPLT as FOPLT,a.FOOPTN as FOOPTN,a.FOFEAT as FOFEAT,a.FOODSC as FOODSC,a.FOBLOP as FOBLOP from HDMFOP a Group By a.FOPLT, a.FOOPTN, a.FOFEAT, a.FOODSC, a.FOBLOP ")
                      @dtw_concat(withSQL, " Union Select VCPLT as FOPLT, VCPITM as FOOPTN, VCFEAT as FOFEAT, VCIMDS as FOODSC, ' ' as FOBLOP from HDVCAT Where VCFEAT<>' ' and VCITEM= ' ' Group By VCPLT, VCPITM,VCFEAT, VCIMDS, ' ') ", withSQL)
                      @dtw_concat(stmtSQL, withSQL, stmtSQL)
                      @dtw_concat(stmtSQL, " Select FOPLT, FOOPTN, FOFEAT, FOODSC, FOBLOP, upper(FOODSC) as FOODSCU", stmtSQL)
                      @dtw_concat(stmtSQL, " , coalesce(PLNAME,' ') as PLNAME, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(upper(PLNAME),' ') as PLNAMEU ", stmtSQL)
                      @dtw_concat(fileSQL, " Temp_HDMFOP", fileSQL)
                      @dtw_concat(fileSQL, " left join HDPLNT on FOPLT=PLPLNT ", fileSQL)
                      %if (wildCardSearch!="" || forPlant>"0" || uv_Sql!="" || includeBiLevels=="O" || includeBiLevels=="N")
                          @dtw_concat(selectSQL, "FOOPTN>' ' ", selectSQL)
                      %endif
                      %if (forPlant > "0")
                         @dtw_concat(selectSQL, " and FOPLT=$(forPlant)", selectSQL)
                      %endif
                      %if (includeBiLevels == "O")
                         @dtw_concat(selectSQL, " and FOBLOP='Y'", selectSQL)
                      %elseif (includeBiLevels == "N")
                         @dtw_concat(selectSQL, " and FOBLOP<>'Y'", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"

                      @dtw_assign(countSQL, "distinct char(FOPLT) concat FOOPTN concat FOFEAT concat FOODSC concat FOBLOP")
                      @RtvFldDescWith("$(withSQL)", "$(selectSQL)", "$(fileSQL)", "char(count(*))", sql_Record_Count)
                      %if (sql_Record_Count == "0")
                          @dtw_assign(stmtSQL, "Select FLTYPE From SYFLAG Where FLTYPE='NoRecFnd'")
                      %else
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)                    
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"                      
                      @Option_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Option_Search (IN CHAR(64)    profileHandle,
     	                              CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr>
                  <th class="colhdr">Option</th>
                  <th class="colhdr">Description</th>
                  <th class="colhdr">Feature</th>
                  <th class="colhdr">Plant</th>   
              </tr>
              <tr>
                  <td><input type="text" class="inputalph"  name="srchOption" size="15" maxlength="15">
                      <input type="hidden" name="operOption" value="LIKE">
                  </td>
                  <td><input type="text" class="inputalph"  name="srchDesc" size="15" maxlength="30">
                      <input type="hidden" name="operDesc" value="LIKE">
                  </td>                  
                  <td><input type="text" class="inputalph"  name="srchFeat" size="15" maxlength="15">
                      <input type="hidden" name="operFeat" value="LIKE">
                  </td>

                  %if (forPlant != "")
                      <td class="colnmbr">$(forPlant)
                          <input type="hidden" name="operPlant" value="=">
                      </td>
                  %else
                      <td class="inputnmbr"><input type="text" name="srchPlant" size="5" maxlength="3" value=$(forPlant)>
                          <input type="hidden" name="operPlant" value="=">
                      </td>
                  %endif
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
          <script TYPE="text/javascript">
              document.Search.srchOption.focus();
          </script>
      </form>
	
      %INCLUDE "WildCardPage.icl"

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              @OrderBy_Sort("FOOPTN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=option" title="Sequence By Option">Option</a></th>
              @OrderBy_Sort("FOODSCU", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=optionDesc" title="Sequence By Description">Description</a></th>
              @OrderBy_Sort("FOFEAT", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=feature" title="Sequence By Feature">Feature</a></th>
              @OrderBy_Sort("FOPLT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlantNumber" title="Sequence By Plant">Plant</a></th>
              @OrderBy_Sort("PLNAMEU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlantName" title="Sequence By Plant Name">Plant Name</a></th>
              @OrderBy_Sort("FOBLOP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=biLevel" title="Sequence By Bi-Level">B/L</a></th>              
          </tr>
          %INCLUDE "NoRecordsFound.icl"

      %ROW{
          %INCLUDE "SetRowClass.icl"
          @Format_Quote(V_FOOPTN, F_FOOPTN)
          @Format_Quote(V_FOODSC, F_FOODSC)          
          @Format_Quote(V_PLNAME, F_PLNAME)

          <tr class="$(rowClass)">

              <td class="colalph">$(V_FOOPTN)</td>
              <td class="colalph">
                  %if (forPlant == "")
                      <a href="javascript:selectOption('$(V_FOPLT)', '$(F_PLNAME)', '$(F_FOOPTN)', '$(F_FOODSC)')" title="Select Option">$(V_FOODSC)</a>
                  %else
                      <a href="javascript:selectOption('$(F_FOOPTN)', '$(F_FOODSC)')" title="Select Option">$(V_FOODSC)</a>
                  %endif
              </td>             
              <td class="colalph">$(V_FOFEAT)</td>
              <td class="colnmbr">$(V_FOPLT)</td>
              <td class="colalph">$(V_PLNAME)</td>
              <td class="colcode">$(V_FOBLOP)</td>
          </tr>
      %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "FOOPTN, FOFEAT")
      @DTW_ASSIGN(orderByDisplay, "Option")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "option")
      %if (orderBy == "FOOPTN, FOFEAT")
          @DTW_ASSIGN(orderBy, "FOOPTN DESC, FOFEAT")
          @DTW_ASSIGN(orderByDisplay, "Option (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FOOPTN, FOFEAT")
          @DTW_ASSIGN(orderByDisplay, "Option")
      %endif
  %elseif (sequence == "optionDesc")
      %if (orderBy == "FOODSCU, FOOPTN, FOFEAT")
          @DTW_ASSIGN(orderBy, "FOODSCU DESC, FOOPTN, FOFEAT")
          @DTW_ASSIGN(orderByDisplay, "Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FOODSCU, FOOPTN, FOFEAT")
          @DTW_ASSIGN(orderByDisplay, "Description")
      %endif      
  %elseif (sequence == "feature")
      %if (orderBy == "FOFEAT, FOOPTN")
          @DTW_ASSIGN(orderBy, "FOFEAT DESC, FOOPTN")
          @DTW_ASSIGN(orderByDisplay, "Feature (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FOFEAT, FOOPTN")
          @DTW_ASSIGN(orderByDisplay, "Feature")
      %endif
  %elseif (sequence == "PlantNumber")
      %if (orderBy == "FOPLT,FOOPTN,FOFEAT")
          @DTW_ASSIGN(orderBy, "FOPLT DESC,FOOPTN,FOFEAT")
          @DTW_ASSIGN(orderByDisplay, "Plant Number (descending), Option, Feature")
      %else
          @DTW_ASSIGN(orderBy, "FOPLT,FOOPTN,FOFEAT")
          @DTW_ASSIGN(orderByDisplay, "Plant Number, Option, Feature")
      %endif
  %elseif (sequence == "PlantName")
      %if (orderBy == "PLNAMEU,FOOPTN,FOFEAT")
          @DTW_ASSIGN(orderBy, "PLNAMEU DESC,FOOPTN,FOFEAT")
          @DTW_ASSIGN(orderByDisplay, "Plant Name (descending), Option, Feature")
      %else
          @DTW_ASSIGN(orderBy, "PLNAMEU,FOOPTN,FOFEAT")
          @DTW_ASSIGN(orderByDisplay, "Plant Name, Option, Feature")
      %endif
  %elseif (sequence == "biLevel")
      %if (orderBy == "FOBLOP,FOOPTN,FOFEAT")
          @DTW_ASSIGN(orderBy, "FOBLOP DESC,FOOPTN,FOFEAT")
          @DTW_ASSIGN(orderByDisplay, "Bi-Level (descending), Option, Feature")
      %else
          @DTW_ASSIGN(orderBy, "FOBLOP,FOOPTN,FOFEAT")
          @DTW_ASSIGN(orderByDisplay, "Bi-Level, Option, Feature")
      %endif      
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("FOOPTN", "Option", $(srchOption), "U", operOption, "A")
  @Build_WildCard ("upper(FOODSC)", "Description", $(srchDesc), "U", operDesc, "A")  
  @Build_WildCard ("FOFEAT", "Feature", $(srchFeat), "U", operFeat, "A")
  @Build_WildCard ("FOPLT", "Plant Number", $(srchPlant), "", operPlant, "N")
  @Build_WildCard ("upper(PLNAME)", "Plant Name", $(srchName), "U", operName, "A")
  
  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}