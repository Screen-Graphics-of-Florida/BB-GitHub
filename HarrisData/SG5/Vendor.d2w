%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Vendor"
  d2wName                 = "Vendor.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;buyerNumber=@dtw_rurlescseq(buyerNumber)&amp;buyerName=@dtw_rurlescseq(buyerName)&amp;fromD2w=@dtw_rurlescseq(d2wName)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HHDVDU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"
  buyerNumber             = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@buyerName", "@dtw_rurlescseq(buyerName)", "1", "a", workURL)
  @dtw_replace(workURL, "@@buyerNumber", "@dtw_rurlescseq(buyerNumber)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchNumber, 7, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "VENDOR")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      @dtw_assign(uv_VendorName, "VMVEND")
                      @dtw_assign(uv_VendorTypeName, "VMVTYP")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select VMVNA1, VMVNA2, VMVNA3, VMVNA4, VMVCTY, VMST, VMZIP,", stmtSQL)
                      @dtw_concat(stmtSQL, " VMVEND, VMPHON, VMVNA1U, VMVNA2U, VMVNA3U, VMVNA4U, VMVCTYU ", stmtSQL)
                      @dtw_concat(fileSQL, " HDVEND ", fileSQL)
                      @dtw_concat(selectSQL, "VMVEND>0 ", selectSQL)
                      %if (buyerNumber != "0")
                          @dtw_concat(selectSQL, " and VMBUYR=$(buyerNumber)", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Vendor_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Vendor_Query (IN  CHAR(64)    profileHandle,
				      CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count != "1")
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1> $(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                      <td  class="toolbar">
                          %if (sec_01 == "Y")
                              <a href="$(homeURL)$(cGIPath)VendorMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
          </table>
          %if(buyerNumber > "0")
              <table $(contentTable)>
                  @Format_Header("Buyer", $(buyerName), $(buyerNumber))
              </table>
          %endif

          %INCLUDE "ConfMessageDisplay.icl"
          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Name</th>
                          <th class="colhdr">Number</th>
                      </tr>
                      <tr><td><input type="text" class="inputalph" name="srchName" size="26" maxlength="26">
                              <input type="hidden" name="operName" value="LIKE">
                          </td>
                          <td><input type="text" class="inputnmbr" name="srchNumber" size="7" maxlength="7">
                              <input type="hidden" name="operNumber" value="=">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchName.focus();
                  </script>
              </form>

              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              <tr>
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y" || sec_05 == "Y"))
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("VMVEND", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Number" title="Sequence By Vendor"> Number</a></th>
                  @OrderBy_Sort("VMVNA1U", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Name" title="Sequence By Name"> Name</a></th>
                  @OrderBy_Sort("VMVNA2U", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Address" title="Sequence By Address"> Address</a></th>
                  @OrderBy_Sort("VMVCTYU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=City" title="Sequence By City, Name"> City</a></th>
                  @OrderBy_Sort("VMST", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=State" title="Sequence By State, Name"> State</a></th>
                  @OrderBy_Sort("VMZIP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Zip" title="Sequence By Zip, Name"> Zip</a></th>
                  @OrderBy_Sort("VMPHON", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Phone" title="Sequence By Phone Number"> Phone Number</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %endif
	   		
              %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_VMVEND)&amp;vendorName=@dtw_rurlescseq(V_VMVNA1)")
                  %if (sql_Record_Count == "1")
                      @Save_WebReg(webRegCurFile, profileHandle, d2wName, "", orderBy, orderByDisplay, "")
                      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)VendorSelect.d2w/REPORT$(genericVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_VMVEND)&amp;vendorName=@dtw_rurlescseq(V_VMVNA1)">
                  %else

                      @EditPhoneNumber(V_VMPHON)

                      %INCLUDE "SetRowClass.icl"
                      @Format_Confirm_Desc($(V_VMVNA1), $(V_VMVEND), "", "", "", "", confirmDesc)
                      @RtvFldDesc("CXVCF='V' and CXNMBR=$(V_VMVEND)", "HDCCMT", "char(count(*))", cmtCount)

                      <tr class="$(rowClass)">
                          %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y" || sec_05 == "Y"))
                              <td class="opticon">
                                  %if (sec_05 == "Y" && sec_02 != "Y")
                                      <a href="$(homeURL)$(cGIPath)VendorMaintainBasic.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                                  %elseif (sec_02 == "Y" || sec_03 == "Y")
                                      <a href="$(homeURL)$(cGIPath)VendorMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                                  %endif
                                  %if (sec_04 == "Y")
                                      <a href="$(homeURL)$(cGIPath)VendorMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                                  %endif
                                  %if (sec_03 == "Y")
                                      <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)VendorMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                                  %endif
            		           %if (cmtCount > "0")
                                      <a href="$(homeURL)$(cGIPath)VendCustCmt.d2w/REPORT$(maintainVar)&amp;vendCustNumber=@dtw_rurlescseq(V_VMVEND)&amp;vendCustName=@dtw_rurlescseq(V_VMVNA1)&amp;vendCustFlag=V&amp;backHome=@dtw_rurlescseq(d2wName)/REPORT">$(commentExistImage)</a>
                                  %else
                                      <a href="$(homeURL)$(cGIPath)VendCustCmt.d2w/REPORT$(maintainVar)&amp;vendCustNumber=@dtw_rurlescseq(V_VMVEND)&amp;vendCustName=@dtw_rurlescseq(V_VMVNA1)&amp;vendCustFlag=V&amp;backHome=@dtw_rurlescseq(d2wName)/REPORT">$(commentImage)</a>
                                  %endif
                              </td>
                          %endif
                          <td class="colnmbr">$(V_VMVEND)</td>                                      	
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)VendorSelect.d2w/REPORT$(genericVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_VMVEND)&amp;vendorName=@dtw_rurlescseq(V_VMVNA1)" title="View Vendor">$(V_VMVNA1)</a></td>
                          <td class="colalph">$(V_VMVNA2)</td>
                          <td class="colalph">$(V_VMVCTY)</td>
                          <td class="colcode">$(V_VMST)</td>
                          <td class="colalph">$(V_VMZIP)</td>
                          <td class="colnmbr">$(V_VMPHON)</td>
                      </tr>
                  %endif
              %}
          </table>
          %if (sql_Record_Count != "1")
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {	
  @dtw_assign(uv_VendorName, "VMVEND")
  %INCLUDE "userview.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select VMVNA1, VMVNA2, VMVNA3, VMVNA4, VMVCTY, VMST, VMZIP,", stmtSQL)
  @dtw_concat(stmtSQL, " VMVEND, VMPHON, VMVNA1U, VMVNA2U, VMVNA3U, VMVNA4U, VMVCTYU ", stmtSQL)
  @dtw_concat(fileSQL, " HDVEND ", fileSQL)
  @dtw_concat(selectSQL, "VMVEND>0 ", selectSQL)
  %if (buyerNumber != "0")
    @dtw_concat(selectSQL, " and VMBUYR=$(buyerNumber)", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @Vendor_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) Vendor_XMLQuery (IN  CHAR(64)    profileHandle,
				         CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("VendorList")
          %ROW{
              @EditPhoneNumber(V_VMPHON)

              @XMLIDTag(V_VMVEND, "Vendor ID")
                  @XMLTag(V_VMVEND, "Number")
                  @XMLTag(V_VMVNA1, "Name")
                  @XMLTag(V_VMVNA2, "Address1")
                  @XMLTag(V_VMVNA3, "Address2")
                  @XMLTag(V_VMVCTY, "City")
                  @XMLTag(V_VMST, "State")
                  @XMLTag(V_VMZIP, "Zip")
                  @XMLTag(V_VMPHON, "Phone")
              @XMLEndTag("Vendor")
          %}
      @XMLEndTag("VendorList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "VMVNA1U")
          @DTW_ASSIGN(orderByDisplay, "Name")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit ()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Number")
      %if (orderBy == "VMVEND")
          @DTW_ASSIGN(orderBy, "VMVEND DESC")
          @DTW_ASSIGN(orderByDisplay, "Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "VMVEND")
          @DTW_ASSIGN(orderByDisplay, "Number")
      %endif
  %elseif (sequence == "Name")
      %if (orderBy == "VMVNA1U")
          @DTW_ASSIGN(orderBy, "VMVNA1U DESC")
          @DTW_ASSIGN(orderByDisplay, "Name (descending)")
      %else
          @DTW_ASSIGN(orderBy, "VMVNA1U")
          @DTW_ASSIGN(orderByDisplay, "Name")
      %endif
  %elseif (sequence == "Address")
      %if (orderBy == "VMVNA2U,VMVNA3U,VMVNA4U")
          @DTW_ASSIGN(orderBy, "VMVNA2U DESC,VMVNA3U,VMVNA4U")
          @DTW_ASSIGN(orderByDisplay, "Address (descending)")
      %else
          @DTW_ASSIGN(orderBy, "VMVNA2U,VMVNA3U,VMVNA4U")
          @DTW_ASSIGN(orderByDisplay, "Address")
      %endif
  %elseif (sequence == "City")
      %if (orderBy == "VMVCTYU,VMVNA1U")
          @DTW_ASSIGN(orderBy, "VMVCTYU DESC,VMVNA1U")
          @DTW_ASSIGN(orderByDisplay, "City (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "VMVCTYU,VMVNA1U")
          @DTW_ASSIGN(orderByDisplay, "City, Name")
      %endif
  %elseif (sequence == "State")
      %if (orderBy == "VMST,VMVNA1U")
          @DTW_ASSIGN(orderBy, "VMST DESC,VMVNA1U")
          @DTW_ASSIGN(orderByDisplay, "State (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "VMST,VMVNA1U")
          @DTW_ASSIGN(orderByDisplay, "State, Name")
      %endif
  %elseif (sequence == "Zip")
      %if (orderBy == "VMZIP,VMVNA1U")
          @DTW_ASSIGN(orderBy, "VMZIP DESC,VMVNA1U")
          @DTW_ASSIGN(orderByDisplay, "Zip (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "VMZIP,VMVNA1U")
          @DTW_ASSIGN(orderByDisplay, "Zip, Name")
      %endif
  %elseif (sequence == "Phone")
      %if (orderBy == "VMPHON")
          @DTW_ASSIGN(orderBy, "VMPHON DESC")
          @DTW_ASSIGN(orderByDisplay, "Phone Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "VMPHON")
          @DTW_ASSIGN(orderByDisplay, "Phone Number")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          @dtw_assign(formName, "Search")
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchPhone, 11, 0) &&
                      editNum(document.Search.srchRemitTo, 7, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "VENDORSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      @RtvFldDesc("CPSCR1<>' '", "APCTRL", "CPSCR1", UDF1)
                      @RtvFldDesc("CPSCR2<>' '", "APCTRL", "CPSCR2", UDF2)
                      @RtvFldDesc("CPSCR3<>' '", "APCTRL", "CPSCR3", UDF3)
                      @RtvFldDesc("CPSCR4<>' '", "APCTRL", "CPSCR4", UDF4)
                      @RtvFldDesc("CPSCR5<>' '", "APCTRL", "CPSCR5", UDF5)

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Vendor Number</td>
                              @dtw_assign(operNbr, "operNumber")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchNumber" size="7" maxlength="7"></td>
                          </tr>

                          <tr><td class="dsphdr">Name</td>
                              @dtw_assign(operNbr, "operName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchName" size="26" maxlength="26"></td>
                          </tr>

                          <tr><td class="dsphdr">Address</td>
                              <td>&nbsp;</td>
                              <td class="inputalph"><input type="text" name="srchAddress" size="26" maxlength="26"></td>	
                          </tr>

                          <tr><td class="dsphdr">State</td>
                              @dtw_assign(operNbr, "operState")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchState" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)StateSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Search&amp;fldName=srchState&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stateDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Zip</td>
                              @dtw_assign(operNbr, "operZip")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchZip" size="14" maxlength="14"></td>
                          </tr>

                          <tr><td class="dsphdr">Phone Number</td>
                              <td>&nbsp;</td>
                              <td class="inputnmbr"><input type="text" name="srchPhone" size="14" maxlength="11"></td>
                          </tr>

                          <tr><td class="dsphdr">Terms Code</td>
                              @dtw_assign(operNbr, "operTerms")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchTerms" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)VendorTermsCodeSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Search&amp;fldName=srchTerms&amp;fldDesc=termsCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="termsCodeDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">1099 Code</td>
                              @dtw_assign(operNbr, "oper1099")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srch1099" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)Vendor1099Search.d2w/ENTRY$(genericVarBase)&amp;docName=Search&amp;fldName=srch1099&amp;fldDesc=ten99Desc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="ten99Desc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Vendor Type</td>
                              @dtw_assign(operNbr, "operType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchType" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)VendorTypeSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Search&amp;fldName=srchType&amp;fldDesc=srchTypeDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="srchTypeDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Remit To Vendor</td>
                              @dtw_assign(operNbr, "operRemitTo")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchRemitTo" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)VendorSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Search&amp;fldName=srchRemitTo&amp;fldDesc=remitToVendorName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="remitToVendorName" value="$(fieldDesc)" type="text" size="30" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Vendor Status</td>
                              @dtw_assign(operNbr, "operStatus")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchStatus" size="2" maxlength="1"><a href="$(homeURL)$(cGIPath)FlagSearch.d2w/REPORT$(genericVarBase)&amp;flagType=VENDORSTAT&amp;flagSrchHdr=@dtw_rurlescseq("Vendor Status")&amp;docName=Search&amp;fldName=srchStatus&amp;fldDesc=srchStatusDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="srchStatusDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Ship Via Code</td>
                              @dtw_assign(operNbr, "operShipVia")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchShipVia" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)ShipViaSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Search&amp;fldName=srchShipVia&amp;fldDesc=shipViaDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="shipViaDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">FOB Code</td>
                              @dtw_assign(operNbr, "operFOB")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchFOB" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)FOBCodeSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Search&amp;fldName=srchFOB&amp;fldDesc=fOBCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fOBCodeDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                          </tr>

                          %if (UDF1 != "")
                              <tr><td class="dsphdr">$(UDF1)</td>
                                  @dtw_assign(operNbr, "operUDF1")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"> <input type="text" name="srchUDF1" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (UDF2 != "")
                              <tr><td class="dsphdr">$(UDF2)</td>
                                  @dtw_assign(operNbr, "operUDF2")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchUDF2" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (UDF3 != "")
                              <tr><td class="dsphdr">$(UDF3)</td>
                                  @dtw_assign(operNbr, "operUDF3")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"> <input type="text" name="srchUDF3" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (UDF4 != "")
                              <tr><td class="dsphdr">$(UDF4)</td>
                                  @dtw_assign(operNbr, "operUDF4")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchUDF4" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (UDF5 != "")
                              <tr><td class="dsphdr">$(UDF5)</td>
                                  @dtw_assign(operNbr, "operUDF5")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"> <input type="text" name="srchUDF5" size="15" maxlength="15"></td>
                              </tr>
                          %endif
                    		
                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchNumber.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @RtvFldDesc("CPSCR1<>' '", "APCTRL", "CPSCR1", UDF1)
  @RtvFldDesc("CPSCR2<>' '", "APCTRL", "CPSCR2", UDF2)
  @RtvFldDesc("CPSCR3<>' '", "APCTRL", "CPSCR3", UDF3)
  @RtvFldDesc("CPSCR4<>' '", "APCTRL", "CPSCR4", UDF4)
  @RtvFldDesc("CPSCR5<>' '", "APCTRL", "CPSCR5", UDF5)

  @Build_WildCard ("VMVEND", "Vendor Number", $(srchNumber), "", operNumber, "N")
  @Build_WildCard ("VMVNA1U", "Vendor Name", $(srchName), "U", operName, "A")

  @dtw_assign(srchAddress,@dtw_rstrip(srchAddress))
  %if (srchAddress != "")
      @Build_WildCard ("VMVNA2U", "Address", $(srchAddress), "U", "LIKE", "V")
      @dtw_mUPPERCASE(srchAddress)
      @dtw_replace(srchAddress, "?", "_", "1", "a", srchAddress)
      @dtw_replace(srchAddress, "*", "%", "1", "a", srchAddress)
      @dtw_concat(wildCardTemp, " (trim(VMVNA2U) LIKE '$(srchAddress)'", wildCardTemp)
      @dtw_concat(wildCardTemp, " OR   trim(VMVNA3U) LIKE '$(srchAddress)'", wildCardTemp)
      @dtw_concat(wildCardTemp, " OR   trim(VMVNA4U) LIKE '$(srchAddress)'", wildCardTemp)
      @dtw_concat(wildCardTemp, " OR   trim(VMVCTYU) LIKE '$(srchAddress)')", wildCardTemp)
  %endif
		
  @Build_WildCard ("VMST", "State", $(srchState), "U", operState, "A")
  @Build_WildCard ("VMZIP", "Zip", $(srchZip), "U", operZip, "A")
  @Build_WildCard ("VMPHON", "Phone Number", $(srchPhone), "", "", "P")
  @Build_WildCard ("VMPTRM", "Terms Code", $(srchTerms), "U", operTerms, "A")
  @Build_WildCard ("VMT99", "1099 Code", $(srch1099), "U", oper1099, "A")
  @Build_WildCard ("VMVTYP", "Vendor Type", $(srchType), "U", operType, "A")
  @Build_WildCard ("VMRTVD", "Remit To Vendor", $(srchRemitTo), "", operRemitTo, "N")
  @Build_WildCard ("VMVSTS", "Vendor Status", $(srchStatus), "U", operStatus, "A")
  @Build_WildCard ("VMSVSV", "Ship Via Code", $(srchShipVia), "U", operShipVia, "A")
  @Build_WildCard ("VMFOBC", "FOB Code", $(srchFOB), "U", operFOB, "A")
  @Build_WildCard ("VMUDF1", "$(UDF1)", $(srchUDF1), "U", operUDF1, "A")
  @Build_WildCard ("VMUDF2", "$(UDF2)", $(srchUDF2), "U", operUDF2, "A")
  @Build_WildCard ("VMUDF3", "$(UDF3)", $(srchUDF3), "U", operUDF3, "A")
  @Build_WildCard ("VMUDF4", "$(UDF4)", $(srchUDF4), "U", operUDF4, "A")
  @Build_WildCard ("VMUDF5", "$(UDF5)", $(srchUDF5), "U", operUDF5, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
