%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"

%Define {
  page_title              = "Sales Forecast Inquiry"
  d2wName                 = "SalesForecastInquiry8.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;type=@dtw_rurlescseq(type)&amp;reference=@dtw_rurlescseq(reference)&amp;year=@dtw_rurlescseq(year)&amp;fdky=@dtw_rurlescseq(fdky)&amp;cust=@dtw_rurlescseq(cust)&amp;FDCUST=@dtw_rurlescseq(FDCUST)&amp;ccls=@dtw_rurlescseq(ccls)&amp;FDCCLS=@dtw_rurlescseq(FDCCLS)&amp;creg=@dtw_rurlescseq(creg)&amp;FDCRGN=@dtw_rurlescseq(FDCRGN)&amp;loc=@dtw_rurlescseq(loc)&amp;FDLOC=@dtw_rurlescseq(FDLOC#)&amp;slmn=@dtw_rurlescseq(slmn)&amp;FDSLSM=@dtw_rurlescseq(FDSLSM)&amp;pcls=@dtw_rurlescseq(pcls)&amp;FDPCLS=@dtw_rurlescseq(FDPCLS)&amp;bac=@dtw_rurlescseq(bac)&amp;FDBAC=@dtw_rurlescseq(FDBAC)&amp;ptyp=@dtw_rurlescseq(ptyp)&amp;FDPTYP=@dtw_rurlescseq(FDPTYP)&amp;plant=@dtw_rurlescseq(plant)&amp;item=@dtw_rurlescseq(item)&amp;parttype=@dtw_rurlescseq(parttype)&amp;periodFormat=@dtw_rurlescseq(periodFormat)&amp;quantityFormat=@dtw_rurlescseq(quantityFormat)&amp;backHome=@dtw_rurlescseq(backHome)"
  d2wVarBaseO             = "$(genericVarBase)&amp;type=@dtw_rurlescseq(type)&amp;reference=@dtw_rurlescseq(reference)&amp;year=@dtw_rurlescseq(year)&amp;fdky=@dtw_rurlescseq(fdky)&amp;cust=@dtw_rurlescseq(cust)&amp;FDCUST=@dtw_rurlescseq(FDCUST)&amp;ccls=@dtw_rurlescseq(ccls)&amp;FDCCLS=@dtw_rurlescseq(FDCCLS)&amp;creg=@dtw_rurlescseq(creg)&amp;FDCRGN=@dtw_rurlescseq(FDCRGN)&amp;loc=@dtw_rurlescseq(loc)&amp;FDLOC=@dtw_rurlescseq(FDLOC#)&amp;slmn=@dtw_rurlescseq(slmn)&amp;FDSLSM=@dtw_rurlescseq(FDSLSM)&amp;pcls=@dtw_rurlescseq(pcls)&amp;FDPCLS=@dtw_rurlescseq(FDPCLS)&amp;bac=@dtw_rurlescseq(bac)&amp;FDBAC=@dtw_rurlescseq(FDBAC)&amp;ptyp=@dtw_rurlescseq(ptyp)&amp;FDPTYP=@dtw_rurlescseq(FDPTYP)&amp;plant=@dtw_rurlescseq(plant)&amp;item=@dtw_rurlescseq(item)&amp;parttype=@dtw_rurlescseq(parttype)&amp;&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
  smallPromptWinPctH      = "50"
%}


%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@type", "@dtw_rurlescseq(type)", "1", "a", workURL)
  @dtw_replace(workURL, "@@reference", "@dtw_rurlescseq(reference)", "1", "a", workURL)
  @dtw_replace(workURL, "@@year", "@dtw_rurlescseq(year)", "1", "a", workURL)
  @dtw_replace(workURL, "@@fdky", "@dtw_rurlescseq(fdky)", "1", "a", workURL)
  @dtw_replace(workURL, "@@cust", "@dtw_rurlescseq(cust)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
              %INCLUDE "NoFormValidate.icl"
              %INCLUDE "ShowHideSelCriteria.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "SALESFORECASTINQUIRY8")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif

                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " WKMINQ ", fileSQL)
                      @dtw_concat(selectSQL, " IQXHND='$(profileHandle)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td>&nbsp;</td>
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                        <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      <a onclick="showSel('options');">$(optionsImage)</a>
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
          %INCLUDE "SalesForecastInquiryOptions.icl"
      </table>
      @RtvFldDesc("FTFTYP='$(type)' and FTREFN='$(reference)' and FTYEAR='$(year)' ", "HDMFDF", "FTFCLD", longDescription)
      @RtvFldDesc("FTFTYP='$(type)' and FTREFN='$(reference)' and FTYEAR='$(year)' ", "HDMFDF", "FTSDAT", startDate)
      @RtvFldDesc("FTFTYP='$(type)' and FTREFN='$(reference)' and FTYEAR='$(year)' ", "HDMFDF", "FTEDAT", endDate)
      @Format_Date_ISO(startDate, "H", F_FTSDAT)
      @Format_Date_ISO(endDate, "H", F_FTEDAT)
      <table $(contentTable)>
          @Format_Header_URL("Forecast Type", $(longDescription), $(type), "")
          @Format_Header_URL("Reference", $(reference), "", "")
          @Format_Header_URL("Forecast Year", $(year), "", "")
          %if (cust == "1")
              @RtvFldDesc("CMCUST=$(FDCUST)", "HDCUST", "CMCNA1", fieldDesc)
              @Format_Header_URL("Customer", $(fieldDesc), $(FDCUST), "")
          %elif (ccls == "1")
              @RtvFldDesc("CCCCLS='$(FDCCLS)' ", "HDCCLS", "CCCCDS", fieldDesc)
              @Format_Header_URL("Customer Class", $(fieldDesc), $(FDCCLS), "")
          %elif (creg == "1")
              @RtvFldDesc("RGCRGN='$(FDCRGN)' ", "HDCRGN", "RGCRDS", fieldDesc)
              @Format_Header_URL("Customer Region", $(fieldDesc), $(FDCRGN), "")
          %elif (loc == "1")
              @RtvFldDesc("LOLO#=$(FDLOC#)", "HDLCTN", "LOLNA1", fieldDesc)
              @Format_Header_URL("Location", $(fieldDesc), $(FDLOC#), "")
          %elif (slmn == "1")
              @RtvFldDesc("SMSLSM=$(FDSLSM)", "HDSLSM", "SMSNA1", fieldDesc)
              @Format_Header_URL("Salesman", $(fieldDesc), $(FDSLSM), "")
          %elif (pcls == "1")
              @RtvFldDesc("PCPCLS='$(FDPCLS)' ", "HDPCLS", "PCPCDS", fieldDesc)
              @Format_Header_URL("Product Class", $(fieldDesc), $(FDPCLS), "")
          %elif (bac == "1")
              @RtvFldDesc("BMBUYR=$(FDBAC)", "HDBUYR", "BMBNA1", fieldDesc)
              @Format_Header_URL("Buyer/Analyst", $(fieldDesc), $(FDBAC), "")
          %elif (ptyp == "1")
              @Format_Header_URL("Part Type", $(FDPTYP), "", "")
          %endif
          %if (cust == "2")
              @RtvFldDesc("CMCUST=$(FDCUST)", "HDCUST", "CMCNA1", fieldDesc)
              @Format_Header_URL("Customer", $(fieldDesc), $(FDCUST), "")
          %elif (ccls == "2")
              @RtvFldDesc("CCCCLS='$(FDCCLS)' ", "HDCCLS", "CCCCDS", fieldDesc)
              @Format_Header_URL("Customer Class", $(fieldDesc), $(FDCCLS), "")
          %elif (creg == "2")
              @RtvFldDesc("RGCRGN='$(FDCRGN)' ", "HDCRGN", "RGCRGN", fieldDesc)
              @Format_Header_URL("Customer Region", $(fieldDesc), $(FDCRGN), "")
          %elif (loc == "2")
              @RtvFldDesc("LOLO#=$(FDLOC#)", "HDLCTN", "LOLNA1", fieldDesc)
              @Format_Header_URL("Location", $(fieldDesc), $(FDLOC#), "")
          %elif (slmn == "2")
              @RtvFldDesc("SMSLSM=$(FDSLSM)", "HDSLSM", "SMSNA1", fieldDesc)
              @Format_Header_URL("Salesman", $(fieldDesc), $(FDSLSM), "")
          %elif (pcls == "2")
              @RtvFldDesc("PCPCLS='$(FDPCLS)' ", "HDPCLS", "PCPCDS", fieldDesc)
              @Format_Header_URL("Product Class", $(fieldDesc), $(FDPCLS), "")
          %elif (bac == "2")
              @RtvFldDesc("BMBUYR=$(FDBAC)", "HDBUYR", "BMBNA1", fieldDesc)
              @Format_Header_URL("Buyer/Analyst", $(fieldDesc), $(FDBAC), "")
          %elif (ptyp == "2")
              @Format_Header_URL("Part Type", $(FDPTYP), "", "")
          %endif
          %if (cust == "3")
              @RtvFldDesc("CMCUST=$(FDCUST)", "HDCUST", "CMCNA1", fieldDesc)
              @Format_Header_URL("Customer", $(fieldDesc), $(FDCUST), "")
          %elif (ccls == "3")
              @RtvFldDesc("CCCCLS='$(FDCCLS)' ", "HDCCLS", "CCCCDS", fieldDesc)
              @Format_Header_URL("Customer Class", $(fieldDesc), $(FDCCLS), "")
          %elif (creg == "3")
              @RtvFldDesc("RGCRGN='$(FDCRGN)' ", "HDCRGN", "RGCRGN", fieldDesc)
              @Format_Header_URL("Customer Region", $(fieldDesc), $(FDCRGN), "")
          %elif (loc == "3")
              @RtvFldDesc("LOLO#=$(FDLOC#)", "HDLCTN", "LOLNA1", fieldDesc)
              @Format_Header_URL("Location", $(fieldDesc), $(FDLOC#), "")
          %elif (slmn == "3")
              @RtvFldDesc("SMSLSM=$(FDSLSM)", "HDSLSM", "SMSNA1", fieldDesc)
              @Format_Header_URL("Salesman", $(fieldDesc), $(FDSLSM), "")
          %elif (pcls == "3")
              @RtvFldDesc("PCPCLS='$(FDPCLS)' ", "HDPCLS", "PCPCDS", fieldDesc)
              @Format_Header_URL("Product Class", $(fieldDesc), $(FDPCLS), "")
          %elif (bac == "3")
              @RtvFldDesc("BMBUYR=$(FDBAC)", "HDBUYR", "BMBNA1", fieldDesc)
              @Format_Header_URL("Buyer/Analyst", $(fieldDesc), $(FDBAC), "")
          %elif (ptyp == "3")
              @Format_Header_URL("Part Type", $(FDPTYP), "", "")
          %endif
          %IF (startDate != "")
              @Format_Header_URL("Start Date", $(F_FTSDAT), "", "")
          %endif
          %IF (endDate != "")
              @Format_Header_URL("End Date", $(F_FTEDAT), "", "")
          %endif
          @RtvFldDesc("PLPLNT=$(plant)", "HDPLNT", "PLNAME", plantName)
          @Format_Header_URL("Plant Number", $(plantName), $(plant), "")
          @RtvFldDesc("IMITEM='$(item)'", "HDIMST", "IMIMDS", itemDescription)
          @Format_Header_URL("Item Number", $(itemDescription), $(item), "")
          @Format_Header_URL("Part Type", $(parttype), "", "")
      </table>
      $(hrTagAttr)

      %if (formatToPrint != "Y")
              <table $(contentTable)>
                  <tr><td> %INCLUDE "AssignPageValue.icl" </td>
                      <td>&nbsp;</td>

                  </tr>
              </table>
          %endif
      <table $(contentTable)>
         <tr><th class="colhdr"> Period<br>End</th>
             <th class="colhdr"> Forecast</th>
             <th class="colhdr"> Customer<br>Demand</th>
             <th class="colhdr"> Accum<br>Difference</th>
             <th class="colhdr"> Last Year<br>Forecast</th>
             <th class="colhdr"> Sales<br>History</th>
         </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Date(V_IQEDAT, "1", F_IQEDAT)
              %if (quantityFormat == "01")
                  @Format_Nbr(V_IQFQTYU, F_IQFQTY, "0", "Z", "", "", "")
                  @Format_Nbr(V_IQDMNDU, F_IQDMND, "0", "Z", "", "", "")
                  @Format_Nbr(V_IQDIFFU, F_IQDIFF, "0", "M", "", "", "")
                  @Format_Nbr(V_IQLASTU, F_IQLAST, "0", "Z", "", "", "")
                  @Format_Nbr(V_IQHISTU, F_IQHIST, "0", "Z", "", "", "")
              %else
                  @Format_Nbr(V_IQFQTY, F_IQFQTY, "2", "M", "Y", "", "")
                  @Format_Nbr(V_IQDMND, F_IQDMND, "2", "M", "Y", "", "")
                  @Format_Nbr(V_IQDIFF, F_IQDIFF, "2", "M", "Y", "", "")
                  @Format_Nbr(V_IQLAST, F_IQLAST, "2", "M", "Y", "", "")
                  @Format_Nbr(V_IQHIST, F_IQHIST, "2", "M", "Y", "", "")
              %endif

              <tr class="$(rowClass)">
                  <td class="colnmbr">$(F_IQEDAT)</td>
                  <td class="colnmbr">$(F_IQFQTY)</td>
                  %if (V_HDOERL>"0")
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)SalesForecastInquiryCustomerDemand.d2w/REPORT$(d2wVarBase)&amp;IQBDAT=@dtw_rurlescseq(V_IQBDAT)&amp;IQEDAT=@dtw_rurlescseq(V_IQEDAT)"title="Click Here For Customer Demand Inquiry">$(F_IQDMND)</a></td>
                  %else
                      <td class="colnmbr">$(F_IQDMND)</td>
                  %endif
                  <td class="colnmbr">$(F_IQDIFF)</td>
                  <td class="colnmbr">$(F_IQLAST)</td>
                  %if (V_HDOERL>"0")
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)SalesForecastInquirySalesHistory.d2w/REPORT$(d2wVarBase)&amp;quantityFormat=@dtw_rurlescseq(quantityFormat)&amp;IQHBGN=@dtw_rurlescseq(V_IQHBGN)&amp;IQHEND=@dtw_rurlescseq(V_IQHEND)"title="Click Here For Sales History Inquiry">$(F_IQHIST)</a></td>
                  %else
                      <td class="colnmbr">$(F_IQHIST)</td>
                  %endif
              </tr>

          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Forecast_Inquiry (IN CHAR(64) profileHandle,
			                            IN CHAR(2)  dataBaseID,
                                            IN DEC(3, 0) type,
                                            IN CHAR(8) reference,
                                            IN DEC(4, 0) year,
                                            IN CHAR(20) fdky,
                                            IN DEC(3, 0) plant,
                                            IN CHAR(15) item,
                                            INOUT DEC(2, 0) periodFormat,
                                            INOUT DEC(2, 0) quantityFormat)


  {%EXEC {HMS435_W.PGM %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"

  %if (formatToPrint == "Y")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else

      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "IQEDAT")
          @DTW_ASSIGN(orderByDisplay, "Period End")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif

  %INCLUDE "SearchReturn.icl"
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
  @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)

  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "IQEDAT")
          @DTW_ASSIGN(orderByDisplay, "Period End")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(LOAD)  {
  %INCLUDE "setLibraryList.icl"
  @Forecast_Inquiry(profileHandle, dataBaseID, type, reference, year, fdky, plant, item, periodFormat, quantityFormat)
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/ENTRY$(d2wVarBase)">
%}