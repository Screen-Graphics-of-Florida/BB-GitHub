%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Detail Pay History"
  d2wName                 = "EmplDetailPayHistory.d2w"
  d2wVarBase              = "$(genericVarBase)$(employeeVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPRCHI"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  inclActive              = ""
  inclTerminated          = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "DateEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              function validate(searchForm) {
                  if (editdate(document.Search.srchDateWorked))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "EMPLDTLHIST")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "UserViewEmpl.icl"
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select  EHCKDT, EHCKNO, ", stmtSQL)
                      @dtw_concat(stmtSQL, " EHPREF, SHREC, SHSEQ,  SHDTWK, SHHRUN, SHHOUR, SHEARN, SHCODE, SHDEPT, ", stmtSQL)
                      @dtw_concat(stmtSQL, " SHGLCO, SHGLFA, SHACCT, SHSACT, SHJOB,  SHOVRT, SHSHFW, SHSUMT, SHWORK, ", stmtSQL)
                      @dtw_concat(stmtSQL, " EMCOMP, EMFACL, EMEMPL, EMLNAM, EMFNAM, EMMIDI, EMRNAM, ", stmtSQL)
                      @dtw_concat(stmtSQL, " EMTYPE, EMLOC,  EMDEPT, EMJOB, EMPRAC, EMTRDT, EMTRCD, EMLNAMU, EMFNAMU ", stmtSQL)
                      @dtw_concat(fileSQL, "  HREMPL inner join PRDTHS on EMCOMP=SHCOMP and EMFACL=SHFACL and EMEMPL=SHEMPL ", fileSQL)
                      @dtw_concat(fileSQL, "         inner join PRCKHS on SHPREF=EHPREF ", fileSQL)
                      @dtw_concat(selectSQL, " EHCOMP = $(prCompany) and EMFACL = $(prFacility) and EHEMPL = $(prEmployee) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @PayHistory_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) PayHistory_Query (IN CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count != "1")
          @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>

          @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
          <tr><td><h2>$(F_EmpName)</h2></td></tr>

          </table>
          %INCLUDE "ConfMessageDisplay.icl"

          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Pay<br>Code</th>
                          <th class="colhdr">Date<br>Worked</th>
                      </tr>
                      <tr><td><input type="text" class="inputalph" name="srchPayCode" size="3" maxlength="3">
                              <input type="hidden" name="operPayCode" value="LIKE">
                          </td>
                          <td><input type="text" class="inputnmbr" name="srchDateWorked" size="6" maxlength="6">
                              <input type="hidden" name="operDateWorked" value="=">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchPayCode.focus();
                  </script>
              </form>

              %INCLUDE "ActiveTerminatedChecked.icl"
              @dtw_assign(viewCheckBox, "HR")
              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("EHCKNO", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CheckNumber" title="Sequence By Check Number, Check Date (descending)">Check<br>Number</a></th>
                  @OrderBy_Sort("EHCKDT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CheckDate" title="Sequence By Check Date, Check Number (descending)">Check<br>Date</a></th>
                  @OrderBy_Sort("EHRCCD", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CheckType" title="Sequence By Check Type, Check Date (descending), Check Number">Check Type</a></th>	
                  @OrderBy_Sort("SHDTWK", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DateWorked" title="Sequence By Date Worked, Pay Code">Date<br>Worked</a></th>
                  @OrderBy_Sort("SHCODE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PayCode" title="Sequence By Pay Code, Employee Number, Date Worked (descending)">Pay<br>Code</a></th>
                  <th class="colhdr">Description</th>
                  <th class="colhdr">Hours</th>
                  <th class="colhdr">Units</th>
                  <th class="colhdr">Pay<br>Rate</th>
                  <th class="colhdr">Earnings</th>
                  @OrderBy_Sort("SHSHFW", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ShiftWorked" title="Sequence By Shift Worked, Employee Number, Descending Date Worked">Shift<br>Worked</a></th>
                  @OrderBy_Sort("SHDEPT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DeptWorked" title="Sequence By Department Worked, Employee Number, Descending Date Worked">Dept<br>Worked</a></th>
                  @OrderBy_Sort("SHACCT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=GlAccount" title="Sequence By G/L Account, Employee Number, Descending Date Worked">G/L<br>Account</a></th>
                  @OrderBy_Sort("SHJOB", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=JobNumber" title="Sequence By Job Number, Employee Number, Descending Date Worked">Job<br>Number</a></th>
              </tr>
          %INCLUDE "NoRecordsFound.icl"
      %endif

              %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;processingReference=@dtw_rurlescseq(V_EHPREF)&amp;detailSequence=@dtw_rurlescseq(V_SHSEQ)")
                  %if (sql_Record_Count == "1")
                      @Save_WebReg(webRegCurFile, profileHandle, d2wName, "", orderBy, orderByDisplay, "")
                      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)EmployeeCheckSelect.d2w/REPORT$(maintainVar)">
                  %else
                      %INCLUDE "SetRowClass.icl"
                      @Format_EmplName(V_EMFNAM, V_EMLNAM, V_EMMIDI, V_EMRNAM, V_EMTRCD, "D", F_EmpName)
                      @Format_Date(V_EHCKDT, "D", F_EHCKDT)
                      @Format_Date(V_SHDTWK, "D", F_SHDTWK)
                      @Format_Acct("$(V_SHACCT)", "$(V_SHSACT)", "", F_AcctSub)
                      @RtvFldDesc("C2COMP=$(prCompany) and C2FACL=$(prFacility) and C2CODE='$(V_SHCODE)'", "PRCODE", "C2DESC", payCodeDesc)
                      @RtvFldDesc("FLTYPE='PRCHKTYPE' and FLVALU='$(V_SHREC)'", "SYFLAG", "FLDESC", checkTypeDesc)

                      <tr class="$(rowClass)">
                          %if ((V_EMTYPE == "H" && sec_06 == "N") || (V_EMTYPE != "H" && sec_07 == "N"))
                              <td class="colnmbr">$(V_EHCKNO)</td>
                          %else
                              <td class="colnmbr"><a href="$(homeURL)$(cGIPath)EmployeeCheckSelect.d2w/REPORT$(maintainVar)" title="View Check Information">$(V_EHCKNO)</a></td>
                          %endif
	                   <td class="coldate"> $(F_EHCKDT)</td>
                          <td class="colcode" $(helpCursor)><span title="$(checkTypeDesc)">$(V_SHREC)</span></td>
	                   <td class="coldate"> $(F_SHDTWK)</td>
	   	           %if ((V_EMTYPE == "H" && sec_06 == "N") || (V_EMTYPE != "H" && sec_07 == "N"))
                              <td class="colalph">$(V_SHCODE)</td>
                          %else
	                       <td class="colalph"><a href="$(homeURL)$(cGIPath)EmployeePayDetailSelect.d2w/REPORT$(maintainVar)" title="View Pay Detail Information">$(V_SHCODE)</a></td>
                          %endif
	                   <td class="colalph"> $(payCodeDesc)</td>
                          %if (V_SHHRUN == "H")
                               @Format_Nbr($(V_SHHOUR), F_SHHOUR, "2", $(hrsEditCode), "", "", "")
	                       <td class="colnmbr"> $(F_SHHOUR)</td>
	                       <td class="colalph"></td>
                          %elif (V_SHHRUN == "U")
                               @Format_Nbr($(V_SHHOUR), F_SHHOUR, "2", $(hrsEditCode), "", "", "")
	                       <td class="colalph"></td>
	                       <td class="colnmbr"> $(F_SHHOUR)</td>
	   	           %else
	                       <td class="colalph"></td>
	                       <td class="colalph"></td>
	   	           %endif
	   	           %if ((V_EMTYPE == "H" && sec_06 == "N") || (V_EMTYPE != "H" && sec_07 == "N"))
                              <td class="colcode">$(earnnotavailImage)</td>
                              <td class="colcode">$(earnnotavailImage)</td>
                          %else
                              %if (V_SHOVRT == ".000")
                                  @dtw_assign(V_SHOVRT, "")
	                           <td class="colnmbr"> $(V_SHOVRT)</td>
                              %else
                                  @Format_Nbr($(V_SHOVRT), F_SHOVRT, $(rteNbrDec), $(rteEditCode), "", "", "")
	                           <td class="colnmbr"> $(F_SHOVRT)</td>
                              %endif
                              @Format_Nbr($(V_SHEARN), F_SHEARN, "2", $(amtEditCode), "", "", "")
	                       <td class="colnmbr"> $(F_SHEARN)</td>
                          %endif
	                   <td class="colcode"> $(V_SHSHFW)</td>
	                   <td class="colalph"> $(V_SHDEPT)</td>

                          %if ((V_SHGLCO != prCompany) || (V_SHGLFA != prFacility))
                              @dtw_assign(interCompany, "*")
                          %else
                              @dtw_assign(interCompany, " ")
                          %endif
	                   <td class="colalph"> $(F_AcctSub) $(interCompany)</td>
	                   <td class="colalph"> $(V_SHJOB)</td>
                      </tr>
                  %endif
          %}
          </table>
          %if (sql_Record_Count != "1")
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "UserViewEmpl.icl"
  %INCLUDE "userview.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "Select  EHCKDT, EHCKNO, ", stmtSQL)
  @dtw_concat(stmtSQL, " EHPREF, SHREC, SHSEQ,  SHDTWK, SHHRUN, SHHOUR, SHEARN, SHCODE, SHDEPT, ", stmtSQL)
  @dtw_concat(stmtSQL, " SHGLCO, SHGLFA, SHACCT, SHSACT, SHJOB,  SHOVRT, SHSHFW, SHSUMT, SHWORK, ", stmtSQL)
  @dtw_concat(stmtSQL, " EMCOMP, EMFACL, EMEMPL, EMLNAM, EMFNAM, EMMIDI, EMRNAM, ", stmtSQL)
  @dtw_concat(stmtSQL, " EMTYPE, EMLOC,  EMDEPT, EMJOB, EMPRAC, EMTRDT, EMTRCD", stmtSQL)
  @dtw_concat(fileSQL, " hrempl join prdths on emcomp=shcomp and emfacl=shfacl and emempl=shempl join prckhs on shpref=ehpref ", fileSQL)
  @dtw_concat(selectSQL, " EMCOMP = $(prCompany) and EMFACL = $(prFacility) and EMEMPL = $(prEmployee) ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @PayHistory_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) PayHistory_XMLQuery (IN CHAR(64)    profileHandle,
			                    CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @XMLBeginTag("PayHistoryList")
          %ROW{
               %if (V_SHRCCD != "H")
		    @dtw_assign(checkType, "Regular")
               %elif (V_SHRCCD != "M")
		    @dtw_assign(checkType, "Manual/Adjustment")
               %elif (V_SHRCCD != "V")
		    @dtw_assign(checkType, "Void")
               %endif
               @RetPayCodeDesc(profileHandle, dataBaseID, prCompany, prFacility, V_SHCODE, payCodeDesc)
               @DateFromCYMD(V_EHCKDT)
               @DateFromCYMD(V_SHDTWK)
               @dtw_assign(hoursunit,"")
               %if(V_SHHRUN == "H")
                  @dtw_assign(hoursunit,"Hours")
               %elif(V_SHHRUN == "U")
                  @dtw_assign(hoursunit,"Units")
               %endif

	        %if ((V_EMTYPE == "H" && sec_06 == "N") || (V_EMTYPE != "H" && sec_07 == "N"))
                  @dtw_assign(V_SHEARN,"")
               %endif

		@XMLIDTag(@DTW_rCONCAT(V_EMCOMP, @DTW_rCONCAT("/", @DTW_rCONCAT(V_EMFACL, @DTW_rCONCAT("/", @DTW_rCONCAT(V_EMEMPL, @DTW_rCONCAT("/", @DTW_rCONCAT(V_SHDTWK, @DTW_rCONCAT("/", V_SHCODE)))))))), "EmployeePayDetail ID")
                   @XMLTag(V_EMCOMP, "CompanyNumber")
                   @XMLTag(V_EMFACL, "FacilityNumber")
                   @XMLTag(V_EMEMPL, "EmployeeNumber")
                       @XMLBeginTag("PersonName")
                           @XMLTag(V_EMRNAM, "FormattedName")
                           @XMLTag(V_EMFNAM, "GivenName")
                           @XMLTag(V_EMMIDI, "MiddleName")
                           @XMLTag(V_EMLNAM, "FamilyName")
                       @XMLEndTag("PersonName")
                   @XMLTag(V_EMDEPT, "HomeDepartment")
                   @XMLTag(V_EHCKNO, "CheckNumber")
                   @XMLTag(V_EHCKDT, "CheckDate")
                   @XMLTag(checkType, "CheckType")
                   @XMLTag(V_SHCODE, "PayCode")
                   @XMLTag(payCodeDesc, "PayDescription")
                   @XMLTag(V_SHDTWK, "DateWorked")
                   @XMLTag(V_SHDEPT, "DepartmentWorked")
                   @XMLTag(V_SHSHFW, "ShiftWorked")
                   @XMLTag(hoursunit, "HoursOrUnits")
                   @XMLTag(V_SHHOUR, "HoursUnitValue")
                   @XMLTag(V_SHEARN, "Earnings")
               @XMLEndTag("EmployeePayDetail")
          %}
      @XMLEndTag("PayHistoryList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "EHCKDT DESC, EHCKNO DESC")
              @DTW_ASSIGN(orderByDisplay, "Check Date (descending), Check Number (descending)")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %elif (chgActive == "Y" && inclActive == "Y")
              @dtw_assign(inclActive, "")
          %elif (chgActive == "Y")
              @dtw_assign(inclActive, "Y")
          %elif (chgTerminated == "Y" && inclTerminated == "Y")
              @dtw_assign(inclTerminated, "")
          %elif (chgTerminated == "Y")
              @dtw_assign(inclTerminated, "Y")
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      %if (inclActive == "" && inclTerminated == "" && chgActive != "Y" && chgTerminated != "Y")
          @dtw_assign(inclActive, activeEmpl)
          @dtw_assign(inclTerminated, terminatedEmpl)
      %endif
      %INCLUDE "SearchReturn.icl"
  %endif
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "CheckNumber")
      %if (orderBy == "EHCKNO,EHCKDT DESC")
          @DTW_ASSIGN(orderBy, "EHCKNO DESC,EHCKDT DESC")
          @DTW_ASSIGN(orderByDisplay, "Check Number (descending), Check Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "EHCKNO,EHCKDT DESC")
          @DTW_ASSIGN(orderByDisplay, "Check Number, Check Date (descending)")
      %endif
  %elif (sequence == "CheckDate")
      %if (orderBy == "EHCKDT,EHCKNO DESC")
          @DTW_ASSIGN(orderBy, "EHCKDT DESC,EHCKNO DESC")
          @DTW_ASSIGN(orderByDisplay, "Check Date (descending), Check Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "EHCKDT,EHCKNO DESC")
          @DTW_ASSIGN(orderByDisplay, "Check Date, Check Number (descending)")
      %endif
  %elif (sequence == "CheckType")
      %if (orderBy == "EHRCCD,EHCKDT DESC,EHCKNO")
          @DTW_ASSIGN(orderBy, "EHRCCD DESC,EHCKDT DESC,EHCKNO")
          @DTW_ASSIGN(orderByDisplay, "Check Type (descending), Check Date (descending), Check Number")
      %else
          @DTW_ASSIGN(orderBy, "EHRCCD,EHCKDT DESC,EHCKNO")
          @DTW_ASSIGN(orderByDisplay, "Check Type, Check Date (descending), Check Number")
      %endif
  %elif (sequence == "DateWorked")
      %if (orderBy == "SHDTWK,SHCODE")
          @DTW_ASSIGN(orderBy, "SHDTWK DESC,SHCODE")
          @DTW_ASSIGN(orderByDisplay, "Date Worked (descending), Pay Code")
      %else
          @DTW_ASSIGN(orderBy, "SHDTWK,SHCODE")
          @DTW_ASSIGN(orderByDisplay, "Date Worked, Pay Code")
      %endif
  %elif (sequence == "PayCode")
      %if (orderBy == "SHCODE,EHEMPL,SHDTWK DESC")
          @DTW_ASSIGN(orderBy, "SHCODE DESC,EHEMPL,SHDTWK DESC")
          @DTW_ASSIGN(orderByDisplay, "Pay Code (descending), Employee Number, Date Worked (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SHCODE,EHEMPL,SHDTWK DESC")
          @DTW_ASSIGN(orderByDisplay, "Pay Code, Employee Number, Date Worked (descending)")
      %endif
  %elif (sequence == "ShiftWorked")
      %if (orderBy == "SHSHFW,EHEMPL,SHDTWK DESC")
          @DTW_ASSIGN(orderBy, "SHSHFW DESC,EHEMPL,SHDTWK DESC")
          @DTW_ASSIGN(orderByDisplay, "Shift Worked (descending), Employee Number, Date Worked (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SHSHFW,EHEMPL,SHDTWK DESC")
          @DTW_ASSIGN(orderByDisplay, "Shift Worked, Employee Number, Date Worked (descending)")
      %endif
  %elif (sequence == "DeptWorked")
      %if (orderBy == "SHDEPT,EHEMPL,SHDTWK DESC")
          @DTW_ASSIGN(orderBy, "SHDEPT DESC,EHEMPL,SHDTWK DESC")
          @DTW_ASSIGN(orderByDisplay, "Department Worked (descending), Employee Number, Date Worked (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SHDEPT,EHEMPL,SHDTWK DESC")
          @DTW_ASSIGN(orderByDisplay, "Department Worked, Employee Number, Date Worked (descending)")
      %endif
  %elif (sequence == "GlAccount")
      %if (orderBy == "SHACCT,SHSACT,EHEMPL,SHDTWK DESC")
          @DTW_ASSIGN(orderBy, "SHACCT DESC,SHSACT,EHEMPL,SHDTWK DESC")
          @DTW_ASSIGN(orderByDisplay, "G/L Account (descending), Employee Number, Date Worked (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SHACCT,SHSACT,EHEMPL,SHDTWK DESC")
          @DTW_ASSIGN(orderByDisplay, "G/L Account, Employee Number, Date Worked (descending)")
      %endif
  %elif (sequence == "JobNumber")
      %if (orderBy == "SHJOB,EHEMPL,SHDTWK DESC")
          @DTW_ASSIGN(orderBy, "SHJOB DESC,EHEMPL,SHDTWK DESC")
          @DTW_ASSIGN(orderByDisplay, "Job Number (descending), Employee Number, Date Worked (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SHJOB,EHEMPL,SHDTWK DESC")
          @DTW_ASSIGN(orderByDisplay, "Job Number, Employee Number, Date Worked (descending)")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              @dtw_assign(formName, "Search")
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchCheck, 6, 0) &&
                      editdate(document.Search.srchFromDate) &&
                      editdate(document.Search.srchToDate) &&
                      editdate(document.Search.srchFromWorked) &&
                      editdate(document.Search.srchToWorked) &&
                      %if ((sec_06 == "Y") && (sec_07 == "Y"))
	                      editNum(document.Search.srchPayRate, 6, 5) &&
                      %endif
                      editNum(document.Search.srchAcct, 4, 0) &&
                      editNum(document.Search.srchSub, 4, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CFDTLHISTSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
                      <h2>$(F_EmpName)</h2>

                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Check Number</td>
                              @dtw_assign(operNbr, "operCheck")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchCheck" size="6" maxlength="6"></td>
                          </tr>

                          <tr><td class="dsphdr">From Check Date</td>
                              @dtw_assign(operNbr, "operFromDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchFromDate" size="6" maxlength="6"> 		
                                  <a href="javascript:calWindow('srchFromDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">To Check Date</td>
                              @dtw_assign(operNbr, "operToDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchToDate" size="6" maxlength="6"> 		
                                  <a href="javascript:calWindow('srchToDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">From Date Worked</td>
                              @dtw_assign(operNbr, "operFromWorked")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchFromWorked" size="6" maxlength="6"> 		
                                  <a href="javascript:calWindow('srchFromWorked');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">To Date Worked</td>
                              @dtw_assign(operNbr, "operToWorked")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchToWorked" size="6" maxlength="6"> 		
                                  <a href="javascript:calWindow('srchToWorked');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Pay Code</td>
                              @dtw_assign(operNbr, "operPayCode")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputnmbr"><input name="srchPayCode" type="text" size="4" maxlength="3"> <a href="$(homeURL)$(phpPath)PayCodeSearch.php$(altVarBase)&amp;docName=Search&amp;forCo=@dtw_rurlescseq(prCompany)&amp;forFac=@dtw_rurlescseq(prFacility)&amp;fldName=srchPayCode&amp;fldDesc=codeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="codeDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Summary Pay Type</td>
                              @dtw_assign(operNbr, "operSumType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchSumType" type="text" size="4" maxlength="1"> <a href="$(homeURL)$(cGIPath)SummaryTypeSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Search&amp;fldName=srchSumType&amp;fldDesc=typeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="typeDesc" value="$(typeDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                          @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMTYPE", PAYTYPECODE)
                          %if ((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_07 == "Y"))
                              <tr><td class="dsphdr">Pay Rate</td>
                                  @dtw_assign(operNbr, "operPayRate")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchPayRate" size="13" maxlength="13"></td>
                              </tr>
                          %endif

                          <tr><td class="dsphdr">Shift Worked</td>
                              @dtw_assign(operNbr, "operShift")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchShift" type="text" size="4" maxlength="2"> <a href="$(homeURL)$(cGIPath)ShiftSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Search&amp;fldName=srchShift&amp;fldDesc=shiftDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="shiftDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Department Worked</td>
                              @dtw_assign(operNbr, "operDeptWorked")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchDeptWorked" type="text" size="4" maxlength="5"> <a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Search&amp;fldName=srchDeptWorked&amp;fldDesc=deptWorkedDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="deptWorkedDesc" value="$(deptDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">G/L Account</td>
                              @dtw_assign(operNbr, "operAcct")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchAcct" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">G/L Subaccount</td>
                              @dtw_assign(operNbr, "operSub")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchSub" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Job Number</td>
                              @dtw_assign(operNbr, "operJobNumber")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchJobNumber" size="14" maxlength="14"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchCheck.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("EHCKNO", "Check Number", $(srchCheck), "", operCheck, "N")
  @Build_WildCard ("EHCKDT", "From Check Date", $(srchFromDate), "", operFromDate, "D")
  @Build_WildCard ("EHCKDT", "To Check Date", $(srchToDate), "", operToDate, "D")
  @Build_WildCard ("SHDTWK", "From Date Worked", $(srchFromWorked), "", operFromWorked, "D")
  @Build_WildCard ("SHDTWK", "To Date Worked", $(srchToWorked), "", operToWorked, "D")
  @Build_WildCard ("SHDTWK", "Date Worked", $(srchDateWorked), "", operDateWorked, "D")
  @Build_WildCard ("SHCODE", "Pay Code", $(srchPayCode), "U", operPayCode, "A")
  @Build_WildCard ("SHSUMT", "Summary Pay Type", $(srchSumType), "U", operSumType, "A")
  @Build_WildCard ("SHOVRT", "Pay Rate", $(srchPayRate), "", operPayRate, "N")
  @Build_WildCard ("SHSHFW", "Shift Worked", $(srchShift), "U", operShift, "A")
  @Build_WildCard ("SHDEPT", "Department Worked", $(srchDeptWorked), "U", operDeptWorked, "A")
  @Build_WildCard ("SHACCT", "G/L Account", $(srchAcct), "", operAcct, "N")
  @Build_WildCard ("SHSACT", "G/L Subaccount", $(srchSub), "", operSub, "N")
  @Build_WildCard ("SHJOB", "Job Number", $(srchJobNumber), "U", operJobNumber, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}