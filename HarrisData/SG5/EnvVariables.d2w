%INCLUDE "$(baseVar)"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"

%Define {
  page_title              = "Environment Variable"
  d2wName                 = "EnvVariables.d2w"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  REMOTE_ADDR             = %ENVVAR
  REMOTE_HOST             = %ENVVAR
  REMOTE_USER             = %ENVVAR
  SCRIPT_NAME             = %ENVVAR
  REMOTE_IDENT            = %ENVVAR
  SERVER_SOFTWARE         = %ENVVAR
  SERVER_NAME             = %ENVVAR
  GATEWAY_INTERFACE       = %ENVVAR
  SERVER_PROTOCOL         = %ENVVAR
  SERVER_PORT             = %ENVVAR
  REQUEST_METHOD          = %ENVVAR
  PATH_INFO               = %ENVVAR
  PATH_TRANSLATED         = %ENVVAR
  SCRIPT_NAME             = %ENVVAR
  QUERY_STRING            = %ENVVAR
  CONTENT_TYPE            = %ENVVAR
  CONTENT_LENGTH          = %ENVVAR
  HTTP_REFERER            = %ENVVAR
  QUERY_STRING            = %ENVVAR
  DOCUMENT_ROOT           = %ENVVAR
  HTTP_USER_AGENT         = %ENVVAR
  HTTP_CONTENT_ACCEPT     = %ENVVAR
  REFERER_URL             = %ENVVAR
  AUTH_TYPE               = %ENVVAR
  HTTP_ACCEPT             = %ENVVAR
  HTTP_REFERER            = %ENVVAR
  HTTP_IF_MODIFIED_SINCE  = %ENVVAR
  DOCUMENT_NAME           = %ENVVAR
  DOCUMENT_URI            = %ENVVAR
  DATE_LOCAL              = %ENVVAR
  DATE_GMT                = %ENVVAR
  LAST_MODIFIED           = %ENVVAR
  SERVER_ROOT             = %ENVVAR
  HTTP_SCRIPT             = %ENVVAR
%}
%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
          <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(contentTable)>
              <tr valign="top">
                  <td class="content">
                      <table $(contentTable)>
                          <colgroup>
                              <col width="85%">
                              <col width="10%">
                          <tr><td><h1>$(page_title)</h1></td>
                              <td class="toolbar">
                                  %INCLUDE "CloseWindow.icl"
                                  @dtw_assign(medIcon, "Y")
                                  %INCLUDE "HelpPage.icl"
                              </td>
                          </tr>
                      </table>
                      <table $(contentTable)>
                          <tr>
                              <th class="colhdr">Variable</th>
                              <th class="colhdr">Value</th>
                          </tr>
                          <tr>
                              <td class="colalph">Remote Address</td>
                              <td class="colalph">$(REMOTE_ADDR)</td>
                          </tr>
                          <tr>
                              <td class="colalph">Remote Host</td>
                              <td class="colalph">$(REMOTE_HOST)</td>
                          </tr>
                          <tr>
                              <td class="colalph">Remote User</td>
                              <td class="colalph">$(REMOTE_USER)</td>
                          </tr>
                          <tr>
                              <td class="colalph">Script Name</td>
                              <td class="colalph">$(SCRIPT_NAME)</td>
                          </tr>
                          <tr>
                              <td class="colalph">Remote Ident</td>
                              <td class="colalph">$(REMOT_IDENT)</td>
                          </tr>
                          <tr>
                              <td class="colalph">Server Name</td>
                              <td class="colalph">$(SERVER_NAME)</td>
                          </tr>
                          <tr>
                              <td class="colalph">Server Software</td>
                              <td class="colalph">$(SERVER_SOFTWARE)</td>
                          </tr>
                          <tr>
                              <td class="colalph">Gateway Interface</td>
                              <td class="colalph">$(GATEWAY_INTERFACE)</td>
                          </tr>
                          <tr>
                              <td class="colalph">Server Protocol</td>
                              <td class="colalph">$(SERVER_PROTOCOL)</td>
                          </tr>
                          <tr>
                              <td class="colalph">Server Port</td>
                              <td class="colalph">$(SERVER_PORT)</td>
                          </tr>
                          <tr>
                              <td class="colalph">Request Method</td>
                              <td class="colalph">$(REQUEST_METHOD)</td>
                          </tr>
                          <tr>
                              <td class="colalph">Path Info</td>
                              <td class="colalph">$(PATH_INFO)</td>
                          </tr>
                          <tr>
                              <td class="colalph">Path Translated</td>
                              <td class="colalph">$(Path_Translated)</td>
                          </tr>
                          <tr>
                              <td class="colalph">Script Name</td>
                              <td class="colalph">$(SCRIPT_NAME)</td>
                          </tr>
                          <tr>
                              <td class="colalph">Query Name</td>
                              <td class="colalph">$(QUERY_NAME)</td>
                          </tr>
                          <tr>
                              <td class="colalph">Content Type</td>
                              <td class="colalph">$(CONTENT_TYPE)</td>
                          </tr>
                          <tr>
                              <td class="colalph">Content Length</td>
                              <td class="colalph">$(CONTENT_LENGTH)</td>
                          </tr>
                          <tr>
                              <td class="colalph">URL</td>
                              <td class="colalph">$(HTTP_REFERER)</td>
                          </tr>
                          <tr>
                              <td class="colalph">Query String</td>
                              <td class="colalph">$(QUERY_STRING)</td>
                          </tr>
                          <tr>
                              <td class="colalph">Document Root</td>
                              <td class="colalph">$(DOCUMENT_ROOT)</td>
                          </tr>
                          <tr>
                              <td class="colalph">User Agent</td>
                              <td class="colalph">$(HTTP_USER_AGENT)</td>
                          </tr>
                          <tr>
                              <td class="colalph">Content</td>
                              <td class="colalph">$(HTTP_CONTENT_ACCEPT)</td>
                          </tr>
			   <tr>
                              <td class="colalph">Refer URL</td>
                              <td class="colalph">$(REFERER_URL)</td>
                          </tr>
			   <tr>
                              <td class="colalph">Authorization Type</td>
                              <td class="colalph">$(AUTH_TYPE)</td>
                          </tr>
			   <tr>
                              <td class="colalph">HTTP Accept</td>
                              <td class="colalph">$(HTTP_ACCEPT)</td>
                          </tr>
			   <tr>
                              <td class="colalph">HTTP Reference</td>
                              <td class="colalph">$(HTTP_REFERER)</td>
                          </tr>
			   <tr>
                              <td class="colalph">HTTP Modified Since</td>
                              <td class="colalph">$(HTTP_IF_MODIFIED_SINCE)</td>
                          </tr>
			   <tr>
                              <td class="colalph">Document Name</td>
                              <td class="colalph">$(DOCUMENT_NAME)</td>
                          </tr>
			   <tr>
                              <td class="colalph">Document URI</td>
                              <td class="colalph">$(DOCUMENT_URI)</td>
                          </tr>
			   <tr>
                              <td class="colalph">Date Local</td>
                              <td class="colalph">$(DATE_LOCAL)</td>
                          </tr>
			   <tr>
                              <td class="colalph">Date GMT</td>
                              <td class="colalph">$(DATE_GMT)</td>
                          </tr>
			   <tr>
                              <td class="colalph">Last Date Modified</td>
                              <td class="colalph">$(LAST_MODIFIED)</td>
                          </tr>
			   <tr>
                              <td class="colalph">Server Root</td>
                              <td class="colalph">$(SERVER_ROOT)</td>
                          </tr>
			   <tr>
                              <td class="colalph">HTTP Script</td>
                              <td class="colalph">$(HTTP_SCRIPT )</td>
                          </tr>
                      </table>
                      $(inquiryhrTagAttr)
                      %INCLUDE "CloseWindow.icl"
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>

          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}