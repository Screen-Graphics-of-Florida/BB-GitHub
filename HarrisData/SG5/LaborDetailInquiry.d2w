%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Mfg Order $(mfgOrder) Labor Detail"
  d2wName                 = "LaborDetailInquiry.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;mfgOrder=@dtw_rurlescseq(mfgOrder)&amp;rtgSeqn=@dtw_rurlescseq(rtgSeqn)&amp;touchScreen=@dtw_rurlescseq(touchScreen)"
  nextPrevVar             = "$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  displayCloseIcon        = "Y"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
   %INCLUDE "$(docType)"
   <html>
       <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "dateedit.icl"
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
          </script>
          %INCLUDE "$(genericHead)"
       </head>

       <body $(bodyTagAttr) onLoad="window.focus()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select LDDATE,LDECO,LDEFAC,LDEMP,LDSHFT,LDLBTY,LDWHRS,LDQTYC,LDRSCR,LDMHRC,LDMHRS, ", stmtSQL)
                      @dtw_concat(stmtSQL, " Case When LDWHRS=0 Then 0 Else Dec(Round(LDQTYC * LDMHRS / Case When LDMHRC='M' then 1000 When LDMHRC='H' then 100 else 1 end * LDMPON / LDWHRS * 100,1),13,1) end as effic", stmtSQL)
                      @dtw_concat(fileSQL, " HDMLDM ", fileSQL)
                      @dtw_concat(selectSQL, " LDPLT=$(plantNumber) and LDORD='$(mfgOrder)' and LDSEQN=$(rtgSeqn) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @LaborDetail_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
     </body>
  </html>
%}

%FUNCTION(dtw_sql) LaborDetail_Query (IN CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (touchScreen == "Y")
          @dtw_assign(displayCloseIcon, "")
          @dtw_assign(formatToPrint, "Y")
          <div class="quickLinksTop">
              <ul class="toolbarTS">
                  <li class="optionTS"><a href="javascript:window.close()">&nbsp;<br>Close</a></li>
              </ul>
          </div>
      %else
          @dtw_assign(displayCloseIcon, "Y")
      %endif
      %INCLUDE "PageTitle.icl"

      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      @RtvFldDesc("OHPLT=$(plantNumber) and OHORD='$(mfgOrder)'", "HDMOHM", "OHPN", itemNumber)
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
      <table $(contentTable)>
          @Format_Header("Plant", $(plantName), $(plantNumber))
          @Format_Header("Item", $(itemDescription), $(itemNumber))
          @Format_Header("Routing Sequence", $(rtgSeqn), "")
      </table>

      $(inquiryhrTagAttr)

      <table $(contentTable)>
          <tr><td > %INCLUDE "AssignPageValue.icl" </td></tr>
      </table>

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              @OrderBy_Sort("LDDATE", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=trxnDate" title="Sequence By Transaction Date"> Transaction<br>Date</a></th>
              @OrderBy_Sort("LDEMP", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=emplNumber" title="Sequence By Employee Number"> Employee<br>Number</a></th>
              @OrderBy_Sort("LDSHFT", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=shiftNumber" title="Sequence By Shift"> Shift</a></th>
              @OrderBy_Sort("LDLBTY", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=laborType" title="Sequence By Labor Type"> Labor<br>Type</a></th>
              @OrderBy_Sort("LDWHRS", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=actualHours" title="Sequence By Actual Hours"> Actual<br>Hours</th>
              @OrderBy_Sort("LDQTYC", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=qtyComplete" title="Sequence By Completed Quantity"> Completed<br>Quantity</a></th>
              @OrderBy_Sort("LDRSCR", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=qtyScrap" title="Sequence By Scrapped Quantity"> Scrapped<br>Quantity</a></th>
              @OrderBy_Sort("LDMHRS", sortVar)
              <th class="colhdr$(sortVar)" COLSPAN="2"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=measuredHrs" title="Sequence By Measured Hours"> Measured<br>Hours</a></th>
              @OrderBy_Sort("effic", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=efficPct" title="Sequence By Efficiency">Efficiency %</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @Format_Date_ISO(V_LDDATE, "D", F_LDDATE)
              @Ret_Format_EmplName(V_LDECO, V_LDEFAC, V_LDEMP, "", "", "D", F_EmpName)
              @Format_Nbr(V_LDWHRS, F_LDWHRS, $(hrsNbrDec), $(hrsEditCode), "", "", "")
              @Format_Nbr($(V_LDQTYC), F_LDQTYC, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_LDRSCR), F_LDRSCR, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr(V_LDMHRS, F_LDMHRS, $(rteNbrDec), $(rteEditCode), "", "", "")
              @RtvFldDesc("FLTYPE='RTMHRC' AND FLVALU='$(V_LDMHRC)'", "SYFLAG", "FLDESC", refCodeDesc)
              @Format_Nbr(V_effic, F_effic, "1", $(pctEditCode), "", "", "")

              %INCLUDE "SetRowClass.icl"

              <tr class="$(rowClass)">
                  <td class="coldate">$(F_LDDATE)</td>
                  <td class="colnmbr" $(helpCursor)><span title="$(F_EmpName)">$(V_LDEMP)</span></td>
                  <td class="colcode">$(V_LDSHFT)</td>
                  <td class="colcode">$(V_LDLBTY)</td>
                  <td class="colnmbr">$(F_LDWHRS)</td>
                  <td class="colnmbr">$(F_LDQTYC)</td>
                  <td class="colnmbr">$(F_LDRSCR)</td>
                  <td class="colnmbr">$(F_LDMHRS)</td>
                  <td class="colcode" $(helpCursor)><span title="$(refCodeDesc)">$(V_LDMHRC)</span></td>
                  <td class="colnmbr">$(F_effic)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      $(inquiryhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "LDDATE,LDEMP")
      @DTW_ASSIGN(orderByDisplay, "Transaction Date, Employee Number")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "LDDATE,LDEMP")
      @DTW_ASSIGN(orderByDisplay, "Transaction Date, Employee Number")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "trxnDate")
      %if (orderBy == "LDDATE,LDEMP")
          @DTW_ASSIGN(orderBy, "LDDATE DESC,LDEMP")
          @DTW_ASSIGN(orderByDisplay, "Date (descending), Employee")
      %else
          @DTW_ASSIGN(orderBy, "LDDATE,LDEMP")
          @DTW_ASSIGN(orderByDisplay, "Date, Employee")
      %endif
  %elif (sequence == "emplNumber")
      %if (orderBy == "LDEMP,LDDATE")
          @DTW_ASSIGN(orderBy, "LDEMP DESC,LDDATE")
          @DTW_ASSIGN(orderByDisplay, "Employee (descending), Date")
      %else
          @DTW_ASSIGN(orderBy, "LDEMP,LDDATE")
          @DTW_ASSIGN(orderByDisplay, "Employee, Date")
      %endif
  %elif (sequence == "shiftNumber")
      %if (orderBy == "LDSHFT,LDDATE,LDEMP")
          @DTW_ASSIGN(orderBy, "LDSHFT DESC,LDDATE,LDEMP")
          @DTW_ASSIGN(orderByDisplay, "Shift (descending), Date, Employee")
      %else
          @DTW_ASSIGN(orderBy, "LDSHFT,LDDATE,LDEMP")
          @DTW_ASSIGN(orderByDisplay, "Shift, Date, Employee")
      %endif
  %elif (sequence == "laborType")
      %if (orderBy == "LDLBTY,LDDATE,LDEMP")
          @DTW_ASSIGN(orderBy, "LDLBTY DESC,LDDATE,LDEMP")
          @DTW_ASSIGN(orderByDisplay, "Labor Type (descending), Date, Employee")
      %else
          @DTW_ASSIGN(orderBy, "LDLBTY,LDDATE,LDEMP")
          @DTW_ASSIGN(orderByDisplay, "Labor Type, Date, Employee")
      %endif
  %elif (sequence == "actualHours")
      %if (orderBy == "LDWHRS,LDDATE,LDEMP")
          @DTW_ASSIGN(orderBy, "LDWHRS DESC,LDDATE,LDEMP")
          @DTW_ASSIGN(orderByDisplay, "Actual Hours (descending), Date, Employee")
      %else
          @DTW_ASSIGN(orderBy, "LDWHRS,LDDATE,LDEMP")
          @DTW_ASSIGN(orderByDisplay, "Actual Hours, Date, Employee")
      %endif
  %elif (sequence == "qtyComplete")
      %if (orderBy == "LDQTYC,LDDATE,LDEMP")
          @DTW_ASSIGN(orderBy, "LDQTYC DESC,LDDATE,LDEMP")
          @DTW_ASSIGN(orderByDisplay, "Completed Quantity (descending), Date, Employee")
      %else
          @DTW_ASSIGN(orderBy, "LDQTYC,LDDATE,LDEMP")
          @DTW_ASSIGN(orderByDisplay, "Completed Quantity, Date, Employee")
      %endif
  %elif (sequence == "qtyScrap")
      %if (orderBy == "LDRSCR,LDDATE,LDEMP")
          @DTW_ASSIGN(orderBy, "LDRSCR DESC,LDDATE,LDEMP")
          @DTW_ASSIGN(orderByDisplay, "Scrapped Quantity (descending), Date, Employee")
      %else
          @DTW_ASSIGN(orderBy, "LDRSCR,LDDATE,LDEMP")
          @DTW_ASSIGN(orderByDisplay, "Scrapped Quantity, Date, Employee")
      %endif
  %elif (sequence == "measuredHrs")
      %if (orderBy == "LDMHRS,LDDATE,LDEMP")
          @DTW_ASSIGN(orderBy, "LDMHRS DESC,LDDATE,LDEMP")
          @DTW_ASSIGN(orderByDisplay, "Measured Hours (descending), Date, Employee")
      %else
          @DTW_ASSIGN(orderBy, "LDMHRS,LDDATE,LDEMP")
          @DTW_ASSIGN(orderByDisplay, "Measured Hours, Date, Employee")
      %endif
  %elif (sequence == "efficPct")
      %if (orderBy == "effic,LDDATE,LDEMP")
          @DTW_ASSIGN(orderBy, "effic DESC,LDDATE,LDEMP")
          @DTW_ASSIGN(orderByDisplay, "Efficiency (descending), Date, Employee")
      %else
          @DTW_ASSIGN(orderBy, "effic,LDDATE,LDEMP")
          @DTW_ASSIGN(orderByDisplay, "Efficiency, Date, Employee")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}