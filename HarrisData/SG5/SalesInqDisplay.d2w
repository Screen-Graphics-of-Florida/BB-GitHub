%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Sales Inquiry"
  d2wName                 = "SalesInqDisplay.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;allUsers=@dtw_rurlescseq(allUsers)&amp;selectSequence=@dtw_rurlescseq(selectSequence)&amp;userSQL=@dtw_rurlescseq(userSQL)&amp;selectRecSQL=@dtw_rurlescseq(selectRecSQL)&amp;selectGroup=@dtw_rurlescseq(selectGroup)&amp;selectGroupBy=@dtw_rurlescseq(selectGroupBy)&amp;selectGroupSQL=@dtw_rurlescseq(selectGroupSQL)&amp;groupBy=@dtw_rurlescseq(groupBy)&amp;grpFldLvl=@dtw_rurlescseq(grpFldLvl)&amp;selectDesc=@dtw_rurlescseq(selectDesc)&amp;totalByQty=@dtw_rurlescseq(totalByQty)&amp;totalByAmt=@dtw_rurlescseq(totalByAmt)&amp;totalByCnt=@dtw_rurlescseq(totalByCnt)&amp;downloadProfileHandle=@dtw_rurlescseq(downloadProfileHandle)"
  currentURL              = "$(homeURL)$(cGIPath)$(d2wName)/PROCESS$(d2wVarBase)&amp;START_ROW_NUM=@dtw_rurlescseq(START_ROW_NUM)"
  nextPrevVar             = "$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_SET_TOTAL_ROWS      = "YES"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  DTW_PAD_PGM_PARMS       = "YES"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  custType                = "S"
  selectName              = "SALESINQ"
  selectGroupSQL          = ""
  totalByQty              = ""
  totalByAmt              = ""
  totalByCnt              = ""
%}

%INCLUDE "opersel_bldSQL.icl"

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "AJAXRequest.icl"
              %INCLUDE "SaveCurrentURL.icl"
              %INCLUDE "Menu.js"
	          %INCLUDE "numedit.icl"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "SALESINQ")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      @dtw_assign(uv_BillingLocationName, "HHLOC#")
                      @dtw_assign(uv_SalesmanName, "HHSLSM")
                      @dtw_assign(uv_OEOrderTypeName, "HHORTY")
                      @dtw_assign(uv_BankName, "HHBANK")
                      @dtw_assign(uv_ShipToName, "DHSHTO")
                      @dtw_assign(uv_ProductClassName, "DHPCLS")
                      @dtw_assign(uv_ProductGroupName, "DHPGRP")
                      @dtw_assign(uv_WarehouseName, "DHWH  ")
                      %INCLUDE "userview.icl"

                      <table $(contentTable)>
            	           <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1>$(selectDesc)</h1></td>
                              %if (formatToPrint != "Y")
                                  <td class="toolbar">
                                      <a href="$(homeURL)$(cGIPath)SalesInqSelect.d2w/RETRIEVE$(d2wVarBase)">$(previousImage)</a>
                                      %if (userSQL == "")
                                          <a href="$(homeURL)$(cGIPath)salesinqupdate.d2w/DISPLAY$(genericVarBase)&amp;selectSequence=@dtw_rurlescseq(selectSequence)&amp;userSQL=@dtw_rurlescseq(userSQL)" onclick="$(selectionWinVar)">$(selectAcceptImage)</a>
                                      %endif
                                      <a href="$(homeURL)$(cGIPath)salesinqcriteria.d2w/DISPLAY$(genericVarBase)&amp;selectSequence=@dtw_rurlescseq(selectSequence)&amp;userSQL=@dtw_rurlescseq(userSQL)" onclick="$(selectionWinVar)">$(selectCriteriaImage)</a>
                                      <a href="$(homeURL)$(cGIPath)$(d2wName)/PROCESS$(d2wVarBase)$(orderByVarBase)&amp;grpFldTyp=formatPrt&amp;formatToPrint=Y" target=_blank>$(formatPrintMed)</a>
                                      @dtw_assign(medIcon, "Y")
                                      %INCLUDE "HelpPage.icl"
                                  </td>
                              %endif
                          </tr>
                      </table>

                      $(hrTagAttr)

                      %if (selectGroupSQL != "")
                          @dtw_assign(stmtSQL, "")
                          @dtw_concat(stmtSQL, " SELECT * FROM SYUSLG WHERE SGXHND='$(downloadProfileHandle)' and SGSEQ#=$(selectSequence) ", stmtSQL)
                          @dtw_concat(stmtSQL, " ORDER BY SGGBLV ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                          @dtw_assign(START_ROW_NUM, "1")
                          @dtw_assign(SAVE_MAX_ROWS, RPT_MAX_ROWS)
                          @dtw_assign(RPT_MAX_ROWS, "9999")
                          @GroupBy_Query(profileHandle, dataBaseID, stmtSQL)
                          @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                          @dtw_assign(RPT_MAX_ROWS, SAVE_MAX_ROWS)
                      %endif

                      @dtw_replace(selectGroupSQL, "@@LIYR", "year(F_MAKEDATE(DHDTLI))", selectGroupSQL)
                      @dtw_replace(selectGroupSQL, "@@LIQT", "quarter(F_MAKEDATE(DHDTLI))", selectGroupSQL)
                      @dtw_replace(selectGroupSQL, "@@LIMO", "month(F_MAKEDATE(DHDTLI))", selectGroupSQL)
                      @dtw_replace(selectGroupSQL, "@@LIWK", "week(F_MAKEDATE(DHDTLI))", selectGroupSQL)

                      @dtw_replace(selectGroupSQL, "@@SDYR", "year(F_MAKEDATE(HHDOTS))", selectGroupSQL)
                      @dtw_replace(selectGroupSQL, "@@SDQT", "quarter(F_MAKEDATE(HHDOTS))", selectGroupSQL)
                      @dtw_replace(selectGroupSQL, "@@SDMO", "month(F_MAKEDATE(HHDOTS))", selectGroupSQL)
                      @dtw_replace(selectGroupSQL, "@@SDWK", "week(F_MAKEDATE(HHDOTS))", selectGroupSQL)

                      @dtw_assign(stmtSQL, "")
                      @dtw_concat(stmtSQL, "WITH TOTAL(TOTQTY,TOTAMT,TOTCST,TOTMAMT,TOTMPCT,TOTCNT) AS ", stmtSQL)
                      @dtw_concat(stmtSQL, " (SELECT sumqty, sumamt, sumcst, sumamt-sumcst as marginamt, case when sumamt = 0 then 0 else dec(((sumamt-sumcst)/sumamt),15,5)*100 end as marginpct, sumcnt ", stmtSQL)
                      @dtw_concat(stmtSQL, " From Table (SELECT sum(DHQSTC) as sumqty, dec(sum(round((DHQSTC*DHSLPR),2)/DHORUF),15,2) as sumamt, dec(sum(DHQSTC*DHCOST),15,5) as sumcst, count(*) as sumcnt ", stmtSQL)
                      @dtw_concat(stmtSQL, " From HDCUST inner join OEORDH on CMCUST=DHSHTO ", stmtSQL)
                      @dtw_concat(stmtSQL, "             inner join OEORHH on HHORD#=DHORD# and HHSEQ#=DHSEQ#", stmtSQL)
                      @dtw_concat(stmtSQL, "             left  join HDIMST on IMITEM=DHITEM ", stmtSQL)
                      @dtw_concat(stmtSQL, " $(selectRecSQL)", stmtSQL)
                      %if (selectGroupSQL != "")
                          @dtw_concat(stmtSQL, " and ($(selectGroupSQL))", stmtSQL)
                      %endif
                      %if (uv_Sql != "")
                          @dtw_concat(stmtSQL, " and ($(uv_Sql))", stmtSQL)
                      %endif
                      %if (userSQL != "")
                          @dtw_concat(stmtSQL, " and ($(userSQL))", stmtSQL)
                      %endif
                      @dtw_concat(stmtSQL, ") as TempA) ", stmtSQL)

                      @dtw_concat(stmtSQL, " Select CMCNA1, CMCNA1U, CMCNA2, CMCNA2U, CMCNA3, CMCNA3U, CMCNA4, CMCNA4U, CMCCTY, CMCCTYU, CMST, CMZIP, CMCCLS, CMCRGN, ", stmtSQL)
                      @dtw_concat(stmtSQL, " HHLOC#, HHSLSM, HHORTY, HHBANK, HHLIV#,", stmtSQL)
                      @dtw_concat(stmtSQL, " DHORD#, DHSEQ#, DHDTLI, DHSHTO, DHBLTO, DHITEM, DHIMDS,", stmtSQL)
                      @dtw_concat(stmtSQL, " DHQSTC, DHSLPR, DHORUF, DHPCLS, DHPGRP, DHWH, DHOREC, DHLOC#,", stmtSQL)
                      @dtw_concat(stmtSQL, " SUMAMT, SUMAMT-SUMCST as MARGINAMT, case when SUMAMT = 0 then 0 else dec(((SUMAMT-SUMCST)/SUMAMT),15,5)*100 end as MARGINPCT, Temp.* ", stmtSQL)
                      @dtw_concat(stmtSQL, " From Table (Select CMCNA1, CMCNA1U, CMCNA2, CMCNA2U, CMCNA3, CMCNA3U, CMCNA4, CMCNA4U, CMCCTY, CMCCTYU, CMST, CMZIP, CMCCLS, CMCRGN, ", stmtSQL)
                      @dtw_concat(stmtSQL, " HHLOC#, HHSLSM, HHORTY, HHBANK, HHLIV#,", stmtSQL)
                      @dtw_concat(stmtSQL, " DHORD#, DHSEQ#, DHDTLI, year(F_MAKEDATE(DHDTLI)) as LIYEAR, quarter(F_MAKEDATE(DHDTLI)) as LIQTR, month(F_MAKEDATE(DHDTLI)) as LIMNTH, week(F_MAKEDATE(DHDTLI)) as LIWEEK, DHSHTO, DHBLTO, DHITEM, DHIMDS,", stmtSQL)
                      @dtw_concat(stmtSQL, " year(F_MAKEDATE(HHDOTS)) as SDYEAR, quarter(F_MAKEDATE(HHDOTS)) as SDQTR, month(F_MAKEDATE(HHDOTS)) as SDMNTH, week(F_MAKEDATE(HHDOTS)) as SDWEEK,", stmtSQL)
                      @dtw_concat(stmtSQL, " DHQSTC, DHSLPR, DHORUF, DHPCLS, DHPGRP, DHWH, DHOREC, DHLOC#,", stmtSQL)
                      @dtw_concat(stmtSQL, " dec(round((DHQSTC*DHSLPR),2)/DHORUF,15,2) as sumamt, dec(DHQSTC*DHCOST,15,5) as sumcst, ", stmtSQL)
                      @dtw_concat(stmtSQL, " TOTAL.TOTQTY, TOTAL.TOTAMT, TOTAL.TOTCST, TOTAL.TOTMAMT, TOTAL.TOTMPCT, TOTAL.TOTCNT", stmtSQL)
                      @dtw_concat(stmtSQL, " From HDCUST inner join OEORDH on CMCUST=DHSHTO ", stmtSQL)
                      @dtw_concat(stmtSQL, "             inner join OEORHH on HHORD#=DHORD# and HHSEQ#=DHSEQ#", stmtSQL)
                      @dtw_concat(stmtSQL, "             left  join HDIMST on IMITEM=DHITEM ", stmtSQL)
                      @dtw_concat(stmtSQL, " , TOTAL $(selectRecSQL) ", stmtSQL)
                      %if (selectGroupSQL != "")
                          @dtw_concat(stmtSQL, " and ($(selectGroupSQL))", stmtSQL)
                      %endif
                      %if (uv_Sql != "")
                          @dtw_concat(stmtSQL, " and ($(uv_Sql))", stmtSQL)
                      %endif
                      %if (userSQL != "")
                          @dtw_concat(stmtSQL, " and ($(userSQL))", stmtSQL)
                      %endif
                      @dtw_concat(stmtSQL, " ) as Temp ", stmtSQL)
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Item_Sales_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) GroupBy_Query (IN CHAR(64)    profileHandle,
				      CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{ 
      <table $(contentTable)>
          <tr><th class="colhdr">Group By</th>
              <th class="colhdr">Value</th>
              <th class="colhdr">Description</th>
          </tr>
	
          %ROW{
              <tr>
                 <td class="dspalph"><a href="$(homeURL)$(cGIPath)SalesInqGroupBy.d2w/PROCESS$(genericVarBase)&amp;downloadProfileHandle=@dtw_rurlescseq(downloadProfileHandle)&amp;allUsers=@dtw_rurlescseq(allUsers)&amp;selectSequence=@dtw_rurlescseq(selectSequence)&amp;userSQL=@dtw_rurlescseq(userSQL)&amp;selectGroup=@dtw_rurlescseq($(V_SGSQLS))&amp;grpFldTyp=goToLevel&amp;grpFldVal=@dtw_rurlescseq($(V_SGFVAL))&amp;grpFldLvl=@dtw_rurlescseq(@dtw_radd($(V_SGGBLV), "1"))&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">$(V_SGFHDR)</a></td>
                 <td class="dspcode">$(V_SGFVAL)</td>
                 <td class="dspalph">$(V_SGFDSC)</td>
              </tr>
          %}
      </table>
  %}
%}

%FUNCTION(dtw_sql) Item_Sales_Query (IN CHAR(64)    profileHandle,
				         CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{ 
      @RtvFldDesc("SPUSER='$(userProfile)' and SPPGID='SALESINQ'", "SYPGMS", "SPOP01", displayMargin)
      %if (TOTAL_ROWS > RPT_MAX_ROWS)
          @DTW_ASSIGN(totalPages, @DTW_RINTDIV(TOTAL_ROWS, RPT_MAX_ROWS))
	   %if (@DTW_RDIVREM(TOTAL_ROWS, RPT_MAX_ROWS) > "0")
	       @DTW_ADD(totalPages, "1", totalPages)
	   %endif
      %else
          @dtw_assign(totalPages, "1")
      %endif

      @dtw_add(START_ROW_NUM, RPT_MAX_ROWS, rowIndexNext)

      @dtw_assign(page, @dtw_radd(@dtw_rdivide(@dtw_rsubtract(START_ROW_NUM, "1"), RPT_MAX_ROWS), "1"))
      @dtw_add(START_ROW_NUM, RPT_MAX_ROWS, rowIndexNext)
      @dtw_assign(firstRecord, "")

      %ROW{  
          %if (firstRecord == "")
              @dtw_assign(firstRecord, "N")
              @dtw_assign(sql_Record_Count, TOTAL_ROWS)
              %if (groupByHdr != "")
                  <table $(contentTable)> 	
                      @dtw_assign(dspVar, "$(groupByHdr)")
                      @Retrieve_Group_Desc(profileHandle, dataBaseID, dspVar)
                      $(dspVar)
                  </table>
              %endif
              %INCLUDE "ConfMessageDisplay.icl"

              <div class="page">
                  <br>
                  %if (formatToPrint == "")
                      Page: $(page) of $(totalPages)
                      %if (START_ROW_NUM > RPT_MAX_ROWS)
                          <a href="input$(nextPrevVar)&amp;START_ROW_NUM=@DTW_RSUBTRACT(START_ROW_NUM, RPT_MAX_ROWS)&amp;RPT_MAX_ROWS=@dtw_rurlescseq(RPT_MAX_ROWS)">$(previousImage)</a>
                      %else
                          %if (TOTAL_ROWS > RPT_MAX_ROWS)
                              $(nextPrevBlank)
                          %endif
                      %endif

                      %if (TOTAL_ROWS >= rowIndexNext)
                          <a href="input$(nextPrevVar)&amp;START_ROW_NUM=$(rowIndexNext)&amp;RPT_MAX_ROWS=@dtw_rurlescseq(RPT_MAX_ROWS)">$(nextImage)</a>
                      %else
                          %if (TOTAL_ROWS > RPT_MAX_ROWS)
                              $(nextPrevBlank)
                          %endif
                      %endif
                  %endif
                  @dtw_assign(TOTQTY, V_TOTQTY)
                  @dtw_assign(TOTAMT, V_TOTAMT)
                  @dtw_assign(TOTCST, V_TOTCST)
                  @dtw_assign(TOTMAMT, V_TOTMAMT)
                  @dtw_assign(TOTMPCT, V_TOTMPCT)
              </div>

              <table $(contentTable)> 	
                  <tr>
                      @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                      @OrderBy_Sort("DHSHTO", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ShipToNumber" title="Sequence By Ship-To Number, Order Number, Sequence">Customer<br>Number</a></th>
                      @OrderBy_Sort("CMCNA1U", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ShipToName" title="Sequence By Ship-To Name, Ship-To Number, Order Number, Sequence">Name</a></th>
                      @OrderBy_Sort("DHORD#", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=OrderNumber" title="Sequence By Order Number, Sequence">Order<br>Number</a></th>
                      @OrderBy_Sort("DHSEQ#", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SeqNumber" title="Sequence By Sequence, Order Number">Seq</a></th>
                      @OrderBy_Sort("DHITEM", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ItemNumber" title="Sequence By Item Number, Order Number">Item<br>Number</a></th>
                      @OrderBy_Sort("DHIMDS", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ItemDesc" title="Sequence By Item Description, Item Number, Order Number">Item<br>Description</a></th>
                      @OrderBy_Sort("HHLIV#", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=InvoiceNumber" title="Sequence By Invoice Number, Order Number, Sequence">Invoice <br> Number</a></th>
                      @OrderBy_Sort("DHDTLI", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=InvoiceDate" title="Sequence By Invoice Date, Order Number, Sequence">Invoice <br> Date</a></th>
                      @OrderBy_Sort("DHSLPR", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Price" title="Sequence By Price, Order Number, Sequence">Price</a></th>
                      @OrderBy_Sort("DHQSTC", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Quantity" title="Sequence By Quantity, Order Number, Sequence">Quantity</a></th>
                      <th class="colhdr">Extended<br>Price</th>
                      %if(displayMargin == "Y")
                          @OrderBy_Sort("SUMCST", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Cost" title="Sequence By Cost">Cost</a></th>

                          @OrderBy_Sort("MARGINAMT", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MarginAmt" title="Sequence By Margin Amount">Margin<br>Amount</a></th>

                          @OrderBy_Sort("MARGINPCT", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MarginPct" title="Sequence By Margin Percent">Margin<br>Percent</a></th>
                      %endif
                  </tr>
          %endif

          @dtw_assign(DTLI, $(V_DHDTLI))

	   %INCLUDE "SetRowClass.icl"
          @Format_Nbr("@dtw_rdivide(@dtw_rmultiply(V_DHQSTC, V_DHSLPR), V_DHORUF)", ExtendedPrice, "2", $(amtEditCode), "Y", "", "")
          @Format_Nbr($(V_DHSLPR), F_DHSLPR, $(prcNbrDec), $(amtEditCode), "", "", "")
          @Format_Nbr($(V_DHQSTC), F_DHQSTC, $(qtyNbrDec), $(qtyEditCode), "", "", "")
          @Format_Date(V_DHDTLI, "D", F_DHDTLI)
          @Check_Invoice(profileHandle, dataBaseID, V_HHLIV#, V_DHBLTO, invoiceFound)

	   <tr class="$(rowClass)">
              <td class="colnmbr">$(V_DHSHTO)</td>
              <td class="colalph"><a href="$(homeURL)$(cGIPath)customerinquiry.d2w/DISPLAY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(V_DHSHTO)" onclick="$(inquiryWinVar)" title="Customer Quickview">$(V_CMCNA1)</a></td>
	       <td class="colnmbr"><a onClick="saveCurrentURL();" href="$(homeURL)$(cGIPath)SelectOrderHistory.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(V_DHSHTO)&amp;ShipToName=@dtw_rurlescseq(V_CMCNA1)&amp;orderNumber=@dtw_rurlescseq(V_DHORD#)&amp;orderSequence=@dtw_rurlescseq(V_DHSEQ#)" title="View Order History Detail">$(V_DHORD#)</a></td>
	       <td class="colnmbr">$(V_DHSEQ#)</td>
              <td class="colalph">$(V_DHITEM)</td>
              %if (V_DHOREC != "N")
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)iteminquiry.d2w/DISPLAY$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq($(V_DHITEM))" onclick="$(inquiryWinVar)" title="Item Quickview">$(V_DHIMDS)</a></td>
              %else
                  <td class="colalph">$(V_DHIMDS)</td>
              %endif
              %if (invoiceFound == "Y")
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)SelectInvoice.d2w/DISPLAY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq($(V_DHBLTO))&amp;invoiceNumber=@dtw_rurlescseq(V_HHLIV#)&amp;invoiceDate=@dtw_rurlescseq(DTLI)&amp;formatToPrint=Y" onclick="$(invoiceWinVar)" title="Invoice Quickview">$(V_HHLIV#)</a></td>
              %else
                  <td class="colnmbr">$(V_HHLIV#)</td>
              %endif
              <td class="coldate">$(F_DHDTLI)</td>
              <td class="coldate">$(F_DHSLPR)</td>
              <td class="colnmbr">$(F_DHQSTC)</td>
              <td class="colnmbr">$(ExtendedPrice)</td>
              %if(displayMargin == "Y")
                  @Format_Nbr($(V_SUMCST), F_SUMCST, $(cstNbrDec), $(cstEditCode), "", "", "")
                  <td class="colnmbr">$(F_SUMCST)</td>

                  @Format_Nbr($(V_MARGINAMT), F_MARGINAMT, $(amtNbrDec), $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_MARGINAMT)</td>

                  @Format_Nbr($(V_MARGINPCT), F_MARGINPCT, $(pctNbrDec), $(pctEditCode), "", "", "")
                  <td class="colnmbr">$(F_MARGINPCT)</td>
              %endif
	   </tr>
      %}
              <tr>
                  %if(totalByQty == "Y" || totalByAmt == "Y" || totalByCnt == "Y")
                      <td colspan="9">&nbsp;</td>
                  %endif
                  %if(totalByQty == "Y")
                      @Format_Nbr($(TOTQTY), F_TOTQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                      <td class="coltotal">$(F_TOTQTY)</td>
                  %else
                      <td>&nbsp;</td>
                  %endif
                  %if(totalByAmt == "Y")
                      @Format_Nbr($(TOTAMT), F_TOTAMT, "2", $(amtEditCode), "", "", "")
                      <td class="coltotal">$(F_TOTAMT)</td>

                      %if(displayMargin == "Y")
                          @Format_Nbr($(TOTCST), F_TOTCST, $(cstNbrDec), $(cstEditCode), "", "", "")
                          <td class="coltotal">$(F_TOTCST)</td>
                          @Format_Nbr($(TOTMAMT), F_TOTMAMT, $(amtNbrDec), $(amtEditCode), "", "", "")
                          <td class="coltotal">$(F_TOTMAMT)</td>
                          @Format_Nbr($(TOTMPCT), F_TOTMPCT, $(pctNbrDec), $(pctEditCode), "", "", "")
                          <td class="coltotal">$(F_TOTMPCT)</td>
                      %endif
                  %endif
              </tr>
  </table>
  %INCLUDE "PageBottom.icl"
  $(hrTagAttr)
  %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Retrieve_User_Selection(INOUT CHAR(64) profileHandle,
                                                  INOUT CHAR(2)  dataBaseID,
                                                  INOUT CHAR(1)  maintCode,
                                                  INOUT CHAR(10) userProfile,
                                                  INOUT CHAR(10) selectName,
                                                  INOUT DEC(5,0) selectSequence,
                                                  INOUT CHAR(50) selectDesc,
                                                  INOUT CHAR(10) selectTotals,
                                                  INOUT CHAR(500) selectGroupBy,
                                                  INOUT CHAR(3000) selectCriteria)
{%EXEC {HSYUSL_W.PGM %}
%}

%FUNCTION(dtw_directcall) Retrieve_Group_Desc(IN    CHAR(64) profileHandle,
                                                    CHAR(2)  dataBaseID,
                                                    DEC(5,0) selectSequence,
                                                    DEC(3,0) grpFldLvl,
                                                    CHAR(10) grpFldTyp,
                                                    CHAR(50) grpFldHdr,
                                                    CHAR(50) grpFldVal,
                                                    CHAR(50) grpFldDsc,
                                                    CHAR(50) selectGroup,
                                              INOUT CHAR(500) selectGroupSQL)
{%EXEC {HSYUSG_W.PGM %}
%}

%HTML(PROCESS) {
  %INCLUDE "setLibraryList.icl"
  %if (downloadProfileHandle == "")
      @dtw_assign(downloadProfileHandle, profileHandle)
  %else
      @dtw_assign(profileHandle, downloadProfileHandle)
  %endif

  %if (grpFldTyp != "")
      @Retrieve_Group_Desc(profileHandle, dataBaseID, selectSequence, grpFldLvl, grpFldTyp, grpFldHdr, grpFldVal, grpFldDsc, selectGroup, selectGroupSQL)
  %else
      @dtw_assign(selectGroupSQL, "")
  %endif
  @dtw_assign(maintCode, "R")
  @Retrieve_User_Selection(profileHandle, dataBaseID, maintCode, userProfile, selectName, selectSequence, selectDesc, selectTotals, selectGroupBy, selectCriteria)

  @dtw_assign(totalByAmt, "")
  @dtw_assign(totalByQty, "")
  @dtw_assign(totalByCnt, "")
  %if (@dtw_rsubstr(selectTotals, "1", "1") == "Y")
       @dtw_assign(totalByQty, "Y")
  %endif
  %if (@dtw_rsubstr(selectTotals, "2", "1") == "Y")
       @dtw_assign(totalByAmt, "Y")
  %endif
  %if (@dtw_rsubstr(selectTotals, "3", "1") == "Y")
       @dtw_assign(totalByCnt, "Y")
  %endif

  @dtw_assign(selectRecSQL, "WHERE DHSEQ# >0 ")
  @Build_SQL("DHITEM", "A")
  @Build_SQL("DHIMDS", "A")
  @Build_SQL("DHBLTO", "N")
  @Build_SQL("DHSHTO", "N")
  @Build_SQL("CMCNA1U", "A")
  @Build_SQL("CMCNA2U", "A")
  @Build_SQL("CMCNA3U", "A")
  @Build_SQL("CMCNA4U", "A")
  @Build_SQL("CMCCTYU", "A")
  @Build_SQL("CMST", "A")
  @Build_SQL("CMZIP", "A")
  @Build_SQL("DHDTLI", "D")
  @Build_SQL("@@LIYR", "N")
  @Build_SQL("@@LIQT", "N")
  @Build_SQL("@@LIMO", "N")
  @Build_SQL("@@LIWK", "N")
  @Build_SQL("DHPCLS", "A")
  @Build_SQL("DHPGRP", "A")
  @Build_SQL("IMITC", "A")
  @Build_SQL("HHDOTS", "D")
  @Build_SQL("@@SDYR", "N")
  @Build_SQL("@@SDQT", "N")
  @Build_SQL("@@SDMO", "N")
  @Build_SQL("@@SDWK", "N")
  @Build_SQL("DHSLPR", "N")
  @Build_SQL("DHQSTC", "N")
  @Build_SQL("HHSLSM", "N")
  @Build_SQL("CMCCLS", "A")
  @Build_SQL("CMCRGN", "A")
  @Build_SQL("DHLOC#", "N")
  @Build_SQL("DHWH", "N")
  @Build_SQL("DHSVSV", "A")
  @Build_SQL("DHSVDS", "A")
  @Build_SQL("HHORTY", "A")
  @Build_SQL("CMUDF1", "A")
  @Build_SQL("CMUDF2", "A")
  @Build_SQL("CMUDF3", "A")
  @Build_SQL("CMUDF4", "A")
  @Build_SQL("CMUDF5", "A")
  @Build_SQL("IMUDA1", "A")
  @Build_SQL("IMUDA2", "A")
  @Build_SQL("IMUDA3", "A")
  @Build_SQL("IMUDA4", "A")
  @Build_SQL("IMUDA5", "A")
  @Build_SQL("IMUDN1", "N")
  @Build_SQL("IMUDN2", "N")
  @Build_SQL("IMUDN3", "N")
  @Build_SQL("IMUDN4", "N")
  @Build_SQL("IMUDN5", "N")

  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "DHORD# DESC,DHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Order Number (descending), Sequence")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "ShipToNumber")
      %if (orderBy == "DHSHTO,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderBy, "DHSHTO DESC,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Ship-To Number (descending), Order Number, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "DHSHTO,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Ship-To Number, Order Number, Sequence")
      %endif
  %elif (sequence == "ShipToName")
      %if (orderBy == "CMCNA1U,DHSHTO,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderBy, "CMCNA1U DESC,DHSHTO,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Ship-To Name (descending), Ship-To Number, Order Number, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "CMCNA1U,DHSHTO,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Ship-To Name, Ship-To Number, Order Number, Sequence")
      %endif
  %elif (sequence == "OrderNumber")
      %if (orderBy == "DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderBy, "DHORD# DESC,DHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Order Number (descending), Sequence")
      %else
          @DTW_ASSIGN(orderBy, "DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Order Number, Sequence")
      %endif
  %elif (sequence == "SeqNumber")
      @DTW_ASSIGN(orderBy, "DHSEQ#,DHORD# DESC")
      %if (orderBy == "DHSEQ#,DHORD#")
          @DTW_ASSIGN(orderBy, "DHSEQ# DESC,DHORD#")
          @DTW_ASSIGN(orderByDisplay, "Sequence (descending), Order Number")
      %else
          @DTW_ASSIGN(orderBy, "DHSEQ#,DHORD#")
          @DTW_ASSIGN(orderByDisplay, "Sequence, Order Number")
      %endif
  %elif (sequence == "ItemNumber")
      %if (orderBy == "DHITEM,DHORD#")
          @DTW_ASSIGN(orderBy, "DHITEM DESC,DHORD#")
          @DTW_ASSIGN(orderByDisplay, "Item Number (descending), Order Number")
      %else
          @DTW_ASSIGN(orderBy, "DHITEM,DHORD#")
          @DTW_ASSIGN(orderByDisplay, "Item Number, Order Number")
      %endif
  %elif (sequence == "ItemDesc")
      %if (orderBy == "DHIMDS,DHITEM,DHORD#")
          @DTW_ASSIGN(orderBy, "DHIMDS DESC,DHITEM,DHORD#")
          @DTW_ASSIGN(orderByDisplay, "Item Description (descending), Item Number, Order Number")
      %else
          @DTW_ASSIGN(orderBy, "DHIMDS,DHITEM,DHORD#")
          @DTW_ASSIGN(orderByDisplay, "Item Description, Item Number, Order Number")
      %endif
  %elif (sequence == "InvoiceNumber")
      %if (orderBy == "HHLIV#,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderBy, "HHLIV# DESC,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Invoice Number (descending), Order Number, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "HHLIV#,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Invoice Number, Order Number, Sequence")
      %endif
  %elif (sequence == "InvoiceDate")
      %if (orderBy == "DHDTLI,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderBy, "DHDTLI DESC,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Invoice Date (descending), Order Number, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "DHDTLI,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Invoice Date, Order Number, Sequence")
      %endif
  %elif (sequence == "Price")
      %if (orderBy == "DHSLPR,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderBy, "DHSLPR DESC,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Price (descending), Order Number, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "DHSLPR,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Price, Order Number, Sequence")
      %endif
  %elif (sequence == "Quantity")
      %if (orderBy == "DHQSTC,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderBy, "DHQSTC DESC,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Quantity (descending), Order Number, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "DHQSTC,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Quantity, Order Number, Sequence")
      %endif
  %elif (sequence == "Cost")
      %if (orderBy == "SUMCST,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderBy, "SUMCST DESC,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Cost (descending), Order Number, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "SUMCST,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Cost, Order Number, Sequence")
      %endif
  %elif (sequence == "MarginAmt")
      %if (orderBy == "MARGINAMT,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderBy, "MARGINAMT DESC,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Quantity (descending), Order Number, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "MARGINAMT,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Quantity, Order Number, Sequence")
      %endif
  %elif (sequence == "MarginPct")
      %if (orderBy == "MARGINPCT,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderBy, "MARGINPCT DESC,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Quantity (descending), Order Number, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "MARGINPCT,DHORD#,DHSEQ#")
          @DTW_ASSIGN(orderByDisplay, "Quantity, Order Number, Sequence")
      %endif
  %endif
	
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}