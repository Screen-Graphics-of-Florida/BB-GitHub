%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Vendor Book"
  d2wName                 = "VendorBook.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)&amp;apid=@dtw_rurlescseq(apid)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "04"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromVendorNumber, 7, 0) &&
                      editNum(document.Chg.toVendorNumber, 7, 0) &&
                      editFromToAll(document.Chg.fromAlphaSequence, document.Chg.toAlphaSequence, document.Chg.allAlphaSequence, "A") &&
                      editFromToAll(document.Chg.fromVendorNumber, document.Chg.toVendorNumber, document.Chg.allVendorNumber, 7) &&
                      editFromToAll(document.Chg.fromVendorType, document.Chg.toVendorType, document.Chg.allVendorType, "A") &&
                      editFromToAll(document.Chg.fromZipCode, document.Chg.toZipCode, document.Chg.allZipCode, "A"))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "VENDORMASTERBOOKLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromAlphaSequence")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@salp", "sortAlphaSequence")        @dtw_assign(Err_N3SALP,  fieldValue)
                                  @DecatErr_Field("@@svnd", "sortVendorNumber")        @dtw_assign(Err_N3SVND,  fieldValue)
                                  @DecatErr_Field("@@styp", "sortVendorType")        @dtw_assign(Err_N3STYP,  fieldValue)
                                  @DecatErr_Field("@@szip", "sortZipCode")        @dtw_assign(Err_N3SZIP,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@cont")  @dtw_assign(V_N1CONT,  fieldValue)
                                  @Decat_Field("@@comm")  @dtw_assign(V_N2COMM,  fieldValue)
                                  @Decat_Field("@@falp")  @dtw_assign(V_N3FALP,  fieldValue)
                                  @Decat_Field("@@talp")  @dtw_assign(V_N3TALP,  fieldValue)
                                  @Decat_Field("@@aalp")  @dtw_assign(V_N3AALP,  fieldValue)
                                  @Decat_Field("@@salp")  @dtw_assign(V_N3SALP,  fieldValue)
                                  @Decat_Field("@@fvnd")  @dtw_assign(V_N3FVND,  fieldValue)
                                  @Decat_Field("@@tvnd")  @dtw_assign(V_N3TVND,  fieldValue)
                                  @Decat_Field("@@avnd")  @dtw_assign(V_N3AVND,  fieldValue)
                                  @Decat_Field("@@svnd")  @dtw_assign(V_N3SVND,  fieldValue)
                                  @Decat_Field("@@ftyp")  @dtw_assign(V_N3FTYP,  fieldValue)
                                  @Decat_Field("@@ttyp")  @dtw_assign(V_N3TTYP,  fieldValue)
                                  @Decat_Field("@@atyp")  @dtw_assign(V_N3ATYP,  fieldValue)
                                  @Decat_Field("@@styp")  @dtw_assign(V_N3STYP,  fieldValue)
                                  @Decat_Field("@@fzip")  @dtw_assign(V_N3FZIP,  fieldValue)
                                  @Decat_Field("@@tzip")  @dtw_assign(V_N3TZIP,  fieldValue)
                                  @Decat_Field("@@azip")  @dtw_assign(V_N3AZIP,  fieldValue)
                                  @Decat_Field("@@szip")  @dtw_assign(V_N3SZIP,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1CONT == "02")
                                      @dtw_assign(special, "")
                                      @dtw_assign(stock, "CHECKED")
                                  %else
                                      @dtw_assign(special, "CHECKED")
                                      @dtw_assign(stock, "")
                                  %endif
                                  %if (V_N2COMM == "02")
                                      @dtw_assign(commentsNo, "")
                                      @dtw_assign(commentsYes, "CHECKED")
                                  %else
                                      @dtw_assign(commentsNo, "CHECKED")
                                      @dtw_assign(commentsYes, "")
                                  %endif
                                  %if (V_N3AALP == "ALL")
                                      @dtw_assign(checkedallAlphaSequence, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallAlphaSequence, "")
                                  %endif
                                  %if (V_N3AVND == "ALL")
                                      @dtw_assign(checkedallVendorNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallVendorNumber, "")
                                  %endif
                                  %if (V_N3ATYP == "ALL")
                                      @dtw_assign(checkedallVendorType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallVendorType, "")
                                  %endif
                                  %if (V_N3AZIP == "ALL")
                                      @dtw_assign(checkedallZipCode, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallZipCode, "")
                                  %endif
                              %else
                                  @dtw_assign(special, "")
                                  @dtw_assign(stock, "CHECKED")
                                  @dtw_assign(commentsNo, "CHECKED")
                                  @dtw_assign(commentsYes, "")
                                  @dtw_assign(checkedallAlphaSequence, "CHECKED")
                                  @dtw_assign(checkedallVendorNumber, "CHECKED")
                                  @dtw_assign(checkedallVendorType, "CHECKED")
                                  @dtw_assign(checkedallZipCode, "CHECKED")
                              %endif

                              <tr><td  class="dsphdr">Forms Type Selection</td>
                                  <td class="inputnmbr"><input type="radio" name="formsType" VALUE='01' $(special)>Special Preprinted Form</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input type="radio" name="formsType" VALUE='02' $(stock)>Stock Paper</td>
                              </tr>

                              <tr><td  class="dsphdr">Print Comments</td>
                                  <td class="inputnmbr"><input type="radio" name="printComments" VALUE='01' $(commentsNo)>No</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input type="radio" name="printComments" VALUE='02' $(commentsYes)>Yes</td>
                              </tr>
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                              </tr>

                              @SetTextOvr(Err_N3FALP)
                              %if (textOvr == "") @SetTextOvr(Err_N3SALP) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Alpha Sequence</span></td>
                                  <td class="inputalph"><input type="text" name="fromAlphaSequence" value="$(V_N3FALP)" size="7" maxlength="4"></td>
                                  <td class="inputalph"><input type="text" name="toAlphaSequence" value="$(V_N3TALP)" size="7" maxlength="4"></td>
                                  <td class="inputalph"><input type="checkbox" name="allAlphaSequence" value='ALL' $(checkedallAlphaSequence) onClick="if (this.checked) this.form.fromAlphaSequence.value='', this.form.toAlphaSequence.value='';"></td>
                                  @Build_Sort_Select("sortAlphaSequence", "$(V_N3SALP)")
                              </tr>
                              @DspErrMsg(Err_N3SALP)

                              @SetTextOvr(Err_N3FVND)
                              %if (textOvr == "") @SetTextOvr(Err_N3SVND) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Vendor</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromVendorNumber" value="$(V_N3FVND)" size="7" maxlength="7">
                                                        <a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="vendorName"></td>
                                  <td class="inputnmbr"><input type="text" name="toVendorNumber" value="$(V_N3TVND)" size="7" maxlength="7">
                                                        <a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="vendorName"></td>
                                  <td class="inputalph"><input type="checkbox" name="allVendorNumber" value='ALL' $(checkedallVendorNumber) onClick="if (this.checked) this.form.fromVendorNumber.value='', this.form.toVendorNumber.value='';"></td>
                                  @Build_Sort_Select("sortVendorNumber", "$(V_N3SVND)")
                              </tr>
                              @DspErrMsg(Err_N3SVND)

                              @SetTextOvr(Err_N3FTYP)
                              %if (textOvr == "") @SetTextOvr(Err_N3STYP) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Vendor Type</span></td>
                                  <td class="inputalph"><input type="text" name="fromVendorType" value="$(V_N3FTYP)" size="7" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)VendorTypeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromVendorType&amp;fldDesc=vendorTypeDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="vendorTypeDesc"></td>
                                  <td class="inputalph"><input type="text" name="toVendorType" value="$(V_N3TTYP)" size="7" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)VendorTypeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toVendorType&amp;fldDesc=vendorTypeDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="vendorTypeDesc"></td>
                                  <td class="inputalph"><input type="checkbox" name="allVendorType" value='ALL' $(checkedallVendorType) onClick="if (this.checked) this.form.fromVendorType.value='', this.form.toVendorType.value='';"></td>
                                  @Build_Sort_Select("sortVendorType", "$(V_N3STYP)")
                              </tr>
                              @DspErrMsg(Err_N3STYP)

                              @SetTextOvr(Err_N3FZIP)
                              %if (textOvr == "") @SetTextOvr(Err_N3SZIP) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Zip</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromZipCode" value="$(V_N3FZIP)" size="18" maxlength="13"></td>
                                  <td class="inputnmbr"><input type="text" name="toZipCode" value="$(V_N3TZIP)" size="18" maxlength="13"></td>
                                  <td class="inputalph"><input type="checkbox" name="allZipCode" value='ALL' $(checkedallZipCode) onClick="if (this.checked) this.form.fromZipCode.value='', this.form.toZipCode.value='';"></td>
                                  @Build_Sort_Select("sortZipCode", "$(V_N3SZIP)")
                              </tr>
                              @DspErrMsg(Err_N3SZIP)

                          </table>

                          @dtw_assign(envProgram, "HHDVDB")
                          @dtw_assign(envPrinter, "HHDVDBPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HHDVDS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(fromAlphaSequence)
  @dtw_mUPPERCASE(toAlphaSequence)
  @dtw_mUPPERCASE(allAlphaSequence)
  @dtw_mUPPERCASE(allVendorNumber)
  @dtw_mUPPERCASE(fromVendorType)
  @dtw_mUPPERCASE(toVendorType)
  @dtw_mUPPERCASE(allVendorType)
  @dtw_mUPPERCASE(fromZipCode)
  @dtw_mUPPERCASE(toZipCode)
  @dtw_mUPPERCASE(allZipCode)

  @dtw_assign(sortAlphaSequence,@dtw_rstrip(sortAlphaSequence))
  @dtw_assign(fromVendorNumber,@dtw_rstrip(fromVendorNumber))
  @dtw_assign(toVendorNumber,@dtw_rstrip(toVendorNumber))
  @dtw_assign(sortVendorNumber,@dtw_rstrip(sortVendorNumber))
  @dtw_assign(sortVendorType,@dtw_rstrip(sortVendorType))
  @dtw_assign(sortZipCode,@dtw_rstrip(sortZipCode))


  %if (allAlphaSequence != "ALL")
      @dtw_assign(allAlphaSequence, "")
  %endif
  %if (allVendorNumber != "ALL")
      @dtw_assign(allVendorNumber, "")
  %endif
  %if (allVendorType != "ALL")
      @dtw_assign(allVendorType, "")
  %endif
  %if (allZipCode != "ALL")
      @dtw_assign(allZipCode, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@cont", formsType)
  @Concat_Field("@@comm", printComments)
  @Concat_Field("@@apid", apid)
  @Concat_Field("@@falp", fromAlphaSequence)
  @Concat_Field("@@talp", toAlphaSequence)
  @Concat_Field("@@aalp", allAlphaSequence)
  @Concat_Field("@@salp", sortAlphaSequence)
  @Concat_Field("@@fvnd", fromVendorNumber)
  @Concat_Field("@@tvnd", toVendorNumber)
  @Concat_Field("@@avnd", allVendorNumber)
  @Concat_Field("@@svnd", sortVendorNumber)
  @Concat_Field("@@ftyp", fromVendorType)
  @Concat_Field("@@ttyp", toVendorType)
  @Concat_Field("@@atyp", allVendorType)
  @Concat_Field("@@styp", sortVendorType)
  @Concat_Field("@@fzip", fromZipCode)
  @Concat_Field("@@tzip", toZipCode)
  @Concat_Field("@@azip", allZipCode)
  @Concat_Field("@@szip", sortZipCode)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}