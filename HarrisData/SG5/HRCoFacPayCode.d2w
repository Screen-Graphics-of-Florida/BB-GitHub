%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Pay Codes"
  d2wName                 = "HRCoFacPayCode.d2w"
  d2wVarBase              = "$(genericVarBase)$(hrCoFacVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPRPYM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "HrCoFacURL.icl"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "PAYCODES")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      @dtw_assign(uv_CompanyName, "C2COMP")
                      @dtw_assign(uv_FacilityName, "C2FACL")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select C2CODE, C2DESC, C2SMTY, C2SEQ, C2HRCD, C2ACCT, C2SUB, C2OVRT, C2JOB, C2STRT, C2END, C2ATCD, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(C2DESC) as C2DESCU", stmtSQL)
                      @dtw_concat(fileSQL, " PRCODE ", fileSQL)
                      @dtw_concat(selectSQL, " C2COMP=$(prCompany) and C2FACL=$(prFacility)", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @PayCode_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) PayCode_Query (IN CHAR(64)    profileHandle,
                                     CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count != "1")
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/report") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>

              @RetHrCompNam(profileHandle, dataBaseID, prCompany, prFacility, coFacName)
              <tr><td><h2>$(coFacName)</h2></td></tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"
          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Description</th></tr>
                      <tr><td><input type="text" class="inputalph" name="srchDesc" size="20" maxlength="20">
                              <input type="hidden" name="operDesc" value="LIKE">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchDesc.focus();
                  </script>
              </form>

              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("C2CODE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PayCode" title="Sequence By Pay Code">Pay Code</a></th>
                  @OrderBy_Sort("C2DESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PayCodeDesc" title="Sequence By Description">Description</a></th>
                  @OrderBy_Sort("C2SMTY", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SumType" title="Sequence By Summary Pay Type">Summary<br>Pay Type</a></th>
                  <th class="colhdr">Summary<br>Pay Type<br>Description</th>
                  @OrderBy_Sort("C2SEQ", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ProcSeq" title="Sequence By Processing Sequence">Processing<br>Sequence</a></th>
                  <th class="colhdr">Hours/Units</th>
                  <th class="colhdr">Override Rate</th>
                  <th class="colhdr">Start Date</th>
                  <th class="colhdr">End Date</th>
                  <th class="colhdr">G/L Account</th>
                  <th class="colhdr">Attendance<br>Exception</th>
              </tr>
          %INCLUDE "NoRecordsFound.icl"
      %endif

              %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;payCode=@dtw_rurlescseq(V_C2CODE)")
                  %if (sql_Record_Count == "1")
                      @Save_WebReg(webRegCurFile, profileHandle, d2wName, "", orderBy, orderByDisplay, "")
                      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)HRCoFacPayCodeSelect.d2w/REPORT$(maintainVar)">
                  %else
                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          <td class="colcode"><a href="$(homeURL)$(cGIPath)HRCoFacPayCodeSelect.d2w/REPORT$(maintainVar)" title="View Pay Code">$(V_C2CODE)</a></td>
                          <td class="colalph">$(V_C2DESC)</td>
                          <td class="colcode">$(V_C2SMTY)</td>
                          @RtvFldDesc("SUMCOD='$(V_C2SMTY)'", "PRSUMT", "SUMDSC", sumDesc)
                          <td class="colalph">$(sumDesc)</td>
                          <td class="colcode">$(V_C2SEQ)</td>
                          @dtw_assign(hoursUnits, "")
                          %if (V_C2HRCD == "H")
                              @dtw_assign(hoursUnits, "Hours")
                          %elseif (V_C2HRCD == "U")
                              @dtw_assign(hoursUnits, "Units")
                          %endif
                          <td class="colcode">$(hoursUnits)</td>
                          %if (V_C2OVRT == ".000")
                              <td class="colnmbr"> </td>
                          %else
                              @Format_Nbr($(V_C2OVRT), F_C2OVRT, $(rteNbrDec), $(rteEditCode), "", "", "")
                              <td class="colnmbr">$(F_C2OVRT)</td>
                          %endif
                          @Format_Date(V_C2STRT, "D", F_C2STRT)
                          <td class="coldate">$(F_C2STRT)</td>
                          @Format_Date(V_C2END, "D", F_C2END)
                          <td class="coldate">$(F_C2END)</td>
                          @Format_Acct("$(V_C2ACCT)", "$(V_C2SUB)", "", F_AcctSub)
                          <td class="colalph">$(F_AcctSub)</td>
                          <td class="colcode">$(V_C2ATCD)</td>
                      </tr>
                  %endif
              %}
          </table>
          %if (sql_Record_Count != "1")
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  @dtw_assign(uv_CompanyName, "C2COMP")
  @dtw_assign(uv_FacilityName, "C2FACL")
  %INCLUDE "userview.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "Select C2CODE, C2DESC, C2SMTY, C2SEQ, C2HRCD, C2ACCT, C2SUB, C2OVRT, C2JOB, C2STRT, C2END, C2ATCD, ", stmtSQL)
  @dtw_concat(stmtSQL, " upper(C2DESC) as C2DESCU", stmtSQL)
  @dtw_concat(fileSQL, " PRCODE ", fileSQL)
  @dtw_concat(selectSQL, " C2COMP=$(prCompany) and C2FACL=$(prFacility)", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @PayCode_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) PayCode_XMLQuery (IN CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("PayCodeList")
          %ROW{
              @RtvFldDesc("SUMCOD='$(V_C2SMTY)'", "PRSUMT", "SUMDSC", sumDesc)
              %if (V_C2HRCD == "H")
                  @dtw_assign(hoursUnits, "Hours")
              %elseif (V_C2HRCD == "U")
                  @dtw_assign(hoursUnits, "Units")
              %else
                  @dtw_assign(hoursUnits, "Earnings")
              %endif
              @Format_Acct("$(V_C2ACCT)", "$(V_C2SUB)", "Y", F_AcctSub)

	       @XMLIDTag(@DTW_rCONCAT(prCompany, @DTW_rCONCAT("/", @DTW_rCONCAT(prFacility, @DTW_rCONCAT("/", V_C2CODE)))), "PayCode ID")
                  @XMLTag(prCompany, "CompanyNumber")
                  @XMLTag(prFacility, "FacilityNumber")
                  @XMLTag(V_C2CODE, "PayCode")
                  @XMLTag(V_C2DESC, "Description")
                  @XMLTag(sumDesc,  "SummaryPayType")
                  @XMLTag(hoursUnits, "HoursOrUnitsOrEarnings")
                  @XMLTag(V_C2PREM, "ApplyShiftPremium")
                  @XMLTag(V_C2DED, "TakeDeductions")
                  @XMLTag(V_C2ACCR,  "IncludeInVacationSickAccruals")
                  @XMLTag(V_C2SEQ, "ProcessingSequence")
                  %if(V_C2HRS != ".00")
                      @XMLTag(V_C2HRS,  "DefaultHoursUnitsEarnings")
                  %endif
                  %if(V_C2DEPT != "")
                      @XMLTag(V_C2DEPT, "Department")
                  %endif
                  %if(V_C2ACCT != "0" || V_C2SUB != "0")
                      @XMLTag(F_AcctSub, "GLAccount")
                  %endif
                  %if(V_C2OVRT != ".000")
                      @XMLTag(V_C2OVRT, "OverrideRate")
                  %endif
                  %if(V_C2SHFW != "")
                      @XMLTag(V_C2SHFW,  "ShiftWorked")
                  %endif
                  %if(V_C2JOB != "")
                      @XMLTag(V_C2JOB, "JobNumber")
                  %endif
                  %if(V_C2MAX1 != ".00")
                      @XMLTag(V_C2MAX1, "MaximumYTDHoursOrUnits")
                  %endif
                  %if(V_C2MAX2 != ".00")
                      @XMLTag(V_C2MAX2, "MaximumYTDEarnings")
                  %endif
                  %if(V_C2ATCD != "")
                      @XMLTag(V_C2ATCD, "AttendanceExceptionCode")
                  %endif
              @XMLEndTag("PayCode")
	   %}
      @XMLEndTag("PayCodeList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (sec_05 == "N")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)progOptSecError.d2w/DISPLAY$(genericVarBase)&amp;page_title=@dtw_rurlescseq(page_title)">
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "C2DESCU")
              @DTW_ASSIGN(orderByDisplay, "Description")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      %INCLUDE "SearchReturn.icl"
  %endif
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "PayCode")
      %if (orderBy == "C2CODE")
          @DTW_ASSIGN(orderBy, "C2CODE DESC")
          @DTW_ASSIGN(orderByDisplay, "Pay Code (descending)")
      %else
          @DTW_ASSIGN(orderBy, "C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Pay Code")
      %endif
  %elseif (sequence == "PayCodeDesc")
      %if (orderBy == "C2DESCU,C2CODE")
          @DTW_ASSIGN(orderBy, "C2DESCU DESC,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Pay Code")
      %else
          @DTW_ASSIGN(orderBy, "C2DESCU,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Description, Pay Code")
      %endif
  %elseif (sequence == "SumType")
      %if (orderBy == "C2SMTY,C2DESCU")
          @DTW_ASSIGN(orderBy, "C2SMTY DESC,C2DESCU")
          @DTW_ASSIGN(orderByDisplay, "Summary Pay Type (descending), Description")
      %else
          @DTW_ASSIGN(orderBy, "C2SMTY,C2DESCU")
          @DTW_ASSIGN(orderByDisplay, "Summary Pay Type, Description")
      %endif
  %elseif (sequence == "ProcSeq")
      %if (orderBy == "C2SEQ,C2CODE")
          @DTW_ASSIGN(orderBy, "C2SEQ DESC,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Processing Sequence (descending), Pay Code")
      %else
          @DTW_ASSIGN(orderBy, "C2SEQ,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Processing Sequence, Pay Code")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          @dtw_assign(formName, "Search")
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "dateedit.icl"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchSeq, 3, 0) &&
                      editNum(document.Search.srchAcct, 4, 0) &&
                      editNum(document.Search.srchSub, 4, 0) &&
                      editNum(document.Search.srchHrs, 7, 2) &&
                      editNum(document.Search.srchRate, 6, 5) &&
                      editdate(document.Search.srchStartDate) &&
                      editdate(document.Search.srchEndDate) &&
                      editNum(document.Search.srchMaxHrs, 9, 2) &&
                      editNum(document.Search.srchMaxEarn, 9, 2))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PAYCODESEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      @RetHrCompNam(profileHandle, dataBaseID, prCompany, prFacility, coFacName)
                      <h2>$(coFacName)</h2>
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Pay Code</td>
                              @dtw_assign(operNbr, "operPayCode")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchPayCode" size="3" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchDesc" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Summary Pay Type</td>
                              @dtw_assign(operNbr, "operSumType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchSumType" type="text" size="1" maxlength="1"> <a href="$(homeURL)$(cGIPath)SummaryTypeSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Search&amp;fldName=srchSumType&amp;fldDesc=typeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="typeDesc" value="$(typeDesc)"  type="text" size="14" maxlength="14"></td>
                          </tr>

                          <tr><td class="dsphdr">Processing Sequence</td>
                              @dtw_assign(operNbr, "operSeq")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchSeq" size="3" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Department Worked</td>
                              @dtw_assign(operNbr, "operDeptWorked")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchDeptWorked" type="text" size="5" maxlength="5"> <a href="$(homeURL)$(cGIPath)DepartmentSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Search&amp;fldName=srchDeptWorked&amp;fldDesc=deptWorkedDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="deptWorkedDesc" value="$(deptDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">G/L Account</td>
                              @dtw_assign(operNbr, "operAcct")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchAcct" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">G/L Subaccount</td>
                              @dtw_assign(operNbr, "operSub")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchSub" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Default Hours/Units/Earnings</td>
                              @dtw_assign(operNbr, "operHrs")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchHrs" size="7" maxlength="7"></td>
                          </tr>

                          <tr><td class="dsphdr">Override Rate</td>
                              @dtw_assign(operNbr, "operRate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchRate" size="11" maxlength="11"></td>
                          </tr>

                          <tr><td class="dsphdr">Shift Worked</td>
                              @dtw_assign(operNbr, "operShift")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchShift" type="text" size="2" maxlength="2"> <a href="$(homeURL)$(cGIPath)ShiftSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Search&amp;fldName=srchShift&amp;fldDesc=shiftDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="shiftDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Job Number</td>
                              @dtw_assign(operNbr, "operJob")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchJob" size="14" maxlength="14"></td>
                          </tr>

                          <tr><td class="dsphdr">Start Date</td>
                              @dtw_assign(operNbr, "operStartDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchStartDate" size="6" maxlength="6">
                                  <a href="javascript:calWindow('srchStartDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">End Date</td>
                              @dtw_assign(operNbr, "operEndDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchEndDate" size="6" maxlength="6">
                                  <a href="javascript:calWindow('srchEndDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Maximum YTD Hours/Units</td>
                              @dtw_assign(operNbr, "operMaxHrs")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchMaxHrs" size="9" maxlength="9"></td>
                          </tr>

                          <tr><td class="dsphdr">Maximum YTD Earnings</td>
                              @dtw_assign(operNbr, "operMaxEarn")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchMaxEarn" size="9" maxlength="9"></td>
                          </tr>

                          <tr><td class="dsphdr">Attendance Exception</td>
                              @dtw_assign(operNbr, "operAttnExc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchAttnExc" type="text" size="2" maxlength="2"> <a href="$(homeURL)$(cGIPath)AttendanceExcSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Search&amp;fldName=srchAttnExc&amp;fldDesc=attnDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="attnDesc" value="$(typeDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Apply Shift Premium</td>
                              @dtw_assign(operNbr, "operApplyPrem")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchApplyPrem" size="1" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Take Deductions</td>
                              @dtw_assign(operNbr, "operTakeDed")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchTakeDed" size="1" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Include In Vac/Sick Accruals</td>
                              @dtw_assign(operNbr, "operAccruals")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchAccruals" size="1" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Process Distribution Tables</td>
                              @dtw_assign(operNbr, "operDistribution")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchDistribution" size="1" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Process Salary Distribution</td>
                              @dtw_assign(operNbr, "operSalary")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchSalary" size="1" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Default Record</td>
                              @dtw_assign(operNbr, "operDefault")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchDefault" size="1" maxlength="1"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchPayCode.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("C2CODE", "Pay Code", $(srchPayCode), "U", operPayCode, "A")
  @Build_WildCard ("upper(C2DESC)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("C2SMTY", "Summary Pay Type", $(srchSumType), "U", operSumType, "A")
  @Build_WildCard ("C2SEQ", "Processing Sequence", $(srchSeq), "", operSeq, "N")
  @Build_WildCard ("C2DEPT", "Department Worked", $(srchDeptWorked), "U", operDeptWorked, "A")
  @Build_WildCard ("C2ACCT", "G/L Account", $(srchAcct), "", operAcct, "N")
  @Build_WildCard ("C2SUB", "G/L Subaccount", $(srchSub), "", operSub, "N")
  @Build_WildCard ("C2HRS", "Default Hours/Units/Earnings", $(srchHrs), "", operHrs, "N")
  @Build_WildCard ("upper(C2JOB)", "Job Number", $(srchJob), "U", operJob, "A")
  @Build_WildCard ("C2OVRT", "Override Rate", $(srchRate), "", operRate, "N")
  @Build_WildCard ("C2JOB", "Job Number", $(srchJob), "U", operJob, "A")
  @Build_WildCard ("C2MAX1", "Maximum YTD Hours/Units", $(srchMaxHrs), "", operMaxHrs, "N")
  @Build_WildCard ("C2MAX2", "Maximum YTD Earnings", $(srchMaxEarn), "", operMaxEarn, "N")
  @Build_WildCard ("C2STRT", "Start Date", $(srchStartDate), "", operStartDate, "D")
  @Build_WildCard ("C2END", "End Date", $(srchEndDate), "", operEndDate, "D")
  @Build_WildCard ("C2ATCD", "Attendance Exception", $(srchAttnExc), "U", operAttnExc, "A")
  @Build_WildCard ("upper(C3SHFW)", "Shift Worked", $(srchShift), "U", operShift, "A")
  @Build_WildCard ("C2PREM", "Apply Shift Premium", $(srchApplyPrem), "U", operApplyPrem, "A")
  @Build_WildCard ("C2DED", "Take Deductions", $(srchTakeDed), "U", operTakeDed, "A")
  @Build_WildCard ("C2ACCR", "Include In Vac/Sick Accruals", $(srchAccruals), "U", operAccruals, "A")
  @Build_WildCard ("C2WGDS", "Process Distribution Tables", $(srchDistribution), "U", operDistribution, "A")
  @Build_WildCard ("C2SLDS", "Process Salary Distribution", $(srchSalary), "U", operSalary, "A")
  @Build_WildCard ("C2DFLT", "Default Record", $(srchDefault), "U", operDefault, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}