*       This deduction search is exactly like DeductionSearc.d2w    *
*       except it returns Calculation Method, Priority, and Cycle   *
*********************************************************************
%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title 	           = "Voluntary Deduction Search"
  d2wName                 = "DeductionSearch3.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;prCompany=@dtw_rurlescseq(prCompany)&amp;prFacility=@dtw_rurlescseq(prFacility)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)&amp;fldCalcMethod=@dtw_rurlescseq(fldCalcMethod)&amp;fldPriority=@dtw_rurlescseq(fldPriority)&amp;fldCycle=@dtw_rurlescseq(fldCycle)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
  fldCalcMethod           = ""
  fldPriority             = ""  
  fldCycle                = ""
  advanceSearch           = "N"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script type="text/javascript">
              function selectCode(deduction, dedDesc, calcMeth, priority, cycle){
                  window.opener.document.$(docName).$(fldName).value = deduction;
                  window.opener.document.$(docName).$(fldDesc).value = dedDesc;
                  window.opener.document.$(docName).$(fldCalcMethod).value = calcMeth;
                  window.opener.document.$(docName).$(fldPriority).value = priority;                  
                  window.opener.document.$(docName).$(fldCycle).value = cycle;                                    
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(uv_CompanyName, "CDCOMP")
                      @dtw_assign(uv_FacilityName, "CDFACL")
	                     %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select HVDDNO, HVDDNM, HVMTHD, HVPRTY, HVCYCL, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(HVDDNM) as HVDDNMU ", stmtSQL)
					  @dtw_concat(fileSQL, " HRCDED inner join HRDEDM on CDDDNO=HVDDNO", fileSQL)                      
                      @dtw_concat(selectSQL, "CDCOMP=$(prCompany) and CDFACL=$(prFacility)", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Ded_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Ded_Search (IN CHAR(64)    profileHandle,
				                  CHAR(2)     dataBaseID,
                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  <td class="toolbar">
                      %INCLUDE "HelpPage.icl"
                      %if (displayCloseIcon == "Y")
                          %INCLUDE "CloseWindow.icl"
                      %endif
                  </td>
              @RetHrCompNam(profileHandle, dataBaseID, prCompany, prFacility, coFacName)
              <tr><td><h2>$(coFacName)</h2></td></tr>
      </table>

      $(searchhrTagAttr)
      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr">Deduction Name</th>
                  <th class="colhdr">Deduction</th>
              </tr>
              <tr><td class="inputalph"><input type="text" name="srchName" size="20" maxlength="20">
                      <input type="hidden" name="operName" value="LIKE">
                  </td>
                  <td class="inputnmbr"><input type="text" name="srchDed" size="3" maxlength="3">
                      <input type="hidden" name="operDed" value="=">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
          <script TYPE="text/javascript">
              document.Search.srchName.focus();
          </script>
      </form>
	
      %INCLUDE "WildCardPage.icl"

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              @OrderBy_Sort("HVDDNMU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=name" title="Sequence By Deduction Name, Deduction"> Deduction Name</a></th>
              @OrderBy_Sort("HVDDNO", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=deduction" title="Sequence By Deduction"> Deduction</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Quote(V_HVDDNM, F_HVDDNM)

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="javascript:selectCode($(V_HVDDNO),'$(F_HVDDNM)',$(V_HVMTHD),$(V_HVPRTY),$(V_HVCYCL))" title="Select Deduction">$(V_HVDDNM)</a></td>
                  <td class="colnmbr">$(V_HVDDNO)</td>
              </tr>
      %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "HVDDNMU,HVDDNO")
      @DTW_ASSIGN(orderByDisplay, "Deduction Name, Deduction")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "deduction")
      %if (orderBy == "HVDDNO")
          @DTW_ASSIGN(orderBy, "HVDDNO DESC")
          @DTW_ASSIGN(orderByDisplay, "Deduction (descending)")
      %else
          @DTW_ASSIGN(orderBy, "HVDDNO")
          @DTW_ASSIGN(orderByDisplay, "Deduction")
      %endif
  %elseif (sequence == "name")
      %if (orderBy == "HVDDNMU,HVDDNO")
          @DTW_ASSIGN(orderBy, "HVDDNMU DESC,HVDDNO")
          @DTW_ASSIGN(orderByDisplay, "Deduction Name (descending), Deduction")
      %else
          @DTW_ASSIGN(orderBy, "HVDDNMU,HVDDNO")
          @DTW_ASSIGN(orderByDisplay, "Deduction Name, Deduction")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")


  @Build_WildCard ("HVDDNO", "Deduction", $(srchDed), "", operDed, "N")
  @Build_WildCard ("upper(HVDDNM)", "Description", $(srchName), "U", operName, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}