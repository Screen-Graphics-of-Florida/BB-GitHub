%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Configuration Header Notes Maintenance"
  d2wName                 = "ConfigurationHeaderNotesMaint.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;configurationType=@dtw_rurlescseq(configurationType)&amp;configurationID=@dtw_rurlescseq(configurationID)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
  documentType            = "CFG"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Display_Comments () {	
  <html>
      <head>
          %INCLUDE "headcmt.icl"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "$(cmtBanner)"
          <!-- End Of Banner Code -->
          <table $(contentTable)>
              <tr valign="top">
                  <td>
                      @dtw_assign(comments, "")
                      @dtw_assign(comment, "")
                      %if (cmtSelection != "C")
                          @Get_Item_Comments(profileHandle, dataBaseID, plantNumber, itemNumber, configurationType, configurationID, documentType, comment)
                      %endif

                      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
                      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
                      @RtvFldDesc("CHPLT=$(plantNumber) and CHITEM='$(itemNumber)' and CHCFGT='$(configurationType)' and CHCFGI='$(configurationID)' ", "HDCFGH", "CHCDSC", ConfigTypeDescription)
                      @RtvFldDesc("DODOCT='$(documentType)' and DOAPID='PD' ", "HDDOCT", "DODESC", docDescr)
                      <table $(contentTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1>$(page_title) </h1></td>
                              <td>
                                  <a href="$(homeURL)$(cGIPath)SpecSearch.d2w/REPORT$(genericVarBase)&amp;docName=Chg&amp;fldComment=comments" onclick="$(searchWinVar)"> $(searchSpecLrg)</a>
                                  %INCLUDE "CloseWindow.icl"
                              </td>
                          </tr>
                      </table>
                      <table $(contentTable)>
                          @Format_Header("Plant", $(plantName), $(plantNumber))
                          @Format_Header("Item", $(itemDescription), $(itemNumber))
                          @Format_Header("Type/ID", $(ConfigTypeDescription), "$(configurationType)/$(configurationID)")
                          @Format_Header("Document", $(docDescr), $(documentType))
                      </table>

                      @dtw_assign(focusField, "comments")
                      <table $(contentTable)>
                          <form class="formClass" METHOD=POST NAME="Chg"  ACTION="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)">
                              <tr>
                                  <td>
                                      %if ("$(comment)" != "")
                                          <textarea name="comments" ROWS=20 COLS=60 WRAP="hard">$(comment)</textarea>
                                      %else
                                          <textarea name="comments" ROWS=20 COLS=60 WRAP="hard"></textarea>
                                      %endif
                                  </td>
                              </tr>
                      </table>

                      <table $(contentTable)>
                          <tr>
                              <td valign="top">
                                  <a href="javascript:check(document.Chg)">$(commentAcceptImage)</a>
                                  <a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)" onclick="$(commentWinVar)">$(commentResetImage)</a>
                                  <a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;cmtSelection=C">$(commentClearImage)</a>
                              </td>
                          </tr>
                      </table>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(cmtTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(DTW_directcall) Update_Comments (INOUT CHAR(64)     profileHandle,
				      		  CHAR(2)      dataBaseID,
                                                 DEC(3,0)     plantNumber,
				      		  CHAR (15)    itemNumber,
                                                 CHAR (5)     configurationType,
                                                 CHAR (5)     configurationID,
				      		  CHAR(3)      documentType,
				      		  CHAR(32000)  comments)

{%EXEC {HPDCHN_W.PGM %}
%}

%FUNCTION(DTW_directcall) Get_Item_Comments(INOUT CHAR(64)     profileHandle,
				                   CHAR(2)      dataBaseID,
                                                  DEC(3,0)     plantNumber,
				      		   CHAR (15)    itemNumber,
                                                  CHAR (5)     configurationType,
                                                  CHAR (5)     configurationID,
				      		   CHAR(3)      documentType,
				                   CHAR(32000)  comment)
{%EXEC {HPDCHN_P.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Display_Comments ()
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  @Update_Comments(profileHandle, dataBaseID, plantNumber, itemNumber, configurationType, configurationID,  documentType, comments)

  @dtw_assign(confMessage, "Confirm Update Of Configuration Header $(itemNumber) - $(configurationType) / $(configurationID)")
  <script TYPE="text/javascript">
      opener.location.href=opener.location.href;
      opener.focus();
      window.close();
  </script>
%}