%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Tracked Work Item Error"
  d2wName                 = "WFError.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;inclMyItem=@dtw_rurlescseq(inclMyItem)&amp;inclReviewed=@dtw_rurlescseq(inclReviewed)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  noMsg                   = ""
  inclMyItem              = ""
  inclReviewed            = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "WFWORKITEMREQUESTHISTORY")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select WFWIVL.*,WFINST.*,   ", stmtSQL)
                      @dtw_concat(stmtSQL, " Date(INTSTP) as INDateStart, Time(INTSTP) as INTimeStart, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(USDESC,' ') as USDESC, coalesce(USDESCU,' ') as USDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(PRDESC,' ') as PRDESC, coalesce(PRDESCU,' ') as PRDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " WFWIVL ", fileSQL)
                      @dtw_concat(fileSQL, " inner join WFINST on ININST=WVINST and ININDT=WVINDT ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYUSER on USUSER=INIUSR ", fileSQL)
                      @dtw_concat(fileSQL, " left join WFPRHD on PRPROC=INPROC ", fileSQL)
                      @dtw_concat(selectSQL, " WVVTYP='T'", selectSQL)
                      %if (inclMyItem == "Y")
                          @dtw_concat(selectSQL, " and INIUSR='$(userProfile)'", selectSQL)
                      %endif
                      %if (inclReviewed!="Y")
                          @dtw_concat(selectSQL, " and WVRVWD<>'Y'", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          %INCLUDE "AlertMessageDisplay.icl"
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      $(hrTagAttr)

      %if (formatToPrint == "")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">Initial User</th>
                      <th class="colhdr">Process</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="15" maxlength="40">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchUser" size="15" maxlength="30">
                          <input type="hidden" name="operUser" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchProcess" size="15" maxlength="50">
                          <input type="hidden" name="operProcess" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %if (inclMyItem == "Y")
              @dtw_assign(myItemChecked, "CHECKED")
          %else
              @dtw_assign(myItemChecked, "")
          %endif

          %if (inclReviewed == "Y")
              @dtw_assign(reviewedChecked, "CHECKED")
          %else
              @dtw_assign(reviewedChecked, "")
          %endif

          @dtw_assign(viewCheckBox, d2wName)
          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y")
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("ININST", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Instance"    title="Sequence By Instance">Instance</a></th>
              @OrderBy_Sort("INDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Description, Instance">Description</a></th>
              @OrderBy_Sort("WVDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Error"       title="Sequence By Error, Instance">Error</a></th>
              @OrderBy_Sort("USDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=User"        title="Sequence By User, Instance">Initial User</a></th>
              @OrderBy_Sort("INDateStart", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DateStart"   title="Sequence By Date Started, Instance">Date Started</a></th>
              @OrderBy_Sort("INTimeStart", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TimeStart"   title="Sequence By Time Started, Instance">Time Started</a></th>
              @OrderBy_Sort("PRDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Process"     title="Sequence By Process, Instance">Process</a></th>
              %if (inclReviewed=="Y")
                  @OrderBy_Sort("WVRVWD", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Reviewed"    title="Sequence By Reviewed, Instance">Reviewed</a></th>
              %endif
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @DateFromISO(V_INDateStart, F_INDateStart)
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;wfInstance=@dtw_rurlescseq(V_WVINST)&amp;wfInstanceDate=@dtw_rurlescseq(V_WVINDT)&amp;wfWorkItem=@dtw_rurlescseq(V_WVWITM)&amp;wfWorkItemSequence=@dtw_rurlescseq(V_WVWISQ)&amp;wfValidationProgram=@dtw_rurlescseq(V_WVVPGM)&amp;wfValidationId=@dtw_rurlescseq(V_WVVLID)")

              <tr class="$(rowClass)">
                  %if (formatToPrint!="Y")
                      <td class="opticon">
                          %if (V_WVRVWD=="")
                              <a href="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(maintainVar)" onClick="return confirm('Mark As Reviewed')">$(wfMarkReview)</a></td>
                          %else
                              &nbsp;
                          %endif
                      </td>
                  %endif
                  <td class="colnmbr">$(V_ININST)</td>                                      	
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)WFHistorySelect.d2w/REPORT$(d2wVarBase)&amp;wfInstance=@dtw_rurlescseq(V_ININST)&amp;wfInstanceDate=@dtw_rurlescseq(V_ININDT)&amp;fromD2w=@dtw_rurlescseq(d2wName)" title="View Work Item">$(V_INDESC)</a></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_WVVPGM)-$(V_WVVLID)">$(V_WVDESC)</span></td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_INIUSR)">$(V_USDESC)</span></td>                                      	
                  <td class="colalph">$(F_INDateStart)</td>                                      	
                  <td class="colalph">$(V_INTimeStart)</td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_INPROC)">$(V_PRDESC)</span></td>                                      	
                  %if (inclReviewed=="Y")
                      <td class="colcode">$(V_WVRVWD)</td>                                      	
                  %endif
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select WFWIVL.*,WFINST.*,   ", stmtSQL)
  @dtw_concat(stmtSQL, " Date(INTSTP) as INDateStart, Time(INTSTP) as INTimeStart, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(USDESC,' ') as USDESC, coalesce(USDESCU,' ') as USDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(PRDESC,' ') as PRDESC, coalesce(PRDESCU,' ') as PRDESCU ", stmtSQL)
  @dtw_concat(fileSQL, " WFWIVL ", fileSQL)
  @dtw_concat(fileSQL, " inner join WFINST on ININST=WVINST and ININDT=WVINDT ", fileSQL)
  @dtw_concat(fileSQL, " left join SYUSER on USUSER=INIUSR ", fileSQL)
  @dtw_concat(fileSQL, " left join WFPRHD on PRPROC=INPROC ", fileSQL)
  @dtw_concat(selectSQL, " WVVTYP='T'", selectSQL)
  %if (inclMyItem == "Y")
      @dtw_concat(selectSQL, " and INIUSR='$(userProfile)'", selectSQL)
  %endif
  %if (inclReviewed!="Y")
      @dtw_concat(selectSQL, " and WVRVWD<>'Y'", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_XMLQuery (IN  CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("WFErrorList")
          %ROW{
              @XMLIDTag("$(V_WVINST)-$(V_WVINDT)-$(V_WVWITM)-$(V_WVWISQ)-$(V_WVVLID)", "WorkItemValidation ID")
                  @XMLTag(V_WVINST, "Instance")
                  @XMLTag(V_WVINDT, "InstanceDate")
                  @XMLTag(V_WVWITM, "WorkItem")
                  @XMLTag(V_WVWISQ, "WorkItemSequence")
                  @XMLTag(V_WVVLID, "ValidationId")
                  @XMLTag(V_WVVTYP, "ValidationType")
              @XMLEndTag("WorkItemValidation")
          %}
      @XMLEndTag("WFErrorList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "INDESCU,ININST")
          @DTW_ASSIGN(orderByDisplay, "Description, Instance")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %elif (chgMyItem == "Y" && inclMyItem == "Y" && chgSelection=="")
          @dtw_assign(inclMyItem, "")
      %elif (chgMyItem == "Y")
          @dtw_assign(inclMyItem, "Y")
      %elif (chgReviewed == "Y" && inclReviewed == "Y" && chgSelection=="")
          @dtw_assign(inclReviewed, "")
      %elif (chgReviewed == "Y" && chgSelection=="")
          @dtw_assign(inclReviewed, "Y")
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %if (inclMyItem=="" && inclReviewed=="" && chgMyItem!="Y" && chgReviewed!="Y" && chgSelection=="")
      @dtw_assign(inclMyItem, "Y")
      @dtw_assign(inclReviewed, "")
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%FUNCTION(dtw_directcall) Mark_Error_Reviewed(INOUT CHAR(64) profileHandle,
                                              INOUT CHAR(2) dataBaseID,
                                              INOUT CHAR(32000) edtVar)                             	
{%EXEC {HWFERU_W.PGM %}
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @dtw_assign(edtVar, "")
  @Concat_Field("@@inst", wfInstance)
  @Concat_Field("@@indt", wfInstanceDate)
  @Concat_Field("@@witm", wfWorkItem)
  @Concat_Field("@@wisq", wfWorkItemSequence)
  @Concat_Field("@@vpgm", wfValidationProgram)
  @Concat_Field("@@vlid", wfValidationId)
  @dtw_concat(edtVar, "}{", edtVar)
  @Mark_Error_Reviewed(profileHandle, dataBaseID, edtVar)

 <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;chgSelection=N">
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Instance")
      %if (orderBy == "ININST")
          @DTW_ASSIGN(orderBy, "ININST DESC,ININST")
          @DTW_ASSIGN(orderByDisplay, "Instance (descending)")
      %else
          @DTW_ASSIGN(orderBy, "ININST")
          @DTW_ASSIGN(orderByDisplay, "Instance")
      %endif
  %elif (sequence == "Description")
      %if (orderBy == "INDESCU,ININST")
          @DTW_ASSIGN(orderBy, "INDESCU DESC,ININST")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Instance")
      %else
          @DTW_ASSIGN(orderBy, "INDESCU,ININST")
          @DTW_ASSIGN(orderByDisplay, "Description, Instance")
      %endif
  %elif (sequence == "Error")
      %if (orderBy == "WVDESCU,ININST")
          @DTW_ASSIGN(orderBy, "WVDESCU DESC,ININST")
          @DTW_ASSIGN(orderByDisplay, "Error (descending), Instance")
      %else
          @DTW_ASSIGN(orderBy, "WVDESCU,ININST")
          @DTW_ASSIGN(orderByDisplay, "Error, Instance")
      %endif
  %elif (sequence == "User")
      %if (orderBy == "USDESCU,ININST")
          @DTW_ASSIGN(orderBy, "USDESCU DESC,ININST")
          @DTW_ASSIGN(orderByDisplay, "Initial User (descending), Instance")
      %else
          @DTW_ASSIGN(orderBy, "USDESCU,ININST")
          @DTW_ASSIGN(orderByDisplay, "Initial User, Instance")
      %endif
  %elif (sequence == "DateStart")
      %if (orderBy == "INDateStart,INTimeStart,ININST")
          @DTW_ASSIGN(orderBy, "INDateStart DESC,INTimeStart DESC,ININST")
          @DTW_ASSIGN(orderByDisplay, "Date Started (descending), Time Started (descending), Instance")
      %else
          @DTW_ASSIGN(orderBy, "INDateStart,INTimeStart,ININST")
          @DTW_ASSIGN(orderByDisplay, "Date Started, Time Started, Instance")
      %endif
  %elif (sequence == "TimeStart")
      %if (orderBy == "INTimeStart,INDateStart,ININST")
          @DTW_ASSIGN(orderBy, "INTimeStart DESC,INDateStart DESC,ININST")
          @DTW_ASSIGN(orderByDisplay, "Time Started (descending), Date Started (descending), Instance")
      %else
          @DTW_ASSIGN(orderBy, "INTimeStart,INDateStart,ININST")
          @DTW_ASSIGN(orderByDisplay, "Time Started, Date Started, Instance")
      %endif
  %elif (sequence == "Process")
      %if (orderBy == "PRDESCU,ININST")
          @DTW_ASSIGN(orderBy, "PRDESCU DESC,ININST")
          @DTW_ASSIGN(orderByDisplay, "Process (descending), Instance")
      %else
          @DTW_ASSIGN(orderBy, "PRDESCU,ININST")
          @DTW_ASSIGN(orderByDisplay, "Process, Instance")
      %endif
  %endif
	
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "numedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "TimeEdit.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchInstance, 15, 0) &&
                      editdate(document.Search.srchFromDateStart) &&
                      editdate(document.Search.srchToDateStart) &&
                      editTimeHM(document.Search.srchFromTimeStart) &&
                      editTimeHM(document.Search.srchToTimeStart))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFERRORSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Instance</td>
                              @dtw_assign(operNbr, "operInstance")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchInstance" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="15" maxlength="40"></td>
                          </tr>

                          <tr><td class="dsphdr">Error</td>
                              @dtw_assign(operNbr, "operError")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchError" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Initial User</td>
                              @dtw_assign(operNbr, "operUser")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchUser" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Process</td>
                              @dtw_assign(operNbr, "operProcess")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchProcess" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Date Started</td>
                              @dtw_assign(operNbr, "operDate")
                              <td>%INCLUDE "opersel_num2_short.icl"</td>
                              <td class="inputnmbr"><input name="srchFromDateStart" type="text" size="6" maxlength="6">
                                  <a href="javascript:calWindow('srchFromDateStart');">$(calendarImage)</a></td>
                              <td class="inputnmbr"><input name="srchToDateStart" type="text" size="6" maxlength="6">
                                  <a href="javascript:calWindow('srchToDateStart');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Time Started</td>
                              @dtw_assign(operNbr, "operTime")
                              <td>%INCLUDE "opersel_num2_short.icl"</td>
                              <td class="inputnmbr"><input name="srchFromTimeStart" type="text" size="4" maxlength="4"></td>
                              <td class="inputnmbr"><input name="srchToTimeStart" type="text" size="4" maxlength="4"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchInstance.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("ININST",  "Instance", $(srchInstance), "", operInstance, "N")
  @Build_WildCard ("INDESCU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("WVDESCU",  "Error", $(srchError), "U", operError, "A")
  @Build_WildCard ("USDESCU",  "Initial User", $(srchUser), "U", operUser, "A")
  @Build_WildCard ("PRDESCU",  "Process", $(srchProcess), "U", operProcess, "A")
  @Range_WildCard ("DATE(INTSTP)", "Date Started", $(srchFromDateStart), $(srchToDateStart), "", operDate, "TSD")
  @Range_WildCard ("TIME(INTSTP)", "Time Started", $(srchFromTimeStart), $(srchToTimeStart), "", operTime, "TST")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
