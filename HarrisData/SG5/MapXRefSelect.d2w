%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Import Cross Reference"
  d2wName                 = "MapXRefSelect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;crossReference=@dtw_rurlescseq(crossReference)&amp;mapImportTable=@dtw_rurlescseq(mapImportTable)"
  programName             = "HSYIXM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
  V_MHDESC                = ""	
  quickLinkByUser         = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_assign(backHome, "$(d2wName)/REPORT")
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          @RtvFldDesc("MXXREF='$(crossReference)' and MXIFIL='$(mapImportTable)'", "SYMXRF", "MXDESC", V_MXDESC)
          @Format_Code("$(crossReference)-$(mapImportTable)", F_crossReference)
          @dtw_assign(title, "$(V_MXDESC) $(F_crossReference)")
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "MAPXREFSELECT")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif

                  <td class="content">

%{ QuickLink Table %}     %INCLUDE "QuickLinkTable.icl"

%{ QuickLink By User %}   %INCLUDE "QuickLinkByUser.icl"

%{ Process Heading %}
                      @dtw_assign(RPT_MAX_ROWS, "99")
                      @dtw_assign(dspMaxRows, "10")
                      @dtw_assign(wildCardSearch, "")  %{ No wildCardSearch %}
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select SYMXRF.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(PMPRMD,' ') as PMPRMD, coalesce(PMPRMDU,' ') as PMPRMDU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(a.FLDESC,' ') as fldtFLDESC, coalesce(upper(a.FLDESC),' ') as fldtFLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(b.FLDESC,' ') as upprFLDESC, coalesce(upper(b.FLDESC),' ') as upprFLDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " SYMXRF ", fileSQL)
                      @dtw_concat(fileSQL, " left join WFPARM on PMPARM=MXPARM ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG a on a.FLTYPE='XRFFLDTYP' and a.FLVALU=MXFLDT ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG b on b.FLTYPE='BY' and b.FLVALU=MXUPPR ", fileSQL)
                      @dtw_concat(selectSQL, " MXXREF='$(crossReference)' and MXIFIL='$(mapImportTable)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Process_Select_Header(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Begin %}     %INCLUDE "QuickLinkBegLoop.icl"

    %{ Value %}
                          %if (quicklinkRef == "value")
                              %INCLUDE "QuickLinkClear.icl"
                              @Retrieve_WebReg(userProfile, "", "MapXRefValue.d2w", wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select *  ", stmtSQL)
                              @dtw_concat(fileSQL, " SYMXRV ", fileSQL)
                              @dtw_concat(selectSQL, " MVXREF='$(crossReference)' and MVIFIL='$(mapImportTable)' ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %if (orderBy == "")
                                  @dtw_assign(orderBy, "MVFVAL, MVTVAL")
                                  @dtw_assign(orderByDisplay, "From Value, To Value")
                              %endif
                              @dtw_concat(stmtSQL, " Order By $(orderBy)", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @Process_Select_Value(profileHandle, dataBaseID, stmtSQL)
                          %endif

    %{ Template %}
                          %if (quicklinkRef == "template")
                              %INCLUDE "QuickLinkClear.icl"
                              @dtw_assign(wildCardSearch, "")
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select SYMITP.*,  ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(FHDESC,' ') as FHDESC, coalesce(FHDESCU,' ') as FHDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(MFDESC,' ') as MFDESC, coalesce(MFDESCU,' ') as MFDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(MDDPOS,0) as MDDPOS, coalesce(MDDESC,' ') as MDDESC, coalesce(MDDLGC,' ') as MDDLGC, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(MDNOTE,' ') as MDNOTE, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(FFDESC,' ') as FFDESC, coalesce(FFDESCU,' ') as FFDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(FRDESC,' ') as FRDESC, coalesce(FRDESCU,' ') as FRDESCU ", stmtSQL)
                              @dtw_concat(fileSQL, " SYMITP ", fileSQL)
                              @dtw_concat(fileSQL, " inner join SYMIHD on FHIMKY=FDIMKY ", fileSQL)
                              @dtw_concat(fileSQL, " inner join SYMMTB on MFMPKY=FHMPKY and MFMFIL=FDMFIL ", fileSQL)
                              @dtw_concat(fileSQL, " inner join SYMMCL on MDMPKY=FHMPKY and MDMFIL=FDMFIL and MDMFLD=FDMFLD ", fileSQL)
                              @dtw_concat(fileSQL, " left  join SYMITB on FFIMKY=FDIMKY and FFIFIL=FDIFIL ", fileSQL)
                              @dtw_concat(fileSQL, " left  join SYMIRT on FRIMKY=FDIMKY and FRIFIL=FDIFIL and FRRTYP=FDRTYP ", fileSQL)
                              @dtw_concat(selectSQL, " FDXREF='$(crossReference)' and FDXIFL='$(mapImportTable)' ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              @dtw_concat(stmtSQL, " ORDER BY MFDESC,MDMFIL,MDDPOS,MDMFLD ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @Process_Select_Template(profileHandle, dataBaseID, stmtSQL)
                          %endif


%{ Quicklink End %}       %INCLUDE "QuickLinkEndLoop.icl"

                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Process_Select_Header (IN CHAR(64)    profileHandle,
                                             CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)MapXRefMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (sec_01=="Y" && sec_04=="Y")
                          <a href="$(homeURL)$(cGIPath)MapXRefMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromCrossReference=@dtw_rurlescseq(crossReference)&amp;fromImportTable=@dtw_rurlescseq(mapImportTable)&amp;maintenanceCode=Z">$(copyImageLrg)</a>
                      %endif
                      %if (sec_02 == "Y" || sec_03 == "Y")
                          <a href="$(homeURL)$(cGIPath)MapXRefMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageLrg)</a>
                      %endif
                      %if (sec_03 == "Y")
                          @Format_Confirm_Desc($(V_MXDESC), "$(crossReference)-$(mapImportTable)", "", "", "", "", confirmDesc)
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)MapXRefMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %ROW{
          <table $(contentTable)>
              <tr><td class="dsphdr">Cross Reference</td>
                  <td class="dspalph">$(V_MXXREF)</td>
              </tr>

              <tr><td class="dsphdr">Import Table</td>
                  <td class="dspalph">$(V_MXIFIL)</td>
              </tr>

              <tr><td class="dsphdr">Description</td>
                  <td class="dspalph">$(V_MXDESC)</td>
              </tr>

              <tr><td class="dsphdr">Workflow Parameter</td>
                  @Format_Code(V_MXPARM, F_MXPARM)
                  <td class="dspalph">$(V_PMPRMD) $(F_MXPARM)</td>
              </tr>

              <tr><td class="dsphdr">Column Type</td>
                  @Format_Code(V_MXFLDT, F_MXFLDT)
                  <td class="dspalph">$(V_fldtFLDESC) $(F_MXFLDT)</td>
              </tr>

              <tr><td class="dsphdr">Whole Number Precision</td>
                  <td class="dspnmbr">$(V_MXSIZE)</td>
              </tr>

              <tr><td class="dsphdr">Decimal Precision</td>
                  <td class="dspnmbr">$(V_MXDECM)</td>
              </tr>

              <tr><td class="dsphdr">Convert To Upper</td>
                  @Format_Code(V_MXUPPR, F_MXUPPR)
                  <td class="dspalph">$(V_upprFLDESC) $(F_MXUPPR)</td>
              </tr>
          </table>

          $(hrTagAttr)

          %INCLUDE "QuickLinkDisplay.icl"
      %}
  %}
%}

%FUNCTION(dtw_sql) Process_Select_Value (IN CHAR(64)    profileHandle,
                                            CHAR(2)     dataBaseID,
                                            CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="value"></a>
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)MapXRefValue.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("MVFVAL", "From Value")
                  @Format_Column_Header("MVTVAL", "To Value")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">$(V_MVFVAL)&nbsp;</td>
                  <td class="colalph">$(V_MVTVAL)&nbsp;</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Process_Select_Template (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="template"></a>
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      @dtw_assign(interfaceTable, "")

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("", "Map Definition")
                  @Format_Column_Header("", "Import Table")
                  @Format_Column_Header("", "Row Type")
                  @Format_Column_Header("", "Interface Table")
                  @Format_Column_Header("", "Column")
                  @Format_Column_Header("", "Description")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph" $(helpCursor)><span title="$(V_FDIMKY)">$(V_FHDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_FDIFIL)">$(V_FFDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_FDRTYP)">$(V_FRDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_FDMFIL)">$(V_MFDESC)</span></td>
                  <td class="colalph">$(V_FDMFLD)</td>
                  <td class="colalph">$(V_MDDESC)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}