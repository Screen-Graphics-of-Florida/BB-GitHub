%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Labor In Process Notes"
  d2wName                 = "LaborInProcessNotesInquiry.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;mfgOrder=@dtw_rurlescseq(mfgOrder)&amp;sequenceNumber=@dtw_rurlescseq(sequenceNumber)&amp;documentType=@dtw_rurlescseq(documentType)&amp;touchScreen=@dtw_rurlescseq(touchScreen)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      @dtw_concat(stmtSQL, " Select OLDESC From HDMLOD ", stmtSQL)
                      @dtw_concat(stmtSQL, " Where (OLPLT=$(plantNumber) and OLMORD='$(mfgOrder)' ", stmtSQL)
                      @dtw_concat(stmtSQL, " and OLSEQN=$(sequenceNumber) and OLDOCT='$(documentType)') ", stmtSQL)
                      @dtw_concat(stmtSQL, " Order By OLLINE ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @LIP_Notes_Inquiry(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) LIP_Notes_Inquiry (IN CHAR(64)    profileHandle,
				          CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (touchScreen == "Y")
          <div class="quickLinksTop">
              <ul class="toolbarTS">
                  <li class="optionTS"><a href="javascript:window.close()">&nbsp;<br>Close</a></li>
              </ul>
          </div>
      %endif
      %INCLUDE "PageTitle.icl"

      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      <table $(contentTable)>
          @Format_Header("Plant", $(plantName), $(plantNumber))
          @Format_Header("Order", $(mfgOrder), "")
          @Format_Header("Sequence", $(sequenceNumber), "")
      </table>

      $(inquiryhrTagAttr)

      <table $(contentTable)>
          %ROW{
              <tr><td class="colalph">$(V_OLDESC)</td></tr>
          %}
      </table>
      $(inquiryhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}