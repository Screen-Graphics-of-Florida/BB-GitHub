%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Order Entry User-Defined Detail"
  d2wName                 = "OrderEntryUserDefinedDetail.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;lineNumber=@dtw_rurlescseq(lineNumber)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
  fileName                = "OEOUDT"
%}

%INCLUDE "userdefined_number.icl"

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @dtw_assign(editVariables, "")
  @dtw_tb_rows(orderDetailUserDefinedTable, userMaxRows)
  @dtw_assign(ux, "1")
  %while(ux <= userMaxRows){
      @dtw_tb_getv(orderDetailUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderDetailUserDefinedTable, "UFFLDN"), V_UFFLDN)
      @dtw_tb_getv(orderDetailUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderDetailUserDefinedTable, "UFDESC"), V_UFDESC)
      @dtw_tb_getv(orderDetailUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderDetailUserDefinedTable, "UFTYPE"), V_UFTYPE)
      @dtw_tb_getv(orderDetailUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderDetailUserDefinedTable, "UFSIZE"), V_UFSIZE)
      @dtw_tb_getv(orderDetailUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderDetailUserDefinedTable, "UFDECM"), V_UFDECM)
      @dtw_tb_getv(orderDetailUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderDetailUserDefinedTable, "UFREQF"), V_UFREQF)

      %if (V_UFTYPE == "N")
          @dtw_concat(editVariables, " editNum(document.Chg.", editVariables)
          @dtw_concat(editVariables, $(V_UFFLDN), editVariables)
          @dtw_concat(editVariables, ", ", editVariables)
          @dtw_concat(editVariables, $(V_UFSIZE), editVariables)
          @dtw_concat(editVariables, ", ", editVariables)
          @dtw_concat(editVariables, $(V_UFDECM), editVariables)
          @dtw_concat(editVariables, ") &&", editVariables)
      %elif (V_UFTYPE == "D")
          @dtw_concat(editVariables, " editdate(document.Chg.", editVariables)
          @dtw_concat(editVariables, $(V_UFFLDN), editVariables)
          @dtw_concat(editVariables, ") &&", editVariables)
      %endif
      %if (V_UFREQF == "Y")
          @dtw_concat(editVariables, " checkReqField(document.Chg.", editVariables)
          @dtw_concat(editVariables, $(V_UFFLDN), editVariables)
          @dtw_concat(editVariables, ") &&", editVariables)
      %endif
      @dtw_add(ux, "1", ux)
  %}
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if ($(editVariables) document.Chg.octl.value != "")
                  return true;
              }
              %INCLUDE "checkReqField.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumZero.icl"
              %INCLUDE "numedit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(stmtSQL, "Select * From OEDTWK Where O1OCTL=$(orderControlNumber) and O1ORL#=$(lineNumber) and O1BLN#=0")
                      %INCLUDE "stmtSQLEnd.icl"
                      @Order_Detail_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Order_Detail_Query (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
	    <table $(contentTable)>
		       <colgroup>
		           <col width="80%">
		           <col width="15%">
	        <tr><td><h1>$(page_title)</h1></td>
	            <td class="toolbar">
                    <a href="javascript:check(document.Chg)">$(acceptImageLrg)</a>
	                <a href="javascript:window.close()">$(closeImageMed)</a>
	                %INCLUDE "HelpPage.icl"
	            </td>
	        </tr>
	    </table>

      %ROW {
          <table $(contentTable)>
              @Format_Header("Item", $(V_O1IMDS), $(V_O1ITEM))
              @Format_Header("Line", $(lineNumber), "")
          </table>
	      $(inquiryhrTagAttr)
	      %INCLUDE "RequiredField.icl"
	
	      <form class="formClass" METHOD=POST name="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
	          <table $(contentTable)>
              <tr><td class="inputalph"><input type="hidden" name="octl" value="$(orderControlNumber)"></td></tr>

              @dtw_tb_rows(orderDetailUserDefinedTable, userMaxRows)
              @dtw_assign(ux, "1")
              %while(ux <= userMaxRows){
                  @dtw_tb_getv(orderDetailUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderDetailUserDefinedTable, "UFFLDN"), V_UFFLDN)
                  @dtw_tb_getv(orderDetailUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderDetailUserDefinedTable, "UFDESC"), V_UFDESC)
                  @dtw_tb_getv(orderDetailUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderDetailUserDefinedTable, "UFTYPE"), V_UFTYPE)
                  @dtw_tb_getv(orderDetailUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderDetailUserDefinedTable, "UFSIZE"), V_UFSIZE)
                  @dtw_tb_getv(orderDetailUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderDetailUserDefinedTable, "UFDECM"), V_UFDECM)
                  @dtw_tb_getv(orderDetailUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderDetailUserDefinedTable, "UFVALU"), V_UFVALU)
                  @dtw_tb_getv(orderDetailUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderDetailUserDefinedTable, "UFBOXS"), V_UFBOXS)
                  @dtw_tb_getv(orderDetailUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderDetailUserDefinedTable, "UFREQF"), V_UFREQF)
                  @dtw_tb_getv(orderDetailUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderDetailUserDefinedTable, "UFVLDV"), V_UFVLDV)

                  @dtw_assign(V_WUFLDD, "")
                  @dtw_assign(V_WUFLDV, "")
                  @dtw_assign(V_WUFLDR, "")
                  @dtw_tb_rows(orderDetailWorkUserDefinedTable, maxRows)
                  @dtw_assign(x, "1")
                  %while((@dtw_tb_rgetv(orderDetailWorkUserDefinedTable, x, @dtw_tb_rQuerycolnonj(orderDetailWorkUserDefinedTable, "WUFLDN")) != V_UFFLDN) && (x <= maxRows))
                      {@dtw_add(x, "1", x)%}
                  %if (x <=maxRows)
                      @dtw_tb_getv(orderDetailWorkUserDefinedTable, x, @dtw_tb_rQuerycolnonj(orderDetailWorkUserDefinedTable, "WUFLDD"), V_WUFLDD)
                      @dtw_tb_getv(orderDetailWorkUserDefinedTable, x, @dtw_tb_rQuerycolnonj(orderDetailWorkUserDefinedTable, "WUFLDV"), V_WUFLDV)
                      @dtw_tb_getv(orderDetailWorkUserDefinedTable, x, @dtw_tb_rQuerycolnonj(orderDetailWorkUserDefinedTable, "WUFLDR"), V_WUFLDR)
                  %else
                      @dtw_assign(V_WUFLDD, "")
                      @dtw_assign(V_WUFLDV, "")
                      @dtw_assign(V_WUFLDR, "")
                  %endif

                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(userEdtVar, "")
                      %else
                          %if (ux == "1")
                              @EdtVarErr(profileHandle, typeValue, edtVar)
                              @ErrVarErr(profileHandle, typeError, errVar)
                          %endif
                          @dtw_assign(catFld, V_UFFLDN)
                          %while(@dtw_rlength(catFld) != "6")
                              {@dtw_insert("@", catFld, @dtw_rlength(catFld), catFld) %}
                          @DecatErr_Field("$(catFld)", "$(V_UFFLDN)")
                          @dtw_concat("Err_", "$(V_UFFLDN)", errFldName)
                          @dtw_assign(errFldName, fieldValue)
                      %endif

                      @Decat_Field("$(catFld)")
                      %if (V_UFTYPE == "A" || V_UFTYPE == "C")
                          @dtw_assign(V_WUFLDV, fieldValue)
                      %elif (V_UFTYPE == "N")
                          @dtw_assign(V_WUFLDN, fieldValue)
                          @dtw_multiply(V_WUFLDN, "1", "21", V_WUFLDN)
                      %elif (V_UFTYPE == "D")
                          @dtw_assign(V_WUFLDD, fieldValue)
                      %endif
                  %else
                      %if (V_UFTYPE == "N")
                          @dtw_assign(Precision, @dtw_radd(V_UFSIZE, V_UFDECM))
                          @dtw_assign(V_WUFLDN, @dtw_rformat(V_WUFLDR, V_UFSIZE, V_UFDECM, "", "", Precision))
                          @dtw_assign(V_WUFLDN, @dtw_rstrip(V_WUFLDN))
                      %elif (V_UFTYPE == "D")
                          @DateInputFromISO("$(V_WUFLDD)", V_WUFLDD)
                      %endif
                  %endif

                  @SetTextOvr(errFldName)
       	          <tr><td class="dsphdr"><span $(textOvr)>$(V_UFDESC)</span></td>
                          %if (V_UFTYPE == "A")
                              <td class="inputalph"><input type="text" name="$(V_UFFLDN)" value="$(V_WUFLDV)" size="$(V_UFSIZE)" maxlength="$(V_UFSIZE)">
                          %elif (V_UFTYPE == "C")
                              <td>%if ("$(V_WUFLDV)" != "")
                                      <textarea name="$(V_UFFLDN)" ROWS=$(V_UFBOXS) COLS=60 onkeyup="checkCmtLength(this.value)" onkeypress="checkCmtLength(this.value)">$(V_WUFLDV)</textarea>
                                  %else
            	                       <textarea name="$(V_UFFLDN)" ROWS=$(V_UFBOXS) COLS=60 onkeyup="checkCmtLength(this.value)" onkeypress="checkCmtLength(this.value)"></textarea>
                                  %endif
                          %elif (V_UFTYPE == "N")
                              @dtw_add(V_UFSIZE, V_UFDECM, V_UFSIZE)
                              %if (V_UFDECM != "0")
                                  @dtw_add(V_UFSIZE, "2", V_UFSIZE)
                              %endif
                              <td class="inputnmbr"><input type="text" name="$(V_UFFLDN)" value="$(V_WUFLDN)" size="$(V_UFSIZE)" maxlength="$(V_UFSIZE)">
                          %elif (V_UFTYPE == "D")
                              <td class="inputnmbr"><input type="text" name="$(V_UFFLDN)" value="$(V_WUFLDD)" size="6" maxlength="6">
                                   %if (V_UFVLDV != "Y")
                                       <a href="javascript:calWindow('$(V_UFFLDN)');">$(calendarImage)</a>
                                   %endif
                          %endif
                          %if (V_UFVALU == "Y" || V_UFVLDV == "Y")
                              <a href="$(homeURL)$(phpPath)UserDefinedSearch.php$(altVarBase)&amp;docName=Chg&amp;fileName=$(fileName)&amp;fldName=$(V_UFFLDN)&amp;fldType=$(V_UFTYPE)&amp;fldDesc=$(V_UFDESC)" onclick="$(searchWinVar)"> $(searchImage) </a>
                          %endif
                          %if (V_UFREQF == "Y")
                              $(reqFieldChar)
                          %endif
                      </td>
                  </tr>
                  @DspErrMsg(errFldName)
                  @dtw_add(ux, "1", ux)
              %}
	      </table>
	      %if (focusField != "")
	          <script TYPE="text/javascript">
	              document.Chg.$(focusField).focus();
	          </script>
	      %endif
	      </form>
      %}
      @dtw_assign(errFound, "")
      <div>
	      <a href="javascript:check(document.Chg)">$(acceptImageLrg)</a>
	      <a href="javascript:window.close()">$(closeImageMed)</a>
	      %INCLUDE "HelpPage.icl"
      </div>
      $(inquiryhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(10)    userProfile,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HOEUDU_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "OrderEntryRetInfo.icl"
  @OrderDetailUDF_Query(fileName, orderControlNumber, lineNumber, orderDetailUserDefinedTable)	
  @OrderDetailWorkUDF_Query(orderControlNumber, lineNumber, orderDetailWorkUserDefinedTable)	
  @Set_SQL(stmtSQL)
  %}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "OrderEntryRetInfo.icl"
  @OrderDetailUDF_Query(fileName, orderControlNumber, lineNumber, orderDetailUserDefinedTable)	
  @OrderDetailWorkUDF_Query(orderControlNumber, lineNumber, orderDetailWorkUserDefinedTable)	
  @Set_SQL(stmtSQL)
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @dtw_assign(edtVar, "")
  @Concat_Field("@@octl", orderControlNumber)
  @Concat_Field("@@orl#", lineNumber)

  @OrderDetailUDF_Query(fileName, orderControlNumber, lineNumber, orderDetailUserDefinedTable)	

  @dtw_tb_rows(orderDetailUserDefinedTable, userMaxRows)
  @dtw_assign(ux, "1")
  %while(ux <= userMaxRows){
      @dtw_tb_getv(orderDetailUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderDetailUserDefinedTable, "UFFLDN"), V_UFFLDN)
      @dtw_tb_getv(orderDetailUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderDetailUserDefinedTable, "UFTYPE"), V_UFTYPE)
      @dtw_assign(UFFLDN, $(V_UFFLDN))
      @dtw_assign(outField, $($(UFFLDN)))
      %if (V_UFTYPE == "A" || V_UFTYPE == "C")
          @dtw_tb_getv(orderDetailUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderDetailUserDefinedTable, "UFUPPR"), V_UFUPPR)
          %if (V_UFUPPR == "Y")
              @dtw_mUPPERCASE(outField)
          %endif
      %elif (V_UFTYPE == "N")
          @dtw_tb_getv(orderDetailUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderDetailUserDefinedTable, "UFSIZE"), V_UFSIZE)
          @dtw_tb_getv(orderDetailUserDefinedTable, ux, @dtw_tb_rQuerycolnonj(orderDetailUserDefinedTable, "UFDECM"), V_UFDECM)
          @Build_User_Number(outField, V_UFSIZE, V_UFDECM, outField)
      %endif
      %while(@dtw_rlength(V_UFFLDN) != "6")
          {@dtw_insert("@", V_UFFLDN, @dtw_rlength(V_UFFLDN), V_UFFLDN) %}
      @dtw_concat(edtVar, @dtw_rconcat("}{$(V_UFFLDN)", $(outField)), edtVar)
      @dtw_add(ux, "1", ux)
  %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(userProfile, errFound, edtVar, errVar)

  %if (errFound == "")
	  <script TYPE="text/javascript">
	      opener.location.href=opener.location.href;
	      opener.focus();
	      window.close();
	  </script>
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}