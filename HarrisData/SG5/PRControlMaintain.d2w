%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "Employee.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Payroll Control Maintenance"
  d2wName                 = "PRControlMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName             = "HPRCTU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.payXactionEntryTimeFormat.value =="" ||
                      document.Chg.printAudits.value ==""  ||
                      document.Chg.printPayXactionEntryAudits.value ==""  ||
                      document.Chg.reclaimResourceLevel.value ==""  ||
                      document.Chg.printDDAdvice.value ==""  ||
                      document.Chg.retainMultYearHistory.value ==""  ||
                      document.Chg.processInterCoDeptWages.value ==""  ||
                      document.Chg.processInterCoDeptFICA.value ==""  ||
                      document.Chg.processInterCoDeptFUI.value ==""  ||
                      document.Chg.processInterCoDeptSUI.value ==""  ||
                      document.Chg.processInterCoDeptSDI.value ==""  ||
                      document.Chg.processInterCoDeptSWC.value ==""  ||
                      document.Chg.processInterCoDeptLIT.value ==""  ||
                      document.Chg.autoAssignEmplNumber.value ==""  ||
                      document.Chg.etdFIT.value ==""  ||
                      document.Chg.etdFUI.value ==""  ||
                      document.Chg.etdSIT.value ==""  ||
                      document.Chg.etdSUI.value ==""  ||
                      document.Chg.etdSDI.value ==""  ||
                      document.Chg.etdSWC.value ==""  ||
                      document.Chg.etdLIT.value ==""  ||
                      document.Chg.asfpFIT.value ==""  ||
                      document.Chg.asfpFUI.value ==""  ||
                      document.Chg.asfpSIT.value ==""  ||
                      document.Chg.asfpSUI.value ==""  ||
                      document.Chg.asfpSDI.value ==""  ||
                      document.Chg.asfpSWC.value ==""  ||
                      document.Chg.asfpLIT.value ==""  ||
                      document.Chg.eftFIT.value ==""  ||
                      document.Chg.eftFUI.value ==""  ||
                      document.Chg.eftSIT.value ==""  ||
                      document.Chg.eftSUI.value ==""  ||
                      document.Chg.eftSDI.value ==""  ||
                      document.Chg.eftSWC.value ==""  ||
                      document.Chg.eftLIT.value ==""  )
                     {alert("$(reqFieldError)"); return false;}
                  if (
                      editNum(document.Chg.emplPercentOfGross, 2, 3) &&
                      editNum(document.Chg.vnFIT, 7, 0) &&
                      editNum(document.Chg.vnFUI, 7, 0) &&
                      editNum(document.Chg.vnSUI, 7, 0) &&
                      editNum(document.Chg.vnSUI, 7, 0) &&
                      editNum(document.Chg.vnSDI, 7, 0) &&
                      editNum(document.Chg.vnSWC, 7, 0) &&
                      editNum(document.Chg.vnLIT, 7, 0)
                      %if (V_HDGLRL=="0") &&
                          editNum(document.Chg.glDistributionPeriod, 4, 0)
                      %endif
                      )
                      return true;
              }
              %INCLUDE "NumEdit.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PRCONTROLMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " PRCTRL ", fileSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
   </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN  CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @dtw_assign(sec_03, "N")
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "checkPrintingProgram")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@ckpg", "checkPrintingProgram")           @dtw_assign(Err_PRCKPG, fieldValue)
                          @DecatErr_Field("@@tetm", "payXactionEntryTimeFormat")      @dtw_assign(Err_PRTETM, fieldValue)
                          @DecatErr_Field("@@mnta", "printAudits")                    @dtw_assign(Err_PRMNTA, fieldValue)
                          @DecatErr_Field("@@enta", "printPayXactionEntryAudits")     @dtw_assign(Err_PRENTA, fieldValue)
                          @DecatErr_Field("@@dper", "glDistributionPeriod")           @dtw_assign(Err_PRDPER, fieldValue)
                          @DecatErr_Field("@@rclr", "reclaimResourceLevel")           @dtw_assign(Err_PRRCLR, fieldValue)
                          @DecatErr_Field("@@ddav", "printDDAdvice")                  @dtw_assign(Err_PRDDAV, fieldValue)
                          @DecatErr_Field("@@myhs", "retainMultYearHistory")          @dtw_assign(Err_PRMYHS, fieldValue)
                          @DecatErr_Field("@@icwg", "processInterCoDeptWages")        @dtw_assign(Err_PRICWG, fieldValue)
                          @DecatErr_Field("@@icfi", "processInterCoDeptFICA")         @dtw_assign(Err_PRICFI, fieldValue)
                          @DecatErr_Field("@@icfu", "processInterCoDeptFUI")          @dtw_assign(Err_PRICFU, fieldValue)
                          @DecatErr_Field("@@icsu", "processInterCoDeptSUI")          @dtw_assign(Err_PRICSU, fieldValue)
                          @DecatErr_Field("@@icsd", "processInterCoDeptSDI")          @dtw_assign(Err_PRICSD, fieldValue)
                          @DecatErr_Field("@@icsw", "processInterCoDeptSWC")          @dtw_assign(Err_PRICSW, fieldValue)
                          @DecatErr_Field("@@icli", "processInterCoDeptLIT")          @dtw_assign(Err_PRICLI, fieldValue)
                          @DecatErr_Field("@@lb@@", "consolidatedReportingDB")        @dtw_assign(Err_PRLB,   fieldValue)
                          @DecatErr_Field("@@gpap", "emplPercentOfGross")             @dtw_assign(Err_PRGPAG, fieldValue)
                          @DecatErr_Field("@@aaen", "autoAssignEmplNumber")           @dtw_assign(Err_PRAAEN, fieldValue)
                          @DecatErr_Field("@@u1ds", "udNumericScreenDesc1")           @dtw_assign(Err_PRU1DS, fieldValue)
                          @DecatErr_Field("@@u1hd", "udNumericScreenHead1")           @dtw_assign(Err_PRU1HD, fieldValue)
                          @DecatErr_Field("@@u2ds", "udNumericScreenDesc2")           @dtw_assign(Err_PRU2DS, fieldValue)
                          @DecatErr_Field("@@u2hd", "udNumericScreenHead2")           @dtw_assign(Err_PRU2HD, fieldValue)
                          @DecatErr_Field("@@u3ds", "udNumericScreenDesc1")           @dtw_assign(Err_PRU3DS, fieldValue)
                          @DecatErr_Field("@@u3hd", "udNumericScreenHead1")           @dtw_assign(Err_PRU3HD, fieldValue)
                          @DecatErr_Field("@@u4ds", "udAlphaScreenDesc1")             @dtw_assign(Err_PRU4DS, fieldValue)
                          @DecatErr_Field("@@u4hd", "udAlphaScreenHead1")             @dtw_assign(Err_PRU4HD, fieldValue)
                          @DecatErr_Field("@@u5ds", "udAlphaScreenDesc2")             @dtw_assign(Err_PRU5DS, fieldValue)
                          @DecatErr_Field("@@u5hd", "udAlphaScreenHead2")             @dtw_assign(Err_PRU5HD, fieldValue)
                          @DecatErr_Field("@@u6ds", "udAlphaScreenDesc3")             @dtw_assign(Err_PRU6DS, fieldValue)
                          @DecatErr_Field("@@u6hd", "udAlphaScreenHead3")             @dtw_assign(Err_PRU6HD, fieldValue)
                          @DecatErr_Field("@@xfit", "etdFIT")                         @dtw_assign(Err_PRXFIT, fieldValue)
                          @DecatErr_Field("@@xfui", "etdFUI")                         @dtw_assign(Err_PRXFUI, fieldValue)
                          @DecatErr_Field("@@xsit", "etdSIT")                         @dtw_assign(Err_PRXSIT, fieldValue)
                          @DecatErr_Field("@@xsui", "etdSUI")                         @dtw_assign(Err_PRXSUI, fieldValue)
                          @DecatErr_Field("@@xsdi", "etdSDI")                         @dtw_assign(Err_PRXSDI, fieldValue)
                          @DecatErr_Field("@@xswc", "etdSWC")                         @dtw_assign(Err_PRXSWC, fieldValue)
                          @DecatErr_Field("@@xlit", "etdLIT")                         @dtw_assign(Err_PRXLIT, fieldValue)
                          @DecatErr_Field("@@afit", "asfpFIT")                        @dtw_assign(Err_PRAFIT, fieldValue)
                          @DecatErr_Field("@@afui", "asfpFUI")                        @dtw_assign(Err_PRAFUI, fieldValue)
                          @DecatErr_Field("@@asit", "asfpSIT")                        @dtw_assign(Err_PRASIT, fieldValue)
                          @DecatErr_Field("@@asui", "asfpSUI")                        @dtw_assign(Err_PRASUI, fieldValue)
                          @DecatErr_Field("@@asdi", "asfpSDI")                        @dtw_assign(Err_PRASDI, fieldValue)
                          @DecatErr_Field("@@aswc", "asfpSWC")                        @dtw_assign(Err_PRASWC, fieldValue)
                          @DecatErr_Field("@@alit", "asfpLIT")                        @dtw_assign(Err_PRALIT, fieldValue)
                          @DecatErr_Field("@@vfit", "vnFIT")                          @dtw_assign(Err_PRVFIT, fieldValue)
                          @DecatErr_Field("@@vfui", "vnFUI")                          @dtw_assign(Err_PRVFUI, fieldValue)
                          @DecatErr_Field("@@vsit", "vnSIT")                          @dtw_assign(Err_PRVSIT, fieldValue)
                          @DecatErr_Field("@@vsui", "vnSUI")                          @dtw_assign(Err_PRVSUI, fieldValue)
                          @DecatErr_Field("@@vsdi", "vnSDI")                          @dtw_assign(Err_PRVSDI, fieldValue)
                          @DecatErr_Field("@@vswc", "vnSWC")                          @dtw_assign(Err_PRVSWC, fieldValue)
                          @DecatErr_Field("@@vlit", "vnLIT")                          @dtw_assign(Err_PRVLIT, fieldValue)
                          @DecatErr_Field("@@efit", "eftFIT")                         @dtw_assign(Err_PREFIT, fieldValue)
                          @DecatErr_Field("@@efui", "eftFUI")                         @dtw_assign(Err_PREFUI, fieldValue)
                          @DecatErr_Field("@@esit", "eftSIT")                         @dtw_assign(Err_PRESIT, fieldValue)
                          @DecatErr_Field("@@esui", "eftSUI")                         @dtw_assign(Err_PRESUI, fieldValue)
                          @DecatErr_Field("@@esdi", "eftSDI")                         @dtw_assign(Err_PRESDI, fieldValue)
                          @DecatErr_Field("@@eswc", "eftSWC")                         @dtw_assign(Err_PRESWC, fieldValue)
                          @DecatErr_Field("@@elit", "eftLIT")                         @dtw_assign(Err_PRELIT, fieldValue)
                        %endif

                      @Decat_Field("@@prrl")   @dtw_assign(V_PRPRRL, fieldValue)
                      @Decat_Field("@@prll")   @dtw_assign(V_PRPRLL, fieldValue)
                      @Decat_Field("@@ckpg")   @dtw_assign(V_PRCKPG, fieldValue)
                      @Decat_Field("@@tetm")   @dtw_assign(V_PRTETM, fieldValue)
                      @Decat_Field("@@mnta")   @dtw_assign(V_PRMNTA, fieldValue)
                      @Decat_Field("@@enta")   @dtw_assign(V_PRENTA, fieldValue)
                      @Decat_Field("@@dper")   @dtw_assign(V_PRDPER, fieldValue)
                      @Decat_Field("@@rclr")   @dtw_assign(V_PRRCLR, fieldValue)
                      @Decat_Field("@@ddav")   @dtw_assign(V_PRDDAV, fieldValue)
                      @Decat_Field("@@myhs")   @dtw_assign(V_PRMYHS, fieldValue)
                      @Decat_Field("@@icwg")   @dtw_assign(V_PRICWG, fieldValue)
                      @Decat_Field("@@icfi")   @dtw_assign(V_PRICFI, fieldValue)
                      @Decat_Field("@@icfu")   @dtw_assign(V_PRICFU, fieldValue)
                      @Decat_Field("@@icsu")   @dtw_assign(V_PRICSU, fieldValue)
                      @Decat_Field("@@icsd")   @dtw_assign(V_PRICSD, fieldValue)
                      @Decat_Field("@@icsw")   @dtw_assign(V_PRICSW, fieldValue)
                      @Decat_Field("@@icli")   @dtw_assign(V_PRICLI, fieldValue)
                      @Decat_Field("@@lb@@")   @dtw_assign(V_PRLB,   fieldValue)
                      @Decat_Field("@@gpap")   @dtw_assign(V_PRGPAP, fieldValue)
                      @Decat_Field("@@aaen")   @dtw_assign(V_PRAAEN, fieldValue)
                      @Decat_Field("@@u1ds")   @dtw_assign(V_PRU1DS, fieldValue)
                      @Decat_Field("@@u1hd")   @dtw_assign(V_PRU1HD, fieldValue)
                      @Decat_Field("@@u2ds")   @dtw_assign(V_PRU2DS, fieldValue)
                      @Decat_Field("@@u2hd")   @dtw_assign(V_PRU2HD, fieldValue)
                      @Decat_Field("@@u3ds")   @dtw_assign(V_PRU3DS, fieldValue)
                      @Decat_Field("@@u3hd")   @dtw_assign(V_PRU3HD, fieldValue)
                      @Decat_Field("@@u4ds")   @dtw_assign(V_PRU4DS, fieldValue)
                      @Decat_Field("@@u4hd")   @dtw_assign(V_PRU4HD, fieldValue)
                      @Decat_Field("@@u5ds")   @dtw_assign(V_PRU5DS, fieldValue)
                      @Decat_Field("@@u5hd")   @dtw_assign(V_PRU5HD, fieldValue)
                      @Decat_Field("@@u6ds")   @dtw_assign(V_PRU6DS, fieldValue)
                      @Decat_Field("@@u6hd")   @dtw_assign(V_PRU6HD, fieldValue)
                      @Decat_Field("@@xfit")   @dtw_assign(V_PRXFIT, fieldValue)
                      @Decat_Field("@@xfui")   @dtw_assign(V_PRXFUI, fieldValue)
                      @Decat_Field("@@xsit")   @dtw_assign(V_PRXSIT, fieldValue)
                      @Decat_Field("@@xsui")   @dtw_assign(V_PRXSUI, fieldValue)
                      @Decat_Field("@@xsdi")   @dtw_assign(V_PRXSDI, fieldValue)
                      @Decat_Field("@@xswc")   @dtw_assign(V_PRXSWC, fieldValue)
                      @Decat_Field("@@xlit")   @dtw_assign(V_PRXLIT, fieldValue)
                      @Decat_Field("@@afit")   @dtw_assign(V_PRAFIT, fieldValue)
                      @Decat_Field("@@afui")   @dtw_assign(V_PRAFUI, fieldValue)
                      @Decat_Field("@@asit")   @dtw_assign(V_PRASIT, fieldValue)
                      @Decat_Field("@@asui")   @dtw_assign(V_PRASUI, fieldValue)
                      @Decat_Field("@@asdi")   @dtw_assign(V_PRASDI, fieldValue)
                      @Decat_Field("@@aswc")   @dtw_assign(V_PRASWC, fieldValue)
                      @Decat_Field("@@alit")   @dtw_assign(V_PRALIT, fieldValue)
                      @Decat_Field("@@vfit")   @dtw_assign(V_PRVFIT, fieldValue)
                      @Decat_Field("@@vfui")   @dtw_assign(V_PRVFUI, fieldValue)
                      @Decat_Field("@@vsit")   @dtw_assign(V_PRVSIT, fieldValue)
                      @Decat_Field("@@vsui")   @dtw_assign(V_PRVSUI, fieldValue)
                      @Decat_Field("@@vsdi")   @dtw_assign(V_PRVSDI, fieldValue)
                      @Decat_Field("@@vswc")   @dtw_assign(V_PRVSWC, fieldValue)
                      @Decat_Field("@@vlit")   @dtw_assign(V_PRVLIT, fieldValue)
                      @Decat_Field("@@efit")   @dtw_assign(V_PREFIT, fieldValue)
                      @Decat_Field("@@efui")   @dtw_assign(V_PREFUI, fieldValue)
                      @Decat_Field("@@esit")   @dtw_assign(V_PRESIT, fieldValue)
                      @Decat_Field("@@esui")   @dtw_assign(V_PRESUI, fieldValue)
                      @Decat_Field("@@esdi")   @dtw_assign(V_PRESDI, fieldValue)
                      @Decat_Field("@@eswc")   @dtw_assign(V_PRESWC, fieldValue)
                      @Decat_Field("@@elit")   @dtw_assign(V_PRELIT, fieldValue)


                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "checkPrintingProgram")
                          @dtw_assign(V_PRCKPG, "HPRC61")
                          @dtw_assign(V_PRTETM, "M")
                          @dtw_assign(V_PRMNTA, "N")
                          @dtw_assign(V_PRENTA, "N")
                          @dtw_assign(V_PRRCLR, "D")
                          @dtw_assign(V_PRDDAV, "N")
                          @dtw_assign(V_PRMYHS, "N")
                          @dtw_assign(V_PRICWG, "N")
                          @dtw_assign(V_PRICFI, "N")
                          @dtw_assign(V_PRICFU, "N")
                          @dtw_assign(V_PRICSU, "N")
                          @dtw_assign(V_PRICSD, "N")
                          @dtw_assign(V_PRICSW, "N")
                          @dtw_assign(V_PRICLI, "N")
                          @dtw_assign(V_PRAAEN, "0")
                          @dtw_assign(V_PRXFIT, "N")
                          @dtw_assign(V_PRXFUI, "N")
                          @dtw_assign(V_PRXSIT, "N")
                          @dtw_assign(V_PRXSUI, "N")
                          @dtw_assign(V_PRXSDI, "N")
                          @dtw_assign(V_PRXSWC, "N")
                          @dtw_assign(V_PRXLIT, "N")
                          @dtw_assign(V_PRAFIT, "N")
                          @dtw_assign(V_PRAFUI, "N")
                          @dtw_assign(V_PRASIT, "N")
                          @dtw_assign(V_PRASUI, "N")
                          @dtw_assign(V_PRASDI, "N")
                          @dtw_assign(V_PRASWC, "N")
                          @dtw_assign(V_PRALIT, "N")
                          @dtw_assign(V_PREFIT, "N")
                          @dtw_assign(V_PREFUI, "N")
                          @dtw_assign(V_PRESIT, "N")
                          @dtw_assign(V_PRESUI, "N")
                          @dtw_assign(V_PRESDI, "N")
                          @dtw_assign(V_PRESWC, "N")
                          @dtw_assign(V_PRELIT, "N")
                      %endif

                      @dtw_assign(errFound, "")

                  %else
                      @dtw_assign(focusField, "checkPrintingProgram")
                      @PeriodInputFromCYP(V_PRDPER)
                  %endif

                  @SetTextOvr(Err_PRPRRL)
                  <tr><td class="dsphdr"><span $(textOvr)>P/R Release Version</span></td>
                          <td class="inputnmbr"><input name="prReleaseVersion" type="hidden" value="$(V_HDPRRL)" size="5" maxlength="5">$(V_HDPRRL)</td>
                  </tr>
                  @DspErrMsg(Err_PRPRRL)

                  @SetTextOvr(Err_PRPRLL)
                  <tr><td class="dsphdr"><span $(textOvr)>P/R Library Level</span></td>
                      <td class="inputnmbr"><input name="prLibraryLevel" type="hidden" value="$(V_HDPRLL)" size="3" maxlength="3">$(V_HDPRLL)</td>
                  </tr>
                  @DspErrMsg(Err_PRPRRL)

                  @SetTextOvr(Err_PRCKPG)
                  <tr><td class="dsphdr"><span $(textOvr)>Check Printing Program Name</span></td>
                      <td class="inputalph"><input name="checkPrintingProgram" value="$(V_PRCKPG)" type="text" size="6" maxlength="6"></td>
                  </tr>
                  @DspErrMsg(Err_PRCKPG)

                  @SetTextOvr(Err_PRTETM)
                  <tr><td class="dsphdr"><span $(textOvr)>Pay Transaction Entry Time Format</span></td>
                      @dtw_tb_rows(timeTable, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(timeTable, x, "1") != V_PRTETM) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(timeTable, "payXactionEntryTimeFormat", "2", "1", "N", "", x, "1") $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_PRTETM)

                  @SetTextOvr(Err_PRMNTA)
                  <tr><td class="dsphdr"><span $(textOvr)>Print File Maintenance Audits</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_PRMNTA) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "printAudits", "2", "1", "N", "", x, "1") $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_PRMNTA)
               			
                  @SetTextOvr(Err_PRENTA)
                  <tr><td class="dsphdr"><span $(textOvr)>Print Pay Transaction Entry Audits</span></td>
                      @dtw_tb_rows(yn02Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn02Table, x, "1") != V_PRENTA) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn02Table, "printPayXactionEntryAudits", "2", "1", "N", "", x, "1") $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_PRENTA)

                  %if (V_HDGLRL=="0")		
                      @SetTextOvr(Err_PRDPER)
                      <tr><td class="dsphdr"><span $(textOvr)>G/L Distribution Period</span></td>
                          <td class="inputnmbr"><input name="glDistributionPeriod" value="$(V_PRDPER)" type="text" size="2" maxlength="4"><a href="$(homeURL)$(cGIPath)PeriodSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldPeriod=glDistributionPeriod&amp;fldBeginDate=begindate&amp;fldEndDate=enddate" onclick="$(searchWinVar)"> $(searchImage) </a><input name="begindate" type="hidden"><input name="enddate" type="hidden"></td>
                      </tr>
                      @DspErrMsg(Err_PRDPER)
                  %endif

                  @SetTextOvr(Err_PRRCLR)
                  <tr><td class="dsphdr"><span $(textOvr)>Reclaim Resource Level</span></td>
