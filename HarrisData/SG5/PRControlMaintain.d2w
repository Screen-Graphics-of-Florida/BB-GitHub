                      @dtw_tb_rows(yn14Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn14Table, x, "1") != V_PRELIT) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn14Table, "eftLIT", "2", "1", "N", "", x, "1") $(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_PRXLIT)
                  @DspErrMsg(Err_PRALIT)
                  @DspErrMsg(Err_PRVLIT)
                  @DspErrMsg(Err_PRELIT)

                  <tr><td><input name="originalTimeStamp" type="hidden" value="$(V_PRTSTP)"></td></tr>
              %}	
          </table>
          </fieldset>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HPRCTU_W.PGM %}
  %}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"

  @RtvFldDesc("", "PRCTRL", "Char(Count(*))", RecCount)
  %if (RecCount>"0")
      @dtw_assign(maintenanceCode,"C")
  %else
      @dtw_assign(maintenanceCode,"A")
  %endif
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if ((sec_02 == "N" && sec_03 == "N" && maintenanceCode != "A") || (sec_01 == "N" && maintenanceCode == "A") || (sec_04 == "N" && maintenanceCode == "Z"))
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)progOptSecError.d2w/DISPLAY$(genericVarBase)&amp;page_title=@dtw_rurlescseq(page_title)">
  %else

      @time_Query(profileHandle, dataBaseID, "STDMILITRY", timeTable)
	   @dtw_tb_insertrow(timeTable, "0", "1")
	   @dtw_tb_setv(timeTable, "", "1", "1")
	   @dtw_tb_setv(timeTable, "", "1", "2")
      @reclaimResource_Query(profileHandle, dataBaseID, "RECLAIMLVL", reclaimResourceTable)
	   @dtw_tb_insertrow(reclaimResourceTable, "0", "1")
	   @dtw_tb_setv(reclaimResourceTable, "", "1", "1")
	   @dtw_tb_setv(reclaimResourceTable, "", "1", "2")
      @directDeposit_Query(profileHandle, dataBaseID, "DIRDEPAD", directDepositTable)
	   @dtw_tb_insertrow(directDepositTable, "0", "1")
	   @dtw_tb_setv(directDepositTable, "", "1", "1")
	   @dtw_tb_setv(directDepositTable, "", "1", "2")
      @autoAssign_Query(profileHandle, dataBaseID, "AUTOASGNEN", autoAssignTable)
	   @dtw_tb_insertrow(autoAssignTable, "0", "1")
	   @dtw_tb_setv(autoAssignTable, "", "1", "1")
	   @dtw_tb_setv(autoAssignTable, "", "1", "2")
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @yn02_Table_Query(profileHandle, dataBaseID, "YORN      ", yn02Table)
      @yn03_Table_Query(profileHandle, dataBaseID, "YORN      ", yn03Table)
      @yn04_Table_Query(profileHandle, dataBaseID, "YORN      ", yn04Table)
      @yn05_Table_Query(profileHandle, dataBaseID, "YORN      ", yn05Table)
      @yn06_Table_Query(profileHandle, dataBaseID, "YORN      ", yn06Table)
      @yn07_Table_Query(profileHandle, dataBaseID, "YORN      ", yn07Table)
      @yn08_Table_Query(profileHandle, dataBaseID, "YORN      ", yn08Table)
      @yn09_Table_Query(profileHandle, dataBaseID, "YORN      ", yn09Table)
      @yn10_Table_Query(profileHandle, dataBaseID, "YORN      ", yn10Table)
      @yn11_Table_Query(profileHandle, dataBaseID, "YORN      ", yn11Table)
      @yn12_Table_Query(profileHandle, dataBaseID, "YORN      ", yn12Table)
      @yn13_Table_Query(profileHandle, dataBaseID, "YORN      ", yn13Table)
      @yn14_Table_Query(profileHandle, dataBaseID, "YORN      ", yn14Table)

      @Set_SQL(stmtSQL)
  %endif
%}


%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(checkPrintingProgram)
  @dtw_mUPPERCASE(payXactionEntryTimeFormat)
  @dtw_mUPPERCASE(reclaimResourceLevel)
  @dtw_mUPPERCASE(printDDAdvice)

  @dtw_assign(checkPrintingProgram,@dtw_rstrip(checkPrintingProgram))
  @dtw_assign(payXactionEntryTimeFormat,@dtw_rstrip(payXactionEntryTimeFormat))
  @dtw_assign(glDistributionPeriod,@dtw_rstrip(glDistributionPeriod))
  @dtw_assign(reclaimResourceLevel,@dtw_rstrip(reclaimResourceLevel))
  @dtw_assign(printDDAdvice,@dtw_rstrip(printDDAdvice))
  @dtw_assign(consolidatedReportingDB,@dtw_rstrip(consolidatedReportingDB))
  @dtw_assign(emplPercentOfGross,@dtw_rstrip(emplPercentOfGross))
  @dtw_assign(udNumericScreenDesc1,@dtw_rstrip(udNumericScreenDesc1))
  @dtw_assign(udNumericScreenHead1,@dtw_rstrip(udNumericScreenHead1))
  @dtw_assign(udNumericScreenDesc2,@dtw_rstrip(udNumericScreenDesc2))
  @dtw_assign(udNumericScreenHead2,@dtw_rstrip(udNumericScreenHead2))
  @dtw_assign(udNumericScreenDesc3,@dtw_rstrip(udNumericScreenDesc3))
  @dtw_assign(udNumericScreenHead3,@dtw_rstrip(udNumericScreenHead3))
  @dtw_assign(udAlphaScreenDesc1,@dtw_rstrip(udAlphaScreenDesc1))
  @dtw_assign(udAlphaScreenHead1,@dtw_rstrip(udAlphaScreenHead1))
  @dtw_assign(udAlphaScreenDesc2,@dtw_rstrip(udAlphaScreenDesc2))
  @dtw_assign(udAlphaScreenHead2,@dtw_rstrip(udAlphaScreenHead2))
  @dtw_assign(udAlphaScreenDesc3,@dtw_rstrip(udAlphaScreenDesc3))
  @dtw_assign(udAlphaScreenHead3,@dtw_rstrip(udAlphaScreenHead3))
  @dtw_assign(vnFIT,@dtw_rstrip(vnFIT))
  @dtw_assign(vnFUI,@dtw_rstrip(vnFUI))
  @dtw_assign(vnSIT,@dtw_rstrip(vnSIT))
  @dtw_assign(vnSUI,@dtw_rstrip(vnSUI))
  @dtw_assign(vnSDI,@dtw_rstrip(vnSDI))
  @dtw_assign(vnSWC,@dtw_rstrip(vnSWC))
  @dtw_assign(vnLIT,@dtw_rstrip(vnLIT))


  @dtw_assign(edtVar, "")
  @Concat_Field("@@ckpg", checkPrintingProgram)
  @Concat_Field("@@tetm", payXactionEntryTimeFormat)
  @Concat_Field("@@mnta", printAudits)
  @Concat_Field("@@enta", printPayXactionEntryAudits)
  @Concat_Field("@@dper", glDistributionPeriod)
  @Concat_Field("@@rclr", reclaimResourceLevel)
  @Concat_Field("@@ddav", printDDAdvice)
  @Concat_Field("@@myhs", retainMultYearHistory)
  @Concat_Field("@@icwg", processInterCoDeptWages)
  @Concat_Field("@@icfi", processInterCoDeptFICA)
  @Concat_Field("@@icfu", processInterCoDeptFUI)
  @Concat_Field("@@icsu", processInterCoDeptSUI)
  @Concat_Field("@@icsd", processInterCoDeptSDI)
  @Concat_Field("@@icsw", processInterCoDeptSWC)
  @Concat_Field("@@icli", processInterCoDeptLIT)
  @Concat_Field("@@lb@@", consolidatedReportingDB)
  @Concat_Field("@@gpap", emplPercentOfGross)
  @Concat_Field("@@aaen", autoAssignEmplNumber)
  @Concat_Field("@@u1ds", udNumericScreenDesc1)
  @Concat_Field("@@u1hd", udNumericScreenHead1)
  @Concat_Field("@@u2ds", udNumericScreenDesc2)
  @Concat_Field("@@u2hd", udNumericScreenHead2)
  @Concat_Field("@@u3ds", udNumericScreenDesc3)
  @Concat_Field("@@u3hd", udNumericScreenHead3)
  @Concat_Field("@@u4ds", udAlphaScreenDesc1)
  @Concat_Field("@@u4hd", udAlphaScreenHead1)
  @Concat_Field("@@u5ds", udAlphaScreenDesc2)
  @Concat_Field("@@u5hd", udAlphaScreenHead2)
  @Concat_Field("@@u6ds", udAlphaScreenDesc3)
  @Concat_Field("@@u6hd", udAlphaScreenHead3)
  @Concat_Field("@@xfit", etdFIT)
  @Concat_Field("@@xfui", etdFUI)
  @Concat_Field("@@xsit", etdSIT)
  @Concat_Field("@@xsui", etdSUI)
  @Concat_Field("@@xsdi", etdSDI)
  @Concat_Field("@@xswc", etdSWC)
  @Concat_Field("@@xlit", etdLIT)
  @Concat_Field("@@afit", asfpFIT)
  @Concat_Field("@@afui", asfpFUI)
  @Concat_Field("@@asit", asfpSIT)
  @Concat_Field("@@asui", asfpSUI)
  @Concat_Field("@@asdi", asfpSDI)
  @Concat_Field("@@aswc", asfpSWC)
  @Concat_Field("@@alit", asfpLIT)
  @Concat_Field("@@vfit", vnFIT)
  @Concat_Field("@@vfui", vnFUI)
  @Concat_Field("@@vsit", vnSIT)
  @Concat_Field("@@vsui", vnSUI)
  @Concat_Field("@@vsdi", vnSDI)
  @Concat_Field("@@vswc", vnSWC)
  @Concat_Field("@@vlit", vnLIT)
  @Concat_Field("@@efit", eftFIT)
  @Concat_Field("@@efui", eftFUI)
  @Concat_Field("@@esit", eftSIT)
  @Concat_Field("@@esui", eftSUI)
  @Concat_Field("@@esdi", eftSDI)
  @Concat_Field("@@eswc", eftSWC)
  @Concat_Field("@@elit", eftLIT)
  @Concat_Field("@@tstp", originalTimeStamp)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, "P/R Control", "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(backHome)$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif

%}
