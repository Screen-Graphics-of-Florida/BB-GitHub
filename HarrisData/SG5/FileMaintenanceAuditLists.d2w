%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Maintenance Audit Lists"
  d2wName                 = "FileMaintenanceAuditLists.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "3"
  sortPlantNumber         = "1"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromPlantNumber, 3, 0) &&
                      editNum(document.Chg.toPlantNumber, 3, 0) &&
                      editdate(document.Chg.fromTransactionDate) &&
                      editdate(document.Chg.toTransactionDate) &&
                      editFromToAll(document.Chg.fromPlantNumber, document.Chg.toPlantNumber, document.Chg.allPlantNumber, 3) &&
                      editFromToAll(document.Chg.fromProgramName, document.Chg.toProgramName, document.Chg.allProgramName, "A") &&
                      editFromToAll(document.Chg.fromTransactionDate, document.Chg.toTransactionDate, document.Chg.allTransactionDate, "D") &&
                      editFromToAll(document.Chg.fromUserIdentification, document.Chg.toUserIdentification, document.Chg.allUserIdentification, "A") &&
                      editFromToAll(document.Chg.fromWorkStation, document.Chg.toWorkStation, document.Chg.allWorkStation, "A")
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "FILEMAINTENANCEAUDITLISTS")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromPlantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@fplt", "fromPlantNumber")        @dtw_assign(Err_N1FPLT,  fieldValue)
                                  @DecatErr_Field("@@splt", "sortPlantNumber")        @dtw_assign(Err_N1SPLT,  fieldValue)
                                  @DecatErr_Field("@@spgm", "sortProgramName")        @dtw_assign(Err_N1SPROG,  fieldValue)
                                  @DecatErr_Field("@@susr", "sortUserIdentification")       @dtw_assign(Err_N1SUSER,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@prnt")  @dtw_assign(V_N1PRNT,  fieldValue)
                                  @Decat_Field("@@fplt")  @dtw_assign(V_N1FPLT,  fieldValue)
                                  @Decat_Field("@@tplt")  @dtw_assign(V_N1TPLT,  fieldValue)
                                  @Decat_Field("@@aplt")  @dtw_assign(V_N1APLT,  fieldValue)
                                  @Decat_Field("@@splt")  @dtw_assign(V_N1SPLT,  fieldValue)
                                  @Decat_Field("@@fpgm")  @dtw_assign(V_N1FPROG, fieldValue)
                                  @Decat_Field("@@tpgm")  @dtw_assign(V_N1TPROG, fieldValue)
                                  @Decat_Field("@@apgm")  @dtw_assign(V_N1APROG, fieldValue)
                                  @Decat_Field("@@spgm")  @dtw_assign(V_N1SPROG, fieldValue)
                                  @Decat_Field("@@fdat")  @dtw_assign(V_N1FDATE, fieldValue)
                                  @Decat_Field("@@tdat")  @dtw_assign(V_N1TDATE, fieldValue)
                                  @Decat_Field("@@adat")  @dtw_assign(V_N1ADATE, fieldValue)
                                  @Decat_Field("@@fusr")  @dtw_assign(V_N1FUSER, fieldValue)
                                  @Decat_Field("@@tusr")  @dtw_assign(V_N1TUSER, fieldValue)
                                  @Decat_Field("@@ausr")  @dtw_assign(V_N1AUSER, fieldValue)
                                  @Decat_Field("@@susr")  @dtw_assign(V_N1SUSER, fieldValue)
                                  @Decat_Field("@@fws@")  @dtw_assign(V_N1FWSID, fieldValue)
                                  @Decat_Field("@@tws@")  @dtw_assign(V_N1TWSID, fieldValue)
                                  @Decat_Field("@@aws@")  @dtw_assign(V_N1AWSID, fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1PRNT == "01")
                                      @dtw_assign(no, "CHECKED")
                                      @dtw_assign(yes, "")
                                  %elif (V_N1PRNT == "02")
                                      @dtw_assign(no, "")
                                      @dtw_assign(yes, "CHECKED")
                                  %endif

                                  %if (V_N1APLT == "ALL")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPlantNumber, "")
                                  %endif
                                  %if (V_N1APROG == "ALL")
                                      @dtw_assign(checkedallProgramName, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallProgramName, "")
                                  %endif
                                  %if (V_N1ADATE == "ALL")
                                      @dtw_assign(checkedallTransactionDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallTransactionDate, "")
                                  %endif
                                  %if (V_N1AUSER == "ALL")
                                      @dtw_assign(checkedallUserIdentification, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallUserIdentification, "")
                                  %endif
                                  %if (V_N1AWSID == "ALL")
                                      @dtw_assign(checkedallWorkStation, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallWorkStation, "")
                                  %endif
                              %else
                                  @dtw_assign(no, "CHECKED")
                                  @dtw_assign(yes, "")
                                  @RtvDftPlant(plantNumber, plantName)
                                  %if (plantNumber == "0")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(V_N1FPLT, plantNumber)
                                      @dtw_assign(V_N1TPLT, plantNumber)
                                      @dtw_assign(checkedallPlantNumber, "")
                                      @dtw_assign(focusField, "fromItemNumber")
                                  %endif
                                  @dtw_assign(checkedallProgramName, "CHECKED")
                                  @dtw_assign(checkedallTransactionDate, "CHECKED")
                                  @dtw_assign(checkedallUserIdentification, "CHECKED")
                                  @dtw_assign(checkedallWorkStation, "CHECKED")
                              %endif

                              <tr><td class="dsphdr"><span $(textOvr)>Print Transactions Previously Printed</span></td>
                                  <td class="inputnmbr"><input name="printPreviouslyPrinted" type="radio" VALUE='01' $(no)>No</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="printPreviouslyPrinted" type="radio" VALUE='02' $(yes)>Yes</td>
                              </tr>

                          </table>

                          <table $(contentTable)>

                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                              </tr>

                              @SetTextOvr(Err_N1FPLT)
                              %if (textOvr == "") @SetTextOvr(Err_N1SPLT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                  <td class="inputnmbr"><input name="fromPlantNumber" value="$(V_N1FPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromPlantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName"  type="hidden"></td>
                                  <td class="inputnmbr"><input name="toPlantNumber" value="$(V_N1TPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toPlantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)">  $(searchImage) </a><input name="plantName"  type="hidden"></td>
                                  <td class="inputalph"><input name="allPlantNumber" value='ALL' $(checkedallPlantNumber) type="checkbox" onClick="if (this.checked) this.form.fromPlantNumber.value='', this.form.toPlantNumber.value='';"></td>
                                  <td class="colcode"><input &name="sortPlantNumber" type="hidden"  Value="$(sortPlantNumber)" size="1" maxlength="1">$(sortPlantNumber)</td>
                              </tr>
                              @DspErrMsg(Err_N1FPLT)
                              @DspErrMsg(Err_N1SPLT)

                              @SetTextOvr(Err_N1FPROG)
                              %if (textOvr == "") @SetTextOvr(Err_N1SPROG) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Program Name</span></td>
                                  <td class="inputalph"><input name="fromProgramName" value="$(V_N1FPROG)" type="text" size="6" maxlength="6"></td>
                                  <td class="inputalph"><input name="toProgramName" value="$(V_N1TPROG)" type="text" size="6" maxlength="6"></td>
                                  <td class="inputalph"><input name="allProgramName" value='ALL' $(checkedallProgramName) type="checkbox" onClick="if (this.checked) this.form.fromProgramName.value='', this.form.toProgramName.value='';"></td>
                                  @Build_Sort_Select("sortProgramName", "$(V_N1SPROG)")
                              </tr>
                              @DspErrMsg(Err_N1SPROG)

                              <tr><td class="dsphdr">Transaction Date</td>
                                  <td class="inputnmbr"><input name="fromTransactionDate" value="$(V_N1FDATE)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromTransactionDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toTransactionDate" value="$(V_N1TDATE)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toTransactionDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allTransactionDate" value='ALL' $(checkedallTransactionDate) type="checkbox" onClick="if (this.checked) this.form.fromTransactionDate.value='', this.form.toTransactionDate.value='';"></td>
                              </tr>

                              @SetTextOvr(Err_N1FUSER)
                              %if (textOvr == "") @SetTextOvr(Err_N1SUSER) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>User Identification</span></td>
                                  <td class="inputalph"><input name="fromUserIdentification" value="$(V_N1FUSER)" type="text" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input name="toUserIdentification" value="$(V_N1TUSER)" type="text" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input name="allUserIdentification" value='ALL' $(checkedallUserIdentification) type="checkbox" onClick="if (this.checked) this.form.fromUserIdentification.value='', this.form.toUserIdentification.value='';"></td>
                                  @Build_Sort_Select("sortUserIdentification", "$(V_N1SUSER)")
                              </tr>
                              @DspErrMsg(Err_N1SUSER)

                              <tr><td class="dsphdr">Work Station</td>
                                  <td class="inputalph"><input name="fromWorkStation" value="$(V_N1FWSID)" type="text" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input name="toWorkStation" value="$(V_N1TWSID)" type="text" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input name="allWorkStation" value='ALL' $(checkedallWorkStation) type="checkbox" onClick="if (this.checked) this.form.fromWorkStation.value='', this.form.toWorkStation.value='';"></td>
                              </tr>

                          </table>

                          @dtw_assign(envProgram, "HPD121")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HPDSEL_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allPlantNumber)
  @dtw_mUPPERCASE(fromProgramName)
  @dtw_mUPPERCASE(toProgramName)
  @dtw_mUPPERCASE(allProgramName)
  @dtw_mUPPERCASE(allTransactionDate)
  @dtw_mUPPERCASE(fromUserIdentification)
  @dtw_mUPPERCASE(toUserIdentification)
  @dtw_mUPPERCASE(allUserIdentification)
  @dtw_mUPPERCASE(fromWorkStation)
  @dtw_mUPPERCASE(toWorkStation)
  @dtw_mUPPERCASE(allWorkStation)

  @dtw_assign(fromPlantNumber,@dtw_rstrip(fromPlantNumber))
  @dtw_assign(toPlantNumber,@dtw_rstrip(toPlantNumber))
  @dtw_assign(sortPlantNumber,@dtw_rstrip(sortPlantNumber))
  @dtw_assign(sortProgramName,@dtw_rstrip(sortProgramName))
  @dtw_assign(sortUserIdentification,@dtw_rstrip(sortUserIdentification))

  %if (allPlantNumber != "ALL")
      @dtw_assign(allPlantNumber, "")
  %endif
  %if (allProgramName != "ALL")
      @dtw_assign(allProgramName, "")
  %endif
  %if (allTransactionDate != "ALL")
      @dtw_assign(allTransactionDate, "")
  %endif
  %if (allUserIdentification != "ALL")
      @dtw_assign(allUserIdentification, "")
  %endif
  %if (allWorkStation != "ALL")
      @dtw_assign(allWorkStation, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@prnt", printPreviouslyPrinted)
  @Concat_Field("@@fplt", fromPlantNumber)
  @Concat_Field("@@tplt", toPlantNumber)
  @Concat_Field("@@aplt", allPlantNumber)
  @Concat_Field("@@splt", sortPlantNumber)
  @Concat_Field("@@fpgm", fromProgramName)
  @Concat_Field("@@tpgm", toProgramName)
  @Concat_Field("@@apgm", allProgramName)
  @Concat_Field("@@spgm", sortProgramName)
  @Concat_Field("@@fdat", fromTransactionDate)
  @Concat_Field("@@tdat", toTransactionDate)
  @Concat_Field("@@adat", allTransactionDate)
  @Concat_Field("@@fusr", fromUserIdentification)
  @Concat_Field("@@tusr", toUserIdentification)
  @Concat_Field("@@ausr", allUserIdentification)
  @Concat_Field("@@susr", sortUserIdentification)
  @Concat_Field("@@fws@", fromWorkStation)
  @Concat_Field("@@tws@", toWorkStation)
  @Concat_Field("@@aws@", allWorkStation)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}