                              %elif (fieldName == "@@DHSVSV ")
                                  @OrderBy_Sort("DHSVSV", sortVar)
                	           <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ShipViaCode" title="Sequence By Ship Via Code">Ship Via <br> Code</a></th>
                                  <th class="colhdr">Description</th>
                              %elif (fieldName == "@@DHSVDS ")
                                  @OrderBy_Sort("DHSVDS", sortVar)
                	           <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ShipViaDesc" title="Sequence By Ship Via Description">Ship Via <br> Description</a></th>
                              %elif (fieldName == "@@HHORTY ")
                                  @OrderBy_Sort("HHORTY", sortVar)
                	           <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=OrderType" title="Sequence By Order Type">Order<br>Type</a></th>
                                  <th class="colhdr">Description</th>
                              %elif (fieldName == "@@CMUDF1 ")
                                  @OrderBy_Sort("CMUDF1", sortVar)
                	           <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CustUDA1" title="Sequence By $(V_CRSCR1)">$(V_CRSCR1)</a></th>
                              %elif (fieldName == "@@CMUDF2 ")
                                  @OrderBy_Sort("CMUDF2", sortVar)
                	           <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CustUDA2" title="Sequence By $(V_CRSCR2)">$(V_CRSCR2)</a></th>
                              %elif (fieldName == "@@CMUDF3 ")
                                  @OrderBy_Sort("CMUDF3", sortVar)
                	           <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CustUDA3" title="Sequence By $(V_CRSCR3)">$(V_CRSCR3)</a></th>
                              %elif (fieldName == "@@CMUDF4 ")
                                  @OrderBy_Sort("CMUDF4", sortVar)
                	           <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CustUDA4" title="Sequence By $(V_CRSCR4)">$(V_CRSCR4)</a></th>
                              %elif (fieldName == "@@CMUDF5 ")
                                  @OrderBy_Sort("CMUDF5", sortVar)
                	           <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CustUDA5" title="Sequence By $(V_CRSCR5)">$(V_CRSCR5)</a></th>
                              %elif (fieldName == "@@IMUDA1 ")
                                  @OrderBy_Sort("IMUDA1", sortVar)
                	           <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ItemUDA1" title="Sequence By $(V_CIIAS1)">$(V_CIIAS1)</a></th>
                              %elif (fieldName == "@@IMUDA2 ")
                                  @OrderBy_Sort("IMUDA2", sortVar)
                	           <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ItemUDA2" title="Sequence By $(V_CIIAS2)">$(V_CIIAS2)</a></th>
                              %elif (fieldName == "@@IMUDA3 ")
                                  @OrderBy_Sort("IMUDA3", sortVar)
                	           <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ItemUDA3" title="Sequence By $(V_CIIAS3)">$(V_CIIAS3)</a></th>
                              %elif (fieldName == "@@IMUDA4 ")
                                  @OrderBy_Sort("IMUDA4", sortVar)
                	           <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ItemUDA4" title="Sequence By $(V_CIIAS4)">$(V_CIIAS4)</a></th>
                              %elif (fieldName == "@@IMUDA5 ")
                                  @OrderBy_Sort("IMUDA5", sortVar)
                	           <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ItemUDA5" title="Sequence By $(V_CIIAS5)">$(V_CIIAS5)</a></th>
                              %elif (fieldName == "@@IMUDN1 ")
                                  @OrderBy_Sort("IMUDN1", sortVar)
                	           <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ItemUDN1" title="Sequence By $(V_CIINS1)">$(V_CIINS1)</a></th>
                              %elif (fieldName == "@@IMUDN2 ")
                                  @OrderBy_Sort("IMUDN2", sortVar)
                	           <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ItemUDN2" title="Sequence By $(V_CIINS2)">$(V_CIINS2)</a></th>
                              %elif (fieldName == "@@IMUDN3 ")
                                  @OrderBy_Sort("IMUDN3", sortVar)
                	           <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ItemUDN3" title="Sequence By $(V_CIINS3)">$(V_CIINS3)</a></th>
                              %elif (fieldName == "@@IMUDN4 ")
                                  @OrderBy_Sort("IMUDN4", sortVar)
                	           <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ItemUDN4" title="Sequence By $(V_CIINS4)">$(V_CIINS4)</a></th>
                              %elif (fieldName == "@@IMUDN5 ")
                                  @OrderBy_Sort("IMUDN5", sortVar)
                	           <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ItemUDN5" title="Sequence By $(V_CIINS5)">$(V_CIINS5)</a></th>
                              %endif
                          %endif
                          @dtw_add(wrkCnt, "1", wrkCnt)
                          @dtw_add(x, "9", x)
                      %}

                      %if(totalByQty == "Y")
                          @OrderBy_Sort("SUMQTY", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TotalQty" title="Sequence By Quantity">Quantity</a></th>
                          <th class="colhdr">Percent<br>Of Total</th>
                      %endif
                      %if(totalByAmt == "Y")
                          @OrderBy_Sort("SUMAMT", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TotalAmt" title="Sequence By Amount">Amount</a></th>
                          <th class="colhdr">Percent<br>Of Total</th>
                      %endif
                      %if(totalByAmt == "Y" && displayMargin == "Y")
                          @OrderBy_Sort("SUMCST", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Cost" title="Sequence By Cost">Cost</a></th>

                          @OrderBy_Sort("MARGINAMT", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MarginAmt" title="Sequence By Margin Amount">Margin<br>Amount</a></th>

                          @OrderBy_Sort("MARGINPCT", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MarginPct" title="Sequence By Margin Percent">Margin<br>Percent</a></th>
                      %endif
                      %if(totalByCnt == "Y")
                          @OrderBy_Sort("SUMCNT", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TotalCnt" title="Sequence By Count">Count</a></th>
                      %endif
                  </tr>
              %endif

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y")
                      %if (grpFldLvl == groupCnt)
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)salesinqdisplay.d2w/PROCESS$(genericVarBase)&amp;downloadProfileHandle=@dtw_rurlescseq(downloadProfileHandle)&amp;allUsers=@dtw_rurlescseq(allUsers)&amp;selectSequence=@dtw_rurlescseq(selectSequence)&amp;userSQL=@dtw_rurlescseq(userSQL)&amp;selectGroup=@dtw_rurlescseq(selectGroup)&amp;selectGroupBy=@dtw_rurlescseq(selectGroupBy)&amp;grpFldTyp=@dtw_rurlescseq(grpFldTyp)&amp;grpFldHdr=@dtw_rurlescseq(grpFldHdr)&amp;grpFldVal=@dtw_rurlescseq(grpFldVal)&amp;grpFldDsc=@dtw_rurlescseq(grpFldDsc)&amp;grpFldLvl=@dtw_rurlescseq(@dtw_radd(grpFldLvl, "1"))&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))" title="View Detail">$(selectImage)</a></td>
                      %else
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/PROCESS$(d2wVarBase)&amp;selectGroup=@dtw_rurlescseq(selectGroup)&amp;selectGroupBy=@dtw_rurlescseq(selectGroupBy)&amp;grpFldTyp=@dtw_rurlescseq(grpFldTyp)&amp;grpFldHdr=@dtw_rurlescseq(grpFldHdr)&amp;grpFldVal=@dtw_rurlescseq(grpFldVal)&amp;grpFldDsc=@dtw_rurlescseq(grpFldDsc)&amp;grpFldLvl=@dtw_rurlescseq(@dtw_radd(grpFldLvl, "1"))&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))" title="View Detail">$(selectImage)</a></td>
                      %endif
                  %endif

                  @dtw_assign(colCnt, "1")
                  @dtw_assign(wrkCnt, "1")
                  @dtw_assign(x, "1")
                  %while(x <= "500" && @dtw_rsubstr(selectGroupBy, x) != "" && wrkCnt <= grpFldLvl){
                      @dtw_substr(selectGroupBy, x, "9", " ", fieldName)

                      %if (wrkCnt == grpFldLvl)
                          %if (fieldName == "@@DHBLTO ")
                              <td class="colnmbr">$(V_DHBLTO)</td>
                              <td class="colalph">$(grpFldDsc)</td>
                              @dtw_assign(colCnt, "2")
                          %elif (fieldName == "@@DHSHTO ")
                              <td class="colnmbr">$(V_DHSHTO)</td>
                              <td class="colalph">$(grpFldDsc)</td>
                              @dtw_assign(colCnt, "2")
                          %elif (fieldName == "@@CMCNA1U")
         	                   <td class="colalph">$(V_CMCNA1U)</td>
                          %elif (fieldName == "@@CMCNA2U")
         	                   <td class="colalph">$(V_CMCNA2U)</td>
                          %elif (fieldName == "@@CMCNA3U")
         	                   <td class="colalph">$(V_CMCNA3U)</td>
                          %elif (fieldName == "@@CMCNA4U")
         	                   <td class="colalph">$(V_CMCNA4U)</td>
                          %elif (fieldName == "@@CMCCTYU")
         	                   <td class="colalph">$(V_CMCCTYU)</td>
                          %elif (fieldName == "@@CMST   ")
         	                   <td class="colalph">$(V_CMST)</td>
                              <td class="colalph">$(grpFldDsc)</td>
                              @dtw_assign(colCnt, "2")
                          %elif (fieldName == "@@CMZIP  ")
         	                   <td class="colalph">$(V_CMZIP)</td>
                          %elif (fieldName == "@@DHORD# ")
         		              <td class="colnmbr">$(V_DHORD#)</a></td>
                          %elif (fieldName == "@@DHITEM ")
         	                   <td class="colalph"> $(V_DHITEM)</td>
                              <td class="colalph">$(grpFldDsc)</td>
                              @dtw_assign(colCnt, "2")
                          %elif (fieldName == "@@DHIMDS ")
         	                   <td class="colalph">$(V_DHIMDS)</td>
                          %elif (fieldName == "@@DHDTLI ")
                              @Format_Date(V_DHDTLI, "D", F_DHDTLI)
                              <td class="coldate">$(F_DHDTLI)</td>
                          %elif (fieldName == "@@@@LIYR ")
                              <td class="colnmbr">$(V_LIYEAR)</td>
                          %elif (fieldName == "@@@@LIQT ")
                              <td class="colnmbr">$(V_LIQTR)</td>
                          %elif (fieldName == "@@@@LIMO ")
                              <td class="colnmbr">$(V_LIMNTH)</td>
                          %elif (fieldName == "@@@@LIWK ")
                              <td class="colnmbr">$(V_LIWEEK)</td>
                          %elif (fieldName == "@@DHPCLS ")
                              <td class="colcode">$(V_DHPCLS)</td>
                              <td class="colalph">$(grpFldDsc)</td>
                              @dtw_assign(colCnt, "2")
                          %elif (fieldName == "@@DHPGRP ")
                              <td class="colcode">$(V_DHPGRP)</td>
                              <td class="colalph">$(grpFldDsc)</td>
                              @dtw_assign(colCnt, "2")
                          %elif (fieldName == "@@IMITC  ")
                              <td class="colcode">$(V_IMITC)</td>
                              <td class="colalph">$(grpFldDsc)</td>
                              @dtw_assign(colCnt, "2")
                          %elif (fieldName == "@@HHDOTS ")
                              @Format_Date(V_HHDOTS, "D", F_HHDOTS)
                              <td class="coldate">$(F_HHDOTS)</td>
                          %elif (fieldName == "@@@@SDYR ")
                              <td class="colnmbr">$(V_SDYEAR)</td>
                          %elif (fieldName == "@@@@SDQT ")
                              <td class="colnmbr">$(V_SDQTR)</td>
                          %elif (fieldName == "@@@@SDMO ")
                              <td class="colnmbr">$(V_SDMNTH)</td>
                          %elif (fieldName == "@@@@SDWK ")
                              <td class="colnmbr">$(V_SDWEEK)</td>
                          %elif (fieldName == "@@DHSLPR ")
                              @Format_Nbr($(V_DHSLPR), F_DHSLPR, $(prcNbrDec), $(amtEditCode), "", "", "")
                              <td class="colnmbr">$(F_DHSLPR)</td>
                          %elif (fieldName == "@@DHQSTC ")
                              @Format_Nbr($(V_DHQSTC), F_DHQSTC, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                              <td class="colnmbr">$(F_DHQSTC)</td>
                          %elif (fieldName == "@@HHSLSM ")
                              <td class="colnmbr">$(V_HHSLSM)</td>
                              <td class="colalph">$(grpFldDsc)</td>
                              @dtw_assign(colCnt, "2")
                          %elif (fieldName == "@@CMCCLS ")
                              <td class="colalph">$(V_CMCCLS)</td>
                              <td class="colalph">$(grpFldDsc)</td>
                              @dtw_assign(colCnt, "2")
                          %elif (fieldName == "@@CMCRGN ")
                              <td class="colalph">$(V_CMCRGN)</td>
                              <td class="colalph">$(grpFldDsc)</td>
                              @dtw_assign(colCnt, "2")
                          %elif (fieldName == "@@DHLOC# ")
                              <td class="colnmbr">$(V_DHLOC#)</td>
                              <td class="colalph">$(grpFldDsc)</td>
                              @dtw_assign(colCnt, "2")
                          %elif (fieldName == "@@DHWH   ")
                              <td class="colnmbr">$(V_DHWH)</td>
                              <td class="colalph">$(grpFldDsc)</td>
                              @dtw_assign(colCnt, "2")
                          %elif (fieldName == "@@DHSVSV ")
                              <td class="colcode">$(V_DHSVSV)</td>
                              <td class="colalph">$(grpFldDsc)</td>
                              @dtw_assign(colCnt, "2")
                          %elif (fieldName == "@@DHSVDS ")
                              <td class="colalph">$(V_DHSVDS)</td>
                          %elif (fieldName == "@@HHORTY ")
                              <td class="colcode">$(V_HHORTY)</td>
                              <td class="colalph">$(grpFldDsc)</td>
                              @dtw_assign(colCnt, "2")
                          %elif (fieldName == "@@CMUDF1 ")
                              <td class="colalph">$(V_CMUDF1)</td>
                          %elif (fieldName == "@@CMUDF2 ")
                              <td class="colalph">$(V_CMUDF2)</td>
                          %elif (fieldName == "@@CMUDF3 ")
                              <td class="colalph">$(V_CMUDF3)</td>
                          %elif (fieldName == "@@CMUDF4 ")
                              <td class="colalph">$(V_CMUDF4)</td>
                          %elif (fieldName == "@@CMUDF5 ")
                              <td class="colalph">$(V_CMUDF5)</td>
                          %elif (fieldName == "@@IMUDA1 ")
                              <td class="colalph">$(V_IMUDA1)</td>
                          %elif (fieldName == "@@IMUDA2 ")
                              <td class="colalph">$(V_IMUDA2)</td>
                          %elif (fieldName == "@@IMUDA3 ")
                              <td class="colalph">$(V_IMUDA3)</td>
                          %elif (fieldName == "@@IMUDA4 ")
                              <td class="colalph">$(V_IMUDA4)</td>
                          %elif (fieldName == "@@IMUDA5 ")
                              <td class="colalph">$(V_IMUDA5)</td>
                          %elif (fieldName == "@@IMUDN1 ")
                              <td class="colnmbr">$(V_IMUDN1)</td>
                          %elif (fieldName == "@@IMUDN2 ")
                              <td class="colnmbr">$(V_IMUDN2)</td>
                          %elif (fieldName == "@@IMUDN3 ")
                              <td class="colnmbr">$(V_IMUDN3)</td>
                          %elif (fieldName == "@@IMUDN4 ")
                              <td class="colnmbr">$(V_IMUDN4)</td>
                          %elif (fieldName == "@@IMUDN5 ")
                              <td class="colnmbr">$(V_IMUDN5)</td>
                          %endif
                      %endif
                      @dtw_add(wrkCnt, "1", wrkCnt)
                      @dtw_add(x, "9", x)
                  %}

                  %if(totalByQty == "Y")
                      @Format_Nbr($(V_SUMQTY), F_SUMQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                      @Format_Nbr("@dtw_rmultiply(@dtw_rdivide(V_SUMQTY, V_TOTQTY), "100")", qtyPercent, "4", $(pctEditCode), "Y", "", "")
                      <td class="colnmbr">$(F_SUMQTY)</td>
                      <td class="colnmbr">$(qtyPercent)</td>
                  %endif
                  %if(totalByAmt == "Y")
                      @Format_Nbr($(V_SUMAMT), F_SUMAMT, "2", $(amtEditCode), "", "", "")
                      @Format_Nbr("@dtw_rmultiply(@dtw_rdivide(V_SUMAMT, V_TOTAMT), "100")", amtPercent, "4", $(pctEditCode), "Y", "", "")
                      <td class="colnmbr">$(F_SUMAMT)</td>
                      <td class="colnmbr">$(amtPercent)</td>
                  %endif
                  %if(totalByAmt == "Y" && displayMargin == "Y")
                      @Format_Nbr($(V_SUMCST), F_SUMCST, $(cstNbrDec), $(cstEditCode), "", "", "")
                      <td class="colnmbr">$(F_SUMCST)</td>

                      @Format_Nbr($(V_MARGINAMT), F_MARGINAMT, $(amtNbrDec), $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_MARGINAMT)</td>

                      @Format_Nbr($(V_MARGINPCT), F_MARGINPCT, $(pctNbrDec), $(pctEditCode), "", "", "")
                      <td class="colnmbr">$(F_MARGINPCT)</td>
                  %endif
                  %if(totalByCnt == "Y")
                      @Format_Nbr($(V_SUMCNT), F_SUMCNT, "0", "1", "", "", "")
                      <td class="colnmbr">$(F_SUMCNT)</td>
                  %endif
              </tr>
          %}
              <tr>
                  %if(totalByQty == "Y" || totalByAmt == "Y" || totalByCnt == "Y")
                      %if (formatToPrint != "Y")
                          @dtw_assign(colCnt, @dtw_radd(colCnt, "1"))
                      %endif
                      <td colspan="$(colCnt)">&nbsp;</td>
                  %endif
                  %if(totalByQty == "Y")
                      @Format_Nbr($(TOTQTY), F_TOTQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                      <td class="coltotal">$(F_TOTQTY)</td>
                      <td>&nbsp;</td>
                  %endif
                  %if(totalByAmt == "Y")
                      @Format_Nbr($(TOTAMT), F_TOTAMT, "2", $(amtEditCode), "", "", "")
                      <td class="coltotal">$(F_TOTAMT)</td>
                      <td>&nbsp;</td>

                      %if(displayMargin == "Y")
                          @Format_Nbr($(TOTCST), F_TOTCST, $(cstNbrDec), $(cstEditCode), "", "", "")
                          <td class="coltotal">$(F_TOTCST)</td>
                          @Format_Nbr($(TOTMAMT), F_TOTMAMT, $(amtNbrDec), $(amtEditCode), "", "", "")
                          <td class="coltotal">$(F_TOTMAMT)</td>
                          @Format_Nbr($(TOTMPCT), F_TOTMPCT, $(pctNbrDec), $(pctEditCode), "", "", "")
                          <td class="coltotal">$(F_TOTMPCT)</td>
                      %endif
                  %endif
                  %if(totalByCnt == "Y")
                      @Format_Nbr($(TOTCNT), F_TOTCNT, "0", "1", "", "", "")
                      <td class="coltotal">$(F_TOTCNT)</td>
                  %else
                      <td>&nbsp;</td>
                  %endif
              </tr>
      </table>
      %if (TOTAL_ROWS > "0")
          %INCLUDE "PageBottom.icl"
          $(hrTagAttr)
          %INCLUDE "Copyright.icl"
      %endif
  %}
%}

%FUNCTION(dtw_directcall) Retrieve_User_Selection(INOUT CHAR(64) profileHandle,
                                                  INOUT CHAR(2)  dataBaseID,
                                                  INOUT CHAR(1)  maintCode,
                                                  INOUT CHAR(10) userProfile,
                                                  INOUT CHAR(10) selectName,
                                                  INOUT DEC(5,0) selectSequence,
                                                  INOUT CHAR(50) selectDesc,
                                                  INOUT CHAR(10) selectTotals,
                                                  INOUT CHAR(500) selectGroupBy,
                                                  INOUT CHAR(3000) selectCriteria)
{%EXEC {HSYUSL_W.PGM %}
%}

%FUNCTION(dtw_directcall) Retrieve_Group_Desc(IN    CHAR(64) profileHandle,
                                                    CHAR(2)  dataBaseID,
                                                    DEC(5,0) selectSequence,
                                                    DEC(3,0) grpFldLvl,
                                                    CHAR(10) grpFldTyp,
                                                    CHAR(50) grpFldHdr,
                                                    CHAR(50) grpFldVal,
                                                    CHAR(50) grpFldDsc,
                                                    CHAR(50) selectGroup,
                                              INOUT CHAR(500) selectGroupSQL)
{%EXEC {HSYUSG_W.PGM %}
%}

%HTML(PROCESS) {
  %INCLUDE "setLibraryList.icl"
  %if (downloadProfileHandle == "")
      @dtw_assign(downloadProfileHandle, profileHandle)
  %else
      @dtw_assign(profileHandle, downloadProfileHandle)
  %endif

  %if (grpFldTyp != "")
      @Retrieve_Group_Desc(profileHandle, dataBaseID, selectSequence, grpFldLvl, grpFldTyp, grpFldHdr, grpFldVal, grpFldDsc, selectGroup, selectGroupSQL)
      %if (grpFldTyp == "goToLevel")
          @dtw_assign(grpFldLvl, @dtw_rsubtract(grpFldLvl, "1"))
      %endif
  %else
      @dtw_assign(selectGroupSQL, "")
  %endif

  @dtw_assign(maintCode, "R")
  @Retrieve_User_Selection(profileHandle, dataBaseID, maintCode, userProfile, selectName, selectSequence, selectDesc, selectTotals, selectGroupBy, selectCriteria)

  @dtw_assign(groupCnt, "0")
  @dtw_assign(x, "1")
  %while(x <= "500" && @dtw_rsubstr(selectGroupBy, x, "2") == "@@")
      {@dtw_add(groupCnt, "1", groupCnt)@dtw_add(x, "9", x)%}

  @dtw_assign(totalByAmt, "")
  @dtw_assign(totalByQty, "")
  @dtw_assign(totalByCnt, "")
  %if (@dtw_rsubstr(selectTotals, "1", "1") == "Y")
       @dtw_assign(totalByQty, "Y")
  %endif
  %if (@dtw_rsubstr(selectTotals, "2", "1") == "Y")
       @dtw_assign(totalByAmt, "Y")
  %endif
  %if (@dtw_rsubstr(selectTotals, "3", "1") == "Y")
       @dtw_assign(totalByCnt, "Y")
  %endif

  @dtw_assign(selectRecSQL, "WHERE DHSEQ# >0 ")
  @dtw_assign(selectGroupWork, "")
  @dtw_assign(groupBy, "")
  @Build_SQL("DHITEM", "A")
  @Build_SQL("DHIMDS", "A")
  @Build_SQL("DHBLTO", "N")
  @Build_SQL("DHSHTO", "N")
  @Build_SQL("CMCNA1U", "A")
  @Build_SQL("CMCNA2U", "A")
  @Build_SQL("CMCNA3U", "A")
  @Build_SQL("CMCNA4U", "A")
  @Build_SQL("CMCCTYU", "A")
  @Build_SQL("CMST", "A")
  @Build_SQL("CMZIP", "A")
  @Build_SQL("DHDTLI", "D")
  @Build_SQL("@@LIYR", "N")
  @Build_SQL("@@LIQT", "N")
  @Build_SQL("@@LIMO", "N")
  @Build_SQL("@@LIWK", "N")
  @Build_SQL("DHPCLS", "A")
  @Build_SQL("DHPGRP", "A")
  @Build_SQL("IMITC", "A")
  @Build_SQL("HHDOTS", "D")
  @Build_SQL("@@SDYR", "N")
  @Build_SQL("@@SDQT", "N")
  @Build_SQL("@@SDMO", "N")
  @Build_SQL("@@SDWK", "N")
  @Build_SQL("DHSLPR", "N")
  @Build_SQL("DHQSTC", "N")
  @Build_SQL("HHSLSM", "N")
  @Build_SQL("CMCCLS", "A")
  @Build_SQL("CMCRGN", "A")
  @Build_SQL("DHLOC#", "N")
  @Build_SQL("DHWH", "N")
  @Build_SQL("DHSVSV", "A")
  @Build_SQL("DHSVDS", "A")
  @Build_SQL("HHORTY", "A")
  @Build_SQL("CMUDF1", "A")
  @Build_SQL("CMUDF2", "A")
  @Build_SQL("CMUDF3", "A")
  @Build_SQL("CMUDF4", "A")
  @Build_SQL("CMUDF5", "A")
  @Build_SQL("IMUDA1", "A")
  @Build_SQL("IMUDA2", "A")
  @Build_SQL("IMUDA3", "A")
  @Build_SQL("IMUDA4", "A")
  @Build_SQL("IMUDA5", "A")
  @Build_SQL("IMUDN1", "N")
  @Build_SQL("IMUDN2", "N")
  @Build_SQL("IMUDN3", "N")
  @Build_SQL("IMUDN4", "N")
  @Build_SQL("IMUDN5", "N")

  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      @dtw_pos(",", groupBy, "1", commaPos)
      %if (commaPos == "0")
          @DTW_ASSIGN(orderBy, groupBy)
      %else
          %while(commaPos != "0"){
              @dtw_assign(lastComma, commaPos)
              @dtw_pos(",", groupBy, @dtw_radd(lastComma, "1"), commaPos)
          %}
          @dtw_assign(orderBy, @dtw_rsubstr(groupBy, @dtw_radd(lastComma, "2")))
      %endif

      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
	
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

