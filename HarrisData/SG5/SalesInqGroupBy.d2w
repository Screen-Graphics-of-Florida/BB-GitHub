%}

%INCLUDE "$(baseVar)"
%INCLUDE "ARControl$(dataBaseID).icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Sales Inquiry"
  d2wName                 = "SalesInqGroupBy.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;allUsers=@dtw_rurlescseq(allUsers)&amp;selectSequence=@dtw_rurlescseq(selectSequence)&amp;userSQL=@dtw_rurlescseq(userSQL)&amp;selectRecSQL=@dtw_rurlescseq(selectRecSQL)&amp;selectGroupWork=@dtw_rurlescseq(selectGroupWork)&amp;selectGroupBy=@dtw_rurlescseq(selectGroupBy)&amp;selectGroupSQL=@dtw_rurlescseq(selectGroupSQL)&amp;groupBy=@dtw_rurlescseq(groupBy)&amp;groupCnt=@dtw_rurlescseq(groupCnt)&amp;selectDesc=@dtw_rurlescseq(selectDesc)&amp;totalByQty=@dtw_rurlescseq(totalByQty)&amp;totalByAmt=@dtw_rurlescseq(totalByAmt)&amp;totalByCnt=@dtw_rurlescseq(totalByCnt)&amp;downloadProfileHandle=@dtw_rurlescseq(downloadProfileHandle)"
  nextPrevVar             = "$(d2wVarBase)&amp;selectGroup=@dtw_rurlescseq(selectGroupSave)&amp;grpFldLvl=@dtw_rurlescseq(grpFldLvl)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_SET_TOTAL_ROWS      = "YES"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  DTW_PAD_PGM_PARMS       = "YES"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  selectName              = "SALESINQ"
  selectGroupSQL          = ""
  totalByQty              = ""
  totalByAmt              = ""
  totalByCnt              = ""
  groupCnt                = ""
%}

%INCLUDE "opersel_bldSQL.icl"

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
	          %INCLUDE "numedit.icl"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "SALESINQ")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      @dtw_assign(uv_BillingLocationName, "HHLOC#")
                      @dtw_assign(uv_SalesmanName, "HHSLSM")
                      @dtw_assign(uv_OEOrderTypeName, "HHORTY")
                      @dtw_assign(uv_BankName, "HHBANK")
                      @dtw_assign(uv_ShipToName, "DHSHTO")
                      @dtw_assign(uv_ProductClassName, "DHPCLS")
                      @dtw_assign(uv_ProductGroupName, "DHPGRP")
                      @dtw_assign(uv_ProdInventoryTypeName, "IMITC  ")
                      @dtw_assign(uv_WarehouseName, "DHWH  ")
                      %INCLUDE "userview.icl"

                      @dtw_assign(SAVE_TOTAL_ROWS, TOTAL_ROWS)
                      @dtw_assign(SAVE_START_ROW_NUM, START_ROW_NUM)

                      <table $(contentTable)>
            	           <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1>$(selectDesc)</h1></td>
                              %if (formatToPrint != "Y")
                                  <td class="toolbar">
                                      <a href="$(homeURL)$(cGIPath)SalesInqSelect.d2w/RETRIEVE$(d2wVarBase)">$(previousImage)</a>
                                      %if (userSQL == "")
                                          <a href="$(homeURL)$(cGIPath)salesinqupdate.d2w/DISPLAY$(d2wVarBase)" onclick="$(selectionWinVar)">$(selectAcceptImage)</a>
                                      %endif
                                      <a href="$(homeURL)$(cGIPath)salesinqcriteria.d2w/DISPLAY$(d2wVarBase)" onclick="$(selectionWinVar)">$(selectCriteriaImage)</a>
                                      <a href="$(homeURL)$(cGIPath)$(d2wName)/PROCESS$(d2wVarBase)&amp;grpFldTyp=formatPrt&amp;grpFldLvl=@dtw_rurlescseq(grpFldLvl)&amp;formatToPrint=Y" target=_blank>$(formatPrintMed)</a>
                                      @dtw_assign(medIcon, "Y")
                                      %INCLUDE "HelpPage.icl"
                                  </td>
                              %endif
                          </tr>
                      </table>

                      $(hrTagAttr)

                      @dtw_assign(START_ROW_NUM, "1")
                      %if (selectGroupSQL != "")
                          @dtw_assign(stmtSQL, "")
                          @dtw_concat(stmtSQL, " SELECT * FROM SYUSLG WHERE SGXHND='$(downloadProfileHandle)' and SGSEQ#=$(selectSequence) ", stmtSQL)
                          @dtw_concat(stmtSQL, " ORDER BY SGGBLV ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @GroupBy_Query(profileHandle, dataBaseID, stmtSQL)
                      %endif
                      @dtw_assign(START_ROW_NUM, SAVE_START_ROW_NUM)
                      @dtw_assign(TOTAL_ROWS, SAVE_TOTAL_ROWS)

                      @dtw_replace(selectGroupSQL, "@@LIYR", "year(F_MAKEDATE(DHDTLI))", selectGroupSQL)
                      @dtw_replace(selectGroupSQL, "@@LIQT", "quarter(F_MAKEDATE(DHDTLI))", selectGroupSQL)
                      @dtw_replace(selectGroupSQL, "@@LIMO", "month(F_MAKEDATE(DHDTLI))", selectGroupSQL)
                      @dtw_replace(selectGroupSQL, "@@LIWK", "week(F_MAKEDATE(DHDTLI))", selectGroupSQL)

                      @dtw_replace(selectGroupSQL, "@@SDYR", "year(F_MAKEDATE(HHDOTS))", selectGroupSQL)
                      @dtw_replace(selectGroupSQL, "@@SDQT", "quarter(F_MAKEDATE(HHDOTS))", selectGroupSQL)
                      @dtw_replace(selectGroupSQL, "@@SDMO", "month(F_MAKEDATE(HHDOTS))", selectGroupSQL)
                      @dtw_replace(selectGroupSQL, "@@SDWK", "week(F_MAKEDATE(HHDOTS))", selectGroupSQL)

                      @dtw_assign(stmtSQL, "")
                      @dtw_concat(stmtSQL, "WITH TOTAL(TOTQTY,TOTAMT,TOTCST,TOTMAMT,TOTMPCT,TOTCNT) AS ", stmtSQL)
                      @dtw_concat(stmtSQL, " (SELECT sumqty, sumamt, sumcst, sumamt-sumcst as marginamt, case when sumamt = 0 then 0 else dec(((sumamt-sumcst)/sumamt),15,5)*100 end as marginpct, sumcnt ", stmtSQL)
                      @dtw_concat(stmtSQL, " From Table (SELECT sum(DHQSTC) as sumqty, dec(sum(round((DHQSTC*DHSLPR),2)/DHORUF),15,2) as sumamt, dec(sum(DHQSTC*DHCOST),15,5) as sumcst, count(*) as sumcnt ", stmtSQL)
                      @dtw_concat(stmtSQL, " From HDCUST inner join OEORDH on CMCUST=DHSHTO ", stmtSQL)
                      @dtw_concat(stmtSQL, "             inner join OEORHH on HHORD#=DHORD# and HHSEQ#=DHSEQ#", stmtSQL)
                      @dtw_concat(stmtSQL, "             left  join HDIMST on IMITEM=DHITEM ", stmtSQL)
                      @dtw_concat(stmtSQL, " $(selectRecSQL)", stmtSQL)
                      %if (selectGroupSQL != "")
                          @dtw_concat(stmtSQL, " and ($(selectGroupSQL))", stmtSQL)
                      %endif
                      %if (uv_Sql != "")
                          @dtw_concat(stmtSQL, " and ($(uv_Sql))", stmtSQL)
                      %endif
                      %if (userSQL != "")
                          @dtw_concat(stmtSQL, " and ($(userSQL))", stmtSQL)
                      %endif
                      @dtw_concat(stmtSQL, ") as TempA) ", stmtSQL)

                      @dtw_assign(groupBy1, groupBy)
                      @dtw_replace(groupBy1, "@@LIYR", "year(F_MAKEDATE(DHDTLI)) as LIYEAR", groupBy1)
                      @dtw_replace(groupBy1, "@@LIQT", "quarter(F_MAKEDATE(DHDTLI)) as LIQTR", groupBy1)
                      @dtw_replace(groupBy1, "@@LIMO", "month(F_MAKEDATE(DHDTLI)) as LIMNTH", groupBy1)
                      @dtw_replace(groupBy1, "@@LIWK", "week(F_MAKEDATE(DHDTLI)) as LIWEEK", groupBy1)
                      @dtw_replace(groupBy1, "@@SDYR", "year(F_MAKEDATE(HHDOTS)) as SDYEAR", groupBy1)
                      @dtw_replace(groupBy1, "@@SDQT", "quarter(F_MAKEDATE(HHDOTS)) as SDQTR", groupBy1)
                      @dtw_replace(groupBy1, "@@SDMO", "month(F_MAKEDATE(HHDOTS)) as SDMNTH", groupBy1)
                      @dtw_replace(groupBy1, "@@SDWK", "week(F_MAKEDATE(HHDOTS)) as SDWEEK", groupBy1)

                      @dtw_assign(groupBy2, groupBy)
                      @dtw_replace(groupBy2, "@@LIYR", "year(F_MAKEDATE(DHDTLI))", groupBy2)
                      @dtw_replace(groupBy2, "@@LIQT", "quarter(F_MAKEDATE(DHDTLI))", groupBy2)
                      @dtw_replace(groupBy2, "@@LIMO", "month(F_MAKEDATE(DHDTLI))", groupBy2)
                      @dtw_replace(groupBy2, "@@LIWK", "week(F_MAKEDATE(DHDTLI))", groupBy2)
                      @dtw_replace(groupBy2, "@@SDYR", "year(F_MAKEDATE(HHDOTS))", groupBy2)
                      @dtw_replace(groupBy2, "@@SDQT", "quarter(F_MAKEDATE(HHDOTS))", groupBy2)
                      @dtw_replace(groupBy2, "@@SDMO", "month(F_MAKEDATE(HHDOTS))", groupBy2)
                      @dtw_replace(groupBy2, "@@SDWK", "week(F_MAKEDATE(HHDOTS))", groupBy2)

                      @dtw_replace(groupBy, "@@LIYR", "LIYEAR", groupBy)
                      @dtw_replace(groupBy, "@@LIQT", "LIQTR", groupBy)
                      @dtw_replace(groupBy, "@@LIMO", "LIMNTH", groupBy)
                      @dtw_replace(groupBy, "@@LIWK", "LIWEEK", groupBy)
                      @dtw_replace(groupBy, "@@SDYR", "SDYEAR", groupBy)
                      @dtw_replace(groupBy, "@@SDQT", "SDQTR", groupBy)
                      @dtw_replace(groupBy, "@@SDMO", "SDMNTH", groupBy)
                      @dtw_replace(groupBy, "@@SDWK", "SDWEEK", groupBy)

                      @dtw_replace(orderBy, "@@LIYR", "LIYEAR", orderBy)
                      @dtw_replace(orderBy, "@@LIQT", "LIQTR", orderBy)
                      @dtw_replace(orderBy, "@@LIMO", "LIMNTH", orderBy)
                      @dtw_replace(orderBy, "@@LIWK", "LIWEEK", orderBy)
                      @dtw_replace(orderBy, "@@SDYR", "SDYEAR", orderBy)
                      @dtw_replace(orderBy, "@@SDQT", "SDQTR", orderBy)
                      @dtw_replace(orderBy, "@@SDMO", "SDMNTH", orderBy)
                      @dtw_replace(orderBy, "@@SDWK", "SDWEEK", orderBy)

                      @dtw_concat(stmtSQL, " SELECT $(groupBy), SUMAMT, SUMAMT-SUMCST as MARGINAMT, case when SUMAMT = 0 then 0 else dec(((SUMAMT-SUMCST)/SUMAMT),15,5)*100 end as MARGINPCT, Temp.* ", stmtSQL)
                      @dtw_concat(stmtSQL, " From Table (SELECT $(groupBy1), sum(DHQSTC) as sumqty, dec(sum(round((DHQSTC*DHSLPR),2)/DHORUF),15,2) as sumamt, dec(sum(DHQSTC*DHCOST),15,5) as sumcst, ", stmtSQL)
                      @dtw_concat(stmtSQL, "             count(*) as sumcnt, TOTAL.TOTQTY, TOTAL.TOTAMT, TOTAL.TOTCST, TOTAL.TOTMAMT, TOTAL.TOTMPCT, TOTAL.TOTCNT", stmtSQL)
                      @dtw_concat(stmtSQL, " From HDCUST inner join OEORDH on CMCUST=DHSHTO ", stmtSQL)
                      @dtw_concat(stmtSQL, "             inner join OEORHH on HHORD#=DHORD# and HHSEQ#=DHSEQ#", stmtSQL)
                      @dtw_concat(stmtSQL, "             left  join HDIMST on IMITEM=DHITEM ", stmtSQL)
                      @dtw_concat(stmtSQL, " , TOTAL $(selectRecSQL) ", stmtSQL)
                      %if (selectGroupSQL != "")
                          @dtw_concat(stmtSQL, " and ($(selectGroupSQL))", stmtSQL)
                      %endif
                      %if (uv_Sql != "")
                          @dtw_concat(stmtSQL, " and ($(uv_Sql))", stmtSQL)
                      %endif
                      %if (userSQL != "")
                          @dtw_concat(stmtSQL, " and ($(userSQL))", stmtSQL)
                      %endif
                      @dtw_concat(stmtSQL, " GROUP BY $(groupBy2), TOTAL.TOTQTY, TOTAL.TOTAMT, TOTAL.TOTCST, TOTAL.TOTMAMT, TOTAL.TOTMPCT, TOTAL.TOTCNT) as Temp ", stmtSQL)
                      @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Item_Sales_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) GroupBy_Query (IN CHAR(64)    profileHandle,
				      CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <tr><th class="colhdr">Group By</th>
              <th class="colhdr">Value</th>
              <th class="colhdr">Description</th>
          </tr>
	
          %ROW{
              <tr>
                  %if (formatToPrint != "Y")
                      <td class="dspalph"><a href="$(homeURL)$(cGIPath)$(d2wName)/PROCESS$(d2wVarBase)&amp;selectGroup=@dtw_rurlescseq($(V_SGSQLS))&amp;grpFldTyp=goToLevel&amp;grpFldVal=@dtw_rurlescseq($(V_SGFVAL))&amp;grpFldLvl=@dtw_rurlescseq(@dtw_radd($(V_SGGBLV), "1"))&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">$(V_SGFHDR)</a></td>
                  %else
                      <td class="dspalph">$(V_SGFHDR)</td>
                  %endif
                  <td class="dspcode">$(V_SGFVAL)</td>
                  <td class="dspalph">$(V_SGFDSC)</td>
              </tr>
          %}
      </table>
  %}
%}

%FUNCTION(dtw_sql) Item_Sales_Query (IN  CHAR(64)    profileHandle,
				          CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("SPUSER='$(userProfile)' and SPPGID='SALESINQ'", "SYPGMS", "SPOP01", displayMargin)
      %if (TOTAL_ROWS > RPT_MAX_ROWS)
          @DTW_ASSIGN(totalPages, @DTW_RINTDIV(TOTAL_ROWS, RPT_MAX_ROWS))
	   %if (@DTW_RDIVREM(TOTAL_ROWS, RPT_MAX_ROWS) > "0")
	       @DTW_ADD(totalPages, "1", totalPages)
	   %endif
      %else
           @dtw_assign(totalPages, "1")
      %endif

      @dtw_add(START_ROW_NUM, RPT_MAX_ROWS, rowIndexNext)

      @dtw_assign(page, @dtw_radd(@dtw_rdivide(@dtw_rsubtract(START_ROW_NUM, "1"), RPT_MAX_ROWS), "1"))
      @dtw_add(START_ROW_NUM, RPT_MAX_ROWS, rowIndexNext)
			
      @dtw_assign(firstRecord, "")
      @dtw_assign(selectGroupSave, selectGroup)
      %if (TOTAL_ROWS == "0")
          <table $(contentTable)>
              <tr><td class="confMsg" colspan="10">No Data Found For Selection Criteria</td></tr>
          </table>      	
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
      %endif

      %ROW{
          @dtw_assign(wrkCnt, "1")
          @dtw_assign(selectGroup, selectGroupWork)
          @dtw_assign(x, "1")
          %while(x <= "500" && @dtw_rsubstr(selectGroupBy, x) != "" && wrkCnt <= grpFldLvl){
              @dtw_substr(selectGroupBy, x, "9", " ", fieldName)
              @dtw_add(wrkCnt, "1", wrkCnt)

              @dtw_assign(grpFldHdr, "")
              @dtw_assign(grpFldTyp, "")
              @dtw_assign(grpFldVal, "")
              @dtw_assign(grpFldDsc, "")
              %if (fieldName == "@@DHITEM ")
                  @dtw_replace(selectGroup, "@@DHITEM", "$(V_DHITEM)", "1", "a", selectGroup)
                  @dtw_assign(grpFldTyp, "Alpha")
                  @dtw_assign(grpFldHdr, "Item Number")
                  @dtw_assign(grpFldVal, "$(V_DHITEM)")
                  @RtvFldDesc("IMITEM='$(V_DHITEM)'", "HDIMST", "IMIMDS", itemDescription)
                  %if (itemDescription=="")
                      @dtw_assign(grpFldDsc, "Non-stock item")
                  %else
                      @dtw_assign(grpFldDsc, "$(itemDescription)")
                  %endif
              %elif (fieldName == "@@DHIMDS ")
                  @dtw_replace(selectGroup, "@@DHIMDS", "$(V_DHIMDS)", "1", "a", selectGroup)
                  @dtw_assign(grpFldTyp, "Alpha")
                  @dtw_assign(grpFldHdr, "Item Description")
                  @dtw_assign(grpFldVal, "$(V_DHIMDS)")
              %elif (fieldName == "@@DHBLTO ")
                  @dtw_replace(selectGroup, "@@DHBLTO", "$(V_DHBLTO)", "1", "a", selectGroup)
                  @dtw_assign(grpFldTyp, "Num7_0")
                  @dtw_assign(grpFldHdr, "Bill-To Number")
                  @dtw_assign(grpFldVal, "$(V_DHBLTO)")
                  @RtvFldDesc("CMCUST=$(V_DHBLTO)", "HDCUST", "CMCNA1", billToName)
                  @dtw_assign(grpFldDsc, "$(billToName)")
              %elif (fieldName == "@@DHSHTO ")
                  @dtw_replace(selectGroup, "@@DHSHTO", "$(V_DHSHTO)", "1", "a", selectGroup)
                  @dtw_assign(grpFldTyp, "Num7_0")
                  @dtw_assign(grpFldHdr, "Ship-To Number")
                  @dtw_assign(grpFldVal, "$(V_DHSHTO)")
                  @RtvFldDesc("CMCUST=$(V_DHSHTO)", "HDCUST", "CMCNA1", ShipToName)
                  @dtw_assign(grpFldDsc, "$(ShipToName)")
              %elif (fieldName == "@@CMCNA1U")
                  @dtw_replace(selectGroup, "@@CMCNA1U", "$(V_CMCNA1U)", "1", "a", selectGroup)
                  @dtw_assign(grpFldTyp, "Alpha")
                  @dtw_assign(grpFldHdr, "Ship-To Name")
                  @dtw_assign(grpFldVal, "$(V_CMCNA1U)")
              %elif (fieldName == "@@CMCNA2U")
                  @dtw_replace(selectGroup, "@@CMCNA2U", "$(V_CMCNA2U)", "1", "a", selectGroup)
                  @dtw_assign(grpFldTyp, "Alpha")
                  @dtw_assign(grpFldHdr, "Address 1")
                  @dtw_assign(grpFldVal, "$(V_CMCNA2U)")
              %elif (fieldName == "@@CMCNA3U")
                  @dtw_replace(selectGroup, "@@CMCNA3U", "$(V_CMCNA3U)", "1", "a", selectGroup)
                  @dtw_assign(grpFldTyp, "Alpha")
                  @dtw_assign(grpFldHdr, "Address 2")
                  @dtw_assign(grpFldVal, "$(V_CMCNA3U)")
              %elif (fieldName == "@@CMCNA4U")
                  @dtw_replace(selectGroup, "@@CMCNA4U", "$(V_CMCNA4U)", "1", "a", selectGroup)
                  @dtw_assign(grpFldTyp, "Alpha")
                  @dtw_assign(grpFldHdr, "Address 3")
                  @dtw_assign(grpFldVal, "$(V_CMCNA4U)")
              %elif (fieldName == "@@CMCCTYU")
                  @dtw_replace(selectGroup, "@@CMCCTYU", "$(V_CMCCTYU)", "1", "a", selectGroup)
                  @dtw_assign(grpFldTyp, "Alpha")
                  @dtw_assign(grpFldHdr, "City")
                  @dtw_assign(grpFldVal, "$(V_CMCCTYU)")
              %elif (fieldName == "@@CMST   ")
                  @dtw_replace(selectGroup, "@@CMST", "$(V_CMST)", "1", "a", selectGroup)
                  @dtw_assign(grpFldTyp, "Alpha")
                  @dtw_assign(grpFldHdr, "State")
                  @dtw_assign(grpFldVal, "$(V_CMST)")
                  @RtvFldDesc("STID='$(V_CMST)'", "HDSTID", "STDESC", stateDesc)
                  @dtw_assign(grpFldDsc, "$(stateDesc)")
              %elif (fieldName == "@@CMZIP  ")
                  @dtw_replace(selectGroup, "@@CMZIP", "$(V_CMZIP)", "1", "a", selectGroup)
                  @dtw_assign(grpFldTyp, "Alpha")
                  @dtw_assign(grpFldHdr, "Zip Code")
                  @dtw_assign(grpFldVal, "$(V_CMZIP)")
              %elif (fieldName == "@@DHDTLI ")
                  @dtw_replace(selectGroup, "@@DHDTLI", "$(V_DHDTLI)", "1", "a", selectGroup)
                  @dtw_assign(grpFldTyp, "Date")
                  @dtw_assign(grpFldHdr, "Invoice Date")
                  @dtw_assign(grpFldVal, "$(V_DHDTLI)")
              %elif (fieldName == "@@@@LIYR ")
                  @dtw_replace(selectGroup, "@@@@LIYR", "$(V_LIYEAR)", "1", "a", selectGroup)
                  @dtw_assign(grpFldTyp, "Num4_0")
                  @dtw_assign(grpFldHdr, "Invoice Year")
                  @dtw_assign(grpFldVal, "$(V_LIYEAR)")
              %elif (fieldName == "@@@@LIQT ")
                  @dtw_replace(selectGroup, "@@@@LIQT", "$(V_LIQTR)", "1", "a", selectGroup)
                  @dtw_assign(grpFldTyp, "Num4_0")
                  @dtw_assign(grpFldHdr, "Invoice Quarter")
                  @dtw_assign(grpFldVal, "$(V_LIQTR)")
              %elif (fieldName == "@@@@LIMO ")
                  @dtw_replace(selectGroup, "@@@@LIMO", "$(V_LIMNTH)", "1", "a", selectGroup)
                  @dtw_assign(grpFldTyp, "Num4_0")
                  @dtw_assign(grpFldHdr, "Invoice Month")
                  @dtw_assign(grpFldVal, "$(V_LIMNTH)")
              %elif (fieldName == "@@@@LIWK ")
                  @dtw_replace(selectGroup, "@@@@LIWK", "$(V_LIWEEK)", "1", "a", selectGroup)
                  @dtw_assign(grpFldTyp, "Num4_0")
                  @dtw_assign(grpFldHdr, "Invoice Week")
                  @dtw_assign(grpFldVal, "$(V_LIWEEK)")
              %elif (fieldName == "@@DHPCLS ")
                  @dtw_replace(selectGroup, "@@DHPCLS", "$(V_DHPCLS)", "1", "a", selectGroup)
                  @dtw_assign(grpFldTyp, "Alpha")
                  @dtw_assign(grpFldHdr, "Product Class")
                  @dtw_assign(grpFldVal, "$(V_DHPCLS)")
                  @RtvFldDesc("PCPCLS='$(V_DHPCLS)'", "HDPCLS", "PCPCDS", prodClassDesc)
                  @dtw_assign(grpFldDsc, "$(prodClassDesc)")
              %elif (fieldName == "@@DHPGRP ")
                  @dtw_replace(selectGroup, "@@DHPGRP", "$(V_DHPGRP)", "1", "a", selectGroup)
                  @dtw_assign(grpFldTyp, "Alpha")
                  @dtw_assign(grpFldHdr, "Product Group")
                  @dtw_assign(grpFldVal, "$(V_DHPGRP)")
                  @RtvFldDesc("PGPGRP='$(V_DHPGRP)'", "HDPRGM", "PGDESC", prodGroupDesc)
                  @dtw_assign(grpFldDsc, "$(prodGroupDesc)")
              %elif (fieldName == "@@IMITC  ")
                  @dtw_replace(selectGroup, "@@IMITC", "$(V_IMITC)", "1", "a", selectGroup)
                  @dtw_assign(grpFldTyp, "Alpha")
                  @dtw_assign(grpFldHdr, "Inventory Type")
                  @dtw_assign(grpFldVal, "$(V_IMITC)")
