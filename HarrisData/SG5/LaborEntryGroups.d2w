%INCLUDE "$(baseVar)"
%INCLUDE "EdtVar.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Labor Entry Groups"
  d2wName                 = "LaborEntryGroups.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;chgGroup=@dtw_rurlescseq(chgGroup)&amp;touchScreen=Y"
  currentURL              = "$(d2wName)/REPORT$(d2wVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = ""
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "8"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "8"
  rowIndexNext            = "1"
  totalPages              = "0"
  groupNumber             = "0"
  plantNumber             = "0"
  sec_01                  = ""
  sec_02                  = ""
  sec_03                  = ""
  sec_04                  = ""
  sec_05                  = ""
  sec_06                  = ""
  sec_07                  = ""
  sec_08                  = ""
  sec_09                  = ""
  sec_10                  = ""
  sec_11                  = ""
  sec_12                  = ""
  sec_13                  = ""
  sec_14                  = ""
  sec_15                  = ""
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %if (chgGroup == "Y")
      @dtw_assign(page_title, "Labor Entry Change Group")
  %else
      @dtw_assign(page_title, "Labor Entry Combine Group")
  %endif
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
              %INCLUDE "AJAXRequestFunction.icl"
              %INCLUDE "KeyboardFunctionsTS.icl"
              %INCLUDE "ShowHideSelCriteria.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">

%{ Labor Entry Heading %}
                      @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                      @dtw_assign(START_ROW_NUM, "1")
                      @dtw_assign(stmtSQL, "")
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(stmtSQL, " From SIDCTW Where WDXHND='$(profileHandle)' ", stmtSQL)
                      @dtw_concat(stmtSQL, " Fetch First 1 Row Only With NC  @@endsql", stmtSQL)
                      @Labor_Entry_Header(profileHandle, dataBaseID, stmtSQL)

%{ Labor Entry Groups %}
                      @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                      %INCLUDE "stmtSQLClear.icl"
                      %if (chgGroup == "Y")
                          @dtw_concat(stmtSQL, " Select BBGRP# as EHGRP,BBDESC ", stmtSQL)
                          @dtw_concat(fileSQL, " HDGRPM ", fileSQL)
                          @dtw_concat(selectSQL, "BBGRP#<>$(groupNumber) and not exists (Select * from HDMECH Where BBGRP#=EHGRP and EHTRAN='10')", selectSQL)
                      %else
                          @dtw_assign(distinctSQL, "EHGRP,BBDESC")
                          @dtw_concat(stmtSQL, " Select EHGRP,BBDESC,max(DFDESC) as DFDESC ", stmtSQL)
                          @dtw_concat(fileSQL, " HDMECH a inner join HDGRPM on a.EHGRP=BBGRP# inner join ETDCDF e on DFCODE= ", fileSQL)
                          @dtw_concat(fileSQL, " (Select max(EHTRAN) From HDMECH b Where b.EHPLNT=a.EHPLNT and b.EHGRP=a.EHGRP and b.EHDATE=a.EHDATE ", fileSQL)
                          @dtw_concat(fileSQL, "  and b.EHSTRT=(select max(EHSTRT) from HDMECH c inner join ETDCDF f on b.EHTRAN=f.DFCODE and DFONOF='ON' ", fileSQL)
                          @dtw_concat(fileSQL, " Where c.EHPLNT=b.EHPLNT and c.EHTRAN=b.EHTRAN and c.EHGRP=b.EHGRP and c.EHDATE=b.EHDATE)) ", fileSQL)
                          @dtw_concat(selectSQL, "a.EHPLNT=$(plantNumber) and a.EHGRP<>$(groupNumber) and a.EHTRAN='10' and a.EHGRP<>0", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      %if (chgGroup == "Y")
                          @dtw_concat(stmtSQL, " Group By BBGRP#,BBDESC ", stmtSQL)
                      %else
                          @dtw_concat(stmtSQL, " Group By EHGRP,BBDESC Having max(DFCODE)='10'", stmtSQL)
                      %endif
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      %if (START_ROW_NUM > sql_Record_Count)
                          @dtw_assign(START_ROW_NUM, "1")
                      %endif	
                      @Labor_Entry_Orders(profileHandle, dataBaseID, stmtSQL)
                  </td>
                  <td>
                      <ul class="toolbarTS">
                          <li class="optionTS"><a href="$(homeURL)$(cGIPath)EmployeeSignOn.d2w/REPORT$(genericVarBase)&amp;touchScreen=Y">&nbsp;<br>Exit</a></li>                      
                          <li class="optionTS"><a href="$(homeURL)$(cGIPath)LaborEntry.d2w/REPORT$(d2wVarBase)">&nbsp;<br>Labor Entry</a></li>
                          %if (chgGroup == "Y")
                              <li class="optionTS"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(genericVarBase)&amp;chgGroup=N&amp;touchScreen=Y">&nbsp;<br>Combine Group</a></li>
                          %else
                              <li class="optionTS"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(genericVarBase)&amp;chgGroup=Y&amp;touchScreen=Y">&nbsp;<br>Change Group</a></li>
                          %endif
                          <li class="optionTS"><a href="$(homeURL)$(cGIPath)LaborEntryEmployees.d2w/REPORT$(d2wVarBase)">&nbsp;<br>Maintain Employees</a></li>
                      </ul>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          <!-- End Of Trailer Code -->
          %if (errFound != "")
              @dtw_assign(errFound, "")
              @ErrVarErr(profileHandle, typeError, errVar)
              @DecatErr_Field("@@sgrp", "selectGroup")  @dtw_assign(alertMessage, "Select Group Error: \n \n $(fieldValue)")
              %INCLUDE "AlertMessageDisplay.icl"
          %endif
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Labor_Entry_Header (IN CHAR(64)    profileHandle,
				           CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <tr><td><h1> $(page_title)</h1></td></tr>
      </table>

      %ROW{
          @dtw_assign(plantNumber, V_WDPLT)
          @dtw_assign(groupNumber, V_WDGRP)
          <table $(contentTable)>
              @Format_Header("Plant", V_WDPNAM, V_WDPLT)
              @dtw_assign(F_WDDEPT, $(V_WDDEPT))
              @dtw_concat(F_WDDEPT, " / ", F_WDDEPT)
              @dtw_concat(F_WDDEPT, $(V_WDWC), F_WDDEPT)
              @Format_Header("Department/Work Center", V_WDWDSC, F_WDDEPT)
              @Format_Header("Group", V_WDGDSC, V_WDGRP)
          </table>
       %}

      %INCLUDE "ConfMessageDisplay.icl"
      $(hrTagAttr)
  %}
%}


%FUNCTION(dtw_sql) Labor_Entry_Orders (IN CHAR(64)    profileHandle,
				           CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <form class="formClass" method="post" name="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr">Group</th>
                  <th class="colhdr">Description</th>
                  <td>&nbsp;</td>
              </tr>
              <tr><td class="inputalph">
                      <input class="input" id="srchGroup" onfocus="kbActive(this, 'numerickeyboard');" name="srchGroup" type="text" size="5" maxlength="5">
                      <input type="hidden" name="operGroup" value="=">
                  </td>
                  <td class="inputalph">
                      <input class="input" id="srchDesc" onfocus="kbActive(this, 'keyboard');" name="srchDesc" type="text" size="15" maxlength="25">
                      <input type="hidden" name="operDesc" value="LIKE">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  <td><input type="hidden" id="submitSearch"></td>
              </tr>
          </table>
      </form>

      @dtw_assign(pageSelectList, "N")
      @dtw_assign(wildCardDefault, "N")
      @dtw_assign(advanceSearch, "N")
      %INCLUDE "WildCardPage.icl"

      <form class="formClass" method="post" name="Select" action="">
          <table $(contentTable)>
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("EHGRP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=GROUP" title="Sequence By Group">Group</a></th>
                  @OrderBy_Sort("BBDESC", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DESC" title="Sequence By Description, Group">Description</a></th>
                  %if (chgGroup != "Y")
                      @OrderBy_Sort("DFDESC", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=LAST" title="Sequence By Last Transaction, Group">Last Transaction</a></th>
                  %endif
              </tr>		
              %INCLUDE "NoRecordsFound.icl"

              %ROW{
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colnmbr" onclick="showSel('selData$(ROW_NUM)');">$(V_EHGRP)</td>
                      <td class="colalph" onclick="showSel('selData$(ROW_NUM)');">$(V_BBDESC)</td>
                      %if (chgGroup != "Y")
                          <td class="colalph" onclick="showSel('selData$(ROW_NUM)');">$(V_DFDESC)</td>
                      %endif
                  </tr>
                  <tr>
                      <td>
                          @dtw_assign(moreInfo, "")
                          @Build_More_Info("Group", V_EHGRP, "", moreInfo)
                          @Build_More_Info("Description", V_BBDESC, "", moreInfo)
                          %if (chgGroup != "Y")
                              @Build_More_Info("Last Transaction", V_DFDESC, "", moreInfo)
                          %endif
                          @Build_More_Info("", "", "", moreInfo)
                          @Build_More_Info("", "", "", moreInfo)
                          <div id="selData$(ROW_NUM)" class="moreInfoPos">
                              <table $(quickSearchTable)>
                                  <tr>
                                      <td>&nbsp;</td>
                                      <td>&nbsp;</td>
                                      <td rowspan="20">
                                          <ul class="toolbarTS">
                                              <li class="optionTS2"><a href="javascript:void+0" onClick="hideSel('selData$(ROW_NUM)')">&nbsp;<br>Exit</a></li>
                                              <li class="optionTS2"><a href="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;selectGroup=@dtw_rurlescseq($(V_EHGRP))">&nbsp;<br>Select Group</a></li>
                                          </ul>
                                      </td>
                                  </tr>
                                  $(moreInfo)
                              </table>
                          </div>
                      </td>
                  </tr>
	       %}
          </table>
      </form>

      %INCLUDE "KeyboardTS.icl"

      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HETLBE_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "EHGRP")
      @DTW_ASSIGN(orderByDisplay, "Group")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @dtw_assign(edtVar, "")
  %if (chgGroup == "Y")
      @Concat_Field("@@subr", "SrChgGrp")
  %else
      @Concat_Field("@@subr", "SrComGrp")
  %endif
  @Concat_Field("@@sgrp", selectGroup)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, errFound, edtVar, errVar)

  %if (errFound == "" || errFound == "C")
      @DecatErr_Field("@@cmsg", "confMessage")
      @dtw_assign(confMessage, fieldValue)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)LaborEntryEmployees.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (errFound == "X")
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)EmployeeSignOn.d2w/REPORT$(genericVarBase)&amp;touchScreen=Y">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "GROUP")
      %if (orderBy == "EHGRP")
          @DTW_ASSIGN(orderBy, "EHGRP DESC")
          @DTW_ASSIGN(orderByDisplay, "Group (descending)")
      %else
          @DTW_ASSIGN(orderBy, "EHGRP")
          @DTW_ASSIGN(orderByDisplay, "Group")
      %endif
  %elif (sequence == "DESC")
      %if (orderBy == "BBDESC,EHGRP")
          @DTW_ASSIGN(orderBy, "BBDESC DESC,EHGRP")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Group")
      %else
          @DTW_ASSIGN(orderBy, "BBDESC,EHGRP")
          @DTW_ASSIGN(orderByDisplay, "Description, Group")
      %endif
  %elif (sequence == "LAST")
      %if (orderBy == "DFDESC,EHGRP")
          @DTW_ASSIGN(orderBy, "DFDESC DESC,EHGRP")
          @DTW_ASSIGN(orderByDisplay, "Last Transaction (descending), Group")
      %else
          @DTW_ASSIGN(orderBy, "DFDESC,EHGRP")
          @DTW_ASSIGN(orderByDisplay, "Last Transaction, Group")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("upper(BBDESC)", "Description", $(srchDesc), "U", operDesc, "A")
  %if (chgGroup == "Y")
      @Build_WildCard ("BBGRP#", "Group", $(srchGroup), "", operGroup, "N")
  %else
      @Build_WildCard ("EHGRP", "Group", $(srchGroup), "", operGroup, "N")
  %endif		
  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}