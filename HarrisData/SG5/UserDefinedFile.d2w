%INCLUDE "$(baseVar)"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "User-Defined Table"
  d2wName                 = "UserDefinedFile.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "USERDEFINEDFILE")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select UNFILN, UNDESC, UNCNDU, upper(UNDESC) as UNDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " SYUDFN ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, "UNFILN>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @UserDefFile_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) UserDefFile_Query (IN  CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @dtw_assign(programName, "HSYUDV_E")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, UDV_01, UDV_02, UDV_03, UDV_04, UDV_05, UDV_06, UDV_07, UDV_08, UDV_09, UDV_10, UDV_11, UDV_12, UDV_13, UDV_14, UDV_15)
                  @dtw_assign(programName, "HSYUDF_E")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, UDF_01, UDF_02, UDF_03, UDF_04, UDF_05, UDF_06, UDF_07, UDF_08, UDF_09, UDF_10, UDF_11, UDF_12, UDF_13, UDF_14, UDF_15)
                  @dtw_assign(programName, "HSYUFN_E")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, UFN_01, UFN_02, UFN_03, UFN_04, UFN_05, UFN_06, UFN_07, UFN_08, UFN_09, UFN_10, UFN_11, UFN_12, UFN_13, UFN_14, UFN_15)
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr"> Description</th></tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="20" maxlength="20">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y")
                  %if (UDF_01 == "Y" || UDF_02 == "Y" || UDF_03 == "Y")
                      <th class="colhdr">Columns</th>
                  %endif
                  %if (UDF_01 == "Y" || UDV_02 == "Y" || UDV_03 == "Y")
                      <th class="colhdr">Events</th>
                  %endif
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("UNFILN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=File" title="Sequence By Table">Table</a></th>
              @OrderBy_Sort("UNDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description, Table">Description</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(genericVarBase)&amp;fileName=@dtw_rurlescseq(V_UNFILN)&amp;fileDesc=@dtw_rurlescseq(V_UNDESC)&amp;condUse=@dtw_rurlescseq(V_UNCNDU)")
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y")
                      %if (UDF_01 == "Y" || UDF_02 == "Y" || UDF_03 == "Y")
                          <td class="opticon"><a href="$(homeURL)$(cGIPath)userdefinedfield.d2w/REPORT$(maintainVar)">$(selectImage)</a></td>
                      %endif
                      %if (UDV_01 == "Y" || UDV_02 == "Y" || UDV_03 == "Y")
                          %if (V_UNCNDU == "Y")
                              <td class="opticon"><a href="$(homeURL)$(cGIPath)eventcode.d2w/REPORT$(maintainVar)">$(selectImage)</a></td>
                          %else
                              <td class="opticon"></td>
                          %endif
                      %endif
                  %endif
                  <td class="colalph">$(V_UNFILN)</td>
                  <td class="colalph">$(V_UNDESC)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "UNDESCU,UNFILN")
          @DTW_ASSIGN(orderByDisplay, "Description, Table")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "File")
      %if (orderBy == "UNFILN")
          @DTW_ASSIGN(orderBy, "UNFILN DESC")
          @DTW_ASSIGN(orderByDisplay, "Table (descending)")
      %else
          @DTW_ASSIGN(orderBy, "UNFILN")
          @DTW_ASSIGN(orderByDisplay, "Table")
      %endif
  %elif (sequence == "Desc")
      %if (orderBy == "UNDESCU,UNFILN")
          @DTW_ASSIGN(orderBy, "UNDESCU DESC,UNFILN")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Table")
      %else
          @DTW_ASSIGN(orderBy, "UNDESCU,UNFILN")
          @DTW_ASSIGN(orderByDisplay, "Description, Table")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("upper(UNDESC)", "Description", $(srchDesc), "U", operDesc, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
