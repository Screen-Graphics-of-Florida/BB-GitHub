%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title 		      = "Employee Benefits"
  d2wName                 = "EmplBenefits.d2w"
  d2wVarBase              = "$(genericVarBase)$(employeeVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(d2wName)"
  nextPrevVar             = "$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  DTW_PAD_PGM_PARMS       = "YES"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext	          = "1"
  totalPages		      = "0"	
  depName                 = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
  @dtw_replace(workURL, "@@fromD2w", "@dtw_rurlescseq(fromD2w)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script type="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              function goToPage(selectedPage) {if (selectedPage != "") {self.location=selectedPage;}}
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                       @dtw_assign(pageID, "EMPLBENEFITS")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "UserViewEmpl.icl"
	               %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "SELECT ECCOVR, CVDESC, CVDESCU, ECPLAN, CCDESC, ECDCE, ECDCT, ECSPDP, ECCLAS, CVAUTD, CVIMG, CVURLI, SDDOB, SDREL, SDCLAS, SDFNAM, ECCOMP, ECFACL, ECEMPL, EMCOMP, EMFACL, EMEMPL, EMPECP, EMPEMP, EMDEPT, EMLOC, EMTYPE", stmtSQL)
                      @dtw_concat(fileSQL, " HREMCV inner join HREMPL on ECCOMP=EMCOMP AND ECFACL=EMFACL AND ECEMPL=EMEMPL  ", fileSQL)
                      @dtw_concat(fileSQL, "        inner join CBCOVR on ECCOMP=CVCOMP and ECFACL=CVFACL and ECCOVR=CVCOVR and ECPLAN=CVPLAN  ", fileSQL)
                      @dtw_concat(fileSQL, "        inner join CBCODE on ECPLAN=CCCODE  ", fileSQL)
                      @dtw_concat(fileSQL, "        left outer join HRSPDP on ECCOMP=SDCOMP AND ECFACL=SDFACL AND ECEMPL=SDEMPL AND ECSPDP=SDSPDP  ", fileSQL)
                      @dtw_concat(selectSQL, " ECCOMP=$(prCompany) and ECFACL=$(prFacility) and ECEMPL=$(hrEmployee)", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Empl_Benefits_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "UserViewEmpl.icl"
  %INCLUDE "userview.icl"

  %INCLUDE "UserViewEmpl.icl"
	               %INCLUDE "userview.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "SELECT ECCOVR, CVDESC, CVDESCU, ECPLAN, CCDESC, ECDCE, ECDCT, ECSPDP, ECCLAS, CVAUTD, CVIMG, CVURLI, SDDOB, SDREL, SDCLAS, SDFNAM, ECCOMP, ECFACL, ECEMPL, EMCOMP, EMFACL, EMEMPL, EMPECP, EMPEMP, EMDEPT, EMLOC, EMTYPE", stmtSQL)
  @dtw_concat(fileSQL, " HREMCV inner join HREMPL on ECCOMP=EMCOMP AND ECFACL=EMFACL AND ECEMPL=EMEMPL  ", fileSQL)
  @dtw_concat(fileSQL, "        inner join CBCOVR on ECCOMP=CVCOMP and ECFACL=CVFACL and ECCOVR=CVCOVR and ECPLAN=CVPLAN  ", fileSQL)
  @dtw_concat(fileSQL, "        inner join CBCODE on ECPLAN=CCCODE  ", fileSQL)
  @dtw_concat(fileSQL, "        left outer join HRSPDP on ECCOMP=SDCOMP AND ECFACL=SDFACL AND ECEMPL=SDEMPL AND ECSPDP=SDSPDP  ", fileSQL)
  @dtw_concat(selectSQL, " ECCOMP=$(prCompany) and ECFACL=$(prFacility) and ECEMPL=$(hrEmployee)", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @Empl_Benefits_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) Empl_Benefits_Query (IN  CHAR(64)    profileHandle,
				             CHAR(2)     dataBaseID,
                                            CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(programName, "HPESDU")
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @dtw_assign (viewDependents, $(sec_05))

      @dtw_assign(programName, "HPECVU")
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @dtw_assign (viewBenefit, $(sec_05))

      @dtw_assign (programName, "HPEECU")
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)

          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                          %endif
                          %if (sec_01 == "Y")
                              <a href="$(homeURL)$(cGIPath)EmplBenefitsAdd.d2w/ADD$(d2wVarBase)&amp;dependentNbr=0000000&amp;maintenanceCode=A">$(addImageLrg)</a>
                          %endif
                          <a href="$(homeURL)$(cGIPath)EmployeeMaintainSelect.d2w/REPORT$(d2wVarBase)">$(emplMaintImage)</a>
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
              @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
              <tr><td><h2>$(F_EmpName)</h2></td></tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"
          $(hrTagAttr)	

          %if (formatToPrint != "Y")
              <table>
                  <tr><td> %INCLUDE "AssignPageValue.icl" </td></tr>
              </table>
          %endif
          <table $(contentTable)>
    	       <tr>
                  %if (formatToPrint != "Y" && ((sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y") || V_CVURLI != ""))
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("ECCOVR", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BenefitCode" title="Sequence By Benefit, Plan, Spouse/Dependent Number">Benefit</a></th>
                  @OrderBy_Sort("CVDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BenefitDesc" title="Sequence By Benefit Description, Plan Description, Spouse/Dependent Number"> Benefit<br>Description</a></th>
                  @OrderBy_Sort("ECPLAN", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlanCode" title="Sequence By Plan, Benefit, Spouse/Dependent Number">Plan</a></th>
                  @OrderBy_Sort("CCDESC", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlanDesc" title="Sequence By Plan Description, Benefit Description, Spouse/Dependent Number"> Plan<br>Description</a></th>	
                  @OrderBy_Sort("ECDCE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DateEffective" title="Sequence By Date Effective, Benefit Description, Plan Description, Spouse/Dependent Number"> Date<br>Effective</a></th>	
                  @OrderBy_Sort("ECDCT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TerminationDate" title="Sequence By Termination Date, Benefit Description, Plan Description, Spouse/Dependent Number "> Termination<br>Date</a></th>	
                  @OrderBy_Sort("SDFNAM", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FirstName" title="Sequence By Spouse/Dependent Name, Benefit Description, Plan Description "> Spouse/Dependent<br>Name</a></th>
                  @OrderBy_Sort("SDREL", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Relationship" title="Sequence By Relationship, Spouse/Dependent Number, Benefit Description, Plan Description "> Relationship </a></th>
                  @OrderBy_Sort("SDDOB", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DateOfBirth" title="Sequence By Date Of Birth, Benefit Description, Plan Description "> Date<br>Of Birth </a></th>
              </tr>		
              %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;benefitCode=@dtw_rurlescseq(V_ECCOVR)&amp;planCode=@dtw_rurlescseq(V_ECPLAN)&amp;dependentNbr=@dtw_rurlescseq(V_ECSPDP)")
              @dtw_assign(maintainPHP, "$(altVarBase)$(hrCoFacVarBase)$(employeeVarBase)&amp;benefitCode=@dtw_rurlescseq(V_ECCOVR)&amp;planCode=@dtw_rurlescseq(V_ECPLAN)&amp;dependentNbr=@dtw_rurlescseq(V_ECSPDP)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              @dtw_assign(imageExists, "")
              %if (V_CVIMG != "")
                  @dtw_assign(fileImage, "$(V_CVIMG)")
                  @dtwf_exists(fileImage, imageExists)
              %endif
              @Format_Date(V_ECDCE, "D", F_ECDCE)
              @DateFromCYMD(V_ECDCE)
              @dtw_assign(displayDateEffective, V_ECDCE)
              @Format_Date(V_ECDCT, "D", F_ECDCT)
              %if (V_ECCLAS == "E")
                  @dtw_assign(V_SDDOB, "0")
              %endif
              @Format_Date(V_SDDOB, "D", F_SDDOB)
              @Format_Confirm_Desc($(V_CVDESC), $(V_ECCOVR), $(V_CCDESC), $(V_ECPLAN), "", "", confirmDesc)
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y")
                      <td class="opticon">
                          %if (viewBenefit == "Y")
                              <a href="$(homeURL)$(cGIPath)hrBenefitSelect.d2w/REPORT$(maintainVar)">$(benefitInfoImage)</a>
                          %endif
                          %if (sec_02 == "Y")
                              <a  href=$(homeURL)$(phpPath)EmplBenefitsMaintain.php$(maintainPHP)&amp;tag=MAINTAIN&amp;maintenanceCode=C&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))>$(changeImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(phpPath)EmplBenefitsMaintain.php$(maintainPHP)&amp;tag=Edit_Data&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                          %if (V_CVURLI != "")
                              <a href="$(V_CVURLI)">
                                  %if (imageExists == "Y")
                                      <img src="$(homeURL)$(fileImage)">
                                  %else
                                      $(planDocImage)
                                  %endif
                              </a>
                          %endif
                      </td>
                  %endif

                  <td class="colcode">$(V_ECCOVR)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)emplBenefitSelect.d2w/REPORT$(maintainVar)" title="View Benefit Row">$(V_CVDESC)</a></td>
                  <td class="colcode">$(V_ECPLAN)</td>
                  <td class="colalph">$(V_CCDESC)</td>
                  <td class="coldate">$(F_ECDCE)</td>
                  <td class="coldate">$(F_ECDCT)</td>
                  <td class="colalph">$(V_SDFNAM)</td>
                  <td class="colnmbr">$(V_SDREL)</td>
                  <td class="coldate">$(F_SDDOB)</td>
    	       </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_sql) Empl_Benefits_XMLQuery (IN CHAR(64) profileHandle,
				               CHAR(2)   dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("EmployeeBenefitList")
          %ROW{
              @DateFromCYMD(V_ECELIG)
              @DateFromCYMD(V_ECELEC)
              @DateFromCYMD(V_ECVEST)
              @DateFromCYMD(V_ECDCE)
              @DateFromCYMD(V_ECPREC)
              @DateFromCYMD(V_ECDCT)
              @DateFromCYMD(V_ECTRCI)
              @EditPhoneNumber(V_ECPHON)
              %if (V_ECSPDP == "0")
                  @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_Name)
                  @dtw_assign(BenefitType, "Employee Benefit")
              %else
                  @Format_EmplName(V_SDFNAM, V_SDLNAM, V_SDMIDI, "", "", "D", F_Name)
                  @dtw_assign(BenefitType, "Dependent Benefit")
              %endif

	           @XMLIDTag(@DTW_rCONCAT(V_ECCOMP, @DTW_rCONCAT("/", @DTW_rCONCAT(V_ECFACL, @DTW_rCONCAT("/", @DTW_rCONCAT(V_ECEMPL, @DTW_rCONCAT("/", @DTW_rCONCAT(V_ECSPDP, @DTW_rCONCAT("/", V_ECCOVR)))))))), "Benefit ID")
                  @XMLTag(V_ECCOMP, "CompanyNumber")
                  @XMLTag(V_ECCOMP, "FacilityNumber")
                  @XMLTag(V_ECEMPL, "EmployeeNumber")
                  @XMLTag(BenefitType, "BenefitType")
                  @XMLBeginTag("PersonName")
                     @XMLTag(F_Name, "FormattedName")
                  @XMLEndTag("PersonName")
                  @XMLBeginTag("BenefitIdentification")
                      @XMLTag(V_ECCOVR, "BenefitCode")
                      @XMLTag(V_CVDESC, "BenefitDescription")
                      @XMLTag(V_ECPLAN, "PlanCode")
                      @XMLTag(V_ECID, "PlanId")
                      @XMLTag(V_ECELIG, "EligibilityDate")
                      @XMLTag(V_ECELEC, "EnrollmentDate")
                      @XMLTag(V_ECDCE, "DateEffective")
                          @XMLTag(V_ECVEST, "VestingDate")
                          @XMLBeginTag("Certificate")
                              @XMLTag(V_ECCERT, "CertificateDateReceived")
                              @XMLTag(V_ECCISU, "CertificateIssuer")
                              @XMLTag(V_ECPHON, "IssuerPhoneNumber")
                              @XMLTag(V_ECMNTH, "PreviousMonthsCoverage")
                              @XMLTag(V_ECPREC, "PreexistingConditionExpDate")
                          @XMLEndTag("Certificate")
                          @XMLBeginTag("BenefitTermination")
                              @XMLTag(V_ECDCT, "DateCoverageTerminated")
                              @XMLTag(V_ECQECD, "QualifyingEventCode")
                              @XMLTag(V_ECTRCI, "DateCertificateIssued")
                          @XMLEndTag("BenefitTermination")
                  @XMLEndTag("BenefitIdentification")
                  @XMLEndTag("Benefit")

          %}
      @XMLEndTag("EmployeeBenefitList")

      @DTWF_CLOSE(xMLFile)
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(programName, "HPEECU")
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint == "Y")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (ORDERbY == "")
              @DTW_ASSIGN(orderBy, "CVDESCU,CCDESC")
              @DTW_ASSIGN(orderByDisplay, "Benefit Description, Plan Description")
              @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)

              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
      %endif
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Input) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "BenefitCode")
      %if (orderBy == "ECCOVR,ECPLAN,ECSPDP")
          @DTW_ASSIGN(orderBy, "ECCOVR DESC,ECPLAN,ECSPDP")
      %else
          @DTW_ASSIGN(orderBy, "ECCOVR,ECPLAN,ECSPDP")
      %endif
  %elif (sequence == "BenefitDesc")
      %if (orderBy == "CVDESCU,CCDESC,ECSPDP")
          @DTW_ASSIGN(orderBy, "CVDESCU DESC,CCDESC,ECSPDP")
      %else
          @DTW_ASSIGN(orderBy, "CVDESCU,CCDESC,ECSPDP")
      %endif
  %elif (sequence == "PlanCode")
      %if (orderBy == "ECPLAN,ECCOVR,ECSPDP")
          @DTW_ASSIGN(orderBy, "ECPLAN DESC,ECCOVR,ECSPDP")
      %else
          @DTW_ASSIGN(orderBy, "ECPLAN,ECCOVR,ECSPDP")
      %endif
  %elif (sequence == "PlanDesc")
      %if (orderBy == "CCDESC,CVDESCU,ECSPDP")
          @DTW_ASSIGN(orderBy, "CCDESC DESC,CVDESCU,ECSPDP")
      %else
          @DTW_ASSIGN(orderBy, "CCDESC,CVDESCU,ECSPDP")
      %endif
  %elif (sequence == "DateEffective")
      %if (orderBy == "ECDCE,CVDESCU,CCDESC,ECSPDP")
          @DTW_ASSIGN(orderBy, "ECDCE DESC,CVDESCU,CCDESC,ECSPDP")
      %else
          @DTW_ASSIGN(orderBy, "ECDCE,CVDESCU,CCDESC,ECSPDP")
      %endif
  %elif (sequence == "TerminationDate")
      %if (orderBy == "ECDCT,CVDESCU,CCDESC,ECSPDP")
          @DTW_ASSIGN(orderBy, "ECDCT DESC,CVDESCU,CCDESC,ECSPDP")
      %else
          @DTW_ASSIGN(orderBy, "ECDCT,CVDESCU,CCDESC,ECSPDP")
      %endif
  %elif (sequence == "Relationship")
      %if (orderBy == "SDREL,ECSPDP,CVDESCU,CCDESC")
          @DTW_ASSIGN(orderBy, "SDREL DESC,ECSPDP,CVDESCU,CCDESC")
      %else
          @DTW_ASSIGN(orderBy, "SDREL,ECSPDP,CVDESCU,CCDESC")
      %endif
  %elif (sequence == "DateOfBirth")
      %if (orderBy == "SDDOB,CVDESCU,CCDESC")
          @DTW_ASSIGN(orderBy, "SDDOB DESC,CVDESCU,CCDESC")
      %else
          @DTW_ASSIGN(orderBy, "SDDOB,CVDESCU,CCDESC")
      %endif
  %elif (sequence == "FirstName")
      %if (orderBy == "SDFNAM,CVDESCU,CCDESC")
          @DTW_ASSIGN(orderBy, "SDFNAM DESC,CVDESCU,CCDESC")
      %else
          @DTW_ASSIGN(orderBy, "SDFNAM,CVDESCU,CCDESC")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}