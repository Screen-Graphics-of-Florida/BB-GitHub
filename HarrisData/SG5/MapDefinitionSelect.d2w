%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Map Definition"
  d2wName                 = "MapDefinitionSelect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;mapKey=@dtw_rurlescseq(mapKey)"
  programName             = "HSYMHM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
  V_MHDESC                = ""	
  quickLinkByUser         = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_assign(backHome, "$(d2wName)/REPORT")
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          @RtvFldDesc("MHMPKY=$(mapKey)", "SYMMHD", "MHDESC", V_MHDESC)
          @Format_Code(mapKey, F_mapKey)
          @dtw_assign(title, "$(V_MHDESC) $(F_mapKey)")
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "MAPDEFINITIONSELECT")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif

                  <td class="content">

%{ QuickLink Table %}     %INCLUDE "QuickLinkTable.icl"

%{ QuickLink By User %}   %INCLUDE "QuickLinkByUser.icl"

%{ Process Heading %}
                      @dtw_assign(RPT_MAX_ROWS, "99")
                      @dtw_assign(dspMaxRows, "10")
                      @dtw_assign(wildCardSearch, "")  %{ No wildCardSearch %}
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " SYMMHD ", fileSQL)
                      @dtw_concat(selectSQL, " MHMPKY=$(mapKey) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Process_Select_Header(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Begin %}     %INCLUDE "QuickLinkBegLoop.icl"

    %{ Table %}
                          %if (quicklinkRef == "table")
                              %INCLUDE "QuickLinkClear.icl"
                              @Retrieve_WebReg(userProfile, "", "MapTable.d2w", wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select a.*,  ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(b.MFDESC,' ') as ParentMFDESC, coalesce(b.MFDESCU,' ') as ParentMFDESCU ", stmtSQL)
                              @dtw_concat(fileSQL, " SYMMTB a ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYMMTB b on b.MFMPKY=a.MFMPKY and b.MFMFIL=a.MFPFIL ", fileSQL)
                              @dtw_concat(selectSQL, " a.MFMPKY=$(mapKey) ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %if (orderBy == "")
                                  @dtw_assign(orderBy, "MFDESCU, MFMFIL")
                                  @dtw_assign(orderByDisplay, "Description, Interface Table")
                              %endif
                              @dtw_concat(stmtSQL, " Order By $(orderBy)", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @Process_Select_Table(profileHandle, dataBaseID, stmtSQL)
                          %endif

    %{ Column %}
                          %if (quicklinkRef == "column")
                              %INCLUDE "QuickLinkClear.icl"
                              @dtw_assign(wildCardSearch, "")
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select SYMMCL.*, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(MFDESC,' ') as MFDESC, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(PMPRMD,' ') as PMPRMD ", stmtSQL)
                              @dtw_concat(fileSQL, " SYMMCL", fileSQL)
                              @dtw_concat(fileSQL, " left join SYMMTB on MFMPKY=MDMPKY and MFMFIL=MDMFIL ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFPARM on PMPARM=MDPARM ", fileSQL)
                              @dtw_concat(selectSQL, " MDMPKY=$(mapKey) and MDDPOS>0 ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              @dtw_assign(orderBy, "MFDESC,MDMFIL,MDDPOS,MDMFLD")
                              @dtw_assign(orderByDisplay, "Interface Table, Display Position, Column")
                              @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @Process_Select_Column(profileHandle, dataBaseID, stmtSQL)
                          %endif

    %{ Import %}
                          %if (quicklinkRef == "import")
                              %INCLUDE "QuickLinkClear.icl"
                              @dtw_assign(wildCardSearch, "")
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select SYMIHD.*, SYMITB.* ", stmtSQL)
                              @dtw_concat(fileSQL, " SYMIHD ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYMITB on FFIMKY=FHIMKY ", fileSQL)
                              @dtw_concat(fileSQL, " and FFIFIL=(Select Max(FFIFIL) from SYMITB where FFIMKY=FHIMKY)", fileSQL)
                              @dtw_concat(selectSQL, " FHMPKY=$(mapKey)  ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              @dtw_concat(stmtSQL, " Order By FHDESCU ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @Process_Select_Import(profileHandle, dataBaseID, stmtSQL)
                          %endif

%{ Quicklink End %}       %INCLUDE "QuickLinkEndLoop.icl"

                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Process_Select_Header (IN CHAR(64)    profileHandle,
                                             CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;fromD2w=")
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)MapDefinitionMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (sec_01=="Y" && sec_04=="Y")
                          <a href="$(homeURL)$(cGIPath)MapDefinitionMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromMapKey=@dtw_rurlescseq(mapKey)&amp;maintenanceCode=Z">$(copyImageLrg)</a>
                      %endif
                      %if (sec_02 == "Y" || sec_03 == "Y")
                          <a href="$(homeURL)$(cGIPath)MapDefinitionMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageLrg)</a>
                      %endif
                      %if (sec_03 == "Y")
                          @Format_Confirm_Desc($(V_MHDESC), $(mapKey), "", "", "", "", confirmDesc)
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)MapDefinitionMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %ROW{
          <table $(contentTable)>
              <tr><td class="dsphdr">Description</td>
                  <td class="dspalph">$(V_MHDESC)</td>
              </tr>

              @RtvFldDesc("ACPGM='$(V_MHWPGM)'", "WFAPCT", "Max(ACDESC)", V_ACDESC)
              <tr><td class="dsphdr">Workflow Program</td>
                  @Format_Code(V_MHWPGM, F_MHWPGM)
                  <td class="dspalph">$(V_ACDESC) $(F_MHWPGM)</td>
              </tr>

              <tr><td class="dsphdr">Map Program</td>
                  <td class="dspalph">$(V_MHMPGM)</td>
              </tr>

              <tr><td class="dsphdr">Interface Report Program</td>
                  <td class="dspalph">$(V_MHRPGM)</td>
              </tr>

              <tr><td class="dsphdr">Interface Clean Up Program</td>
                  <td class="dspalph">$(V_MHCPGM)</td>
              </tr>

              <tr><td class="dsphdr">Interface Process Program</td>
                  <td class="dspalph">$(V_MHPPGM)</td>
              </tr>
          </table>

          $(hrTagAttr)

          %INCLUDE "QuickLinkDisplay.icl"
      %}
  %}
%}

%FUNCTION(dtw_sql) Process_Select_Table (IN CHAR(64)    profileHandle,
                                            CHAR(2)     dataBaseID,
                                            CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="table"></a>
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)MapTable.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("MFMFIL", "Interface Table")
                  @Format_Column_Header("MFDESCU", "Description")
                  @Format_Column_Header("ParentMFDESCU", "Parent Interface Table")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">$(V_MFMFIL)</td>
                  <td class="colalph">$(V_MFDESC)</td>
                  <td class="colalph" $(helpCursor)><span title="$(V_MFPFIL)">$(V_ParentMFDESC)</span></td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Process_Select_Column (IN CHAR(64)    profileHandle,
                                             CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="column"></a>
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("MDMFIL",  "Interface Table")
                  @Format_Column_Header("MDMFLD",  "Column")
                  @Format_Column_Header("MDDESCU", "Description")
                  @Format_Column_Header("MDNOTE",  "Note")
                  @Format_Column_Header("MDFLDT",  "Field Type")
                  @Format_Column_Header("MDSTOR",  "Numeric Stored")
                  @Format_Column_Header("MDNAB",   "Normal Balance")
                  @Format_Column_Header("MDDLGC",  "Default Logic")
                  @Format_Column_Header("MDPARM",  "Workflow Parameter")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph" $(helpCursor)><span title="$(V_MDMFIL)">$(V_MFDESC)</span></td>                                      	
                  <td class="colalph">$(V_MDMFLD)</td>                                      	
                  <td class="colalph">$(V_MDDESC)</td>                                      	
                  %if (V_MDNOTE != "")
                      <td class="colcode" $(helpCursor)><span title="$(V_MDNOTE)">Y</span></td>                                      	
                  %else
                      <td class="colalph">&nbsp;</td>                                      	
                  %endif
                  <td class="colcode">$(V_MDFLDT)</td>                                      	
                  <td class="colcode">$(V_MDSTOR)</td>                                      	
                  <td class="colcode">$(V_MDNAB)</td>                                      	
                  <td class="colcode">$(V_MDDLGC)</td>
                  <td class="colalph" $(helpCursor)><span title="$(V_PMPRMD)">$(V_MDPARM)</span></td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Process_Select_Import (IN CHAR(64)    profileHandle,
                                             CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="import"></a>
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)MapImportDefinition.d2w/REPORT$(d2wVarBase)&amp;specificMapKey=@dtw_rurlescseq(mapKey)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("FHDESCU", "Import Definition")
                  @Format_Column_Header("FFDESCU", "Import Table")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph" $(helpCursor)><span title="$(V_FHIMKY)">$(V_FHDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_FFIFIL)">$(V_FFDESC)</span></td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}