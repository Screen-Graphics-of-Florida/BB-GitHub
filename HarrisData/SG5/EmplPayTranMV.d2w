%FUNCTION(dtw_sql) ManualVoid_Transaction_Overrides (IN  CHAR(64) profileHandle,
				                          CHAR(2)   dataBaseID,
                                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="paytransmvoverrides"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %ROW {
              <tr><td class="dsphdr"> State Tax ID</td>
                  <td class="colalph"> $(V_CKSTID)</td></tr>

              <tr><td class="dsphdr"> SUI ID</td>
                  <td class="colalph"> $(V_CKSUID)</td></tr>

              %if (V_CKSWID != "")
                  <tr><td class="dsphdr"> SWC ID</td>
                      <td class="colalph"> $(V_CKSWID)</td></tr>
              %endif

              %if (V_CKSDID != "")
                  <tr><td class="dsphdr"> SDI ID</td>
                      <td class="colalph"> $(V_CKSDID)</td></tr>
              %endif

              %if (V_CKLID1 != "")
                  <tr><td class="dsphdr"> Local Tax ID 1</td>
                      <td class="colalph"> $(V_CKLID1)</td></tr>
              %endif

              %if (V_CKLID2 != "")
                  <tr><td class="dsphdr"> Local Tax ID 2</td>
                      <td class="colalph"> $(V_CKLID2)</td></tr>
              %endif

              %if (V_CKR401 != ".00")
                  <tr><td class="dsphdr"> Employer 401(k) Match</td>
                      <td class="colalph"> $(V_CKR401)</td></tr>
 	           %endif	

              %if (V_CKD401 != ".00")
                  <tr><td class="dsphdr"> 401(k) Discretionary</td>
                      @Format_Nbr($(V_CKD401), F_CKD401, "2", $(amtEditCode), "", "", "")
                      <td class="colalph"> $(F_CKD401)</td></tr>
 	           %endif	

              <tr><td class="colhdr"> Accrual Type</td>
                  <td class="colhdr"> Process</td>
                  <td class="colhdr"> Hours</td>
                  <td class="colhdr"> Dollars</td></tr>
   			
              <tr><td class="dsphdr"> Vacation</td>
                  <td class="colcode">$(V_CKAVSC)</td>
                  @Format_Nbr($(V_CKACVH), F_CKACVH, "2", $(hrsEditCode), "", "", "")
                  <td class="colnmbr"> $(F_CKACVH)</td>
                  @Format_Nbr($(V_CKACVD), F_CKACVD, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr"> $(F_CKACVD)</td></tr>
   			
              <tr><td class="dsphdr"> Sick</td>
                  <td class="colcode">$(V_CKASSC)</td>
                  @Format_Nbr($(V_CKACSH), F_CKACSH, "2", $(hrsEditCode), "", "", "")
                  <td class="colnmbr"> $(F_CKACSH)</td>
                  @Format_Nbr($(V_CKACSD), F_CKACSD, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr"> $(F_CKACSD)</td></tr>
   			
              %if ((V_CKACMH != ".00")  || (V_CKACMD != ".00"))
                  <tr><td class="dsphdr"> Miscellaneous</td>
                      <td class="colcode">$(V_CKACMS)</td>
                      @Format_Nbr($(V_CKACMH), F_CKACMH, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKACMH)</td>
                      @Format_Nbr($(V_CKACMD), F_CKACMD, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKACMD)</td></tr>
              %endif   			

              %if ((V_CKCOME != ".00")  || (V_CKBNSE != ".00"))
                  <tr><td class="colhdr"> Comm/Bonus Withholding</td>
                      <td class="colhdr"> FIT %</td>
                      <td class="colhdr"> SIT %</td></tr>
   			
                  %if (V_CKCOME != ".00")
                      <tr><td class="dsphdr"> Commission W/H Percent</td>
                          @Format_Nbr(@dtw_rmultiply(V_CKCEFP, "100"), F_CKCEFP, "1", $(pctEditCode), "", "", "")
                          <td class="colnmbr"> $(F_CKCEFP)</td>
                          @Format_Nbr(@dtw_rmultiply(V_CKCESP, "100"), F_CKCESP, "3", $(pctEditCode), "", "", "")
                          <td class="colnmbr"> $(F_CKCESP)</td></tr>
                  %endif   			

                  %if (V_CKBNSE != ".00")
                      <tr><td class="dsphdr"> Bonus W/H Percent</td>
                          @Format_Nbr(@dtw_rmultiply(V_CKBEFP, "100"), F_CKBEFP, "1", $(pctEditCode), "", "", "")
                          <td class="colnmbr"> $(F_CKBEFP)</td>
                          @Format_Nbr(@dtw_rmultiply(V_CKBESP, "100"), F_CKBESP, "3", $(pctEditCode), "", "", "")
                          <td class="colnmbr"> $(F_CKBESP)</td>
                  %endif   			
              %endif   			
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) ManualVoid_Transaction_Deposits (IN  CHAR(64) profileHandle,
				                         CHAR(2)   dataBaseID,
                                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="paytransmvdeposits"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %ROW {
              %if (V_CKPDD1 == "N" && V_CKPDD2 == "N" && V_CKPDD3 == "N" && V_CKPDD4 == "N" && V_CKPDD5 == "N" && V_CKPDD6 == "N" && V_CKPDD7 == "N")
                  <tr><td>No Direct Deposits Are Entered</td></tr>
              %else
                  <tr><td class="colhdr">Account</td>
                      <td class="colhdr">Type</td>
                      <td class="colhdr">Amount</td></tr>

                  %if (V_CKPDD1 == "Y")
                      <tr><td class="colalph">$(V_ACACT1)</td>
                          %if (V_ACTYP1 == "C")
                              @dtw_assign(accountType1, "Checking")
                          %else
                              @dtw_assign(accountType1, "Savings")
                          %endif
                          <td class="colalph">$(accountType1)</td>
                          @Format_Nbr($(V_CKDD01), F_CKDD01, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_CKDD01)</td></tr>
                  %endif

                  %if (V_CKPDD2 == "Y")
                      <tr><td class="colalph">$(V_ACACT2)</td>
                          %if (V_ACTYP2 == "C")
                              @dtw_assign(accountType2, "Checking")
                          %else
                              @dtw_assign(accountType2, "Savings")
                          %endif
                          <td class="colalph">$(accountType2)</td>
                          @Format_Nbr($(V_CKDD02), F_CKDD02, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_CKDD02)</td></tr>
                  %endif

                  %if (V_CKPDD3 == "Y")
                      <tr><td class="colalph">$(V_ACACT3)</td>
                          %if (V_ACTYP3 == "C")
                              @dtw_assign(accountType3, "Checking")
                          %else
                              @dtw_assign(accountType3, "Savings")
                          %endif
                          <td class="colalph">$(accountType3)</td>
                          @Format_Nbr($(V_CKDD02), F_CKDD03, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_CKDD03)</td></tr>
                  %endif

                  %if (V_CKPDD4 == "Y")
                      <tr><td class="colalph">$(V_ACACT4)</td>
                          %if (V_ACTYP4 == "C")
                              @dtw_assign(accountType4, "Checking")
                          %else
                              @dtw_assign(accountType4, "Savings")
                          %endif
                          <td class="colalph">$(accountType4)</td>
                          @Format_Nbr($(V_CKDD04), F_CKDD04, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_CKDD04)</td></tr>
                  %endif

                  %if (V_CKPDD5 == "Y")
                      <tr><td class="colalph">$(V_ACACT5)</td>
                          %if (V_ACTYP5 == "C")
                              @dtw_assign(accountType5, "Checking")
                          %else
                              @dtw_assign(accountType5, "Savings")
                          %endif
                          <td class="colalph">$(accountType5)</td>
                          @Format_Nbr($(V_CKDD05), F_CKDD05, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_CKDD05)</td></tr>
                  %endif

                  %if (V_CKPDD6 == "Y")
                      <tr><td class="colalph">$(V_ACACT6)</td>
                          %if (V_ACTYP6 == "C")
                              @dtw_assign(accountType6, "Checking")
                          %else
                              @dtw_assign(accountType6, "Savings")
                          %endif
                          <td class="colalph">$(accountType6)</td>
                          @Format_Nbr($(V_CKDD06), F_CKDD06, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_CKDD06)</td></tr>
                  %endif

                  %if (V_CKPDD7 == "Y")
                      <tr><td class="colalph">$(V_ACACT7)</td>
                          %if (V_ACTYP7 == "C")
                              @dtw_assign(accountType7, "Checking")
                          %else
                              @dtw_assign(accountType7, "Savings")
                          %endif
                          <td class="colalph">$(accountType7)</td>
                          @Format_Nbr($(V_CKDD07), F_CKDD07, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_CKDD07)</td></tr>
                  %endif
              %endif
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) ManualVoid_Transaction_Taxes (IN  CHAR(64) profileHandle,
				                      CHAR(2)   dataBaseID,
                                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="paytransmvtaxes"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %ROW {
              <tr><th class="colhdr"> Tax Type</th>
                  <th class="colhdr"> Tax ID</th>
                  <th class="colhdr"> Employee Tax</th>
                  <th class="colhdr"> Employer Tax</th>
                  <th class="colhdr"> Taxable Wages</th>
                  <th class="colhdr"> Exempt Wages</th>	
                  <th class="colhdr"> Deferred Wages</th>
              </tr>	
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr"> Federal Tax</td>
                  <td class="colnmbr">&nbsp;</td>
                  @Format_Nbr($(V_CKEFIT), F_CKEFIT, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr"> $(F_CKEFIT)</td>
                  <td class="colnmbr">&nbsp;</td>
                  @Format_Nbr($(V_CKFITW), F_CKFITW, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr"> $(F_CKFITW)</td>
                  @Format_Nbr($(V_CKXFIT), F_CKXFIT, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr"> $(F_CKXFIT)</td>
                  @Format_Nbr($(V_CKDFIT), F_CKDFIT, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr"> $(F_CKDFIT)</td>
              </tr>
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr"> FICA HI Tax</td>
                  <td class="colnmbr">&nbsp;</td>
                  @Format_Nbr($(V_CKEHI), F_CKEHI, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr"> $(F_CKEHI)</td>
                  @Format_Nbr($(V_CKRHI), F_CKRHI, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr"> $(F_CKRHI)</td>
                  @Format_Nbr($(V_CKHIWG), F_CKHIWG, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr"> $(F_CKHIWG)</td>
                  @Format_Nbr($(V_CKXFIC), F_CKXFIC, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr"> $(F_CKXFIC)</td>
                  <td class="colnmbr">&nbsp;</td>
              </tr>
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr"> FICA OASDI Tax</td>
                  <td class="colnmbr">&nbsp;</td>
                  @Format_Nbr($(V_CKEOA), F_CKEOA, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr"> $(F_CKEOA)</td>
                  @Format_Nbr($(V_CKROA), F_CKROA, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr"> $(F_CKROA)</td>
                  @Format_Nbr($(V_CKOASW), F_CKOASW, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr"> $(F_CKOASW)</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr">&nbsp;</td>
              </tr>

              @dtw_assign(totalEmployeeFica, "0")
              @dtw_add(V_CKEHI, V_CKEOA, totalEmployeeFica)
              @dtw_assign(totalEmployerFica, "0")
              @dtw_add(V_CKRHI, V_CKROA, totalEmployerFica)

              %INCLUDE "SetRowClass.icl"
              @Format_Nbr($(totalEmployeeFica), F_totalEmployeeFica, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(totalEmployerFica), F_totalEmployerFica, "2", $(amtEditCode), "", "", "")
              <tr class="$(rowClass)">
                  <td class="colalph">Total FICA Tax</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr"> $(F_totalEmployeeFica)</td>
                  <td class="colnmbr"> $(F_totalEmployerFica)</td>
              </tr>

              %if (($(V_CKRFUI) != ".00")  || ($(V_CKFUIW) != ".00") || ($(V_CKXFUI) != ".00"))
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> FUI Tax</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                      @Format_Nbr($(V_CKRFUI), F_CKRFUI, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKRFUI)</td>
                      @Format_Nbr($(V_CKFUIW), F_CKFUIW, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKFUIW)</td>
                      @Format_Nbr($(V_CKXFUI), F_CKXFUI, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKXFUI)</td>
                      <td class="colnmbr">&nbsp;</td>
                  </tr>
              %endif

              %if ($(V_CKEIC) != ".00")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> EIC</td>
                      <td class="colnmbr">&nbsp;</td>
                      @Format_Nbr($(V_CKEIC), F_CKEIC, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKEIC)</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                  </tr>
              %endif

              %if (($(V_CKSITW) != ".00") || ($(V_CKXSIT) != ".00") || ($(V_CKDSIT) != ".00") || ($(V_CKESIT) != ".00"))
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> State Tax</td>
                      <td class="colcode"> $(V_CKSTID)</td>
                      @Format_Nbr($(V_CKESIT), F_CKESIT, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKESIT)</td>
                      <td class="colnmbr">&nbsp;</td>
                      @Format_Nbr($(V_CKSITW), F_CKSITW, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKSITW)</td>
                      @Format_Nbr($(V_CKXSIT), F_CKXSIT, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKXSIT)</td>
                      @Format_Nbr($(V_CKDSIT), F_CKDSIT, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKDSIT)</td>
                  </tr>
              %endif
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr"> Total SUI Wages</td>
                  <td class="colcode"> $(V_CKSUID)</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr">&nbsp;</td>
                  @Format_Nbr($(V_CKSUIW), F_CKSUIW, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr"> $(F_CKSUIW)</td>
                  @Format_Nbr($(V_CKXSUI), F_CKXSUI, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr"> $(F_CKXSUI)</td>
                  <td class="colnmbr">&nbsp;</td>
              </tr>

              %if (($(V_CKESUI) != ".00") || ($(V_CKESUB) != ".00"))
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> Employee SUI Tax</td>
                      <td class="colnmbr">&nbsp;</td>
                      @Format_Nbr($(V_CKESUI), F_CKESUI, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKESUI)</td>
                      <td class="colnmbr">&nbsp;</td>
                      @Format_Nbr($(V_CKESUB), F_CKESUB, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKESUB)</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                  </tr>
              %endif
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr"> Employer SUI Tax</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr">&nbsp;</td>
                  @Format_Nbr($(V_CKRSUI), F_CKRSUI, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr"> $(F_CKRSUI)</td>
                  @Format_Nbr($(V_CKRSUB), F_CKRSUB, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr"> $(F_CKRSUB)</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr">&nbsp;</td>
              </tr>

              %if (($(V_CKESSR) != ".00") || ($(V_CKESSB) != ".00"))
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> Employee SUI Surtax</td>
                      <td class="colnmbr">&nbsp;</td>
                      @Format_Nbr($(V_CKESSR), F_CKESSR, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKESSR)</td>
                      <td class="colnmbr">&nbsp;</td>
                      @Format_Nbr($(V_CKESSB), F_CKESSB, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKESSB)</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                  </tr>
              %endif

              %if (($(V_CKRSSR) != ".00") || ($(V_CKRSSB) != ".00"))
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> Employer SUI Surtax</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                      @Format_Nbr($(V_CKRSSR), F_CKRSSR, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKRSSR)</td>
                      @Format_Nbr($(V_CKRSSB), F_CKRSSB, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKRSSB)</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                  </tr>
              %endif

              %if (($(V_CKESDI) != ".00") || ($(V_CKRSDI) != ".00"))
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> SDI Tax</td>
                      <td class="colcode"> $(F_CKSDID)</td>
                      @Format_Nbr($(V_CKESDI), F_CKESDI, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKESDI)</td>
                      @Format_Nbr($(V_CKRSDI), F_CKRSDI, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKRSDI)</td>
                      @Format_Nbr($(V_CKSDIW), F_CKSDIW, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKSDIW)</td>
                      @Format_Nbr($(V_CKXSDI), F_CKXSDI, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKXSDI)</td>
                      <td class="colnmbr">&nbsp;</td>
                  </tr>
              %endif

              %if (($(V_CKESWC) != ".00") || ($(V_CKRSWC) != ".00") || ($(V_CKSWCW) != ".00") || ($(V_CKXSWC) != ".00"))
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> SWC Tax</td>
                      <td class="colcode"> $(F_CKSWID)</td>
                      @Format_Nbr($(V_CKESWC), F_CKESWC, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKESWC)</td>
                      @Format_Nbr($(V_CKRSWC), F_CKRSWC, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKRSWC)</td>
                      @Format_Nbr($(V_CKRSDI), F_CKTSWC, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKTSWC)</td>
                      @Format_Nbr($(V_CKXSWC), F_CKXSWC, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKXSWC)</td>
                      <td class="colnmbr">&nbsp;</td>
                  </tr>
              %endif

              %if (($(V_CKELIT) != ".00") || ($(V_CKRLT1) != ".00") || ($(V_CKLITW) != ".00") || ($(V_CKXLIT) != ".00") || ($(V_CKDLIT) != ".00"))
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> Local Tax 1</td>
                      <td class="colcode"> $(V_CKLID1)</td>
                      @Format_Nbr($(V_CKELIT), F_CKELIT, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKELIT)</td>
                      @Format_Nbr($(V_CKRLT1), F_CKRLT1, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKRLT1)</td>
                      @Format_Nbr($(V_CKLITW), F_CKLITW, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKLITW)</td>
                      @Format_Nbr($(V_CKXLIT), F_CKXLIT, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKXLIT)</td>
                      @Format_Nbr($(V_CKDLIT), F_CKDLIT, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKDLIT)</td>
                  </tr>
              %endif

              %if (($(V_CKELT2) != ".00") || ($(V_CKRLT2) != ".00") || ($(V_CKTLT2) != ".00") || ($(V_CKXLT2) != ".00") || ($(V_CKDLT2) != ".00"))
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> Local Tax 2</td>
                      <td class="colcode"> $(V_CKLID2)</td>
                      @Format_Nbr($(V_CKELT2), F_CKELT2, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKELT2)</td>
                      @Format_Nbr($(V_CKRLT2), F_CKRLT2, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKRLT2)</td>
                      @Format_Nbr($(V_CKTLT2), F_CKTLT2, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKTLT2)</td>
                      @Format_Nbr($(V_CKXLT2), F_CKXLT2, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKXLT2)</td>
                      @Format_Nbr($(V_CKDLT2), F_CKDLT2, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr"> $(F_CKDLT2)</td>
                  </tr>
              %endif

              @dtw_assign(totalEmplTax, "0")
              @dtw_add(V_CKEFIT, totalEmplTax, totalEmplTax)
              @dtw_add(V_CKEHI, totalEmplTax, totalEmplTax)
              @dtw_add(V_CKEOA, totalEmplTax, totalEmplTax)
              @dtw_add(V_CKEEIC, totalEmplTax, totalEmplTax)
              @dtw_add(V_CKESIT, totalEmplTax, totalEmplTax)
              @dtw_add(V_CKESUI, totalEmplTax, totalEmplTax)
              @dtw_add(V_CKESUS, totalEmplTax, totalEmplTax)
              @dtw_add(V_CKESDI, totalEmplTax, totalEmplTax)
              @dtw_add(V_CKESWC, totalEmplTax, totalEmplTax)
              @dtw_add(V_CKELIT, totalEmplTax, totalEmplTax)
              @dtw_add(V_CKELT2, totalEmplTax, totalEmplTax)

              @dtw_assign(totalEmployerTax, "0")
              @dtw_add(V_CKRHI, totalEmployerTax, totalEmployerTax)
              @dtw_add(V_CKROA, totalEmployerTax, totalEmployerTax)
              @dtw_add(V_CKRFUI, totalEmployerTax, totalEmployerTax)
              @dtw_add(V_CKRSUI, totalEmployerTax, totalEmployerTax)
              @dtw_add(V_CKRSUS, totalEmployerTax, totalEmployerTax)
              @dtw_add(V_CKRSDI, totalEmployerTax, totalEmployerTax)
              @dtw_add(V_CKRSWC, totalEmployerTax, totalEmployerTax)
              @dtw_add(V_CKRLT1, totalEmployerTax, totalEmployerTax)
              @dtw_add(V_CKRLT2, totalEmployerTax, totalEmployerTax)

              %INCLUDE "SetRowClass.icl"
              <tr><td class="colalph">Total Taxes</td>
                  @Format_Nbr($(totalEmplTax), F_totalEmplTax, "2", $(hrsEditCode), "", "", "")
                  @Format_Nbr($(totalEmployerTax), F_totalEmployerTax, "2", $(hrsEditCode), "", "", "")
                  <td class="colcode"">&nbsp;</td>
                  <td class="colnmbr"> $(F_totalEmplTax)</td>
                  <td class="colnmbr"> $(F_totalEmployerTax)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) ManualVoid_Transaction_Detail (IN  CHAR(64) profileHandle,
				                       CHAR(2)   dataBaseID,
                                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="paytransmvdetail"></a>
      @dtw_assign(displayMaxRowsMsg, "Y")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (TOTAL_ROWS == "0")
              <tr><td class="colalph">ERROR - No Pay Detail Found For This Check</td></tr>
          %else
	       <tr>
	           <th class="colhdr">Date<br>Worked</th>
		   <th class="colhdr">Pay<br>Code</th>
		   <th class="colhdr">Description</th>
		   <th class="colhdr">Hours</th>
		   <th class="colhdr">Units</th>
                  <th class="colhdr">Earnings</th>
                  <th class="colhdr">Pay<br>Rate</th>
                  <th class="colhdr">Shift</th>
                  <th class="colhdr">Department</th>
                  <th class="colhdr">G/L Account</th>
              </tr>
              @dtw_assign(workedHours, "0")
              @dtw_assign(notWorked, "0")
              @dtw_assign(totalUnits, "0")
              @dtw_assign(totalEarnings, "0")
          %endif

          %ROW{


              %INCLUDE "SetRowClass.icl"
              @Format_Date(V_SBDTWK, "D", F_SBDTWK)

	       <tr class="$(rowClass)">
                  <td class="coldate">$(F_SBDTWK)</td>
	   	   <td class="colcode">$(V_SBCODE)</td>
                  @RetPayCodeDesc(profileHandle, dataBaseID, prCompany, prFacility, V_SBCODE, payCodeDesc)
    	           <td class="colalph"><a href="$(homeURL)$(cGIPath)emplPayTranDetailSelect.d2w/report$(d2wVarBase)&amp;detailSequence=@dtw_rurlescseq(V_SBSEQ)" title="View Pay Transaction Detail"> $(payCodeDesc)</a></td>
	           %if(V_SBHRUN == "H")
                      @Format_Nbr($(V_SBHOUR), F_SBHOUR, "2", $(hrsEditCode), "", "", "")
	   	       <td class="colnmbr">$(F_SBHOUR)</td>
                      <td class="colnmbr"></td>
                      %if(V_C2RPHR == "Y")
                          @dtw_add(V_SBHOUR, workedHours, workedHours)
                      %else
                          @dtw_add(V_SBHOUR, notWorked, notWorked)
                      %endif
	           %elif(V_SBHRUN == "U")
                      <td class="colnmbr"></td>
                       @Format_Nbr($(V_SBHOUR), F_SBHOUR, "2", $(qtyEditCode), "", "", "")
                      <td class="colnmbr">$(F_SBHOUR)</td>
	                   @dtw_add(V_SBHOUR, totalUnits, totalUnits)
	           %else
                      <td class="colnmbr"></td>
                      <td class="colnmbr"></td>
	           %endif
	           @dtw_add(V_SBEARN, totalEarnings, totalEarnings)
                  @Format_Nbr($(V_SBEARN), F_SBEARN, "2", $(amtEditCode), "", "", "")
	           <td class="colnmbr">$(F_SBEARN)</td>
                  %if(V_SBOVRT == ".000")
                      @dtw_assign(V_SBOVRT, "")
                  %endif
                  @Format_Nbr($(V_SBOVRT), F_SBOVRT, $(rteNbrDec), $(rteEditCode), "", "", "")
                  <td class="colnmbr">$(V_SBOVRT)</td>
                  <td class="colcode">$(V_SBSHFW)</td>
	           <td class="colcode">$(V_SBDEPT)</td>
	   	   <td class="colalph">$(V_SBACCT)-$(V_SBSACT)</td>
	       </tr>	
          %}
              <tr><td class="colalph">Total Worked Hours</td>
                  @Format_Nbr($(workedHours), F_workedHours, "2", $(hrsEditCode), "", "", "")
                  <td class="colnmbr">$(F_workedHours)</td>
	       %if(notWorked != "0")
                  <td class="colalph">Total Hours Not Worked</td>
                  @Format_Nbr($(notWorked), F_notWorked, "2", $(hrsEditCode), "", "", "")
                  <td class="colnmbr">$(F_notWorked)</td>
	       %endif
              </tr>
	       %if(totalUnits != "0")
                  <tr><td class="colalph">Total Units</td>
                      @Format_Nbr($(totalUnits), F_totalUnits, "2", $(qtyEditCode), "", "", "")
                      <td class="colnmbr"> $(F_totalUnits)</td>
                  </tr>
	       %endif
              <tr><td class="colalph">Total Earnings</td>
                  @Format_Nbr($(totalEarnings), F_totalEarnings, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr"> $(F_totalEarnings)</td></tr>
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,
                                        INOUT CHAR(32000) errVar)

 {%EXEC {HPRPAY_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMTYPE", PAYTYPECODE)
  %if ((sec_05 == "N") || (sec_06 == "N" && PAYTYPECODE == "H") || (sec_07 == "N" && PAYTYPECODE != "H"))
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}
%HTML(DELETE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(maintenanceCode, "D")
  @dtw_assign(edtVar, "")
  @Concat_Field("@@caller", caller)
  @Concat_Field("@@comp", prCompany)
  @Concat_Field("@@facl", prFacility)
  @Concat_Field("@@empl", prEmployee)
  @Concat_Field("@@type", prCKTYPE)
  @Concat_Field("@@sepc", prCKSEPC)
  @dtw_concat(edtVar,"}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      %if(prCKTYPE == "1")
         @dtw_assign(checkType, "Void")
      %elif(prCKTYPE == "2")
         @dtw_assign(checkType, "Manual")
      %elif(prCKTYPE == "3")
         @dtw_assign(checkType, "Regular")
      %endif
      @Format_ConfMsg_Desc(maintenanceCode, "Sep Ck", $(prCKSEPC), "Check Type", $(checkType), "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)emplpaytran.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @DecatErr_Field("@@type", "checktype")       @dtw_assign(deleteError, fieldValue)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)&amp;deleteError=@dtw_rurlescseq(deleteError)">
  %endif
%}