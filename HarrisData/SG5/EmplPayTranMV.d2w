%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "Employee.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "QuickLink.icl"

%Define {
  page_title 	        = "Employee Pay Transaction"
  d2wName              = "EmplPayTranMV.d2w"
  d2wVarBase           = "$(genericVarBase)$(employeeVarBase)&amp;prCKTYPE=@dtw_rurlescseq(prCKTYPE)&amp;prCKSEPC=@dtw_rurlescseq(prCKSEPC)&amp;backHome=@dtw_rurlescseq(backHome)"
  PAYTYPECODE          = ""
  programName          = "HPRSBE"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  DTW_SET_TOTAL_ROWS   = "YES"
  RPT_MAX_ROWS         = "99"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext	        = "1"
  TIPPAYROLL           = ""
  totalPages	        = "0"	
  showError            = "N"
  quickLinkByUser      = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
   @dtw_replace(workURL, "@@prCKTYPE", "@dtw_rurlescseq(prCKTYPE)", "1", "a", workURL)
   @dtw_replace(workURL, "@@prCKSEPC", "@dtw_rurlescseq(prCKSEPC)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @dtw_assign(applicationID, "PR")
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script type="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "EMPLPAYTRANMV")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">

%{ QuickLink Table %}     %INCLUDE "QuickLinkTable.icl"

%{ QuickLink By User %}   %INCLUDE "QuickLinkByUser.icl"

%{ Pay Transaction Header %}
                          @dtw_assign(stmtSQL, "")
                          @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                          @dtw_concat(stmtSQL, " FROM PRCHCK ", stmtSQL)
                          @dtw_concat(stmtSQL, " WHERE CKCOMP=$(prCompany) and CKFACL=$(prFacility) and CKEMPL=$(prEmployee) and CKTYPE='$(prCKTYPE)' and CKSEPC='$(prCKSEPC)'", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @ManualVoid_Transaction_Header(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Begin %}     %INCLUDE "QuickLinkBegLoop.icl"

      %{ paytransmvgrosstonet %}
                              %if (quicklinkRef == "paytransmvgrosstonet")
                                  @dtw_assign(stmtSQL, "")
                                  @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                                  @dtw_concat(stmtSQL, " FROM PRCHCK left outer join PREACH on CKCOMP=ACCOMP and CKFACL=ACFACL and CKEMPL=ACEMPL", stmtSQL)
                                  @dtw_concat(stmtSQL, " WHERE CKCOMP=$(prCompany) and CKFACL=$(prFacility) and CKEMPL=$(prEmployee) and CKTYPE='$(prCKTYPE)' and CKSEPC='$(prCKSEPC)'", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @ManualVoid_Transaction_GrosToNet(profileHandle, dataBaseID, stmtSQL)

      %{ paytransmvsummary %}
                              %elif (quicklinkRef == "paytransmvsummary")
                                  @dtw_assign(stmtSQL, "")
                                  @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                                  @dtw_concat(stmtSQL, " FROM PRCHCK left outer join PREACH on CKCOMP=ACCOMP and CKFACL=ACFACL and CKEMPL=ACEMPL", stmtSQL)
                                  @dtw_concat(stmtSQL, " WHERE CKCOMP=$(prCompany) and CKFACL=$(prFacility) and CKEMPL=$(prEmployee) and CKTYPE='$(prCKTYPE)' and CKSEPC='$(prCKSEPC)'", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @ManualVoid_Transaction_Summary(profileHandle, dataBaseID, stmtSQL)

      %{ paytransmvdeductions %}
                              %elif (quicklinkRef == "paytransmvdeductions")
                                  @dtw_assign(stmtSQL, "")
                                  @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                                  @dtw_concat(stmtSQL, " FROM PRCHCK left outer join PREACH on CKCOMP=ACCOMP and CKFACL=ACFACL and CKEMPL=ACEMPL", stmtSQL)
                                  @dtw_concat(stmtSQL, " WHERE CKCOMP=$(prCompany) and CKFACL=$(prFacility) and CKEMPL=$(prEmployee) and CKTYPE='$(prCKTYPE)' and CKSEPC='$(prCKSEPC)'", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @ManualVoid_Transaction_Deductions(profileHandle, dataBaseID, stmtSQL)

      %{ paytransmvoverrides %}
                              %elif (quicklinkRef == "paytransmvoverrides")
                                  @dtw_assign(stmtSQL, "")
                                  @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                                  @dtw_concat(stmtSQL, " FROM PRCHCK left outer join PREACH on CKCOMP=ACCOMP and CKFACL=ACFACL and CKEMPL=ACEMPL", stmtSQL)
                                  @dtw_concat(stmtSQL, " WHERE CKCOMP=$(prCompany) and CKFACL=$(prFacility) and CKEMPL=$(prEmployee) and CKTYPE='$(prCKTYPE)' and CKSEPC='$(prCKSEPC)'", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @ManualVoid_Transaction_Overrides(profileHandle, dataBaseID, stmtSQL)

      %{ paytransmvdeposits %}
                              %elif (quicklinkRef == "paytransmvdeposits")
                                  @dtw_assign(stmtSQL, "")
                                  @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                                  @dtw_concat(stmtSQL, " FROM PRCHCK left outer join PREACH on CKCOMP=ACCOMP and CKFACL=ACFACL and CKEMPL=ACEMPL", stmtSQL)
                                  @dtw_concat(stmtSQL, " WHERE CKCOMP=$(prCompany) and CKFACL=$(prFacility) and CKEMPL=$(prEmployee) and CKTYPE='$(prCKTYPE)' and CKSEPC='$(prCKSEPC)'", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @ManualVoid_Transaction_Deposits(profileHandle, dataBaseID, stmtSQL)

      %{ paytransmvtaxes %}
                              %elif (quicklinkRef == "paytransmvtaxes")
                                  @dtw_assign(stmtSQL, "")
                                  @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                                  @dtw_concat(stmtSQL, " FROM PRCHCK left outer join PREACH on CKCOMP=ACCOMP and CKFACL=ACFACL and CKEMPL=ACEMPL", stmtSQL)
                                  @dtw_concat(stmtSQL, " WHERE CKCOMP=$(prCompany) and CKFACL=$(prFacility) and CKEMPL=$(prEmployee) and CKTYPE='$(prCKTYPE)' and CKSEPC='$(prCKSEPC)'", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @ManualVoid_Transaction_Taxes(profileHandle, dataBaseID, stmtSQL)

      %{ paytransmvdetail %}
                              %elif (quicklinkRef == "paytransmvdetail")
                                  @dtw_assign(stmtSQL, "")
                                  @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                                  @dtw_concat(stmtSQL, " FROM PRTIME inner join PRCODE on SBCOMP=C2COMP and SBFACL=C2FACL and SBCODE=C2CODE", stmtSQL)
                                  @dtw_concat(stmtSQL, " WHERE SBCOMP=$(prCompany) and SBFACL=$(prFacility) and SBEMPL=$(prEmployee) and SBTYPE='$(prCKTYPE)' and SBSEPC='$(prCKSEPC)'", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @ManualVoid_Transaction_Detail(profileHandle, dataBaseID, stmtSQL)
                              %endif

%{ Quicklink End %}       %INCLUDE "QuickLinkEndLoop.icl"

                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) ManualVoid_Transaction_Header (IN CHAR(64)    profileHandle,
				                      CHAR(2)     dataBaseID,
                                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("CFCOMP=$(prCompany) and CFFACL=$(prFacility)", "HRCOFC", "PCTIP", TIPPAYROLL)
      @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMTYPE", PAYTYPECODE)
      %INCLUDE "ProgSecurityTestView.icl"
      %if (pgmOptAuth=="F")
          %INCLUDE "ProgSecurityError.icl"
      %endif

      %ROW {
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      @Format_Confirm_Desc($(checkType), $(V_CKSEPC), "", "", "", "", confirmDesc)
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="BackHome">$(portalHome)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)$(d2wName)/DELETE$(d2wVarBase)&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                          %endif
                          <a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)prCKSEPC)&amp;formatToPrint=Y&amp;backHome=@dtw_rurlescseq(backHome)" target=_blank>$(formatPrintDesc)</a>
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
              @Ret_Format_EmplName(prCompany, prFacility, prEmployee, UVHRCo, UVHREmpl, "H", F_EmpName)
              <tr><td><h2>$(F_EmpName)</h2></td></tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"
          $(hrTagAttr)

          <table $(contentTable)>
              <tr><td class="dsphdr">Check Number</td>
                  <td class="dspalph">$(V_CKCKNO)</td></tr>
              @Format_Date(V_CKCKDT, "H", F_CKCKDT)
              <tr><td class="dsphdr">Check Date</td>
                  <td class="dspalph">$(F_CKCKDT)</td></tr>
              %if (V_CKRCCD == "H")
                  @dtw_assign(checkType, "Regular")
              %elif (V_CKRCCD == "V")
                  @dtw_assign(checkType, "Void")
              %elif (V_CKRCCD == "M")
                  @dtw_assign(checkType, "Manual/History Adjustment")
              %elif (V_CKRCCD == "4")
                  @dtw_assign(checkType, "Non Elective Contribution")
              %endif
              <tr><td class="dsphdr">Check Type</td>
                  <td class="dspalph">$(checkType)</td>
                  %if (deleteError != "")
                      <td class="dspalph">$(deleteError)</td>
                      @dtw_assign(deleteError, "")
                  %endif
              </tr>
              %if (V_CKSEPC != "")
              <tr><td class="dsphdr">Separate Check</td>
                  <td class="dspalph">$(V_CKSEPC)</td></tr>
              %endif
          </table>
          $(hrTagAttr)
          %INCLUDE "QuickLinkDisplay.icl"
      %}
  %}
%}

%FUNCTION(dtw_sql) ManualVoid_Transaction_GrosToNet (IN  CHAR(64) profileHandle,
				                          CHAR(2)   dataBaseID,
                                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="paytransmvgrosstonet"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %ROW {
              <tr><td class="dsphdr">Gross Pay</td>
                  @Format_Nbr($(V_CKGRSP), F_CKGRSP, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_CKGRSP)</td></tr>

              <tr><td class="dsphdr">Employee Taxes </td>
                  @Format_Nbr(@dtw_radd(V_CKEFIT, @dtw_radd(V_CKETFC, @dtw_radd(V_CKESIT, @dtw_radd(V_CKESDI, @dtw_radd(V_CKESWC, @dtw_radd(V_CKESUI, @dtw_radd(V_CKESSR, @dtw_radd(V_CKELIT, V_CKELT2)))))))), F_totalTax, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_totalTax)</td>
              </tr>

              <tr><td class="dsphdr">Voluntary Deductions </td>
                  @Format_Nbr(@dtw_radd(V_CKD01, @dtw_radd(V_CKD02, @dtw_radd(V_CKD03, @dtw_radd(V_CKD04, @dtw_radd(V_CKD05, @dtw_radd(V_CKD06, @dtw_radd(V_CKD07, @dtw_radd(V_CKD08, @dtw_radd(V_CKD09, @dtw_radd(V_CKD10, @dtw_radd(V_CKD11, @dtw_radd(V_CKD12, @dtw_radd(V_CKD13, @dtw_radd(V_CKD14, @dtw_radd(V_CKD15, @dtw_radd(V_CKD16, @dtw_radd(V_CKD17, @dtw_radd(V_CKD18, @dtw_radd(V_CKD19, V_CKD20))))))))))))))))))), F_totalDed, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_totalDed)</td>
              </tr>

              %if (V_CKFRIN != ".00")
                  <tr><td class="dsphdr">Fringe Benefits </td>
                  @Format_Nbr($(V_CKFRIN), F_CKFRIN, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKFRIN)</td></tr>
              %endif

              %if (V_CKEIC != ".00")
                  <tr><td class="dsphdr">Earned Income Credit</td>
                  @Format_Nbr($(V_CKEIC), F_CKEIC, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKEIC)</td></tr>
              %endif

              %if (V_CKOPNT != ".00")
                  <tr><td class="dsphdr">Nontaxable </td>
                  @Format_Nbr($(V_CKOPNT), F_CKOPNT, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKOPNT)</td></tr>
              %endif

              %if (V_CKCSTP != ".00")
                  <tr><td class="dsphdr">Cash Tips </td>
                  @Format_Nbr($(V_CKCSTP), F_CKCSTP, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKCSTP)</td></tr>
              %endif

              %if (V_CKMEAL != ".00")
                  <tr><td class="dsphdr">Meal Allowance </td>
                  @Format_Nbr($(V_CKMEAL), F_CKMEAL, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKMEAL)</td></tr>
              %endif

              <tr><td class="dsphdr">Net Pay</td>
                  @Format_Nbr($(V_CKNET), F_CKNET, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_CKNET)</td></tr>
          %}

      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) ManualVoid_Transaction_Summary (IN  CHAR(64) profileHandle,
				                          CHAR(2)   dataBaseID,
                                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="paytransmvsummary"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %ROW {
              <tr><td class="colhdr">Description</td>
                  <td class="colhdr">Hours/Units</td>
                  <td class="colhdr">Earnings</td></tr>

                  @dtw_assign(totalHours, "0")
                  @dtw_assign(totalEarnings, "0")

              %if (V_CKREGH != ".00" || V_CKREGE != ".00")
                  <tr><td class="dsphdr">Regular</td>
                      @dtw_add(V_CKREGH, totalHours, totalHours)
                      @dtw_add(V_CKREGE, totalEarnings, totalEarnings)
                      @Format_Nbr($(V_CKREGH), F_CKREGH, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKREGH)</td>
                      @Format_Nbr($(V_CKREGE), F_CKREGE, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKREGE)</td></tr>
              %endif
              %if (V_CKOVTH != ".00" || V_CKOVTE != ".00")
                  <tr><td class="dsphdr">Overtime</td>
                      @dtw_add(V_CKOVTH, totalHours, totalHours)
                      @dtw_add(V_CKOVTE, totalEarnings, totalEarnings)
                      @Format_Nbr($(V_CKOVTH), F_CKOVTH, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKOVTH)</td>
                      @Format_Nbr($(V_CKOVTE), F_CKOVTE, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKOVTE)</td></tr>
              %endif
              %if (V_CKDBLH != ".00" || V_CKDBLE != ".00")
                  <tr><td class="dsphdr">Double Time</td>
                      @dtw_add(V_CKDBLH, totalHours, totalHours)
                      @dtw_add(V_CKDBLE, totalEarnings, totalEarnings)
                      @Format_Nbr($(V_CKDBLH), F_CKDBLH, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKDBLH)</td>
                      @Format_Nbr($(V_CKDBLE), F_CKDBLE, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKDBLE)</td></tr>
              %endif
              %if (V_CKVACH != ".00" || V_CKVACE != ".00")
                  <tr><td class="dsphdr">Vacation</td>
                      @dtw_add(V_CKVACH, totalHours, totalHours)
                      @dtw_add(V_CKVACE, totalEarnings, totalEarnings)
                      @Format_Nbr($(V_CKVACH), F_CKVACH, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKVACH)</td>
                      @Format_Nbr($(V_CKVACE), F_CKVACE, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKVACE)</td></tr>
              %endif
              %if (V_CKHOLH != ".00" || V_CKHOLE != ".00")
                  <tr><td class="dsphdr">Holiday</td>
                      @dtw_add(V_CKHOLH, totalHours, totalHours)
                      @dtw_add(V_CKHOLE, totalEarnings, totalEarnings)
                      @Format_Nbr($(V_CKHOLH), F_CKHOLH, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKHOLH)</td>
                      @Format_Nbr($(V_CKHOLE), F_CKHOLE, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKHOLE)</td></tr>
              %endif
              %if (V_CKSICH != ".00" || V_CKSICE != ".00")
                  <tr><td class="dsphdr">Sick</td>
                      @dtw_add(V_CKSICH, totalHours, totalHours)
                      @dtw_add(V_CKSICE, totalEarnings, totalEarnings)
                      @Format_Nbr($(V_CKSICH), F_CKSICH, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKSICH)</td>
                      @Format_Nbr($(V_CKSICE), F_CKSICE, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKSICE)</td></tr>
              %endif
              %if (V_CKOTHH != ".00" || V_CKOTPT != ".00")
                  <tr><td class="dsphdr">Other Taxable</td>
                      @dtw_add(V_CKOTHH, totalHours, totalHours)
                      @dtw_add(V_CKOTPT, totalEarnings, totalEarnings)
                      @Format_Nbr($(V_CKOTHH), F_CKOTHH, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKOTHH)</td>
                      @Format_Nbr($(V_CKOTPT), F_CKOTPT, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKOTPT)</td></tr>
              %endif
              %if (V_CKOPNT != ".00")
                  <tr><td class="dsphdr">Nontaxable</td>
                      @dtw_add(V_CKOPNT, totalEarnings, totalEarnings)
                      <td class="colnmbr"></td>
                      @Format_Nbr($(V_CKOPNT), F_CKOPNT, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKOPNT)</td></tr>
              %endif
              %if (V_CKFRIN != ".00")
                  <tr><td class="dsphdr">Fringe Benefits</td>
                      @dtw_add(V_CKFRIN, totalEarnings, totalEarnings)
                      <td class="colnmbr"></td>
                      @Format_Nbr($(V_CKFRIN), F_CKFRIN, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKFRIN)</td></tr>
              %endif
              %if (V_CKCOME != ".00")
                  <tr><td class="dsphdr">Commission</td>
                      @dtw_add(V_CKCOME, totalEarnings, totalEarnings)
                      <td class="colnmbr"></td>
                      @Format_Nbr($(V_CKCOME), F_CKCOME, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKCOME)</td></tr>
              %endif
              %if (V_CKBNSE != ".00")
                  <tr><td class="dsphdr">Bonus</td>
                      @dtw_add(V_CKBNSE, totalEarnings, totalEarnings)
                      <td class="colnmbr"></td>
                      @Format_Nbr($(V_CKBNSE), F_CKBNSE, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKBNSE)</td></tr>
              %endif
              %if (V_CKCSTP != ".00")
                  <tr><td class="dsphdr">Cash Tips</td>
                      @dtw_add(V_CKCSTP, totalEarnings, totalEarnings)
                      <td class="colnmbr"></td>
                      @Format_Nbr($(V_CKCSTP), F_CKCSTP, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKCSTP)</td></tr>
              %endif
              %if (V_CKCHTP != ".00")
                  <tr><td class="dsphdr">Charge Tips</td>
                      @dtw_add(V_CKCHTP, totalEarnings, totalEarnings)
                      <td class="colnmbr"></td>
                      @Format_Nbr($(V_CKCHTP), F_CKCHTP, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKCHTP)</td></tr>
              %endif
              %if (V_CKMEAL != ".00")
                  <tr><td class="dsphdr">Meal Allowance</td>
                      @dtw_add(V_CKMEAL, totalEarnings, totalEarnings)
                      <td class="colnmbr"></td>
                      @Format_Nbr($(V_CKMEAL), F_CKMEAL, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKMEAL)</td></tr>
              %endif
              <tr><td class="dsphdr">Total</td>
                  @Format_Nbr($(totalHours), F_totalHours, "2", $(hrsEditCode), "", "", "")
                  <td class="colnmbr">$(F_totalHours)</td>
                  @Format_Nbr($(totalEarnings), F_totalEarnings, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_totalEarnings)</td></tr>

              %if (V_CKGRRC != ".00")
                  <tr><td class="dsphdr">Gross Receipts</td>
                      <td class="colnmbr"></td>
                      @Format_Nbr($(V_CKGRRC), F_CKGRRC, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_CKGRRC)</td></tr>
              %endif

              <tr><td class="colhdr">Description</td></tr>

              %if ((TIPPAYROLL == "Y") && ((PAYTYPECODE == "S") || (PAYTYPECODE == "H")))
                  <tr><td class="dsphdr">Tip Type</td>
                      <td class="colalph">$(V_CKTHTY)</td>
                  </tr>
              %endif

              %if(V_CKWKSW != "")
                  <tr><td class="dsphdr">Override Shift Worked</td>
                      <td class="colalph">$(V_CKWKSW)</td>
                  </tr>
              %endif

              <tr><td class="dsphdr"> Credit Service Weeks</td>
                  @Format_Nbr($(V_CKCRWK), F_CKCRWK, "1", $(amtEditCode), "", "", "")
                  <td class="colalph">$(F_CKCRWK)</td></tr>
   			
              <tr><td class="dsphdr"> Equiv. Days Worked</td>
                  @Format_Nbr($(V_CKEQDY), F_CKEQDY, "0", $(amtEditCode), "", "", "")
                  <td class="colalph"> $(F_CKEQDY)</td></tr>

              %if(V_CKWKDP != "")
                  <tr><td class="dsphdr">Override Department</td>
                      @RtvFldDesc("EADEPT='$(V_CKWKDP)' ", "PREXAC", "EANAME", deptName)
                      @Format_Code(V_CKWKDP, F_CKWKDP)
                      <td class="dspalph">$(deptName)</td>
                      <td class="dspalph">$(F_CKWKDP)</td>
                  </tr>
              %endif

              %if(V_CKWKAC != "0" || V_CKWKSB != "0")
                  <tr><td class="dsphdr">Override Expense Account</td>
                      @dtw_assign(expacct,"")
                      @dtw_concat(expacct,"$(V_CKWKCO)",expacct)
                      @dtw_concat(expacct,"/",expacct)
                      @dtw_concat(expacct,"$(V_CKWKFA)",expacct)
                      @dtw_concat(expacct,"  $(V_CKWKAC)",expacct)
                      @dtw_concat(expacct,"-",expacct)
                      @dtw_concat(expacct,"$(V_CKWKSB)",expacct)
                      <td class="colalph">$(expacct)</td></tr>
              %endif

              %if((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_08 == "Y"))
                  <tr><td class="dsphdr">Override Rate</td>
                      @Format_Nbr($(V_CKWKRT), F_CKWKRT, $(rteNbrDec), $(rteEditCode), "", "", "")
                      <td class="colalph">$(F_CKWKRT)</td></tr>
              %endif

              %if(V_CKWKDT != "0")
                  <tr><td class="dsphdr">Override Date Worked</td>
                      @Format_Date(V_CKWKDT, "D", F_CKWKDT)
                      <td class="colalph">$(F_CKWKDT)</td></tr>
              %endif
          %}
      </table>
      </fieldset>
  %}
%}

