%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Lot List"
  d2wName                 = "LotList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)&amp;apid=@dtw_rurlescseq(apid)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "3"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromWarehouse, 3, 0) &&
                      editNum(document.Chg.toWarehouse, 3, 0) &&
                      editFromToAll(document.Chg.fromWarehouse, document.Chg.toWarehouse, document.Chg.allWarehouse, 3) &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromLotNumber, document.Chg.toLotNumber, document.Chg.allLotNumber, "A"))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "LOTLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromWarehouse")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@sqwh", "sortWarehouse")        @dtw_assign(Err_N1SQWH,  fieldValue)
                                  @DecatErr_Field("@@sqit", "sortItemNumber")        @dtw_assign(Err_N1SQIT,  fieldValue)
                                  @DecatErr_Field("@@sqlt", "sortLotNumber")        @dtw_assign(Err_N1SQLT,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@frwh")  @dtw_assign(V_N1FRWH,  fieldValue)
                                  @Decat_Field("@@towh")  @dtw_assign(V_N1TOWH,  fieldValue)
                                  @Decat_Field("@@alwh")  @dtw_assign(V_N1ALWH,  fieldValue)
                                  @Decat_Field("@@sqwh")  @dtw_assign(V_N1SQWH,  fieldValue)
                                  @Decat_Field("@@frit")  @dtw_assign(V_N1FRIT,  fieldValue)
                                  @Decat_Field("@@toit")  @dtw_assign(V_N1TOIT,  fieldValue)
                                  @Decat_Field("@@alit")  @dtw_assign(V_N1ALIT,  fieldValue)
                                  @Decat_Field("@@sqit")  @dtw_assign(V_N1SQIT,  fieldValue)
                                  @Decat_Field("@@frlt")  @dtw_assign(V_N1FRLT,  fieldValue)
                                  @Decat_Field("@@tolt")  @dtw_assign(V_N1TOLT,  fieldValue)
                                  @Decat_Field("@@allt")  @dtw_assign(V_N1ALLT,  fieldValue)
                                  @Decat_Field("@@sqlt")  @dtw_assign(V_N1SQLT,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}

                                  %if (V_N1ALWH == "ALL")
                                      @dtw_assign(checkedallWarehouse, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallWarehouse, "")
                                  %endif
                                  %if (V_N1ALIT == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_N1ALLT == "ALL")
                                      @dtw_assign(checkedallLotNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallLotNumber, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedallWarehouse, "CHECKED")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallLotNumber, "CHECKED")
                              %endif

                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                              </tr>

                              @SetTextOvr(Err_N1FRWH)
                              %if (textOvr == "") @SetTextOvr(Err_N1SQWH) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Warehouse Number</span></td>
                                  <td class="inputnmbr"><input name="fromWarehouse" value="$(V_N1FRWH)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromWarehouse&amp;fldDesc=fwarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fwarehouseName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toWarehouse" value="$(V_N1TOWH)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toWarehouse&amp;fldDesc=twarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="twarehouseName" type="hidden"></td>
                                  <td class="inputalph"><input name="allWarehouse" value='ALL' $(checkedallWarehouse) type="checkbox" onClick="if (this.checked) this.form.fromWarehouse.value='', this.form.toWarehouse.value='';"></td>
                                  @Build_Sort_Select("sortWarehouse", "$(V_N1SQWH)")
                              </tr>
                              @DspErrMsg(Err_N1SQWH)

                              @SetTextOvr(Err_N1FRIT)
                              %if (textOvr == "") @SetTextOvr(Err_N1SQIT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N1FRIT)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N1TOIT)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                                  @Build_Sort_Select("sortItemNumber", "$(V_N1SQIT)")
                              </tr>
                              @DspErrMsg(Err_N1SQIT)

                              @SetTextOvr(Err_N1FRLT)
                              %if (textOvr == "") @SetTextOvr(Err_N1SQLT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Lot Number</span></td>
                                  <td class="inputalph"><input name="fromLotNumber" value="$(V_N1FRLT)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(cGIPath)LotSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldLot=fromLotNumber&amp;fldItem=fItem&amp;fldWhs=fWhs" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fItem" type="hidden"><input name="fWhs" type="hidden"></td>
                                  <td class="inputalph"><input name="toLotNumber" value="$(V_N1TOLT)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(cGIPath)LotSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldLot=toLotNumber&amp;fldItem=fItem&amp;fldWhs=fWhs" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fItem" type="hidden"><input name="fWhs" type="hidden"></td>
                                  <td class="inputalph"><input name="allLotNumber" value='ALL' $(checkedallLotNumber) type="checkbox" onClick="if (this.checked) this.form.fromLotNumber.value='', this.form.toLotNumber.value='';"></td>
                                  @Build_Sort_Select("sortLotNumber", "$(V_N1SQLT)")
                              </tr>
                              @DspErrMsg(Err_N1SQLT)

                          </table>

                          @dtw_assign(envProgram, "HHDLNL")
                          @dtw_assign(envPrinter, "HHDLNLPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HHDLNS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allWarehouse)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(fromLotNumber)
  @dtw_mUPPERCASE(toLotNumber)
  @dtw_mUPPERCASE(allLotNumber)

  @dtw_assign(fromWarehouse,@dtw_rstrip(fromWarehouse))
  @dtw_assign(toWarehouse,@dtw_rstrip(toWarehouse))
  @dtw_assign(sortWarehouse,@dtw_rstrip(sortWarehouse))
  @dtw_assign(sortItemNumber,@dtw_rstrip(sortItemNumber))
  @dtw_assign(sortLotNumber,@dtw_rstrip(sortLotNumber))


  %if (allWarehouse != "ALL")
      @dtw_assign(allWarehouse, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allLotNumber != "ALL")
      @dtw_assign(allLotNumber, "")
  %endif


  @dtw_assign(edtVar, "")
  @Concat_Field("@@apid", apid)
  @Concat_Field("@@frwh", fromWarehouse)
  @Concat_Field("@@towh", toWarehouse)
  @Concat_Field("@@alwh", allWarehouse)
  @Concat_Field("@@sqwh", sortWarehouse)
  @Concat_Field("@@frit", fromItemNumber)
  @Concat_Field("@@toit", toItemNumber)
  @Concat_Field("@@alit", allItemNumber)
  @Concat_Field("@@sqit", sortItemNumber)
  @Concat_Field("@@frlt", fromLotNumber)
  @Concat_Field("@@tolt", toLotNumber)
  @Concat_Field("@@allt", allLotNumber)
  @Concat_Field("@@sqlt", sortLotNumber)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}