%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "$(vendCustHdg) Item/Warehouse Maintenance"
  d2wName                 = "VendCustItemWhsMaint.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;vendCustNumber=@dtw_rurlescseq(vendCustNumber)&amp;vendCustName=@dtw_rurlescseq(vendCustName)&amp;vendCustFlag=@dtw_rurlescseq(vendCustFlag)&amp;vendCustId=@dtw_rurlescseq(vendCustId)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;itemDescr=@dtw_rurlescseq(itemDescr)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;whsNumber=@dtw_rurlescseq(whsNumber)&amp;warehouseName=@dtw_rurlescseq(warehouseName)&amp;maintenanceCode=D"
  programName             = "HHDVCW"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  helpExt                 = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (vendCustFlag == "C")
      @dtw_assign(helpExt, " (Customer)")
      @dtw_assign(customerNumber, $(vendCustNumber))
      @CustomerUserView(profileHandle, dataBaseID, userPass, customerNumber, " ")
  %else
      @dtw_assign(helpExt, " (Vendor)")
      @dtw_assign(vendorNumber, $(vendCustNumber))
      @VendorUserView(profileHandle, dataBaseID, userPass, vendorNumber)
  %endif

  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  function validate(chgForm) {
                      if (editNum(document.Chg.whsNumber, 3, 0) &&
                          editNum(document.Chg.leadTime, 3, 0) &&
                          editNum(document.Chg.orderNumber, 8, 0) &&
                          editNum(document.Chg.lineNumber, 3, 0) &&
                          editNum(document.Chg.quantity, 9, 4) &&
                          editNum(document.Chg.costPrice, 8, 5) &&
                          editdate(document.Chg.requiredDate) &&
                          editdate(document.Chg.shippedDate))
                          return true;
                  }
	           %INCLUDE "numedit.icl"
                  %INCLUDE "dateedit.icl"
                  %INCLUDE "calendar.icl"
                  function confirmDelete() {return confirm("$(delRecordConf)")}
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "VENDCUSTITEMWHSMAINT")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "Select * From HDVCIW Where WIID=$(vendCustId) and WIWHS=$(whsNumber)", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (vendCustFlag == "C")
          @dtw_assign(costHdg, "Price")
          @dtw_assign(dateHdg, "Shipped Date")
          @dtw_assign(vendCustHdg, "Customer")
      %else
          @dtw_assign(costHdg, "Cost")
          @dtw_assign(dateHdg, "Received Date")
          @dtw_assign(vendCustHdg, "Vendor")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          @Format_Header($(vendCustHdg), $(vendCustName), $(vendCustNumber))
          @Format_Header("Item", $(itemDescr), $(itemNumber))
      </table>

      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "whsNumber")
                      %else
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @dtw_assign(focusField, "")
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@id@@", "vendCustId")   @dtw_assign(Err_WIID,   fieldValue)
                          @DecatErr_Field("@@whs@", "whsNumber")    @dtw_assign(Err_WIWHS,  fieldValue)
                          @DecatErr_Field("@@lt@@", "leadTime")     @dtw_assign(Err_WILT,   fieldValue)
                          @DecatErr_Field("@@lor#", "orderNumber")  @dtw_assign(Err_WILOR#, fieldValue)
                          @DecatErr_Field("@@lorl", "lineNumber")   @dtw_assign(Err_WILORL, fieldValue)
                          @DecatErr_Field("@@lrsq", "quantity")     @dtw_assign(Err_WILRSQ, fieldValue)
                          @DecatErr_Field("@@lorc", "costPrice")    @dtw_assign(Err_WILORC, fieldValue)
                          @DecatErr_Field("@@lord", "requiredDate") @dtw_assign(Err_WILORD, fieldValue)
                          @DecatErr_Field("@@lrsd", "shippedDate")  @dtw_assign(Err_WILRSD, fieldValue)
                      %endif

                      @Decat_Field("@@id@@")   @dtw_assign(V_WIID,   fieldValue)
                      @Decat_Field("@@whs@")   @dtw_assign(V_WIWHS,  fieldValue)
                      @Decat_Field("@@lt@@")   @dtw_assign(V_WILT,   fieldValue)
                      @Decat_Field("@@lor#")   @dtw_assign(V_WILOR#, fieldValue)
                      @Decat_Field("@@lorl")   @dtw_assign(V_WILORL, fieldValue)
                      @Decat_Field("@@lrsq")   @dtw_assign(V_WILRSQ, fieldValue)
                      @Decat_Field("@@lorc")   @dtw_assign(V_WILORC, fieldValue)
                      @Decat_Field("@@lord")   @dtw_assign(V_WILORD, fieldValue)
                      @Decat_Field("@@lrsd")   @dtw_assign(V_WILRSD, fieldValue)
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(V_WIWHS, "0")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "whsNumber")
                      @dtw_assign(V_WIWHS,  "0")
                      @DateInputFromCYMD(V_WILORD)
                      @DateInputFromCYMD(V_WILRSD)

                  %else
                      %if (vendCustFlag == "V")
                          @dtw_assign(focusField, "leadTime")
                      %else
                          @dtw_assign(focusField, "orderNumber")
                      %endif
                      @DateInputFromCYMD(V_WILORD)
                      @DateInputFromCYMD(V_WILRSD)
                  %endif

                  @Default_Zero(V_WIWHS)
                  @RtvFldDesc("WHWHS=$(V_WIWHS)", "HDWHSM", "WHWHNM", fieldDesc)
                  @SetTextOvr(Err_WIWHS)
                  <tr><td class="dsphdr"><span $(textOvr)>Warehouse Number</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="whsNumber" type="text" value="$(V_WIWHS)" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=whsNumber&amp;fldDesc=warehouseName" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input name="warehouseName" type="text" value="$(fieldDesc)" size="30" maxlength="30"></td>
                      %else
                          <td class="inputnmbr"><input name="whsNumber" type="hidden" value="$(V_WIWHS)" size="3" maxlength="3">$(V_WIWHS) &nbsp; $(fieldDesc)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_WIWHS)

                  %if (vendCustFlag == "V")
                      @SetTextOvr(Err_WILT)
                      <tr><td class="dsphdr"><span $(textOvr)>Lead Time</span></td>
                          <td class="inputnmbr"><input name="leadTime" type="text" value="$(V_WILT)" size="3" maxlength="3"></td>
                      </tr>
                      @DspErrMsg(Err_WILT)
                  %else
                      <tr><td class="inputnmbr"><input type="hidden" name="leadTime" value="$(V_WILT)"></td></tr>
                  %endif
              </table>

              <fieldset class="legendBody">
                  <legend class="legendTitle">Last Order</legend>
                  <table $(contentTable)>
                      @SetTextOvr(Err_WILOR#)
                      <tr><td class="dsphdr"><span $(textOvr)>Number</span></td>
                          <td class="inputnmbr"><input name="orderNumber" type="text" value="$(V_WILOR#)" size="8" maxlength="8"></td>
                      </tr>
                      @DspErrMsg(Err_WILOR#)
    	   		
                      @SetTextOvr(Err_WILORL)
                      <tr><td class="dsphdr"><span $(textOvr)>Line Number</span></td>
                          <td class="inputnmbr"><input name="lineNumber" type="text" value="$(V_WILORL)" size="3" maxlength="3"></td>
                      </tr>
                      @DspErrMsg(Err_WILORL)
    	   		
                      @SetTextOvr(Err_WILRSQ)
                      <tr><td class="dsphdr"><span $(textOvr)>Quantity</span></td>
                          <td class="inputnmbr"><input name="quantity" type="text" value="$(V_WILRSQ)" size="15" maxlength="15"></td>
                      </tr>
                      @DspErrMsg(Err_WILRSQ)
    	   		
                      @SetTextOvr(Err_WILORC)
                      <tr><td class="dsphdr"><span $(textOvr)>$(costHdg)</span></td>
                          <td class="inputnmbr"><input name="costPrice" type="text" value="$(V_WILORC)" size="15" maxlength="15"></td>
                      </tr>
                      @DspErrMsg(Err_WILORC)
    	   		
                      @SetTextOvr(Err_WILORD)
                      <tr><td class="dsphdr"><span $(textOvr)>Required Date</span></td>
                          <td class="inputnmbr"><input name="requiredDate" type="text" value="$(V_WILORD)" size="6" maxlength="6">
                          <a href="javascript:calWindow('requiredDate');">$(calendarImage)</a></td>
                      </tr>
                      @DspErrMsg(Err_WILORD)
    	   		
                      @SetTextOvr(Err_WILRSD)
                      <tr><td class="dsphdr"><span $(textOvr)>$(dateHdg)</span></td>
                          <td class="inputnmbr"><input name="shippedDate" type="text" value="$(V_WILRSD)" size="6" maxlength="6">
                          <a href="javascript:calWindow('shippedDate');">$(calendarImage)</a></td>
                      </tr>
                      @DspErrMsg(Err_WILRSD)
                  </table>
              </fieldset>
          %}	

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDVCW_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(leadTime,@dtw_rstrip(leadTime))
  @dtw_assign(orderNumber,@dtw_rstrip(orderNumber))
  @dtw_assign(lineNumber,@dtw_rstrip(lineNumber))
  @dtw_assign(quantity,@dtw_rstrip(quantity))
  @dtw_assign(costPrice,@dtw_rstrip(costPrice))
  @dtw_assign(requiredDate,@dtw_rstrip(requiredDate))
  @dtw_assign(shippedDate,@dtw_rstrip(shippedDate))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@id@@", vendCustId)
  @Concat_Field("@@item", itemNumber)
  @Concat_Field("@@whs@", whsNumber)
  @Concat_Field("@@lt@@", leadTime)
  @Concat_Field("@@lor#", orderNumber)
  @Concat_Field("@@lorl", lineNumber)
  @Concat_Field("@@lrsq", quantity)
  @Concat_Field("@@lorc", costPrice)
  @Concat_Field("@@lord", requiredDate)
  @Concat_Field("@@lrsd", shippedDate)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  @Default_Zero(whsNumber)
  @RtvFldDesc("WHWHS=$(whsNumber)", "HDWHSM", "WHWHNM", fieldDesc)
  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(fieldDesc), $(whsNumber), "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)VendCustItemWhs.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@id@@", "vendCustId")
      @Format_ConfMsg_Desc("", $(fieldDesc), $(whsNumber), "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)VendCustItemWhs.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}