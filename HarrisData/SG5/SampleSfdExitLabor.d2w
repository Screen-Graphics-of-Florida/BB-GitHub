%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Sample Shop Floor Dispatch Labor Exit"
  d2wName                 = "SampleSfdExitLabor.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;mfgOrder=@dtw_rurlescseq(mfgOrder)&amp;seqNumber=@dtw_rurlescseq(seqNumber)&amp;touchScreen=Y"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
  formatToPrint           = ""	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %if (touchScreen == "Y")
              <link rel=stylesheet type="text/css" href="$(homeURL)$(homePath)HDSTouchScreen.css">
          %endif
          <script type="text/javascript">
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " HDMLPM ", fileSQL)
                      @dtw_concat(selectSQL, "LPPLT=$(plantNumber) and LPORD='$(mfgOrder)' and LPSEQN='$(seqNumber)'  ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      @labor_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) labor_Query (IN  CHAR(64)    profileHandle,
                                    CHAR(2)     dataBaseID,
                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td></tr>
      </table>

      $(hrTagAttr)

      <table $(contentTable)>
          %ROW {
              @RtvFldDesc("PLPLNT=$(V_LPPLT)", "HDPLNT", "PLNAME", plantName)
              <tr><td class="dsphdr">Plant</td>
                  <td class="dspnmbr">$(V_LPPLT)</td>
                  <td class="dspalph">$(plantName)</td>
              </tr>

              <tr><td class="dsphdr">Mfg Order</td>
                  <td class="dspalph">$(V_LPORD)</td>
                  <td class="dspalph">&nbsp;</td>
              </tr>

              <tr><td class="dsphdr">Rtg Seqn</td>
                  <td class="dspalph">$(V_LPSEQN)</td>
                  <td class="dspalph">&nbsp;</td>
              </tr>
          %}
      </table>
      $(hrTagAttr)	
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}