%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Document Comment Search"
  d2wName                 = "DocumentCommentSearch.d2w"
  d2wVarBase              = "$(genericVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "9999"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "9999"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
%}

%FUNCTION(DTW_directcall) Get_Document_Comments (INOUT CHAR(2)      documentApplication,
				      	                CHAR(3)      documentType,
				      	                CHAR(1)      headerTrailer,
				                        char(32000)  comment)
{%EXEC {HHDDCM_P.PGM %}
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select HDDCMT.*,DODESC ", stmtSQL)
                      @dtw_concat(fileSQL, " HDDCMT ", fileSQL)
                      @dtw_concat(fileSQL, "        inner join HDDOCT on DCAPID=DOAPID and DCDOCT=DODOCT ", fileSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By DCDOCT,DCAPID,DCHT,DCSEQ# ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @CommentSearch_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
     </body>
  </html>
%}

%FUNCTION(dtw_sql) CommentSearch_Query (IN CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(commentType) $(page_title)</h1></td>
              <td class="toolbar">
                  %INCLUDE "CloseWindow.icl"
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>

      $(searchhrTagAttr)

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %if (V_DCAPID != H_DCAPID || V_DCDOCT != H_DCDOCT || V_DCHT != H_DCHT)
                  %if (H_DCDOCT != "")
                      </table>
                  %endif
                  @RtvFldDesc("DCAPID='$(V_DCAPID)' and DCDOCT='$(V_DCDOCT)' and DCHT='$(V_DCHT)'", "HDDCMT", "char(count(*))", cmtCount)
                  @Get_Document_Comments(V_DCAPID, V_DCDOCT, V_DCHT, comment)
                  @dtw_assign(H_DCAPID, V_DCAPID)
                  @dtw_assign(H_DCDOCT, V_DCDOCT)
                  @dtw_assign(H_DCHT, V_DCHT)
                  %if (V_DCHT == "H")
                      @dtw_assign(htDesc, "Header Comments")
                  %else
                      @dtw_assign(htDesc, "Trailer Comments")
                  %endif
                  @dtw_assign(F_DCAPID, "")
                  %if (V_DCAPID != "")
                      @Format_Code("$(V_DCAPID)", F_DCAPID)
                  %endif
                  @Format_Code(V_DCDOCT, F_DCDOCT)
                      <table $(contentTable)>
                      <tr><td><h2>$(V_DODESC) &nbsp; $(F_DCDOCT) &nbsp; $(htDesc) &nbsp; $(F_DCAPID)</h2></td></tr>
                      <tr><td><textarea name="comments" readonly ROWS=$(cmtCount) COLS=60 WRAP="hard">$(comment)</textarea></td></tr>
              %endif
          %}
      </table>
      $(searchhrTagAttr)
      %INCLUDE "CloseWindow.icl"
      %INCLUDE "Copyright.icl"
  %}
%}
%MACRO_FUNCTION Display_Comments () {	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(contentTable)>
              <tr valign="top">
                  <td>
                      %if (commentFile == "HDCCMT")
                          @Get_Customer_Comments(profileHandle, dataBaseID, vendCustFlag, customerNumber, fromDocument, headerTrailer, comment)
                      %elif (commentFile == "HDIMXD")
                          @Get_Item_Comments(profileHandle, dataBaseID, itemNumber, fromDocument, comment)
                      %else
                          @RtvFldDesc("VCVCF='C' and VCVNCS=$(customerNumber) and VCITEM='$(itemNumber)'", "HDVCIT", "char(VCID)", customerIDNumber)
                          @Get_CustItem_Comments(profileHandle, dataBaseID, customerIDNumber, fromDocument, comment)
                      %endif
                      <table $(contentTable)>
                          <tr><td><h1>$(page_title)</h1></td>
                              <td class="toolbar">
                                  <a href="$(homeURL)$(cGIPath)$(d2wName)/SELECT$(d2wVarBase)&amp;fromDocument=@dtw_rurlescseq(fromDocument)&amp;commentFile=@dtw_rurlescseq(commentFile)" title="Select Comments">$(copyImageLrg)</a>
                                  %INCLUDE "CloseWindow.icl"
                              </td>
                          </tr>
                      </table>
                      <table $(contentTable)>
                          @Format_Header("Customer", $(customerName), $(customerNumber))
                          @Format_Header("Document", $(docDescription), $(documentType))
                          %if (itemNumber != "")
                              @Format_Header("Item", $(itemDescription), $(itemNumber))
                          %endif
                      </table>
                      <table $(contentTable)>
                          <tr align="center"><td><h2>$(fromDocumentDesc)</h2></td></tr>
                          <tr><td><textarea ROWS=20 COLS=60 WRAP="hard">$(comment)</textarea></td></tr>
                      </table>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(VIEW) {
  %INCLUDE "setLibraryList.icl"
  @Display_Comments ()
%}

%HTML(SELECT){
  %INCLUDE "setLibraryList.icl"
  @Select_Comments(profileHandle, dataBaseID, commentFile, fromDocument, documentType, customerNumber, orderControlNumber, itemNumber, lineNumber)

  <script TYPE="text/javascript">
      opener.location.href=opener.location.href;
      window.close()
  </script>
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "DODESCU,DODOCT")
      @DTW_ASSIGN(orderByDisplay, "Description, Document")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "document")
      %if (orderBy == "DODOCT")
          @DTW_ASSIGN(orderBy, "DODOCT DESC")
          @DTW_ASSIGN(orderByDisplay, "Document (descending)")
      %else
          @DTW_ASSIGN(orderBy, "DODOCT")
          @DTW_ASSIGN(orderByDisplay, "Document")
      %endif
  %elif (sequence == "description")
      %if (orderBy == "DODESCU,DODOCT")
          @DTW_ASSIGN(orderBy, "DODESCU DESC,DODOCT")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Document")
      %else
          @DTW_ASSIGN(orderBy, "DODESCU,DODOCT")
          @DTW_ASSIGN(orderByDisplay, "Description, Document")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("DODOCT", "Document", $(srchDoc), "U", operDoc, "A")
  @Build_WildCard ("upper(DODESC)", "Description", $(srchDesc), "U", operDesc, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}