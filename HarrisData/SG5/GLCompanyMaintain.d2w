%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "G/L Company Maintenance"
  d2wName                 = "GLCompanyMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;glcompany=@dtw_rurlescseq(glcompany)&amp;glcompanyname=@dtw_rurlescseq(glcompanyname)&amp;maintenanceCode=D"
  programName             = "HHDCOU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  V_CTCCLO                = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
	       %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.glcompany.value =="" ||
                      document.Chg.glcompanyname.value =="" ||
                      document.Chg.currentperiod =="")
                     {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.glcompany, 2, 0) &&
                      %if (V_CTCCLO == "Y")
                          editNum(document.Chg.currentperiod, 5, 0) &&
                          editdate(document.Chg.lastperiodclose) &&
                      %endif
                      editdate(document.Chg.datestarted) &&
                      editdate(document.Chg.dateoutofbusiness))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "GLCOMPANYMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " HDCOMP ", fileSQL)
                          @dtw_concat(selectSQL, " COCO = $(glcompany) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=155")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" NAME="Chg" METHOD=POST ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "glcompany")
                      %else
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @dtw_assign(focusField, "")
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@co@@", "glcompany")         @dtw_assign(Err_COCO,   fieldValue)
                          @DecatErr_Field("@@name", "glcompanyname")     @dtw_assign(Err_CONAME, fieldValue)
                          @DecatErr_Field("@@glcp", "currentperiod")     @dtw_assign(Err_COGLCP, fieldValue)
                          @DecatErr_Field("@@lpdc", "lastperiodclose")   @dtw_assign(Err_COLPDC, fieldValue)
                          @DecatErr_Field("@@user", "userprofile")       @dtw_assign(Err_COUSER, fieldValue)
                          @DecatErr_Field("@@dtes", "datestarted")       @dtw_assign(Err_CODTES, fieldValue)
                          @DecatErr_Field("@@dtde", "dateoutofbusiness") @dtw_assign(Err_CODTDE, fieldValue)
                      %endif

                      @Decat_Field("@@co@@")   @dtw_assign(V_COCO,   fieldValue)
                      @Decat_Field("@@name")   @dtw_assign(V_CONAME, fieldValue)
                      @Decat_Field("@@glcp")   @dtw_assign(V_COGLCP, fieldValue)
                      @Decat_Field("@@lpdc")   @dtw_assign(V_COLPDC, fieldValue)
                      @Decat_Field("@@user")   @dtw_assign(V_COUSER, fieldValue)
                      @Decat_Field("@@dtes")   @dtw_assign(V_CODTES, fieldValue)
                      @Decat_Field("@@dtde")   @dtw_assign(V_CODTDE, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          %if (V_CTCCLO == "Y")
                              @RtvFldDesc("CTCCLO='Y'", "GLCTRL", "CTGLCP", V_COGLCP)
                              @PeriodInputFromCYP(V_COGLCP)
                          %endif
                          @dtw_assign(focusField, "glcompany")
                      %endif
                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_COCO,  "")
                      @DateInputFromCYMD(V_COLPDC)
                      @DateInputFromCYMD(V_CODTES)
                      @DateInputFromCYMD(V_CODTDE)
                      @PeriodInputFromCYP(V_COGLCP)
                      @dtw_assign(focusField, "glcompany")

                  %elif (maintenanceCode != "A")
                      @DateInputFromCYMD(V_COLPDC)
                      @DateInputFromCYMD(V_CODTES)
                      @DateInputFromCYMD(V_CODTDE)
                      @PeriodInputFromCYP(V_COGLCP)
                      @dtw_assign(focusField, "glcompanyname")
                  %endif

                  @SetTextOvr(Err_COCO)
                  <tr><td class="dsphdr"><span $(textOvr)>Company Number</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="glcompany" type="text" value="$(V_COCO)" size="2" maxlength="2"> $(reqFieldChar) </td>
                      %else
                          <td class="inputnmbr"><input name="glcompany" type="hidden" value="$(V_COCO)" size="2" maxlength="2">$(V_COCO)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_COCO)

                  @SetTextOvr(Err_CONAME)
                  <tr><td class="dsphdr"><span $(textOvr)>Name</span></td>
                      <td class="inputalph"><input name="glcompanyname" type="text" value="$(V_CONAME)" size="30" maxlength="30"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_CONAME)
    			
                  %if (V_CTCCLO == "Y")
                      @SetTextOvr(Err_COGLCP)
                      <tr><td class="dsphdr"><span $(textOvr)>Current Accounting Period</span></td>
                          <td class="inputnmbr"><input name="currentperiod" type="text" value="$(V_COGLCP)" size="5" maxlength="5"> $(reqFieldChar) </td>
                      </tr>
                      @DspErrMsg(Err_COGLCP)

                      @SetTextOvr(Err_COLPDC)
                      <tr><td class="dsphdr"><span $(textOvr)>Last Period Close Date</span></td>
                          <td class="inputnmbr"><input name="lastperiodclose" type="text" value="$(V_COLPDC)" size="6" maxlength="6">
        		       <a href="javascript:calWindow('lastperiodclose');">$(calendarImage)</a></td>
                      </tr>
                      @DspErrMsg(Err_COLPDC)
                  %endif

                  @SetTextOvr(Err_COUSER)
                  <tr><td class="dsphdr"><span $(textOvr)>User Profile</span></td>
                      <td class="inputalph"><input name="userprofile" type="text" value="$(V_COUSER)" size="10" maxlength="10"></td>
                  </tr>
                  @DspErrMsg(Err_COUSER)
	              	
                  @SetTextOvr(Err_CODTES)
                  <tr><td class="dsphdr"><span $(textOvr)>Date Started</span></td>
                      <td class="inputnmbr"><input name="datestarted" type="text" value="$(V_CODTES)" size="6" maxlength="6">
                      <a href="javascript:calWindow('datestarted');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_CODTES)

                  @SetTextOvr(Err_CODTDE)
                  <tr><td class="dsphdr"><span $(textOvr)>Date Out Of Business</span></td>
                      <td class="inputnmbr"><input name="dateoutofbusiness" type="text" value="$(V_CODTDE)" size="6" maxlength="6">
                      <a href="javascript:calWindow('dateoutofbusiness');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_CODTDE)
              %}
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDCOU_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @RtvFldDesc("CTCCLO='Y'", "GLCTRL", "CTCCLO", V_CTCCLO)
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @dtw_mUPPERCASE(userprofile)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@co@@", glcompany)
  @Concat_Field("@@name", glcompanyname)
  @Concat_Field("@@glcp", currentperiod)
  @Concat_Field("@@lpdc", lastperiodclose)
  @Concat_Field("@@user", userprofile)
  @Concat_Field("@@dtes", datestarted)
  @Concat_Field("@@dtde", dateoutofbusiness)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(glcompanyname), $(glcompany), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@co@@", "glcompany")   @dtw_assign(confMessage, "$(glcompanyname) [$(glcompany)]<br>$(fieldValue)")
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=155&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;glcompany=@dtw_rurlescseq(glcompany)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
