%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SalesmanMaintain.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Salesman Maintenance"
  d2wName                 = "SalesmanMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromSel=@dtw_rurlescseq(fromSel)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;salesmanNumber=@dtw_rurlescseq(salesmanNumber)&amp;salesmanName=@dtw_rurlescseq(salesmanName)&amp;maintenanceCode=D"
  programName             = "HHDSLU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (maintenanceCode == "A")
      @dtw_assign(userPass, "Y")
  %else
      @SalesmanUserView(profileHandle, dataBaseID, userPass, salesmanNumber)
  %endif
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                      if (document.Chg.salesmanNumber.value =="" ||
                          document.Chg.salesmanName.value =="" ||
                          document.Chg.addressLineOne.value =="" ||
                          document.Chg.city.value ==""
                          %if (V_HDFORN == "N")
                              || document.Chg.state.value ==""
                              || document.Chg.zip.value ==""
                          %endif
                          )
                             {alert("$(reqFieldError)"); return false;}
                      if (editNum(document.Chg.salesmanNumber, 3, 0) &&
                          editNum(document.Chg.phoneNumber, 11, 0) &&
                          editNum(document.Chg.commissionPercent, 3, 4))
                          return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
	           %INCLUDE "numedit.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "SALESMANMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, " Select SMSLSM, SMSNA1, SMSNA2, SMSNA3, SMSNA4, SMSCTY, SMST, SMZIP, ", stmtSQL)
                              @dtw_concat(stmtSQL, " SMPHON, SMALPH, SMREGN, SMCTRY, SMSCPT, SMSCPC ", stmtSQL)
                              @dtw_concat(stmtSQL, " From HDSLSM Where SMSLSM = $(salesmanNumber)", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (fromSel == "Y")
          @dtw_assign(backURL, "$(homeURL)$(cGIPath)SalesmanSelect.d2w/REPORT$(genericVarBase)&amp;salesmanNumber=@dtw_rurlescseq(salesmanNumber)&amp;salesmanName=@dtw_rurlescseq(salesmanName)")
      %else
          @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
          %if (backURL == "")
              @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=101")
          %endif
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "salesmanNumber")
                      %else
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @dtw_assign(focusField, "")
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@slsm", "salesmanNumber")    @dtw_assign(Err_SMSLSM, fieldValue)
                          @DecatErr_Field("@@sna1", "salesmanName")      @dtw_assign(Err_SMSNA1, fieldValue)
                          @DecatErr_Field("@@sna2", "addressLineOne")    @dtw_assign(Err_SMSNA2, fieldValue)
                          @DecatErr_Field("@@sna3", "addressLineTwo")    @dtw_assign(Err_SMSNA3, fieldValue)
                          @DecatErr_Field("@@sna4", "addressLineThree")  @dtw_assign(Err_SMSNA4, fieldValue)
                          @DecatErr_Field("@@scty", "city")              @dtw_assign(Err_SMSCTY, fieldValue)
                          @DecatErr_Field("@@st@@", "state")             @dtw_assign(Err_SMST,   fieldValue)
                          @DecatErr_Field("@@zip@", "zip")               @dtw_assign(Err_SMZIP,  fieldValue)
                          @DecatErr_Field("@@phon", "phoneNumber")       @dtw_assign(Err_SMPHON, fieldValue)
                          @DecatErr_Field("@@alph", "alphaSequence")     @dtw_assign(Err_SMALPH, fieldValue)
                          @DecatErr_Field("@@regn", "region")            @dtw_assign(Err_SMREGN, fieldValue)
                          @DecatErr_Field("@@ctry", "country")           @dtw_assign(Err_SMCTRY, fieldValue)
                          @DecatErr_Field("@@scpt", "commissionType")    @dtw_assign(Err_SMSCPT, fieldValue)
                          @DecatErr_Field("@@scpc", "commissionPercent") @dtw_assign(Err_SMSCPC, fieldValue)
                      %endif

                      @Decat_Field("@@slsm")   @dtw_assign(V_SMSLSM, fieldValue)
                      @Decat_Field("@@sna1")   @dtw_assign(V_SMSNA1, fieldValue)
                      @Decat_Field("@@sna2")   @dtw_assign(V_SMSNA2, fieldValue)
                      @Decat_Field("@@sna3")   @dtw_assign(V_SMSNA3, fieldValue)
                      @Decat_Field("@@sna4")   @dtw_assign(V_SMSNA4, fieldValue)
                      @Decat_Field("@@scty")   @dtw_assign(V_SMSCTY, fieldValue)
                      @Decat_Field("@@st@@")   @dtw_assign(V_SMST,   fieldValue)
                      @Decat_Field("@@zip@")   @dtw_assign(V_SMZIP,  fieldValue)
                      @Decat_Field("@@phon")   @dtw_assign(V_SMPHON, fieldValue)
                      @Decat_Field("@@alph")   @dtw_assign(V_SMALPH, fieldValue)
                      @Decat_Field("@@regn")   @dtw_assign(V_SMREGN, fieldValue)
                      @Decat_Field("@@ctry")   @dtw_assign(V_SMCTRY, fieldValue)
                      @Decat_Field("@@scpt")   @dtw_assign(V_SMSCPT, fieldValue)
                      @Decat_Field("@@scpc")   @dtw_assign(V_SMSCPC, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(V_SMSCPT, "K")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "salesmanNumber")
                      @dtw_assign(V_SMSLSM,  "")
                      @dtw_assign(V_SMSCPC, "@dtw_rformat(@dtw_rmultiply(V_SMSCPC, "100"),"","4")")
                  %else
                      @dtw_assign(focusField, "salesmanName")
                      @dtw_assign(V_SMSCPC, "@dtw_rformat(@dtw_rmultiply(V_SMSCPC, "100"),"","4")")
                  %endif

                  @SetTextOvr(Err_SMSLSM)
                  <tr><td class="dsphdr"><span $(textOvr)>Salesman Number</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="salesmanNumber" type="text" value="$(V_SMSLSM)" size="3" maxlength="3"> $(reqFieldChar) </td>
                      %else
                          <td class="inputnmbr"><input name="salesmanNumber" type="hidden" value="$(V_SMSLSM)">$(V_SMSLSM)</td>
	      		   %endif  		
                  </tr>
                  @DspErrMsg(Err_SMSLSM)

                  @SetTextOvr(Err_SMSNA1)
                  <tr><td class="dsphdr"><span $(textOvr)>Salesman Name</span></td>
                      <td class="inputalph"><input name="salesmanName" type="text" value="$(V_SMSNA1)" size="26" maxlength="26"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_SMSNA1)

                  @SetTextOvr(Err_SMSNA2)
                  <tr><td class="dsphdr"><span $(textOvr)>Address Line One</span></td>
                      <td class="inputalph"><input name="addressLineOne" type="text" value="$(V_SMSNA2)" size="26" maxlength="26"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_SMSNA2)

                  @SetTextOvr(Err_SMSNA3)
                  <tr><td class="dsphdr"><span $(textOvr)>Address Line Two</span></td>
                      <td class="inputalph"><input type="text" name="addressLineTwo" value="$(V_SMSNA3)" size="26" maxlength="26"></td>
                  </tr>
                  @DspErrMsg(Err_SMSNA3)
	      			
                  @SetTextOvr(Err_SMSNA4)
                  <tr><td class="dsphdr"><span $(textOvr)>Address Line Three</span></td>
                      <td class="inputalph"><input type="text" name="addressLineThree" value="$(V_SMSNA4)" size="19" maxlength="19"></td>
                  </tr>
                  @DspErrMsg(Err_SMSNA4)

                  @SetTextOvr(Err_SMSCTY)
                  <tr><td class="dsphdr"><span $(textOvr)>City</span></td>
                      <td class="inputalph"><input type="text" name="city" value="$(V_SMSCTY)" size="26" maxlength="26"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_SMSCTY)

                  %if (V_HDFORN == "N")
                      @dtw_assign(stateZipReq,  "$(reqFieldChar)")
                  %else
                      @dtw_assign(stateZipReq,  "")
                  %endif
                  @RtvFldDesc("STID='$(V_SMST)'", "HDSTID", "STDESC", fieldDesc)
                  @SetTextOvr(Err_SMST)
                  <tr><td class="dsphdr"><span $(textOvr)>State</span></td>
                      <td class="inputalph"><input name="state" type="text" value="$(V_SMST)" size="5" maxlength="2"><a href="$(homeURL)$(phpPath)StateSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=state&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(stateZipReq) $(searchImage) </a><input name="stateDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_SMST)

                  @SetTextOvr(Err_SMZIP)
                  <tr><td class="dsphdr"><span $(textOvr)>Zip</span></td>
                      <td class="inputalph"><input type="text" name="zip" value="$(V_SMZIP)" size="13" maxlength="13"> $(stateZipReq)</td>
                  </tr>
                  @DspErrMsg(Err_SMZIP)

                  @RtvFldDesc("CNCTCD='$(V_SMCTRY)'", "HDCTRY", "CNCDES", fieldDesc)
                  @SetTextOvr(Err_SMCTRY)
                  <tr><td class="dsphdr"><span $(textOvr)>Country</span></td>
                      <td class="inputalph"><input name="country" type="text" value="$(V_SMCTRY)" size="5" maxlength="3"><a href="$(homeURL)$(phpPath)CountrySearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=country&amp;fldDesc=countryDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="countryDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_SMCTRY)

                  @SetTextOvr(Err_SMPHON)
                  <tr><td class="dsphdr"><span $(textOvr)>Phone Number</span></td>
                      <td class="inputnmbr"><input type="text" name="phoneNumber" value="$(V_SMPHON)" size="11" maxlength="11"></td>
                  </tr>
                  @DspErrMsg(Err_SMPHON)

                  @SetTextOvr(Err_SMALPH)
                  <tr><td class="dsphdr"><span $(textOvr)>Alpha Sequence</span></td>
                      <td class="inputalph"><input type="text" name="alphaSequence" value="$(V_SMALPH)" size="5" maxlength="4"></td>
                  </tr>
                  @DspErrMsg(Err_SMALPH)
	      		
                  @RtvFldDesc("RGCRGN='$(V_SMREGN)'", "HDCRGN", "RGCRDS", fieldDesc)
                  @SetTextOvr(Err_SMREGN)
                  <tr><td class="dsphdr"><span $(textOvr)>Region</span></td>
                      <td class="inputalph"><input name="region" type="text" value="$(V_SMREGN)" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)RegionSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=region&amp;fldDesc=regionDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="regionDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_SMREGN)
               			
                  @SetTextOvr(Err_SMSCPT)
                  <tr><td class="dsphdr"><span $(textOvr)>Commission Type</span></td>
                      @dtw_tb_rows(commissionTypeTable, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(commissionTypeTable, x, "1") != V_SMSCPT) && (x < maxRows))
                            {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(commissionTypeTable, "commissionType", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_SMSCPT)
	      		
                  @SetTextOvr(Err_SMSCPC)
                  <tr><td class="dsphdr"><span $(textOvr)>Commission Percent</span></td>
                      <td class="inputnmbr"><input type="text" name="commissionPercent" value="$(V_SMSCPC)" size="9" maxlength="9"></td>
                  </tr>
                  @DspErrMsg(Err_SMSCPC)
              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)	
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDSLU_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Commission_Type_Query(profileHandle, dataBaseID, "COMMTYPE  ", commissionTypeTable)

      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(state)
  @dtw_mUPPERCASE(zip)
  @dtw_mUPPERCASE(country)
  @dtw_mUPPERCASE(alphaSequence)
  @dtw_mUPPERCASE(region)
  @dtw_assign(salesmanNumber,@dtw_rstrip(salesmanNumber))
  @dtw_assign(phoneNumber,@dtw_rstrip(phoneNumber))
  @dtw_assign(commissionPercent,@dtw_rstrip(commissionPercent))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@slsm", salesmanNumber)
  @Concat_Field("@@sna1", salesmanName)
  @Concat_Field("@@sna2", addressLineOne)
  @Concat_Field("@@sna3", addressLineTwo)
  @Concat_Field("@@sna4", addressLineThree)
  @Concat_Field("@@scty", city)
  @Concat_Field("@@st@@", state)
  @Concat_Field("@@zip@", zip)
  @Concat_Field("@@phon", phoneNumber)
  @Concat_Field("@@alph", alphaSequence)
  @Concat_Field("@@regn", region)
  @Concat_Field("@@ctry", country)
  @Concat_Field("@@scpt", commissionType)
  @Concat_Field("@@scpc", commissionPercent)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(salesmanName), $(salesmanNumber), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@slsm", "salesmanNumber")
          @Format_ConfMsg_Desc("", $(salesmanName), $(salesmanNumber), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      %if (fromSel == "Y" && maintenanceCode != "D")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)SalesmanSelect.d2w/REPORT$(genericVarBase)&amp;salesmanNumber=@dtw_rurlescseq(salesmanNumber)&amp;salesmanName=@dtw_rurlescseq(salesmanName)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
          %if (backURL == "")
              <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=101&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %else
              <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %endif
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;salesmanNumber=@dtw_rurlescseq(salesmanNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}