%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "Employee.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title 	           = "Employee Pay Transaction Entry"
  d2wName                 = "EmplPaySummary.d2w"
  d2wVarBase              = "$(genericVarBase)$(employeeVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;prCKTYPE=@dtw_rurlescseq(prCKTYPE)&amp;prCKSEPC=@dtw_rurlescseq(prCKSEPC)&amp;maintenanceCode=D"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "99"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  programName             = "HPRSBE"
  caller                  = "summary   "
  rowIndexNext	           = "1"
  totalPages	           = "0"	
  sec_06                  = ""
  showError               = "N"
  TIPPAYROLL              = ""
  PAYTYPECODE             = ""
  JOBCL                   = ""
  FREQ                    = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
  @dtw_replace(workURL, "@@prCKTYPE", "@dtw_rurlescseq(prCKTYPE)", "1", "a", workURL)
  @dtw_replace(workURL, "@@prCKSEPC", "@dtw_rurlescseq(prCKSEPC)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(applicationID, "PR")
  @dtw_assign(UVHRCo, "00")
  @dtw_assign(UVHREmpl, "000000000")
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMTYPE", PAYTYPECODE)
      @RtvFldDesc("CFCOMP=$(prCompany) and CFFACL=$(prFacility)", "HRCOFC", "PCTIP", TIPPAYROLL)
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "$(docType)"
          <html>
              <head>
	           %INCLUDE "$(headInclude)"
                  @dtw_assign(formName, "Chg")
                  <script type="text/javascript">
                      %INCLUDE "calendar.icl"
                      %INCLUDE "dateedit.icl"
                      %INCLUDE "Menu.js"
                      %INCLUDE "numedit.icl"
                      %INCLUDE "CheckEnterChg.icl"
                      function validate(chgForm) {
                          if (editNum(document.Chg.REGH, 5, 2) &&
                              editNum(document.Chg.OVTH, 5, 2) &&
                              editNum(document.Chg.DBLH, 5, 2) &&
                              editNum(document.Chg.VACH, 5, 2) &&
                              editNum(document.Chg.HOLH, 5, 2) &&
                              editNum(document.Chg.SICH, 5, 2) &&
                              editNum(document.Chg.OTHH, 5, 2) &&
            	               %if((PAYTYPECODE == "H" && sec_07 == "Y") || (PAYTYPECODE != "H" && sec_09 == "Y"))
                                  editNum(document.Chg.REGE, 7, 2)  &&
                                  editNum(document.Chg.OVTE, 7, 2) &&
                                  editNum(document.Chg.DBLE, 7, 2) &&
                                  editNum(document.Chg.VACE, 7, 2) &&
                                  editNum(document.Chg.HOLE, 7, 2) &&
                                  editNum(document.Chg.SICE, 7, 2) &&
                                  editNum(document.Chg.OTPT, 7, 2) &&
                                  editNum(document.Chg.OPNT, 7, 2) &&
                                  editNum(document.Chg.FRIN, 7, 2) &&
                                  editNum(document.Chg.COME, 7, 2) &&
                                  editNum(document.Chg.BNSE, 7, 2) &&
                                  editNum(document.Chg.WKRT, 6, 5) &&
                              %endif
                              %if ((TIPPAYROLL == "Y") && ((PAYTYPECODE == "S") || (PAYTYPECODE == "H")))
                                  editNum(document.Chg.CSTP, 5, 2) &&
                                  editNum(document.Chg.CHTP, 5, 2) &&
                                  editNum(document.Chg.GRRC, 5, 2) &&
                                  editNum(document.Chg.MEAL, 5, 2) &&
                              %endif
                              editNum(document.Chg.EQDY, 3, 0) &&
                              editNum(document.Chg.WKAC, 4, 0) &&
                              editNum(document.Chg.WKSB, 4, 0) &&
                              editNum(document.Chg.JBCL, 4, 0) &&
                              editNum(document.Chg.CRWK, 2, 1) &&
                              editNum(document.Chg.EQDY, 3, 0) &&
                              editdate(document.Chg.WKDT))
                              return true;
                      }
                      function confirmDelete() {return confirm("$(delRecordConf)")}
                  </script>
                  %INCLUDE "$(genericHead)"
              </head>
              <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
                  <!-- Start Of Banner Code -->
                  %INCLUDE "banner.icl"
                  <!-- End Of Banner Code -->
                  <table $(baseTable)>
                      <tr valign="top">
                          @dtw_assign(pageID, "EMPLPAYSUMMARY")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                          <td class="content">
                              @dtw_assign(stmtSQL, "")
                              %if (maintenanceCode == "A")
                                  %INCLUDE "AddRecordSQL.icl"
                              %else
                                  @dtw_concat(stmtSQL, "SELECT * FROM PRCHCK left outer join PREACH on CKCOMP=ACCOMP and CKFACL=ACFACL and CKEMPL=ACEMPL", stmtSQL)
                                  @dtw_concat(stmtSQL, " WHERE CKCOMP=$(prCompany) and CKFACL=$(prFacility) and CKEMPL=$(prEmployee) and CKTYPE='$(prCKTYPE)' and CKSEPC='$(prCKSEPC)'", stmtSQL)
                              %endif
                              %INCLUDE "stmtSQLEnd.icl"
                              @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                          </td>
                      </tr>
                  </table>
                  <!-- Start Of Trailer Code -->
                  %INCLUDE "trailer.icl"
                  <!-- End Of Trailer Code -->
              </body>
          </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN  CHAR(64) profileHandle,
				     CHAR(2)   dataBaseID,
                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

   %REPORT{
      @In_Process(profileHandle, dataBaseID, INPROCESS)
      %if (INPROCESS == "Y")
          @dtw_assign(sec_01, "N")
          @dtw_assign(sec_02, "N")
          @dtw_assign(sec_03, "N")
      %endif
      %INCLUDE "MaintainTop.icl"
      %if (INPROCESS != "Y")
          %INCLUDE "ErrorDisplay.icl"
      %endif
      @Ret_Format_EmplName(prCompany, prFacility, prEmployee, UVHRCo, UVHREmpl, "H", F_EmpName)
      <h2>$(F_EmpName)</h2>
      $(hrTagAttr)

      %if (INPROCESS == "Y")
          <table $(contentTable)>
              <tr><td class="colalph"> %include "InProcessMessage.icl" </td></tr>
          </table>
      %endif
      %ROW {
          %if (INPROCESS != "Y")
              <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;prCKTYPE=@dtw_rurlescseq(prCKTYPE)&amp;prCKSEPC=@dtw_rurlescseq(prCKSEPC)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
                      %if (errFound != "" || maintenanceCode == "A")
                          %if (errFound == "" && maintenanceCode == "A")
                              @dtw_assign(edtVar, "")
                              @dtw_assign(focusField, "REGH")
                          %else
                              @dtw_assign(focusField, "")
                              @EdtVarErr(profileHandle, typeValue, edtVar)
                              @ErrVarErr(profileHandle, typeError, errVar)
                              @DecatErr_Field("@@type", "checktype")     @dtw_assign(Err_checktype, fieldValue)
                              @DecatErr_Field("@@rege", "REGE")          @dtw_assign(Err_CKREGE, fieldValue)
                              @DecatErr_Field("@@ovte", "OVTE")          @dtw_assign(Err_CKOVTE, fieldValue)
                              @DecatErr_Field("@@dble", "DBLE")          @dtw_assign(Err_CKDBLE, fieldValue)
                              @DecatErr_Field("@@vace", "VACE")          @dtw_assign(Err_CKVACE, fieldValue)
                              @DecatErr_Field("@@hole", "HOLE")          @dtw_assign(Err_CKHOLE, fieldValue)
                              @DecatErr_Field("@@sice", "SICE")          @dtw_assign(Err_CKSICE, fieldValue)
                              @DecatErr_Field("@@otpt", "OTPT")          @dtw_assign(Err_CKOTPT, fieldValue)
                              @DecatErr_Field("@@opnt", "OPNT")          @dtw_assign(Err_CKOPNT, fieldValue)
                              @DecatErr_Field("@@frin", "FRIN")          @dtw_assign(Err_CKFRIN, fieldValue)
                              @DecatErr_Field("@@come", "COME")          @dtw_assign(Err_CKCOME, fieldValue)
                              @DecatErr_Field("@@bnse", "BNSE")          @dtw_assign(Err_CKBNSE, fieldValue)
                              @DecatErr_Field("@@cstp", "CSTP")          @dtw_assign(Err_CKCSTP, fieldValue)
                              @DecatErr_Field("@@chtp", "CHTP")          @dtw_assign(Err_CKCHTP, fieldValue)
                              @DecatErr_Field("@@grrc", "GRRC")          @dtw_assign(Err_CKGRRC, fieldValue)
                              @DecatErr_Field("@@meal", "MEAL")          @dtw_assign(Err_CKMEAL, fieldValue)
                              @DecatErr_Field("@@thty", "THTY")          @dtw_assign(Err_CKTHTY, fieldValue)
                              @DecatErr_Field("@@wksw", "WKSW")          @dtw_assign(Err_CKWKSW, fieldValue)
                              @DecatErr_Field("@@crwk", "CRWK")          @dtw_assign(Err_CKCRWK, fieldValue)
                              @DecatErr_Field("@@eqdy", "EQDY")          @dtw_assign(Err_CKEQDY, fieldValue)
                              @DecatErr_Field("@@wkdp", "WKDP")          @dtw_assign(Err_CKWKDP, fieldValue)
                              @DecatErr_Field("@@wkfa", "WKFA")          @dtw_assign(Err_CKWKFA, fieldValue)
                              @DecatErr_Field("@@wksb", "WKSB")          @dtw_assign(Err_CKWKSB, fieldValue)
                              @DecatErr_Field("@@jbcl", "JBCL")          @dtw_assign(Err_JBCL, fieldValue)
                              @DecatErr_Field("@@wkrt", "WKRT")          @dtw_assign(Err_CKWKRT, fieldValue)
                              @DecatErr_Field("@@wkdt", "WKDT")          @dtw_assign(Err_CKWKDT, fieldValue)
                              @DecatErr_Field("@@tstp", "timeStampe")    @dtw_assign(Err_CKTSTP, fieldValue)
                          %endif

                          %if (V_CKWKCO == "")
                              @dtw_assign(V_CKWKCO, "00")
                              @dtw_assign(V_CKWKFA, "0000")
                          %endif

                          @Decat_Field("@@type")   @dtw_assign(V_CKTYPE, fieldValue)
                          @Decat_Field("@@regh")   @dtw_assign(V_CKREGH, fieldValue)
                          @Decat_Field("@@rege")   @dtw_assign(V_CKREGE, fieldValue)
                          @Decat_Field("@@ovth")   @dtw_assign(V_CKOVTH, fieldValue)
                          @Decat_Field("@@ovte")   @dtw_assign(V_CKOVTE, fieldValue)
                          @Decat_Field("@@dblh")   @dtw_assign(V_CKDBLH, fieldValue)
                          @Decat_Field("@@dble")   @dtw_assign(V_CKDBLE, fieldValue)
                          @Decat_Field("@@vach")   @dtw_assign(V_CKVACH, fieldValue)
                          @Decat_Field("@@vace")   @dtw_assign(V_CKVACE, fieldValue)
                          @Decat_Field("@@holh")   @dtw_assign(V_CKHOLH, fieldValue)
                          @Decat_Field("@@hole")   @dtw_assign(V_CKHOLE, fieldValue)
                          @Decat_Field("@@sich")   @dtw_assign(V_CKSICH, fieldValue)
                          @Decat_Field("@@sice")   @dtw_assign(V_CKSICE, fieldValue)
                          @Decat_Field("@@othh")   @dtw_assign(V_CKOTHH, fieldValue)
                          @Decat_Field("@@otpt")   @dtw_assign(V_CKOTPT, fieldValue)
                          @Decat_Field("@@opnt")   @dtw_assign(V_CKOPNT, fieldValue)
                          @Decat_Field("@@frin")   @dtw_assign(V_CKFRIN, fieldValue)
                          @Decat_Field("@@come")   @dtw_assign(V_CKCOME, fieldValue)
                          @Decat_Field("@@bnse")   @dtw_assign(V_CKBNSE, fieldValue)
                          @Decat_Field("@@cstp")   @dtw_assign(V_CKCSTP, fieldValue)
                          @Decat_Field("@@chtp")   @dtw_assign(V_CKCHTP, fieldValue)
                          @Decat_Field("@@grrc")   @dtw_assign(V_CKGRRC, fieldValue)
                          @Decat_Field("@@meal")   @dtw_assign(V_CKMEAL, fieldValue)
                          @Decat_Field("@@thty")   @dtw_assign(V_CKTHTY, fieldValue)
                          @Decat_Field("@@wksw")   @dtw_assign(V_CKWKSW, fieldValue)
                          @Decat_Field("@@crwk")   @dtw_assign(V_CKCRWK, fieldValue)
                          @Decat_Field("@@eqdy")   @dtw_assign(V_CKEQDY, fieldValue)
                          @Decat_Field("@@wkdp")   @dtw_assign(V_CKWKDP, fieldValue)
                          @Decat_Field("@@wkco")   @dtw_assign(V_CKWKCO, fieldValue)
                          @Decat_Field("@@wkfa")   @dtw_assign(V_CKWKFA, fieldValue)
                          @Decat_Field("@@wkac")   @dtw_assign(V_CKWKAC, fieldValue)
                          @Decat_Field("@@wksb")   @dtw_assign(V_CKWKSB, fieldValue)
                          @Decat_Field("@@jbcl")   @dtw_assign(JBCL, fieldValue)
                          @Decat_Field("@@wkrt")   @dtw_assign(V_CKWKRT, fieldValue)
                          @Decat_Field("@@wkdt")   @dtw_assign(V_CKWKDT, fieldValue)
                          @Decat_Field("@@tstp")   @dtw_assign(V_CKTSTP, fieldValue)

                          %if (errFound == "" && maintenanceCode == "A")
                              @dtw_assign(xxsepc, "")
                              @NextSeparateCheck(profileHandle, dataBaseID, prCompany, prFacility, prEmployee, prCKTYPE, xxsepc, errflg)
                              @dtw_assign(V_CKSEPC, xxsepc)
                              %if (xxsepc == "")
                                  @dtw_assign(FREQ, "0")
                                  @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "char(EMFREQ)", FREQ)
                                  %if (FREQ == "1")
                                      @dtw_assign(V_CKEQDY, "5")
                                      @dtw_assign(V_CKCRWK, "1")
                                  %elseif (FREQ == "2")
                                      @dtw_assign(V_CKEQDY, "10")
                                      @dtw_assign(V_CKCRWK, "2")
                                  %elseif (FREQ == "3")
                                      @dtw_assign(V_CKEQDY, "11")
                                      @dtw_assign(V_CKCRWK, "2")
                                  %elseif (FREQ == "4")
                                      @dtw_assign(V_CKEQDY, "22")
                                      @dtw_assign(V_CKCRWK, "4")
                                  %endif
                              %endif
                              @dtw_assign(focusField, "REGH")
                              @RtvFldDesc("ERCOMP=$(prCompany) and ERFACL=$(prFacility) and EREMPL=$(prEmployee)", "PREMPL", "char(ERJBCL)", JBCL)
                          %endif
                          @dtw_assign(errFound, "")
                          @dtw_assign(focusField, "REGH")
                      %elseif (maintenanceCode != "A")
                          @DateInputFromCYMD(V_CKWKDT)
                          @dtw_assign(focusField, "REGH")
                          @RtvFldDesc("SBCOMP=$(prCompany) and SBFACL=$(prFacility) and SBEMPL=$(prEmployee) and SBTYPE='$(prCKTYPE)' and SBSEPC='$(prCKSEPC)'", "PRTIME", "char(SBJBCL)", JBCL)
                      %endif

                      <table $(contentTable)>
                          %if (prCKTYPE != "3")
                              <tr><td class="dsphdr">Check Number</td>
                                  <td class="dspalph">$(V_CKCKNO)</td></tr>
                              @DateFromCYMD(V_CKCKDT)
                              <tr><td class="dsphdr">Check Date</td>
                                  <td class="dspalph">$(V_CKCKDT)</td></tr>
                          %endif
                          %if (prCKTYPE == "3")
                              @dtw_assign(checkType, "Regular")
                          %elseif (prCKTYPE == "1")
                              @dtw_assign(checkType, "Void")
                          %elseif (prCKTYPE == "2")
                              @dtw_assign(checkType, "Manual/History Adjustment")
                          %elseif (V_CKRCCD == "4")
                              @dtw_assign(checkType, "Non Elective Contribution")
                          %endif
                          @SetTextOvr(Err_checktype)
                          <tr><td class="dsphdr"><span $(textOvr)>Check Type</span></td>
                              <td class="dspalph">$(checkType)</td>
                          </tr>
                          @DspErrMsg(Err_checktype)

                          %if (V_CKSEPC != "" || maintenanceCode == "A")
                              %if (maintenanceCode == "A")
                                  @SetTextOvr(Err_CKSEPC)
                                  <tr><td class="dsphdr"><span $(textOvr)>Separate Check</span></td>
                                      <td class="colnmbr"></td>
                                          <td class="inputnmbr"><input name="prCKSEPC" type="text" value="$(V_CKSEPC)" size=1 maxlength=1</td>
                                  </tr>
                                  @DspErrMsg(Err_CKSEPC)
                              %else
                                  <tr><td class="dsphdr">Separate Check Code</td>
                                      <td class="dspalph">$(V_CKSEPC)</td>
                                  </tr>
                              %endif
                          %endif
                          @SetTextOvr(Err_CKTSTP)
                          <tr><td><input name="timeStamp" type="hidden" value="$(V_CKTSTP)"></td></tr>
                          @DspErrMsg(Err_CKTSTP)
                      </table>

              $(hrTagAttr)
              <a name="summary"></a>
              <fieldset class="legendBody">
              <legend class="legendTitle">Summary Hours Entry</legend>

                  <table $(contentTable)>

                      <tr><td class="colhdr">Description</td>
                          <td class="colhdr">Hours/Units</td>
                          <td class="colhdr">Earnings</td></tr>

                      @SetTextOvr(Err_CKREGE)
                      <tr><td class="dsphdr"><span $(textOvr)>Regular</span></td>
                          <td class="inputnmbr"><input name="REGH" type="text" value="$(V_CKREGH)" size="9" maxlength="8"></td>
            	           %if((PAYTYPECODE == "H" && sec_06 == "N") || (PAYTYPECODE != "H" && sec_08 == "N"))
                              <td class="colcode">$(earnnotavailImage)<input name="REGE" type="hidden" value="$(V_CKREGE)"></td>
                          %elseif((PAYTYPECODE == "H" && sec_07 == "N") || (PAYTYPECODE != "H" && sec_09 == "N"))
                              @Format_Nbr($(V_CKREGE), F_CKREGE, "2", $(amtEditCode), "", "", "")
                              <td class="colnmbr"><input name="REGE" type="hidden" value="$(V_CKREGE)">$(F_CKREGE)</td>
                          %else
                              <td class="inputnmbr"><input name="REGE" type="text" value="$(V_CKREGE)" size=11 maxlength=10></td>
                          %endif
                      </tr>
                      @DspErrMsg(Err_CKREGE)

                      @SetTextOvr(Err_CKOVTE)
                      <tr><td class="dsphdr"><span $(textOvr)>Overtime</span></td>
                          <td class="inputnmbr"><input name="OVTH" type="text" value="$(V_CKOVTH)" size=9 maxlength=8</td>
            	           %if((PAYTYPECODE == "H" && sec_06 == "N") || (PAYTYPECODE != "H" && sec_08 == "N"))
                              <td class="colcode"><input name="OVTE" type="hidden" value="$(V_CKOVTE)"></td>
                          %elseif((PAYTYPECODE == "H" && sec_07 == "N") || (PAYTYPECODE != "H" && sec_09 == "N"))
                              @Format_Nbr($(V_CKOVTE), F_CKOVTE, "2", $(amtEditCode), "", "", "")
                              <td class="colnmbr"><input name="OVTE" type="hidden" value="$(V_CKOVTE)">$(F_CKOVTE)</td>
                          %else
                              <td class="inputnmbr"><input name="OVTE" type="text" value="$(V_CKOVTE)" size=11 maxlength=10</td>
                          %endif
                      </tr>
                      @DspErrMsg(Err_CKOVTE)

                      @SetTextOvr(Err_CKDBLE)
                      <tr><td class="dsphdr"><span $(textOvr)>Double Time</span></td>
                          <td class="inputnmbr"><input name="DBLH" type="text" value="$(V_CKDBLH)" size=9 maxlength=8</td>
            	           %if((PAYTYPECODE == "H" && sec_06 == "N") || (PAYTYPECODE != "H" && sec_08 == "N"))
                              <td class="colcode"><input name="DBLE" type="hidden" value="$(V_CKDBLE)"></td>
                          %elseif((PAYTYPECODE == "H" && sec_07 == "N") || (PAYTYPECODE != "H" && sec_09 == "N"))
                              @Format_Nbr($(V_CKDBLE), F_CKDBLE, "2", $(amtEditCode), "", "", "")
                              <td class="colnmbr"><input name="DBLE" type="hidden" value="$(V_CKDBLE)">$(F_CKDBLE)</td>
                          %else
                              <td class="inputnmbr"><input name="DBLE" type="text" value="$(V_CKDBLE)" size=11 maxlength=10</td>
                          %endif
                      </tr>
                      @DspErrMsg(Err_CKDBLE)

                      @SetTextOvr(Err_CKVACE)
                      <tr><td class="dsphdr"><span $(textOvr)>Vacation</span></td>
                          <td class="inputnmbr"><input name="VACH" type="text" value="$(V_CKVACH)" size=9 maxlength=8</td>
            	           %if((PAYTYPECODE == "H" && sec_06 == "N") || (PAYTYPECODE != "H" && sec_08 == "N"))
                              <td class="colcode"><input name="VACE" type="hidden" value="$(V_CKVACE)"></td>
                          %elseif((PAYTYPECODE == "H" && sec_07 == "N") || (PAYTYPECODE != "H" && sec_09 == "N"))
                              @Format_Nbr($(V_CKVACE), F_CKVACE, "2", $(amtEditCode), "", "", "")
                              <td class="colnmbr"><input name="VACE" type="hidden" value="$(V_CKVACE)">$(F_CKVACE)</td>
                          %else
                              <td class="inputnmbr"><input name="VACE" type="text" value="$(V_CKVACE)" size=11 maxlength=10</td>
                          %endif
                      </tr>
                      @DspErrMsg(Err_CKVACE)

                      @SetTextOvr(Err_CKHOLE)
                      <tr><td class="dsphdr"><span $(textOvr)>Holiday</span></td>
                          <td class="inputnmbr"><input name="HOLH" type="text" value="$(V_CKHOLH)" size=9 maxlength=8</td>
            	           %if((PAYTYPECODE == "H" && sec_06 == "N") || (PAYTYPECODE != "H" && sec_08 == "N"))
                              <td class="colcode"><input name="HOLE" type="hidden" value="$(V_CKHOLE)"></td>
                          %elseif((PAYTYPECODE == "H" && sec_07 == "N") || (PAYTYPECODE != "H" && sec_09 == "N"))
                              @Format_Nbr($(V_CKHOLE), F_CKHOLE, "2", $(amtEditCode), "", "", "")
                              <td class="colnmbr"><input name="HOLE" type="hidden" value="$(V_CKHOLE)">$(F_CKHOLE)</td>
                          %else
                              <td class="inputnmbr"><input name="HOLE" type="text" value="$(V_CKHOLE)" size=11 maxlength=10</td>
                          %endif
                      </tr>
                      @DspErrMsg(Err_CKHOLE)

                      @SetTextOvr(Err_CKSICE)
                      <tr><td class="dsphdr"><span $(textOvr)>Sick</span></td>
                          <td class="inputnmbr"><input name="SICH" type="text" value="$(V_CKSICH)" size=9 maxlength=8</td>
            	           %if((PAYTYPECODE == "H" && sec_06 == "N") || (PAYTYPECODE != "H" && sec_08 == "N"))
                              <td class="colcode"><input name="SICE" type="hidden" value="$(V_CKSICE)"></td>
                          %elseif((PAYTYPECODE == "H" && sec_07 == "N") || (PAYTYPECODE != "H" && sec_09 == "N"))
                              @Format_Nbr($(V_CKSICE), F_CKSICE, "2", $(amtEditCode), "", "", "")
                              <td class="colnmbr"><input name="SICE" type="hidden" value="$(V_CKSICE)">$(F_CKSICE)</td>
                          %else
                              <td class="inputnmbr"><input name="SICE" type="text" value="$(V_CKSICE)" size=11 maxlength=10</td>
                          %endif
                      </tr>
                      @DspErrMsg(Err_CKSICE)

                      @SetTextOvr(Err_CKOTPT)
                      <tr><td class="dsphdr"><span $(textOvr)>Other Taxable</span></td>
                          <td class="inputnmbr"><input name="OTHH" type="text" value="$(V_CKOTHH)" size=9 maxlength=8</td>
            	           %if((PAYTYPECODE == "H" && sec_06 == "N") || (PAYTYPECODE != "H" && sec_08 == "N"))
                              <td class="colcode"><input name="OTPT" type="hidden" value="$(V_CKOTPT)"></td>
                          %elseif((PAYTYPECODE == "H" && sec_07 == "N") || (PAYTYPECODE != "H" && sec_09 == "N"))
                              @Format_Nbr($(V_CKOTPT), F_CKOTPT, "2", $(amtEditCode), "", "", "")
                              <td class="colnmbr"><input name="OTPT" type="hidden" value="$(V_CKOTPT)">$(F_CKOTPT)</td>
