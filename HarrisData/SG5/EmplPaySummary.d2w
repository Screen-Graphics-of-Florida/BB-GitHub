                              @Format_Nbr($(V_CKOPNT), F_CKOPNT, "2", $(amtEditCode), "", "", "")
                              <td class="colnmbr"><input name="OTPT" type="hidden" value="$(V_CKOPNT)">$(F_CKOPNT)</td>
                          %else
                              <td class="inputnmbr"><input name="OPNT" type="text" value="$(V_CKOPNT)" size=11 maxlength=10</td>
                          %endif
                      </tr>
                      @DspErrMsg(Err_CKOPNT)

                      @SetTextOvr(Err_CKFRIN)
                      <tr><td class="dsphdr"><span $(textOvr)>Fringe Benefits</span></td>
                          <td class="colnmbr"></td>
            	           %if((PAYTYPECODE == "H" && sec_06 == "N") || (PAYTYPECODE != "H" && sec_08 == "N"))
                              <td class="colcode"><input name="FRIN" type="hidden" value="$(V_CKFRIN)"></td>
                          %elseif((PAYTYPECODE == "H" && sec_07 == "N") || (PAYTYPECODE != "H" && sec_09 == "N"))
                              @Format_Nbr($(V_CKFRIN), F_CKFRIN, "2", $(amtEditCode), "", "", "")
                              <td class="colnmbr"><input name="FRIN" type="hidden" value="$(V_CKFRIN)">$(F_CKFRIN)</td>
                          %else
                              <td class="inputnmbr"><input name="FRIN" type="text" value="$(V_CKFRIN)" size=11 maxlength=10</td>
                          %endif
                      </tr>
                      @DspErrMsg(Err_CKFRIN)

                      @SetTextOvr(Err_CKCOME)
                      <tr><td class="dsphdr"><span $(textOvr)>Commission</span></td>
                          <td class="colnmbr"></td>
            	           %if((PAYTYPECODE == "H" && sec_06 == "N") || (PAYTYPECODE != "H" && sec_08 == "N"))
                              <td class="colcode"><input name="COME" type="hidden" value="$(V_CKCOME)"></td>
                          %elseif((PAYTYPECODE == "H" && sec_07 == "N") || (PAYTYPECODE != "H" && sec_09 == "N"))
                              @Format_Nbr($(V_CKCOME), F_CKCOME, "2", $(amtEditCode), "", "", "")
                              <td class="colnmbr"><input name="COME" type="hidden" value="$(V_CKCOME)">$(F_CKCOME)</td>
                          %else
                              <td class="inputnmbr"><input name="COME" type="text" value="$(V_CKCOME)" size=11 maxlength=10</td>
                          %endif
                      </tr>
                      @DspErrMsg(Err_CKCOME)

                      @SetTextOvr(Err_CKBNSE)
                      <tr><td class="dsphdr"><span $(textOvr)>Bonus</span></td>
                          <td class="colnmbr"></td>
            	           %if((PAYTYPECODE == "H" && sec_06 == "N") || (PAYTYPECODE != "H" && sec_08 == "N"))
                              <td class="colcode"><input name="BNSE" type="hidden" value="$(V_CKBNSE)"></td>
                          %elseif((PAYTYPECODE == "H" && sec_07 == "N") || (PAYTYPECODE != "H" && sec_09 == "N"))
                              @Format_Nbr($(V_CKBNSE), F_CKBNSE, "2", $(amtEditCode), "", "", "")
                              <td class="colnmbr"><input name="BNSE" type="hidden" value="$(V_CKBNSE)">$(F_CKBNSE)</td>
                          %else
                              <td class="inputnmbr"><input name="BNSE" type="text" value="$(V_CKBNSE)" size=11 maxlength=10</td>
                          %endif
                      </tr>
                      @DspErrMsg(Err_CKBNSE)

                      %if ((TIPPAYROLL == "Y") && ((PAYTYPECODE == "S") || (PAYTYPECODE == "H")))

                          @SetTextOvr(Err_CKCSTP)
                          <tr><td class="dsphdr"><span $(textOvr)>Cash Tips</span></td>
                              <td class="colnmbr"></td>
               	       %if((PAYTYPECODE == "H" && sec_06 == "N") || (PAYTYPECODE != "H" && sec_08 == "N"))
                                  <td class="colcode"><input name="CSTP" type="hidden" value="$(V_CKCSTP)"></td>
                              %elseif((PAYTYPECODE == "H" && sec_07 == "N") || (PAYTYPECODE != "H" && sec_09 == "N"))
                                  @Format_Nbr($(V_CKCSTP), F_CKCSTP, "2", $(amtEditCode), "", "", "")
                                  <td class="colnmbr"><input name="CSTP" type="hidden" value="$(V_CKCSTP)">$(F_CKCSTP)</td>
                              %else
                                  <td class="inputnmbr"><input name="CSTP" type="text" value="$(V_CKCSTP)" size=9 maxlength=8</td>
                              %endif
                          </tr>
                          @DspErrMsg(Err_CKCSTP)

                          @SetTextOvr(Err_CKCHTP)
                          <tr><td class="dsphdr"><span $(textOvr)>Charge Tips</span></td>
                              <td class="colnmbr"></td>
               	       %if((PAYTYPECODE == "H" && sec_06 == "N") || (PAYTYPECODE != "H" && sec_08 == "N"))
                                  <td class="colcode"><input name="CHTP" type="hidden" value="$(V_CKCHTP)"></td>
                              %elseif((PAYTYPECODE == "H" && sec_07 == "N") || (PAYTYPECODE != "H" && sec_09 == "N"))
                                  @Format_Nbr($(V_CKCHTP), F_CKCHTP, "2", $(amtEditCode), "", "", "")
                                  <td class="colnmbr"><input name="CHTP" type="hidden" value="$(V_CKCHTP)">$(F_CKCHTP)</td>
                              %else
                                  <td class="inputnmbr"><input name="CHTP" type="text" value="$(V_CKCHTP)" size=9 maxlength=8</td>
                              %endif
                          </tr>
                          @DspErrMsg(Err_CKCHTP)

                          @SetTextOvr(Err_CKGRRC)
                          <tr><td class="dsphdr"><span $(textOvr)>Gross Receipts</span></td>
                              <td class="colnmbr"></td>
               	       %if((PAYTYPECODE == "H" && sec_06 == "N") || (PAYTYPECODE != "H" && sec_08 == "N"))
                                  <td class="colcode"><input name="GRRC" type="hidden" value="$(V_CKGRRC)"></td>
                              %elseif((PAYTYPECODE == "H" && sec_07 == "N") || (PAYTYPECODE != "H" && sec_09 == "N"))
                                  @Format_Nbr($(V_CKGRRC), F_CKGRRC, "2", $(amtEditCode), "", "", "")
                                  <td class="colnmbr"><input name="GRRC" type="hidden" value="$(V_CKGRRC)">$(F_CKGRRC)</td>
                              %else
                                  <td class="inputnmbr"><input name="GRRC" type="text" value="$(V_CKGRRC)" size=9 maxlength=8</td>
                              %endif
                          </tr>
                          @DspErrMsg(Err_CKGRRC)

                          @SetTextOvr(Err_CKMEAL)
                          <tr><td class="dsphdr"><span $(textOvr)>Meal Allowance</span></td>
                              <td class="colnmbr"></td>
               	       %if((PAYTYPECODE == "H" && sec_06 == "N") || (PAYTYPECODE != "H" && sec_08 == "N"))
                                  <td class="colcode"><input name="MEAL" type="hidden" value="$(V_CKMEAL)"></td>
                              %elseif((PAYTYPECODE == "H" && sec_07 == "N") || (PAYTYPECODE != "H" && sec_09 == "N"))
                                  @Format_Nbr($(V_CKMEAL), F_CKMEAL, "2", $(amtEditCode), "", "", "")
                                  <td class="colnmbr"><input name="MEAL" type="hidden" value="$(V_CKMEAL)">$(F_CKMEAL)</td>
                              %else
                                  <td class="inputnmbr"><input name="MEAL" type="text" value="$(V_CKMEAL)" size=9 maxlength=8></td>
                              %endif
                          </tr>
                          @DspErrMsg(Err_CKMEAL)

                     %endif

                  </table>
              </fieldset>
              <fieldset class="legendBody">
              <legend class="legendTitle">Overrides</legend>
                  <table $(contentTable)>

                      <tr><td class="colhdr">Description</td>
                          <td class="colhdr">Entry</td></tr>

                      %if ((TIPPAYROLL == "Y") && ((PAYTYPECODE == "S") || (PAYTYPECODE == "H")))
                         @SetTextOvr(Err_CKTHTY)
                         <tr><td class="dsphdr"><span $(textOvr)>Tip Type (D,I)</span></td>
                             <td class="inputalph"><input name="THTY" type="text" value="$(V_CKTHTY)" size=2 maxlength=1 </td>
                         </tr>
                         @DspErrMsg(Err_CKTHTY)
                      %else
                         <td class="colcode"><input name="THTY" type="hidden" value="$(V_CKTHTY)"</td>
                      %endif

                      @SetTextOvr(Err_CKWKSW)
                      <tr><td class="dsphdr"><span $(textOvr)> Shift Worked</span></td>
                          <td class="inputalph"><input name="WKSW" type="text" value="$(V_CKWKSW)" size="4" maxlength="2"> <a href="$(homeURL)$(cGIPath)PremiumRateSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Chg&amp;fldName=WKSW&amp;fldDesc=shiftDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="shiftDesc" value="$(fieldDesc)"  type="text" size="20" maxlength="20"></td>
                      </tr>
                      @DspErrMsg(Err_CKWKSW)

                      @SetTextOvr(Err_CKCRWK)
                      <tr><td class="dsphdr"><span $(textOvr)>Credit Service Weeks</span></td>
                          <td class="inputnmbr"><input name="CRWK" type="text" value="$(V_CKCRWK)" size="4" maxlength="4"></td>
                      </tr>
                      @DspErrMsg(Err_CKCRWK)

                      @SetTextOvr(Err_CKEQDY)
                      <tr><td class="dsphdr"><span $(textOvr)>Equiv. Days Worked</span></td>
                          <td class="inputnmbr"><input name="EQDY" type="text" value="$(V_CKEQDY)" size="4" maxlength="3"></td>
                      </tr>
                      @DspErrMsg(Err_CKEQDY)

                      @RtvFldDesc("EADEPT='$(V_CKWKDP)'", "PREXAC", "EANAME", deptName)
                      @SetTextOvr(Err_CKWKDP)
                      <tr><td class="dsphdr"><span $(textOvr)>Department Worked</span></td>
                          <td class="inputalph"><input name="WKDP" type="text" value="$(V_CKWKDP)" size="4" maxlength="5"><a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=WKDP&amp;fldDesc=deptName" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="deptName" value="$(deptName)"  type="text" size="20"></td>
                      </tr>
                      @DspErrMsg(Err_CKWKDP)

                      @SetTextOvr(Err_CKWKFA)
                      <tr><td class="dsphdr"><span $(textOvr)>Expense Company/Facility</span></td>
                          @RtvFldDesc("CFCOMP=$(V_CKWKCO) and CFFACL=$(V_CKWKFA) ", "HRCOFC", "CFNAME", fieldDesc)
                          <td class="inputnmbr"><input name="companyNumber" value="$(V_CKWKCO)" type="text" size="4" maxlength="2"> / <input name="facilityNumber" value="$(V_CKWKFA)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=companyNumber&amp;fldFac=facilityNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="coFacDesc" value="$(fieldDesc)"  type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_CKWKFA)

                      @Default_Zero(V_CKWKAC)
                      @Default_Zero(V_CKWKSB)
                      @dtw_assign(acctDesc, "")
                      @SetTextOvr(Err_CKWKSB)
                      <tr><td class="dsphdr"><span $(textOvr)>Expense Account</span></td>
                          @RtvFldDesc("CHACCT=$(V_CKWKAC) and CHSUB=$(V_CKWKSB) ", "HDCHRT", "CHCHDS", acctDesc)
                          <td class="inputnmbr"><input name="WKAC" value="$(V_CKWKAC)" type="text" size="4" maxlength="4"> - <input name="WKSB" value="$(V_CKWKSB)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=WKAC&amp;subFld=WKSB&amp;descFld=OverrideAcctDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="OverrideAcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_CKWKSB)

                      @RtvFldDesc("JBCLAS=$(JBCL) ", "PRJBCL", "JBDESC", classDesc)
                      @SetTextOvr(Err_JBCL)
                      <tr><td class="dsphdr"><span $(textOvr)>Job Class</span></td>
                          <td class="inputalph"><input name="JBCL" type="text" value="$(JBCL)" size="4" maxlength="4"><a href="$(homeURL)$(cGIPath)PRJobClassSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=JBCL&amp;fldDesc=jbclDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="jbclDesc" value="$(classDesc)" type="text" size="20" disabled></td>
                      </tr>
                      @DspErrMsg(Err_JBCL)

                      @SetTextOvr(Err_CKWKRT)
                      <tr><td class="dsphdr"><span $(textOvr)>Rate</span></td>
            	       %if((PAYTYPECODE == "H" && sec_06 == "N") || (PAYTYPECODE != "H" && sec_08 == "N"))
                              <td class="colcode">$(earnnotavailImage)<input name="WKRT" type="hidden" value="$(V_CKWKRT)"></td>
                          %elseif((PAYTYPECODE == "H" && sec_07 == "N") || (PAYTYPECODE != "H" && sec_09 == "N"))
                              @Format_Nbr($(V_CKWKRT), F_CKWKRT, $(rteNbrDec), $(rteEditCode), "", "", "")
                              <td class="colalph"><input name="WKRT" type="hidden" value="$(V_CKWKRT)">$(F_CKWKRT)</td>
                          %else
                              <td class="inputnmbr"><input name="WKRT" type="text" value="$(V_CKWKRT)" size=13 maxlength=12</td>
                          %endif
                      </tr>
                      @DspErrMsg(Err_CKWKRT)

                      @SetTextOvr(Err_CKWKDT)
                      <tr><td class="dsphdr"><span $(textOvr)>Date Worked</span></td>

                          <td class="inputnmbr"><input type="text" name="WKDT" value="$(V_CKWKDT)" size="6" maxlength="6">
                                  <a href="javascript:calWindow('WKDT');">$(calendarImage)</a></td>
                      </tr>
                      @DspErrMsg(Err_CKWKDT)

                      %if ((sec_02 == "Y" || sec_03 == "Y") && (maintenanceCode == "C"))
                          <tr><th class="dsphdr">Additional Override Entries</th></tr>
                          %if (V_CKDN01 != "0")
                              <tr><td class="dsphdr">
                                  <a href="$(homeURL)$(cGIPath)emplpayded.d2w/DEDUCTIONS$(d2wVarBase)&amp;prCKTYPE=@dtw_rurlescseq(prCKTYPE)&amp;prCKSEPC=@dtw_rurlescseq(prCKSEPC)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=C">Voluntary Deductions</a></td>
                              </tr>
                          %endif

                          <tr><td class="dsphdr">
                              <a  href="$(homeURL)$(cGIPath)emplpayovrrides.d2w/OVERRIDE$(d2wVarBase)&amp;prCKTYPE=@dtw_rurlescseq(prCKTYPE)&amp;prCKSEPC=@dtw_rurlescseq(prCKSEPC)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=C">Tax Overrides/Accrual</a></td>
                          </tr>

                          %if (V_ACTYP1 != "" || V_ACTYP2 != "" || V_ACTYP3 != "" || V_ACTYP4 != "" || V_ACTYP5 != "" || V_ACTYP6 != "" || V_ACTYP7 != "")
                              <tr><td class="dsphdr">
                              <a   href="$(homeURL)$(cGIPath)emplpaydirdep.d2w/DIRDEP$(d2wVarBase)&amp;prCKTYPE=@dtw_rurlescseq(prCKTYPE)&amp;prCKSEPC=@dtw_rurlescseq(prCKSEPC)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=C">Direct Deposits</a></td>
                              </tr>
                          %endif
                      %endif

              %endif
          %}
          %if (INPROCESS != "Y")
              </table>
              <script type="text/javascript">
                  document.Chg.$(focusField).focus();
              </script>
              </fieldset>
          %endif
      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
   %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64) profileHandle,
                                               INOUT CHAR(2) dataBaseID,
                                               INOUT CHAR(1) maintenanceCode,
                                               INOUT CHAR(1) errFound,
                                               INOUT CHAR(32000) edtVar,
                                               INOUT CHAR(32000) errVar)

 {%EXEC {HPRPAY_W.PGM %}
%}

%FUNCTION(dtw_directcall) NextSeparateCheck (INOUT CHAR(64) profileHandle,
                                             INOUT CHAR(2) dataBaseID,
                                             INOUT DEC(2,0) prCompany,
                                             INOUT DEC(4,0) prFacility,
                                             INOUT DEC(5,0) prEmployee,
                                             INOUT CHAR(1) prCKTYPE,
                                             INOUT CHAR(1) xxsepc,
                                             INOUT CHAR(1) errflg)
 {%EXEC {HPRNSC_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(WKCO,@dtw_rstrip(companyNumber))
  @dtw_assign(WKFA,@dtw_rstrip(facilityNumber))
  @dtw_assign(REGH,@dtw_rstrip(REGH))
  @dtw_assign(REGE,@dtw_rstrip(REGE))
  @dtw_assign(OVTH,@dtw_rstrip(OVTH))
  @dtw_assign(OVTE,@dtw_rstrip(OVTE))
  @dtw_assign(DBLH,@dtw_rstrip(DBLH))
  @dtw_assign(DBLE,@dtw_rstrip(DBLE))
  @dtw_assign(VACH,@dtw_rstrip(VACH))
  @dtw_assign(VACE,@dtw_rstrip(VACE))
  @dtw_assign(HOLH,@dtw_rstrip(HOLH))
  @dtw_assign(HOLE,@dtw_rstrip(HOLE))
  @dtw_assign(SICH,@dtw_rstrip(SICH))
  @dtw_assign(SICE,@dtw_rstrip(SICE))
  @dtw_assign(OTHH,@dtw_rstrip(OTHH))
  @dtw_assign(OTPT,@dtw_rstrip(OTPT))
  @dtw_assign(OPNT,@dtw_rstrip(OPNT))
  @dtw_assign(FRIN,@dtw_rstrip(FRIN))
  @dtw_assign(COME,@dtw_rstrip(COME))
  @dtw_assign(BNSE,@dtw_rstrip(BNSE))
  @dtw_assign(CSTP,@dtw_rstrip(CSTP))
  @dtw_assign(CHTP,@dtw_rstrip(CHTP))
  @dtw_assign(GRRC,@dtw_rstrip(GRRC))
  @dtw_assign(MEAL,@dtw_rstrip(MEAL))
  @dtw_assign(EQDY,@dtw_rstrip(EQDY))
  @dtw_assign(WKCO,@dtw_rstrip(WKCO))
  @dtw_assign(WKFA,@dtw_rstrip(WKFA))
  @dtw_assign(WKAC,@dtw_rstrip(WKAC))
  @dtw_assign(WKSB,@dtw_rstrip(WKSB))
  @dtw_assign(WKRT,@dtw_rstrip(WKRT))
  @dtw_assign(WKDT,@dtw_rstrip(WKDT))

  %if (maintenanceCode == "A")
      @dtw_assign(prCKTYPE, "3")
  %endif
  @dtw_assign(THTY, @dtw_rUPPERCASE(THTY))
  @dtw_assign(prCKSEPC, @dtw_rUPPERCASE(prCKSEPC))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@call", caller)
  @Concat_Field("@@comp", prCompany)
  @Concat_Field("@@facl", prFacility)
  @Concat_Field("@@empl", prEmployee)
  @Concat_Field("@@type", prCKTYPE)
  @Concat_Field("@@sepc", prCKSEPC)
  @Concat_Field("@@rccd", "H")
  @Concat_Field("@@regh", REGH)
  @Concat_Field("@@rege", REGE)
  @Concat_Field("@@ovth", OVTH)
  @Concat_Field("@@ovte", OVTE)
  @Concat_Field("@@dblh", DBLH)
  @Concat_Field("@@dble", DBLE)
  @Concat_Field("@@vach", VACH)
  @Concat_Field("@@vace", VACE)
  @Concat_Field("@@holh", HOLH)
  @Concat_Field("@@hole", HOLE)

  @Concat_Field("@@sich", SICH)
  @Concat_Field("@@sice", SICE)
  @Concat_Field("@@othh", OTHH)
  @Concat_Field("@@otpt", OTPT)
  @Concat_Field("@@opnt", OPNT)
  @Concat_Field("@@frin", FRIN)
  @Concat_Field("@@come", COME)
  @Concat_Field("@@bnse", BNSE)
  @Concat_Field("@@cstp", CSTP)
  @Concat_Field("@@chtp", CHTP)

  @Concat_Field("@@grrc", GRRC)
  @Concat_Field("@@meal", MEAL)
  @Concat_Field("@@thty", THTY)
  @Concat_Field("@@wksw", WKSW)
  @Concat_Field("@@crwk", CRWK)
  @Concat_Field("@@eqdy", EQDY)
  @Concat_Field("@@wkdp", WKDP)
  @Concat_Field("@@wkco", WKCO)
  @Concat_Field("@@wkfa", WKFA)
  @Concat_Field("@@wkac", WKAC)

  @Concat_Field("@@wksb", WKSB)
  @Concat_Field("@@jbcl", JBCL)
  @Concat_Field("@@wkrt", WKRT)
  @Concat_Field("@@wkdt", WKDT)
  @Concat_Field("@@tstp", timeStamp)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)
  @DecatErr_Field("@@type", "checktype")      @dtw_assign(Err_checktype, fieldValue)

  %if (errFound == "")
      %if(prCKTYPE == "1")
         @dtw_assign(checkType, "Void")
      %elseif(prCKTYPE == "2")
         @dtw_assign(checkType, "Manual")
      %elseif(prCKTYPE == "3")
         @dtw_assign(checkType, "Regular")
      %endif
      %if (maintenanceCode == "A")
          @Decat_Field("@@sepc")   @dtw_assign(prCKSEPC, fieldValue)
      %endif
      @Format_ConfMsg_Desc(maintenanceCode, "Sep Ck", $(prCKSEPC), "Check Type", $(checkType), "", "", confMessage)

      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)EmplPayTran.d2w/REPORT$(d2wVarBase)&amp;prCKTYPE=@dtw_rurlescseq(prCKTYPE)&amp;prCKSEPC=@dtw_rurlescseq(prCKSEPC)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif ((maintenanceCode == "C" || maintenanceCode == "D") && errFound != "" && Err_checktype != "")
      %if(prCKTYPE == "1")
         @dtw_assign(checkType, "Void")
      %elseif(prCKTYPE == "2")
         @dtw_assign(checkType, "Manual")
      %elseif(prCKTYPE == "3")
         @dtw_assign(checkType, "Regular")
      %endif
      @Format_ConfMsg_Desc("E", "Sep Ck", $(prCKSEPC), "Check Type", $(checkType), "<br>$(Err_checktype)", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)EmplPayTran.d2w/REPORT$(d2wVarBase)&amp;prCKTYPE=@dtw_rurlescseq(prCKTYPE)&amp;prCKSEPC=@dtw_rurlescseq(prCKSEPC)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;prCKTYPE=@dtw_rurlescseq(prCKTYPE)&amp;prCKSEPC=@dtw_rurlescseq(prCKSEPC)&amp;errFound=@dtw_rurlescseq(errFound)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}