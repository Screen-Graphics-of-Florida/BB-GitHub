%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Item Availability"
  d2wName                 = "VendCustProdAvail.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;vendCustNumber=@dtw_rurlescseq(vendCustNumber)&amp;vendCustName=@dtw_rurlescseq(vendCustName)&amp;vendCustFlag=@dtw_rurlescseq(vendCustFlag)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  buyerNumber             = "0"
  buyerSearch             = ""
  buyerSearchAppend       = ""
  imageExists             = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@customerName", "@dtw_rurlescseq(vendCustName)", "1", "a", workURL)
  @dtw_replace(workURL, "@@customerNumber", "@dtw_rurlescseq(vendCustNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@vendCustName", "@dtw_rurlescseq(vendCustName)", "1", "a", workURL)
  @dtw_replace(workURL, "@@vendCustNumber", "@dtw_rurlescseq(vendCustNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@vendCustFlag", "@dtw_rurlescseq(vendCustFlag)", "1", "a", workURL)
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (vendCustFlag == "C")
      @dtw_assign(customerNumber, $(vendCustNumber))
      @CustomerUserView(profileHandle, dataBaseID, userPass, customerNumber, " ")
  %else
      @dtw_assign(vendorNumber, $(vendCustNumber))
      @VendorUserView(profileHandle, dataBaseID, userPass, vendorNumber)
  %endif

  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterSearch.icl"
                  %INCLUDE "Menu.js"
                  %INCLUDE "NoFormValidate.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                	       %if (vendCustFlag == "C")
                               @dtw_assign(pageID, "CUSTITEMPRODAVAIL")
                	       %else
                               @dtw_assign(pageID, "VENDITEMPRODAVAIL")
                	       %endif
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          %if (vendCustFlag == "C")
                              @dtw_assign(uv_CustomerName, "VCVNCS")
                          %else
                              @dtw_assign(uv_VendorName, "VCVNCS")
                          %endif
                          @dtw_assign(uv_WarehouseName, "WIWHS")
                          @dtw_assign(uv_ProductClassName, "IMPCLS")
                          @dtw_assign(uv_ProdInventoryTypeName, "IMITC")
                          @dtw_assign(uv_ProdPartTypeName, "IMPTYP")
                          %INCLUDE "userview.icl"

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select VCVCF, VCVNCS, VCITEM, VCVCIT, VCVCITU, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(IMIMDS,' ') as IMIMDS, coalesce(IMIMDSU,' ') as IMIMDSU, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(WIWHS,0) as WIWHS, coalesce(WILORD,0) as WILORD, coalesce(WILRSQ,0) as WILRSQ ", stmtSQL)
                          @dtw_concat(fileSQL, " HDVCIT ", fileSQL)
                          @dtw_concat(fileSQL, " left join HDIMST on IMITEM=VCITEM ", fileSQL)
                          @dtw_concat(fileSQL, " left join HDVCIW on WIID  =VCID   ", fileSQL)
                          @dtw_concat(selectSQL, "VCVNCS=$(vendCustNumber) and VCVCF='$(vendCustFlag)' and IMKIT=' ' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Product_Avail_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Product_Avail_Query (IN   CHAR(64)    profileHandle,
				              CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count == "0" && wildCardSearch == "")
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)prodavail.d2w/REPORT$(d2wVarBase)&amp;vendCustItemsFound=N">
          @DTW_EXIT()
      %endif

      %if (vendCustFlag == "C")
          @DTW_ASSIGN(vendCustHdg, "Customer Item")
      %else
          @DTW_ASSIGN(vendCustHdg, "Vendor Item")
      %endif

      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      <table $(contentTable)>
          %if (vendCustFlag == "C")
              @Format_Header_URL("Customer", $(vendCustName), $(vendCustNumber), "$(homeURL)$(cGIPath)CustomerSelect.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(vendCustNumber)&amp;customerName=@dtw_rurlescseq(vendCustName)")
          %else
              @Format_Header_URL("Vendor", $(vendCustName), $(vendCustNumber), "$(homeURL)$(cGIPath)VendorSelect.d2w/REPORT$(genericVarBase)&amp;vendorNumber=@dtw_rurlescseq(vendCustNumber)&amp;vendorName=@dtw_rurlescseq(vendCustName)")
          %endif
      </table>

      $(hrTagAttr)
				
      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">$(vendCustHdg)</th>
                      <th class="colhdr">Description</th></tr>
                  <tr><td class="inputalph"><input type="text" name="srchCustItem" size="17" maxlength="15">
                          <input type="hidden" name="operCustItem" value="LIKE">
                      </td>
                      <td class="inputalph"><input type="text" name="srchItemDesc" size="15" maxlength="30">
                          <input type="hidden" name="operItemDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchCustItem.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          @DTW_ASSIGN(vendCustItemsFound, "")
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              @OrderBy_Sort("VCVCITU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=VendCustItem" title="Sequence By $(vendCustHdg)"> $(vendCustHdg)</a></th>
              @OrderBy_Sort("WIWHS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Whs" title="Sequence By Warehouse, Item Number"> Whs</a></th>
              @OrderBy_Sort("IMIMDSU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description, $(vendCustHdg)"> Description</a></th>
              %if (vendCustFlag == "C")
                  <th class="colhdr">Price</th>
              %endif
              @OrderBy_Sort("WILORD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=LastOrderDate" title="Sequence By Last Order Date, Last Order Quantity"> Last Order<br>Date</a></th>
              @OrderBy_Sort("WILRSQ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=LastOrderQty" title="Sequence By Last Order Quantity, Last Order Date"> Last Order<br>Quantity</a></th>
              <th class="colhdr">Quantity<br>Available</th>
              <th></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"
	
          %ROW{
%{ Check Item Comments %}
              @Check_Item_Comments(profileHandle, dataBaseID, V_VCITEM, vendCustFlag, vendCustNumber, documentType, headerTrailer, itemComments)
%{ Get Quantity Available %}
              @Get_Qty_Avail(profileHandle, dataBaseID, V_VCITEM, V_WIWHS, qtyAvailable)
%{ Get Unit Price %}
              %if (vendCustFlag == "C")
                  @Cust_Unit_Price(profileHandle, dataBaseID, vendCustNumber, V_VCITEM, unitPrice, V_WIWHS, piecesPerPricing)
              %else
                  @dtw_assign(unitPrice, "0")
              %endif

              @Format_Nbr($(unitPrice), F_unitPrice, $(prcNbrDec), $(amtEditCode), "", "", "")
              @Format_Nbr($(V_WILRSQ), F_WILRSQ, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(qtyAvailable), F_qtyAvailable, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Date(V_WILORD, "D", F_WILORD)
              @Format_Nbr($(V_WIWHS), F_WIWHS, "0", $(amtEditCode), "", "", "")
              @RtvFldDesc("WHWHS=$(V_WIWHS)", "HDWHSM", "WHWHNM", whsName)

              %INCLUDE "SetRowClass.icl"

              @dtw_assign(itemImage, "$(V_VCITEM)$(itemImageExt)")
              @dtwf_exists(itemImage, imageExists)
              <tr class="$(rowClass)">
                  <td class="colalph">$(V_VCVCIT)</td>                                      	
                  <td class="colnmbr" $(helpCursor)><span title="$(whsName)">$(F_WIWHS)</span></td>
                  <td class="colalph">$(V_IMIMDS)</td>
                  %if (vendCustFlag == "C")
                      %if (IMKIT == "K")
                          @RtvFldDesc("KTKTIT='$(V_VCITEM)'", "HDKIT", "KTKTPR", KTKTPR)
                      %endif
                      %if ((V_IMKIT == "" || (V_IMKIT == "K" && V_KTKTPR == "K")))
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)PricingInquiry.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(vendCustNumber)&amp;itemNumber=@dtw_rurlescseq(V_VCITEM)&amp;itemDescription=@dtw_rurlescseq(V_IMIMDS)&amp;warehouseNumber=@dtw_rurlescseq(V_WIWHS)&amp;productClass=@dtw_rurlescseq(V_IMPCLS)&amp;quantity=1" onclick="$(inquiryWinVar)" title="View Pricing">$(F_unitPrice)</a></td>
                      %else
                          <td class="colnmbr">$(F_unitPrice)</td>
                      %endif
                  %endif
                  <td class="colnmbr">$(F_WILORD)</td>
                  <td class="colnmbr">$(F_WILRSQ)</td>
                  <td class="colnmbr">$(F_qtyAvailable)</td>
                  %if (itemComments == "Y" && formatToPrint != "Y")
                      <td class="colicon"><a href="$(homeURL)$(cGIPath)ItemComments.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_VCITEM)&amp;itemDesc=@dtw_rurlescseq(V_IMIMDS)" onclick="$(commentWinVar)">$(commentExistImage)</a></td>
                  %elif(itemComments != "" && formatToPrint != "Y")
                      <td class="colicon"><a href="$(homeURL)$(cGIPath)VendCustItemComments.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_VCITEM)&amp;vendCustItemNumber=@dtw_rurlescseq(V_VCVCIT)&amp;itemDesc=@dtw_rurlescseq(V_IMIMDS)&amp;vendCustNumber=@dtw_rurlescseq(vendCustNumber)&amp;vendCustFlag=@dtw_rurlescseq(vendCustFlag)" onclick="$(commentWinVar)">$(commentExistImage)</a></td>
                  %else
                      <td class="colicon">&nbsp;</td>
                  %endif
                  %if (imageExists == "Y" && formatToPrint != "Y")
                      <td class="colicon"><a href="$(homeURL)$(cGIPath)ImageDisplay.d2w/DISPLAY$(genericVarBase)&amp;imageDisplayPath=$(homeURL)$(itemImage)&amp;imageDesc=@dtw_rurlescseq(V_IMIMDS)" onclick="$(itemImageWinVar)">$(foundImage)</a></td>
                  %endif
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {	
  %if (vendCustFlag == "C")
      @dtw_assign(uv_CustomerName, "VCVNCS")
  %else
      @dtw_assign(uv_VendorName, "VCVNCS")
  %endif
  @dtw_assign(uv_WarehouseName, "WIWHS")
  @dtw_assign(uv_ProductClassName, "IMPCLS")
  @dtw_assign(uv_InventoryTypeName, "IMITC")
  @dtw_assign(uv_PartTypeName, "IMPTYP")
  %INCLUDE "userview.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select VCVCF, VCVNCS, VCITEM, VCVCIT, VCVCITU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(IMIMDS,' ') as IMIMDS, coalesce(IMIMDSU,' ') as IMIMDSU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(WIWHS,0) as WIWHS, coalesce(WILORD,0) as WILORD, coalesce(WILRSQ,0) as WILRSQ ", stmtSQL)
  @dtw_concat(fileSQL, " HDVCIT ", fileSQL)
  @dtw_concat(fileSQL, " left join HDIMST on IMITEM=VCITEM ", fileSQL)
  @dtw_concat(fileSQL, " left join HDVCIW on WIID  =VCID   ", fileSQL)
  @dtw_concat(selectSQL, "VCVNCS=$(vendCustNumber) and VCVCF='$(vendCustFlag)' and IMKIT=' ' ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @Product_Avail_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) Product_Avail_XMLQuery (IN CHAR(64)    profileHandle,
				               CHAR(2)     dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      %if (vendCustFlag == "C")
          @XMLBeginTag("CustomerItemList")
	       @XMLIDTag(vendCustNumber, "Customer ID")
          @XMLTag(vendCustNumber, "CustomerNumber")
          @XMLTag(vendCustName, "CustomerName")
      %else
          @XMLBeginTag("VendorItemList")
	       @XMLIDTag(vendCustNumber, "Vendor ID")
          @XMLTag(vendCustNumber, "VendorNumber")
          @XMLTag(vendCustName, "VendorName")
      %endif

          %ROW{
              @XMLIDTag(V_VCITEM, "ItemNumber ID")
                  @XMLTag(V_VCITEM, "ItemNumber")
                  @XMLTag(V_IMIMDS, "ItemDescription")
                  %if (vendCustFlag == "C")
                     @XMLTag(V_VCVCIT, "CustomerItemNumber")
                  %else
                     @XMLTag(V_VCVCIT, "VendorItemNumber")
                  %endif
                  %if (V_WIWHS > "0")
                      @XMLTag(V_WIWHS, "WarehouseNumber")
                      @XMLTag(V_WILRSQ, "LastOrderQuantity")
                  %endif
              @XMLEndTag("ItemNumber")

          %}
      %if (vendCustFlag == "C")
          @XMLEndTag("Customer")
          @XMLEndTag("CustomerItemList")
      %else
          @XMLEndTag("Vendor")
          @XMLEndTag("VendorItemList")
      %endif
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"

  %if (vendCustFlag == "C")
      @DTW_ASSIGN(vendCustHdg, "Customer Item")
  %else
      @DTW_ASSIGN(vendCustHdg, "Vendor Item")
  %endif

  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "VCVCITU")
          @DTW_ASSIGN(orderByDisplay, "$(vendCustHdg)")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit ()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"

  %if (vendCustFlag == "C")
      @DTW_ASSIGN(vendCustHdg, "Customer Item Number")
  %else
      @DTW_ASSIGN(vendCustHdg, "Vendor Item Number")
  %endif

  %if (sequence == "VendCustItem")
      %if (orderBy == "VCVCITU")
          @DTW_ASSIGN(orderBy, "VCVCITU DESC")
          @DTW_ASSIGN(orderByDisplay, "$(vendCustHdg) (descending)")
      %else
          @DTW_ASSIGN(orderBy, "VCVCITU")
          @DTW_ASSIGN(orderByDisplay, "$(vendCustHdg)")
      %endif
  %elif (sequence == "Whs")
      %if (orderBy == "WIWHS,VCVCITU")
          @DTW_ASSIGN(orderBy, "WIWHS DESC,VCVCITU")
          @DTW_ASSIGN(orderByDisplay, "Warehouse (descending), $(vendCustHdg)")
      %else
          @DTW_ASSIGN(orderBy, "WIWHS,VCVCITU")
          @DTW_ASSIGN(orderByDisplay, "Warehouse, $(vendCustHdg)")
      %endif
  %elif (sequence == "Desc")
      %if (orderBy == "IMIMDSU,VCVCITU")
          @DTW_ASSIGN(orderBy, "IMIMDSU DESC,VCVCITU")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), $(vendCustHdg)")
      %else
          @DTW_ASSIGN(orderBy, "IMIMDSU,VCVCITU")
          @DTW_ASSIGN(orderByDisplay, "Description, $(vendCustHdg)")
      %endif
  %elif (sequence == "Item")
      %if (orderBy == "VCITEM")
          @DTW_ASSIGN(orderBy, "VCITEM DESC")
          @DTW_ASSIGN(orderByDisplay, "Item (descending)")
      %else
          @DTW_ASSIGN(orderBy, "VCITEM")
          @DTW_ASSIGN(orderByDisplay, "Item")
      %endif
  %elif (sequence == "LastOrderDate")
      %if (orderBy == "WILORD,WILRSQ Desc")
          @DTW_ASSIGN(orderBy, "WILORD DESC,WILRSQ Desc")
          @DTW_ASSIGN(orderByDisplay, "Last Order Date (descending), Last Order Qty (descending)")
      %else
          @DTW_ASSIGN(orderBy, "WILORD,WILRSQ Desc")
          @DTW_ASSIGN(orderByDisplay, "Last Order Date, Last Order Qty (descending)")
      %endif
  %elif (sequence == "LastOrderQty")
      %if (orderBy == "WILRSQ,WILORD Desc")
          @DTW_ASSIGN(orderBy, "WILRSQ DESC,WILORD Desc")
          @DTW_ASSIGN(orderByDisplay, "Last Order Qty (descending), Last Order Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "WILRSQ,WILORD Desc")
          @DTW_ASSIGN(orderByDisplay, "Last Order Qty, Last Order Date (descending)")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              function validate(searchForm) {
                  if (editNum(document.Search.srchUPC, 13, 0)
                      %if (V_CIINS1 != "")
                          && editNum(document.Search.srchNumeric01, 8, 5)
                      %endif
                      %if (V_CIINS2 != "")
                          && editNum(document.Search.srchNumeric02, 8, 5)
                      %endif
                      %if (V_CIINS3 != "")
                          && editNum(document.Search.srchNumeric03, 8, 5)
                      %endif
                      %if (V_CIINS4 != "")
                          && editNum(document.Search.srchNumeric04, 8, 5)
                      %endif
                      %if (V_CIINS5 != "")
                          && editNum(document.Search.srchNumeric05, 8, 5)
                      %endif
                     )
                  return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      %if (vendCustFlag == "C")
          @DTW_ASSIGN(vendCustHdg, "Customer Item")
      %else
          @DTW_ASSIGN(vendCustHdg, "Vendor Item")
      %endif

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ITEMSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">$(vendCustHdg)</td>
                              @dtw_assign(operNbr, "operCustItem")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchCustItem" type="text" size="30" maxlength="30"></td>
        		   </tr>	

                          <tr><td class="dsphdr">Item Number</td>
                              @dtw_assign(operNbr, "operItem")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchItem" type="text" size="15" maxlength="15">$(V_IMITEM)</td>
        		   </tr>	

                          <tr><td class="dsphdr">Item Description</td>
                              @dtw_assign(operNbr, "operItemDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchItemDesc" type="text" size="30" maxlength="30"></td>
        		   </tr>	

                          <tr><td class="dsphdr">Product Class</td>
                              @dtw_assign(operNbr, "operProdClass")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchProdClass" type="text" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Catalog Number</td>
                              @dtw_assign(operNbr, "operCatalog")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCatalog" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">U.P.C. Number</td>
                              @dtw_assign(operNbr, "operUpc")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchUPC" size="13" maxlength="13"></td>
                          </tr>

                          %if (V_CIIAS1 != "")		
                              <tr><td class="dsphdr">$(V_CIIAS1)</td>
                                  @dtw_assign(operNbr, "operAlpha01")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchAlpha01" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIIAS2 != "")		
                              <tr><td class="dsphdr">$(V_CIIAS2)</td>
                                  @dtw_assign(operNbr, "operAlpha02")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchAlpha02" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIIAS3 != "")		
                              <tr><td class="dsphdr">$(V_CIIAS3)</td>
                                  @dtw_assign(operNbr, "operAlpha03")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchAlpha03" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIIAS4 != "")		
                              <tr><td class="dsphdr">$(V_CIIAS4)</td>
                                  @dtw_assign(operNbr, "operAlpha04")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchAlpha04" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIIAS5 != "")		
                              <tr><td class="dsphdr">$(V_CIIAS5)</td>
                                  @dtw_assign(operNbr, "operAlpha05")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchAlpha05" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIINS1 != "")		
                              <tr><td class="dsphdr">$(V_CIINS1)</td>
                                  @dtw_assign(operNbr, "operNumeric01")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchNumeric01" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIINS2 != "")		
                              <tr><td class="dsphdr">$(V_CIINS2)</td>
                                  @dtw_assign(operNbr, "operNumeric02")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchNumeric02" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIINS3 != "")		
                              <tr><td class="dsphdr">$(V_CIINS3)</td>
                                  @dtw_assign(operNbr, "operNumeric03")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchNumeric03" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIINS4 != "")		
                              <tr><td class="dsphdr">$(V_CIINS4)</td>
                                  @dtw_assign(operNbr, "operNumeric04")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchNumeric04" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIINS5 != "")		
                              <tr><td class="dsphdr">$(V_CIINS5)</td>
                                   @dtw_assign(operNbr, "operNumeric05")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                 <td class="inputnmbr"><input type="text" name="srchNumeric05" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchCustItem.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  %if (vendCustFlag == "C")
      @DTW_ASSIGN(vendCustHdg, "Customer Item Number")
  %else
      @DTW_ASSIGN(vendCustHdg, "Vendor Item Number")
  %endif

  @Build_WildCard ("VCVCITU", "$(vendCustHdg)", $(srchCustItem), "U", operCustItem, "A")
  @Build_WildCard ("IMITEM", "Item Number", $(srchItem), "U", operItem, "A")
  @Build_WildCard ("IMIMDSU", "Item Description", $(srchItemDesc), "U", operItemDesc, "A")
  @Build_WildCard ("IMPCLS", "Product Class", $(srchProdClass), "U", operProdClass, "A")
  @Build_WildCard ("IMCATN", "Catalog Number", $(srchCatalog), "U", operCatalog, "A")
  @Build_WildCard ("IMUPC", "U.P.C. Number", $(srchUPC), "", operUpc, "N")
  @Build_WildCard ("IMUDA1", "$(V_CIIAS1)", $(srchAlpha01), "U", operAlpha01, "A")
  @Build_WildCard ("IMUDA2", "$(V_CIIAS2)", $(srchAlpha02), "U", operAlpha02, "A")
  @Build_WildCard ("IMUDA3", "$(V_CIIAS3)", $(srchAlpha03), "U", operAlpha03, "A")
  @Build_WildCard ("IMUDA4", "$(V_CIIAS4)", $(srchAlpha04), "U", operAlpha04, "A")
  @Build_WildCard ("IMUDA5", "$(V_CIIAS5)", $(srchAlpha05), "U", operAlpha05, "A")
  @Build_WildCard ("IMUDN1", "$(V_CIINS1)", $(srchNumeric01), "", operNumeric01, "N")
  @Build_WildCard ("IMUDN2", "$(V_CIINS2)", $(srchNumeric02), "", operNumeric02, "N")
  @Build_WildCard ("IMUDN3", "$(V_CIINS3)", $(srchNumeric03), "", operNumeric03, "N")
  @Build_WildCard ("IMUDN4", "$(V_CIINS4)", $(srchNumeric04), "", operNumeric04, "N")
  @Build_WildCard ("IMUDN5", "$(V_CIINS5)", $(srchNumeric05), "", operNumeric05, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}