%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define{
  page_title              = "Product Class"
  d2wName                 = "ProdClass.d2w"
  d2wVarBase              = "$(genericVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HHDPCM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "PRODCLASS")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select HDPCLS.*, upper(PCPCDS) as PCPCDSU  ", stmtSQL)
                      @dtw_concat(fileSQL, " HDPCLS ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, "PCPCLS>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @ProdClass_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) ProdClass_Query (IN CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td ><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)ProdClassMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Product<br>Class</th>
                      <th class="colhdr">Description</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchClass" size="4" maxlength="4">
                          <input type="hidden" name="operClass" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchDesc" size="20" maxlength="20">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchClass.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("PCPCLS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Type" title="Sequence By Product Class">Product<br>Class</a></th>
              @OrderBy_Sort("PCPCDSU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description, Product Class">Description</a></th>
              @OrderBy_Sort("PCIAAC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=InvAssetAccount" title="Sequence By Inventory Asset Account, Product Class">Inventory Asset<br>Account</a></th>
              %if (V_HDPDRL == "0")
                  @OrderBy_Sort("PCSLAC", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SalesAccount" title="Sequence By Sales Account, Product Class">Sales<br>Account</a></th>
                  @OrderBy_Sort("PCCSAC", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CostAccount" title="Sequence By Cost Of Goods Sold Account, Product Class">Cost Of Goods Sold<br>Account</a></th>
              %endif
              %if (V_HDTCV=="A")
                  @OrderBy_Sort("PCKAAC", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=KitAccount" title="Sequence By Kit Additional Cost Account, Product Class">Kit Additional Cost<br>Account</a></th>
              %endif
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(genericVarBase)&amp;productClass=@dtw_rurlescseq(V_PCPCLS)&amp;productClassDesc=@dtw_rurlescseq(V_PCPCDS)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_PCPCDS), $(V_PCPCLS), "", "", "", "", confirmDesc)
              @dtw_assign(F_SalesAcct, "")
              @dtw_assign(F_CostAcct, "")
              @dtw_assign(F_InvAcct, "")
              @dtw_assign(F_KitAcct, "")
              @dtw_assign(H_SalesAcct, "")
              @dtw_assign(H_CostAcct, "")
              @dtw_assign(H_InvAcct, "")
              @dtw_assign(H_KitAcct, "")
              %if (V_PCSLAC !="0" && V_HDPDRL == "0")
                  @Format_Acct(V_PCSLAC, V_PCSLSB, "", F_SalesAcct)
                  @RtvFldDesc("CHACCT=$(V_PCSLAC) and CHSUB=$(V_PCSLSB) ", "HDCHRT", "CHCHDS", H_SalesAcct)
              %endif
              %if (V_PCCSAC !="0" && V_HDPDRL == "0")
                  @Format_Acct(V_PCCSAC, V_PCCSSB, "", F_CostAcct)
                  @RtvFldDesc("CHACCT=$(V_PCCSAC) and CHSUB=$(V_PCCSSB) ", "HDCHRT", "CHCHDS", H_CostAcct)
              %endif
              %if (V_PCIAAC !="0")
                  @Format_Acct(V_PCIAAC, V_PCIASB, "", F_InvAcct)
                  @RtvFldDesc("CHACCT=$(V_PCIAAC) and CHSUB=$(V_PCIASB) ", "HDCHRT", "CHCHDS", H_InvAcct)
              %endif
              %if (V_PCKAAC !="0" && V_HDTCV=="A")
                  @Format_Acct(V_PCKAAC, V_PCKASB, "", F_KitAcct)
                  @RtvFldDesc("CHACCT=$(V_PCKAAC) and CHSUB=$(V_PCKASB) ", "HDCHRT", "CHCHDS", H_KitAcct)
              %endif

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)ProdClassMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_04 == "Y")
                              <a href="$(homeURL)$(cGIPath)ProdClassMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)ProdClassMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                          %if (V_HDPDRL > "0")
                              <a href="$(homeURL)$(cGIPath)ProdClassByPlant.d2w/REPORT$(maintainVar)">$(pltImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_PCPCLS)</td>
                  <td class="colalph">$(V_PCPCDS)</td>
                  <td class="colcode" $(helpCursor)><span title="$(H_InvAcct)">$(F_InvAcct)</span></td>
                  %if (V_HDPDRL == "0")
                      <td class="colcode" $(helpCursor)><span title="$(H_SalesAcct)">$(F_SalesAcct)</span></td>
                      <td class="colcode" $(helpCursor)><span title="$(H_CostAcct)">$(F_CostAcct)</span></td>
                  %endif
                  %if (V_HDTCV=="A")
                      <td class="colcode" $(helpCursor)><span title="$(H_KitAcct)">$(F_KitAcct)</span></td>
                  %endif
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select HDPCLS.*, upper(PCPCDS) as PCPCDSU  ", stmtSQL)
  @dtw_concat(fileSQL, " HDPCLS ", fileSQL)
  %if (wildCardSearch!="")
      @dtw_concat(selectSQL, "PCPCLS>' ' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @ProdClass_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) ProdClass_XMLQuery (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("ProductClassList")

          %ROW{
	       @XMLIDTag(V_PCPCLS, "ProductClass ID")
                  @XMLTag(V_PCPCLS, "ProductClass")
                  @XMLTag(V_PCPCDS, "Description")
                  @XMLTag(@dtw_rformat(@dtw_rmultiply(V_PCLOPP, "100"),"","4"), "LowPctProfit")
                  @XMLTag(@dtw_rformat(@dtw_rmultiply(V_PCHIPP, "100"),"","4"), "HighPctProfit")
                  @XMLTag(V_PCCOMM, "Commissionable")
                  @XMLTag(@dtw_rformat(@dtw_rmultiply(V_PCCMPC, "100"),"","4"), "CommissionPct")
                  @XMLTag(V_PCIAAC, "InvAssetAccount")
                  @XMLTag(V_PCIASB, "InvAssetSubaccount")
                  @XMLTag("$(V_PCIAAC)-$(V_PCIASB)", "InvAssetAccountSub")
                  %if (V_HDPDRL == "0")
                      @XMLTag(V_PCSLAC, "SalesAccount")
                      @XMLTag(V_PCSLSB, "SalesSubaccount")
                      @XMLTag("$(V_PCSLAC)-$(V_PCSLSB)", "SalesAccountSub")
                      @XMLTag(V_PCCSAC, "CostAccount")
                      @XMLTag(V_PCCSSB, "CostSubaccount")
                      @XMLTag("$(V_PCCSAC)-$(V_PCCSSB)", "CostAccountSub")
                  %endif
                  %if (V_HDTCV=="A")
                      @XMLTag(V_PCKAAC, "KitAccount")
                      @XMLTag(V_PCKASB, "KitSubaccount")
                      @XMLTag("$(V_PCKAAC)-$(V_PCKASB)", "KitAccountSub")
                  %endif
              @XMLEndTag("ProductClass")
	       %}

      @XMLEndTag("ProductClassList")
  %}
%}

%HTML(REPORT){
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "PCPCDSU,PCPCLS")
          @DTW_ASSIGN(orderByDisplay, "Description, Product Class")
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT){
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit ()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT){
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY){
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Type")
      %if (orderBy == "PCPCLS")
          @DTW_ASSIGN(orderBy, "PCPCLS DESC")
          @DTW_ASSIGN(orderByDisplay, "Product Class (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PCPCLS")
          @DTW_ASSIGN(orderByDisplay, "Product Class")
      %endif
  %elseif (sequence == "Desc")
      %if (orderBy == "PCPCDSU,PCPCLS")
          @DTW_ASSIGN(orderBy, "PCPCDSU DESC,PCPCLS")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Product Class")
      %else
          @DTW_ASSIGN(orderBy, "PCPCDSU,PCPCLS")
          @DTW_ASSIGN(orderByDisplay, "Description, Product Class")
      %endif
  %elseif (sequence == "SalesAccount")
      %if (orderBy == "PCSLAC,PCSLSB,PCPCLS")
          @DTW_ASSIGN(orderBy, "PCSLAC DESC,PCSLSB DESC,PCPCLS")
          @DTW_ASSIGN(orderByDisplay, "Sales Account (descending), Product Class")
      %else
          @DTW_ASSIGN(orderBy, "PCSLAC,PCSLSB,PCPCLS")
          @DTW_ASSIGN(orderByDisplay, "Sales Account, Product Class")
      %endif
  %elseif (sequence == "CostAccount")
      %if (orderBy == "PCCSAC,PCCSSB,PCPCLS")
          @DTW_ASSIGN(orderBy, "PCCSAC DESC,PCCSSB DESC,PCPCLS")
          @DTW_ASSIGN(orderByDisplay, "Cost Of Goods Sold Account (descending), Product Class")
      %else
          @DTW_ASSIGN(orderBy, "PCCSAC,PCCSSB,PCPCLS")
          @DTW_ASSIGN(orderByDisplay, "Cost Of Goods Sold Account, Product Class")
      %endif
  %elseif (sequence == "InvAssetAccount")
      %if (orderBy == "PCIAAC,PCIASB,PCPCLS")
          @DTW_ASSIGN(orderBy, "PCIAAC DESC,PCIASB DESC,PCPCLS")
          @DTW_ASSIGN(orderByDisplay, "Inventory Asset Account (descending), Product Class")
      %else
          @DTW_ASSIGN(orderBy, "PCIAAC,PCIASB,PCPCLS")
          @DTW_ASSIGN(orderByDisplay, "Inventory Asset Account, Product Class")
      %endif
  %elseif (sequence == "KitAccount")
      %if (orderBy == "PCKAAC,PCKASB,PCPCLS")
          @DTW_ASSIGN(orderBy, "PCKAAC DESC,PCKASB DESC,PCPCLS")
          @DTW_ASSIGN(orderByDisplay, "Kit Additional Cost Account (descending), Product Class")
      %else
          @DTW_ASSIGN(orderBy, "PCKAAC,PCKASB,PCPCLS")
          @DTW_ASSIGN(orderByDisplay, "Kit Additional Cost Account, Product Class")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (
                      %if (V_HDTCV=="A")
                          editNum(document.Search.srchKitAcct, 4, 0) &&
                          editNum(document.Search.srchKitSub, 4, 0)  &&
                      %endif
                      %if (V_HDPDRL == "0")
                          editNum(document.Search.srchSalesAcct, 4, 0) &&
                          editNum(document.Search.srchSalesSub, 4, 0)  &&
                          editNum(document.Search.srchCostAcct, 4, 0) &&
                          editNum(document.Search.srchCostSub, 4, 0)  &&
                      %endif
                      editNum(document.Search.srchInvAcct, 4, 0) &&
                      editNum(document.Search.srchInvSub, 4, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PRODCLASSSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Product Class</td>
                              @dtw_assign(operNbr, "operClass")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchClass" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchDesc" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Inventory Asset Account</td>
                              @dtw_assign(operNbr, "operInvAcct")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchInvAcct" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Inventory Asset SubAccount</td>
                              @dtw_assign(operNbr, "operInvSub")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchInvSub" size="4" maxlength="4"></td>
                          </tr>

                          %if (V_HDPDRL == "0")
                              <tr><td class="dsphdr">Sales Account</td>
                                  @dtw_assign(operNbr, "operSalesAcct")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchSalesAcct" size="4" maxlength="4"></td>
                              </tr>

                              <tr><td class="dsphdr">Sales SubAccount</td>
                                  @dtw_assign(operNbr, "operSalesSub")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchSalesSub" size="4" maxlength="4"></td>
                              </tr>

                              <tr><td class="dsphdr">Cost Of Goods Sold Account</td>
                                  @dtw_assign(operNbr, "operCostAcct")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchCostAcct" size="4" maxlength="4"></td>
                              </tr>

                              <tr><td class="dsphdr">Cost Of Goods Sold SubAccount</td>
                                  @dtw_assign(operNbr, "operCostSub")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchCostSub" size="4" maxlength="4"></td>
                              </tr>
                          %endif
                          %if (V_HDTCV=="A")
                              <tr><td class="dsphdr">Kit Additional Cost Account</td>
                                  @dtw_assign(operNbr, "operKitAcct")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchKitAcct" size="4" maxlength="4"></td>
                              </tr>

                              <tr><td class="dsphdr">Kit Additional Cost SubAccount</td>
                                  @dtw_assign(operNbr, "operKitSub")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchKitSub" size="4" maxlength="4"></td>
                              </tr>
                          %endif

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchClass.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("PCPCLS", "Product Class", $(srchClass), "U", operClass, "A")
  @Build_WildCard ("upper(PCPCDS)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("PCIAAC", "Inventory Asset Account", $(srchInvAcct), "", operInvAcct, "N")
  @Build_WildCard ("PCIASB", "Inventory Asset SubAccount", $(srchInvSub), "", operInvSub, "N")
  @Build_WildCard ("PCSLAC", "Sales Account", $(srchSalesAcct), "", operSaleAcct, "N")
  @Build_WildCard ("PCSLSB", "Sales SubAccount", $(srchSalesSub), "", operSalesSub, "N")
  @Build_WildCard ("PCCSAC", "Cost Of Goods Sold Account", $(srchCostAcct), "", operCostAcct, "N")
  @Build_WildCard ("PCCSSB", "Cost Of Goods Sold SubAccount", $(srchCostSub), "", operCostSub, "N")
  @Build_WildCard ("PCKAAC", "Kit Additional Cost Account", $(srchKitAcct), "", operKitAcct, "N")
  @Build_WildCard ("PCKASB", "Kit Additional Cost SubAccount", $(srchKitSub), "", operKitSub, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}