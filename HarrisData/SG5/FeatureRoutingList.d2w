%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Feature Routing List"
  d2wName                 = "FeatureRoutingList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.featureOnly.checked == false &&
                      document.Chg.featureFeaturedItem.checked == false &&
                      document.Chg.optionOnly.checked == false &&
                      document.Chg.optionFeature.checked == false)
                      {alert("Must select at least one type of routings");
                      document.Chg.featureOnly.focus();
                      document.Chg.featureOnly();
                      return false;}
                  if (editNum(document.Chg.fromPlantNumber, 3, 0) &&
                      editNum(document.Chg.toPlantNumber, 3, 0) &&
                      editFromToAll(document.Chg.fromPlantNumber, document.Chg.toPlantNumber, document.Chg.allPlantNumber, 3) &&
                      editFromToAll(document.Chg.fromFeature, document.Chg.toFeature, document.Chg.allFeature, "A") &&
                      editFromToAll(document.Chg.fromOption, document.Chg.toOption, document.Chg.allOption, "A") &&
                      editFromToAll(document.Chg.fromFeaturedItem, document.Chg.toFeaturedItem, document.Chg.allFeaturedItem, "A")
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "FEATUREROUTINGLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromPlantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@feat", "featureOnly") @dtw_assign(Err_N1FEAT,  fieldValue)
                                  @DecatErr_Field("@@ffi@", "featureFeaturedItem") @dtw_assign(Err_N1FITM,  fieldValue)
                                  @DecatErr_Field("@@optn", "optionOnly") @dtw_assign(Err_N1OPTN,  fieldValue)
                                  @DecatErr_Field("@@opft", "optionFeature") @dtw_assign(Err_N1OPFT,  fieldValue)
                                  @DecatErr_Field("@@fplt", "fromPlantNumber")        @dtw_assign(Err_N1FPLT,  fieldValue)
                                  @DecatErr_Field("@@ffea", "fromFeature")        @dtw_assign(Err_N1FFEAT,  fieldValue)
                                  @DecatErr_Field("@@ffop", "fromOption")        @dtw_assign(Err_N1FOPTN,  fieldValue)
                                  @DecatErr_Field("@@fitm", "fromFeaturedItem")        @dtw_assign(Err_N1FITEM,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@feat")  @dtw_assign(V_N1FEAT,  fieldValue)
                                  @Decat_Field("@@ffi@")  @dtw_assign(V_N1FITM,  fieldValue)
                                  @Decat_Field("@@optn")  @dtw_assign(V_N1OPTN,  fieldValue)
                                  @Decat_Field("@@opft")  @dtw_assign(V_N1OPFT,  fieldValue)
                                  @Decat_Field("@@fplt")  @dtw_assign(V_N1FPLT,  fieldValue)
                                  @Decat_Field("@@tplt")  @dtw_assign(V_N1TPLT,  fieldValue)
                                  @Decat_Field("@@aplt")  @dtw_assign(V_N1APLT,  fieldValue)
                                  @Decat_Field("@@ffea")  @dtw_assign(V_N1FFEAT,  fieldValue)
                                  @Decat_Field("@@tfea")  @dtw_assign(V_N1TFEAT,  fieldValue)
                                  @Decat_Field("@@afea")  @dtw_assign(V_N1AFEAT,  fieldValue)
                                  @Decat_Field("@@fopt")  @dtw_assign(V_N1FOPTN,  fieldValue)
                                  @Decat_Field("@@topt")  @dtw_assign(V_N1TOPTN,  fieldValue)
                                  @Decat_Field("@@aopt")  @dtw_assign(V_N1AOPTN,  fieldValue)
                                  @Decat_Field("@@fitm")  @dtw_assign(V_N1FITEM,  fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N1TITEM,  fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N1AITEM,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1FEAT == "1")
                                      @dtw_assign(checkedFeatureOnly, "CHECKED")
                                  %else
                                      @dtw_assign(checkedFeatureOnly, "")
                                  %endif
                                  %if (V_N1FITM == "1")
                                      @dtw_assign(checkedFeatureFeaturedItem, "CHECKED")
                                  %else
                                      @dtw_assign(checkedFeatureFeaturedItem, "")
                                  %endif
                                  %if (V_N1OPTN == "1")
                                      @dtw_assign(checkedOptionOnly, "CHECKED")
                                  %else
                                      @dtw_assign(checkedOptionOnly, "")
                                  %endif
                                  %if (V_N1OPFT == "1")
                                      @dtw_assign(checkedOptionFeature, "CHECKED")
                                  %else
                                      @dtw_assign(checkedOptionFeature, "")
                                  %endif
                                  %if (V_N1APLT == "ALL")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPlantNumber, "")
                                  %endif
                                  %if (V_N1AFEAT == "ALL")
                                      @dtw_assign(checkedallFeature, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallFeature, "")
                                  %endif
                                  %if (V_N1AOPTN == "ALL")
                                      @dtw_assign(checkedallOption, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallOption, "")
                                  %endif
                                  %if (V_N1AITEM == "ALL")
                                      @dtw_assign(checkedallFeaturedItem, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallFeaturedItem, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedFeatureOnly, "CHECKED")
                                  @dtw_assign(checkedFeatureFeaturedItem, "CHECKED")
                                  @dtw_assign(checkedOptionOnly, "CHECKED")
                                  @dtw_assign(checkedOptionFeature, "CHECKED")
                                  @RtvDftPlant(plantNumber, plantName)
                                  %if (plantNumber == "0")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(V_N1FPLT, plantNumber)
                                      @dtw_assign(V_N1TPLT, plantNumber)
                                      @dtw_assign(checkedallPlantNumber, "")
                                      @dtw_assign(focusField, "fromFeature")
                                  %endif
                                  @dtw_assign(checkedallFeature, "CHECKED")
                                  @dtw_assign(checkedallOption, "CHECKED")
                                  @dtw_assign(checkedallFeaturedItem, "CHECKED")
                              %endif
                          </table>

                          <table $(contentTable)>
                              @SetTextOvr(Err_N1FEAT)
                              <tr><td class="dsphdr"><span $(textOvr)>Select Type Of Routings </span></td>
                                  <td class="inputnmbr"><input name="featureOnly" type="checkbox" VALUE='1' $(checkedFeatureOnly)>Feature Only</td>
                              </tr>
                              @DspErrMsg(Err_N1FEAT)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="featureFeaturedItem" type="checkbox" VALUE='1' $(checkedFeatureFeaturedItem)>Feature/Featured Item</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="optionOnly" type="checkbox" VALUE='1' $(checkedOptionOnly)>Option Only</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="optionFeature" type="checkbox" VALUE='1' $(checkedOptionFeature)>Option/Feature</td>
                              </tr>

                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_N1FPLT)
                              <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                  <td class="inputnmbr"><input name="fromPlantNumber" value="$(V_N1FPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromPlantNumber&amp;fldDesc=fplantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fplantName"  type="hidden"></td>
                                  <td class="inputnmbr"><input name="toPlantNumber" value="$(V_N1TPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toPlantNumber&amp;fldDesc=tplantName" onclick="$(searchWinVar)">  $(searchImage) </a><input name="tplantName"  type="hidden"></td>
                                  <td class="inputalph"><input name="allPlantNumber" value='ALL' $(checkedallPlantNumber) type="checkbox" onClick="if (this.checked) this.form.fromPlantNumber.value='', this.form.toPlantNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FPLT)

                              @SetTextOvr(Err_N1FFEAT)
                              <tr><td class="dsphdr"><span $(textOvr)>Feature</span></td>
                                  <td class="inputalph"><input name="fromFeature" value="$(V_N1FFEAT)" type="text" size="15" maxlength="15"></td>
                                  <td class="inputalph"><input name="toFeature" value="$(V_N1TFEAT)" type="text" size="15" maxlength="15"></td>
                                  <td class="inputalph"><input name="allFeature" value='ALL' $(checkedallFeature) type="checkbox" onClick="if (this.checked) this.form.fromFeature.value='', this.form.toFeature.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FFEAT)

                              @SetTextOvr(Err_N1FOPTN)
                              <tr><td class="dsphdr"><span $(textOvr)>Option</span></td>
                                  <td class="inputalph"><input name="fromOption" value="$(V_N1FOPTN)" type="text" size="15" maxlength="15"></td>
                                  <td class="inputalph"><input name="toOption" value="$(V_N1TOPTN)" type="text" size="15" maxlength="15"></td>
                                  <td class="inputalph"><input name="allOption" value='ALL' $(checkedallOption) type="checkbox" onClick="if (this.checked) this.form.fromOption.value='', this.form.toOption.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FOPTN)

                              @SetTextOvr(Err_N1FITEM)
                              <tr><td class="dsphdr"><span $(textOvr)>Featured Item</span></td>
                                  <td class="inputalph"><input name="fromFeaturedItem" value="$(V_N1FITEM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromFeaturedItem&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toFeaturedItem" value="$(V_N1TITEM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toFeaturedItem&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allFeaturedItem" value='ALL' $(checkedallFeaturedItem) type="checkbox" onClick="if (this.checked) this.form.fromFeaturedItem.value='', this.form.toFeaturedItem.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FITEM)

                          </table>

                          @dtw_assign(envProgram, "HPD104")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HPDFRT_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allPlantNumber)
  @dtw_mUPPERCASE(fromFeature)
  @dtw_mUPPERCASE(toFeature)
  @dtw_mUPPERCASE(allFeature)
  @dtw_mUPPERCASE(fromOption)
  @dtw_mUPPERCASE(toOption)
  @dtw_mUPPERCASE(allOption)
  @dtw_mUPPERCASE(fromFeaturedItem)
  @dtw_mUPPERCASE(toFeaturedItem)
  @dtw_mUPPERCASE(allFeaturedItem)

  @dtw_assign(fromPlantNumber,@dtw_rstrip(fromPlantNumber))
  @dtw_assign(toPlantNumber,@dtw_rstrip(toPlantNumber))

  %if (allPlantNumber != "ALL")
      @dtw_assign(allPlantNumber, "")
  %endif
  %if (allFeature != "ALL")
      @dtw_assign(allFeature, "")
  %endif
  %if (allOption != "ALL")
      @dtw_assign(allOption, "")
  %endif
  %if (allFeaturedItem != "ALL")
      @dtw_assign(allFeaturedItem, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@feat", featureOnly)
  @Concat_Field("@@ffi@", featureFeaturedItem)
  @Concat_Field("@@optn", optionOnly)
  @Concat_Field("@@opft", optionFeature)
  @Concat_Field("@@fplt", fromPlantNumber)
  @Concat_Field("@@tplt", toPlantNumber)
  @Concat_Field("@@aplt", allPlantNumber)
  @Concat_Field("@@ffea", fromFeature)
  @Concat_Field("@@tfea", toFeature)
  @Concat_Field("@@afea", allFeature)
  @Concat_Field("@@fopt", fromOption)
  @Concat_Field("@@topt", toOption)
  @Concat_Field("@@aopt", allOption)
  @Concat_Field("@@fitm", fromFeaturedItem)
  @Concat_Field("@@titm", toFeaturedItem)
  @Concat_Field("@@aitm", allFeaturedItem)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}