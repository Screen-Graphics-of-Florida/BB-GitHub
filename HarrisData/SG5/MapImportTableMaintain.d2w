%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Import Table Maintenance"
  d2wName                 = "MapImportTableMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;importKey=@dtw_rurlescseq(importKey)&amp;passedImportTable=@dtw_rurlescseq(passedImportTable)&amp;fromImportTable=@dtw_rurlescseq(fromImportTable)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;updRecNbr=@dtw_rurlescseq(updRecNbr)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;importTable=@dtw_rurlescseq(importTable)&amp;maintenanceCode=D"
  programName             = "HSYITM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	

  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function confirmDelete() {return confirm("$(delRecordConf)")}
              function validate(chgForm) {
                  if (document.Chg.importTable.value =="" ||
                      document.Chg.importTableDescription.value =="")
                         {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.positionPlacement, 5, 0) &&
                      editNum(document.Chg.recTypeLength, 1, 0)
                      )
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "MAPIMPORTTABLEMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " SYMITB ", fileSQL)
                          @dtw_concat(selectSQL, " FFIMKY=$(importKey) and FFIFIL='$(importTable)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "FHDESC", V_FHDESC)
          @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "CHAR(FHMPKY)", V_FHMPKY)
          @Format_Header("Import Definition", $(V_FHDESC), $(importKey))

          @RtvFldDesc("MHMPKY=$(V_FHMPKY)", "SYMMHD", "MHDESC", V_MHDESC)
          @RtvFldDesc("MHMPKY=$(V_FHMPKY)", "SYMMHD", "MHWPGM", V_MHWPGM)
          @Format_Header("Map Definition", $(V_MHDESC), $(V_MHWPGM))
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          %ROW {
              %if (errFound != "" || maintenanceCode == "A")
                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(edtVar, "")
                      @dtw_assign(focusField, "importTable")
                  %else
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@ifil", "importTable")                @dtw_assign(Err_FFIFIL, fieldValue)
                      @DecatErr_Field("@@desc", "importTableDescription")     @dtw_assign(Err_FFDESC, fieldValue)
                      @DecatErr_Field("@@fixf", "fixedFormat")                @dtw_assign(Err_FFFIXF, fieldValue)
                      @DecatErr_Field("@@fdlm", "fieldDelimiter")             @dtw_assign(Err_FFFDLM, fieldValue)
                      @DecatErr_Field("@@rtps", "positionPlacement")          @dtw_assign(Err_FFRTPS, fieldValue)
                      @DecatErr_Field("@@rtln", "recTypeLength")              @dtw_assign(Err_FFRTLN, fieldValue)
                      @DecatErr_Field("@@dtfm", "dateFormat")                 @dtw_assign(Err_FFDTFM, fieldValue)
                      @DecatErr_Field("@@pdfm", "periodFormat")               @dtw_assign(Err_FFPDFM, fieldValue)
                      @DecatErr_Field("@@tmfm", "timeFormat")                 @dtw_assign(Err_FFTMFM, fieldValue)
                  %endif

                  @Decat_Field("@@ifil")   @dtw_assign(V_FFIFIL, fieldValue)
                  @Decat_Field("@@desc")   @dtw_assign(V_FFDESC, fieldValue)
                  @Decat_Field("@@fixf")   @dtw_assign(V_FFFIXF, fieldValue)
                  @Decat_Field("@@fdlm")   @dtw_assign(V_FFFDLM, fieldValue)
                  @Decat_Field("@@rtps")   @dtw_assign(V_FFRTPS, fieldValue)
                  @Decat_Field("@@rtln")   @dtw_assign(V_FFRTLN, fieldValue)
                  @Decat_Field("@@dtfm")   @dtw_assign(V_FFDTFM, fieldValue)
                  @Decat_Field("@@pdfm")   @dtw_assign(V_FFPDFM, fieldValue)
                  @Decat_Field("@@tmfm")   @dtw_assign(V_FFTMFM, fieldValue)

                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(focusField, "importTable")
                  %endif

                  @dtw_assign(errFound, "")

              %elif (maintenanceCode == "Z")
                  @dtw_assign(focusField, "importTable")
              %else
                  @dtw_assign(focusField, "importTableDescription")
              %endif

              <table $(contentTable)>
                  @SetTextOvr(Err_FFIFIL)
                  <tr><td class="dsphdr"><span $(textOvr)>Import Table</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input type="text" name="importTable" value="$(V_FFIFIL)" size="10" maxlength="10">$(reqFieldChar)</td>
                      %else
                          <td class="inputalph"><input type="hidden" name="importTable" value="$(V_FFIFIL)">$(V_FFIFIL) $(fieldDesc)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_FFIFIL)

                  @SetTextOvr(Err_FFDESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input type="text" name="importTableDescription" value="$(V_FFDESC)" size="50" maxlength="50">$(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_FFDESC)

                  @RtvFldDesc("FLTYPE='BY' and FLVALU='$(V_FFFIXF)'", "SYFLAG", "FLDESC", fieldDesc)
                  @SetTextOvr(Err_FFFIXF)
                  <tr><td class="dsphdr"><span $(textOvr)>Fixed Format</span></td>
                      <td class="inputalph"><input type="text" name="fixedFormat" value="$(V_FFFIXF)" size="10" maxlength="1">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=BY&amp;flagSrchHdr=@dtw_rurlescseq("Fixed Format")&amp;docName=Chg&amp;fldName=fixedFormat&amp;fldDesc=fixedFormatDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                            <input type="text" disabled name="fixedFormatDesc" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_FFFIXF)

                  @SetTextOvr(Err_FFFDLM)
                  <tr><td class="dsphdr"><span $(textOvr)>Column Delimiter</span></td>
                      <td class="inputalph"><input type="text" name="fieldDelimiter" value="$(V_FFFDLM)" size="10" maxlength="1"></td>
                  </tr>
                  @DspErrMsg(Err_FFFDLM)

                  @SetTextOvr(Err_FFRTPS)
                  <tr><td class="dsphdr"><span $(textOvr)>Row Type Position/Placement</span></td>
                      <td class="inputnmbr"><input type="text" name="positionPlacement" value="$(V_FFRTPS)" size="10" maxlength="5"></td>
                  </tr>
                  @DspErrMsg(Err_FFRTPS)

                  @SetTextOvr(Err_FFRTLN)
                  <tr><td class="dsphdr"><span $(textOvr)>Row Type Length</span></td>
                      <td class="inputnmbr"><input type="text" name="recTypeLength" value="$(V_FFRTLN)" size="10" maxlength="1"></td>
                  </tr>
                  @DspErrMsg(Err_FFRTLN)

                  @RtvFldDesc("FLTYPE='DATEFMT' and FLVALU='$(V_FFDTFM)'", "SYFLAG", "FLDESC", fieldDesc)
                  @SetTextOvr(Err_FFDTFM)
                  <tr><td class="dsphdr"><span $(textOvr)>Date Format</span></td>
                      <td class="inputalph"><input type="text" name="dateFormat" value="$(V_FFDTFM)" size="10" maxlength="10">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=DATEFMT&amp;flagSrchHdr=@dtw_rurlescseq("Date Format")&amp;docName=Chg&amp;fldName=dateFormat&amp;fldDesc=dateFormatDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                            <input type="text" disabled name="dateFormatDesc" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_FFDTFM)

                  @RtvFldDesc("FLTYPE='PDFMT' and FLVALU='$(V_FFPDFM)'", "SYFLAG", "FLDESC", fieldDesc)
                  @SetTextOvr(Err_FFPDFM)
                  <tr><td class="dsphdr"><span $(textOvr)>Period Format</span></td>
                      <td class="inputalph"><input type="text" name="periodFormat" value="$(V_FFPDFM)" size="10" maxlength="10">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=PDFMT&amp;flagSrchHdr=@dtw_rurlescseq("Period Format")&amp;docName=Chg&amp;fldName=periodFormat&amp;fldDesc=periodFormatDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                            <input type="text" disabled name="periodFormatDesc" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_FFPDFM)

                  @RtvFldDesc("FLTYPE='TIMEFMT' and FLVALU='$(V_FFTMFM)'", "SYFLAG", "FLDESC", fieldDesc)
                  @SetTextOvr(Err_FFTMFM)
                  <tr><td class="dsphdr"><span $(textOvr)>Time Format</span></td>
                      <td class="inputalph"><input type="text" name="timeFormat" value="$(V_FFTMFM)" size="10" maxlength="10">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=TIMEFMT&amp;flagSrchHdr=@dtw_rurlescseq("Time Format")&amp;docName=Chg&amp;fldName=timeFormat&amp;fldDesc=timeFormatDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                            <input type="text" disabled name="timeFormatDesc" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_FFTMFM)

              </table>
          %}

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSYITM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  %if (importTableDescription == "")
      @RtvFldDesc("FFIMKY=$(importKey) and FFIFIL='$(importTable)'", "SYMITB", "FFDESC", importTableDescription)
  %endif

  @dtw_mUPPERCASE(importTable)
  @dtw_mUPPERCASE(fixedFormat)
  @dtw_mUPPERCASE(dateFormat)
  @dtw_mUPPERCASE(periodFormat)
  @dtw_mUPPERCASE(timeFormat)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@frm1", fromImportTable)
  @Concat_Field("@@imky", importKey)
  @Concat_Field("@@ifil", importTable)
  @Concat_Field("@@desc", importTableDescription)
  @Concat_Field("@@fixf", fixedFormat)
  @Concat_Field("@@fdlm", fieldDelimiter)
  @Concat_Field("@@rtps", positionPlacement)
  @Concat_Field("@@rtln", recTypeLength)
  @Concat_Field("@@dtfm", dateFormat)
  @Concat_Field("@@pdfm", periodFormat)
  @Concat_Field("@@tmfm", timeFormat)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(importTableDescription), "$(importTable)", "", "", "", "", confMessage)
      %if (maintenanceCode == "D" || fromD2w == "MapImportTable.d2w")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)MapImportTable.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          %if (passedImportTable != "")
              @dtw_assign(passedImportTable, "")
          %endif
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;passedImportTable=@dtw_rurlescseq(importTable)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@ifil", "importTable")
      @Format_ConfMsg_Desc("", $(importTableDescription), "$(importTable)", "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)MapImportTable.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;importTable=@dtw_rurlescseq(importTable)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
