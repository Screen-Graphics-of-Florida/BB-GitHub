%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Period Format Search"
  d2wName                 = "PeriodFormatSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;plant=@dtw_rurlescseq(plant)&amp;periodFormat=@dtw_rurlescseq(periodFormat)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  advanceSearch           = "N"
  period                  = ""
  wkperiod                = ""
%}
	
%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
              function selectperiod(period){
                  window.opener.document.$(docName).$(fldPeriod).value = period;
                  window.opener.document.$(docName).$(fldPeriod).focus();
                  window.close();
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                      <td class="toolbar">
                          <a href="javascript:check(document.Search)">$(acceptImageMed)</a>
                          <a href="javascript:window.close()">$(closeImageMed)</a>
                      </td>
              </tr>
          </table>
          $(searchhrTagAttr)

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)">
                          <table $(quickSearchTable)>

                              %if (periodFormat == "W")
                                      @dtw_assign(weekly, "CHECKED")
                                      @dtw_assign(monthly, "")
                                      @dtw_assign(quarterly, "")
                              %elif (periodFormat == "M")
                                      @dtw_assign(weekly, "")
                                      @dtw_assign(monthly, "CHECKED")
                                      @dtw_assign(quarterly, "")
                              %elif (periodFormat == "Q")
                                      @dtw_assign(weekly, "")
                                      @dtw_assign(monthly, "")
                                      @dtw_assign(quarterly, "CHECKED")
                              %endif
             <td class="colnmbr"><a href="javascript:selectperiod('$(V_PDPER#)',$(V_PDBDAT),$(V_PDEDAT))" title="Select Period">$(F_PDPER#)</a></td>

                              <tr><td class="dsphdr">Select Period Format</td>
                                  <td class="inputnmbr"><input name="period" type="radio" VALUE='01' onclick="javascript:selectperiod('$(period)')" </td> $(weekly)>Weekly</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="period" type="radio" VALUE='02' $(monthly)>Monthly</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="period" type="radio" VALUE='03' $(quarterly)>Quarterly</td>
                              </tr>

                          </table>
                      </form>	

                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(ACCEPT) {
  @dtw_assign(goto, "")
  @dtw_assign(caller, "")
  @dtw_assign(callerBase, "")
  @dtw_assign(wkperiod,period)
  %if (wkperiod == "01")
      @dtw_assign(periodFormat, "W")
  %elif (wkperiod == "02")
      @dtw_assign(periodFormat, "M")
  %elif (wkperiod == "03")
      @dtw_assign(periodFormat, "Q")
  %endif
      @dtw_assign(caller, "ProductionPlanReport.d2w")
      @dtw_assign(callerBase, $(d2wVarBase))
  <script TYPE="text/javascript">
      opener.location.href='$(homeURL)$(cGIPath)$(caller)/REPORT$(callerBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))';
      window.close();
  </script>
%}

%HTML(CLOSE) {
  <script TYPE="text/javascript">
      window.close();
  </script>
%}