                                  <td class="dspalph">$(From_EMOVTM)</td>
                                  <td class="dspalph$(chgVar)">$(syFlagDesc2)</td>
                                  <td class="dspalph">$(To_EMOVTM)</td>
                              </tr>
                          %endif

                          @Decat_FromTo("@@hce@")  @dtw_assign(F_EMHCE,   fromValue)  @dtw_assign(T_EMHCE,   toValue)
                          %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
