%Define {
  page_title           = "Audit Information"
  d2wName              = "AuditEmployee.d2w"
  d2wVarBase           = "$(genericVarBase)$(employeeVarBase)&amp;grouping=@dtw_rurlescseq(grouping)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;inclChgOnly=@dtw_rurlescseq(inclChgOnly)"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  RPT_MAX_ROWS	        = "99"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  imageExists          = ""
  prtMaxRows           = "$(prtMaxRowsDft)"
  prUserPass           = ""
  rowIndexNext	        = "1"
  showError            = "N"
  totalPages	        = "0"	
  quickLinkByUser      = "Y"
  chgVar               = ""
  fromValue            = ""
  toValue              = ""
  edtVar2              = ""
  demoChg              = ""
  payInfoChg           = ""
  accrCodeChg          = ""
  accrVacChg           = ""
  accrSickChg          = ""
  accrMiscChg          = ""
  cobraChg             = ""
  genEmplChg           = ""
  superChg             = ""
  securityChg          = ""
  emerChg              = ""
  contact1Chg          = ""
  contact2Chg          = ""
  educChg              = ""
  latestEmplChg        = ""
  prActChg             = ""
  fedChg               = ""
  sitChg               = ""
  suiChg               = ""
  swcChg               = ""
  sdiChg               = ""
  ltaxChg              = ""
  taxReportChg         = ""
  inclChgOnly          = ""
  auditCode            = ""

%}

%MACRO_FUNCTION Decat_FromToTest (IN CHAR(6) fieldName, CHAR(10) section) {
  %if ((auditCode != "C" && auditCode != "R" && auditCode != "T")|| inclChgOnly != "Y")
      @dtw_assign(demoChg, "Y")
      @dtw_assign(payInfoChg, "Y")
      @dtw_assign(accrCodeChg, "Y")
      @dtw_assign(accrVacChg, "Y")
      @dtw_assign(accrSickChg, "Y")
      @dtw_assign(accrMiscChg, "Y")
      @dtw_assign(cobraChg, "Y")
      @dtw_assign(genEmplChg, "Y")
      @dtw_assign(superChg, "Y")
      @dtw_assign(securityChg, "Y")
      @dtw_assign(emerChg, "Y")
      @dtw_assign(contact1Chg, "Y")
      @dtw_assign(contact2Chg, "Y")
      @dtw_assign(educChg, "Y")
      @dtw_assign(latestEmplChg, "Y")
      @dtw_assign(prActChg, "Y")
      @dtw_assign(fedChg, "Y")
      @dtw_assign(sitChg, "Y")
      @dtw_assign(suiChg, "Y")
      @dtw_assign(swcChg, "Y")
      @dtw_assign(sdiChg, "Y")
      @dtw_assign(ltaxChg, "Y")
      @dtw_assign(taxReportChg, "Y")
  %else
      @dtw_assign(fromValue, "")
      @dtw_assign(toValue, "")
      @dtw_pos("$(fieldName)", edtVar, pos)
      %if (pos > "0")
          @dtw_pos("}{", edtVar, @dtw_radd(pos, "1"), posNext)
          @dtw_substr(edtVar, @dtw_radd(pos, "6"), @dtw_rsubtract(posNext, @dtw_radd(pos, "6")), fromValue)
      %endif
      %if (edtVar2 != "")
          @dtw_pos("$(fieldName)", edtVar2, pos)
          %if (pos > "0")
              @dtw_pos("}{", edtVar2, @dtw_radd(pos, "1"), posNext)
              @dtw_substr(edtVar2, @dtw_radd(pos, "6"), @dtw_rsubtract(posNext, @dtw_radd(pos, "6")), toValue)
          %endif
          %if (fromValue != toValue)
              %if (section == "demo")
                  @dtw_assign(demoChg, "Y")
              %elseif (section == "payinfo")
                  @dtw_assign(payInfoChg, "Y")
              %elseif (section == "accrcode")
                  @dtw_assign(accrCodeChg, "Y")
              %elseif (section == "accrvac")
                  @dtw_assign(accrVacChg, "Y")
              %elseif (section == "accrsick")
                  @dtw_assign(accrSickChg, "Y")
              %elseif (section == "accrmisc")
                  @dtw_assign(accrMiscChg, "Y")
              %elseif (section == "cobra")
                  @dtw_assign(cobraChg, "Y")
              %elseif (section == "genempl")
                  @dtw_assign(genEmplChg, "Y")
              %elseif (section == "super")
                  @dtw_assign(superChg, "Y")
              %elseif (section == "security")
                  @dtw_assign(securityChg, "Y")
              %elseif (section == "emer")
                  @dtw_assign(emerChg, "Y")
              %elseif (section == "contact1")
                  @dtw_assign(contact1Chg, "Y")
              %elseif (section == "contact2")
                  @dtw_assign(contact2Chg, "Y")
              %elseif (section == "educ")
                  @dtw_assign(educChg, "Y")
              %elseif (section == "latestempl")
                  @dtw_assign(latestEmplChg, "Y")
              %elseif (section == "pract")
                  @dtw_assign(prActChg, "Y")
              %elseif (section == "fed")
                  @dtw_assign(fedChg, "Y")
              %elseif (section == "sit")
                  @dtw_assign(sitChg, "Y")
              %elseif (section == "sui")
                  @dtw_assign(suiChg, "Y")
              %elseif (section == "swc")
                  @dtw_assign(swcChg, "Y")
              %elseif (section == "sdi")
                  @dtw_assign(sdiChg, "Y")
              %elseif (section == "ltax")
                  @dtw_assign(ltaxChg, "Y")
              %elseif (section == "taxreport")
                  @dtw_assign(taxReportChg, "Y")
              %endif
          %endif
      %endif
  %endif


%}


%MACRO_FUNCTION Decat_FromTo (IN CHAR(6) fieldName) {
  @dtw_assign(fromValue, "")
  @dtw_assign(toValue, "")
  @dtw_assign(chgVar, "")
  @dtw_pos("$(fieldName)", edtVar, pos)
  %if (pos > "0")
      @dtw_pos("}{", edtVar, @dtw_radd(pos, "1"), posNext)
      @dtw_substr(edtVar, @dtw_radd(pos, "6"), @dtw_rsubtract(posNext, @dtw_radd(pos, "6")), fromValue)
  %endif
  %if (edtVar2 != "")
      @dtw_pos("$(fieldName)", edtVar2, pos)
      %if (pos > "0")
          @dtw_pos("}{", edtVar2, @dtw_radd(pos, "1"), posNext)
          @dtw_substr(edtVar2, @dtw_radd(pos, "6"), @dtw_rsubtract(posNext, @dtw_radd(pos, "6")), toValue)
      %endif
      %if (fromValue != toValue)
          @dtw_assign(chgVar, "chg")
      %endif
  %endif

%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>  	
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                       @dtw_assign(pageID, "AUDITEMPLOYEE")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " HDAUDT ", fileSQL)
                      @dtw_concat(selectSQL, "AUGRP='EMPLOYEE' and AUTSTP='$(timestamp)' and AUSEQ<2 ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"

                      @Audit_Empl_Common_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}


%FUNCTION(DTW_directcall) Ret_Audit_Info (INOUT CHAR(32000) edtVar)

{%EXEC {HHDRAI_W.PGM %}
%}

%FUNCTION(dtw_sql) Audit_Empl_Common_Query (IN CHAR(64)    profileHandle,
				                CHAR(2)     dataBaseID,
                                               CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_tb_setcols(quicklinkSeqTable, "4")

      %ROW {
          @dtw_assign(auditCode, V_AUCODE)
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                          %endif
                          <a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;timestamp=@dtw_rurlescseq(timestamp)&amp;formatToPrint=Y" target="_blank">$(formatPrintDesc)</a>
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
              <tr><td>
                  <h2>EMPLOYEE - Employee Information
                  </h2>
              </td></tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"
          $(hrTagAttr)

          <table $(contentTable)>
              @Format_HRCoFac("$(V_AUCO#)", "$(V_AUFAC#)", "F", F_CoFac)
              @RtvFldDesc("FLTYPE='AUDACTCODE' and FLVALU='$(V_AUCODE)'", "SYFLAG", "FLDESC", actCodeDesc)
              @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
              @RtvFldDesc("USUSER='$(V_AUUSER)'", "SYUSER", "USDESC", userProfileDesc)

              <tr><td>
                  <table $(contentTable)>
                      <tr><td class="dsphdr">Company/Facility</td>
                          <td class="dspnmbr">$(returnFldDesc)</td>
                          <td class="dspnmbr">$(F_CoFac)</td>
                      </tr>
                      <tr><td class="dsphdr">PR Employee</td>
                          <td class="dspalph">$(F_EmpName)</td>
                          <td class="dspnmbr">[$(V_AUPREM)]</td>
                      </tr>
                      %if(V_AUCO# != V_AUPECO)
                          <tr><td class="dsphdr">HR Company</td>
                              <td class="dspnmbr">$(V_AUPECO)</td>
                          </tr?
                      %endif
                      %if(V_AUPREM != V_AUPEEM)
                          <tr><td class="dsphdr">HR Employee</td>
                              <td class="dspalph">$(V_AUPEEM)</td>
                          </tr>
                      %endif

                      @dtw_assign(uv_CompanyName, "AUCO#")
                      @dtw_assign(uv_FacilityName, "AUFAC#")
                      @dtw_assign(uv_HRCompanyName, "AUPECO")
                      @dtw_assign(uv_HRLocationName, "AUPELC")
                      @dtw_assign(uv_HomeDepartmentName, "AUDEPT")
                      @dtw_assign(uv_PayTypeName, "AUPAYT")
                      @dtw_assign(uv_SalaryControlName, "AUPAYD")
                      @dtw_assign(uv_PREmployeeName, "AUPREM")
                      @dtw_assign(uv_HREmployeeName, "AUPEEM")
                      %INCLUDE "userview.icl"
                      %INCLUDE "AuditFileRetInfo.icl"
                      <tr>
                          <td class="dsphdr">Timestamp</td>
                          <td class="dspalph" colspan="2" nowrap>&nbsp;
                              %if (firstAudit > "0001-01-01-00.00.00.000000" && formatToPrint == "")
                                  <a href="$(homeURL)$(cGIPath)AuditEmployee.d2w/REPORT$(d2wVarBase)&amp;timestamp=@dtw_rurlescseq(firstAudit)" title="View first"><b> |< </b></a>
                              %endif
                              %if (prevAudit > "0001-01-01-00.00.00.000000" && formatToPrint == "")
                                  <a href="$(homeURL)$(cGIPath)AuditEmployee.d2w/REPORT$(d2wVarBase)&amp;timestamp=@dtw_rurlescseq(prevAudit)" title="View previous"><b> < </b></a>
                              %endif
                              $(timestamp)
                              %if (nextAudit > "0001-01-01-00.00.00.000000" && formatToPrint == "")
                                  <a href="$(homeURL)$(cGIPath)AuditEmployee.d2w/REPORT$(d2wVarBase)&amp;timestamp=@dtw_rurlescseq(nextAudit)" title="View next"><b> > </b></a>
                              %endif
                              %if (lastAudit > "0001-01-01-00.00.00.000000" && formatToPrint == "")
                                  <a href="$(homeURL)$(cGIPath)AuditEmployee.d2w/REPORT$(d2wVarBase)&amp;timestamp=@dtw_rurlescseq(lastAudit)" title="View last"><b> >| </b></a>
                              %endif
                          </td>
                      </tr>

                  </table>
                  </td>

                  <td>
                  <table $(contentTable)>
                      <tr><td class="dsphdr">Activity</td>
                          <td class="dspalph">$(actCodeDesc)</td>
                      </tr>
                      %if (V_AUFILE == "HREMPL")
                          @dtw_assign(F_File, "Common")
                      %elseif (V_AUFILE == "PEEMPL")
                          @dtw_assign(F_File, "HR")
                      %elseif (V_AUFILE == "PREMPL")
                          @dtw_assign(F_File, "Payroll")
                      %endif
                      <tr><td class="dsphdr">Table</td>
                          <td class="dspalph">$(F_File)</td>
                          <td class="dspalph">[$(V_AUFILE)]</td>
                      </tr>
                      <tr><td class="dsphdr">User</td>
                          <td class="dspalph">$(userProfileDesc)</td>
                          <td class="dspalph">[$(V_AUUSER)]</td>
                      </tr>
                      <tr><td>&nbsp;</td></tr>
                      %if (inclChgOnly == "Y")
                          @dtw_assign(chgOnlyChecked, "CHECKED")
                      %else
                          @dtw_assign(chgOnlyChecked, "")
                      %endif

                      %if (V_AUCODE=="C" || V_AUCODE=="R" || V_AUCODE=="T")
                          %if (formatToPrint == "")
                              <tr><td class="dsphdr">Changed Only</td>
                                  <td><input type="checkbox" name="chgOnly" $(chgOnlyChecked) onClick="window.location.href='$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;timestamp=@dtw_rurlescseq(V_AUTSTP)&amp;chgChgOnly=Y'"></td>
                              </tr>
                          %else
                              %if (chgOnlyChecked != "")
                                  <tr><td class="dsphdr">Changed Only Information Shown</td></tr>
                              %else
                                  <tr><td class="dsphdr">All Information Shown</td></tr>
                              %endif
                          %endif
                      %else
                          @dtw_assign(inclChgOnly, "")
                      %endif


                  </table>
                  </td>
              </tr>
          </table>

          @dtw_assign(edtVar,V_AUDATA)
          @RtvColVal("AUGRP='EMPLOYEE' and AUTSTP='$(timestamp)' and AUSEQ!=2", "HDAUDT", "(AUSSNO)", "D", xsocsec)
          @dtw_assign(edtVar2,"")
          @RtvFldDesc("AUGRP='EMPLOYEE' and AUTSTP='$(timestamp)' and AUSEQ=2", "HDAUDT", "AUDATA", edtVar2)
          @RtvColVal("AUGRP='EMPLOYEE' and AUTSTP='$(timestamp)' and AUSEQ=2", "HDAUDT", "(AUSSNO)", "D", xsocsec2)

%{ HREMPL Begin %}
          %if (V_AUFILE == "HREMPL")

              $(hrTagAttr)
              %if (formatToPrint == "")
                  <table $(quickLinkTable)>
                      <tr>
                          <td class="quickLinkTabs"><a href="#demographics">Demographics</a></td>
                          <td class="quickLinkTabs"><a href="#payinformation">Pay Information</a></td>
                          <td class="quickLinkTabs"><a href="#accruals">Accruals</a></td>
                          <td class="quickLinkTabs"><a href="#cobra">COBRA</a></td>
                      </tr>
                  </table>
              %endif

              <a name="demographics"></a>
              <fieldset class="legendBody">
                  <legend class="legendTitle">Demographics</legend>
                  %if (formatToPrint == "")
                  <div class="quickLinksTop">
                      <a href="#top">$(topOfFormImage)</a>
                  </div>
                  %endif
                  <table $(contentTable)>
                      @Decat_FromToTest("@@act@", "demo")
                      @Decat_FromToTest("@@prac", "demo")
                      @Decat_FromToTest("@@peac", "demo")
                      @Decat_FromToTest("@@rnam", "demo")
                      @Decat_FromToTest("@@lnam", "demo")
                      @Decat_FromToTest("@@fnam", "demo")
                      @Decat_FromToTest("@@midi", "demo")
                      @Decat_FromToTest("@@adr1", "demo")
                      @Decat_FromToTest("@@adr2", "demo")
                      @Decat_FromToTest("@@city", "demo")
                      @Decat_FromToTest("@@stat", "demo")
                      @Decat_FromToTest("@@zip@", "demo")
                      @Decat_FromToTest("@@cntr", "demo")
                      @Decat_FromToTest("@@prov", "demo")
                      @Decat_FromToTest("@@phon", "demo")
                      @Decat_FromToTest("@@loc@", "demo")
                      @Decat_FromToTest("@@dept", "demo")
                      @Decat_FromToTest("@@dob@", "demo")

                      @Decat_FromToTest("@@sssf", "demo")
                      @Decat_FromToTest("@@gndr", "demo")
                      @Decat_FromToTest("@@msta", "demo")
                      @Decat_FromToTest("@@nodp", "demo")
                      @Decat_FromToTest("@@hire", "demo")
                      @Decat_FromToTest("@@strt", "demo")
                      @Decat_FromToTest("@@senr", "demo")
                      @Decat_FromToTest("@@trdt", "demo")
                      @Decat_FromToTest("@@trcd", "demo")
                      @Decat_FromToTest("@@ctzn", "demo")
                      @Decat_FromToTest("@@alrg", "demo")
                      @Decat_FromToTest("@@job@", "demo")
                      @Decat_FromToTest("@@eeo@", "demo")
                      @Decat_FromToTest("@@uncd", "demo")
                      @Decat_FromToTest("@@unmn", "demo")
                      @Decat_FromToTest("@@shft", "demo")
                      @Decat_FromToTest("@@anhr", "demo")
                      @Decat_FromToTest("@@schd", "demo")
                      @Decat_FromToTest("@@plnt", "demo")
                      @Decat_FromToTest("@@mdpt", "demo")
                      @Decat_FromToTest("@@wc@@", "demo")
                      @Decat_FromToTest("@@hgrp", "demo")
                      @Decat_FromToTest("@@usr1", "demo")
                      @Decat_FromToTest("@@usr2", "demo")
                      @Decat_FromToTest("@@usr3", "demo")
                      @Decat_FromToTest("@@usr4", "demo")
                      @Decat_FromToTest("@@usr5", "demo")
                      @Decat_FromToTest("@@usr6", "demo")
                      
                      %if (xsocsec != xsocsec2)
          						@dtw_assign(demoChg, "Y")
      					  %endif
                     %if (demoChg != "Y")
                          <tr><td class="dsphdr">No Changes Found</td></tr>
                      %else

                          %if (V_AUCODE=="G")
                              <tr><td>&nbsp;</td><th class="dsphdr">Added</th>
                              </tr>
                          %elseif (V_AUCODE=="C" || V_AUCODE=="R" || V_AUCODE=="T")
                              <tr><td>&nbsp;</td><th class="dsphdr">Changed From</th>
                                  <td>&nbsp;</td><th class="dsphdr">Changed To</th>
                              </tr>
                          %elseif (V_AUCODE=="D")
                              <tr><td>&nbsp;</td><th class="dsphdr">Deleted</th>
                              </tr>
                          %endif

                          @Decat_FromTo("@@act@")  @dtw_assign(F_EMACT, fromValue)  @dtw_assign(T_EMACT, toValue)
                          %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
                              <tr><td class="dsphdr">Row Activity Code</td>
                                  <td class="dspalph$(chgVar)">$(F_EMACT)</td><td>&nbsp;</td>
                                  <td class="dspalph$(chgVar)">$(T_EMACT)</td>
                              </tr>
                          %endif

                          @Decat_FromTo("@@prac")  @dtw_assign(F_EMPRAC, fromValue)  @dtw_assign(T_EMPRAC, toValue)
                          %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
                              <tr><td class="dsphdr">P/R Activity Code</td>
                                  <td class="dspalph$(chgVar)">$(F_EMPRAC)</td><td>&nbsp;</td>
                                  <td class="dspalph$(chgVar)">$(T_EMPRAC)</td>
                              </tr>
                          %endif

                          @Decat_FromTo("@@peac")  @dtw_assign(F_EMPEAC, fromValue)  @dtw_assign(T_EMPEAC, toValue)
                          %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
                              <tr><td class="dsphdr">H/R Activity Code</td>
                                  <td class="dspalph$(chgVar)">$(F_EMPEAC)</td><td>&nbsp;</td>
                                  <td class="dspalph$(chgVar)">$(T_EMPEAC)</td>
                              </tr>
                          %endif

                          @Format_HRCoFac("$(V_AUCO#)", "$(V_AUFAC#)", "F", F_CoFac)
                          <tr><td class="dsphdr">Company/Facility</td>
                              <td class="dspnmbr">$(returnFldDesc)</td>
                              <td class="dspnmbr">$(F_CoFac)</td>
                          </tr>

                          <tr><td class="dsphdr">Employee Number</td>
                              <td class="dspnmbr">$(V_AUPREM)</td></tr>

                          <tr><td class="dsphdr">H/R Company</td>
                              <td class="dspalph">$(V_EMPECO)</td></tr>

                          <tr><td class="dsphdr">H/R Employee Number</td>
                              <td class="dspalph">$(V_AUPEEM)</td></tr>

                          @Decat_FromTo("@@rnam")  @dtw_assign(F_EMRNAM, fromValue)  @dtw_assign(T_EMRNAM, toValue)
                          %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
                              <tr><td class="dsphdr">Report Name</td>
                                  <td class="dspalph$(chgVar)">$(F_EMRNAM)</td><td>&nbsp;</td>
                                  <td class="dspalph$(chgVar)">$(T_EMRNAM)</td>
                              </tr>
                          %endif

                          @Decat_FromTo("@@lnam")  @dtw_assign(F_EMLNAM, fromValue)  @dtw_assign(T_EMLNAM, toValue)
                          %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
                              <tr><td class="dsphdr">Last Name</td>
                                  <td class="dspalph$(chgVar)">$(F_EMLNAM)</td><td>&nbsp;</td>
                                  <td class="dspalph$(chgVar)">$(T_EMLNAM)</td>
                              </tr>
                          %endif

                          @Decat_FromTo("@@fnam")  @dtw_assign(F_EMFNAM, fromValue)  @dtw_assign(T_EMFNAM, toValue)
                          %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
