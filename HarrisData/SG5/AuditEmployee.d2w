                              </tr>
                          %endif

                          @Decat_FromTo("@@ehlt")  @dtw_assign(F_EREHLT, fromValue)  @dtw_assign(T_EREHLT, toValue)
                          %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
                               <tr><td class="dsphdr">Employee Health Insurance Code</td>
                                  <td class="dspnmbr$(chgVar)">$(F_EREHLT)</td><td>&nbsp;</td>
                                  <td class="dspnmbr$(chgVar)">$(T_EREHLT)</td>
                              </tr>
                          %endif

                          @Decat_FromTo("@@rhlt")  @dtw_assign(F_ERRHLT, fromValue)  @dtw_assign(T_ERRHLT, toValue)
                          %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
                               <tr><td class="dsphdr">Employer Health Insurance Code</td>
                                  <td class="dspnmbr$(chgVar)">$(F_ERRHLT)</td><td>&nbsp;</td>
                                  <td class="dspnmbr$(chgVar)">$(T_ERRHLT)</td>
                              </tr>
                          %endif

                          @Decat_FromTo("@@wgpc")  @dtw_assign(F_ERWGPC, fromValue)  @dtw_assign(T_ERWGPC, toValue)
                          %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
                               <tr><td class="dsphdr">Wage Plan Code</td>
                                  <td class="dspalph$(chgVar)">$(F_ERWGPC)</td><td>&nbsp;</td>
                                  <td class="dspalph$(chgVar)">$(T_ERWGPC)</td>
                              </tr>
                          %endif

                          @Decat_FromTo("@@seas")  @dtw_assign(F_ERSEAS, fromValue)  @dtw_assign(T_ERSEAS, toValue)
                          %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
                               <tr><td class="dsphdr">Seasonal Indicator</td>
                                  <td class="dspalph$(chgVar)">$(F_ERSEAS)</td><td>&nbsp;</td>
                                  <td class="dspalph$(chgVar)">$(T_ERSEAS)</td>
                              </tr>
                          %endif

                          @Decat_FromTo("@@unit")  @dtw_assign(F_ERUNIT, fromValue)  @dtw_assign(T_ERUNIT, toValue)
                          %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
                               <tr><td class="dsphdr">Unit/Div/Loc/Plant Code</td>
                                  <td class="dspalph$(chgVar)">$(F_ERUNIT)</td><td>&nbsp;</td>
                                  <td class="dspalph$(chgVar)">$(T_ERUNIT)</td>
                              </tr>
                          %endif

                          @Decat_FromTo("@@dcdt")  @dtw_assign(F_ERDCDT, fromValue)  @dtw_assign(T_ERDCDT, toValue)
                          %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
                              @Format_Date(F_ERDCDT, "H", From_ERDCDT)
                              @Format_Date(T_ERDCDT, "H", To_ERDCDT)
                              <tr><td class="dsphdr">Deceased Date</td>
                                  <td class="dspdate$(chgVar)">$(From_ERDCDT)</td><td>&nbsp;</td>
                                  <td class="dspdate$(chgVar)">$(To_ERDCDT)</td>
                              </tr>
                          %endif
                      %endif
                  </table>
              </fieldset>


          %endif
          $(hrTagAttr)
          %INCLUDE "Copyright.icl"
          %INCLUDE "QuickLinkDisplay.icl"
      %}
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %if (chgChgOnly == "Y" && inclChgOnly == "Y")
      @dtw_assign(inclChgOnly, "N")
  %elseif (chgChgOnly == "Y")
      @dtw_assign(inclChgOnly, "Y")
  %endif
  %if (inclChgOnly == "" && chgChgOnly != "Y")
      @dtw_assign(inclChgOnly, "Y")
  %endif
  @Set_SQL(stmtSQL)
%}

