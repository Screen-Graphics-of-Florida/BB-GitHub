              <a name="accruals"></a>
              <fieldset class="legendBody">
                  <legend class="legendTitle">Accruals</legend>
                  %if (formatToPrint == "")
                  <div class="quickLinksTop">
                      <a href="#top">$(topOfFormImage)</a>
                  </div>
                  %endif
                  <table $(contentTable)>
                      @Decat_FromToTest("@@vasc", "accrcode")
                      @Decat_FromToTest("@@msac", "accrcode")
                      @Decat_FromToTest("@@acdt", "accrcode")
                      @Decat_FromToTest("@@acvh", "accrvac")
                      @Decat_FromToTest("@@vha@", "accrvac")
                      @Decat_FromToTest("@@acvd", "accrvac")
                      @Decat_FromToTest("@@vda@", "accrvac")
                      @Decat_FromToTest("@@ash@", "accrsick")
                      @Decat_FromToTest("@@sha@", "accrsick")
                      @Decat_FromToTest("@@asd@", "accrsick")
                      @Decat_FromToTest("@@sda@", "accrsick")
                      @Decat_FromToTest("@@amh@", "accrmisc")
                      @Decat_FromToTest("@@mha@", "accrmisc")
                      @Decat_FromToTest("@@amd@", "accrmisc")
                      @Decat_FromToTest("@@mda@", "accrmisc")

                      %if (accrCodeChg != "Y" && accrVacChg != "Y" && accrSickChg != "Y" && accrMiscChg != "Y")
                          <tr><td class="dsphdr">No Changes Found</td></tr>
                      %else

                          %if (V_AUCODE=="G")
                              <tr><td>&nbsp;</td><th class="dsphdr">Added</th>
                              </tr>
                          %elseif (V_AUCODE=="C" || V_AUCODE=="R" || V_AUCODE=="T")
                              <tr><td>&nbsp;</td><th class="dsphdr">Changed From</th>
                                  <td>&nbsp;</td><th class="dsphdr">Changed To</th>
                              </tr>
                          %elseif (V_AUCODE=="D")
                              <tr><td>&nbsp;</td><th class="dsphdr">Deleted</th>
                              </tr>
                          %endif
                      %endif


                      %if (accrCodeChg == "Y")
                          <tr><th class="dsphdr" colspan="1">Accrual Code <br>And Dates</th></tr>

                          @Decat_FromTo("@@vasc")   @dtw_assign(F_EMVASC, fromValue)   @dtw_assign(T_EMVASC, toValue)
                          %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
                              <tr><td class="dsphdr">Vacation/Sick</td>
                                  <td class="dspalph$(chgVar)">$(F_EMVASC)</td><td>&nbsp;</td>
                                  <td class="dspalph$(chgVar)">$(T_EMVASC)</td>
                              </tr>
                          %endif

                          @Decat_FromTo("@@msac")   @dtw_assign(F_EMMSAC, fromValue)   @dtw_assign(T_EMMSAC, toValue)
                          %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
                              <tr><td class="dsphdr">Miscellaneous</td>
                                  <td class="dspalph$(chgVar)">$(F_EMMSAC)</td><td>&nbsp;</td>
                                  <td class="dspalph$(chgVar)">$(T_EMMSAC)</td>
                              </tr>
                          %endif

                          @Decat_FromTo("@@acdt")   @dtw_assign(F_EMACDT, fromValue)   @dtw_assign(T_EMACDT, toValue)
                          %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
                              @Format_Date(F_EMACDT, "H", From_EMACDT)
                              @Format_Date(T_EMACDT, "H", To_EMACDT)
                              <tr><td class="dsphdr">Accrual Date</td>
                                  <td class="dspdate$(chgVar)">$(From_EMACDT)</td><td>&nbsp;</td>
                                  <td class="dspdate$(chgVar)">$(To_EMACDT)</td>
                              </tr>
                          %endif
                      %endif

                      %if (accrVacChg == "Y")
                          <tr><td>&nbsp;</td></tr>
                          <tr><th class="dsphdr">Vacation</th></tr>

