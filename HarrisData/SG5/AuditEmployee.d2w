              <a name="payinformation"></a>
              <fieldset class="legendBody">
                  <legend class="legendTitle">Pay Information</legend>
                  %if (formatToPrint == "")
                  <div class="quickLinksTop">
                      <a href="#top">$(topOfFormImage)</a>
                  </div>
                  %endif
                  <table $(contentTable)>

                      @dtw_assign(payInfoChg, "")
                      @Decat_FromToTest("@@type", "payinfo")
                      @Decat_FromToTest("@@exmt", "payinfo")
                      @Decat_FromToTest("@@freq", "payinfo")
                      @Decat_FromToTest("@@amt@", "payinfo")
                      @Decat_FromToTest("@@srcd", "payinfo")
                      @Decat_FromToTest("@@ovtm", "payinfo")
                      @Decat_FromToTest("@@hce@", "payinfo")
                      @Decat_FromToTest("@@ofcr", "payinfo")
