                          %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
                              @RtvFldDesc("WCPLT=$(F_EMPLNT) AND WCDEPT='$(F_EMMDPT)' and WCWC='$(F_EMWC)' ", "HDMWCM", "WCDESC", deptwcDesc)
                              @RtvFldDesc("WCPLT=$(T_EMPLNT) AND WCDEPT='$(T_EMMDPT)' and WCWC='$(T_EMWC)' ", "HDMWCM", "WCDESC", deptwcDesc2)
                              @Format_Code("$(F_EMMDPT) / $(F_EMWC)", From_EMDPWC)
                              @Format_Code("$(T_EMMDPT) / $(T_EMWC)", To_EMDPWC)
                              <tr><td class="dsphdr">Mfg Department/Work Center</td>
                                  <td class="dspalph$(chgVar)">$(deptwcDesc)</td>
                                  <td class="dspalph">$(From_EMDPWC)</td>
