                              @RtvFldDesc("ODCOMP=$(V_AUCO#) AND ODFACL=$(V_AUFAC#) AND ODTYPE='I' ", "PECODE", "ODDESC", salChgDesc2)
                              @Format_Code(F_EMSCRS, From_EMSCRS)
