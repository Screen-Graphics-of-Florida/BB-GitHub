                              @RtvFldDesc("BBGRP#=$(T_EMHGRP) ", "HDGRPM", "BBDESC", groupDesc2)
                              @Format_Code(F_EMHGRP, From_EMHGRP)
                              @Format_Code(T_EMHGRP, To_EMHGRP)
