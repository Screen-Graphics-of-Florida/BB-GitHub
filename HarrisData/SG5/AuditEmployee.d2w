                          @Decat_FromTo("@@mdpt")  @dtw_assign(F_EMMDPT, fromValue)  @dtw_assign(T_EMMDPT, toValue)
                          @dtw_assign(mdptChg,chgVar)
                          @Decat_FromTo("@@wc@@")  @dtw_assign(F_EMWC,   fromValue)  @dtw_assign(T_EMWC,   toValue)
                          @dtw_assign(wcChg,chgVar)
                          %if (mdptChg != "" || wcChg !="")
                              @dtw_assign(chgVar, "chg")
