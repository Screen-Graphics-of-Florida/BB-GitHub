                              %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
                                  <tr><td class="dsphdr">$(UDF1)</td>
                                      <td class="dspnmbr$(chgVar)">$(F_EMUSR1)</td><td>&nbsp;</td>
                                      <td class="dspnmbr$(chgVar)">$(T_EMUSR1)</td>
                                  </tr>
                              %endif
                          %endif
                          %if($(UDF2) != "")
                          @Decat_FromTo("@@usr2")  @dtw_assign(F_EMUSR2, fromValue)  @dtw_assign(T_EMUSR2, toValue)
                              %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
                                  <tr><td class="dsphdr">$(UDF2)</td>
                                      <td class="dspnmbr$(chgVar)">$(F_EMUSR2)</td><td>&nbsp;</td>
                                      <td class="dspnmbr$(chgVar)">$(T_EMUSR2)</td>
                                  </tr>
                              %endif
                          %endif
                          %if($(UDF3) != "")
