                                  <td class="dspalph">$(From_EMHGRP)</td>
                                  <td class="dspalph$(chgVar)">$(groupDesc2)</td>
                                  <td class="dspalph">$(To_EMHGRP)</td>
                              </tr>
                          %endif

                          @RtvFldDesc("PRU1DS<>' '", "PRCTRL", "PRU1DS", UDF1)
                          @RtvFldDesc("PRU2DS<>' '", "PRCTRL", "PRU2DS", UDF2)
                          @RtvFldDesc("PRU3DS<>' '", "PRCTRL", "PRU3DS", UDF3)
