                                  <td class="dspalph">$(To_EMSRCD)</td>
                              </tr>
                          %endif

                          @Decat_FromTo("@@ovtm")  @dtw_assign(F_EMOVTM, fromValue)  @dtw_assign(T_EMOVTM, toValue)
                          %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
                              @RtvFldDesc("FLTYPE='OVERTIME' and FLVALU='$(F_EMOVTM)'", "SYFLAG", "FLDESC", syFlagDesc)
                              @RtvFldDesc("FLTYPE='OVERTIME' and FLVALU='$(T_EMOVTM)'", "SYFLAG", "FLDESC", syFlagDesc2)
                              @Format_Code(F_EMOVTM, From_EMOVTM)
                              @Format_Code(T_EMOVTM, To_EMOVTM)
                              <tr><td class="dsphdr">Overtime Calculation Method</td>
