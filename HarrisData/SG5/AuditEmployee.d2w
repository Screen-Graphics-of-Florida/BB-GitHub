                              %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
                                  <tr><td class="dsphdr">$(UDF3)</td>
                                      <td class="dspnmbr$(chgVar)">$(F_EMUSR3)</td><td>&nbsp;</td>
                                      <td class="dspnmbr$(chgVar)">$(T_EMUSR3)</td>
                                  </tr>
                              %endif
                          %endif
                          %if($(UDF4) != "")
