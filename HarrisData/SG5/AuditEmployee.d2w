                              @RtvYNDesc($(T_EMHCE), syFlagDesc2)
                              @Format_Code(F_EMHCE, From_EMHCE)
                              @Format_Code(T_EMHCE, To_EMHCE)
                              <tr><td class="dsphdr">Highly Compensated Employee</td>
                                  <td class="dspalph$(chgVar)">$(syFlagDesc)</td>
                                  <td class="dspalph">$(From_EMHCE)</td>
                                  <td class="dspalph$(chgVar)">$(syFlagDesc2)</td>
                                  <td class="dspalph">$(To_EMHCE)</td>
                              </tr>
                          %endif

                          @Decat_FromTo("@@ofcr")  @dtw_assign(F_EMOFCR, fromValue)  @dtw_assign(T_EMOFCR, toValue)
                          %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
                              @RtvYNDesc($(F_EMOFCR), syFlagDesc)
                              @RtvYNDesc($(T_EMOFCR), syFlagDesc2)
                              @Format_Code(F_EMOFCR, From_EMOFCR)
                              @Format_Code(T_EMOFCR, To_EMOFCR)
                              <tr><td class="dsphdr">Corporate Officer</td>
                                  <td class="dspalph$(chgVar)">$(syFlagDesc)</td>
                                  <td class="dspalph">$(From_EMOFCR)</td>
                                  <td class="dspalph$(chgVar)">$(syFlagDesc2)</td>
                                  <td class="dspalph">$(To_EMOFCR)</td>
                              </tr>
                          %endif

                          @Decat_FromTo("@@keye")  @dtw_assign(F_EMKEYE, fromValue)  @dtw_assign(T_EMKEYE, toValue)
                          %if ((inclChgOnly == "Y" && chgVar != "") || inclChgOnly != "Y")
                              @RtvYNDesc($(F_EMKEYE), syFlagDesc)
                              @RtvYNDesc($(T_EMKEYE), syFlagDesc2)
                              @Format_Code(F_EMKEYE, From_EMKEYE)
                              @Format_Code(T_EMKEYE, To_EMKEYE)
                              <tr><td class="dsphdr">Key Employee</td>
