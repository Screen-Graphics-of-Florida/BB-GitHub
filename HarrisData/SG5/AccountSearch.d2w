%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Account Search"
  d2wName                 = "AccountSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;acctFld=@dtw_rurlescseq(acctFld)&amp;subFld=@dtw_rurlescseq(subFld)&amp;descFld=@dtw_rurlescseq(descFld)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  acctFld                 = ""
  subFld                  = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL)  {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function selectAcctSub(acct, sub, desc){
                      window.opener.document.$(docName).$(acctFld).value = acct;
                      window.opener.document.$(docName).$(subFld).value = sub;
                      window.opener.document.$(docName).$(descFld).value = desc;
                      window.opener.document.$(docName).$(acctFld).focus();
                      window.close();
                      return false;
                  }
	           %INCLUDE "numedit.icl"
                  %INCLUDE "CheckEnterSearch.icl"
                  function validate(searchForm) {
                      if (editNum(document.Search.srchAcct, 4, 0) &&
                          editNum(document.Search.srchSub, 4, 0))
                          return true;
                  }
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "$(searchBanner)"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      <td class="content">
                          @dtw_assign(uv_AccountName, "CHACCT")
                          @dtw_assign(uv_SubaccountName, "CHSUB")
                          %INCLUDE "userview.icl"

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " HDCHRT ", fileSQL)
                          %if (moreInfo == "Y")
                              @dtw_concat(selectSQL, "CHACCT=$(accountNumber) and CHSUB=$(subaccountNumber)", selectSQL)
                          %elseif (wildCardSearch!="" || uv_Sql!="")
                              @dtw_concat(selectSQL, "CHACCT>0 ", selectSQL)
                          %endif
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Account_Search(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "$(searchTrailer)"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}
%FUNCTION(dtw_sql) Account_Search (IN  CHAR(64)    profileHandle,
				        CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Description</th>
                      <th class="colhdr">Account</th>
                  </tr>
                  <tr><td class="inputalph">
                           <input type="text" name="srchDesc" size="30" maxlength="30">
                           <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td class="inputnum">
                          <input type="text" name="srchAcct" size="4" maxlength="4">
                          <input type="text" name="srchSub" size="4" maxlength="4">
                          <input type="hidden" name="operAcct" value=">=">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>	

          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("CHACCT", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=account" title="Sequence By Account"> Account</a></th>
                  @OrderBy_Sort("CHCHDSU", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=description" title="Sequence By Description, Account"> Description</a></th>
                  @OrderBy_Sort("CHDTES", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=established" title="Sequence By Date Established, Account"> Established</a></th>
                  @OrderBy_Sort("CHDTDE", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=deactivated" title="Sequence By Date Deactivated, Account"> Deactivated</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %else
          <table $(contentTable)>
      %endif		
              %ROW{
                  %INCLUDE "SetRowClass.icl"
                  @Format_Acct("$(V_CHACCT)", "$(V_CHSUB)", "", F_AcctSub)
                  @Format_Quote(V_CHCHDS, F_CHCHDS)

                  %if (moreInfo != "Y")	
                      @Format_Date(V_CHDTES, "D", F_CHDTES)
                      @Format_Date(V_CHDTDE, "D", F_CHDTDE)
                      <tr class="$(rowClass)">
                          <td class="colalph"> $(F_AcctSub)</td>
                          <td class="colalph"><a href="javascript:selectAcctSub($(V_CHACCT),$(V_CHSUB),'$(F_CHCHDS)')" title="Select Account">$(V_CHCHDS)</a></td>
                          <td class="coldate"> $(F_CHDTES)</td>
                          <td class="coldate"> $(F_CHDTDE)</td>
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)$(orderByVarBase)&amp;accountNumber=@dtw_rurlescseq(V_CHACCT)&amp;subaccountNumber=@dtw_rurlescseq(V_CHSUB)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                      </tr>

                  %else
                      @Format_Date(V_CHDTES, "H", F_CHDTES)
                      @Format_Date(V_CHDTDE, "H", F_CHDTDE)
                      @Format_Acct("$(V_CHACCT)", "$(V_CHSUB)", "", F_AcctSub)
                      <tr><td><a href="javascript:selectAcctSub($(V_CHACCT),$(V_CHSUB),'$(F_CHCHDS)')" title="Select Account">$(selectImageLrg)</a>
                          </td>
                      </tr>

                      <tr><td class="dsphdr">Account</td>
                          <td class="dspalph">$(F_AcctSub)</td></tr>
    			
                      <tr><td class="dsphdr">Description</td>
                          <td class="dspalph">$(V_CHCHDS)</td></tr>

                      <tr><td class="dsphdr">Normal Account Balance</td>
                          <td class="dspalph">$(V_CHNAB)</td></tr>

                      <tr><td class="dsphdr">Account Usage</td>
                          <td class="dspalph">$(V_CHACSG)</td></tr>

                      <tr><td class="dsphdr">Date Established</td>
                          <td class="dspdate">$(F_CHDTES)</td></tr>

                      <tr><td class="dsphdr">Date Deactivated</td>
                          <td class="dspdate">$(F_CHDTDE)</td></tr>

                      %if (V_HDMCRL>"0")
                          <tr><td class="dsphdr">Currency Rate Type</td>
                              <td class="dspalph">$(V_CHRTYP)</td></tr>
                      %endif

                      %if (V_CHUPDT > "0")
                          @Format_Date(V_CHUPDT, "H", F_CHUPDT)
                          <tr><td class="dsphdr">Date Last Maintained</td>
                              <td class="dspdate">$(F_CHUPDT)</td></tr>
                      %endif

                      <tr><td class="dsphdr">User Profile</td>
                          <td class="dspalph">$(V_CHUSER)</td></tr>

                  %endif
              %}
          </table>
	   %if (moreInfo != "Y")	
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
	   %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "CHCHDSU,CHACCT,CHSUB")
      @DTW_ASSIGN(orderByDisplay, "Description")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"

  %if (sequence == "account")
      %if (orderBy == "CHACCT,CHSUB")
          @DTW_ASSIGN(orderBy, "CHACCT DESC,CHSUB")
          @DTW_ASSIGN(orderByDisplay, "Account (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CHACCT,CHSUB")
          @DTW_ASSIGN(orderByDisplay, "Account")
      %endif
  %elseif (sequence == "description")
      %if (orderBy == "CHCHDSU,CHACCT,CHSUB")
          @DTW_ASSIGN(orderBy, "CHCHDSU DESC,CHACCT,CHSUB")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Account")
      %else
          @DTW_ASSIGN(orderBy, "CHCHDSU,CHACCT,CHSUB")
          @DTW_ASSIGN(orderByDisplay, "Description, Account")
      %endif
  %elseif (sequence == "established")
      %if (orderBy == "CHDTES,CHACCT,CHSUB")
          @DTW_ASSIGN(orderBy, "CHDTES DESC,CHACCT,CHSUB")
          @DTW_ASSIGN(orderByDisplay, "Date Established (descending), Account")
      %else
          @DTW_ASSIGN(orderBy, "CHDTES,CHACCT,CHSUB")
          @DTW_ASSIGN(orderByDisplay, "Date Established, Account")
      %endif
  %elseif (sequence == "deactivated")
      %if (orderBy == "CHDTDE,CHACCT,CHSUB")
          @DTW_ASSIGN(orderBy, "CHDTDE DESC,CHACCT,CHSUB")
          @DTW_ASSIGN(orderByDisplay, "Date Deactivated (descending), Account")
      %else
          @DTW_ASSIGN(orderBy, "CHDTDE,CHACCT,CHSUB")
          @DTW_ASSIGN(orderByDisplay, "Date Deactivated, Account")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          @dtw_assign(formName, "Search")
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchAcct, 4, 0) &&
                      editNum(document.Search.srchSub, 4, 0) &&
                      editdate(document.Search.srchDateEst) &&
                      editdate(document.Search.srchDateDea))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ACCOUNTSEARCH")
                  <td>
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                              <tr><td class="dsphdr">Account</td>
                                  @dtw_assign(operNbr, "operAcct")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input name="srchAcct" type="text" size="4" maxlength="4">&nbsp;-&nbsp;<input name="srchSub" type="text" size="4" maxlength="4"></td>
            			
                              <tr><td class="dsphdr">Description</td>
                                  @dtw_assign(operNbr, "operDesc")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input name="srchDesc" type="text" size="30" maxlength="30"></td></tr>
            			
                              <tr><td class="dsphdr">Date Established</td>
                                  @dtw_assign(operNbr, "operDateEst")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchDateEst" size="6" maxlength="6">
                                      <a href="javascript:calWindow('srchDateEst');">$(calendarImage)</a></td></tr>
            			
                              <tr><td class="dsphdr">Date Deactivated</td>
                                  @dtw_assign(operNbr, "operDateDea")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchDateDea" size="6" maxlength="6">
                                      <a href="javascript:calWindow('srchDateDea');">$(calendarImage)</a></td></tr>

                              %if (V_HDMCRL>"0")
                                  <tr><td class="dsphdr">Currency Rate Type</td>
                                  @dtw_assign(operNbr, "operCurt")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                      <td class="inputalph"><input type="text" name="srchCurt" size="10" maxlength="10"></td></tr>
                              %endif

                      %INCLUDE "SearchBottom.icl"
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("CHACCT", "Account", $(srchAcct), "", operAcct, "N")
  @Build_WildCard ("CHSUB", "Subaccount", $(srchSub), "", operAcct, "N")
  @Build_WildCard ("CHCHDSU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("CHDTES", "Date Established", $(srchDateEst), "", operDateEst, "D")
  @Build_WildCard ("CHDTDE", "Date Deactivated", $(srchDateDea), "", operDateDea, "D")
  @Build_WildCard ("CHRTYP", "Currency Rate Type", $(srchCurt), "U", operCurt, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}