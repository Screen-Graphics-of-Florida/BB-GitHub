%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Detail Load Analysis Report"
  d2wName                 = "DetailLoadAnalysisReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;apid=@dtw_rurlescseq(apid)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {

                      if  (editNum(document.Chg.fromPlant, 3, 0) &&
                           editNum(document.Chg.toPlant, 3, 0) &&
                           editdate(document.Chg.fromLoadDate) &&
                           editdate(document.Chg.toLoadDate) &&
                           editFromToAll(document.Chg.fromPlant, document.Chg.toPlant, document.Chg.allPlant, 3) &&
                           editFromToAll(document.Chg.fromDepartment, document.Chg.toDepartment, document.Chg.allDepartment, "A") &&
                           editFromToAll(document.Chg.fromWorkCenter, document.Chg.toWorkCenter, document.Chg.allWorkCenter, "A") &&
                           editFromToAll(document.Chg.fromLoadDate, document.Chg.toLoadDate, document.Chg.allLoadDate, "D")
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "DETAILLOADANALYSISREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromPlant")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@fplt", "fromPlant")        @dtw_assign(Err_N1FPLT,  fieldValue)
                                  @DecatErr_Field("@@tplt", "toPlant")        @dtw_assign(Err_N1TPLT,  fieldValue)
                                  @DecatErr_Field("@@aplt", "allPlant")        @dtw_assign(Err_N1APLT,  fieldValue)
                                  @DecatErr_Field("@@fdpt", "fromDepartment")        @dtw_assign(Err_N1FDPT,  fieldValue)
                                  @DecatErr_Field("@@tdpt", "toDepartment")        @dtw_assign(Err_N1TDPT,  fieldValue)
                                  @DecatErr_Field("@@adpt", "allDepartment")        @dtw_assign(Err_N1ADPT,  fieldValue)
                                  @DecatErr_Field("@@fwc@", "fromWorkCenter")        @dtw_assign(Err_N1FWC,  fieldValue)
                                  @DecatErr_Field("@@twc@", "toWorkCenter")        @dtw_assign(Err_N1TWC,  fieldValue)
                                  @DecatErr_Field("@@awc@", "allWorkCenter")        @dtw_assign(Err_N1AWC,  fieldValue)
                                  @DecatErr_Field("@@fdat", "fromLoadDate")        @dtw_assign(Err_N1FDAT,  fieldValue)
                                  @DecatErr_Field("@@tdat", "toLoadDate")        @dtw_assign(Err_N1TDAT,  fieldValue)
                                  @DecatErr_Field("@@adat", "allLoadDate")        @dtw_assign(Err_N1ADAT,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@fplt")  @dtw_assign(V_N1FPLT, fieldValue)
                                  @Decat_Field("@@tplt")  @dtw_assign(V_N1TPLT, fieldValue)
                                  @Decat_Field("@@aplt")  @dtw_assign(V_N1APLT, fieldValue)

                                  @Decat_Field("@@fdpt")  @dtw_assign(V_N1FDPT, fieldValue)
                                  @Decat_Field("@@tdpt")  @dtw_assign(V_N1TDPT, fieldValue)
                                  @Decat_Field("@@adpt")  @dtw_assign(V_N1ADPT, fieldValue)

                                  @Decat_Field("@@fwc@")  @dtw_assign(V_N1FWC, fieldValue)
                                  @Decat_Field("@@twc@")  @dtw_assign(V_N1TWC, fieldValue)
                                  @Decat_Field("@@awc@")  @dtw_assign(V_N1AWC, fieldValue)

                                  @Decat_Field("@@fdat")  @dtw_assign(V_N1FDAT, fieldValue)
                                  @Decat_Field("@@tdat")  @dtw_assign(V_N1TDAT, fieldValue)
                                  @Decat_Field("@@adat")  @dtw_assign(V_N1ADAT, fieldValue)

                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries
 Values %}

                                  %if (V_N1APLT == "ALL")
                                      @dtw_assign(checkedallPlant, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPlant, "")
                                  %endif
                                  %if (V_N1ADPT == "ALL")
                                      @dtw_assign(checkedallDepartment, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallDepartment, "")
                                  %endif
                                  %if (V_N1AWC == "ALL")
                                      @dtw_assign(checkedallWorkCenter, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallWorkCenter, "")
                                  %endif
                                  %if (V_N1ADAT == "ALL")
                                      @dtw_assign(checkedallLoadDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallLoadDate, "")
                                  %endif

                              %else

                                  @RtvDftPlant(plantNumber, plantName)
                                  %if (plantNumber == "0")
                                      @dtw_assign(checkedallPlant, "CHECKED")
                                  %else
                                      @dtw_assign(V_N1FPLT, plantNumber)
                                      @dtw_assign(V_N1TPLT, plantNumber)
                                      @dtw_assign(checkedallPlant, "")
                                  %endif
                                  @dtw_assign(checkedallDepartment, "CHECKED")
                                  @dtw_assign(checkedallWorkCenter, "CHECKED")
                                  @dtw_assign(checkedallLoadDate, "CHECKED")
                              %endif

                          </table>

                          <table $(contentTable)>

                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_N1FPLT)
                              %if (textOvr == "") @SetTextOvr(Err_N1TPLT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1APLT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Plant</span></td>
                                  <td class="inputnmbr"><input name="fromPlant" value="$(V_N1FPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromPlant&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toPlant" value="$(V_N1TPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toPlant&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName" type="hidden"></td>
                                  <td class="inputalph"><input name="allPlant" value='ALL' $(checkedallPlant) type="checkbox" onClick="if (this.checked) this.form.fromPlant.value='', this.form.toPlant.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FPLT)
                              @DspErrMsg(Err_N1TPLT)
                              @DspErrMsg(Err_N1APLT)

                              @SetTextOvr(Err_N1FDPT)
                              %if (textOvr == "") @SetTextOvr(Err_N1TDPT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ADPT) %endif
                              <tr><td class="dsphdr">Department</td>
                                  <td class="inputalph"><input name="fromDepartment" value="$(V_N1FDPT)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=fromDepartment&amp;fldWC=fromWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="toDepartment" value="$(V_N1TDPT)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=toDepartment&amp;fldWC=toWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="allDepartment" value='ALL' $(checkedallDepartment) type="checkbox" onClick="if (this.checked) this.form.fromDepartment.value='', this.form.toDepartment.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FDPT)
                              @DspErrMsg(Err_N1TDPT)
                              @DspErrMsg(Err_N1ADPT)

                              @SetTextOvr(Err_N1FWC)
                              %if (textOvr == "") @SetTextOvr(Err_N1TWC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AWC) %endif
                              <tr><td class="dsphdr">Work Center </td>
                                  <td class="inputalph"><input name="fromWorkCenter" value="$(V_N1FWC)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=fromDepartment&amp;fldWC=fromWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="toWorkCenter" value="$(V_N1TWC)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=toDepartment&amp;fldWC=toWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="allWorkCenter" value='ALL' $(checkedallWorkCenter) type="checkbox" onClick="if (this.checked) this.form.fromWorkCenter.value='', this.form.toWorkCenter.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FWC)
                              @DspErrMsg(Err_N1TWC)
                              @DspErrMsg(Err_N1AWC)

                              @SetTextOvr(Err_N1FDAT)
                              %if (textOvr == "") @SetTextOvr(Err_N1TDAT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ADAT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Load Date</span></td>
                                  <td class="inputnmbr"><input  name="fromLoadDate" type="text" value="$(V_N1FDAT)" size="6" maxlength="6"><a href="javascript:calWindow('fromLoadDate');"> $(calendarImage)</a></td>
                                  <td class="inputnmbr"><input  name="toLoadDate" type="text" value="$(V_N1TDAT)" size="6" maxlength="6"><a href="javascript:calWindow('toLoadDate');"> $(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allLoadDate" value='ALL' $(checkedallLoadDate) type="checkbox" onClick="if (this.checked) this.form.fromLoadDate.value='', this.form.toLoadDate.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FDAT)
                              @DspErrMsg(Err_N1TDAT)
                              @DspErrMsg(Err_N1ADAT)
                          </table>

                          @dtw_assign(envProgram, "HCP532")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HCP542_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allPlant)
  @dtw_mUPPERCASE(fromDepartment)
  @dtw_mUPPERCASE(toDepartment)
  @dtw_mUPPERCASE(allDepartment)
  @dtw_mUPPERCASE(fromWorkCenter)
  @dtw_mUPPERCASE(toWorkCenter)
  @dtw_mUPPERCASE(allWorkCenter)
  @dtw_mUPPERCASE(allLoadDate)

  @dtw_assign(fromPlant,@dtw_rstrip(fromPlant))
  @dtw_assign(toPlant,@dtw_rstrip(toPlant))
  @dtw_assign(fromLoadDate,@dtw_rstrip(fromLoadDate))
  @dtw_assign(toLoadDate,@dtw_rstrip(toLoadDate))

  %if (allPlant != "ALL")
      @dtw_assign(allPlant, "")
  %endif
  %if (allDepartment != "ALL")
      @dtw_assign(allDepartment, "")
  %endif
  %if (allWorkCenter != "ALL")
      @dtw_assign(allWorkCenter, "")
  %endif
  %if (allLoadDate != "ALL")
      @dtw_assign(allLoadDate, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@fplt", fromPlant)
  @Concat_Field("@@tplt", toPlant)
  @Concat_Field("@@aplt", allPlant)
  @Concat_Field("@@fdpt", fromDepartment)
  @Concat_Field("@@tdpt", toDepartment)
  @Concat_Field("@@adpt", allDepartment)
  @Concat_Field("@@fwc@", fromWorkCenter)
  @Concat_Field("@@twc@", toWorkCenter)
  @Concat_Field("@@awc@", allWorkCenter)
  @Concat_Field("@@fdat", fromLoadDate)
  @Concat_Field("@@tdat", toLoadDate)
  @Concat_Field("@@adat", allLoadDate)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}