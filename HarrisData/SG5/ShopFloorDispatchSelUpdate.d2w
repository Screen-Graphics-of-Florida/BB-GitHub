%INCLUDE "$(baseVar)"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "VarBase.icl"

%Define {	
  d2wName                 = "ShopFloorDispatchSelUpdate.d2w"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  DTW_HTML_TABLE          = "NO"
%}

%HTML(UPDATE) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Update SIDOPW Set WOOSEL='$(selFlag)' ", stmtSQL)
  @dtw_concat(stmtSQL, " Where WOPLT=$(plantNumber) and WOMORD='$(mfgOrder)' and WOSEQN=$(seqNumber) and WOXHND='$(profileHandle)' @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)
%}