%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Period Begin And End Dates Search"
  d2wName                 = "PeriodSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldPeriod=@dtw_rurlescseq(fldPeriod)&amp;fldBeginDate=@dtw_rurlescseq(fldBeginDate)&amp;fldEndDate=@dtw_rurlescseq(fldEndDate)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
  advanceSearch           = "N"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectperiod(period, beginDate, endDate){
                  window.opener.document.$(docName).$(fldPeriod).value = period;
                  window.opener.document.$(docName).$(fldBeginDate).value = beginDate;
                  window.opener.document.$(docName).$(fldEndDate).value = endDate;
                  window.opener.document.$(docName).$(fldPeriod).focus();
                  window.close();
              }
	       %INCLUDE "numedit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchPeriod, 4, 0) &&
                      editdate(document.Search.srchBeginDate) &&
                      editdate(document.Search.srchEndDate))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select PDPER#, PDBDAT, PDEDAT, PDWKDY as PDWKDY", stmtSQL)
                      @dtw_concat(fileSQL, " HDPBED ", fileSQL)
                      %if (wildCardSearch!="")
                         @dtw_concat(selectSQL, " PDPER#<>0 ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Period_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) Period_Search (IN  CHAR(64) profileHandle,
				           CHAR(2)   dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr">Period</th>
                  <th class="colhdr">Begin Date</th>
                  <th class="colhdr">End Date</th>
              </tr>
              <tr><td class="inputnmbr">
                      <input type="text" name="srchPeriod" size="4" maxlength="4">
                      <input type="hidden" name="operPeriod" value="=">
                  </td>
                  <td class="inputnmbr">
                      <input type="text" name="srchBeginDate" size="6" maxlength="6">
                      <input type="hidden" name="operBeginDate" value=">=">
                  </td>
                  <td class="inputnmbr">
                      <input type="text" name="srchEndDate" size="6" maxlength="6">
                      <input type="hidden" name="operEndDate" value=">=">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
          <script TYPE="text/javascript">
              document.Search.srchPeriod.focus();
          </script>
      </form>
	
      %INCLUDE "WildCardPage.icl"

      <table $(contentTable)>
          <tr>	
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("PDPER#", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=period" title="Sequence By Period"> Period</a></th>
              @OrderBy_Sort("PDBDAT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=beginDate" title="Sequence By Begin Date"> Begin <br> Date</a></th>
              @OrderBy_Sort("PDEDAT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=endDate" title="Sequence By End Date"> End <br> Date</a></th>
              <th class="colhdr">Working<br>Days</th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @dtw_assign(F_PDPER#, V_PDPER#)
              @PeriodInputFromCYP(V_PDPER#)
              @PeriodFromCYP(F_PDPER#)
              @Format_Date(V_PDBDAT, "D", F_PDBDAT)
              @Format_Date(V_PDEDAT, "D", F_PDEDAT)

              <tr class="$(rowClass)">
                  <td class="colnmbr"><a href="javascript:selectperiod('$(V_PDPER#)',$(V_PDBDAT),$(V_PDEDAT))" title="Select Period">$(F_PDPER#)</a></td>
                  <td class="colnmbr">$(F_PDBDAT)</td>
                  <td class="colnmbr">$(F_PDEDAT)</td>
                  <td class="colcode">$(V_PDWKDY)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "PDPER#")
      @DTW_ASSIGN(orderByDisplay, "Period")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY)  {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "period")
      %if (orderBy == "PDPER#")
          @DTW_ASSIGN(orderBy, "PDPER# DESC")
          @DTW_ASSIGN(orderByDisplay, "Period (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PDPER#")
          @DTW_ASSIGN(orderByDisplay, "Period")
      %endif
  %elseif (sequence == "beginDate")
      %if (orderBy == "PDBDAT")
          @DTW_ASSIGN(orderBy, "PDBDAT DESC")
          @DTW_ASSIGN(orderByDisplay, "Begin Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PDBDAT")
          @DTW_ASSIGN(orderByDisplay, "Begin Date")
      %endif
  %elseif (sequence == "endDate")
      %if (orderBy == "PDEDAT")
          @DTW_ASSIGN(orderBy, "PDEDAT DESC")
          @DTW_ASSIGN(orderByDisplay, "End Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PDEDAT")
          @DTW_ASSIGN(orderByDisplay, "End Date")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @PeriodToCYP(srchPeriod)
  @DateToCYMD(srchBeginDate)
  @DateToCYMD(srchEndDate)
  @Build_WildCard ("PDPER#", "Period", $(srchPeriod), "", operPeriod, "N")
  @Build_WildCard ("PDBDAT", "Begin Date", $(srchBeginDate), "", operBeginDate, "N")
  @Build_WildCard ("PDEDAT", "End Date", $(srchEndDate), "", operEndDate, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}