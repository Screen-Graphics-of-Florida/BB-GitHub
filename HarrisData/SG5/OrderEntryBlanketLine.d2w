%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Blanket Line"
  d2wName                 = "OrderEntryBlanketLine.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;lineNumber=@dtw_rurlescseq(lineNumber)&amp;orderTypeDesc=@dtw_rurlescseq(orderTypeDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "10"
  rowIndexNext	           = "1"
  totalPages              = "0"
  index                   = "0"
  itemNumber              = ""
  itemDesc                = ""
  releaseNumber           = "000"
  qtyOrdered              = "0"
  qtyShipped              = "0"
  qtyOpen                 = "0"
  relQty                  = "0"
  relErr                  = ""
  maintCode               = ""
  novcf                   = ""
  custType                = "B"
  H1BLTO                  = ""
  multShipToCustomer      = ""
  popUpWin                = "Y"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@customerName", "@dtw_rurlescseq(customerName)", "1", "a", workURL)
  @dtw_replace(workURL, "@@customerNumber", "@dtw_rurlescseq(customerNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@orderControlNumber", "@dtw_rurlescseq(orderControlNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@lineNumber", "@dtw_rurlescseq(lineNumber)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  var rows = document.Chg.row1.value;
                  var ok = true;
                  if (rows >= 1  && document.Chg.sts1.value == "O")                {if (editNum(document.Chg.qty1, 9, 4) == false  || editdate(document.Chg.rqd1)== false) {ok = false};}
                  if (rows >= 2  && document.Chg.sts2.value == "O" && ok == true)  {if (editNum(document.Chg.qty2, 9, 4) == false  || editdate(document.Chg.rqd2)== false) {ok = false};}
                  if (rows >= 3  && document.Chg.sts3.value == "O" && ok == true)  {if (editNum(document.Chg.qty3, 9, 4) == false  || editdate(document.Chg.rqd3)== false) {ok = false};}
                  if (rows >= 4  && document.Chg.sts4.value == "O" && ok == true)  {if (editNum(document.Chg.qty4, 9, 4) == false  || editdate(document.Chg.rqd4)== false) {ok = false};}
                  if (rows >= 5  && document.Chg.sts5.value == "O" && ok == true)  {if (editNum(document.Chg.qty5, 9, 4) == false  || editdate(document.Chg.rqd5)== false) {ok = false};}
                  if (rows >= 6  && document.Chg.sts6.value == "O" && ok == true)  {if (editNum(document.Chg.qty6, 9, 4) == false  || editdate(document.Chg.rqd6)== false) {ok = false};}
                  if (rows >= 7  && document.Chg.sts7.value == "O" && ok == true)  {if (editNum(document.Chg.qty7, 9, 4) == false  || editdate(document.Chg.rqd7)== false) {ok = false};}
                  if (rows >= 8  && document.Chg.sts8.value == "O" && ok == true)  {if (editNum(document.Chg.qty8, 9, 4) == false  || editdate(document.Chg.rqd8)== false) {ok = false};}
                  if (rows >= 9  && document.Chg.sts9.value == "O" && ok == true)  {if (editNum(document.Chg.qty9, 9, 4) == false  || editdate(document.Chg.rqd9)== false) {ok = false};}
                  if (rows >= 10 && document.Chg.sts10.value == "O" && ok == true) {if (editNum(document.Chg.qty10, 9, 4)== false  || editdate(document.Chg.rqd10)== false) {ok = false};}
                  if (ok == true) {return true;}
              }
              %INCLUDE "dateedit.icl"
              %INCLUDE "numedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "NewWindowOpen.icl"
              function confirmNoUpdate() {return confirm("Confirm No Update Of Blanket")}
              function confirmRemove() {return confirm("Confirm Removal Of Blanket")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "OrderEntryRetInfo.icl"
                      @Get_Detail_Line(profileHandle, dataBaseID, orderControlNumber, lineNumber, dropShipNumber, itemNumber, itemDesc, qtyOrdered, qtyShippped, pricedByKit, qtyOpen, relQty, relErr, maintCode)
                      @dtw_assign(multShipToCustomer, "0")
                      %if (dropShipNumber == "0")
                          @RtvFldDesc("CMCUST=$(H1BLTO) or CMBLTO=$(H1BLTO)", "HDCUST", "CHAR(COUNT(CMCUST))", multShipToCustomer)
                      %endif

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " OEBLWK ", fileSQL)
                      @dtw_concat(selectSQL, "BWOCTL=$(orderControlNumber) and BWORL#=$(lineNumber) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Blanket_Line_Maintain(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) Blanket_Line_Maintain (IN CHAR(64)    profileHandle,
				              CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="50%">
              <col width="45%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  %if (qtyOrdered == relQty && relErr != "Y")
                      <a href="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">$(acceptImageMed)</a>
                  %endif
                  <a href="$(homeURL)$(cGIPath)$(d2wName)/ADDREL$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">$(addMoreImage)</a>
                  %if (qtyOrdered == qtyOpen)
                      <a onClick="return confirmRemove()" href="$(homeURL)$(cGIPath)$(d2wName)/REMOVE$(d2wVarBase)">$(deleteImageMed)</a>
                  %endif
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>

      $(hrTagAttr)

      <table $(contentTable)>
          <tr>
              <td class="colhdr">Item Number</td>
              <td class="colhdr">Description</td>
              <td class="colhdr">Quantity<br>Ordered</td>
              <td class="colhdr">Total Release<br>Quantity</td>
              <td class="colhdr">Unscheduled<br>Quantity</td>
          </tr>
          <tr>
              <td class="colalph">$(itemNumber)</td>		
              <td class="colalph">$(itemDesc)</td>		
              <td class="colnmbr">$(qtyOrdered)</td>
              <td class="colnmbr">$(relQty)</td>
              <td class="colnmbr">@dtw_rsubtract(qtyOrdered, relQty)</td>
              %if (qtyOrdered != relQty)
                  <td class="error">**</td>
              %endif
          </tr>
      </table>

      %if (qtyOrdered != relQty)
          <table $(contentTable)>
              <tr><td class="error">** Unscheduled Quantity Must Be Applied To A Release</td></tr>
          </table>
      %endif

      <table $(contentTable)>
          <tr><td>%INCLUDE "AssignPageValue.icl"</td></tr>
      </table>
			
      <form class="formClass" METHOD=POST name="Chg" onSubmit="return false;" ACTION="$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(d2wVarBase)&amp;updateRowNum=@dtw_rurlescseq($(START_ROW_NUM))">
          <table $(contentTable)>
              <tr>
                  <td class="colhdr">Rel</td>
                  <td class="colhdr">Quantity</td>
                  <td class="colhdr">Required Date</td>
                  %if (maintCode != "A")
                      <td class="colhdr">Quantity Shipped</td>
                  %endif
                  %if (multShipToCustomer>"1")
                      <td class="colhdr">Ship-To</td>
                      <td class="colhdr">Ship Via</td>
                  %endif
                 <td><a href="javascript:check(document.Chg)">$(acceptImageMed)</a></td>
              </tr>
		
              %ROW{
                  %INCLUDE "SetRowClass.icl"

                  %if (V_BWRQDT > "0" && V_BWER# != "HHD0014")
                      @DateInputFromCYMD(V_BWRQDT)
                  %endif
          	
                  %if (V_BWER# != "")
                      @Ret_Error_Msg(profileHandle, dataBaseID, $(V_BWER#), errorMessage)
                  %endif

                  <tr class="$(rowClass)">
                      <td class="colcode">$(V_BWBLN#)</td>
                      %if (V_BWORST == "O")
                          <td class="inputnmbr"><input type="text" name="qty$(ROW_NUM)" value="$(V_BWQORD)" size="6" maxlength="15"></td>		
                          <td class="inputnmbr">
                              %if (ROW_NUM == "1")
                                  <input type="text" name="rqd1" value="$(V_BWRQDT)" size="4" maxlength="6"><a href="javascript:calWindow('rqd1');">$(calendarImage)</a>
                              %endif
                              %if (ROW_NUM == "2")
                                  <input type="text" name="rqd2" value="$(V_BWRQDT)" size="4" maxlength="6"><a href="javascript:calWindow('rqd2');">$(calendarImage)</a>
                              %endif
                              %if (ROW_NUM == "3")
                                  <input type="text" name="rqd3" value="$(V_BWRQDT)" size="4" maxlength="6"><a href="javascript:calWindow('rqd3');">$(calendarImage)</a>
                              %endif
                              %if (ROW_NUM == "4")
                                  <input type="text" name="rqd4" value="$(V_BWRQDT)" size="4" maxlength="6"><a href="javascript:calWindow('rqd4');">$(calendarImage)</a>
                              %endif
                              %if (ROW_NUM == "5")
                                  <input type="text" name="rqd5" value="$(V_BWRQDT)" size="4" maxlength="6"><a href="javascript:calWindow('rqd5');">$(calendarImage)</a>
                              %endif
                              %if (ROW_NUM == "6")
                                  <input type="text" name="rqd6" value="$(V_BWRQDT)" size="4" maxlength="6"><a href="javascript:calWindow('rqd6');">$(calendarImage)</a>
                              %endif
                              %if (ROW_NUM == "7")
                                  <input type="text" name="rqd7" value="$(V_BWRQDT)" size="4" maxlength="6"><a href="javascript:calWindow('rqd7');">$(calendarImage)</a>
                              %endif
                              %if (ROW_NUM == "8")
                                  <input type="text" name="rqd8" value="$(V_BWRQDT)" size="4" maxlength="6"><a href="javascript:calWindow('rqd8');">$(calendarImage)</a>
                              %endif
                              %if (ROW_NUM == "9")
                                  <input type="text" name="rqd9" value="$(V_BWRQDT)" size="4" maxlength="6"><a href="javascript:calWindow('rqd9');">$(calendarImage)</a>
                              %endif
                              %if (ROW_NUM == "10")
                                  <input type="text" name="rqd10" value="$(V_BWRQDT)" size="4" maxlength="6"><a href="javascript:calWindow('rqd10');">$(calendarImage)</a>
                              %endif
                              <input type="hidden" name="sts$(ROW_NUM)" value="$(V_BWORST)">
                          </td>

                          %if (maintCode != "A")
                              <td class="colnmbr">@dtw_radd($(V_BWQSTD), $(V_BWQSTC))</td>		
                          %endif
                          %if (multShipToCustomer>"1")
                              @RtvFldDesc("CMCUST=$(V_BWSHTO)", "HDCUST", "CMCNA1", fieldDesc)
                              <td class="inputnmbr" nowrap><input name="sht$(ROW_NUM)" type="text" value="$(V_BWSHTO)" size="4" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;forCustomer=@dtw_rurlescseq(H1BLTO)&amp;docName=Chg&amp;fldName=sht$(ROW_NUM)&amp;fldDesc=custName$(ROW_NUM)" onclick="$(searchWinVar)"> $(searchImage) </a><input name="custName$(ROW_NUM)" value="$(fieldDesc)" size="26" type="text" disabled></td>

                              @RtvFldDesc("SVSVSV='$(V_BWSVSV)'", "HDSHPV", "SVSVDS", fieldDesc)
                              <td class="inputalph" nowrap><input name="shv$(ROW_NUM)" type="text" value="$(V_BWSVSV)" size="2" maxlength="2"><a href="$(homeURL)$(phpPath)ShipViaSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=shv$(ROW_NUM)&amp;fldDesc=shipViaDesc$(ROW_NUM)" onclick="$(searchWinVar)"> $(searchImage) </a><input name="shipViaDesc$(ROW_NUM)" value="$(fieldDesc)" type="text" size="20" disabled></td>
                          %endif
                      %else
                          <td class="colnmbr">$(V_BWQORD)</td>		
	                   @dtw_assign(BWRQDT, V_BWRQDT)
                          @DateToCYMD(V_BWRQDT)
                          @Format_Date(V_BWRQDT, "D", F_BWRQDT)
                          <td class="coldate">$(F_BWRQDT)</td>
                          <td class="colnmbr">$(V_BWQSTD)</td>		
                          <td class="colicon"><input type="hidden" name="qty$(ROW_NUM)" value="$(V_BWQORD)"><input type="hidden" name="rqd$(ROW_NUM)" value="$(BWRQDT)">
                                              <input type="hidden" name="sts$(ROW_NUM)" value="$(V_BWORST)">
                          </td>		
                      %endif
                      <td class="colicon">
                          <input type="hidden" name="rel$(ROW_NUM)" value=$(V_BWBLN#)><input type="hidden" name="row$(ROW_NUM)" value="@dtw_radd(@dtw_rsubtract(sql_Record_Count, START_ROW_NUM), "1")">
                      </td>		
                  </tr>
                  %if (V_BWER# != "")
                      <tr><td colspan="3">&nbsp;</td><td class="error" colspan="8">$(errorMessage)</td></tr>		
                  %endif
              %}
          </table>
      </form>
      %INCLUDE "PageBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(DTW_directcall) Add_Releases (IN	CHAR(64) profileHandle,
				      		CHAR(2)  dataBaseID,
				      		DEC(8,0) orderControlNumber,
				      		DEC(3,0) lineNumber)

{%EXEC {HOEBWA_W.PGM %}
%}

%FUNCTION(DTW_directcall) Get_Detail_Line (INOUT CHAR(64) profileHandle,
                                                 CHAR(2)   dataBaseID,
                                                 DEC(8,0)  orderControlNumber,
                                                 DEC(3,0)  lineNumber,
                                                 DEC(7,0)  dropShipNumber,
                                                 CHAR(15)  itemNumber,
                                                 CHAR(30)  itemDesc,
                                                 DEC(13,4) qtyOrdered,
                                                 DEC(13,4) qtyShipped,
                                                 CHAR(1)   pricedByKit,
                                                 DEC(13,4) qtyOpen,
                                                 DEC(13,4) relQty,
                                                 CHAR(1)   relErr,
                                                 CHAR(1)   maintCode)

{%EXEC {HOEDWR_W.PGM %}
%}

%FUNCTION(dtw_directcall) Update_Blanket (IN  CHAR(64) profileHandle,
				               CHAR(2)   dataBaseID,
                                              DEC(8,0)  orderControlNumber,
                                              DEC(3,0)  lineNumber,
                                              DEC(3,0)  rel1,
                                              DEC(3,0)  rel2,
                                              DEC(3,0)  rel3,
                                              DEC(3,0)  rel4,
                                              DEC(3,0)  rel5,
                                              DEC(3,0)  rel6,
                                              DEC(3,0)  rel7,
                                              DEC(3,0)  rel8,
                                              DEC(3,0)  rel9,
                                              DEC(3,0)  rel10,
                                              DEC(13,4) qty1,
                                              DEC(13,4) qty2,
                                              DEC(13,4) qty3,
                                              DEC(13,4) qty4,
                                              DEC(13,4) qty5,
                                              DEC(13,4) qty6,
                                              DEC(13,4) qty7,
                                              DEC(13,4) qty8,
                                              DEC(13,4) qty9,
                                              DEC(13,4) qty10,
                                              DEC(6,0)  rqd1,
                                              DEC(6,0)  rqd2,
                                              DEC(6,0)  rqd3,
                                              DEC(6,0)  rqd4,
                                              DEC(6,0)  rqd5,
                                              DEC(6,0)  rqd6,
                                              DEC(6,0)  rqd7,
                                              DEC(6,0)  rqd8,
                                              DEC(6,0)  rqd9,
                                              DEC(6,0)  rqd10,
                                              DEC(7,0)  sht1,
                                              DEC(7,0)  sht2,
                                              DEC(7,0)  sht3,
                                              DEC(7,0)  sht4,
                                              DEC(7,0)  sht5,
                                              DEC(7,0)  sht6,
                                              DEC(7,0)  sht7,
                                              DEC(7,0)  sht8,
                                              DEC(7,0)  sht9,
                                              DEC(7,0)  sht10,
                                              CHAR(100) shv,
				               CHAR(1)   updCode)
{%EXEC {HOEBWU_W.PGM %}
%}

%HTML(UPDATE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(shv1)
  @dtw_mUPPERCASE(shv2)
  @dtw_mUPPERCASE(shv3)
  @dtw_mUPPERCASE(shv4)
  @dtw_mUPPERCASE(shv5)
  @dtw_mUPPERCASE(shv6)
  @dtw_mUPPERCASE(shv7)
  @dtw_mUPPERCASE(shv8)
  @dtw_mUPPERCASE(shv9)
  @dtw_mUPPERCASE(shv10)

  @dtw_assign(sht1,@dtw_rstrip(sht1))
  @dtw_assign(sht2,@dtw_rstrip(sht2))
  @dtw_assign(sht3,@dtw_rstrip(sht3))
  @dtw_assign(sht4,@dtw_rstrip(sht4))
  @dtw_assign(sht5,@dtw_rstrip(sht5))
  @dtw_assign(sht6,@dtw_rstrip(sht6))
  @dtw_assign(sht7,@dtw_rstrip(sht7))
  @dtw_assign(sht8,@dtw_rstrip(sht8))
  @dtw_assign(sht9,@dtw_rstrip(sht9))
  @dtw_assign(sht10,@dtw_rstrip(sht10))

  @dtw_assign(qty1,@dtw_rstrip(qty1))
  @dtw_assign(qty2,@dtw_rstrip(qty2))
  @dtw_assign(qty3,@dtw_rstrip(qty3))
  @dtw_assign(qty4,@dtw_rstrip(qty4))
  @dtw_assign(qty5,@dtw_rstrip(qty5))
  @dtw_assign(qty6,@dtw_rstrip(qty6))
  @dtw_assign(qty7,@dtw_rstrip(qty7))
  @dtw_assign(qty8,@dtw_rstrip(qty8))
  @dtw_assign(qty9,@dtw_rstrip(qty9))
  @dtw_assign(qty10,@dtw_rstrip(qty10))
  @dtw_assign(rqd1,@dtw_rstrip(rqd1))
  @dtw_assign(rqd2,@dtw_rstrip(rqd2))
  @dtw_assign(rqd3,@dtw_rstrip(rqd3))
  @dtw_assign(rqd4,@dtw_rstrip(rqd4))
  @dtw_assign(rqd5,@dtw_rstrip(rqd5))
  @dtw_assign(rqd6,@dtw_rstrip(rqd6))
  @dtw_assign(rqd7,@dtw_rstrip(rqd7))
  @dtw_assign(rqd8,@dtw_rstrip(rqd8))
  @dtw_assign(rqd9,@dtw_rstrip(rqd9))
  @dtw_assign(rqd10,@dtw_rstrip(rqd10))

  @dtw_concat(shv, @dtw_rconcat(@dtw_rconcat("@@shv1", shv1),
	                @dtw_rconcat(@dtw_rconcat("}{@@shv2", shv2),
	                @dtw_rconcat(@dtw_rconcat("}{@@shv3", shv3),
	                @dtw_rconcat(@dtw_rconcat("}{@@shv4", shv4),
	                @dtw_rconcat(@dtw_rconcat("}{@@shv5", shv5),
	                @dtw_rconcat(@dtw_rconcat("}{@@shv6", shv6),
                   @dtw_rconcat(@dtw_rconcat("}{@@shv7", shv7),
                   @dtw_rconcat(@dtw_rconcat("}{@@shv8", shv8),
                   @dtw_rconcat(@dtw_rconcat("}{@@shv9", shv9),
                   @dtw_rconcat(@dtw_rconcat("}{@@shva", shv10),
                   @dtw_rconcat("", "}{"))))))))))), shv)

  @dtw_assign(updCode, "")
  @Update_Blanket (profileHandle, dataBaseID, orderControlNumber, lineNumber,
                   rel1, rel2, rel3, rel4, rel5, rel6, rel7, rel8, rel9, rel10,
                   qty1, qty2, qty3, qty4, qty5, qty6, qty7, qty8, qty9, qty10,
                   rqd1, rqd2, rqd3, rqd4, rqd5, rqd6, rqd7, rqd8, rqd9, rqd10,
                   sht1, sht2, sht3, sht4, sht5, sht6, sht7, sht8, sht9, sht10,
                   shv, updCode)

  @dtw_assign(START_ROW_NUM,  "$(updateRowNum)")
  @Set_SQL(stmtSQL)
%}

%HTML(ADDREL) {
  %INCLUDE "setLibraryList.icl"
  @Add_Releases (profileHandle, dataBaseID, orderControlNumber, lineNumber)
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/INPUT$(d2wVarBase)&amp;index=@dtw_rurlescseq(index)">
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(updCode, "U")
  @Update_Blanket (profileHandle, dataBaseID, orderControlNumber, lineNumber,
                   rel1, rel2, rel3, rel4, rel5, rel6, rel7, rel8, rel9, rel10,
                   qty1, qty2, qty3, qty4, qty5, qty6, qty7, qty8, qty9, qty10,
                   rqd1, rqd2, rqd3, rqd4, rqd5, rqd6, rqd7, rqd8, rqd9, rqd10,
                   sht1, sht2, sht3, sht4, sht5, sht6, sht7, sht8, sht9, sht10,
                   shv, updCode)
  @DTW_ASSIGN(updateTotal, "Y")
  @Update_Misc_Charges (profileHandle, dataBaseID, orderControlNumber, freightCharge, specialCharge, updateTotal)
  <script TYPE="text/javascript">
      opener.location.href=opener.location.href;
      window.close()
  </script>
%}

%HTML(NOUPDATE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(updCode, "L")
  @Update_Blanket (profileHandle, dataBaseID, orderControlNumber, lineNumber,
                   rel1, rel2, rel3, rel4, rel5, rel6, rel7, rel8, rel9, rel10,
                   qty1, qty2, qty3, qty4, qty5, qty6, qty7, qty8, qty9, qty10,
                   rqd1, rqd2, rqd3, rqd4, rqd5, rqd6, rqd7, rqd8, rqd9, rqd10,
                   sht1, sht2, sht3, sht4, sht5, sht6, sht7, sht8, sht9, sht10,
                   shv, updCode)
  <script TYPE="text/javascript">
      opener.location.href=opener.location.href;
      window.close()
  </script>
%}

%HTML(REMOVE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(updCode, "R")
  @Update_Blanket (profileHandle, dataBaseID, orderControlNumber, lineNumber,
                   rel1, rel2, rel3, rel4, rel5, rel6, rel7, rel8, rel9, rel10,
                   qty1, qty2, qty3, qty4, qty5, qty6, qty7, qty8, qty9, qty10,
                   rqd1, rqd2, rqd3, rqd4, rqd5, rqd6, rqd7, rqd8, rqd9, rqd10,
                   sht1, sht2, sht3, sht4, sht5, sht6, sht7, sht8, sht9, sht10,
                   shv, updCode)
  <script TYPE="text/javascript">
      opener.location.href=opener.location.href;
      window.close()
  </script>
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  %if (blanket == "N")
      @Add_Releases (profileHandle, dataBaseID, orderControlNumber, lineNumber)
  %endif
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/INPUT$(d2wVarBase)&amp;index=@dtw_rurlescseq(index)">
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}