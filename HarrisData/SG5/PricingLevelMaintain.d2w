%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Customer Pricing Level Maintenance"
  d2wName                 = "PricingLevelMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;dtlCnt=@dtw_rurlescseq(dtlCnt)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(genericVarBase)&amp;pricingLevel=@dtw_rurlescseq(pricingLevel)&amp;levelDesc=@dtw_rurlescseq(levelDesc)&amp;maintenanceCode=D"
  programName             = "HOEPLM_E"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "PricingLevelMaintain.icl"
              %INCLUDE "MultiChoiceSelectList2.icl"
              %INCLUDE "NewWindowOpen.icl"
              function validate(chgForm) {
                  if (document.Chg.pricingLevel.value =="" ||
                      document.Chg.levelDesc.value =="")
                     {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.pricingLevel, 2, 0))
                      return true;
              }
              function check(chgForm) {
                  if (validate(chgForm) &&
                      saveSel(chgForm.choiceBox,chgForm.choices))
                      chgForm.submit();
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
              %INCLUDE "NumEdit.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PRICINGLEVELMAINT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, " Select * From HDPRLC Where PVPMLV = $(pricingLevel)", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, daataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %if (sec_03 == "Y")
          @RtvFldDesc("PMPMLV=$(pricingLevel)", "HDPRCD", "CHAR(COUNT(PMPMLV))", detailCount)
          %if (detailCount > "0")
              @dtw_assign(sec_03, "N")
          %endif
      %endif
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          %ROW {
              <table $(contentTable)>
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "pricingLevel")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@pmlv", "pricingLevel")   @dtw_assign(Err_PVPMLV,  fieldValue)
                          @DecatErr_Field("@@lvds", "levelDesc")      @dtw_assign(Err_PVLVDS,  fieldValue)
                          @DecatErr_Field("@@whsq", "available")      @dtw_assign(Err_PVWHSQ,  fieldValue)
                          @DecatErr_Field("@@cn@@", "contract")       @dtw_assign(Err_PVCN,    fieldValue)
                          @DecatErr_Field("@@ll@@", "listLess")       @dtw_assign(Err_PVLL,    fieldValue)
                          @DecatErr_Field("@@cp@@", "costPlus")       @dtw_assign(Err_PVCP,    fieldValue)
                          @DecatErr_Field("@@dl@@", "dollarAmt")      @dtw_assign(Err_PVDL,    fieldValue)
                          @DecatErr_Field("@@up@@", "usePercent")     @dtw_assign(Err_PVUP,    fieldValue)
                          @DecatErr_Field("@@bp@@", "bracketQty")     @dtw_assign(Err_PVBP,    fieldValue)
                          @DecatErr_Field("@@ba@@", "bracketAmt")     @dtw_assign(Err_PVBA,    fieldValue)
                          @DecatErr_Field("@@comm", "commissionable") @dtw_assign(Err_PVCOMM, fieldValue)
                      %endif

                      @Decat_Field("@@pmlv")   @dtw_assign(V_PVPMLV, fieldValue)
                      @Decat_Field("@@lvds")   @dtw_assign(V_PVLVDS, fieldValue)

                      @Decat_Field("@@whsq")   @dtw_assign(V_PVWHSQ, fieldValue)
                      @Decat_Field("@@itsq")   @dtw_assign(V_PVITSQ, fieldValue)
                      @Decat_Field("@@cssq")   @dtw_assign(V_PVCSSQ, fieldValue)
                      @Decat_Field("@@ccsq")   @dtw_assign(V_PVCCSQ, fieldValue)
                      @Decat_Field("@@pcsq")   @dtw_assign(V_PVPCSQ, fieldValue)
                      @Decat_Field("@@rgsq")   @dtw_assign(V_PVRGSQ, fieldValue)
                      @Decat_Field("@@pgsq")   @dtw_assign(V_PVPGSQ, fieldValue)

                      @Decat_Field("@@cn@@")   @dtw_assign(V_PVCN, fieldValue)
                      @Decat_Field("@@ll@@")   @dtw_assign(V_PVLL, fieldValue)
                      @Decat_Field("@@cp@@")   @dtw_assign(V_PVCP, fieldValue)
                      @Decat_Field("@@dl@@")   @dtw_assign(V_PVDL, fieldValue)
                      @Decat_Field("@@up@@")   @dtw_assign(V_PVUP, fieldValue)
                      @Decat_Field("@@bp@@")   @dtw_assign(V_PVBP, fieldValue)
                      @Decat_Field("@@ba@@")   @dtw_assign(V_PVBA, fieldValue)
                      @Decat_Field("@@comm")   @dtw_assign(V_PVCOMM, fieldValue)

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_PVPMLV, "")
                      @dtw_assign(focusField, "pricingLevel")
                  %else
                      @dtw_assign(focusField, "levelDesc")
                  %endif

                  @Field_Checked(V_PVCN, "Y", contractChecked)
                  @Field_Checked(V_PVLL, "Y", listLessChecked)
                  @Field_Checked(V_PVCP, "Y", costPlusChecked)
                  @Field_Checked(V_PVDL, "Y", dollarAmtChecked)
                  @Field_Checked(V_PVUP, "Y", usePercentChecked)
                  @Field_Checked(V_PVBP, "Y", bracketQtyChecked)
                  @Field_Checked(V_PVBA, "Y", bracketAmtChecked)

                  @SetTextOvr(Err_PVPMLV)
                  <tr><td class="dsphdr"><span $(textOvr)>Pricing Level</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="pricingLevel" type="text" value="$(V_PVPMLV)" size="5" maxlength="2"> $(reqFieldChar) </td>
                      %else
                          <td class="inputnmbr"><input name="pricingLevel" type="hidden" value="$(V_PVPMLV)" size="5" maxlength="2">$(V_PVPMLV)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_PVPMLV)

                  @SetTextOvr(Err_PVLVDS)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="levelDesc" type="text" value="$(V_PVLVDS)" size="30" maxlength="30"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_PVLVDS)
              </table>
              %if (dtlCnt <= "0" || maintenanceCode == "Z")
                  <fieldset>
                      <table $(contentTable)>
                          <tr><td class="copr">To select a category, click on the Available Categories description. <br>
                                               To move a Selected Category, click on it and then select the up or down icon.<br>
                                               To remove a Selected Category, click on it and then select the delete icon. <br><br>
                              </td>
                          </tr>
                      </table>
                  </fieldset>
              %endif
              %if (Err_PVWHSQ != "")
                  <span class="error" $(textOvr)>$(Err_PVWHSQ)</span>
              %endif
              <table $(contentTable)>
                  <tr>
                      %if (dtlCnt <= "0" || maintenanceCode == "Z")
                          <td valign="top" class="colhdr">
                              Available Categories:
                              <br>
                              <select name="available" size="8" onChange="moveSelOver();">
                              </select>
                              <script TYPE="text/javascript">
                                  loadAvailable(document.Chg.available);
                              </script>
                          </td>
                          <td>&nbsp;</td>
                      %endif
                      <td valign="top" class="colhdr">
                          Selected Categories:
                          <br>
                          <select multiple name="choiceBox" size="8">
                          </select>
                          %if (V_PVWHSQ != "0" && V_PVWHSQ != "")
                              <script TYPE="text/javascript">
                                  loadOption("0",document.Chg.choiceBox,@dtw_rsubtract(V_PVWHSQ, "1"));
                              </script>
                          %endif
                          %if (V_PVITSQ != "0" && V_PVITSQ != "")
                              <script TYPE="text/javascript">
                                  loadOption("1",document.Chg.choiceBox,@dtw_rsubtract(V_PVITSQ, "1"));
                              </script>
                          %endif
                          %if (V_PVCSSQ != "0" && V_PVCSSQ != "")
                              <script TYPE="text/javascript">
                                  loadOption("2",document.Chg.choiceBox,@dtw_rsubtract(V_PVCSSQ, "1"));
                              </script>
                          %endif
                          %if (V_PVCCSQ != "0" && V_PVCCSQ != "")
                              <script TYPE="text/javascript">
                                  loadOption("3",document.Chg.choiceBox,@dtw_rsubtract(V_PVCCSQ, "1"));
                              </script>
                          %endif
                          %if (V_PVPCSQ != "0" && V_PVPCSQ != "")
                              <script TYPE="text/javascript">
                                  loadOption("4",document.Chg.choiceBox,@dtw_rsubtract(V_PVPCSQ, "1"));
                              </script>
                          %endif
                          %if (V_PVRGSQ != "0" && V_PVRGSQ != "")
                              <script TYPE="text/javascript">
                                  loadOption("5",document.Chg.choiceBox,@dtw_rsubtract(V_PVRGSQ, "1"));
                              </script>
                          %endif
                          %if (V_PVPGSQ != "0" && V_PVPGSQ != "")
                              <script TYPE="text/javascript">
                                  loadOption("6",document.Chg.choiceBox,@dtw_rsubtract(V_PVPGSQ, "1"));
                              </script>
                          %endif
                      </td>
                      <td valign="middle">
                          %if (dtlCnt <= "0" || maintenanceCode == "Z")
                              $(reqFieldChar)<br><br>
                              <a onClick="moveSelUp(document.Chg.choiceBox)">$(topOfFormImage)</a><br><br>
                              <a onClick="moveSelDown(document.Chg.choiceBox)">$(botOfFormImage)</a><br><br>
                              <a onClick="removeSel(document.Chg.choiceBox)">$(deleteImageSml)</a>
                          %endif
                          <input name="choices" type="hidden">
                      </td>
                  </tr>
              </table>

              <fieldset><legend class="legendTitle">Pricing Structure Definition</legend>
              <table $(contentTable)>
                  @SetTextOvr(Err_PVCN)
                  <tr><td class="dsphdr"><span $(textOvr)>Contract</span></td>
                      <td class="inputalph">
                           <input name="contract" type="checkbox" $(contractChecked) value="Y" %if (dtlCnt > "0" && maintenanceCode != "Z") disabled %endif >
                           <input name="contract2" type="hidden" value="$(V_PVCN)">
                      </td>
                  </tr>
                  @DspErrMsg(Err_PVCN)

                  @SetTextOvr(Err_PVLL)
                  <tr><td class="dsphdr"><span $(textOvr)>List Less Amount</span></td>
                      <td class="inputalph"><input name="listLess" type="checkbox" $(listLessChecked) value="Y"></td>
                  </tr>
                  @DspErrMsg(Err_PVLL)

                  @SetTextOvr(Err_PVCP)
                  <tr><td class="dsphdr"><span $(textOvr)>Cost Plus Amount</span></td>
                      <td class="inputalph"><input name="costPlus" type="checkbox" $(costPlusChecked) value="Y"></td>
                  </tr>
                  @DspErrMsg(Err_PVCP)

                  @SetTextOvr(Err_PVDL)
                  <tr><td class="dsphdr"><span $(textOvr)>Dollar Amount</span></td>
                      <td class="inputalph"><input name="dollarAmt" type="checkbox" $(dollarAmtChecked) value="Y"></td>
                  </tr>
                  @DspErrMsg(Err_PVDL)

                  @SetTextOvr(Err_PVUP)
                  <tr><td class="dsphdr"><span $(textOvr)>Use Percentages</span></td>
                      <td class="inputalph"><input name="usePercent" type="checkbox" $(usePercentChecked) value="Y"></td>
                  </tr>
                  @DspErrMsg(Err_PVUP)

                  @SetTextOvr(Err_PVBP)
                  <tr><td class="dsphdr"><span $(textOvr)>Bracket By Quantity</span></td>
                      <td class="inputalph"><input name="bracketQty" type="checkbox" $(bracketQtyChecked) value="Y"></td>
                  </tr>
                  @DspErrMsg(Err_PVBP)

                  @SetTextOvr(Err_PVBA)
                  <tr><td class="dsphdr"><span $(textOvr)>Bracket By Amount</span></td>
                      <td class="inputalph"><input name="bracketAmt" type="checkbox" $(bracketAmtChecked) value="Y"></td>
                  </tr>
                  @DspErrMsg(Err_PVBA)

                  @SetTextOvr(Err_PVCOMM)
                  <tr><td class="dsphdr"><span $(textOvr)>Commissionable</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_PVCOMM) && (x < maxRows))
                             {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "commissionable", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_PVCOMM)

              </table>
              </fieldset>
          %}
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(10)    userProfile,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HOEPLM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @yn01_Table_Query(profileHandle, dataBaseID, "PRCLVLCOMM", yn01Table)
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(pricingLevel,@dtw_rstrip(pricingLevel))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@pmlv", pricingLevel)
  @Concat_Field("@@lvds", levelDesc)
  @dtw_concat(edtVar, "}{", edtVar)
  @dtw_concat(edtVar, choices, edtVar)
  %if (dtlCnt > "0" || maintenanceCode == "Z")
      @Concat_Field("@@cn@@", contract2)
  %else
      @Concat_Field("@@cn@@", contract)
  %endif
  @Concat_Field("@@ll@@", listLess)
  @Concat_Field("@@cp@@", costPlus)
  @Concat_Field("@@dl@@", dollarAmt)
  @Concat_Field("@@up@@", usePercent)
  @Concat_Field("@@bp@@", bracketQty)
  @Concat_Field("@@ba@@", bracketAmt)
  @Concat_Field("@@comm", commissionable)
  @dtw_concat(edtVar, "}{", edtVar)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @Validate_Data(userProfile, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(levelDesc), $(pricingLevel), "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)PricingLevel.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@lvds", "levelDesc")
      @Format_ConfMsg_Desc("", $(levelDesc), $(pricingLevel), "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)PricingLevel.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;pricingLevel=@dtw_rurlescseq(pricingLevel)&amp;levelDesc=@dtw_rurlescseq(levelDesc)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
