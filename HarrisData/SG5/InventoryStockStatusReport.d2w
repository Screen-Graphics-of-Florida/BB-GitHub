%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Inventory Stock Status Report"
  d2wName                 = "InventoryStockStatusReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "10"
  sortPlantNumber         = "1"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.negativeOnHands.checked == true &&
                      document.Chg.zeroOnHands.checked == true)
                      {alert("Second and third options are mutually exclusive");
                      document.Chg.negativeOnHands.focus();
                      document.Chg.negativeOnHands();
                      return false;}
                  if (document.Chg.negativeOnHands.checked == true &&
                      document.Chg.noActivity.checked == true)
                      {alert("Second and fifth options are mutually exclusive");
                      document.Chg.negativeOnHands.focus();
                      document.Chg.negativeOnHands();
                      return false;}
                  if (editNum(document.Chg.fromPlantNumber, 3, 0) &&
                      editNum(document.Chg.toPlantNumber, 3, 0) &&
                      editNum(document.Chg.fromBuyerAnalyst, 7, 0) &&
                      editNum(document.Chg.toBuyerAnalyst, 7, 0) &&
                      editFromToAll(document.Chg.fromPlantNumber, document.Chg.toPlantNumber, document.Chg.allPlantNumber, 3) &&
                      editFromToAll(document.Chg.fromPartClass, document.Chg.toPartClass, document.Chg.allPartClass, "A") &&
                      editFromToAll(document.Chg.fromProductClass, document.Chg.toProductClass, document.Chg.allProductClass, "A") &&
                      editFromToAll(document.Chg.fromBuyerAnalyst, document.Chg.toBuyerAnalyst, document.Chg.allBuyerAnalyst, 7) &&
                      editFromToAll(document.Chg.fromMaterialCode, document.Chg.toMaterialCode, document.Chg.allMaterialCode, "A") &&
                      editFromToAll(document.Chg.fromABCCode, document.Chg.toABCCode, document.Chg.allABCCode, "A") &&
                      editFromToAll(document.Chg.fromInventoryType, document.Chg.toInventoryType, document.Chg.allInventoryType, "A") &&
                      editFromToAll(document.Chg.fromPartType, document.Chg.toPartType, document.Chg.allPartType, "A") &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromBackflushCode, document.Chg.toBackflushCode, document.Chg.allBackflushCode, "A")
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "INVENTORYSTOCKSTATUSREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromPlantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@pl1@", "fromPlantNumber")        @dtw_assign(Err_TRPL1,  fieldValue)
                                  @DecatErr_Field("@@spl@", "sortPlantNumber")        @dtw_assign(Err_SEQPL,  fieldValue)
                                  @DecatErr_Field("@@sic@", "sortPartClass")        @dtw_assign(Err_SEQIC,  fieldValue)
                                  @DecatErr_Field("@@spc@", "sortProductClass")        @dtw_assign(Err_SEQPC,  fieldValue)
                                  @DecatErr_Field("@@sbac", "sortBuyerAnalyst")        @dtw_assign(Err_SEQBAC,  fieldValue)
                                  @DecatErr_Field("@@smc@", "sortMaterialCode")        @dtw_assign(Err_SEQMC,  fieldValue)
                                  @DecatErr_Field("@@sab@", "sortABCCode")        @dtw_assign(Err_SEQAB,  fieldValue)
                                  @DecatErr_Field("@@sit@", "sortInventoryType")        @dtw_assign(Err_SEQIT,  fieldValue)
                                  @DecatErr_Field("@@spt@", "sortPartType")        @dtw_assign(Err_SEQPT,  fieldValue)
                                  @DecatErr_Field("@@sitm", "sortItemNumber")        @dtw_assign(Err_SEQITM,  fieldValue)
                                  @DecatErr_Field("@@swc@", "sortBackflushCode")        @dtw_assign(Err_SEQWC,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@um@@")  @dtw_assign(V_RPTUM,  fieldValue)
                                  @Decat_Field("@@ooq@")  @dtw_assign(V_INCOOQ,  fieldValue)
                                  @Decat_Field("@@noh@")  @dtw_assign(V_PRTNOH,  fieldValue)
                                  @Decat_Field("@@zoh@")  @dtw_assign(V_PRTZOH,  fieldValue)
                                  @Decat_Field("@@zoo@")  @dtw_assign(V_PRTZOO,  fieldValue)
                                  @Decat_Field("@@ina@")  @dtw_assign(V_INCINA,  fieldValue)

                                  @Decat_Field("@@pl1@")  @dtw_assign(V_TRPL1,  fieldValue)
                                  @Decat_Field("@@pl2@")  @dtw_assign(V_TRPL2,  fieldValue)
                                  @Decat_Field("@@apl@")  @dtw_assign(V_ALLPL,  fieldValue)
                                  @Decat_Field("@@spl@")  @dtw_assign(V_SEQPL,  fieldValue)
                                  @Decat_Field("@@ppl@")  @dtw_assign(V_TRPPL,  fieldValue)

                                  @Decat_Field("@@ic1@")  @dtw_assign(V_TRIC1,  fieldValue)
                                  @Decat_Field("@@ic2@")  @dtw_assign(V_TRIC2,  fieldValue)
                                  @Decat_Field("@@aic@")  @dtw_assign(V_ALLIC,  fieldValue)
                                  @Decat_Field("@@sic@")  @dtw_assign(V_SEQIC,  fieldValue)
                                  @Decat_Field("@@pic@")  @dtw_assign(V_TRPIC,  fieldValue)

                                  @Decat_Field("@@pc1@")  @dtw_assign(V_TRPC1,  fieldValue)
                                  @Decat_Field("@@pc2@")  @dtw_assign(V_TRPC2,  fieldValue)
                                  @Decat_Field("@@apc@")  @dtw_assign(V_ALLPC,  fieldValue)
                                  @Decat_Field("@@spc@")  @dtw_assign(V_SEQPC,  fieldValue)
                                  @Decat_Field("@@ppc@")  @dtw_assign(V_TRPPC,  fieldValue)

                                  @Decat_Field("@@bac1")  @dtw_assign(V_TRBAC1,  fieldValue)
                                  @Decat_Field("@@bac2")  @dtw_assign(V_TRBAC2,  fieldValue)
                                  @Decat_Field("@@abac")  @dtw_assign(V_ALLBAC,  fieldValue)
                                  @Decat_Field("@@sbac")  @dtw_assign(V_SEQBAC,  fieldValue)
                                  @Decat_Field("@@pbac")  @dtw_assign(V_TRPBAC,  fieldValue)

                                  @Decat_Field("@@mc1@")  @dtw_assign(V_TRMC1,  fieldValue)
                                  @Decat_Field("@@mc2@")  @dtw_assign(V_TRMC2,  fieldValue)
                                  @Decat_Field("@@amc@")  @dtw_assign(V_ALLMC,  fieldValue)
                                  @Decat_Field("@@smc@")  @dtw_assign(V_SEQMC,  fieldValue)
                                  @Decat_Field("@@pmc@")  @dtw_assign(V_TRPMC,  fieldValue)

                                  @Decat_Field("@@ab1@")  @dtw_assign(V_TRAB1,  fieldValue)
                                  @Decat_Field("@@ab2@")  @dtw_assign(V_TRAB2,  fieldValue)
                                  @Decat_Field("@@aab@")  @dtw_assign(V_ALLAB,  fieldValue)
                                  @Decat_Field("@@sab@")  @dtw_assign(V_SEQAB,  fieldValue)
                                  @Decat_Field("@@pab@")  @dtw_assign(V_TRPAB,  fieldValue)

                                  @Decat_Field("@@it1@")  @dtw_assign(V_TRIT1,  fieldValue)
                                  @Decat_Field("@@it2@")  @dtw_assign(V_TRIT2,  fieldValue)
                                  @Decat_Field("@@ait@")  @dtw_assign(V_ALLIT,  fieldValue)
                                  @Decat_Field("@@sit@")  @dtw_assign(V_SEQIT,  fieldValue)
                                  @Decat_Field("@@pit@")  @dtw_assign(V_TRPIT,  fieldValue)

                                  @Decat_Field("@@pt1@")  @dtw_assign(V_TRPT1,  fieldValue)
                                  @Decat_Field("@@pt2@")  @dtw_assign(V_TRPT2,  fieldValue)
                                  @Decat_Field("@@apt@")  @dtw_assign(V_ALLPT,  fieldValue)
                                  @Decat_Field("@@spt@")  @dtw_assign(V_SEQPT,  fieldValue)
                                  @Decat_Field("@@ppt@")  @dtw_assign(V_TRPPT,  fieldValue)

                                  @Decat_Field("@@itm1")  @dtw_assign(V_TRITM1,  fieldValue)
                                  @Decat_Field("@@itm2")  @dtw_assign(V_TRITM2,  fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_ALLITM,  fieldValue)
                                  @Decat_Field("@@sitm")  @dtw_assign(V_SEQITM,  fieldValue)

                                  @Decat_Field("@@wc1@")  @dtw_assign(V_TRWC1,  fieldValue)
                                  @Decat_Field("@@wc2@")  @dtw_assign(V_TRWC2,  fieldValue)
                                  @Decat_Field("@@awc@")  @dtw_assign(V_ALLWC,  fieldValue)
                                  @Decat_Field("@@swc@")  @dtw_assign(V_SEQWC,  fieldValue)
                                  @Decat_Field("@@pwc@")  @dtw_assign(V_TRPWC,  fieldValue)

                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries
 Values %}
                                  %if (V_RPTUM == "02")
                                      @dtw_assign(stocking, "")
                                      @dtw_assign(purchasing, "CHECKED")
                                  %else
                                      @dtw_assign(stocking, "CHECKED")
                                      @dtw_assign(purchasing, "")
                                  %endif
                                  %if (V_INCOOQ == "1")
                                      @dtw_assign(checkedOnOrderQuantity, "CHECKED")
                                  %else
                                      @dtw_assign(checkedOnOrderQuantity, "")
                                  %endif
                                  %if (V_PRTNOH == "1")
                                      @dtw_assign(checkedNegativeOnHands, "CHECKED")
                                  %else
                                      @dtw_assign(checkedNegativeOnHands, "")
                                  %endif
                                  %if (V_PRTZOH == "1")
                                      @dtw_assign(checkedZeroOnHands, "CHECKED")
                                  %else
                                      @dtw_assign(checkedZeroOnHands, "")
                                  %endif
                                  %if (V_PRTZOO == "1")
                                      @dtw_assign(checkedZeroOnOrder, "CHECKED")
                                  %else
                                      @dtw_assign(checkedZeroOnOrder, "")
                                  %endif
                                  %if (V_INCINA == "1")
                                      @dtw_assign(checkedNoActivity, "CHECKED")
                                  %else
                                      @dtw_assign(checkedNoActivity, "")
                                  %endif
                                  %if (V_ALLPL == "ALL")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPlantNumber, "")
                                  %endif
                                  %if (V_ALLIC == "ALL")
                                      @dtw_assign(checkedallPartClass, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPartClass, "")
                                  %endif
                                  %if (V_ALLPC == "ALL")
                                      @dtw_assign(checkedallProductClass, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallProductClass, "")
                                  %endif
                                  %if (V_ALLBAC == "ALL")
                                      @dtw_assign(checkedallBuyerAnalyst, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallBuyerAnalyst, "")
                                  %endif
                                  %if (V_ALLMC == "ALL")
                                      @dtw_assign(checkedallMaterialCode, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallMaterialCode, "")
                                  %endif
                                  %if (V_ALLAB == "ALL")
                                      @dtw_assign(checkedallABCCode, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallABCCode, "")
                                  %endif
                                  %if (V_ALLIT == "ALL")
                                      @dtw_assign(checkedallInventoryType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallInventoryType, "")
                                  %endif
                                  %if (V_ALLPT == "ALL")
                                      @dtw_assign(checkedallPartType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPartType, "")
                                  %endif
                                  %if (V_ALLITM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_ALLWC == "ALL")
                                      @dtw_assign(checkedallBackflushCode, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallBackflushCode, "")
                                  %endif

                                  %if (V_TRPPL == "Y")
                                      @dtw_assign(checkedPlantNumberBreak, "CHECKED")
                                  %else
                                      @dtw_assign(checkedPlantNumberBreak, "")
                                  %endif
                                  %if (V_TRPIC == "Y")
                                      @dtw_assign(checkedPartClassBreak, "CHECKED")
                                  %else
                                      @dtw_assign(checkedPartClassBreak, "")
                                  %endif
                                  %if (V_TRPPC == "Y")
                                      @dtw_assign(checkedProductClassBreak, "CHECKED")
                                  %else
                                      @dtw_assign(checkedProductClassBreak, "")
                                  %endif
                                  %if (V_TRPBAC == "Y")
                                      @dtw_assign(checkedBuyerAnalystBreak, "CHECKED")
                                  %else
                                      @dtw_assign(checkedBuyerAnalystBreak, "")
                                  %endif
                                  %if (V_TRPMC == "Y")
                                      @dtw_assign(checkedMaterialCodeBreak, "CHECKED")
                                  %else
                                      @dtw_assign(checkedMaterialCodeBreak, "")
                                  %endif
                                  %if (V_TRPAB == "Y")
                                      @dtw_assign(checkedABCCodeBreak, "CHECKED")
                                  %else
                                      @dtw_assign(checkedABCCodeBreak, "")
                                  %endif
                                  %if (V_TRPIT == "Y")
                                      @dtw_assign(checkedInventoryTypeBreak, "CHECKED")
                                  %else
                                      @dtw_assign(checkedInventoryTypeBreak, "")
                                  %endif
                                  %if (V_TRPPT == "Y")
                                      @dtw_assign(checkedPartTypeBreak, "CHECKED")
                                  %else
                                      @dtw_assign(checkedPartTypeBreak, "")
                                  %endif
                                  %if (V_TRPWC == "Y")
                                      @dtw_assign(checkedBackflushCodeBreak, "CHECKED")
                                  %else
                                      @dtw_assign(checkedBackflushCodeBreak, "")
                                  %endif
                              %else
                                  @dtw_assign(stocking, "CHECKED")
                                  @dtw_assign(purchasing, "")
                                  @dtw_assign(checkedOnOrderQuantity, "")
                                  @dtw_assign(checkedNegativeOnHands, "")
                                  @dtw_assign(checkedZeroOnHands, "")
                                  @dtw_assign(checkedZeroOnOrder, "")
                                  @dtw_assign(checkedNoActivity, "")
                                  @RtvDftPlant(plantNumber, plantName)
                                  %if (plantNumber == "0")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(V_TRPL1, plantNumber)
                                      @dtw_assign(V_TRPL2, plantNumber)
                                      @dtw_assign(checkedallPlantNumber, "")
                                      @dtw_assign(focusField, "fromPartClass")
                                  %endif
                                  @dtw_assign(checkedallPartClass, "CHECKED")
                                  @dtw_assign(checkedallProductClass, "CHECKED")
                                  @dtw_assign(checkedallBuyerAnalyst, "CHECKED")
                                  @dtw_assign(checkedallMaterialCode, "CHECKED")
                                  @dtw_assign(checkedallABCCode, "CHECKED")
                                  @dtw_assign(checkedallInventoryType, "CHECKED")
                                  @dtw_assign(checkedallPartType, "CHECKED")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallBackflushCode, "CHECKED")
                                  @dtw_assign(checkedPlantNumberBreak, "CHECKED")
                                  @dtw_assign(checkedPartClassBreak, "")
                                  @dtw_assign(checkedProductClassBreak, "")
                                  @dtw_assign(checkedBuyerAnalystBreak, "")
                                  @dtw_assign(checkedMaterialCodeBreak, "")
                                  @dtw_assign(checkedABCCodeBreak, "")
                                  @dtw_assign(checkedInventoryTypeBreak, "")
                                  @dtw_assign(checkedPartTypeBreak, "")
                                  @dtw_assign(checkedItemNumberBreak, "")
                                  @dtw_assign(checkedBackflushCodeBreak, "")
                                  @dtw_assign(V_SEQITM, "2")
                              %endif

                              <tr><td  class="dsphdr"><span $(textOvr)>Report Unit Of Measure</span></td>
                                  <td class="inputnmbr"><input name="unitOfMeasure" type="radio" VALUE='01' $(stocking)>Stocking</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="unitOfMeasure" type="radio" VALUE='02' $(purchasing)>Purchasing</td>
                              </tr>

                              <tr><td class="dsphdr"><span $(textOvr)>Select Options</span></td>
                                  <td class="inputnmbr"><input name="onOrderQuantity" type="checkbox" VALUE='1' $(checkedOnOrderQuantity)>Include On Order Quantity For Availability</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="negativeOnHands" type="checkbox" VALUE='1' $(checkedNegativeOnHands)>Print Only Negative On Hands</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td  class="inputnmbr"><input name="zeroOnHands" type="checkbox" VALUE='1' $(checkedZeroOnHands)>Print Only Zero On Hands</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td  class="inputnmbr"><input name="zeroOnOrder" type="checkbox" VALUE='1' $(checkedZeroOnOrder)>Print Only Zero On Order</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td  class="inputnmbr"><input name="noActivity" type="checkbox" VALUE='1' $(checkedNoActivity)>Include Items With No Activity</td>
                              </tr>
                          </table>

                          <table $(contentTable)>

                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                                  <td class="colhdr">Page<br>Break</td>
                              </tr>

                              @SetTextOvr(Err_TRPL1)
                              %if (textOvr == "") @SetTextOvr(Err_SEQPL) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                  <td class="inputnmbr"><input name="fromPlantNumber" value="$(V_TRPL1)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromPlantNumber&amp;fldDesc=fplantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fplantName"  type="hidden"></td>
                                  <td class="inputnmbr"><input name="toPlantNumber" value="$(V_TRPL2)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toPlantNumber&amp;fldDesc=tplantName" onclick="$(searchWinVar)">  $(searchImage) </a><input name="tplantName"  type="hidden"></td>
                                  <td class="inputalph"><input name="allPlantNumber" value='ALL' $(checkedallPlantNumber) type="checkbox" onClick="if (this.checked) this.form.fromPlantNumber.value='', this.form.toPlantNumber.value='';"></td>
                                  <td class="colcode"><input &name="sortPlantNumber" type="hidden"  Value="$(sortPlantNumber)" size="1" maxlength="1">$(sortPlantNumber)</td>
                                  <td align=center ><input name="breakPlantNumber" type="checkbox" $(checkedPlantNumberBreak) disabled VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_TRPL1)
                              @DspErrMsg(Err_SEQPL)

                              @SetTextOvr(Err_SEQIC)
                              <tr><td  class="dsphdr"><span $(textOvr)>Part Class</span></td>
                                  <td class="inputnmbr"><input name="fromPartClass" value="$(V_TRIC1)" type="text" size="2" maxlength="2"></td>
                                  <td class="inputnmbr"><input name="toPartClass" value="$(V_TRIC2)" type="text" size="2" maxlength="2"></td>
                                  <td class="inputalph"><input name="allPartClass" value='ALL' $(checkedallPartClass) type="checkbox" onClick="if (this.checked) this.form.fromPartClass.value='', this.form.toPartClass.value='';"></td>
                                  @Build_Sort_Select("sortPartClass", "$(V_SEQIC)")
                                  <td align=center ><input name="breakPartClass" type="checkbox" $(checkedPartClassBreak) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_SEQIC)

                              @SetTextOvr(Err_SEQPC)
                              <tr><td  class="dsphdr"><span $(textOvr)>Product Class</span></td>
                                  <td class="inputalph"><input name="fromProductClass" value="$(V_TRPC1)" type="text" size="8" maxlength="4"><a href="$(homeURL)$(cGIPath)ProdClassSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromProductClass&amp;fldDesc=fproductClassDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fproductClassDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="toProductClass" value="$(V_TRPC2)" type="text" size="8" maxlength="4"><a href="$(homeURL)$(cGIPath)ProdClassSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toProductClass&amp;fldDesc=tproductClassDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="tproductClassDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allProductClass" value='ALL' $(checkedallProductClass) type="checkbox" onClick="if (this.checked) this.form.fromProductClass.value='', this.form.toProductClass.value='';"></td>
                                  @Build_Sort_Select("sortProductClass", "$(V_SEQPC)")
                                  <td align=center ><input name="breakProductClass" type="checkbox" $(checkedProductClassBreak) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_SEQPC)

                              @SetTextOvr(Err_SEQBAC)
                              <tr><td  class="dsphdr"><span $(textOvr)>Buyer/Analyst</span></td>
                                  <td class="inputnmbr"><input name="fromBuyerAnalyst" value="$(V_TRBAC1)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)BuyerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromBuyerAnalyst&amp;fldDesc=analystName&amp;buyerAnalyst=Analyst" onclick="$(searchWinVar)"> $(searchImage) </a><input name="analystName" type="hidden"><input name="Analyst" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toBuyerAnalyst" value="$(V_TRBAC2)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)BuyerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toBuyerAnalyst&amp;fldDesc=analystName&amp;buyerAnalyst=Analyst" onclick="$(searchWinVar)"> $(searchImage) </a><input name="analystName" type="hidden"><input name="Analyst" type="hidden"></td>
                                  <td class="inputalph"><input name="allBuyerAnalyst" value='ALL' $(checkedallBuyerAnalyst) type="checkbox" onClick="if (this.checked) this.form.fromBuyerAnalyst.value='', this.form.toBuyerAnalyst.value='';"></td>
                                  @Build_Sort_Select("sortBuyerAnalyst", "$(V_SEQBAC)")
                                  <td align=center ><input name="breakBuyerAnalyst" type="checkbox" $(checkedBuyerAnalystBreak) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_SEQBAC)

                              @SetTextOvr(Err_SEQMC)
                              <tr><td  class="dsphdr"><span $(textOvr)>Material Code</span></td>
                                  <td class="inputnmbr"><input name="fromMaterialCode" value="$(V_TRMC1)" type="text" size="4" maxlength="4"></td>
                                  <td class="inputnmbr"><input name="toMaterialCode" value="$(V_TRMC2)" type="text" size="4" maxlength="4"></td>
                                  <td class="inputalph"><input name="allMaterialCode" value='ALL' $(checkedallMaterialCode) type="checkbox" onClick="if (this.checked) this.form.fromMaterialCode.value='', this.form.toMaterialCode.value='';"></td>
                                  @Build_Sort_Select("sortMaterialCode", "$(V_SEQMC)")
                                  <td align=center ><input name="breakMaterialCode" type="checkbox" $(checkedMaterialCodeBreak) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_SEQMC)

                              @SetTextOvr(Err_SEQAB)
                              <tr><td  class="dsphdr"><span $(textOvr)>ABC Code</span></td>
                                  <td class="inputnmbr"><input name="fromABCCode" value="$(V_TRAB1)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputnmbr"><input name="toABCCode" value="$(V_TRAB2)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="allABCCode" value='ALL' $(checkedallABCCode) type="checkbox" onClick="if (this.checked) this.form.fromABCCode.value='', this.form.toABCCode.value='';"></td>
                                  @Build_Sort_Select("sortABCCode", "$(V_SEQAB)")
                                  <td align=center ><input name="breakABCCode" type="checkbox" $(checkedABCCodeBreak) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_SEQAB)

                              @SetTextOvr(Err_SEQIT)
                              <tr><td  class="dsphdr"><span $(textOvr)>Inventory Type</span></td>
                                  <td class="inputalph"><input name="fromInventoryType" value="$(V_TRIT1)" type="text" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)invtypesearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromInventoryType&amp;fldDesc=finventoryTypeDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="finventoryTypeDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="toInventoryType" value="$(V_TRIT2)" type="text" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)invtypesearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toInventoryType&amp;fldDesc=tinventoryTypeDesc" onclick="$(searchWinVar)">$(searchImage) </a><input name="tinventoryTypeDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="allInventoryType" value='ALL' $(checkedallInventoryType) type="checkbox" onClick="if (this.checked) this.form.fromInventoryType.value='', this.form.toInventoryType.value='';"></td>
                                  @Build_Sort_Select("sortInventoryType", "$(V_SEQIT)")
                                  <td align=center ><input name="breakInventoryType" type="checkbox" $(checkedInventoryTypeBreak) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_SEQIT)

                              @SetTextOvr(Err_SEQPT)
                              <tr><td  class="dsphdr"><span $(textOvr)>Part Type</span></td>
                                  <td class="inputnmbr"><input name="fromPartType" value="$(V_TRPT1)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputnmbr"><input name="toPartType" value="$(V_TRPT2)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="allPartType" value='ALL' $(checkedallPartType) type="checkbox" onClick="if (this.checked) this.form.fromPartType.value='', this.form.toPartType.value='';"></td>
                                  @Build_Sort_Select("sortPartType", "$(V_SEQPT)")
                                  <td align=center ><input name="breakPartType" type="checkbox" $(checkedPartTypeBreak) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_SEQPT)

                              @SetTextOvr(Err_SEQITM)
                              <tr><td  class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_TRITM1)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_TRITM2)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                                  @Build_Sort_Select("sortItemNumber", "$(V_SEQITM)")
                              </tr>
                              @DspErrMsg(Err_SEQITM)

                              @SetTextOvr(Err_SEQWC)
                              <tr><td  class="dsphdr"><span $(textOvr)>Backflush Code</span></td>
                                  <td class="inputalph"><input name="fromBackflushCode" value="$(V_TRWC1)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="toBackflushCode" value="$(V_TRWC2)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="allBackflushCode" value='ALL' $(checkedallBackflushCode) type="checkbox" onClick="if (this.checked) this.form.fromBackflushCode.value='', this.form.toBackflushCode.value='';"></td>
                                  @Build_Sort_Select("sortBackflushCode", "$(V_SEQWC)")
                                  <td align=center ><input name="breakBackflushCode" type="checkbox" $(checkedBackflushCodeBreak) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_SEQWC)

                          </table>

                          @dtw_assign(envProgram, "HSI310")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSI911_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allPlantNumber)
  @dtw_mUPPERCASE(breakPlantNumber)
  @dtw_mUPPERCASE(fromPartClass)
  @dtw_mUPPERCASE(toPartClass)
  @dtw_mUPPERCASE(allPartClass)
  @dtw_mUPPERCASE(breakPartClass)
  @dtw_mUPPERCASE(fromProductClass)
  @dtw_mUPPERCASE(toProductClass)
  @dtw_mUPPERCASE(allProductClass)
  @dtw_mUPPERCASE(breakProductClass)
  @dtw_mUPPERCASE(allBuyerAnalyst)
  @dtw_mUPPERCASE(breakBuyerAnalyst)
  @dtw_mUPPERCASE(fromMaterialCode)
  @dtw_mUPPERCASE(toMaterialCode)
  @dtw_mUPPERCASE(allMaterialCode)
  @dtw_mUPPERCASE(breakMaterialCode)
  @dtw_mUPPERCASE(fromABCCode)
  @dtw_mUPPERCASE(toABCCode)
  @dtw_mUPPERCASE(allABCCode)
  @dtw_mUPPERCASE(breakABCCode)
  @dtw_mUPPERCASE(fromInventoryType)
  @dtw_mUPPERCASE(toInventoryType)
  @dtw_mUPPERCASE(allInventoryType)
  @dtw_mUPPERCASE(breakInventoryType)
  @dtw_mUPPERCASE(fromPartType)
  @dtw_mUPPERCASE(toPartType)
  @dtw_mUPPERCASE(allPartType)
  @dtw_mUPPERCASE(breakPartType)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(fromBackflushCode)
  @dtw_mUPPERCASE(toBackflushCode)
  @dtw_mUPPERCASE(allBackflushCode)
  @dtw_mUPPERCASE(breakBackflushCode)

  @dtw_assign(fromPlantNumber,@dtw_rstrip(fromPlantNumber))
  @dtw_assign(toPlantNumber,@dtw_rstrip(toPlantNumber))
  @dtw_assign(sortPlantNumber,@dtw_rstrip(sortPlantNumber))
  @dtw_assign(sortPartClass,@dtw_rstrip(sortPartClass))
  @dtw_assign(sortProductClass,@dtw_rstrip(sortProductClass))
  @dtw_assign(fromBuyerAnalyst,@dtw_rstrip(fromBuyerAnalyst))
  @dtw_assign(toBuyerAnalyst,@dtw_rstrip(toBuyerAnalyst))
  @dtw_assign(sortBuyerAnalyst,@dtw_rstrip(sortBuyerAnalyst))
  @dtw_assign(sortMaterialCode,@dtw_rstrip(sortMaterialCode))
  @dtw_assign(sortABCCode,@dtw_rstrip(sortABCCode))
  @dtw_assign(sortInventoryType,@dtw_rstrip(sortInventoryType))
  @dtw_assign(sortPartType,@dtw_rstrip(sortPartType))
  @dtw_assign(sortItemNumber,@dtw_rstrip(sortItemNumber))
  @dtw_assign(sortBackflushCode,@dtw_rstrip(sortBackflushCode))

  %if (allPlantNumber != "ALL")
      @dtw_assign(allPlantNumber, "")
  %endif
  %if (allPartClass != "ALL")
      @dtw_assign(allPartClass, "")
  %endif
  %if (allProductClass != "ALL")
      @dtw_assign(allProductClass, "")
  %endif
  %if (allBuyerAnalyst != "ALL")
      @dtw_assign(allBuyerAnalyst, "")
  %endif
  %if (allMaterialCode != "ALL")
      @dtw_assign(allMaterialCode, "")
  %endif
  %if (allABCCode != "ALL")
      @dtw_assign(allABCCode, "")
  %endif
  %if (allInventoryType != "ALL")
      @dtw_assign(allInventoryType, "")
  %endif
  %if (allPartType != "ALL")
      @dtw_assign(allPartType, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allBackflushCode != "ALL")
      @dtw_assign(allBackflushCode, "")
  %endif

  @dtw_assign(breakPlantNumber, "Y")

  %if (breakPartClass != "Y")
      @dtw_assign(breakPartClass, "N")
  %endif
  %if (breakProductClass != "Y")
      @dtw_assign(breakProductClass, "N")
  %endif
  %if (breakBuyerAnalyst != "Y")
      @dtw_assign(breakBuyerAnalyst, "N")
  %endif
  %if (breakMaterialCode != "Y")
      @dtw_assign(breakMaterialCode, "N")
  %endif
  %if (breakABCCode != "Y")
      @dtw_assign(breakABCCode, "N")
  %endif
  %if (breakInventoryType != "Y")
      @dtw_assign(breakInventoryType, "N")
  %endif
  %if (breakPartType != "Y")
      @dtw_assign(breakPartType, "N")
  %endif
  %if (breakItemNumber != "Y")
      @dtw_assign(breakItemNumber, "N")
  %endif
  %if (breakBackflushCode != "Y")
      @dtw_assign(breakBackflushCode, "N")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@um@@", unitOfMeasure)
  @Concat_Field("@@ooq@", onOrderQuantity)
  @Concat_Field("@@noh@", negativeOnHands)
  @Concat_Field("@@zoh@", zeroOnHands)
  @Concat_Field("@@zoo@", zeroOnOrder)
  @Concat_Field("@@ina@", noActivity)
  @Concat_Field("@@pl1@", fromPlantNumber)
  @Concat_Field("@@pl2@", toPlantNumber)
  @Concat_Field("@@apl@", allPlantNumber)
  @Concat_Field("@@spl@", sortPlantNumber)
  @Concat_Field("@@ppl@", breakPlantNumber)
  @Concat_Field("@@ic1@", fromPartClass)
  @Concat_Field("@@ic2@", toPartClass)
  @Concat_Field("@@aic@", allPartClass)
  @Concat_Field("@@sic@", sortPartClass)
  @Concat_Field("@@pic@", breakPartClass)
  @Concat_Field("@@pc1@", fromProductClass)
  @Concat_Field("@@pc2@", toProductClass)
  @Concat_Field("@@apc@", allProductClass)
  @Concat_Field("@@spc@", sortProductClass)
  @Concat_Field("@@ppc@", breakProductClass)
  @Concat_Field("@@bac1", fromBuyerAnalyst)
  @Concat_Field("@@bac2", toBuyerAnalyst)
  @Concat_Field("@@abac", allBuyerAnalyst)
  @Concat_Field("@@sbac", sortBuyerAnalyst)
  @Concat_Field("@@pbac", breakBuyerAnalyst)
  @Concat_Field("@@mc1@", fromMaterialCode)
  @Concat_Field("@@mc2@", toMaterialCode)
  @Concat_Field("@@amc@", allMaterialCode)
  @Concat_Field("@@smc@", sortMaterialCode)
  @Concat_Field("@@pmc@", breakMaterialCode)
  @Concat_Field("@@ab1@", fromABCCode)
  @Concat_Field("@@ab2@", toABCCode)
  @Concat_Field("@@aab@", allABCCode)
  @Concat_Field("@@sab@", sortABCCode)
  @Concat_Field("@@pab@", breakABCCode)
  @Concat_Field("@@it1@", fromInventoryType)
  @Concat_Field("@@it2@", toInventoryType)
  @Concat_Field("@@ait@", allInventoryType)
  @Concat_Field("@@sit@", sortInventoryType)
  @Concat_Field("@@pit@", breakInventoryType)
  @Concat_Field("@@pt1@", fromPartType)
  @Concat_Field("@@pt2@", toPartType)
  @Concat_Field("@@apt@", allPartType)
  @Concat_Field("@@spt@", sortPartType)
  @Concat_Field("@@ppt@", breakPartType)
  @Concat_Field("@@itm1", fromItemNumber)
  @Concat_Field("@@itm2", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@sitm", sortItemNumber)
  @Concat_Field("@@wc1@", fromBackflushCode)
  @Concat_Field("@@wc2@", toBackflushCode)
  @Concat_Field("@@awc@", allBackflushCode)
  @Concat_Field("@@swc@", sortBackflushCode)
  @Concat_Field("@@pwc@", breakBackflushCode)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}