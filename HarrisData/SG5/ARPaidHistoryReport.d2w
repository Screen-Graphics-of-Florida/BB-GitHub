%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "A/R Paid History Report"
  d2wName                 = "ARPaidHistoryReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "5"
  V_CRPRMC                = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  %if (V_HDMCRL > "0")
      @RtvFldDesc("CRPRMC>' '", "ARCTRL", "CRPRMC", V_CRPRMC)
  %endif
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {

                  if (editNum(document.Chg.fromLocationNumber, 3, 0) &&
                      editNum(document.Chg.toLocationNumber, 3, 0) &&
                      editNum(document.Chg.fromCustomerNumber, 7, 0) &&
                      editNum(document.Chg.toCustomerNumber, 7, 0) &&
                      editNum(document.Chg.fromSalesmanNumber, 3, 0) &&
                      editNum(document.Chg.toSalesmanNumber, 3, 0) &&
                      editdate(document.Chg.fromDatePaid) &&
                      editdate(document.Chg.toDatePaid) &&
                      editFromToAll(document.Chg.fromLocationNumber, document.Chg.toLocationNumber, document.Chg.allLocationNumber, 3) &&
                      editFromToAll(document.Chg.fromCustomerNumber, document.Chg.toCustomerNumber, document.Chg.allCustomerNumber, 7) &&
                      editFromToAll(document.Chg.fromSalesmanNumber, document.Chg.toSalesmanNumber, document.Chg.allSalesmanNumber, 3) &&
                      editFromToAll(document.Chg.fromPaymentCodes, document.Chg.toPaymentCodes, document.Chg.allPaymentCodes, "A") &&
                      editFromToAll(document.Chg.fromDatePaid, document.Chg.toDatePaid, document.Chg.allDatePaid, "D")
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PAIDHISTORYREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromLocationNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@sloc", "sortLocationNumber")        @dtw_assign(Err_SLOC#,  fieldValue)
                                  @DecatErr_Field("@@scus", "sortCustomerNumber")        @dtw_assign(Err_SCUST,  fieldValue)
                                  @DecatErr_Field("@@ssls", "sortSalesmanNumber")          @dtw_assign(Err_SSLS,  fieldValue)
                                  @DecatErr_Field("@@spcd", "sortPaymentCodes")        @dtw_assign(Err_SPCDE,  fieldValue)
                                  @DecatErr_Field("@@sdtp", "sortDatePaid")        @dtw_assign(Err_SPDTE,  fieldValue)
                                  %if (V_CRPRMC == "Y")
                                      @DecatErr_Field("@@idcr", "currencyID") @dtw_assign(Err_IDCR,  fieldValue)
                                      @DecatErr_Field("@@curt", "currencyType") @dtw_assign(Err_CURT,  fieldValue)
                                  %endif
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@floc")  @dtw_assign(V_FLOC#,  fieldValue)
                                  @Decat_Field("@@tloc")  @dtw_assign(V_TLOC#,  fieldValue)
                                  @Decat_Field("@@aloc")  @dtw_assign(V_ALOC#,  fieldValue)
                                  @Decat_Field("@@sloc")  @dtw_assign(V_SLOC#,  fieldValue)
                                  @Decat_Field("@@ploc")  @dtw_assign(V_PLOC#,  fieldValue)
                                  @Decat_Field("@@fcus")  @dtw_assign(V_FCUST,  fieldValue)
                                  @Decat_Field("@@tcus")  @dtw_assign(V_TCUST,  fieldValue)
                                  @Decat_Field("@@acus")  @dtw_assign(V_ACUST,  fieldValue)
                                  @Decat_Field("@@scus")  @dtw_assign(V_SCUST,  fieldValue)
                                  @Decat_Field("@@pcus")  @dtw_assign(V_PCUST,  fieldValue)
                                  @Decat_Field("@@fslm")  @dtw_assign(V_FSLS,  fieldValue)
                                  @Decat_Field("@@tslm")  @dtw_assign(V_TSLS,  fieldValue)
                                  @Decat_Field("@@aslm")  @dtw_assign(V_ASLS,  fieldValue)
                                  @Decat_Field("@@sslm")  @dtw_assign(V_SSLS,  fieldValue)
                                  @Decat_Field("@@pslm")  @dtw_assign(V_PSLS,  fieldValue)
                                  @Decat_Field("@@fpcd")  @dtw_assign(V_FPCDE,  fieldValue)
                                  @Decat_Field("@@tpcd")  @dtw_assign(V_TPCDE,  fieldValue)
                                  @Decat_Field("@@apcd")  @dtw_assign(V_APCDE,  fieldValue)
                                  @Decat_Field("@@spcd")  @dtw_assign(V_SPCDE,  fieldValue)
                                  @Decat_Field("@@ppcd")  @dtw_assign(V_PPCDE,  fieldValue)
                                  @Decat_Field("@@fdtp")  @dtw_assign(V_FPDTE,  fieldValue)
                                  @Decat_Field("@@tdtp")  @dtw_assign(V_TPDTE,  fieldValue)
                                  @Decat_Field("@@adtp")  @dtw_assign(V_APDTE,  fieldValue)
                                  @Decat_Field("@@sdtp")  @dtw_assign(V_SPDTE,  fieldValue)
                                  @Decat_Field("@@pdtp")  @dtw_assign(V_PPDTE,  fieldValue)
                                  %if (V_CRPRMC == "Y")
                                      @Decat_Field("@@idcr")  @dtw_assign(V_IDCR,  fieldValue)
                                      @Decat_Field("@@curt")  @dtw_assign(V_CURT,  fieldValue)
                                  %endif
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_ALOC# == "ALL")
                                      @dtw_assign(checkedAllLocationNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllLocationNumber, "")
                                  %endif
                                  %if (V_ACUST == "ALL")
                                      @dtw_assign(checkedAllCustomerNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllCustomerNumber, "")
                                  %endif
                                  %if (V_ASLS == "ALL")
                                      @dtw_assign(checkedAllSalesmanNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllSalesmanNumber, "")
                                  %endif
                                  %if (V_APCDE == "ALL")
                                      @dtw_assign(checkedAllPaymentCodes, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllPaymentCodes, "")
                                  %endif
                                  %if (V_APDTE == "ALL")
                                      @dtw_assign(checkedAllDatePaid, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllDatePaid, "")
                                  %endif
                                  %if (V_PLOC# == "Y")
                                      @dtw_assign(checkedLocationNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedLocationNumberTotals, "")
                                  %endif
                                  %if (V_PCUST == "Y")
                                      @dtw_assign(checkedCustomerNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedCustomerNumberTotals, "")
                                  %endif
                                  %if (V_PSLS == "Y")
                                      @dtw_assign(checkedSalesmanNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedSalesmanNumberTotals, "")
                                  %endif
                                  %if (V_PPCDE == "Y")
                                      @dtw_assign(checkedPaymentCodesTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedPaymentCodesTotals, "")
                                  %endif
                                  %if (V_PPDTE == "Y")
                                      @dtw_assign(checkedDatePaidTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedDatePaidTotals, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedAllLocationNumber, "CHECKED")
                                  @dtw_assign(checkedAllCustomerNumber, "CHECKED")
                                  @dtw_assign(checkedAllSalesmanNumber, "CHECKED")
                                  @dtw_assign(checkedAllPaymentCodes, "CHECKED")
                                  @dtw_assign(checkedAllDatePaid, "CHECKED")
                                  %if (V_CRPRMC == "Y")
                                      @dtw_assign(V_IDCR, "I")
                                      @dtw_assign(currencyType, "")
                                  %endif
                              %endif

                          <td><input type="hidden" name="multiCurrency" value="$(V_CRPRMC)"></td>

                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                                  <td class="colhdr">Print<br>Totals</td>
                              </tr>

                              @SetTextOvr(Err_FLOC#)
                              %if (textOvr == "") @SetTextOvr(Err_SLOC#) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Location Number</span></td>
                                  <td class="inputnmbr"><input name="fromLocationNumber" value="$(V_FLOC#)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(cGIPath)LocationSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromLocationNumber&amp;fldDesc=flocDesc" onclick="$(searchWinVar)">$(searchImage) </a> <input name="flocDesc" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toLocationNumber" value="$(V_TLOC#)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(cGIPath)LocationSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toLocationNumber&amp;fldDesc=tlocDesc" onclick="$(searchWinVar)">$(searchImage) </a> <input name="tlocDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allLocationNumber" value='ALL' $(checkedAllLocationNumber) type="checkbox" onClick="if (this.checked) this.form.fromLocationNumber.value='', this.form.toLocationNumber.value='';"></td>
                                  @Build_Sort_Select("sortLocationNumber", "$(V_SLOC#)")
                                  <td align=center ><input name="totalLocationNumber" type="checkbox" $(checkedLocationNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_SLOC#)

                              @SetTextOvr(Err_FCUST)
                              %if (textOvr == "") @SetTextOvr(Err_SCUST) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Customer Number</span></td>
                                  <td class="inputnmbr"><input name="fromCustomerNumber" value="$(V_FCUST)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)customersearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromCustomerNumber&amp;fldDesc=fcusName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="fcusName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toCustomerNumber" value="$(V_TCUST)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)customersearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toCustomerNumber&amp;fldDesc=tcusName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="tcusName" type="hidden"></td>
                                  <td class="inputalph"><input name="allCustomerNumber" value='ALL' $(checkedAllCustomerNumber) type="checkbox" onClick="if (this.checked) this.form.fromCustomerNumber.value='', this.form.toCustomerNumber.value='';"></td>
                                  @Build_Sort_Select("sortCustomerNumber", "$(V_SCUST)")
                                  <td align=center ><input name="totalCustomerNumber" type="checkbox" $(checkedCustomerNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_SCUST)

                              @SetTextOvr(Err_FSLS)
                              %if (textOvr == "") @SetTextOvr(Err_SSLS) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Salesman Number</span></td>
                                  <td class="inputnmbr"><input name="fromSalesmanNumber" value="$(V_FSLS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(cGIPath)SalesmanSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromSalesmanNumber&amp;fldDesc=salesmanName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="salesmanName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toSalesmanNumber" value="$(V_TSLS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(cGIPath)SalesmanSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toSalesmanNumber&amp;fldDesc=salesmanName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="salesmanName" type="hidden"></td>
                                  <td class="inputalph"><input name="allSalesmanNumber" value='ALL' $(checkedAllSalesmanNumber) type="checkbox" onClick="if (this.checked) this.form.fromSalesmanNumber.value='', this.form.toSalesmanNumber.value='';"></td>
                                   @Build_Sort_Select("sortSalesmanNumber", "$(V_SSLS)")
                                  <td align=center ><input name="totalSalesmanNumber" type="checkbox" $(checkedSalesmanNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_SSLS)

                              @SetTextOvr(Err_FPCDE)
                              %if (textOvr == "") @SetTextOvr(Err_SPCDE) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Payment Codes</td>
                                  <td class="inputalph"><input name="fromPaymentCodes" value="$(V_FPCDE)" type="text" size="1" maxlength="1"><a href="$(homeURL)$(cGIPath)ARPaymentCodeSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromPaymentCodes&amp;fldDesc=fDesc" onclick="$(searchWinVar)">$(searchImage) </a> <input name="fDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="toPaymentCodes" value="$(V_TPCDE)" type="text" size="1" maxlength="1"><a href="$(homeURL)$(cGIPath)ARPaymentCodeSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toPaymentCodes&amp;fldDesc=tDesc" onclick="$(searchWinVar)">$(searchImage) </a> <input name="tDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allPaymentCodes" value='ALL' $(checkedAllPaymentCodes) type="checkbox" onClick="if (this.checked) this.form.fromPaymentCodes.value='', this.form.toPaymentCodes.value='';"></td>
                                  @Build_Sort_Select("sortPaymentCodes", "$(V_SPCDE)")
                                  <td align=center ><input name="totalPaymentCodes" type="checkbox" $(checkedPaymentCodesTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_SPCDE)

                              @SetTextOvr(Err_FPDTE)
                              %if (textOvr == "") @SetTextOvr(Err_SPDTE) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Date Paid</span></td>
                                  <td class="inputnmbr"><input name="fromDatePaid" value="$(V_FPDTE)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromDatePaid');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toDatePaid" value="$(V_TPDTE)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toDatePaid');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allDatePaid" value='ALL' $(checkedAllDatePaid) type="checkbox" onClick="if (this.checked) this.form.fromDatePaid.value='', this.form.toDatePaid.value='';"></td>
                                  @Build_Sort_Select("sortDatePaid", "$(V_SPDTE)")
                                  <td align=center ><input name="totalDatePaid" type="checkbox" $(checkedDatePaidTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_SPDTE)

                              %if (V_CRPRMC == "Y")
                                  @SetTextOvr(Err_IDCR )
                                  <tr><td class="dsphdr"><span $(textOvr)>Invoice/Domestic Currency (I,D)</span></td>
                                         <td class="inputalph"><input name="currencyID" value="$(V_IDCR)" type="text" size="1" maxlength="1"></td>
                                  </tr>
                                  @DspErrMsg(Err_IDCR)

                                  <tr><td class="dsphdr">--OR--</td></tr>

                                  @SetTextOvr(Err_CURT)
                                     <tr><td class="dsphdr"><span $(textOvr)>Convert To Currency Type</span></td>
                                         <td class="inputalph"><input name="currencyType" value="$(V_CURT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(cGIPath)CurrencyTypeSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=currencyType&amp;fldDesc=currencyTypeDesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input name="currencyTypeDesc" type="hidden"></td>
                                  </tr>
                                  @DspErrMsg(Err_CURT)
                              %endif
                          </table>

                          @dtw_assign(envProgram, "HARPHY")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HARSPH_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {

  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allLocationNumber)
  @dtw_mUPPERCASE(allCustomerNumber)
  @dtw_mUPPERCASE(allSalesmanNumber)
  @dtw_mUPPERCASE(fromPaymentCodes)
  @dtw_mUPPERCASE(toPaymentCodes)
  @dtw_mUPPERCASE(allPaymentCodes)
  @dtw_mUPPERCASE(allDatePaid)
  @dtw_mUPPERCASE(currencyID)
  @dtw_mUPPERCASE(currencyType)

  @dtw_assign(fromLocationNumber,@dtw_rstrip(fromLocationNumber))
  @dtw_assign(toLocationNumber,@dtw_rstrip(toLocationNumber))
  @dtw_assign(sortLocationNumber,@dtw_rstrip(sortLocationNumber))
  @dtw_assign(fromCustomerNumber,@dtw_rstrip(fromCustomerNumber))
  @dtw_assign(toCustomerNumber,@dtw_rstrip(toCustomerNumber))
  @dtw_assign(sortCustomerNumber,@dtw_rstrip(sortCustomerNumber))
  @dtw_assign(fromSalesmanNumber,@dtw_rstrip(fromSalesmanNumber))
  @dtw_assign(toSalesmanNumber,@dtw_rstrip(toSalesmanNumber))
  @dtw_assign(sortSalesmanNumber,@dtw_rstrip(sortSalesmanNumber))
  @dtw_assign(sortPaymentCodes,@dtw_rstrip(sortPaymentCodes))
  @dtw_assign(fromDatePaid,@dtw_rstrip(fromDatePaid))
  @dtw_assign(toDatePaid,@dtw_rstrip(toDatePaid))
  @dtw_assign(sortDatePaid,@dtw_rstrip(sortDatePaid))

  %if (allLocationNumber != "ALL")
      @dtw_assign(allLocationNumber, "")
  %endif
  %if (allCustomerNumber != "ALL")
      @dtw_assign(allCustomerNumber, "")
  %endif
  %if (allSalesmanNumber != "ALL")
      @dtw_assign(allSalesmanNumber, "")
  %endif
  %if (allPaymentCodes != "ALL")
      @dtw_assign(allPaymentCodes, "")
  %endif
  %if (allDatePaid != "ALL")
      @dtw_assign(allDatePaid, "")
  %endif

  %if (totalLocationNumber != "Y")
      @dtw_assign(totalLocationNumber, "N")
  %endif
  %if (totalCustomerNumber != "Y")
      @dtw_assign(totalCustomerNumber, "N")
  %endif
  %if (totalSalesmanNumber != "Y")
      @dtw_assign(totalSalesmanNumber, "N")
  %endif
  %if (totalPaymentCodes != "Y")
      @dtw_assign(totalPaymentCodes, "N")
  %endif
  %if (totalDatePaid != "Y")
      @dtw_assign(totalDatePaid, "N")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@mult", multiCurrency)
  @Concat_Field("@@floc", fromLocationNumber)
  @Concat_Field("@@tloc", toLocationNumber)
  @Concat_Field("@@aloc", allLocationNumber)
  @Concat_Field("@@sloc", sortLocationNumber)
  @Concat_Field("@@ploc", totalLocationNumber)
  @Concat_Field("@@fcus", fromCustomerNumber)
  @Concat_Field("@@tcus", toCustomerNumber)
  @Concat_Field("@@acus", allCustomerNumber)
  @Concat_Field("@@scus", sortCustomerNumber)
  @Concat_Field("@@pcus", totalCustomerNumber)
  @Concat_Field("@@fslm", fromSalesmanNumber)
  @Concat_Field("@@tslm", toSalesmanNumber)
  @Concat_Field("@@aslm", allSalesmanNumber)
  @Concat_Field("@@sslm", sortSalesmanNumber)
  @Concat_Field("@@pslm", totalSalesmanNumber)
  @Concat_Field("@@fpcd", fromPaymentCodes)
  @Concat_Field("@@tpcd", toPaymentCodes)
  @Concat_Field("@@apcd", allPaymentCodes)
  @Concat_Field("@@spcd", sortPaymentCodes)
  @Concat_Field("@@ppcd", totalPaymentCodes)
  @Concat_Field("@@fdtp", fromDatePaid)
  @Concat_Field("@@tdtp", toDatePaid)
  @Concat_Field("@@adtp", allDatePaid)
  @Concat_Field("@@sdtp", sortDatePaid)
  @Concat_Field("@@pdtp", totalDatePaid)
  %if (multiCurrency == "Y")
      @Concat_Field("@@idcr", currencyID)
      @Concat_Field("@@curt", currencyType)
  %endif


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}