%INCLUDE "$(baseVar)"
%INCLUDE "BrowserType.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "ETControl$(dataBaseID).icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Employee Shift On/Off"
  d2wName                 = "EmployeeShiftOnOff.d2w"
  d2wVarBase              = "$(genericVarBase)$(employeeVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName             = "HETQTE"  
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
  headerTable             = %table
  detailTable             = %table
  print                   = "Y"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
%}

%FUNCTION(DTW_directcall) accept_FIELDS (INOUT CHAR(64)    profileHandle,
                                               CHAR(2)     dataBaseID,
                                               DEC(2,0)    prCompany,
                                               DEC(4,0)    prFacility,
                                               DEC(5,0)    prEmployee,
                                               CHAR(6)     inputtime,
                                               CHAR(6)     inputdate,
                                               char(75)    error,
                                               char(75)    confirmationMessage)
{%EXEC {HETQTE_W.PGM %}
%}

%MACRO_FUNCTION SHIFT () {

  %REPORT{
      %INCLUDE "EmplUV.icl"
      %if (userPass == "N")
          %INCLUDE "userViewError.icl"
      %else
          %INCLUDE "$(docType)"
          <html>
              <head>
    	       %INCLUDE "$(headInclude)"
                  <script TYPE="text/javascript">
                      %INCLUDE "Menu.js"
                      %INCLUDE "numedit.icl"
                      %INCLUDE "NewWindowOpen.icl"
                  </script>
                  %INCLUDE "$(genericHead)"
              </head>
              <body $(bodyTagAttr)>
                  <!-- Start Of Banner Code -->
                  %INCLUDE "banner.icl"
                  <!-- End Of Banner Code -->
                  <table $(baseTable)>
                      <tr valign="top">
                          @dtw_assign(pageID, "EMPLOYEESHIFTONOFF")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                          <td class="content">
                              <table $(contentTable)>
                                  <colgroup>
                                      <col width="80%">
                                      <col width="15%">
                                  <tr><td><h1>$(page_title)</h1></td></tr>

                                  @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
                                  <tr><td><h2>$(F_EmpName)</h2></td></tr>
                              </table>
                              %INCLUDE "ConfMessageDisplay.icl"
                              $(hrTagAttr)
                              
                              @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                              <table $(contentTable)>
                                  <form class="formClass" METHOD=POST onSubmit="return (editNum(date, 6, 0) &&
                                                                                        editNum(time, 6, 0)
                                                                                       )"
                                  ACTION="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)&amp;time=@dtw_rurlescseq(time)&amp;date=@dtw_rurlescseq(date)">
                                  %If (resetTime == "N")
                                      <tr><td class="dsphdr">Date:</td>
                                          <td class="dspdate">$(date) &nbsp; &nbsp; </td>
                                          <td class="dsphdr">Time:</td>
                                          <td class="dspnmbr">$(time)</td>
                                      </tr>
                                  %else
                                      <tr><td class="dsphdr">Date:</td>
                                          <td class="inputnmbr"><input type="text" name="date" value="$(date6)" size="8" maxlength="8">&nbsp;</td>
                                          <td class="dsphdr">Time:</td>
                                          <td class="inputnmbr"><input type="text" name="time" value="$(time6)" size="8" maxlength="8"></td>
                                      </tr>
                                  %endif
                              </table>
                	
                              <table $(contentTable)>
                                  <tr><td><input TYPE=SUBMIT VALUE="Accept"></td>
                     </form>

                                      %if (V_TAALRT == "Y" && resetTime == "N" && sec_02 == "Y")
                                          <td><form class="formClass" METHOD=POST ACTION="$(homeURL)$(cGIPath)$(d2wName)/RESETTIME$(d2wVarBase)&amp;resetTime=@dtw_rurlescseq(resetTime)&amp;time=@dtw_rurlescseq(time)&amp;date=@dtw_rurlescseq(date)">
                                                  <input TYPE=SUBMIT VALUE="Reset Time">
                                              </form>
                                          </td>
                                      %endif
                                      <td><form class="formClass" METHOD=POST ACTION="$(homeURL)$(cGIPath)$(d2wName)/CANCEL$(d2wVarBase)">
                                              <input TYPE=SUBMIT VALUE="Cancel">
                                          </form>
                                      </td>
                                  </tr>
                              </table>
                              $(hrTagAttr)
                              %INCLUDE "Copyright.icl"
                          </td>
                      </tr>
                  </table>
                  <!-- Start Of Trailer Code -->
                  %INCLUDE "trailer.icl"
                  <!-- End Of Trailer Code -->
              </body>
          </html>
      %endif
  %}
%}

%HTML(EMPLOYEE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(applicationID, "")
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      @DTW_ASSIGN(resetTime, "N")
      @DTW_TIME(time)
      @DTW_DATE("U", date)
      @SHIFT ()
  %endif
%}

%HTML(RESETTIME) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(resetTime, "Y")
  @DTW_ASSIGN(date6, $(date))
  @DTW_ASSIGN(time6, $(time))
  @DTW_ASSIGN(date, "")
  @DTW_ASSIGN(time, "")
  @SHIFT ()
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(inputtime, $(time))
  @DTW_DELSTR(inputtime, "3", "1", inputtime)
  @DTW_DELSTR(inputtime, "5", "1", inputtime)
  @DTW_ASSIGN(inputdate, $(date))
  @DTW_DELSTR(inputdate, "3", "1", inputdate)
  @DTW_DELSTR(inputdate, "5", "1", inputdate)

  @accept_FIELDS (profileHandle, dataBaseID, prCompany, prFacility, prEmployee, inputtime, inputdate, error, confirmationMessage)

  %if (error == "")
      @DTW_ASSIGN(confMessage, $(confirmationMessage))
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(backHome)$(genericVarBase)&amp;prCompany=@dtw_rurlescseq(prCompany)&amp;prFacility=@dtw_rurlescseq(prFacility)&amp;prEmployee=@dtw_rurlescseq(prEmployee)&amp;hrCompany=@dtw_rurlescseq(hrCompany)&amp;hrEmployee=@dtw_rurlescseq(hrEmployee)&amp;confMessage=@dtw_rurlescseq(confMessage)&amp;backHome=@dtw_rurlescseq(backHome)">
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              %INCLUDE "$(genericHead)"
          </head>

          <table $(contentTable)>
              <colgroup>
              <col width="80%">
              <col width="15%">
              <tr><td><h1> $(page_title)</h1></td></tr>
          </table>

          <body $(bodyTagAttr)>
              @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
              <h2>Editing data for: $(F_EmpName) </h2>
              Errors Found on entry: <div class="error"> $(error). </div>
              Press Back to reenter.
          </body>
      </html>
  %endif
%}

%HTML(CANCEL) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(confMessage, "Confirm Cancel Of Shift On/Off")
  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(backHome)$(genericVarBase)&amp;prCompany=@dtw_rurlescseq(prCompany)&amp;prFacility=@dtw_rurlescseq(prFacility)&amp;prEmployee=@dtw_rurlescseq(prEmployee)&amp;hrCompany=@dtw_rurlescseq(hrCompany)&amp;hrEmployee=@dtw_rurlescseq(hrEmployee)&amp;confMessage=@dtw_rurlescseq(confMessage)&amp;backHome=@dtw_rurlescseq(backHome)">
%}