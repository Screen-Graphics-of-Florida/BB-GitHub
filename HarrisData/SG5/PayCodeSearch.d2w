%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "WildCardAcct.icl"

%Define {	
  page_title              = "Pay Code Search"
  d2wName                 = "PayCodeSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldCo=@dtw_rurlescseq(fldCo)&amp;fldFac=@dtw_rurlescseq(fldFac)&amp;fldPayCd=@dtw_rurlescseq(fldPayCd)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldCo                   = ""
  fldFac                  = ""
  fldPayCd                = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function selectPayCode(companyNumber, facilityNumber, payCode, desc){
                      window.opener.document.$(docName).$(fldCo).value = companyNumber;
                      window.opener.document.$(docName).$(fldFac).value = facilityNumber;
                      window.opener.document.$(docName).$(fldPayCd).value = payCode;
                      window.opener.document.$(docName).$(fldDesc).value = desc;
                      window.opener.document.$(docName).$(fldPayCd).focus();
                      window.close();
                  }
    	           %INCLUDE "NumEdit.icl"
                  %INCLUDE "CheckEnterSearch.icl"
                  function validate(searchForm) {
                      if (editNum(document.Search.srchCo, 2, 0) &&
                          editNum(document.Search.srchFac, 4, 0))
                          return true;
                  }
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "$(searchBanner)"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      <td class="content">
                          @dtw_assign(uv_CompanyName, "C2COMP")
                          @dtw_assign(uv_FacilityName, "C2FACL")
                          %INCLUDE "userview.icl"

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select PRCODE.*, ", stmtSQL)
                          @dtw_concat(stmtSQL, " upper(C2DESC) as C2DESCU  ", stmtSQL)
                          @dtw_concat(fileSQL, " PRCODE ", fileSQL)
                          %if (moreInfo == "Y")
                              @dtw_concat(selectSQL, " C2COMP=$(companyNumber) and C2FACL=$(facilityNumber) and C2CODE='$(payCode)' ", selectSQL)
                          %elseif (wildCardSearch!="" || uv_Sql!="")
                              @dtw_concat(selectSQL, " C2COMP<>0", selectSQL)
                          %endif
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Process_Search(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "$(searchTrailer)"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}
%FUNCTION(dtw_sql) Process_Search (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Description</th>
                      <th class="colhdr">Co/Fac</th>
                      <th class="colhdr">Pay<br>Code</th>
                  </tr>
                  <tr>
                      <td class="inputalph">
                          <input type="text" name="srchDesc" size="30" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td class="inputnmbr"><input name="srchCo" type="text" size="2" maxlength="2"> / <input name="srchFac" type="text" size="4" maxlength="4">
                          <input type="hidden" name="operCo" value="=">
                          <input type="hidden" name="operFac" value="=">
                      </td>
                      <td class="inputalph">
                          <input type="text" name="srchPayCode" size="3" maxlength="3">
                          <input type="hidden" name="operPayCode" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>
	
          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("C2COMP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CoFac" title="Sequence By Company/Facility, Pay Code"> Co/Fac</a></th>
                  @OrderBy_Sort("C2CODE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PayCode" title="Sequence By Pay Code, Company/Facility">Pay<br>Code</a></th>
                  @OrderBy_Sort("C2DESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description, Company/Facility, Pay Code">Description</a></th>
                  @OrderBy_Sort("C2HRCD", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=HoursUnit" title="Sequence By Hours/Units, Company/Facility, Pay Code">Hours/<br>Units</a></th>
                  @OrderBy_Sort("C2STRT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=StartDate" title="Sequence By Start Date, Company/Facility, Pay Code"> Start<br>Date</a></th>
                  @OrderBy_Sort("C2END", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=EndDate" title="Sequence By End Date, Company/Facility, Pay Code">End<br>Date</a></th>
                  @OrderBy_Sort("C2ACCT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Account" title="Sequence By Account, Company/Facility, Pay Code">Account</a></th>
                  @OrderBy_Sort("C2SMTY", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SummaryType" title="Sequence By Summary Type, Company/Facility, Pay Code">Summary<br>Type</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %endif		

              %ROW{
                  @Default_Zero(V_C2COMP)
                  @Default_Zero(V_C2FACL)
                  @Format_CoFac("$(V_C2COMP)", "$(V_C2FACL)", "", F_CoFac)
                  @Default_Zero(V_C2ACCT)
                  @Default_Zero(V_C2SUB)
                  @Format_Acct("$(V_C2ACCT)", "$(V_C2SUB)", "", F_AcctSub)
                  @Format_Date(V_C2STRT, "D", F_C2STRT)
                  @Format_Date(V_C2END, "D", F_C2END)
                  @Format_Quote(V_C2CODE, F_C2CODE)
                  @Format_Quote(V_C2DESC, F_C2DESC)

    	           %if (moreInfo != "Y")	
                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          <td class="colnmbr">$(F_CoFac)</td>
                          <td class="colalph">$(V_C2CODE)</td>
                          <td class="colalph"><a href="javascript:selectPayCode($(V_C2COMP),$(V_C2FACL),'$(F_C2CODE)','$(F_C2DESC)')" title="Select Pay Code">$(V_C2DESC)</a></td>
                          <td class="colcode">$(V_C2HRCD)</td>
                          <td class="coldate">$(F_C2STRT)</td>
                          <td class="coldate">$(F_C2END)</td>
                          <td class="colnmbr">$(F_AcctSub)</td>
                          <td class="colcode">$(V_C2SMTY)</td>
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;companyNumber=@dtw_rurlescseq(V_C2COMP)&amp;facilityNumber=@dtw_rurlescseq(V_C2FACL)&amp;payCode=@dtw_rurlescseq(V_C2CODE)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                      </tr>

                  %else
                      %{ More Information Screen %}

                      <table $(contentTable)>
                          <tr><td><a href="javascript:selectPayCode($(V_C2COMP),$(V_C2FACL),'$(F_C2CODE)','$(F_C2DESC)')" title="Select Pay Code">$(selectImageLrg)</a>
                          </td></tr>
                      </table>

                      <a name="top"></a>
                      <table $(contentTable)>
                          <tr><td><a href="#processVariables">Processing Variables</a></td></tr>
                          <tr><td><a href="#employeeDefaults">Employee Defaults</a></td></tr>
                          <tr><td>&nbsp;</td></tr>
                      </table>

                      <table $(contentTable)>
                          <tr><td><a href="#top">$(topOfFormImage)</a></td></tr>
                      </table>

                      <a name="processVariables"></a>
                      <fieldset class="legendBody">
                          <legend class="legendTitle">Processing Variables</legend>
                          <table $(contentTable)>
                              %if (V_HDPRRL>"0")
                                  @RtvFldDesc("CFCOMP=$(V_C2COMP) and CFFACL=$(V_C2FACL) ", "HRCOFC", "CFNAME", V_CFCFNM)
                              %else
                                  @RtvFldDesc("CFCO#=$(V_C2COMP) and CFFAC#=$(V_C2FACL) ", "HDCFAC", "CFCFNM", V_CFCFNM)
                              %endif
                              <tr><td class="dsphdr">Company/Facility</td>
                                  <td class="dspalph">$(F_CoFac)</td>
                                  <td class="dspalph">$(V_CFCFNM)</td>
                              </tr>
            	   		
                              <tr><td class="dsphdr">Pay Code</td>
                                  <td class="dspalph">$(V_C2CODE)</td>
                              </tr>
            	   		
                              <tr><td class="dsphdr">Description</td>
                                  <td class="dspalph">$(V_C2DESC)</td>
                              </tr>

                              <tr><td class="dsphdr">Report Heading</td>
                                  <td class="dspalph">$(V_C2RPHD)</td>
                              </tr>

                              @RtvFldDesc("SUMCOD='$(V_C2SMTY)' ", "PRSUMT", "SUMDSC", V_SUMDSC)
                              <tr><td class="dsphdr">Summary Pay Type</td>
                                  <td class="dspalph">$(V_C2SMTY)</td>
                                  <td class="dspalph">$(V_SUMDSC)</td>
                              </tr>

                              <tr><td class="dsphdr">Hours Or Units</td>
                                  <td class="dspalph">$(V_C2HRCD)</td>
                              </tr>

                              <tr><td class="dsphdr">Apply Shift Premium</td>
                                  <td class="dspalph">$(V_C2PREM)</td>
                              </tr>

                              <tr><td class="dsphdr">Take Deductions</td>
                                  <td class="dspalph">$(V_C2DED)</td>
                              </tr>

                              <tr><td class="dsphdr">Include In Vacation/Sick Accruals</td>
                                  <td class="dspalph">$(V_C2ACCR)</td>
                              </tr>

                              <tr><td class="dsphdr">Include In Overtime</td>
                                  <td class="dspalph">$(V_C2IOTC)</td>
                              </tr>

                              <tr><td class="dsphdr">Process Distibution Tables</td>
                                  <td class="dspalph">$(V_C2WGDS)</td>
                              </tr>

                              <tr><td class="dsphdr">Process Salary Distribution</td>
                                  <td class="dspalph">$(V_C2SLDS)</td>
                              </tr>

                              <tr><td class="dsphdr">Processing Sequence</td>
                                  <td class="dspnmbr">$(V_C2SEQ)</td>
                              </tr>

                              @RtvFldDesc("CHACCT=$(V_C2ACCT) and CHSUB=$(V_C2SUB) ", "HDCHRT", "CHCHDS", V_CHCHDS)
                              <tr><td class="dsphdr">G/L Account</td>
                                  <td class="dspalph">$(F_AcctSub)</td>
                                  <td class="dspalph">$(V_CHCHDS)</td>
                              </tr>

                              <tr><td class="dsphdr">Unpaid Hours/Units</td>
                                  <td class="dspalph">$(V_C2NOPY)</td>
                              </tr>

                              <tr><td class="dsphdr">Worked Hours</td>
                                  <td class="dspalph">$(V_C2RPHR)</td>
                              </tr>

                              <tr><td class="dsphdr">Attendance Exception</td>
                                  <td class="dspalph">$(V_C2ATCD)</td>
                              </tr>
                          </table>
                      </fieldset>

                      <table $(contentTable)>
                          <tr><td><a href="#top">$(topOfFormImage)</a></td></tr>
                      </table>

                      <a name="employeeDefaults"></a>
                      <fieldset class="legendBody">
                          <legend class="legendTitle">Employee Defaults</legend>
                          <table $(contentTable)>

                              <tr><td class="dsphdr">Hours/Units/Earnings</td>
                                  <td class="dspnmbr">$(V_C2HRS)</td>
                              </tr>

                              @RtvFldDesc("EADEPT='$(V_C2DEPT)' ", "PREXAC", "EANAME", deptName)
                              <tr><td class="dsphdr">Department Worked</td>
                                  <td class="dspalph">$(V_C2DEPT)</td>
                                  <td class="dspalph">$(deptName)</td>
                              </tr>

                              <tr><td class="dsphdr">Override Rate</td>
                                  <td class="dspnmbr">$(V_C2OVRT)</td>
                              </tr>

                              @RtvFldDesc("PPCOMP=$(V_C2COMP) and PPFACL=$(V_C2FACL) and PPDEPT='$(V_C2DEPT)' and PPSHFT='$(V_C2SHFW) ", "PRPREM", "PPDESC", V_PPDESC)
                              %if (V_PPDESC=="")
                                  @RtvFldDesc("PPCOMP=$(V_C2COMP) and PPFACL=$(V_C2FACL) and PPDEPT=' ' and PPSHFT='$(V_C2SHFW) ", "PRPREM", "PPDESC", V_PPDESC)
                              %endif
                              <tr><td class="dsphdr">Shift Worked</td>
                                  <td class="dspalph">$(V_C2SHFW)</td>
                                  <td class="dspalph">$(V_PPDESC)</td>
                              </tr>

                              <tr><td class="dsphdr">Job Number</td>
                                  <td class="dspalph">$(V_C2JOB)</td>
                              </tr>

                              <tr><td class="dsphdr">Start Date</td>
                                  <td class="dspdate">$(F_C2STRT)</td>
                              </tr>

                              <tr><td class="dsphdr">End Date</td>
                                  <td class="dspdate">$(F_C2END)</td>
                              </tr>

                              <tr><td class="dsphdr">Maximum YTD Hours/Units</td>
                                  <td class="dspnmbr">$(V_C2MAX1)</td>
                              </tr>

                              <tr><td class="dsphdr">Maximum Earnings</td>
                                  <td class="dspnmbr">$(V_C2MAX2)</td>
                              </tr>

                              <tr><td class="dsphdr">Default Record</td>
                                  <td class="dspalph">$(V_C2DFLT)</td>
                              </tr>
                          </table>
                      </fieldset>
                  %endif
              %}
      %if (moreInfo != "Y")	
          </table>
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
      %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "C2DESCU,C2COMP,C2FACL,C2CODE")
      @DTW_ASSIGN(orderByDisplay, "Description, Company/Facility, Pay Code")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(orderBy, "C2COMP")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "CoFac")
      %if (orderBy == "C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderBy, "C2COMP DESC,C2FACL DESC,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Company/Facility (descending), Pay Code")
      %else
          @DTW_ASSIGN(orderBy, "C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Company/Facility, Pay Code")
      %endif
  %elseif (sequence == "PayCode")
      %if (orderBy == "C2CODE,C2COMP,C2FACL")
          @DTW_ASSIGN(orderBy, "C2CODE DESC,C2COMP,C2FACL")
          @DTW_ASSIGN(orderByDisplay, "Pay Code (descending), Company/Facility")
      %else
          @DTW_ASSIGN(orderBy, "C2CODE,C2COMP,C2FACL")
          @DTW_ASSIGN(orderByDisplay, "Pay Code, Company/Facility")
      %endif
  %elseif (sequence == "Desc")
      %if (orderBy == "C2DESCU,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderBy, "C2DESCU DESC,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Company/Facility, Pay Code")
      %else
          @DTW_ASSIGN(orderBy, "C2DESCU,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Description, Company/Facility, Pay Code")
      %endif
  %elseif (sequence == "HoursUnit")
      %if (orderBy == "C2HRCD,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderBy, "C2HRCD DESC,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Hours/Unit (descending), Company/Facility, Pay Code")
      %else
          @DTW_ASSIGN(orderBy, "C2HRCD,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Hours/Unit, Company/Facility, Pay Code")
      %endif
  %elseif (sequence == "StartDate")
      %if (orderBy == "C2STRT,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderBy, "C2STRT DESC,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Start Date (descending), Company/Facility, Pay Code")
      %else
          @DTW_ASSIGN(orderBy, "C2STRT,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Start Date, Company/Facility, Pay Code")
      %endif
  %elseif (sequence == "EndDate")
      %if (orderBy == "C2END,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderBy, "C2END DESC,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "End Date (descending), Company/Facility, Pay Code")
      %else
          @DTW_ASSIGN(orderBy, "C2END,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "End Date, Company/Facility, Pay Code")
      %endif
  %elseif (sequence == "Account")
      %if (orderBy == "C2ACCT,C2SUB,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderBy, "C2ACCT DESC,C2SUB DESC,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Account (descending), Company/Facility, Pay Code")
      %else
          @DTW_ASSIGN(orderBy, "C2ACCT,C2SUB,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Account, Company/Facility, Pay Code")
      %endif
  %elseif (sequence == "SummaryType")
      %if (orderBy == "C2SMTY,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderBy, "C2SMTY DESC,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Summary Type (descending), Company/Facility, Pay Code")
      %else
          @DTW_ASSIGN(orderBy, "C2SMTY,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Summary Type, Company/Facility, Pay Code")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchCo, 2, 0) &&
                      editNum(document.Search.srchFac, 4, 0) &&
                      editdate(document.Search.srchStart) &&
                      editdate(document.Search.srchEnd) &&
                      editNum(document.Search.srchAcct, 4, 0) &&
                      editNum(document.Search.srchSub, 4, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Company</td>
                              @dtw_assign(operNbr, "operCo")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchCo" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Facility</td>
                              @dtw_assign(operNbr, "operFac")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchFac" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Pay Code</td>
                              @dtw_assign(operNbr, "operPayCode")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchPayCode" size="3" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchDesc" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Hours Or Units</td>
                              @dtw_assign(operNbr, "operHourUnit")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchHourUnit" size="1" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Start Date</td>
                              @dtw_assign(operNbr, "operStart")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchStart" size="6" maxlength="6"><a href="javascript:calWindow('srchStart');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">End Date</td>
                              @dtw_assign(operNbr, "operEnd")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchEnd" size="6" maxlength="6"><a href="javascript:calWindow('srchEnd');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">G/L Account</td>
                              @dtw_assign(operNbr, "operAcct")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchAcct" size="4" maxlength="4">
                                                          <input type="text" name="srchSub" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Summary Type</td>
                              @dtw_assign(operNbr, "operSumType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchSumType" size="1" maxlength="1"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchCo.focus();
                          </script>
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("C2COMP", "Company", $(srchCo), "", operCo, "N")
  @Build_WildCard ("C2FACL", "Facility", $(srchFac), "", operFac, "N")
  @Build_WildCard ("C2CODE", "Pay Code", $(srchPayCode), "U", operPayCode, "A")
  @Build_WildCard ("upper(C2DESC)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("C2HRCD", "Hours Or Units", $(srchHourUnit), "U", operHourUnit, "A")
  @Build_WildCard ("C2STRT", "Start Date", $(srchStart), "", operStart, "D")
  @Build_WildCard ("C2END", "End Date", $(srchEnd), "", operEnd, "D")
  @Build_WildCard ("C2SMTY", "Summary Type", $(srchSumType), "U", operSumType, "A")
  @Build_WildCard_Acct ("C2ACCT", "C2SUB", "Account", $(srchAcct), $(srchSub), $(operAcct))

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}