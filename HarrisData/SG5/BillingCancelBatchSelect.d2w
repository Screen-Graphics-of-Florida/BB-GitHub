%INCLUDE "$(baseVar)"
%INCLUDE "Billing.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Cancel Batch"
  d2wName                 = "BillingCancelBatchSelect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;batchNumber=@dtw_rurlescseq(batchNumber)&amp;shipThru=@dtw_rurlescseq(shipThru)&amp;recurThru=@dtw_rurlescseq(recurThru)&amp;invDate=@dtw_rurlescseq(invDate)&amp;fromLoc=@dtw_rurlescseq(fromLoc)&amp;toLoc=@dtw_rurlescseq(toLoc)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  submitNoSelection       = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              function confirmCancel() {return confirm("OK to cancel batch?")}
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onkeypress="return event.keyCode!=13">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "BILLINGCANCELBATCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      <table $(contentTable)>
                    	       <colgroup>
                    	           <col width="80%">
                    	           <col width="15%">
                            <tr><td><h1>$(page_title)</h1></td>
                                <td class="toolbar">
                                    <a onClick="return confirmCancel()" href="javascript:check(document.Chg)">$(deleteImageMed)</a>
                                    <a href="javascript:history.back()">$(cancelImageLrg)</a>
                                    @dtw_assign(medIcon, "Y")
                                    %INCLUDE "HelpPage.icl"
                                </td>
                            </tr>
                      </table>
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          @Format_Date(shipThru, "D", F_shipThru)
                          @Format_Date(recurThru, "D", F_recurThru)
                          @Format_Date(invDate, "D", F_invDate)

                          <table $(contentTable)>
                              <tr><td class="dsphdr">Batch Number</td>
                                  <td class="dspnmbr">$(batchNumber)</td>
                              </tr>

                              %if (shipThru>"0")
                                  <tr><td class="dsphdr">Shipments Through</td>
                                      <td class="dspnmbr">$(F_shipThru)</td>
                                  </tr>
                              %endif

                              %if (recurThru>"0")
                                  <tr><td class="dsphdr">Recurring Orders Through</td>
                                      <td class="dspnmbr">$(F_recurThru)</td>
                                  </tr>
                              %endif

                              %if (invDate>"0")
                                  <tr><td class="dsphdr">Invoice Date</td>
                                      <td class="dspnmbr">$(F_invDate)</td>
                                  </tr>
                              %endif

                              <tr><td class="dsphdr">Locations</td>
                                  <td class="dspalph">
                                      %if (fromLoc=="1" && toLoc=="999")
                                          All
                                      %else
                                          $(fromLoc) - $(toLoc)
                                      %endif
                                  </td>
                              </tr>
                          </table>

                          @Billing_Selections(batchNumber)
                          <table $(contentTable)>
                                <tr>
                                    <td class="toolbar">
                                        <a onClick="return confirmCancel()" href="javascript:check(document.Chg)">$(deleteImageMed)</a>
                                        <a href="javascript:history.back()">$(cancelImageLrg)</a>
                                        @dtw_assign(medIcon, "Y")
                                        %INCLUDE "HelpPage.icl"
                                    </td>
                                </tr>
                          </table>
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HOECBB_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"

  @dtw_assign(maintenanceCode, "X")
  @dtw_assign(edtVar, "")
  @Concat_Field("@@btch", batchNumber)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, "Batch Number", $(batchNumber), "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)BillingCancelBatch.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}