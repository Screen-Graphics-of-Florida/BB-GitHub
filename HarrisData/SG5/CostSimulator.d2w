%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "ItemMaintain.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Cost Simulation"
  d2wName                 = "CostSimulator.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  imageExists             = ""
  plantNumber             = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
  @dtw_replace(workURL, "@@itemNumber", "@dtw_rurlescseq(itemNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@plantNumber", "@dtw_rurlescseq(plantNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@plantName", "@dtw_rurlescseq(plantName)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) { 	
  @dtw_assign(userPass, "")
  %if (plantNumber > "0")
      @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %endif
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterSearch.icl"
                  %INCLUDE "Menu.js"
                  %INCLUDE "numedit.icl"
                  %if (plantNumber == "")
                      function validate(searchForm) {
                          if (editNum(document.Search.srchPlant, 3, 0))
                              return true;
                      }
                  %else
                      %INCLUDE "NoFormValidate.icl"
                  %endif
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                          @dtw_assign(pageID, "ITEMFORPLANT")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif

                      <td class="content">
                          @dtw_assign(uv_PlantName, "IPPLT")
                          @dtw_assign(uv_PltInventoryTypeName, "IPITC")
                          @dtw_assign(uv_PltPartTypeName, "IPPTYP")
                          @dtw_assign(uv_PartClassName, "IPCLAS")
                          @dtw_assign(uv_VendorName, "IPVEND")
                          @dtw_assign(uv_BuyerName, "IPBAC")
                          @dtw_assign(uv_ProductClassName, "IMPCLS")
                          %INCLUDE "userview.icl"

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, "Select HDIPLT.*, HDIMST.* ", stmtSQL)
                          %if (plantNumber == "")
                              @dtw_concat(stmtSQL, " , coalesce(PLNAME,' ') as PLNAME, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(upper(PLNAME),' ') as PLNAMEU ", stmtSQL)
                          %endif
                          @dtw_concat(fileSQL, " HDIPLT join HDIMST on IPITEM=IMITEM ", fileSQL)
                          %if (plantNumber == "")
                              @dtw_concat(fileSQL, " left join HDPLNT on IPPLT=PLPLNT ", fileSQL)
                          %endif
                          @dtw_concat(selectSQL, " (IPPTYP='M' or IPPTYP='B') ", selectSQL)
                          %if (plantNumber > "0")
                              @dtw_concat(selectSQL, " and IPPLT=$(plantNumber) ", selectSQL)
                          %endif
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @list_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) list_Query (IN   CHAR(64)    profileHandle,
                                    CHAR(2)     dataBaseID,
                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @dtw_assign(programName, "HSCSIM")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)

                  <td class="toolbar">
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      %if (plantNumber > "0")
          <table $(contentTable)>
              @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
              @Format_Header_URL("Plant", $(plantName), $(plantNumber), "$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(d2wVarBase)")
          </table>
      %endif
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)
			
      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Item Number</th>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">Product<br>Class</th>
                      %if (plantNumber == "")
                          <th class="colhdr">Plant</th>
                      %endif
                  </tr>
                  <tr>
                      <td class="inputalph">
                          <input type="text" name="srchItem" size="15" maxlength="15">
                          <input type="hidden" name="operItem" value="LIKE">
                      </td>
                      <td class="inputalph">
                          <input type="text" name="srchDesc" size="15" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td class="inputalph">
                          <input type="text" name="srchProdClass" size="5" maxlength="4">
                          <input type="hidden" name="operProdClass" value="LIKE">
                      </td>
                      %if (plantNumber == "")
                          <td><input type="text" class="inputnmbr" name="srchPlant" size="5" maxlength="3">
                              <input type="hidden" name="operPlant" value="=">
                          </td>
                      %endif
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchItem.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("IPITEM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=itemNumber" title="Sequence By Item Number"> Item Number</a></th>
              @OrderBy_Sort("IMIMDSU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=description" title="Sequence By Description, Item Number"> Description</a></th>
              @OrderBy_Sort("IMPCLS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=productClass" title="Sequence By Product Class, Item Number"> Product <br> Class</a></th>
              @OrderBy_Sort("IMKIT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=kit" title="Sequence By Kit/Featured Item/Configurable, Item Number"> KFC</a></th>
              %if (V_CILTUS == "Y")
                  @OrderBy_Sort("IMLOT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=lot" title="Sequence By Lot Controlled, Item Number"> Lot </a></th>
              %endif
              @OrderBy_Sort("IPPTYP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=partType" title="Sequence By Part Type, Item Number">Part<br>Type</a></th>
              %if (plantNumber == "")
                  @OrderBy_Sort("IPPLT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlantNumber" title="Sequence By Plant">Plant</a></th>
                  @OrderBy_Sort("PLNAMEU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlantName" title="Sequence By Plant Name">Plant Name</a></th>
              %endif
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_IPITEM)&amp;itemDescription=@dtw_rurlescseq(V_IMIMDS)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"

              @RtvFldDesc("IXITEM='$(V_IPITEM)'", "HDIMXD", "char(count(*))", cmtCount)
              @dtw_assign(itemImage, "$(V_IPITEM)$(itemImageExt)")
              @dtwf_exists(itemImage, imageExists)
              @RtvFldDesc("(PCPCLS='$(V_IMPCLS)')", "HDPCLS", "PCPCDS", pclsDesc)
              @RtvFldDesc("(FLTYPE='KIT' and FLVALU='$(V_IMKIT)')", "SYFLAG", "FLDESC", kitDesc)
              @RtvFldDesc("(FLTYPE='LOT' and FLVALU='$(V_IMLOT)')", "SYFLAG", "FLDESC", lotDesc)
              @RtvFldDesc("(FLTYPE='PARTTYPE' and FLVALU='$(V_IPPTYP)')", "SYFLAG", "FLDESC", ptypDesc)

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)CostSimulatorDisplay.d2w/BUILD$(maintainVar)&amp;plantNumber=@dtw_rurlescseq(V_IPPLT)&amp;fromPlant=@dtw_rurlescseq(plantNumber)" title="View Cost Simulation">$(V_IPITEM)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemInquiry.d2w/DISPLAY$(maintainVar)" onclick="$(inquiryWinVar)" title="Item Quickview">$(V_IMIMDS)</a></td>
                  <td class="colalph" $(helpCursor)><span title="$(pclsDesc)">$(V_IMPCLS)</span></td>
                  <td class="colcode" $(helpCursor)><span title="$(kitDesc)">$(V_IMKIT)</span></td>
                  %if (V_CILTUS == "Y")
                      <td class="colcode" $(helpCursor)><span title="$(lotDesc)">$(V_IMLOT)</span></td>
                  %endif
                  <td class="colcode" $(helpCursor)><span title="$(ptypDesc)">$(V_IPPTYP)</span></td>
                  %if (plantNumber == "")
                      <td class="colnmbr">$(V_IPPLT)</td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(V_IPPLT)&amp;plantName=@dtw_rurlescseq(V_PLNAME)" title="View Plant">$(V_PLNAME)</a></td>
                  %endif
                  %if (V_IMIMAC == "I")
                      <td class="colcode">$(inactiveImageSml)</td>
                  %endif
    		   %if (imageExists == "Y" && formatToPrint != "Y")
                      <td class="colicon">
                          <a href="$(homeURL)$(cGIPath)ImageDisplay.d2w/DISPLAY$(genericVarBase)&amp;imageDisplayPath=$(homeURL)$(itemImage)&amp;imageDesc=@dtw_rurlescseq(V_IMIMDS)" onclick="$(itemImageWinVar)">$(foundImage)</a>
                      </td>
                  %endif
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) { 	
  @dtw_assign(uv_PlantName, "IPPLT")
  @dtw_assign(uv_PltInventoryTypeName, "IPITC")
  @dtw_assign(uv_PltPartTypeName, "IPPTYP")
  @dtw_assign(uv_PartClassName, "IPCLAS")
  @dtw_assign(uv_VendorName, "IPVEND")
  @dtw_assign(uv_BuyerName, "IPBAC")
  @dtw_assign(uv_ProductClassName, "IMPCLS")
  %INCLUDE "userview.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "Select *.HDIPLT, *.HDIMST ", stmtSQL)
  %if (plantNumber == "")
      @dtw_concat(stmtSQL, " , coalesce(PLNAME,' ') as PLNAME, ", stmtSQL)
      @dtw_concat(stmtSQL, " coalesce(upper(PLNAME),' ') as PLNAMEU ", stmtSQL)
  %endif
  @dtw_concat(fileSQL, " HDIPLT join HDIMST on IPITEM=IMITEM ", fileSQL)
  %if (plantNumber == "")
      @dtw_concat(fileSQL, " left join HDPLNT on IPPLT=PLPLNT ", fileSQL)
  %endif
  @dtw_concat(selectSQL, " (IPPTYP='M' or IPPTYP='B') ", selectSQL)
  %if (plantNumber > "0")
      @dtw_concat(selectSQL, " and IPPLT=$(plantNumber) ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @inquiry_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) inquiry_XMLQuery (IN CHAR(64) profileHandle,
				         CHAR(2)   dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("ItemList")		
      %if (plantNumber > "0")
          @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
	   @XMLIDTag(plantNumber, "Plant ID")
              @XMLTag(plantNumber, "PlantNumber")
              @XMLTag(plantName, "PlantName")
      %endif
      %ROW{
          @XMLIDTag(V_IPITEM, "Item ID")
              @XMLTag(V_IPITEM, "Item")
              @XMLTag(V_IMPCLS, "ProductClass")
              @XMLTag(V_IMIMWG, "Weight")
              @XMLTag(V_IMIMDS, "Description")
              @XMLTag(V_IMITC, "InventoryType")
              %if (plantNumber == "")
                  @XMLTag(V_IPPLT, "PlantNumber")
                  @XMLTag(V_PLNAME, "PlantName")
              %endif
          @XMLEndTag("Item")
      %}
      %if (plantNumber > "0")
          @XMLEndTag("Plant")
      %endif
      @XMLEndTag("ItemList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (plantNumber > "0" && orderBy == "PLNAMEU,IPITEM")
          @dtw_assign(orderBy, "")
      %endif
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "IMIMDSU,IPITEM")
          @DTW_ASSIGN(orderByDisplay, "Description, Item Number")
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit ()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "IPITEM")
      @DTW_ASSIGN(orderByDisplay, "Item Number")
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "itemNumber")
      %if (orderBy == "IPITEM")
          @DTW_ASSIGN(orderBy, "IPITEM DESC")
          @DTW_ASSIGN(orderByDisplay, "Item Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "IPITEM")
          @DTW_ASSIGN(orderByDisplay, "Item Number")
      %endif
  %elif (sequence == "description")
      %if (orderBy == "IMIMDSU,IPITEM")
          @DTW_ASSIGN(orderBy, "IMIMDSU DESC,IPITEM")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Item Number")
      %else
          @DTW_ASSIGN(orderBy, "IMIMDSU,IPITEM")
          @DTW_ASSIGN(orderByDisplay, "Description, Item Number")
      %endif
  %elif (sequence == "productClass")
      %if (orderBy == "IMPCLS,IPITEM")
          @DTW_ASSIGN(orderBy, "IMPCLS DESC,IPITEM")
          @DTW_ASSIGN(orderByDisplay, "Product Class (descending), Item Number")
      %else
          @DTW_ASSIGN(orderBy, "IMPCLS,IPITEM")
          @DTW_ASSIGN(orderByDisplay, "Product Class, Item Number")
      %endif
  %elif (sequence == "kit")
      %if (orderBy == "IMKIT,IPITEM")
          @DTW_ASSIGN(orderBy, "IMKIT DESC,IPITEM")
          @DTW_ASSIGN(orderByDisplay, "Kit/Featured Item/Configurable (descending), Item Number")
      %else
          @DTW_ASSIGN(orderBy, "IMKIT,IPITEM")
          @DTW_ASSIGN(orderByDisplay, "Kit/Featured Item/Configurable, Item Number")
      %endif
  %elif (sequence == "lot")
      %if (orderBy == "IMLOT,IPITEM")
          @DTW_ASSIGN(orderBy, "IMLOT DESC,IPITEM")
          @DTW_ASSIGN(orderByDisplay, "Lot Controlled (descending), Item Number")
      %else
          @DTW_ASSIGN(orderBy, "IMLOT,IPITEM")
          @DTW_ASSIGN(orderByDisplay, "Lot Controlled, Item Number")
      %endif
  %elif (sequence == "partType")
      %if (orderBy == "IPPTYP,IPITEM")
          @DTW_ASSIGN(orderBy, "IPPTYP DESC,IPITEM")
          @DTW_ASSIGN(orderByDisplay, "Part Type (descending), Item Number")
      %else
          @DTW_ASSIGN(orderBy, "IPPTYP,IPITEM")
          @DTW_ASSIGN(orderByDisplay, "Part Type, Item Number")
      %endif
  %elif (sequence == "PlantNumber")
      %if (orderBy == "IPPLT,IPITEM")
          @DTW_ASSIGN(orderBy, "IPPLT DESC,IPITEM")
          @DTW_ASSIGN(orderByDisplay, "Plant Number (descending), Item Number")
      %else
          @DTW_ASSIGN(orderBy, "IPPLT,IPITEM")
          @DTW_ASSIGN(orderByDisplay, "Plant Number, Item Number")
      %endif
  %elif (sequence == "PlantName")
      %if (orderBy == "PLNAMEU,IPITEM")
          @DTW_ASSIGN(orderBy, "PLNAMEU DESC,IPITEM")
          @DTW_ASSIGN(orderByDisplay, "Plant Name (descending), Item Number")
      %else
          @DTW_ASSIGN(orderBy, "PLNAMEU,IPITEM")
          @DTW_ASSIGN(orderByDisplay, "Plant Name, Item Number")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (
                      %if (plantNumber == "")
                          editNum(document.Search.srchPlant, 3, 0) &&
                      %endif
                      editNum(document.Search.srchUPC, 13, 0) &&
                      editNum(document.Search.srchNumeric1, 8, 5) &&
                      editNum(document.Search.srchNumeric2, 8, 5) &&
                      editNum(document.Search.srchNumeric3, 8, 5) &&
                      editNum(document.Search.srchNumeric4, 8, 5) &&
                      editNum(document.Search.srchNumeric5, 8, 5))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ITEMSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Item Number</td>
                              @dtw_assign(operNbr, "operItem")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchItem" type="text" size="15" maxlength="15">$(V_IPITEM)</td>
                          </tr>
        			
                          <tr><td class="dsphdr">Item Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchDesc" type="text" size="30" maxlength="30"></td>
                          </tr>
        			
                          <tr><td class="dsphdr">Product Class</td>
                              @dtw_assign(operNbr, "operProdClass")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchProdClass" type="text" size="4" maxlength="4"><a href="$(homeURL)$(cGIPath)prodclasssearch.d2w/ENTRY$(genericVarBase)&amp;docName=Search&amp;fldName=srchProdClass&amp;fldDesc=productClassDescH" onclick="$(searchWinVar)"> $(searchImage) </a><input name="productClassDescH" type="text" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Kit Item / Featured Item / Cfg</td>
                              @dtw_assign(operNbr, "operKit")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchKit" type="text" size="1" maxlength="1"></td>
                          </tr>

                          %if (V_CILTUS == "Y")
                              <tr><td class="dsphdr">Lot Controlled</td>
                                  @dtw_assign(operNbr, "operLot")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input name="srchLot" type="text" size="1" maxlength="1"></td>
                              </tr>
                          %endif

                          %if (V_HDPDRL>"0")
                              <tr><td class="dsphdr">Part Type</td>
                                  @dtw_assign(operNbr, "operPartType")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input name="srchPartType" type="text" size="1" maxlength="1"></td>
                              </tr>
                          %endif

                          <tr><td class="dsphdr">Catalog Number</td>
                              @dtw_assign(operNbr, "operCatalog")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchCatalog" type="text" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">U.P.C. Number</td>
                              @dtw_assign(operNbr, "operUPC")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputnmbr"><input name="srchUPC" type="text" size="13" maxlength="13"></td>
                          </tr>

                          %if (V_CIIAS1 != "")		
                              <tr><td class="dsphdr">$(V_CIIAS1)</td>
                                  @dtw_assign(operNbr, "operAlpha1")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchAlpha1" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIIAS2 != "")		
                              <tr><td class="dsphdr">$(V_CIIAS2)</td>
                                  @dtw_assign(operNbr, "operAlpha2")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchAlpha2" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIIAS3 != "")		
                              <tr><td class="dsphdr">$(V_CIIAS3)</td>
                                  @dtw_assign(operNbr, "operAlpha3")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchAlpha3" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIIAS4 != "")		
                              <tr><td class="dsphdr">$(V_CIIAS4)</td>
                                  @dtw_assign(operNbr, "operAlpha4")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchAlpha4" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (V_CIIAS5 != "")		
                              <tr><td class="dsphdr">$(V_CIIAS5)</td>
                                  @dtw_assign(operNbr, "operAlpha5")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchAlpha5" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          <tr>
                              %if (V_CIINS1 != "")		
                                 <td class="dsphdr">$(V_CIINS1)</td>
                                  @dtw_assign(operNbr, "operNumeric1")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchNumeric1" size="15" maxlength="15"></td>
                              %else
                                  <td class="inputnmbr"><input type="hidden" name="srchNumeric1"></td>
                              %endif
                          </tr>

                          <tr>
                              %if (V_CIINS2 != "")		
                                  <td class="dsphdr">$(V_CIINS2)</td>
                                  @dtw_assign(operNbr, "operNumeric2")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchNumeric2" size="15" maxlength="15"></td>
                              %else
                                  <td class="inputnmbr"><input type="hidden" name="srchNumeric2"></td>
                              %endif
                          </tr>

                          <tr>
                              %if (V_CIINS3 != "")		
                                  <td class="dsphdr">$(V_CIINS3)</td>
                                  @dtw_assign(operNbr, "operNumeric3")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchNumeric3" size="15" maxlength="15"></td>
                              %else
                                  <td class="inputnmbr"><input type="hidden" name="srchNumeric3"></td>
                              %endif
                          </tr>

                          <tr>
                              %if (V_CIINS4 != "")		
                                  <td class="dsphdr">$(V_CIINS4)</td>
                                  @dtw_assign(operNbr, "operNumeric4")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchNumeric4" size="15" maxlength="15"></td>
                              %else
                                  <td class="inputnmbr"><input type="hidden" name="srchNumeric4"></td>
                              %endif
                          </tr>

                          <tr>
                              %if (V_CIINS5 != "")		
                                  <td class="dsphdr">$(V_CIINS5)</td>
                                  @dtw_assign(operNbr, "operNumeric5")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchNumeric5" size="15" maxlength="15"></td>
                              %else
                                  <td class="inputnmbr"><input type="hidden" name="srchNumeric5"></td>
                              %endif
                          </tr>

                          %if (plantNumber == "")
                              <tr><td class="dsphdr">Plant Number</td>
                                  @dtw_assign(operNbr, "operPlant")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchPlant" size="5" maxlength="3"></td>
                              </tr>

                              <tr><td class="dsphdr">Plant Name</td>
                                  @dtw_assign(operNbr, "operName")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"> <input type="text" name="srchName" size="30" maxlength="26"></td>
                              </tr>
                          %endif

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchItem.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("IPITEM", "Item Number", $(srchItem), "U", operItem, "A")
  @Build_WildCard ("IMIMDSU", "Item Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("IMPCLS", "Product Class", $(srchProdClass), "U", operProdClass, "A")
  @Build_WildCard ("IMKIT",  "Kit Item / Featured Item / Cfg", $(srchKit), "U", operKit, "A")
  @Build_WildCard ("IMLOT",  "Lot Controlled", $(srchLot), "U", operLot, "A")
  @Build_WildCard ("IPPTYP", "Part Type", $(srchPartType), "U", operPartType, "A")
  @Build_WildCard ("IMCATN", "Catalog Number", $(srchCatalog), "U", operCatalog, "A")
  @Build_WildCard ("IMUPC", "U.P.C. Number", $(srchUPC), "", operUPC, "N")
  @Build_WildCard ("IMUDA1", "$(V_CIIAS1)", $(srchAlpha1), "U", operAlpha1, "A")
  @Build_WildCard ("IMUDA2", "$(V_CIIAS2)", $(srchAlpha2), "U", operAlpha2, "A")
  @Build_WildCard ("IMUDA3", "$(V_CIIAS3)", $(srchAlpha3), "U", operAlpha3, "A")
  @Build_WildCard ("IMUDA4", "$(V_CIIAS4)", $(srchAlpha4), "U", operAlpha4, "A")
  @Build_WildCard ("IMUDA5", "$(V_CIIAS5)", $(srchAlpha5), "U", operAlpha5, "A")
  @Build_WildCard ("IMUDN1", "$(V_CIINS1)", $(srchNumeric1), "", operNumeric1, "N")
  @Build_WildCard ("IMUDN2", "$(V_CIINS2)", $(srchNumeric2), "", operNumeric2, "N")
  @Build_WildCard ("IMUDN3", "$(V_CIINS3)", $(srchNumeric3), "", operNumeric3, "N")
  @Build_WildCard ("IMUDN4", "$(V_CIINS4)", $(srchNumeric4), "", operNumeric4, "N")
  @Build_WildCard ("IMUDN5", "$(V_CIINS5)", $(srchNumeric5), "", operNumeric5, "N")
  %if (plantNumber == "")
      @Build_WildCard ("IPPLT", "Plant Number", $(srchPlant), "", operPlant, "N")
      @Build_WildCard ("upper(PLNAME)", "Plant Name", $(srchName), "U", operName, "A")
  %endif

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}