%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Select Order"
  d2wName                 = "SelectOrderFlags.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;lineNumber=@dtw_rurlescseq(lineNumber)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;batchNumber=@dtw_rurlescseq(batchNumber)&amp;turnaround=@dtw_rurlescseq(turnaround)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "1000"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "1000"
  prtMaxRows              = "1000"
  rowIndexNext            = "1"
  totalPages              = "0"
  tabID                   = "FLAGS"
  lgCTitle                = "Click here to cancel this shipment"	
  lgHTitle                = "Click here to hold this shipment"	
  lgOTitle                = "Click here to omit this shipment from the billing cycle"	
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              function confirmCloseCancel() { return confirm("Confirm Close/Cancel Of Order")}
              function confirmCancel(turn,order) { return confirm("Confirm Cancel Of Shipment" + "\n" + "\n" + "Turnaround " + turn + "\n" + "Order Number " + order)}
              function confirmHold(turn,order)   { return confirm("Confirm Hold Of Shipment" + "\n" + "\n" + "Turnaround " + turn + "\n" + "Order Number " + order)}
              function confirmOmit(turn,order)   { return confirm("Confirm Omit From Billing Cycle" + "\n" + "\n" + "Turnaround " + turn + "\n" + "Order Number " + order)}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "SELECTORDER")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "AddRecordSQL.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      @Select_Order_Flags(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Select_Order_Flags (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "SelectOrderTabs.icl"

      <table $(contentTable)>
          <tr>
              <th class="colhdr">Flag</th>
              <th class="colhdr">Description</th>
              <th class="colhdr" colspan="2">Value</th>
          </tr>

          %ROW{
              @dtw_assign(recCnt, "01")
              %while(recCnt <= "20") {
                  @RtvFldDesc("FLTYPE='$(orderApplication)FLAGDSC' and FLVALU='$(recCnt)'", "SYFLAG", "FLDESC", flagDesc)
                  %if ($(flag_$(recCnt)) != "" && flagDesc != "")
                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          <td class="colnmbr">$(recCnt)</td>
                          <td class="colalph">$(flagDesc)</td>
                          @RtvFldDesc("FLTYPE='$(orderApplication)FLAG$(recCnt)' and FLVALU='$(flag_$(recCnt))'", "SYFLAG", "FLDESC", flagValue)
                          <td class="colalph">$(flagValue)</td>
                          @Format_Code($(flag_$(recCnt)), F_Value)
                          <td class="colnmbr">$(F_Value)</td>
                      </tr>
                  %endif
                  @dtw_add(recCnt, "1", recCnt)
                  %while(@dtw_rlength(recCnt) != "2") {@dtw_insert("0", recCnt, recCnt)%}
              %}
          %}
      </table>
      %INCLUDE "EndTabs.icl"
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}