%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Item Comments"
  d2wName                 = "ItemComments.d2w"
  d2wVarBase              = "$(genericVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  DTW_PAD_PGM_PARMS       = "YES"
%}

%FUNCTION(dtw_sql) ITEM_COMMENTS (IN CHAR(64) profileHandle,
				      CHAR(2)  dataBaseID,
                                     CHAR(15) item)
{CALL $(pgmLibrary)HHDICP_W

  %REPORT{
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "headcmt.icl"
          </head>

          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "$(cmtBanner)"
              <!-- End Of Banner Code -->
              <table $(contentTable)>
                  @Format_Header("Item", $(itemDesc), $(itemNumber))
              </table>
              $(hrTagAttr)

              <form class="formClass" METHOD=POST ACTION="">
                  <table $(contentTable)>
                      %ROW{
                          <tr><td class="colalph"> $(V_IXDESC)</td></tr>
                      %}
                  </table>
              </form>
              $(hrTagAttr)
    	       <table $(contentTable)>
                  <tr>
                      <td valign="top">
                          %INCLUDE "CloseWindow.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "$(cmtTrailer)"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_concat(itemNumber, "               ", item)
  @ITEM_COMMENTS(profileHandle, dataBaseID, item)
%}