%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Message Text Maintenance"
  d2wName                 = "WFMessageTextMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromMsgId=@dtw_rurlescseq(fromMsgId)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;backHome=@dtw_rurlescseq(backHome)&amp;updRecNbr=@dtw_rurlescseq(updRecNbr)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;wfMsgId=@dtw_rurlescseq(wfMsgId)&amp;maintenanceCode=D"
  programName             = "HWFMSM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function confirmDelete() {return confirm("$(delRecordConf)")}
              function validate(chgForm) {
                  if (document.Chg.wfMsgDesc.value =="" ||
                      document.Chg.workListLink.value =="" ||
                      document.Chg.workHistLink.value =="" ||
                      document.Chg.wfMsgText.value =="")
                         {alert("$(reqFieldError)"); return false;}
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFMESSAGETEXTMAINT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " WFMSGT ", fileSQL)
                          @dtw_concat(selectSQL, " MSMSID='$(wfMsgId)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)

                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=149")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          %ROW {
              %if (errFound != "" || maintenanceCode == "A")
                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(edtVar, "")
                      @dtw_assign(focusField, "wfMsgId")
                  %else
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@msid", "wfMsgId")             @dtw_assign(Err_MSMSID, fieldValue)
                      @DecatErr_Field("@@desc", "wfMsgDesc")           @dtw_assign(Err_MSDESC, fieldValue)
                      @DecatErr_Field("@@list", "workListLink")        @dtw_assign(Err_MSLIST, fieldValue)
                      @DecatErr_Field("@@hist", "workHistLink")        @dtw_assign(Err_MSHIST, fieldValue)
                      @DecatErr_Field("@@text", "wfMsgText")           @dtw_assign(Err_MSTEXT, fieldValue)
                  %endif

                  @Decat_Field("@@msid")   @dtw_assign(V_MSMSID, fieldValue)
                  @Decat_Field("@@desc")   @dtw_assign(V_MSDESC, fieldValue)
                  @Decat_Field("@@list")   @dtw_assign(V_MSLIST, fieldValue)
                  @Decat_Field("@@hist")   @dtw_assign(V_MSHIST, fieldValue)
                  @Decat_Field("@@text")   @dtw_assign(V_MSTEXT, fieldValue)

                  @dtw_assign(errFound, "")

              %elif (maintenanceCode == "Z")
                  @dtw_assign(focusField, "wfMsgId")
              %else
                  @dtw_assign(focusField, "wfMsgDesc")
              %endif

              <table $(contentTable)>
                  @SetTextOvr(Err_MSMSID)
                  <tr><td class="dsphdr"><span $(textOvr)>Message ID</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input type="text" name="wfMsgId" value="$(V_MSMSID)" size="10" maxlength="10"> $(reqFieldChar) </td>
                      %else
                          <td class="inputalph"><input type="hidden" name="wfMsgId" value="$(V_MSMSID)">$(V_MSMSID)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_MSMSID)

                  @SetTextOvr(Err_MSDESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input type="text" name="wfMsgDesc" value="$(V_MSDESC)" size="30" maxlength="30"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_MSDESC)

                  @RtvYNDesc($(V_MSLIST), fieldDesc)
                  @SetTextOvr(Err_MSLIST)
                  <tr><td class="dsphdr"><span $(textOvr)>Work List Link</span></td>
                      <td class="inputalph"><input type="text" name="workListLink" value="$(V_MSLIST)" size="1" maxlength="1">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=YORN&amp;flagSrchHdr=@dtw_rurlescseq("Work List Link")&amp;docName=Chg&amp;fldName=workListLink&amp;fldDesc=workListLinkDesc" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage) </a>
                                            <input type="text" disabled name="workListLinkDesc" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_MSLIST)

                  @RtvYNDesc($(V_MSHIST), fieldDesc)
                  @SetTextOvr(Err_MSHIST)
                  <tr><td class="dsphdr"><span $(textOvr)>Work Item History Link</span></td>
                      <td class="inputalph"><input type="text" name="workHistLink" value="$(V_MSHIST)" size="1" maxlength="1">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=YORN&amp;flagSrchHdr=@dtw_rurlescseq("Work Item History Link")&amp;docName=Chg&amp;fldName=workHistLink&amp;fldDesc=workHistLinkDesc" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage) </a>
                                            <input type="text" disabled name="workHistLinkDesc" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_MSHIST)

                  <tr><td class="dsphdr"><span $(textOvr)>Message Text</span></td></tr>
              </table>

              <table $(contentTable)>
                  @SetTextOvr(Err_MSTEXT)
                  <tr><td class="inputalph">
                          %if (V_MSTEXT != "")
                              <textarea name="wfMsgText" ROWS=10 COLS=60 WRAP="hard">$(V_MSTEXT)</textarea>
                          %else
                              <textarea name="wfMsgText" ROWS=10 COLS=60 WRAP="hard"></textarea>
                          %endif
                       $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_MSTEXT)
              </table>
          %}

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      %INCLUDE "MaintainBottom.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HWFMSM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  %if (wfMsgDesc == "")
      @RtvFldDesc("MSMSID='$(wfMsgId)' ", "WFMSGT", "MSDESC", wfMsgDesc)
  %endif

  @dtw_mUPPERCASE(wfMsgId)
  @dtw_mUPPERCASE(workListLink)
  @dtw_mUPPERCASE(workHistLink)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@frm1", fromMsgId)
  @Concat_Field("@@msid", wfMsgId)
  @Concat_Field("@@desc", wfMsgDesc)
  @Concat_Field("@@list", workListLink)
  @Concat_Field("@@hist", workHistLink)
  @Concat_Field("@@text", wfMsgText)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(wfMsgDesc), $(wfMsgId), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@msid", "wfMsgId")
          @Format_ConfMsg_Desc("", $(wfMsgDesc), $(wfMsgId), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=149&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;wfMsgId=@dtw_rurlescseq(wfMsgId)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}