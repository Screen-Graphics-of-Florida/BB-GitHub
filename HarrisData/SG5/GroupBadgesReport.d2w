%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "ETControl$(dataBaseID).icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Group Badges Report"
  d2wName                 = "GroupBadgesReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;apid=@dtw_rurlescseq(apid)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  %if (V_TABDGF == " ")
      @dtw_assign(V_TABDGF, "E")
  %endif
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  %if (apid == "ME")
                      if (editNum(document.Chg.fromPlantNumber, 3, 0) &&
                          editNum(document.Chg.toPlantNumber, 3, 0) &&
                          editNum(document.Chg.fromGroupNumber, 5, 0) &&
                          editNum(document.Chg.toGroupNumber, 5, 0) &&
                          editFromToAll(document.Chg.fromPlantNumber, document.Chg.toPlantNumber, document.Chg.allPlantNumber, 3) &&
                          editFromToAll(document.Chg.fromGroupNumber, document.Chg.toGroupNumber, document.Chg.allGroupNumber, 5)
                  %else
                      if (editNum(document.Chg.fromGroupNumber, 5, 0) &&
                          editNum(document.Chg.toGroupNumber, 5, 0) &&
                          editFromToAll(document.Chg.fromGroupNumber, document.Chg.toGroupNumber, document.Chg.allGroupNumber, 5)

                  %endif
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "GROUPBADGESREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              %if (apid == "ME")
                                  @dtw_assign(focusField, "fromPlantNumber")
                              %else
                                  @dtw_assign(focusField, "fromGroupNumber")
                              %endif
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  %if (apid == "ME")
                                      @DecatErr_Field("@@fpln", "fromPlantNumber")        @dtw_assign(Err_N1FPLN,  fieldValue)
                                  %else
                                      @DecatErr_Field("@@fgrp", "fromGroupNumber")        @dtw_assign(Err_N1FGRP,  fieldValue)
                                  %endif
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@bdgf")  @dtw_assign(V_N1BDGF,  fieldValue)

                                  %if (apid == "ME")
                                      @Decat_Field("@@fpln")  @dtw_assign(V_N1FPLN,  fieldValue)
                                      @Decat_Field("@@tpln")  @dtw_assign(V_N1TPLN,  fieldValue)
                                      @Decat_Field("@@apln")  @dtw_assign(V_N1APLN,  fieldValue)
                                  %endif

                                  @Decat_Field("@@fgrp")  @dtw_assign(V_N1FGRP, fieldValue)
                                  @Decat_Field("@@tgrp")  @dtw_assign(V_N1TGRP, fieldValue)
                                  @Decat_Field("@@agrp")  @dtw_assign(V_N1AGRP, fieldValue)

                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}

                                  %if (V_N1BDGF == "02")
                                      @dtw_assign(groupNumber, "")
                                      @dtw_assign(badgeNumber, "CHECKED")
                                  %else
                                      @dtw_assign(groupNumber, "CHECKED")
                                      @dtw_assign(badgeNumber, "")
                                  %endif
                                  %if (V_N1APLN == "ALL")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPlantNumber, "")
                                  %endif
                                  %if (V_N1AGRP == "ALL")
                                      @dtw_assign(checkedallGroupNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallGroupNumber, "")
                                  %endif

                              %else
                                  %if (V_TABDGF == "E")
                                      @dtw_assign(groupNumber, "CHECKED")
                                      @dtw_assign(badgeNumber, "")
                                  %else
                                      @dtw_assign(groupNumber, "")
                                      @dtw_assign(badgeNumber, "CHECKED")
                                  %endif

                                  @RtvDftPlant(plantNumber, plantName)
                                  %if (plantNumber == "0")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(V_N1FPLN, plantNumber)
                                      @dtw_assign(V_N1TPLN, plantNumber)
                                      @dtw_assign(checkedallPlantNumber, "")
                                  %endif
                                  @dtw_assign(checkedallGroupNumber, "CHECKED")
                              %endif

                          </table>

                          <table $(contentTable)>

                              <tr><td class="dsphdr"><span $(textOvr)>Badge Format</span></td>
                                  <td class="inputnmbr"><input name="badgeFormat" type="radio" VALUE='01' $(groupNumber)>Group Number</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="badgeFormat" type="radio" VALUE='02' $(badgeNumber)>Badge Number</td>
                              </tr>

                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>


                              %if (apid == "ME")
                                  <tr><td class="dsphdr"><span $(textOvr)>Plant Number</td>
                                      <td class="inputnmbr"><input name="fromPlantNumber" value="$(V_N1FPLN)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromPlantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName" type="hidden"></td>
                                      <td class="inputnmbr"><input name="toPlantNumber" value="$(V_N1TPLN)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toPlantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName" type="hidden"></td>
                                      <td class="inputalph"><input name="allPlantNumber" value='ALL' $(checkedallPlantNumber) type="checkbox" onClick="if (this.checked) this.form.fromPlantNumber.value='', this.form.toPlantNumber.value='';"></td>
                                  </tr>
                              %endif

                                  <tr><td class="dsphdr">Group Number</td>
                                      <td class="inputnmbr"><input name="fromGroupNumber" VALUE="$(V_N1FGRP)" type="text" size="5" maxlength="5"> <a href="$(homeURL)$(phpPath)GroupNumberSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromGroupNumber&amp;fldDesc=fgroupName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="fgroupName" type="hidden"></td>
                                      <td class="inputnmbr"><input name="toGroupNumber" VALUE="$(V_N1TGRP)" type="text" size="5" maxlength="5"> <a href="$(homeURL)$(phpPath)GroupNumberSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toGroupNumber&amp;fldDesc=tgroupName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="tgroupName" type="hidden"></td>
                                      <td class="inputalph"><input name="allGroupNumber" value='ALL' $(checkedallGroupNumber) type="checkbox" onClick="if (this.checked) this.form.fromGroupNumber.value='', this.form.toGroupNumber.value='';"></td>
                                  </tr>

                          </table>

                          @dtw_assign(envProgram, "HETGBR")
                          @dtw_assign(envPrinter, "HETGBRPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HETGBS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allPlantNumber)
  @dtw_mUPPERCASE(allGroupNumber)

  @dtw_assign(fromPlantNumber,@dtw_rstrip(fromPlantNumber))
  @dtw_assign(toPlantNumber,@dtw_rstrip(toPlantNumber))
  @dtw_assign(fromGroupNumber,@dtw_rstrip(fromGroupNumber))
  @dtw_assign(toGroupNumber,@dtw_rstrip(toGroupNumber))

  %if (allPlantNumber != "ALL")
      @dtw_assign(allPlantNumber, "")
  %endif
  %if (allGroupNumber != "ALL")
      @dtw_assign(allGroupNumber, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@apid", apid)
  @Concat_Field("@@bdgf", badgeFormat)

  %if (apid == "ME")
      @Concat_Field("@@fpln", fromPlantNumber)
      @Concat_Field("@@tpln", toPlantNumber)
      @Concat_Field("@@apln", allPlantNumber)
  %endif

  @Concat_Field("@@fgrp", fromGroupNumber)
  @Concat_Field("@@tgrp", toGroupNumber)
  @Concat_Field("@@agrp", allGroupNumber)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}