%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Import Key Maintenance"
  d2wName                 = "MapImportKeyMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;importKey=@dtw_rurlescseq(importKey)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;passedImportTable=@dtw_rurlescseq(passedImportTable)&amp;passedRecordType=@dtw_rurlescseq(passedRecordType)&amp;limitRecordType=@dtw_rurlescseq(limitRecordType)&amp;fromImportTable=@dtw_rurlescseq(fromImportTable)&amp;fromImportRecordType=@dtw_rurlescseq(fromImportRecordType)&amp;fromImportInterfaceTable=@dtw_rurlescseq(fromImportInterfaceTable)&amp;fromImportParentTable=@dtw_rurlescseq(fromImportParentTable)&amp;updRecNbr=@dtw_rurlescseq(updRecNbr)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;importTable=@dtw_rurlescseq(importTable)&amp;importRecordType=@dtw_rurlescseq(importRecordType)&amp;interfaceTable=@dtw_rurlescseq(interfaceTable)&amp;parentInterfaceTable=@dtw_rurlescseq(parentInterfaceTable)&amp;backHome=@dtw_rurlescseq(backHome)&amp;mapKey=@dtw_rurlescseq(mapKey)&amp;maintenanceCode=D&amp;updateOption=U"
  refreshURL              = "$(homeURL)$(cGIPath)$(d2wName)/REFRESH$(d2wVarBase)&amp;importTable=@dtw_rurlescseq(importTable)&amp;importRecordType=@dtw_rurlescseq(importRecordType)&amp;interfaceTable=@dtw_rurlescseq(interfaceTable)&amp;parentInterfaceTable=@dtw_rurlescseq(parentInterfaceTable)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;backHome=@dtw_rurlescseq(backHome)&amp;mapKey=@dtw_rurlescseq(mapKey)"
  programName             = "HSYIKM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  editVariables           = ""
  interfaceLibrary        = ""
  ux                      = ""
  LastCol                 = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @RtvFldDesc("FWXHND='$(profileHandle)' and FWIMKY=$(importKey) and FWIFIL='$(importTable)' and FWRTYP='$(importRecordType)' and FWMFIL='$(interfaceTable)' and FWPFIL='$(parentInterfaceTable)'  ", "SYMKYE", "char(count(*))", recCount)	
  %if (recCount <= "0")
      %if (fromImportTable != "")
          @dtw_assign(importTable, fromImportTable)
          @dtw_assign(importRecordType, fromImportRecordType)
          @dtw_assign(interfaceTable, fromImportInterfaceTable)
          @dtw_assign(parentInterfaceTable, fromImportParentTable)
      %elif (maintenanceCode=="A")
          @dtw_assign(importTable, "")
          @dtw_assign(importRecordType, "")
          @dtw_assign(interfaceTable, "")
          @dtw_assign(parentInterfaceTable, "")
      %endif
          @dtw_assign(copyImportTable, importTable)
          @dtw_assign(copyImportRecordType, importRecordType)
          @dtw_assign(copyImportInterfaceTable, interfaceTable)
          @dtw_assign(copyImportParentTable, parentInterfaceTable)

      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Delete From SYMKYE Where FWXHND='$(profileHandle)' and FWIMKY=$(importKey) ", stmtSQL)
      @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)

      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Insert Into SYMKYE (FWXHND,FWIMKY,      FWIFIL,          FWRTYP,               FWMFIL,             FWPFIL,                   FWKYID,FWKYSQ,FWKYPS,FWKYLN) ", stmtSQL)
      @dtw_concat(stmtSQL, " Select '$(profileHandle)', $(importKey),'$(importTable)','$(importRecordType)','$(interfaceTable)','$(parentInterfaceTable)',FKKYSQ,FKKYSQ,FKKYPS,FKKYLN ", stmtSQL)
      @dtw_concat(stmtSQL, " From SYMIKY Where FKIMKY=$(importKey) and FKIFIL='$(copyImportTable)' and FKRTYP='$(copyImportRecordType)' and FKMFIL='$(copyImportInterfaceTable)' and FKPFIL='$(copyImportParentTable)' ", stmtSQL)
      @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)
  %endif

  @RtvFldDesc("FWXHND='$(profileHandle)' and FWIMKY=$(importKey) and FWKYSQ=0 ", "SYMKYE", "char(Count(FWKYID))", recordCount) 	
  %if (recordCount <="0" && errFound == "")
      @RtvFldDesc("FWXHND='$(profileHandle)' and FWIMKY=$(importKey) ", "SYMKYE", "char(Max(FWKYID))", cntFWKYID) %if (cntFWKYID=="")  @dtw_assign(cntFWKYID, "0") %endif	
      @dtw_format(cntFWKYSQ, "3", "0", cntFWKYSQ)
      @dtw_add("1", cntFWKYID, W_FWKYID)
      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Insert Into SYMKYE (FWXHND,           FWIMKY,       FWIFIL,          FWRTYP,               FWMFIL,            FWPFIL,                   FWKYID,     FWKYSQ,FWKYPS,FWKYLN) ", stmtSQL)
      @dtw_concat(stmtSQL, "            Values ('$(profileHandle)',$(importKey),'$(importTable)','$(importRecordType)','$(interfaceTable)','$(parentInterfaceTable)',$(W_FWKYID),0     ,0     ,0) ", stmtSQL)
      @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)
      @dtw_add(ux, "1", ux)
  %endif

  @RtvFldDesc("FWXHND='$(profileHandle)' and FWIMKY=$(importKey) ", "SYMKYE", "char(count(*))", recCount)	
  @dtw_assign(editVariables, "")
  @dtw_assign(ux, "1")
  %while(ux <= recCount){
      @dtw_assign(recNbr, ux)
      %while(@dtw_rlength(recNbr) != "4") {@dtw_insert("0", recNbr, recNbr)%}
      %if (editVariables != "")
          @dtw_concat(editVariables, "  &&", editVariables)
      %endif
      @dtw_concat(editVariables, " editNum(document.Chg.sq$(recNbr), 3, 2) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.ps$(recNbr), 5, 0) && ", editVariables)
      @dtw_concat(editVariables, " editNum(document.Chg.ln$(recNbr), 2, 0) ", editVariables)
      @dtw_add(ux, "1", ux)
  %}

  @dtw_subtract(ux, "1", LastCol)
  %while(@dtw_rlength(LastCol) != "4") {@dtw_insert("0", LastCol, LastCol)%}

  %INCLUDE "$(docType)"
  <html>
      <head>
 	   %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function confirmDelete() {return confirm("$(delRecordConf)")}
              function confirmRefresh() { return confirm("Confirm refresh of columns")}
              function validate(chgForm) {
                  if ($(editVariables))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "MAPIMPORTKEYMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select SYMKYE.*,  ", stmtSQL)
                      @dtw_concat(stmtSQL, " Case WHEN FWKYSQ > 0 THEN 'A' ELSE 'B' END as Section", stmtSQL)
                      @dtw_concat(stmtSQL, " From SYMKYE ", stmtSQL)
                      @dtw_concat(stmtSQL, " Where FWXHND='$(profileHandle)' and FWIMKY=$(importKey) ", stmtSQL)
                      @dtw_concat(stmtSQL, " Order By Section,FWKYSQ,FWKYPS ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  <a href="javascript:document.Chg.updateOption.value=' '; check(document.Chg)">$(editNoUpdateSml)</a>
                  %if ((sec_01 != "N" && (maintenanceCode == "A" || maintenanceCode == "Z")) || (sec_02 != "N" && maintenanceCode == "C") || (maintenanceCode != "A" && maintenanceCode != "C" && maintenanceCode != "D" && maintenanceCode != "Z"))
                      <a href="javascript:document.Chg.updateOption.value='U'; check(document.Chg)">$(acceptImageMed)</a>
                  %endif
                  <a href="javascript:history.back()">$(cancelImageMed)</a>
                  %if (sec_03 != "N" && maintenanceCode == "C")
                      <a onClick="return confirmDelete()" href="$(deleteURL)">$(deleteImageMed)</a>
                  %endif
                  <a onClick="return confirmRefresh()" href="$(refreshURL)">$(selectResetImage)</a>
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>
      <table $(contentTable)>
          @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "FHDESC", V_FHDESC)
          @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "CHAR(FHMPKY)", V_FHMPKY)
          @Format_Header("Import Definition", $(V_FHDESC), $(importKey))

          @RtvFldDesc("MHMPKY=$(V_FHMPKY)", "SYMMHD", "MHDESC", V_MHDESC)
          @RtvFldDesc("MHMPKY=$(V_FHMPKY)", "SYMMHD", "MHWPGM", V_MHWPGM)
          @Format_Header("Map Definition", $(V_MHDESC), $(V_MHWPGM))
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
		
      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          @dtw_assign(once, "")
          <table $(contentTable)>
              %ROW {
                  %if (once == "")
                      %if (passedImportTable != "")
                          @dtw_assign(specificTable, passedImportTable)
                          @dtw_assign(V_FWIFIL, passedImportTable)
                      %else
                          @RtvFldDesc("FFIMKY=$(importKey)", "SYMITB", "CHAR(COUNT(*))", recCount)
                          %if (recCount == "1")
                              @RtvFldDesc("FFIMKY=$(importKey)", "SYMITB", "MAX(FFIFIL)", specificTable)
                              @dtw_assign(V_FWIFIL, specificTable)
                          %else
                              @dtw_assign(specificTable, "")
                          %endif
                      %endif

                      %if (limitRecordType == "Y")
                          @dtw_assign(specificRecordType, passedRecordType)
                          @dtw_assign(V_FWRTYP, passedRecordType)
                      %else
                          %if (passedImportTable == "")
                              @RtvFldDesc("FFIMKY=$(importKey)", "SYMITB", "CHAR(COUNT(*))", recCount)
                              @RtvFldDesc("FFIMKY=$(importKey) and FFRTPS>0 ", "SYMITB", "char(Count(*))", recordTypeTables)
                              @RtvFldDesc("FRIMKY=$(importKey)", "SYMIRT", "CHAR(COUNT(*))", recordTypeCount)
                          %else
                              @RtvFldDesc("FFIMKY=$(importKey) and FFIFIL='$(passedImportTable)'", "SYMITB", "CHAR(COUNT(*))", recCount)
                              @RtvFldDesc("FFIMKY=$(importKey) and FFIFIL='$(passedImportTable)' and FFRTPS>0 ", "SYMITB", "char(Count(*))", recordTypeTables)
                              @RtvFldDesc("FRIMKY=$(importKey) and FRIFIL='$(passedImportTable)'", "SYMIRT", "CHAR(COUNT(*))", recordTypeCount)
                          %endif
                          %if (recordTypeTables == recCount && recordTypeCount=="1")
                              @dtw_assign(limitRecordType, "Y")
                              %if (passedImportTable == "")
                                  @RtvFldDesc("FRIMKY=$(importKey)", "SYMIRT", "MAX(FRRTYP)", specificRecordType)
                              %else
                                  @RtvFldDesc("FRIMKY=$(importKey) and FRIFIL='$(passedImportTable)'", "SYMIRT", "MAX(FRRTYP)", specificRecordType)
                              %endif
                              @dtw_assign(V_FWRTYP, specificRecordType)
                          %else
                              @dtw_assign(specificRecordType, "")
                          %endif
                      %endif

                      %if (errFound != "")
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@ifil", "importTable")          @dtw_assign(Err_FWIFIL, fieldValue)
                          @DecatErr_Field("@@rtyp", "importRecordType")     @dtw_assign(Err_FWRTYP, fieldValue)
                          @DecatErr_Field("@@mfil", "interfaceTable")       @dtw_assign(Err_FWMFIL, fieldValue)
                          @DecatErr_Field("@@pfil", "parentInterfaceTable") @dtw_assign(Err_FWPFIL, fieldValue)

                          @dtw_assign(errFound, "")
                      %elif (maintenanceCode != "Z" && LastCol > "1")
                          @dtw_assign(focusField, "sq$(LastCol)")
                      %elif ((maintenanceCode == "A" || maintenanceCode == "Z") && specificTable == "")
                          @dtw_assign(focusField, "importTable")
                      %elif ((maintenanceCode == "A" || maintenanceCode == "Z") && limitRecordType == "" && recordTypeCount> "0")
                          @dtw_assign(focusField, "importRecordType")
                      %elif (maintenanceCode == "A" || maintenanceCode == "Z")
                          @dtw_assign(focusField, "interfaceTable")
                      %else
                          @dtw_assign(focusField, "sq$(LastCol)")
                      %endif

                      <tr><td><input type="hidden" name="keyRecords" value="$(LastCol)"></td></tr>
                      <tr><td><input type="hidden" name="updateOption"></td></tr>

                      @RtvFldDesc("FFIMKY=$(importKey) and FFIFIL='$(V_FWIFIL)'", "SYMITB", "FFDESC", fieldDesc)
                      @SetTextOvr(Err_FWIFIL)
                      <tr><td class="dsphdr"><span $(textOvr)>Import Table</span></td>
                          %if ((maintenanceCode == "A" || maintenanceCode == "Z") && specificTable == "")
                              <td class="inputalph"><input type="text" name="importTable" value="$(V_FWIFIL)" size="10" maxlength="10">
                                                    <a href="$(homeURL)$(cGIPath)MapImportTableSearch.d2w/REPORT$(d2wVarBase)&amp;specificImportKey=@dtw_rurlescseq(importKey)&amp;docName=Chg&amp;fldName=importTable&amp;fldDesc=importTableDesc" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage)</a>
                                                    <input type="text" disabled name="importTableDesc" value="$(fieldDesc)" size="30"></td>
                          %else
                              <td class="inputalph"><input type="hidden" name="importTable" value="$(V_FWIFIL)">$(V_FWIFIL) $(fieldDesc)
                                                    <input type="hidden" name="importTableDesc"></td>
                          %endif
                      </tr>
                      @DspErrMsg(Err_FWIFIL)

                      %if (specificTable != "")
                          @RtvFldDesc("FFIMKY=$(importKey) and FFIFIL='$(specificTable)'", "SYMITB", "char(FFRTLN)", V_FFRTLN)
                      %else
                          @RtvFldDesc("FFIMKY=$(importKey) ", "SYMITB", "char(max(FFRTLN))", V_FFRTLN)
                      %endif
                      @RtvFldDesc("FRIMKY=$(importKey) and FRIFIL='$(V_FWIFIL)' and FRRTYP='$(V_FWRTYP)'", "SYMIRT", "FRDESC", fieldDesc)
                      @SetTextOvr(Err_FWRTYP)
                      <tr><td class="dsphdr"><span $(textOvr)>Row Type</span></td>
                          %if ((maintenanceCode == "A" || maintenanceCode == "Z") && limitRecordType == "" && recordTypeCount> "0")
                              <td class="inputalph"><input type="text" name="importRecordType" value="$(V_FWRTYP)" size="10" maxlength="$(V_FFRTLN)">
                                                    <a href="$(homeURL)$(cGIPath)MapImportRecordTypeSearch.d2w/REPORT$(d2wVarBase)&amp;specificImportTable=@dtw_rurlescseq(passedImportTable)&amp;docName=Chg&amp;fldTable=importTable&amp;fldTableDesc=importTableDesc&amp;fldName=importRecordType&amp;fldDesc=importRecordTypeDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                    <input type="text" disabled name="importRecordTypeDesc" value="$(fieldDesc)" size="30"></td>
                          %else
                              <td class="inputalph"><input type="hidden" name="importRecordType" value="$(V_FWRTYP)">$(V_FWRTYP) $(fieldDesc)</td>
                          %endif
                      </tr>
                      @DspErrMsg(Err_FWRTYP)

                      @RtvFldDesc("MFMPKY=$(V_FHMPKY) and MFMFIL='$(V_FWMFIL)'", "SYMMTB", "MFDESC", fieldDesc)
                      @SetTextOvr(Err_FWMFIL)
                      <tr><td class="dsphdr"><span $(textOvr)>Interface Table</span></td>
                          %if (maintenanceCode == "A" || maintenanceCode == "Z")
                              <td class="inputalph"><input type="text" name="interfaceTable" value="$(V_FWMFIL)" size="10" maxlength="10">
                                                    <a href="$(homeURL)$(cGIPath)MapTableSearch.d2w/REPORT$(genericVarBase)&amp;specificMapKey=@dtw_rurlescseq(V_FHMPKY)&amp;docName=Chg&amp;fldName=interfaceTable&amp;fldDesc=interfaceTableDesc" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage)</a>
                                                    <input type="text" disabled name="interfaceTableDesc" value="$(fieldDesc)" size="30"></td>
                          %else
                              <td class="inputalph"><input type="hidden" name="interfaceTable" value="$(V_FWMFIL)">$(V_FWMFIL) $(fieldDesc)</td>
                          %endif
                      </tr>
                      @DspErrMsg(Err_FWMFIL)

                      @RtvFldDesc("MFMPKY=$(V_FHMPKY) and MFMFIL='$(V_FWPFIL)'", "SYMMTB", "MFDESC", fieldDesc)
                      @SetTextOvr(Err_FWPFIL)
                      <tr><td class="dsphdr"><span $(textOvr)>Parent Interface Table</span></td>
                          %if (maintenanceCode == "A" || maintenanceCode == "Z")
                              <td class="inputalph"><input type="text" name="parentInterfaceTable" value="$(V_FWPFIL)" size="10" maxlength="10">
                                                    <a href="$(homeURL)$(cGIPath)MapTableSearch.d2w/REPORT$(genericVarBase)&amp;specificMapKey=@dtw_rurlescseq(V_FHMPKY)&amp;docName=Chg&amp;fldName=parentInterfaceTable&amp;fldDesc=parentInterfaceTableDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                    <input type="text" disabled name="parentInterfaceTableDesc" value="$(fieldDesc)" size="30"></td>
                          %else
                              <td class="inputalph"><input type="hidden" name="parentInterfaceTable" value="$(V_FWPFIL)">$(V_FWPFIL) $(fieldDesc)</td>
                          %endif
                      </tr>
                      @DspErrMsg(Err_FWPFIL)
                  </table>

                  <table $(contentTable)>
                      <tr>
                          <td class="colhdr">Sequence</td>
                          <td class="colhdr">Key Position/<br>Placement</td>
                          <td class="colhdr">Key Length</td>
                      </tr>
                      @dtw_assign(once, "Y")
                  %endif

                      @dtw_assign(recNbr, $(ROW_NUM))
                      %while(@dtw_rlength(recNbr) != "4") {@dtw_insert("0", recNbr, recNbr)%}
                      <tr>
                          <td class="inputnmbr"><input type="text"   name="sq$(recNbr)" value="$(V_FWKYSQ)" size="6" maxlength="6"></td>
                          <td class="inputnmbr"><input type="text"   name="ps$(recNbr)" value="$(V_FWKYPS)" size="5" maxlength="5"></td>
                          <td class="inputnmbr"><input type="text"   name="ln$(recNbr)" value="$(V_FWKYLN)" size="2" maxlength="2"></td>
                          %if (V_FWMSG# != "")
                              %if (focusField == "")
                                  @dtw_assign(focusField, "sq$(recNbr)")
                              %endif
                              @Ret_Error_Msg(profileHandle, dataBaseID, $(V_FWMSG#), errorMessage)
                              <td class="error">$(errorMessage)</td>		
                          %endif
                      </tr>
                      <tr><td><input type="hidden" name="id$(recNbr)" value="$(V_FWKYID)"></td></tr>
              %}
          </table>
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      <table $(contentTable)>
          <tr>
              <td class="toolbar">
                  <a href="javascript:document.Chg.updateOption.value=' '; check(document.Chg)">$(editNoUpdateSml)</a>
                  %if ((sec_01 != "N" && (maintenanceCode == "A" || maintenanceCode == "Z")) || (sec_02 != "N" && maintenanceCode == "C") || (maintenanceCode != "A" && maintenanceCode != "C" && maintenanceCode != "D" && maintenanceCode != "Z"))
                      <a href="javascript:document.Chg.updateOption.value='U'; check(document.Chg)">$(acceptImageMed)</a>
                  %endif
                  <a href="javascript:history.back()">$(cancelImageMed)</a>
                  %if (sec_03 != "N" && maintenanceCode == "C")
                      <a onClick="return confirmDelete()" href="$(deleteURL)">$(deleteImageMed)</a>
                  %endif
                  <a onClick="return confirmRefresh()" href="$(refreshURL)">$(selectResetImage)</a>
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSYIKM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(REFRESH) {
  %INCLUDE "setLibraryList.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Delete From SYMKYE Where FWXHND='$(profileHandle)' and FWIMKY=$(importKey) ", stmtSQL)
  @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
  @SQL_Update(stmtSQL, status)

  @Set_SQL(stmtSQL)
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @dtw_mUPPERCASE(importTable)
  @dtw_mUPPERCASE(importRecordType)
  @dtw_mUPPERCASE(interfaceTable)
  @dtw_mUPPERCASE(parentInterfaceTable)

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Delete From SYMKYE Where FWXHND='$(profileHandle)' and FWIMKY=$(importKey) ", stmtSQL)
  @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
  @SQL_Update(stmtSQL, status)

  @dtw_assign(ux, "1")
  %while(ux <= keyRecords){
      @dtw_assign(recNbr, ux)
      %while(@dtw_rlength(recNbr) != "4") {@dtw_insert("0", recNbr, recNbr)%}
      @dtw_assign(seq, $(sq$(recNbr)))   %if (seq=="")  @dtw_assign(seq, "0") %endif
      @dtw_assign(plc, $(ps$(recNbr)))   %if (plc=="")  @dtw_assign(plc, "0") %endif
      @dtw_assign(lng, $(ln$(recNbr)))   %if (lng=="")  @dtw_assign(lng, "0") %endif
      @dtw_assign(id,  $(id$(recNbr)))   %if (id=="")   @dtw_assign(id, "0") %endif

      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Insert Into SYMKYE (FWXHND,           FWIMKY,       FWIFIL,          FWRTYP,               FWMFIL,             FWPFIL,                  FWKYID,FWKYSQ,FWKYPS,FWKYLN) ", stmtSQL)
      @dtw_concat(stmtSQL, "            Values ('$(profileHandle)',$(importKey),'$(importTable)','$(importRecordType)','$(interfaceTable)','$(parentInterfaceTable)',$(id), $(seq),$(plc),$(lng)) ", stmtSQL)
      @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)

      @dtw_add(ux, "1", ux)
  %}

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@frm1", fromImportKey)
  @Concat_Field("@@imky", importKey)
  @Concat_Field("@@ifil", importTable)
  @Concat_Field("@@rtyp", importRecordType)
  @Concat_Field("@@mfil", interfaceTable)
  @Concat_Field("@@pfil", parentInterfaceTable)
  @Concat_Field("@@@upd", updateOption)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)
  %if (errFound == "" && updateOption=="U")
      @RtvFldDesc("FFIMKY=$(importKey) and FFIFIL='$(importTable)'", "SYMITB", "FFDESC", importTableDescription)
      @Format_ConfMsg_Desc(maintenanceCode, $(importTableDescription), "$(importTable)-$(importRecordType)-$(interfaceTable)-$(parentInterfaceTable)", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@desc", "mapKey")
      @Format_ConfMsg_Desc("", $(mapKeyDescription), $(mapKey), "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)MapImportKey.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;importTable=@dtw_rurlescseq(importTable)&amp;importRecordType=@dtw_rurlescseq(importRecordType)&amp;interfaceTable=@dtw_rurlescseq(interfaceTable)&amp;parentInterfaceTable=@dtw_rurlescseq(parentInterfaceTable)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
