%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NoteComment.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Note Search"
  d2wName                 = "NoteSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;feature=@dtw_rurlescseq(feature)&amp;featureDesc=@dtw_rurlescseq(featureDesc)&amp;option=@dtw_rurlescseq(option)&amp;featuredItem=@dtw_rurlescseq(featuredItem)&amp;configurationType=@dtw_rurlescseq(configurationType)&amp;configurationID=@dtw_rurlescseq(configurationID)&amp;mfgOrder=@dtw_rurlescseq(mfgOrder)&amp;sequenceNumber=@dtw_rurlescseq(sequenceNumber)&amp;docName=@dtw_rurlescseq(docName)&amp;fldComment=@dtw_rurlescseq(fldComment)&amp;plantName=@dtw_rurlescseq(plantName)&amp;itemDescription=@dtw_rurlescseq(itemDescription)&amp;documentType=@dtw_rurlescseq(documentType)&amp;docDescr=@dtw_rurlescseq(docDescr)&amp;noteFile=@dtw_rurlescseq(noteFile)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectNote(note){
                  window.opener.document.$(docName).$(fldComment).value += note;
                  window.opener.document.$(docName).$(fldComment).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(distinctSQL, "DODOCT concat DODESC ", distinctSQL)
                      @dtw_concat(stmtSQL, " Select DODOCT, DODESC, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(DODESC) as DODESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " HDDOCT ", fileSQL)
                      %if (noteFile == "HDMARN")
                          @dtw_concat(selectSQL, " Exists (Select * From $(noteFile) ", selectSQL)
                          @dtw_concat(selectSQL, " Where ADPLT=$(plantNumber) ", selectSQL)
                          @dtw_concat(selectSQL, " and ADITEM='$(itemNumber)' ", selectSQL)
                          @dtw_concat(selectSQL, " and ADCFGT='$(configurationType)' ", selectSQL)
                          @dtw_concat(selectSQL, " and ADCFGI='$(configurationID)' ", selectSQL)
                          @dtw_concat(selectSQL, " and ADSEQN=$(sequenceNumber) ", selectSQL)
                          @dtw_concat(selectSQL, " and ADDOCT=DODOCT) ", selectSQL)
                      %elif (noteFile == "HDMFOD" && option == "")
                          @dtw_concat(selectSQL, " Exists (Select * From $(noteFile) ", selectSQL)
                          @dtw_concat(selectSQL, " Where ODPLT=$(plantNumber) ", selectSQL)
                          @dtw_concat(selectSQL, " and ODFEAT='$(feature)' ", selectSQL)
                          @dtw_concat(selectSQL, " and ODFITM='$(featuredItem)' ", selectSQL)
                          @dtw_concat(selectSQL, " and ODSEQN=$(sequenceNumber) ", selectSQL)
                          @dtw_concat(selectSQL, " and ODDOCT=DODOCT) ", selectSQL)
                      %elif (noteFile == "HDMFOD" && option != "")
                          @dtw_concat(selectSQL, " Exists (Select * From $(noteFile) ", selectSQL)
                          @dtw_concat(selectSQL, " Where ODPLT=$(plantNumber) ", selectSQL)
                          @dtw_concat(selectSQL, " and ODFEAT='$(option)' ", selectSQL)
                          @dtw_concat(selectSQL, " and ODFITM='$(feature)' ", selectSQL)
                          @dtw_concat(selectSQL, " and ODSEQN=$(sequenceNumber) ", selectSQL)
                          @dtw_concat(selectSQL, " and ODDOCT=DODOCT) ", selectSQL)
                      %elif (noteFile == "HDMODM")
                          @dtw_concat(selectSQL, " Exists (Select * From $(noteFile) ", selectSQL)
                          @dtw_concat(selectSQL, " Where ODPLT=$(plantNumber) ", selectSQL)
                          @dtw_concat(selectSQL, " and ODPN='$(itemNumber)' ", selectSQL)
                          @dtw_concat(selectSQL, " and ODSEQN=$(sequenceNumber) ", selectSQL)
                          @dtw_concat(selectSQL, " and ODDOCT=DODOCT) ", selectSQL)
                      %elif (noteFile == "HDMLOD")
                          @dtw_concat(selectSQL, " Exists (Select * From $(noteFile) ", selectSQL)
                          @dtw_concat(selectSQL, " Where OLPLT=$(plantNumber) ", selectSQL)
                          @dtw_concat(selectSQL, " and OLMORD='$(mfgOrder)' ", selectSQL)
                          @dtw_concat(selectSQL, " and OLSEQN=$(sequenceNumber) ", selectSQL)
                          @dtw_concat(selectSQL, " and OLDOCT=DODOCT) ", selectSQL)
                      %elif (noteFile == "HDKBCM")
                          @dtw_concat(selectSQL, " Exists (Select * From $(noteFile) ", selectSQL)
                          @dtw_concat(selectSQL, " Where KCPLT=$(plantNumber) ", selectSQL)
                          @dtw_concat(selectSQL, " and KCITEM='$(itemNumber)' ", selectSQL)
                          @dtw_concat(selectSQL, " and KCDOCT=DODOCT) ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Group By DODOCT, DODESC ", stmtSQL)
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @NoteSearch_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
     </body>
  </html>
%}

%FUNCTION(dtw_sql) NoteSearch_Query (IN CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(displayCloseIcon, "Y")
      %INCLUDE "PageTitle.icl"

      %if (noteFile == "HDMARN")
          @RtvFldDesc("CHPLT=$(plantNumber) and CHITEM='$(itemNumber)' and CHCFGT='$(configurationType)' and CHCFGI='$(configurationID)' ", "HDCFGH", "CHCDSC", ConfigTypeDescription)
      %elseif (noteFile == "HDMFOD" && option != "")
          @RtvFldDesc("IMITEM='$(option)'", "HDIMST", "IMIMDS", optionDesc)
      %endif

      <table $(contentTable)>
          @Format_Header("Plant", $(plantName), $(plantNumber))
          %if (noteFile == "HDMARN")
              @Format_Header("Item", $(itemDescription), $(itemNumber))
              @Format_Header("Type/ID", $(ConfigTypeDescription), "$(configurationType)/$(configurationID)")
              @Format_Header("Sequence", $(sequenceNumber), "")
          %elif (noteFile == "HDMFOD" && option == "")
              @Format_Header("Feature", $(featureDesc), $(feature))
              %if (featuredItem != "")
                  @Format_Header("Featured Item/Family", $(itemDescription), $(featuredItem))
              %endif
              @Format_Header("Sequence", $(sequenceNumber), "")
          %elif (noteFile == "HDMFOD" && option != "")
              @Format_Header("Option", $(optionDesc), $(option))
              %if (feature != "")
                  @Format_Header("Feature", $(featureDesc), $(feature))
              %endif
              @Format_Header("Sequence", $(sequenceNumber), "")
          %elif (noteFile == "HDMODM")
              @Format_Header("Item", $(itemDescription), $(itemNumber))
              @Format_Header("Sequence", $(sequenceNumber), "")
          %elif (noteFile == "HDMLOD")
              @Format_Header("Mfg Order", $(mfgOrder), "")
              @Format_Header("Sequence", $(sequenceNumber), "")
          %elif (noteFile == "HDKBCM")
              @Format_Header("Item", $(itemDescription), $(itemNumber))
          %endif
      </table>

      $(searchhrTagAttr)

      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr"> Document </th>
                  <th class="colhdr"> Description </th></tr>
              <tr><td align=center><input type="text" class="inputalph" name="srchDoc" size="7" maxlength="3">
                      <input type="hidden" name="operDoc" value="LIKE">
                  </td>
                  <td><input type="text" class="inputalph" name="srchDesc" size="30" maxlength="30">
                      <input type="hidden" name="operDesc" value="LIKE">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
          <script TYPE="text/javascript">
              document.Search.srchDoc.focus();
          </script>
      </form>

      %INCLUDE "WildCardPage.icl"

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              @OrderBy_Sort("DODOCT", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=document" title="Sequence By Document"> Document</a></th>
              @OrderBy_Sort("DODESCU", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=description" title="Sequence By Description, Document"> Description</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @dtw_assign(fromDocument, "$(V_DODOCT)")
              %if (noteFile == "HDMARN")
                  @Get_Alternate_Notes(profileHandle, dataBaseID, plantNumber, itemNumber, configurationType, configurationID, sequenceNumber, fromDocument, comment)
              %elif (noteFile == "HDMFOD" && option == "")
                  @Get_Feature_Notes(profileHandle, dataBaseID, plantNumber, feature, featuredItem, sequenceNumber, fromDocument, comment)
              %elif (noteFile == "HDMFOD" && option != "")
                  @Get_Option_Notes(profileHandle, dataBaseID, plantNumber, option, feature, sequenceNumber, fromDocument, comment)
              %elif (noteFile == "HDMODM")
                  @Get_Routing_Notes(profileHandle, dataBaseID, plantNumber, itemNumber, sequenceNumber, fromDocument, comment)
              %elif (noteFile == "HDMLOD")
                  @Get_Labor_Notes(profileHandle, dataBaseID, plantNumber, mfgOrder, sequenceNumber, fromDocument, comment)
              %elif (noteFile == "HDKBCM")
                  @Get_Kanban_Comments(profileHandle, dataBaseID, plantNumber, itemNumber, fromDocument, comment)
              %endif
              @DTW_CHARTOHEX(comment, cmtHex)
              @DTW_POS("0D", cmtHex, dPos)
              @dtw_assign(beg, "1")
              @dtw_assign(inc, "0")
              %while(dPos > "0") {
                  @DTW_SUBTRACT(dPos, "1", end)
                  @DTW_DIVREM(end, "2", result)
                  %if (result == "0")
                      @DTW_divide(end, "2", str)
                      @DTW_add(str, inc, str)
                      @DTW_INSERT("\r", comment, str, comment)
                      @DTW_add(inc, "2", inc)
                  %endif
                  @DTW_ADD(dPos, "2", beg)
                  @DTW_POS("0D", cmtHex, beg, dPos)
              %}
              
              @Format_Quote(comment, F_comment)
              <tr class="$(rowClass)">
                  <td class="colalph">$(V_DODOCT)</td>
                  <td class="colalph"><a href="javascript:selectNote('$(F_comment)')" title="Select Notes">$(V_DODESC)</a></td>
                  <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/VIEW$(d2wVarBase)&amp;fromDocument=@dtw_rurlescseq(V_DODOCT)&amp;fromDocumentDesc=@dtw_rurlescseq(V_DODESC)" title="View Notes">$(moreInfoImage)</a></td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Display_Comments () {	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectNote(note){
                  window.opener.document.$(docName).$(fldComment).value += note;
                  window.opener.document.$(docName).$(fldComment).focus();
                  window.close();
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table width="100%" $(contentTable)>
              <tr valign="top">
                  <td>
                      %if (noteFile == "HDMARN")
                          @Get_Alternate_Notes(profileHandle, dataBaseID, plantNumber, itemNumber, configurationType, configurationID, sequenceNumber, fromDocument, comment)
                      %elif (noteFile == "HDMFOD" && option == "")
                          @Get_Feature_Notes(profileHandle, dataBaseID, plantNumber, feature, featuredItem, sequenceNumber, fromDocument, comment)
                      %elif (noteFile == "HDMFOD" && option != "")
                          @Get_Option_Notes(profileHandle, dataBaseID, plantNumber, option, feature, sequenceNumber, fromDocument, comment)
                      %elif (noteFile == "HDMODM")
                          @Get_Routing_Notes(profileHandle, dataBaseID, plantNumber, itemNumber, sequenceNumber, fromDocument, comment)
                      %elif (noteFile == "HDMLOD")
                          @Get_Labor_Notes(profileHandle, dataBaseID, plantNumber, mfgOrder, sequenceNumber, fromDocument, comment)
                      %elif (noteFile == "HDKBCM")
                          @Get_Kanban_Comments(profileHandle, dataBaseID, plantNumber, itemNumber, fromDocument, comment)
                      %endif
                      @Format_Quote(comment, F_comment)
                      <table $(contentTable)>
                          <tr><td><h1>$(page_title)</h1></td>
                              <td class="toolbar">
                                  <a href="javascript:selectNote('$(F_comment)')" title="Select Note">$(copyImageLrg)</a>
                                  %INCLUDE "CloseWindow.icl"
                              </td>
                          </tr>
                      </table>

                      %if (noteFile == "HDMARN")
                          @RtvFldDesc("CHPLT=$(plantNumber) and CHITEM='$(itemNumber)' and CHCFGT='$(configurationType)' and CHCFGI='$(configurationID)' ", "HDCFGH", "CHCDSC", ConfigTypeDescription)
                      %elseif (noteFile == "HDMFOD" && option != "")
                          @RtvFldDesc("IMITEM='$(option)'", "HDIMST", "IMIMDS", optionDesc)
                      %endif

                      <table $(contentTable)>
                           @Format_Header("Plant", $(plantName), $(plantNumber))
                           %if (noteFile == "HDMARN")
                               @Format_Header("Item", $(itemDescription), $(itemNumber))
                               @Format_Header("Type/ID", $(ConfigTypeDescription), "$(configurationType)/$(configurationID)")
                               @Format_Header("Sequence", $(sequenceNumber), "")
                           %elif (noteFile == "HDMFOD" && option == "")
                               @Format_Header("Feature", $(featureDesc), $(feature))
                               %if (featuredItem != "")
                                   @Format_Header("Featured Item/Family", $(itemDescription), $(featuredItem))
                               %endif
                               @Format_Header("Sequence", $(sequenceNumber), "")
                           %elif (noteFile == "HDMFOD" && option != "")
                               @Format_Header("Option", $(optionDesc), $(option))
                               %if (feature != "")
                                   @Format_Header("Feature", $(featureDesc), $(feature))
                               %endif
                               @Format_Header("Sequence", $(sequenceNumber), "")
                           %elif (noteFile == "HDMODM")
                               @Format_Header("Item", $(itemDescription), $(itemNumber))
                               @Format_Header("Sequence", $(sequenceNumber), "")
                           %elif (noteFile == "HDMLOD")
                               @Format_Header("Mfg Order", $(mfgOrder), "")
                               @Format_Header("Sequence", $(sequenceNumber), "")
                           %elif (noteFile == "HDKBCM")
                               @Format_Header("Item", $(itemDescription), $(itemNumber))
                           %endif
                      </table>
                      <table $(contentTable)>
                          <tr align="center"><td><h2>$(fromDocumentDesc)</h2></td></tr>
                          <tr><td><textarea ROWS=20 COLS=60 WRAP="hard">$(comment)</textarea></td></tr>
                      </table>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(VIEW) {
  %INCLUDE "setLibraryList.icl"
  @Display_Comments ()
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "DODESCU,DODOCT")
      @DTW_ASSIGN(orderByDisplay, "Description, Document")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "document")
      %if (orderBy == "DODOCT")
          @DTW_ASSIGN(orderBy, "DODOCT DESC")
          @DTW_ASSIGN(orderByDisplay, "Document (descending)")
      %else
          @DTW_ASSIGN(orderBy, "DODOCT")
          @DTW_ASSIGN(orderByDisplay, "Document")
      %endif
  %elif (sequence == "description")
      %if (orderBy == "DODESCU,DODOCT")
          @DTW_ASSIGN(orderBy, "DODESCU DESC,DODOCT")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Document")
      %else
          @DTW_ASSIGN(orderBy, "DODESCU,DODOCT")
          @DTW_ASSIGN(orderByDisplay, "Description, Document")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("DODOCT", "Document", $(srchDoc), "U", operDoc, "A")
  @Build_WildCard ("upper(DODESC)", "Description", $(srchDesc), "U", operDesc, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}