%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "SalesOrderStatus.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Sales Order Status"
  d2wName                 = "SalesOrderStatus.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;shipTo=@dtw_rurlescseq(shipTo)&amp;customerName=@dtw_rurlescseq(customerName)&amp;billTo=@dtw_rurlescseq(billTo)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;orderType=@dtw_rurlescseq(orderType)&amp;orderDate=@dtw_rurlescseq(orderDate)&amp;reqDate=@dtw_rurlescseq(reqDate)&amp;refNumber=@dtw_rurlescseq(refNumber)&amp;deptView=@dtw_rurlescseq(deptView)&amp;pctView=@dtw_rurlescseq(pctView)&amp;inclComponent=@dtw_rurlescseq(inclComponent)&amp;inclCompleted=@dtw_rurlescseq(inclCompleted)&amp;thruReqDate=@dtw_rurlescseq(thruReqDate)"
  currentURL              = "$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  DTW_PAD_PGM_PARMS       = "YES"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"	
  type                    = "O"
  orderSequence           = "0"
  inclComponent           = ""
  inclCompleted           = ""
  deptView                = ""
  pctView                 = ""
  thruReqDate             = ""
  pctHours                = "H"
  zero                    = "0"
%}

%FUNCTION(DTW_directcall) Get_Name_Address (INOUT CHAR(64)     profileHandle,
                                                  CHAR(2)      dataBaseID,
                                                  DECIMAL(8,0) orderNumber,
                                                  DECIMAL(3,0) orderSequence,
                                                  CHAR(1)      type,
                                                  char(30)     shipToName,
                                                  char(30)     shipToAdrOne,
                                                  char(30)     shipToAdrTwo,
                                                  char(30)     shipToAdrThree,
                                                  char(26)     shipToCity,
                                                  char(2)      shipToState,
                                                  char(13)     shipToZip,
                                                  char(1)      dropShip,
                                                  char(30)     billToName,
                                                  char(30)     billToAdrOne,
                                                  char(30)     billToAdrTwo,
                                                  char(30)     billToAdrThree,
                                                  char(26)     billToCity,
                                                  char(2)      billToState,
                                                  char(13)     billToZip,
                                                  char(40)     orderTypeDesc,
                                                  char(23)     uDFDescriptionOne,
                                                  char(23)     uDFDescriptionTwo,
                                                  char(23)     uDFDescriptionThree,
                                                  char(23)     uDFDescriptionFour,
                                                  char(23)     uDFDescriptionFive)

{%EXEC {HOEONA_W.PGM %}
%}

%FUNCTION(DTW_directcall) Get_MfgOrder_Hours (INOUT DECIMAL(3,0)  plantNumber,
                                                    CHAR(9)       mfgOrder,
                                                    DECIMAL(3,0)  laborSeq,
                                                    DECIMAL(8,0)  orderNumber,
                                                    DECIMAL(13,2) thours,
                                                    DECIMAL(13,2) rhours,
                                                    CHAR(1)       pctView,
                                                    DECIMAL(3,0)  compPct,
                                                    CHAR(1)       includeScrap)
{%EXEC {HSIHRS_W.PGM %}
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @CustomerUserView(profileHandle, dataBaseID, userPass, shipTo, " ")
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @Decat_Field("@@dptv")   @dtw_assign(deptView, fieldValue)
      @Decat_Field("@@pctv")   @dtw_assign(pctView, fieldValue)
      @Decat_Field("@@icmp")   @dtw_assign(inclComponent, fieldValue)
      @Decat_Field("@@icpl")   @dtw_assign(inclCompleted, fieldValue)
      @Decat_Field("@@thru")   @dtw_assign(thruReqDate, fieldValue)
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
                  %INCLUDE "AJAXRequest.icl"
                  %INCLUDE "SaveCurrentURL.icl"
                  %INCLUDE "Menu.js"
	              %INCLUDE "numedit.icl"
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "CheckEnterSearch.icl"
                  %INCLUDE "NoFormValidate.icl"
                  %INCLUDE "calendarAutoSubmit.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- Start Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "SALESORDERSTATUS")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select OEORDT.*,OEORHD.*, OHSTC, OHCPNS, OHLATY, OHQTYR, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(OHPLT,ODPLT) as OHPLT, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(OHORD,' ') as OHORD, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(OHPN,ODITEM) as OHPN, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(OHCQTY,ODQORD) as OHCQTY ", stmtSQL)
                          @dtw_concat(fileSQL, " OEORDT left join HDMOHM on ODORD#=OHORD#", fileSQL)
                          @dtw_concat(fileSQL, " and ODORL#=OHORL# and ODBLN#=OHBLN# ", fileSQL)
                          %if (inclComponent != "Y")
                              @dtw_concat(fileSQL, " and ODITEM=OHPN ", fileSQL)
                          %endif
                          @dtw_concat(fileSQL, " left join OEORHD on OEORD#=ODORD# ", fileSQL)
                          @dtw_concat(selectSQL, "ODORD#=$(orderNumber) and ODBLKT<>'Y' ", selectSQL)
                          %if (thruReqDate > "0")
                              @dtw_assign(thruCYMD, thruReqDate)
                              @DateToCYMD(thruCYMD)
                              @dtw_concat(selectSQL, " and ODRQDT<=$(thruCYMD) ", selectSQL)
                          %endif
                          %if (inclCompleted != "Y")
                              @dtw_concat(selectSQL, "and (OHSTC<>'C' and OHQTYR<OHCQTY or OHSTC is null) ", selectSQL)
                          %endif
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Customer_MfgOrder_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Customer_MfgOrder_Query (IN CHAR(64)    profileHandle,
				                CHAR(2)     dataBaseID,
                                               CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W



  %REPORT{
      @Get_Name_Address(profileHandle,
                        dataBaseID,
                        orderNumber,
                        orderSequence,
                        type,
                        shipToName,
                        shipToAdrOne,
                        shipToAdrTwo,
                        shipToAdrThree,
                        shipToCity,
                        shipToState,
                        shipToZip,
                        dropShip,
                        billToName,
                        billToAdrOne,
                        billToAdrTwo,
                        billToAdrThree,
                        billToCity,
                        billToState,
                        billToZip,
                        orderTypeDesc,
                        uDFDescriptionOne,
                        uDFDescriptionTwo,
                        uDFDescriptionThree,
                        uDFDescriptionFour,
                        uDFDescriptionFive)

          <table $(contentTable)>
              <colgroup>
                  <col width="90%">
                  <col width="5%">
              <tr><td><h1> $(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"
          $(hrTagAttr)

          <table $(contentTable)>
              <colgroup>
                  <col width="30%">
                  <col width="10%">
                  <col width="30%">
                  <col width="10%">
              <tr>
                  %if (dropShip == "Y")
                      <td class="colhdr">Drop Ship</td>
                  %else
                      <td class="colhdr">Ship-To</td>
                  %endif
                  <td>&nbsp;</td>
                  <td class="colhdr">Bill-To</td>
                  <td>&nbsp;</td>
              </tr>
              <tr valign=top>
                  <td rowspan="5" class="dspalph">
                      %if (dropShip == "Y")
                          $(shipToName) <br>
                      %else
                          @Format_Code(shipTo, F_shipTo)
                          <a href="$(homeURL)$(cGIPath)CustomerSelect.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(shipTo)&amp;customerName=@dtw_rurlescseq(shipToName)" title="View Customer">$(shipToName) &nbsp; $(F_shipTo)</a> <br>
                      %endif
                      %if (shipToAdrOne != "")
                          $(shipToAdrOne) <br>
                      %endif
                      %if (shipToAdrTwo != "")
                          $(shipToAdrTwo) <br>
                      %endif
                      %if (shipToAdrThree != "")
                          $(shipToAdrThree) <br>
                      %endif

                      $(shipToCity), $(shipToState) $(shipToZip)
                  </td>

                  <td>&nbsp;</td>

                  @Format_Code(billTo, F_billTo)
                  <td rowspan="5" class="dspalph"><a href="$(homeURL)$(cGIPath)CustomerSelect.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(billTo)&amp;customerName=@dtw_rurlescseq(billToName)" title="View Customer">$(billToName) &nbsp; $(F_billTo)</a> <br>
                      %if (billToAdrOne != "")
                          $(billToAdrOne) <br>
                      %endif
                      %if (billToAdrTwo != "")
                          $(billToAdrTwo) <br>
                      %endif
                      %if (billToAdrThree != "")
                          $(billToAdrThree) <br>
                      %endif

                      $(billToCity), $(billToState) $(billToZip)
                  </td>
              </tr>
          </table>

          <table $(contentTable)>
              <tr><th class="colhdr">Ordered</th>
                  <th class="colhdr">Required</th>
                  <th class="colhdr">Reference<br>Number</th>
                  <th class="colhdr">Order<br>Type</th>
                  <th class="colhdr">Order<br>Number</th>
                  <th class="colhdr">Total<br>Hours</th>
                  <th class="colhdr">Hours<br>Remaining</th>
                  <th class="colhdr">Completion<br>Percent</th>
                  <th class="colhdr">Thru<br>Required Date</th>
              </tr>

              @RtvFldDesc("OEORD#=$(orderNumber) and OEORST='O'", "OEORHD", "OEORST", orderStatus)
              @RtvFldDesc("OTAPID='OE' and OTOTCD='$(orderType)'", "HDOTYP", "OTDESC", orderTypeDesc)
              @Format_Date(reqDate, "D", F_reqDate)
              @Format_Date(orderDate, "D", F_orderDate)
              @Get_MfgOrder_Hours(V_OHPLT, V_OHORD, laborSeq, orderNumber, thours, rhours, pctHours, compPct, includeScrap)
              @Format_Nbr(thours, F_thours, "2", $(hrsEditCode), "Y", "", "")
              @Format_Nbr(rhours, F_rhours, "2", $(hrsEditCode), "Y", "", "")
              @Format_Nbr($(compPct), F_percentOfTotal, "0", $(pctEditCode), "", "", "%")

              <tr class="oddrow">
                  <td class="coldate">$(F_orderDate)</td>
                  <td class="coldate">$(F_reqDate)</td>
                  <td class="colalph">$(refNumber)</td>
                  <td class="colcode" $(helpCursor)><span title="$(orderType)">$(orderTypeDesc)</span></td>
                  %if (orderStatus == "O")
                      <td class="colnmbr"><a onClick="saveCurrentURL();" href="$(homeURL)$(cGIPath)SelectOrder.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(shipTo)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderNumber=@dtw_rurlescseq(orderNumber)" title="View Order Detail">$(orderNumber)</a></td>
                  %else
                      <td class="colnmbr"><a onClick="saveCurrentURL();" href="$(homeURL)$(cGIPath)SelectOrderHistory.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(shipTo)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;orderSequence=000" title="View Shipment Summary">$(orderNumber)</a></td>
                  %endif
                  <td class="colnmbr">$(F_thours)</td>
                  <td class="colnmbr">$(F_rhours)</td>
                  <td class="colnmbr">$(F_percentOfTotal)</td>
                  <form class="formClass" name="Chg" METHOD="POST" action="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)">
                      <td class="colnmbr"><input type="text" name="thruDate" value="$(thruReqDate)" size="6" maxlength="6"><a href="javascript:calWindow('thruDate');">$(calendarImage)</a></td>
                  </form>
              </tr>
          </table>
	
      $(hrTagAttr)	

      %if (formatToPrint != "Y")
          %if (dspSearch == "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Mfg<br>Order</th>
                          <th class="colhdr">Item Number</th>
                      </tr>

                      <tr><td><input type="text" class="inputalph" name="srchOrder" size="9" maxlength="9">
                              <input type="hidden" name="operOrder" value="LIKE">
                          </td>
                          <td><input type="text" class="inputalph" name="srchItem" size="15" maxlength="15">
                              <input type="hidden" name="operItem" value="LIKE">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a>
                          </td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchOrder.focus();
                  </script>
              </form>
          %endif
	
          %if (inclComponent == "Y")
              @dtw_assign(viewComponent, "CHECKED")
          %else
              @dtw_assign(viewComponent, "")
          %endif
	
          %if (inclCompleted == "Y")
              @dtw_assign(viewCompleted, "CHECKED")
          %else
              @dtw_assign(viewCompleted, "")
          %endif

          %if (deptView == "F")
              @dtw_assign(firstChecked, "CHECKED")
              @dtw_assign(lastChecked, "")
          %else
              @dtw_assign(firstChecked, "")
              @dtw_assign(lastChecked, "CHECKED")
          %endif

          %if (V_HDPDRL > "0")
              @dtw_assign(viewCheckBox, "SalesOrderStatus")
          %endif
          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("OHSTC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Status" title="Sequence By Status, Order Number">Sts</a></th>	
              @OrderBy_Sort("OHORD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Order" title="Sequence By Order Number">Mfg<br>Order</a></th>	
              @OrderBy_Sort("ODORL#", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Line" title="Sequence By Line, Release, Order Number)">Line</a></th>	
              @OrderBy_Sort("ODBLN#", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Rel" title="Sequence By Release, Order Number)">Rel</a></th>	
              @OrderBy_Sort("OHPN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Item" title="Sequence By Item Number, Order Number">Item Number</a></th>
              <th class="colhdr">Item Description</th>
              <th class="colhdr">Quantity<br>Ordered</th>
              <th class="colhdr">Quantity<br>Open</th>
              <th class="colhdr">Quantity<br>Received</th>
              <th class="colhdr">Quantity<br>Available</th>
              %if (deptView == "F")
                  <th class="colhdr"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;chgDeptView=Y&amp;START_ROW_NUM=$(START_ROW_NUM)" title="Click here to view Last Reported Department">First Incomplete<br>Department</a></th>
              %else
                  <th class="colhdr"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;chgDeptView=Y&amp;START_ROW_NUM=$(START_ROW_NUM)" title="Click here to view First Incomplete Department">Last Reported<br>Department</a></th>
              %endif
              %if (pctView == "H")
                  <th class="colhdr"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;chgPctView=Y&amp;START_ROW_NUM=$(START_ROW_NUM)" title="Click here to view Quantity Completion Percent">Hours<br>Completion<br>Percent</a></th>
              %else
                  <th class="colhdr"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;chgPctView=Y&amp;START_ROW_NUM=$(START_ROW_NUM)" title="Click here to view Hours Completion Percent">Quantity<br>Completion<br>Percent</a></th>
              %endif
              <th class="colhdr">Quantity<br>Completed<br>Good</th>
              <th class="colhdr">Dept Hours<br>Remaining</th>
              <th class="colhdr">Mfg Order<br>Hours<br>Remaining</th>
              <th class="colhdr">Extended<br>Amount</th>
              @OrderBy_Sort("OHPLT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Plant" title="Sequence By Plant, Order Number">Plant</a></th>
              @OrderBy_Sort("ODWH", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Whs" title="Sequence By Warehouse, Item Number, Order Number">Whs</a></th>	
              @OrderBy_Sort("ODRQDT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ReqDate" title="Sequence By Required Date, Item Number, Order Number">Required<br>Date</a></th>	
          </tr>		
          %INCLUDE "NoRecordsFound.icl"
          @dtw_assign(T_workPrice, "0")
          @dtw_assign(T_rhours, "0")
          @dtw_assign(T_thours, "0")

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(V_OHPLT)&amp;mfgOrder=@dtw_rurlescseq(V_OHORD)")
              @RtvFldDesc("PLPLNT=$(V_OHPLT)", "HDPLNT", "PLNAME", plantName)
              @RtvFldDesc("IMITEM='$(V_OHPN)'", "HDIMST", "IMIMDS", itemDesc)
              @dtw_assign(deptDesc, "")
              @dtw_assign(F_percentOfTotal, "")
              @dtw_assign(F_thours, "")
              @dtw_assign(F_rhours, "")
              @dtw_assign(F_timeLeft, "")
              @dtw_assign(F_qtyGood, "")
              @dtw_assign(workPrice, "0")
              @dtw_assign(timeLeft, "0")
              @dtw_assign(laborSeq, "0")

              %if (V_OHORD != "")
                  %if (V_OHSTC != "C")
                      %if (V_OHLATY == "CR" && deptView == "F")
                          @RtvFldDesc("LPPLT=$(V_OHPLT) and LPORD='$(V_OHORD)' ", "HDMLPM", "coalesce(min(LPSEQN),0)", laborSeq)
                      %else
                          %if (deptView == "F")
                              @RtvFldDesc("LPPLT=$(V_OHPLT)  and LPORD='$(V_OHORD)' and LPALTC<>'A' and LPOPRC<>'Y' and LPQTYC+LPRSCR<$(V_OHCQTY) ", "HDMLPM", "coalesce(min(LPSEQN),0)", laborSeq)
                          %else
                              @RtvFldDesc("LPPLT=$(V_OHPLT) and LPORD='$(V_OHORD)' and LPALTC<>'A' and LPOPRC<>'Y' and ((LPQTYC+LPRSCR<$(V_OHCQTY) and (LPQTYC<>0 or LPRSCR<>0 or LPACTS<>0 or LPACTD<>0)) or (LPTVQT<>0 and LPFVQT<$(V_OHCQTY))) ", "HDMLPM", "coalesce(max(LPSEQN),0)", laborSeq)
                              %if (laborSeq == "0")
                                  @RtvFldDesc("LPPLT=$(V_OHPLT) and LPORD='$(V_OHORD)' and LPALTC<>'A' and (LPQTYC<>0 or LPRSCR<>0 or LPACTS<>0 or LPACTD<>0) ", "HDMLPM", "coalesce(max(LPSEQN),0)", laborSeq)
                              %endif
                          %endif
                      %endif

                      %if (laborSeq > "0")
                          @RtvFldDesc("LPPLT=$(V_OHPLT) and LPORD='$(V_OHORD)' and LPSEQN=$(laborSeq) ", "HDMLPM", "LPRTYP", routingType)
                          %if (routingType == "V")
                              @RtvFldDesc("LPPLT=$(V_OHPLT) and LPORD='$(V_OHORD)' and LPSEQN=$(laborSeq) ", "HDMLPM", "LPFVQT", qtyFromVendor)
                              @dtw_multiply(qtyFromVendor, "100", percentOfTotal)
                              @dtw_divide(percentOfTotal, V_OHCQTY, percentOfTotal)
                              @Format_Nbr($(percentOfTotal), F_percentOfTotal, "0", $(pctEditCode), "", "", "%")
                          %endif
                          @RtvFldDesc("LPPLT=$(V_OHPLT) and LPORD='$(V_OHORD)' and LPSEQN=$(laborSeq) ", "HDMWCM join HDMLPM on WCPLT=LPPLT and WCDEPT=LPDEPT and WCWC=LPWC", "WCDESC", deptDesc)
                          @RtvFldDesc("LPPLT=$(V_OHPLT) and LPORD='$(V_OHORD)' and LPSEQN=$(laborSeq) ", "HDMLPM", "LPQTYC", qtyGood)
                          @Format_Nbr($(qtyGood), F_qtyGood, $(qtyNbrDec), $(qtyEditCode), "", "", "")

                          %if (routingType != "V")
                              @Get_MfgOrder_Hours(V_OHPLT, V_OHORD, laborSeq, zero, thours, rhours, pctView, compPct, includeScrap)
                              @Format_Nbr($(compPct), F_percentOfTotal, "0", $(pctEditCode), "", "", "%")
                              @dtw_add(T_rhours, rhours, T_rhours)
                              @Format_Nbr(thours, F_thours, "2", $(hrsEditCode), "Y", "", "")
                          %else
                              @Get_MfgOrder_Hours(V_OHPLT, V_OHORD, zero, zero, thours, rhours, pctView, compPct, includeScrap)
                              @Format_Nbr(thours, F_thours, "2", $(hrsEditCode), "Y", "", "")
                          %endif
                      %else
                          @Get_MfgOrder_Hours(V_OHPLT, V_OHORD, laborSeq, zero, thours, rhours, pctView, compPct, includeScrap)
                          @Format_Nbr(thours, F_thours, "2", $(hrsEditCode), "Y", "", "")
                      %endif
                      @Format_Nbr(rhours, F_rhours, "2", $(hrsEditCode), "Y", "", "")
                      @dtw_add(T_thours, thours, T_thours)
                  %endif
              %endif

              @Format_Nbr($(V_OHQTYR), F_OHQTYR, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Get_Qty_Avail(profileHandle, dataBaseID, V_OHPN, V_ODWH, qtyAvailable)
              @Format_Nbr($(qtyAvailable), F_qtyAvailable, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_OHCQTY), F_OHCQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              %if (V_ODITEM == V_OHPN && V_OHSTC != "C")
                  @dtw_assign(compOrder, "")
                  @dtw_assign(qtyOpen, @dtw_rsubtract(V_ODQORD, @dtw_radd(V_ODQSTD, V_ODQSTC)))
                  %if (qtyOpen < "0") @dtw_assign(qtyOpen, "0") %endif
                  @dtw_assign(workPrice, @dtw_rformat(@dtw_rdivide(@dtw_rmultiply(qtyOpen, V_ODSLPR), V_ODORUF), "21", "2", "0", "", "23"))
                  @Format_Nbr(workPrice, ExtendedPrice, "2", $(amtEditCode), "Y", "", "")
                  @dtw_add(T_workPrice, workPrice, "15", T_workPrice)
              %else
                  @dtw_assign(qtyOpen, @dtw_rsubtract(V_OHCQTY, V_OHQTYR))
                  %if (qtyOpen < "0") @dtw_assign(qtyOpen, "0") %endif
                  @dtw_assign(compOrder, "$(reqFieldChar)")
                  @dtw_assign(ExtendedPrice, "")
              %endif
              @Format_Nbr(qtyOpen, F_qtyOpen, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Date(V_ODRQDT, "D", F_ODRQDT)
              @RtvFldDesc("OCORD#=$(orderNumber) and OCORL#=$(V_ODORL#) and OCBLN#=$(V_ODBLN#) and OCDOCT='RTG'", "OEOCMT", "char(count(*))", cmtCount)
              @RtvFldDesc("FLTYPE='MFGORDSTAT' and FLVALU='$(V_OHSTC)'", "SYFLAG", "FLDESC", orderStatus)

	       <tr class="$(rowClass)">
                  %if (V_OHSTC == "A" && V_OHCPNS == "Y")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)ProductStructureIndentedStockStatusInquiry.d2w/DISPLAY$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(V_OHPLT)&amp;itemNumber=@dtw_rurlescseq(V_OHPN)" onclick="$(inquiryWinVar)" title="View Indented Stock Status">S</a></td>
                  %else
                      <td class="colalph" $(helpCursor)><span title="$(orderStatus)">$(V_OHSTC)</span></td>
                  %endif
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)SelectMfgOrder.d2w/REPORT$(maintainVar)" onclick="$(inquiryWinVar)" title="View Mfg Order">$(compOrder) $(V_OHORD)</a>
    		       %if (cmtCount > "0")
                          <a href="$(homeURL)$(cGIPath)OrderComments.d2w/REPORT$(genericVarBase)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;lineNumber=@dtw_rurlescseq(V_ODORL#)&amp;orderSequence=000&amp;releaseNumber=@dtw_rurlescseq(V_ODBLN#)&amp;orderDocType=RTG&amp;type=O" onclick="$(commentWinVar)">$(drillDownCmtImg)</a>
                      %endif
                  </td>
                  %if (V_OHORD != "" && V_OHSTC !="C" && V_OHSTC !="T")
                       <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=445&amp;fKey1=OHORD&amp;fVal1=@dtw_rurlescseq(V_OHORD)" title="View Mfg Order Line Detail">%if (V_ODSGEN == "Y") ($(V_ODSGBL)) &nbsp; %endif $(V_ODORL#)</a></td>
                  %else
                      <td class="colnmbr">%if (V_ODSGEN == "Y") ($(V_ODSGBL)) &nbsp; %endif $(V_ODORL#)</td>
                  %endif
                  <td class="colnmbr">$(V_ODBLN#)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemPlantSelect.d2w/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(V_OHPLT)&amp;itemNumber=@dtw_rurlescseq(V_OHPN)" title="View Item/Plant">$(V_OHPN)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_OHPN)&amp;itemDescription=@dtw_rurlescseq(itemDesc)" title="View Item">$(itemDesc)</a></td>
                  <td class="colnmbr">$(F_OHCQTY)</td>
                  <td class="colnmbr">$(F_qtyOpen)</td>
                  <td class="colnmbr">$(F_OHQTYR)</td>
                  <td class="colnmbr">$(F_qtyAvailable)</td>
                  <td class="colalph">$(deptDesc)</td>
                  <td class="colnmbr">$(F_percentOfTotal)</td>
                  <td class="colnmbr">$(F_qtyGood)</td>
                  %if (V_OHORD != "")
                      <td class="colnmbr">$(F_rhours)</td>
                  %else
                      <td class="colalph">&nbsp;</td>
                  %endif
                  <td class="colnmbr">$(F_thours)</td>
                  <td class="colnmbr">$(ExtendedPrice)</td>
                  %if (V_OHPLT > "0")
                      <td class="colnmbr" $(helpCursor)><span title="$(plantName)">$(V_OHPLT)</span></td>
                  %else
                      <td class="colnmbr">&nbsp;</td>
                  %endif
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)ItemWarehouseSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_OHPN)&amp;warehouseNumber=@dtw_rurlescseq(V_ODWH)" title="View Item/Warehouse">$(V_ODWH)</a></td>
                  <td class="coldate">$(F_ODRQDT)</td>
	       </tr>
	   %}
          %INCLUDE "SetRowClass.icl"
          @Format_Nbr(T_rhours, F_rhours, "2", $(hrsEditCode), "Y", "", "")
          @Format_Nbr(T_thours, F_thours, "2", $(hrsEditCode), "Y", "", "")
          @Format_Nbr(T_workPrice, ExtendedPrice, "2", $(amtEditCode), "Y", "", "")
          <tr>
              <td class="colnmbr" colspan="13">Total</td>
              <td class="coltotal">$(F_rhours)</td>
              <td class="coltotal">$(F_thours)</td>
              <td class="coltotal">$(ExtendedPrice)</td>
          </tr>
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "OHPLT,OHORD")
          @DTW_ASSIGN(orderByDisplay, "Plant Number, Order Number")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %elif (chgComponent == "Y" && inclComponent == "Y")
          @dtw_assign(inclComponent, "")
      %elif (chgComponent == "Y")
          @dtw_assign(inclComponent, "Y")
      %elif (chgCompleted == "Y" && inclCompleted == "Y")
          @dtw_assign(inclCompleted, "")
      %elif (chgCompleted == "Y")
          @dtw_assign(inclCompleted, "Y")
      %elif (chgDeptView == "Y" && deptView == "F")
          @dtw_assign(deptView, "L")
      %elif (chgDeptView == "Y" && deptView == "L")
          @dtw_assign(deptView, "F")
      %elif (chgPctView == "Y" && pctView == "H")
          @dtw_assign(pctView, "Q")
      %elif (chgPctView == "Y")
          @dtw_assign(pctView, "H")
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif

  @EdtVarErr(profileHandle, typeValue, edtVar)
  %if (edtVar == "" || deptView == "")
      @dtw_assign(edtVar, "")
      @Concat_Field("@@dptv", dftDepartment)
      @Concat_Field("@@pctv", dftPercent)
      @Concat_Field("@@icmp", dftComponent)
      @Concat_Field("@@icpl", dftCompleted)
      @dtw_concat(edtVar, "}{", edtVar)
      @EdtVarErr(profileHandle, typeValue, edtVar)
  %else
      @dtw_assign(edtVar, "")
      @Concat_Field("@@dptv", deptView)
      @Concat_Field("@@pctv", pctView)
      @Concat_Field("@@icmp", inclComponent)
      @Concat_Field("@@icpl", inclCompleted)
      @Concat_Field("@@thru", thruDate)
      @dtw_concat(edtVar, "}{", edtVar)
      @EdtVarErr(profileHandle, typeValue, edtVar)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Plant")
      %if (orderBy == "OHPLT,OHORD")
          @DTW_ASSIGN(orderBy, "OHPLT DESC,OHORD")
          @DTW_ASSIGN(orderByDisplay, "Plant (descending), Order Number")
      %else
          @DTW_ASSIGN(orderBy, "OHPLT,OHORD")
          @DTW_ASSIGN(orderByDisplay, "Plant, Order Number")
      %endif
  %elif (sequence == "Status")
      %if (orderBy == "OHSTC,OHORD")
          @DTW_ASSIGN(orderBy, "OHSTC DESC,OHORD")
          @DTW_ASSIGN(orderByDisplay, "Status (descending), Order Number")
      %else
          @DTW_ASSIGN(orderBy, "OHSTC,OHORD")
          @DTW_ASSIGN(orderByDisplay, "Status, Order Number")
      %endif
  %elif (sequence == "Order")
      %if (orderBy == "OHORD,OHPLT")
          @DTW_ASSIGN(orderBy, "OHORD DESC,OHPLT")
          @DTW_ASSIGN(orderByDisplay, "Order Number (descending), Plant")
      %else
          @DTW_ASSIGN(orderBy, "OHORD,OHPLT")
          @DTW_ASSIGN(orderByDisplay, "Order Number, Plant")
      %endif
  %elif (sequence == "Line")
      %if (orderBy == "ODORL#,ODBLN#,OHORD")
          @DTW_ASSIGN(orderBy, "ODORL# DESC,ODBLN#,OHORD")
          @DTW_ASSIGN(orderByDisplay, "Line (descending), Release, Order Number")
      %else
          @DTW_ASSIGN(orderBy, "ODORL#,ODBLN#,OHORD")
          @DTW_ASSIGN(orderByDisplay, "Line, Release, Order Number")
      %endif
  %elif (sequence == "Rel")
      %if (orderBy == "ODBLN#,OHORD")
          @DTW_ASSIGN(orderBy, "ODBLN# DESC,OHORD")
          @DTW_ASSIGN(orderByDisplay, "Release (descending), Order Number")
      %else
          @DTW_ASSIGN(orderBy, "ODBLN#,OHORD")
          @DTW_ASSIGN(orderByDisplay, "Release, Order Number")
      %endif
  %elif (sequence == "Whs")
      %if (orderBy == "ODWH,OHPN,OHORD")
          @DTW_ASSIGN(orderBy, "ODWH DESC,OHPN,OHORD")
          @DTW_ASSIGN(orderByDisplay, "Warehouse (descending), Item Number, Order Number")
      %else
          @DTW_ASSIGN(orderBy, "ODWH,OHPN,OHORD")
          @DTW_ASSIGN(orderByDisplay, "Warehouse, Item Number, Order Number")
      %endif
  %elif (sequence == "Item")
      %if (orderBy == "OHPN,OHORD")
          @DTW_ASSIGN(orderBy, "OHPN DESC,OHORD")
          @DTW_ASSIGN(orderByDisplay, "Item Number (descending), Order Number")
      %else
          @DTW_ASSIGN(orderBy, "OHPN,OHORD")
          @DTW_ASSIGN(orderByDisplay, "Item Number, Order Number")
      %endif
  %elif (sequence == "ReqDate")
      %if (orderBy == "ODRQDT,OHPN,OHORD")
          @DTW_ASSIGN(orderBy, "ODRQDT DESC,OHPN,OHORD")
          @DTW_ASSIGN(orderByDisplay, "Required Date (descending), Item Number, Order Number")
      %else
          @DTW_ASSIGN(orderBy, "ODRQDT,OHPN,OHORD")
          @DTW_ASSIGN(orderByDisplay, "Required Date, Item Number, Order Number")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "dateedit.icl"
	          %INCLUDE "numedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              function validate(searchForm) {
                  if (editNum(document.Search.srchPlant, 3, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "SALESORDERSTATUS")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"
                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Mfg Order</td>
                              @dtw_assign(operNbr, "operOrder")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchOrder" size="9" maxlength="9"></td>
                          </tr>

                          <tr><td class="dsphdr">Item Number</td>
                              @dtw_assign(operNbr, "operItem")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchItem" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Search&amp;fldName=srchItem&amp;fldDesc=itemDescription" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="itemDescription" value="$(fieldDesc)" type="text" size="30" maxlength="30" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Plant</td>
                              @dtw_assign(operNbr, "operPlant")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchPlant" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Search&amp;fldName=srchPlant&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="plantName" value="$(fieldDesc)" type="text" size="30" maxlength="30" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Warehouse</td>
                              @dtw_assign(operNbr, "operWhs")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchWhs" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Search&amp;fldName=srchWhs&amp;fldDesc=whsName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="whsName" value="$(fieldDesc)" type="text" size="30" maxlength="30" disabled></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchOrder.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("coalesce(OHPLT,ODPLT)", "Plant", $(srchPlant), "", operPlant, "N")
  @Build_WildCard ("OHORD", "Order Number", $(srchOrder), "U", operOrder, "A")
  @Build_WildCard ("coalesce(OHPN,ODITEM)", "Item Number", $(srchItem), "U", operItem, "A")
  @Build_WildCard ("ODWH", "Warehouse", $(srchWhs), "", operWhs, "N")
		
  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}