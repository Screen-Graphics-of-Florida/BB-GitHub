%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "Menu.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Item Availability"
  d2wName                 = "OrderEntryItemWhsQty.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;lineNumber=@dtw_rurlescseq(lineNumber)&amp;relNumber=@dtw_rurlescseq(relNumber)&amp;inquiryOnly=@dtw_rurlescseq(inquiryOnly)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "9999"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "9999"
  rowIndexNext            = "1"
  totalPages              = "0"
  popUpWin                = "Y"
  maintCode               = "A"
  displayCloseIcon        = "Y"
  subr                    = "RetPltNbr"
  haveHeader              = ""
  headerTable             = %table
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(uv_WarehouseName, "IWWHS")
                      @dtw_assign(uv_ProductClassName, "IMPCLS")
                      @dtw_assign(uv_ProductGroupName, "IWPGRP")
                      @dtw_assign(uv_ProdInventoryTypeName, "IMITC")
                      @dtw_assign(uv_ProdPartTypeName, "IMPTYP")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select IWWHS, IWITEM, IWOHQT, IWOHRC, IWQHSR, IWRESQ, IWQOO, IWDSQO, IWLIST, IWIWAC, IWQOPK, ", stmtSQL)
                      @dtw_concat(stmtSQL, " IMPTYP, IMITC, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(WHWHNM,' ') as WHWHNM, upper(coalesce(WHWHNM,' ')) as WHWHNMU ", stmtSQL)
                      @dtw_concat(stmtSQL, " , F_QTYAVAIL(IWITEM,IWWHS,' ',' ',' ',' ') as IWAVAL ", stmtSQL)
                      @dtw_concat(stmtSQL, " , F_QTYAVPCK(IWITEM,IWWHS,' ',' ',' ',' ') as IWAVPK ", stmtSQL)
                      @dtw_concat(fileSQL, " HDIWHS ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDIMST on IMITEM=IWITEM ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDWHSM on WHWHS =IWWHS ", fileSQL)
                      @dtw_concat(selectSQL, "IWITEM='$(itemNumber)' ", selectSQL)
                      @dtw_concat(selectSQL, "  and IWIWAC=' '", selectSQL)
                      %if (warehouseNumber > "0")
                          @dtw_concat(selectSQL, "  and IWWHS=$(warehouseNumber)", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By IWWHS ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @ItemWhs_Qty_Query(profileHandle, dataBaseID, stmtSQL)

                      %if (onOrderWhs > "0")
                          @dtw_assign(uv_WarehouseName, "PDOVWH")
                          @dtw_assign(uv_ProductClassName, "PDPCLS")
                          %INCLUDE "userview.icl"

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select POPOMD.*, POVEND, VMVNA1 ", stmtSQL)
                          @dtw_concat(fileSQL, " POPOMS inner join POPOMD on PDPO=POPO ", fileSQL)
                          @dtw_concat(fileSQL, "        inner join HDVEND on VMVEND=POVEND ", fileSQL)
                          @dtw_concat(selectSQL, "POSTAT='O' and PDSTAT='O' and PDPOLT<>'B' and PDPOEC='S' and ", selectSQL)
                          @dtw_concat(selectSQL, "POFL02='1' and PODSHP=0 and PDITEM='$(itemNumber)' ", selectSQL)
                          %if (onOrderWhs != "All")
                              @dtw_concat(selectSQL, " and PDOVWH=$(onOrderWhs) ", selectSQL)
                          %endif
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By PDOVWH,PDRQDT,PDPO,PDPOL#,PDPORL ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @OnOrder_Qty_Query(profileHandle, dataBaseID, stmtSQL)
                      %elif (resQtyWhs > "0")
                          @dtw_assign(uv_WarehouseName, "ODWH")
                          @dtw_assign(uv_ProductClassName, "ODPCLS")
                          @dtw_assign(uv_ProductGroupName, "ODPGRP")
                          %INCLUDE "userview.icl"

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select OEORDT.*, OESHTO, CMCNA1", stmtSQL)
                          @dtw_concat(fileSQL, " OEORHD inner join OEORDT on ODORD#=OEORD# ", fileSQL)
                          @dtw_concat(fileSQL, "        inner join HDCUST on CMCUST=OESHTO ", fileSQL)
                          @dtw_concat(selectSQL, "OEORST='O' and ODORST='O'and ODBLKT<>'Y' ", selectSQL)
                          @dtw_concat(selectSQL, "and OEFL07='1' and ODITEM='$(itemNumber)' ", selectSQL)
                          %if (resQtyWhs != "All")
                              @dtw_concat(selectSQL, " and ODWH=$(resQtyWhs) ", selectSQL)
                          %endif
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By ODWH,ODRQDT,ODORD#,ODORL#,ODBLN# ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Reserved_Qty_Query(profileHandle, dataBaseID, stmtSQL)
                      %elif (atpPlant > "0")
                          @dtw_assign(uv_Sql, "")

                          @Fill_ATP_Work_File(profileHandle, dataBaseID, atpPlant, itemNumber)
                          @MS230A_Query(profileHandle, dataBaseID, atpPlant, itemNumber, headerTable)
                          %if (@dtw_tb_rrows(headerTable)>"0")
                              @dtw_assign(haveHeader, "Y")
                          %else
                              @dtw_assign(haveHeader, "")
                          %endif
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " MS230W ", fileSQL)
                          @dtw_concat(selectSQL, "E_PLNT=$(atpPlant) and E_ITEM='$(itemNumber)' and E_XHND='$(profileHandle)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By E_DATE,E_PAST DESC ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Avail_To_Promise(profileHandle, dataBaseID, stmtSQL)
                      %endif
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) ItemWhs_Qty_Query (IN CHAR(64)    profileHandle,
				          CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(medIcon, "Y")
      %INCLUDE "PageTitle.icl"

      <table $(contentTable)>
          @Format_Header("Item", $(itemDescription), $(itemNumber))
      </table>

      $(hrTagAttr)

      %if (V_HDPDRL>"0")
          @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMQUAL", V_IMQUAL)
      %endif

      %if ((V_HDPDRL > "0" && V_IMQUAL != "Y") || V_HDPDRL == "0")
          @dtw_assign(includeOnHandRecv, "Y")
      %else
          @dtw_assign(includeOnHandRecv, "")
      %endif

      <table $(contentTable)>
          <tr>
              <th class="colhdr">Whs</th>
              <th class="colhdr">Name</th>
              <th class="colhdr">List<br>Price</th>
              <th class="colhdr">Quantity<br>On Hand</th>
              %if (includeOnHandRecv == "Y")
                  <th class="colhdr">Quantity<br>On Hand<br>Receiving</th>
              %endif
              <th class="colhdr">Quantity<br>Held<br>In Stock</th>
              <th class="colhdr">Quantity<br>Reserved</th>
              %if (V_CIOOIA == "Y")
                  <th class="colhdr">Quantity<br>On Order</th>
                  <th class="colhdr">Quantity<br>Drop Shipped</th>
              %endif
              <th class="colhdr">Quantity<br>Available</th>
              %if (dspAvailToPick == "Y")
                  <th class="colhdr">Quantity<br>On Pick</th>
                  <th class="colhdr">Quantity<br>Available<br>To Pick</th>
              %endif
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          @dtw_assign(T_IWOHQT, "0")
          @dtw_assign(T_IWOHRC, "0")
          @dtw_assign(T_IWQHSR, "0")
          @dtw_assign(T_IWRESQ, "0")
          @dtw_assign(T_IWQOO, "0")
          @dtw_assign(T_IWDSQO, "0")
          @dtw_assign(T_qtyAvailable, "0")
          @dtw_assign(T_IWAVAL, "0")
          @dtw_assign(T_IWQOPK, "0")
          @dtw_assign(T_IWAVPK, "0")

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Nbr(V_IWLIST, F_IWLIST, $(prcNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Nbr(V_IWOHQT, F_IWOHQT, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              %if (includeOnHandRecv == "Y")
                  @Format_Nbr(V_IWOHRC, F_IWOHRC, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              %endif
              @Format_Nbr(V_IWQHSR, F_IWQHSR, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_IWRESQ, F_IWRESQ, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              %if (V_CIOOIA == "Y")
                  @Format_Nbr(V_IWQOO, F_IWQOO, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                  @Format_Nbr(V_IWDSQO, F_IWDSQO, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              %endif
              @Format_Nbr(V_IWAVAL, F_IWAVAL, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              %if (dspAvailToPick == "Y")
              	  @Format_Nbr(V_IWQOPK, F_IWQOPK, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
			  @Format_Nbr(V_IWAVPK, F_IWAVPK, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @dtw_add(T_IWQOPK, V_IWQOPK, "15", T_IWQOPK)
                  @dtw_add(T_IWAVPK, V_IWAVPK, "15", T_IWAVPK)
		   %endif
              @dtw_add(T_IWOHQT, V_IWOHQT, "15", T_IWOHQT)
              %if (includeOnHandRecv == "Y")
                  @dtw_add(T_IWOHRC, V_IWOHRC, "15", T_IWOHRC)
              %endif
              @dtw_add(T_IWQHSR, V_IWQHSR, "15", T_IWQHSR)
              @dtw_add(T_IWRESQ, V_IWRESQ, "15", T_IWRESQ)
              %if (V_CIOOIA == "Y")
                  @dtw_add(T_IWQOO, V_IWQOO, "15", T_IWQOO)
                  @dtw_add(T_IWDSQO, V_IWDSQO, "15", T_IWDSQO)
              %endif
              @dtw_add(T_IWAVAL, V_IWAVAL, "15", T_IWAVAL)
              %if (V_HDPDRL > "0")
                  @RetPltNbr(profileHandle, dataBaseID, subr, V_IWWHS, itemNumber, V_atpPlant)
              %endif

              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_IWWHS)</td>
                  <td class="colalph">
                      %if (inquiryOnly == "Y")
                          $(V_WHWHNM)
                      %else
                          <a href="$(homeURL)$(cGIPath)$(d2wName)/SELECT$(d2wVarBase)&amp;warehouseNumber=@dtw_rurlescseq(V_IWWHS)" title="Select Warehouse">$(V_WHWHNM)</a>
                      %endif
                  </td>
                  <td class="colnmbr">$(F_IWLIST)</td>
                  <td class="colnmbr">$(F_IWOHQT)</td>
                  %if (includeOnHandRecv == "Y")
                      <td class="colnmbr">$(F_IWOHRC)</td>
                  %endif
                  <td class="colnmbr">$(F_IWQHSR)</td>
                  %if (V_IWRESQ > "0")
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;resQtyWhs=@dtw_rurlescseq(V_IWWHS)&amp;resQtyWhsName=@dtw_rurlescseq(V_WHWHNM)" title="View Open Orders for Whs $(V_IWWHS) - $(V_WHWHNM)">$(F_IWRESQ)</a></td>
                  %else
                      <td class="colnmbr">$(F_IWRESQ)</td>
                  %endif
                  %if (V_CIOOIA == "Y")
                      %if (V_IWQOO > "0")
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;onOrderWhs=@dtw_rurlescseq(V_IWWHS)&amp;onOrderWhsName=@dtw_rurlescseq(V_WHWHNM)" title="View Purchase Orders for Whs $(V_IWWHS) - $(V_WHWHNM)">$(F_IWQOO)</a></td>
                      %else
                          <td class="colnmbr">$(F_IWQOO)</td>
                      %endif
                      <td class="colnmbr">$(F_IWDSQO)</td>
                  %endif
                  %if (V_HDPDRL > "0" && V_atpPlant > "0")
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;atpPlant=@dtw_rurlescseq(V_atpPlant)" title="View Available To Promise">$(F_IWAVAL)</a></td>
                  %else
                      <td class="colnmbr">$(F_IWAVAL)</td>
                  %endif
                  %if (dspAvailToPick == "Y")
                      <td class="colnmbr">$(F_IWQOPK)</td>
                      <td class="colnmbr">$(F_IWAVPK)</td>
                  %endif
                  %if (V_IWIWAC == "I")
                      <td class="colicon">$(inactiveImageSml)</td>
                  %endif
              </tr>
          %}
          %if (sql_Record_Count>"1")
              %INCLUDE "SetRowClass.icl"
              @Format_Nbr(T_IWLIST, F_IWLIST, $(prcNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Nbr(T_IWOHQT, F_IWOHQT, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              %if (includeOnHandRecv == "Y")
                  @Format_Nbr(T_IWOHRC, F_IWOHRC, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              %endif
              @Format_Nbr(T_IWQHSR, F_IWQHSR, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(T_IWRESQ, F_IWRESQ, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              %if (V_CIOOIA == "Y")
                  @Format_Nbr(T_IWQOO, F_IWQOO, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                  @Format_Nbr(T_IWDSQO, F_IWDSQO, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              %endif
              @Format_Nbr(T_IWAVAL, F_IWAVAL, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              %if (dspAvailToPick == "Y")
              	  @Format_Nbr(T_IWQOPK, F_IWQOPK, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
			  @Format_Nbr(T_IWAVPK, F_IWAVPK, $(qtyNbrDec), $(qtyEditCode), "", "", "")
		   %endif
              <tr>
                  %if (formatToPrint == "Y")
                      <td class="colnmbr" colspan="2">Total</td>
                  %else
                      <td class="colnmbr" colspan="3">Total</td>
                  %endif
                  <td class="coltotal">$(F_IWOHQT)</td>
                  %if (includeOnHandRecv == "Y")
                      <td class="coltotal">$(F_IWOHRC)</td>
                  %endif
                  <td class="coltotal">$(F_IWQHSR)</td>
                  %if (T_IWRESQ > "0")
                      <td class="coltotal"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;resQtyWhs=All" title="View Open Orders for All Warehouses"">$(F_IWRESQ)</a></td>
                  %else
                      <td class="coltotal">$(F_IWRESQ)</td>
                  %endif
                  %if (V_CIOOIA == "Y")
                      %if (T_IWQOO > "0")
                          <td class="coltotal"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;onOrderWhs=All" title="View Purchase Orders for All Warehouses">$(F_IWQOO)</a></td>
                      %else
                          <td class="coltotal">$(F_IWQOO)</td>
                      %endif
                      <td class="coltotal">$(F_IWDSQO)</td>
                  %endif
                  <td class="coltotal">$(F_IWAVAL)</td>
                  %if (dspAvailToPick == "Y")
                      <td class="coltotal">$(F_IWQOPK)</td>
                      <td class="coltotal">$(F_IWAVPK)</td>
                  %endif
              </tr>
          %endif
      </table>
      %if (onOrderWhs == "" && resQtyWhs == "" && atpPlant == "")
          $(hrTagAttr)
          %INCLUDE "Copyright.icl"
      %endif
  %}
%}

%FUNCTION(dtw_sql) OnOrder_Qty_Query (IN CHAR(64)    profileHandle,
				          CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <fieldset class="legendBody">
      %if (onOrderWhs == "All")
          <legend class="legendTitle">Purchase Orders for All Warehouses </legend>
      %else
          <legend class="legendTitle">Purchase Orders for Whs $(onOrderWhs) - $(onOrderWhsName) </legend>
      %endif
          <div class="quickLinksTop">
              <a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)">$(closeImageMed)</a>
          </div>

      <table $(contentTable)>
          <tr>
              %if (onOrderWhs == "All")
                  <th class="colhdr">Whs</th>
                  @dtw_assign(spanCount, "5")
              %else
                  @dtw_assign(spanCount, "4")
              %endif
              <th class="colhdr">Order<br>Number</th>
              <th class="colhdr">Line</th>
              <th class="colhdr">Rel</th>
              <th class="colhdr">Required<br>Date</th>
              <th class="colhdr">Quantity<br>Ordered</th>
              <th class="colhdr">Quantity<br>Received</th>
              <th class="colhdr">Quantity<br>Open</th>
              <th class="colhdr">Vendor<br>Number</th>
              <th class="colhdr">Name</th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"
	   		
          %ROW{
              %INCLUDE "SetRowClass.icl"
              @dtw_assign(mmyy, @dtw_rsubstr(V_PDRQDT, "2", "4"))
              %if (mmyy != W_mmyy)
                  %if (W_mmyy != "")
                      @dtw_assign(mm, @dtw_rsubstr(W_mmyy, "3", "2"))
                      @dtw_assign(yy, @dtw_rsubstr(W_mmyy, "1", "2"))
                      @Format_Nbr(T_PDQTOR, F_PDQTOR, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                      @Format_Nbr(T_QRECVD, F_QRECVD, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                      @Format_Nbr(T_QOPEN, F_QOPEN, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                      <tr>
                          <td class="colnmbr" colspan="$(spanCount)">Total for $(mm)$(dateEdit)$(yy)</td>
                          <td class="coltotal">$(F_PDQTOR)</td>
                          <td class="coltotal">$(F_QRECVD)</td>
                          <td class="coltotal">$(F_QOPEN)</td>
                      </tr>
                  %endif
                  @dtw_assign(W_mmyy, mmyy)
                  @dtw_assign(T_PDQTOR, "0")
                  @dtw_assign(T_QRECVD, "0")
                  @dtw_assign(T_QOPEN, "0")
              %endif

              @Format_Date(V_PDRQDT, "D", F_PDRQDT)
              @Format_Nbr(V_PDQTOR, F_PDQTOR, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @dtw_add(V_PDQRST, V_PDQRRT, subTotal)
              @dtw_add(subTotal, V_PDQRFT, V_QRECVD)
              @Format_Nbr(V_QRECVD, F_QRECVD, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @dtw_subtract(V_PDQTOR, V_QRECVD, V_QOPEN)
              @Format_Nbr(V_QOPEN, F_QOPEN, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")

              @dtw_add(T_PDQTOR, V_PDQTOR, T_PDQTOR)
              @dtw_add(T_QRECVD, V_QRECVD, T_QRECVD)
              @dtw_add(T_QOPEN, V_QOPEN, T_QOPEN)

              <tr class="$(rowClass)">
                  %if (onOrderWhs == "All")
                      <td class="colnmbr">
                          %if (inquiryOnly == "Y")
                              $(V_PDOVWH)
                          %else
                              <a href="$(homeURL)$(cGIPath)$(d2wName)/SELECT$(d2wVarBase)&amp;warehouseNumber=@dtw_rurlescseq(V_PDOVWH)" title="Select Warehouse">$(V_PDOVWH)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colnmbr">$(V_PDPO)</td>
                  <td class="colnmbr">$(V_PDPOL#)</td>
                  <td class="colnmbr">$(V_PDPORL)</td>
                  <td class="coldate">$(F_PDRQDT)</td>
                  <td class="colnmbr">$(F_PDQTOR)</td>
                  <td class="colnmbr">$(F_QRECVD)</td>
                  <td class="colnmbr">$(F_QOPEN)</td>
                  <td class="colnmbr">$(V_POVEND)</td>
                  <td class="colalph">$(V_VMVNA1)</td>
              </tr>
          %}
          %if (W_mmyy != "")
              @dtw_assign(mm, @dtw_rsubstr(W_mmyy, "3", "2"))
              @dtw_assign(yy, @dtw_rsubstr(W_mmyy, "1", "2"))
              @Format_Nbr(T_PDQTOR, F_PDQTOR, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(T_QRECVD, F_QRECVD, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(T_QOPEN, F_QOPEN, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              <tr>
                  <td class="colnmbr" colspan="$(spanCount)">Total for $(mm)$(dateEdit)$(yy)</td>
                  <td class="coltotal">$(F_PDQTOR)</td>
                  <td class="coltotal">$(F_QRECVD)</td>
                  <td class="coltotal">$(F_QOPEN)</td>
              </tr>
          %endif
      </table>
      </fieldset>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_sql) Reserved_Qty_Query (IN CHAR(64)    profileHandle,
				           CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <fieldset class="legendBody">
      %if (resQtyWhs == "All")
          <legend class="legendTitle">Open Orders for All Warehouses </legend>
      %else
          <legend class="legendTitle">Open Orders for Whs $(resQtyWhs) - $(resQtyWhsName) </legend>
      %endif
          <div class="quickLinksTop">
              <a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)">$(closeImageMed)</a>
          </div>

      <table $(contentTable)>
          %if (sql_Record_Count > "0")
              <tr>
                  %if (resQtyWhs == "All")
                      <th class="colhdr">Whs</th>
                      @dtw_assign(spanCount, "5")
                  %else
                      @dtw_assign(spanCount, "4")
                  %endif
                  <th class="colhdr">Order<br>Number</th>
                  <th class="colhdr">Line</th>
                  <th class="colhdr">Rel</th>
                  <th class="colhdr">Required<br>Date</th>
                  <th class="colhdr">Quantity<br>Ordered</th>
                  <th class="colhdr">Quantity<br>Shipped</th>
                  <th class="colhdr">Quantity<br>Open</th>
                  <th class="colhdr">Customer<br>Number</th>
                  <th class="colhdr">Name</th>
              </tr>
          %endif
          %INCLUDE "NoRecordsFound.icl"
	   		
          %ROW{
              %INCLUDE "SetRowClass.icl"
              @dtw_assign(mmyy, @dtw_rsubstr(V_ODRQDT, "2", "4"))
              %if (mmyy != W_mmyy)
                  %if (W_mmyy != "")
                      @dtw_assign(mm, @dtw_rsubstr(W_mmyy, "3", "2"))
                      @dtw_assign(yy, @dtw_rsubstr(W_mmyy, "1", "2"))
                      @Format_Nbr(T_ODQORD, F_ODQORD, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                      @Format_Nbr(T_qtyShip, F_qtyShip, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                      @Format_Nbr(T_QOPEN, F_QOPEN, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                      <tr>
                          <td class="colnmbr" colspan="$(spanCount)">Total for $(mm)$(dateEdit)$(yy)</td>
                          <td class="coltotal">$(F_ODQORD)</td>
                          <td class="coltotal">$(F_qtyShip)</td>
                          <td class="coltotal">$(F_QOPEN)</td>
                      </tr>
                  %endif
                  @dtw_assign(W_mmyy, mmyy)
                  @dtw_assign(T_ODQORD, "0")
                  @dtw_assign(T_qtyShip, "0")
                  @dtw_assign(T_QOPEN, "0")
              %endif

              @Format_Date(V_ODRQDT, "D", F_ODRQDT)
              @Format_Nbr(V_ODQORD, F_ODQORD, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @dtw_add(V_ODQSTD, V_ODQSTC, qtyShip)
              @Format_Nbr(qtyShip, F_qtyShip, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @dtw_subtract(V_ODQORD, qtyShip, V_QOPEN)
              @Format_Nbr(V_QOPEN, F_QOPEN, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")

              @dtw_add(T_ODQORD, V_ODQORD, T_ODQORD)
              @dtw_add(T_qtyShip, qtyShip, T_qtyShip)
              @dtw_add(T_QOPEN, V_QOPEN, T_QOPEN)

              <tr class="$(rowClass)">
                  %if (resQtyWhs == "All")
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)$(d2wName)/SELECT$(d2wVarBase)&amp;warehouseNumber=@dtw_rurlescseq(V_ODWH)" title="Select Warehouse">$(V_ODWH)</a></td>
                  %endif
                  <td class="colnmbr">$(V_ODORD#)</td>
                  <td class="colnmbr">$(V_ODORL#)</td>
                  <td class="colnmbr">$(V_ODBLN#)</td>
                  <td class="coldate">$(F_ODRQDT)</td>
                  <td class="colnmbr">$(F_ODQORD)</td>
                  <td class="colnmbr">$(F_qtyShip)</td>
                  <td class="colnmbr">$(F_QOPEN)</td>
                  <td class="colnmbr">$(V_OESHTO)</td>
                  <td class="colalph">$(V_CMCNA1)</td>
              </tr>
          %}
          %if (W_mmyy != "")
              @dtw_assign(mm, @dtw_rsubstr(W_mmyy, "3", "2"))
              @dtw_assign(yy, @dtw_rsubstr(W_mmyy, "1", "2"))
              @Format_Nbr(T_ODQORD, F_ODQORD, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(T_qtyShip, F_qtyShip, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(T_QOPEN, F_QOPEN, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              <tr>
                  <td class="colnmbr" colspan="$(spanCount)">Total for $(mm)$(dateEdit)$(yy)</td>
                  <td class="coltotal">$(F_ODQORD)</td>
                  <td class="coltotal">$(F_qtyShip)</td>
                  <td class="coltotal">$(F_QOPEN)</td>
              </tr>
          %endif
      </table>
      </fieldset>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_sql) Avail_To_Promise (IN CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <fieldset class="legendBody">
          @Format_Nbr(atpPlant, F_atpPlant, "0", $(qtyEditCode), "Y", "", "")
          @RtvFldDesc("PLPLNT=$(atpPlant)", "HDPLNT", "PLNAME", plantName)
          <legend class="legendTitle">Available To Promise for Plant $(F_atpPlant) - $(plantName)</legend>
          <div class="quickLinksTop">
              <a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)">$(closeImageMed)</a>
          </div>

      %if (sql_Record_Count > "0")
          <table $(contentTable)>
              <tr><td class="colhdr">Lead<br>Time</td>
                  <td class="colhdr">Part<br>Type</td>
                  <td class="colhdr">UM</td>
                  <td class="colhdr">On Hand</td>
                  <td class="colhdr">Released</td>
                  <td class="colhdr">Firm</td>
                  <td class="colhdr">Demand</td>
                  <td class="colhdr">Sold MTD</td>
                  <td class="colhdr">Analyst<br>Number</td>
                  <td class="colhdr">ABC</td>
                  <td class="colhdr">MPS</td>
                  <td class="colhdr">Demand</td>
              </tr>

              %if (haveHeader == "Y")
                  @dtw_tb_getv(headerTable, "1", "7", partType)
                  @RtvFldDesc("FLTYPE='PARTTYPE' and FLVALU='$(partType)'", "SYFLAG", "FLDESC", partTypeDesc)
                  @dtw_tb_getv(headerTable, "1", "8", uom)
                  @RtvFldDesc("UMUOM='$(uom)'", "HDUOM", "UMUMLD", uomDesc)
                  @dtw_tb_getv(headerTable, "1", "14", analyst)
                  @RtvFldDesc("BMBUYR=$(analyst)", "HDBUYR", "BMBNA1", analystName)
                  @dtw_tb_getv(headerTable, "1", "17", demandCode)
                  @RtvFldDesc("FLTYPE='SCHDDEMAND' and FLVALU='$(demandCode)'", "SYFLAG", "FLDESC", demandCodeDesc)
                  @Format_Nbr("@dtw_tb_rgetv(headerTable, "1", "9")", onHand, "0", $(qtyEditCode), "", "", "")
                  @Format_Nbr("@dtw_tb_rgetv(headerTable, "1", "10")", released, "0", $(qtyEditCode), "", "", "")
                  @Format_Nbr("@dtw_tb_rgetv(headerTable, "1", "11")", firm, "0", $(qtyEditCode), "", "", "")
                  @Format_Nbr("@dtw_tb_rgetv(headerTable, "1", "12")", demand, "0", $(qtyEditCode), "", "", "")
                  @Format_Nbr("@dtw_tb_rgetv(headerTable, "1", "13")", soldMTD, "0", $(qtyEditCode), "", "", "")
                  <tr><td class="colnmbr">@dtw_tb_rgetv(headerTable, "1", "6")</td>
                      <td class="colcode" $(helpCursor)><span title="$(partTypeDesc)">$(partType)</span></td>
                      <td class="colcode" $(helpCursor)><span title="$(uomDesc)">$(uom)</span></td>
                      <td class="colnmbr">$(onHand)</td>
                      <td class="colnmbr">$(released)</td>
                      <td class="colnmbr">$(firm)</td>
                      <td class="colnmbr">$(demand)</td>
                      <td class="colnmbr">$(soldMTD)</td>
                      <td class="colnmbr" $(helpCursor)><span title="$(analystName)">$(analyst)</span></td>
                      <td class="colcode">@dtw_tb_rgetv(headerTable, "1", "15")</td>
                      <td class="colcode">@dtw_tb_rgetv(headerTable, "1", "16")</td>
                      <td class="colcode" $(helpCursor)><span title="$(demandCodeDesc)">$(demandCode)</span></td>
                  </tr>
              %endif
          </table>
      %endif

	   <table $(contentTable)>
              %if (sql_Record_Count > "0")
                  <th class="colhdr">Date</th>
                  <th class="colhdr">Sales<br>Forecast</th>
                  <th class="colhdr">Customer<br>Demand</th>
                  <th class="colhdr">Pegged<br>Requirements</th>
                  <th class="colhdr">Available<br>To<br>Promise</th>
                  <th class="colhdr">Released/<br>Firm</th>
                  <th class="colhdr">Planned<br>Orders</th>
              %endif
              %INCLUDE "NoRecordsFound.icl"

          %ROW {
	       %INCLUDE "SetRowClass.icl"

              %if (V_E_PAST == "Y")
                  @dtw_assign(F_E_DATE, "Past Due")
                  @dtw_assign(once, "Y")
              %elif (V_E_DATE == "9999999")
                  @dtw_assign(F_E_DATE, "Future")
              %else
                  @Format_Date(V_E_DATE, "D", F_E_DATE)
              %endif

              @Format_Nbr(V_E_FOR, F_E_FOR, "0", $(qtyEditCode), "", "", "")
              @Format_Nbr(V_E_COR, F_E_COR, "0", $(qtyEditCode), "", "", "")
              @Format_Nbr(V_E_PEG, F_E_PEG, "0", $(qtyEditCode), "", "", "")
              @Format_Nbr(V_E_AVL, F_E_AVL, "0", $(qtyEditCode), "", "", "")
              @Format_Nbr(V_E_REC, F_E_REC, "0", $(qtyEditCode), "", "", "")
              @Format_Nbr(V_E_PLN, F_E_PLN, "0", $(qtyEditCode), "", "", "")

	       <tr class="$(rowClass)">
                  <td class="coldate">$(F_E_DATE)</td>
                  <td class="colnmbr">$(F_E_FOR)</td>
                  <td class="colnmbr">$(F_E_COR)</td>
                  <td class="colnmbr">$(F_E_PEG)</td>
                  <td class="colnmbr">$(F_E_AVL)</td>
                  <td class="colnmbr">$(F_E_REC)</td>
                  <td class="colnmbr">$(F_E_PLN)</td>
	       </tr>
          %}
      </table>
      </fieldset>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
  @Set_SQL(stmtSQL)
%}

%HTML(SELECT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Update OEDTWK Set O1WH=$(warehouseNumber) ", stmtSQL)
  @dtw_concat(stmtSQL, " Where O1OCTL=$(orderControlNumber) and O1ORL#=$(lineNumber) @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)
  <script TYPE="text/javascript">
      opener.location.href=opener.location.href;
      window.close()
  </script>
%}