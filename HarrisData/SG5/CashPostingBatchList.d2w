%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "A/R Payment Batch List"
  d2wName                 = "CashPostingBatchList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "5"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {

                  if (editNum(document.Chg.fromBatchNumber, 4, 0) &&
                      editNum(document.Chg.toBatchNumber, 4, 0) &&
                      editdate(document.Chg.fromBatchDate) &&
                      editdate(document.Chg.toBatchDate) &&
                      editNum(document.Chg.fromBankNumber, 2, 0) &&
                      editNum(document.Chg.toBankNumber, 2, 0) &&
                      editFromToAll(document.Chg.fromBatchType, document.Chg.toBatchType, document.Chg.allBatchType, "A") &&
                      editFromToAll(document.Chg.fromBatchNumber, document.Chg.toBatchNumber, document.Chg.allBatchNumber, 4) &&
                      editFromToAll(document.Chg.fromBatchDate, document.Chg.toBatchDate, document.Chg.allBatchDate, "D") &&
                      editFromToAll(document.Chg.fromBankNumber, document.Chg.toBankNumber, document.Chg.allBankNumber, 2) &&
                      editFromToAll(document.Chg.fromBatchStatus, document.Chg.toBatchStatus, document.Chg.allBatchStatus, "A")
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CASHPOSTINGBATCHLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromBatchType")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@styp", "sortBatchType")        @dtw_assign(Err_N1STYP,  fieldValue)
                                  @DecatErr_Field("@@sbno", "sortBatchNumber")        @dtw_assign(Err_N1SBNO,  fieldValue)
                                  @DecatErr_Field("@@sbdt", "sortBatchDate")          @dtw_assign(Err_N1SBDT,  fieldValue)
                                  @DecatErr_Field("@@sbnk", "sortBankNumber")        @dtw_assign(Err_N1SBNK,  fieldValue)
                                  @DecatErr_Field("@@sbst", "sortBatchStatus")        @dtw_assign(Err_N1SBST,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@ftyp")  @dtw_assign(V_N1FTYP,  fieldValue)
                                  @Decat_Field("@@ttyp")  @dtw_assign(V_N1TTYP,  fieldValue)
                                  @Decat_Field("@@atyp")  @dtw_assign(V_N1ATYP,  fieldValue)
                                  @Decat_Field("@@styp")  @dtw_assign(V_N1STYP,  fieldValue)
                                  @Decat_Field("@@ptyp")  @dtw_assign(V_N1PTYP,  fieldValue)
                                  @Decat_Field("@@fbno")  @dtw_assign(V_N1FBNO,  fieldValue)
                                  @Decat_Field("@@tbno")  @dtw_assign(V_N1TBNO,  fieldValue)
                                  @Decat_Field("@@abno")  @dtw_assign(V_N1ABNO,  fieldValue)
                                  @Decat_Field("@@sbno")  @dtw_assign(V_N1SBNO,  fieldValue)
                                  @Decat_Field("@@pbno")  @dtw_assign(V_N1PBNO,  fieldValue)
                                  @Decat_Field("@@fbdt")  @dtw_assign(V_N1FBDT,  fieldValue)
                                  @Decat_Field("@@tbdt")  @dtw_assign(V_N1TBDT,  fieldValue)
                                  @Decat_Field("@@abdt")  @dtw_assign(V_N1ABDT,  fieldValue)
                                  @Decat_Field("@@sbdt")  @dtw_assign(V_N1SBDT,  fieldValue)
                                  @Decat_Field("@@pbdt")  @dtw_assign(V_N1PBDT,  fieldValue)
                                  @Decat_Field("@@fbnk")  @dtw_assign(V_N1FBNK,  fieldValue)
                                  @Decat_Field("@@tbnk")  @dtw_assign(V_N1TBNK,  fieldValue)
                                  @Decat_Field("@@abnk")  @dtw_assign(V_N1ABNK,  fieldValue)
                                  @Decat_Field("@@sbnk")  @dtw_assign(V_N1SBNK,  fieldValue)
                                  @Decat_Field("@@pbnk")  @dtw_assign(V_N1PBNK,  fieldValue)
                                  @Decat_Field("@@fbst")  @dtw_assign(V_N1FBST,  fieldValue)
                                  @Decat_Field("@@tbst")  @dtw_assign(V_N1TBST,  fieldValue)
                                  @Decat_Field("@@abst")  @dtw_assign(V_N1ABST,  fieldValue)
                                  @Decat_Field("@@sbst")  @dtw_assign(V_N1SBST,  fieldValue)
                                  @Decat_Field("@@pbst")  @dtw_assign(V_N1PBST,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1ATYP == "ALL")
                                      @dtw_assign(checkedAllBatchType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllBatchType, "")
                                  %endif
                                  %if (V_N1ABNO == "ALL")
                                      @dtw_assign(checkedAllBatchNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllBatchNumber, "")
                                  %endif
                                  %if (V_N1ABDT == "ALL")
                                      @dtw_assign(checkedAllBatchDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllBatchDate, "")
                                  %endif
                                  %if (V_N1ABNK == "ALL")
                                      @dtw_assign(checkedAllBankNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllBankNumber, "")
                                  %endif
                                  %if (V_N1ABST == "ALL")
                                      @dtw_assign(checkedAllBatchStatus, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllBatchStatus, "")
                                  %endif

                                  %if (V_N1PTYP == "Y")
                                      @dtw_assign(checkedBatchTypeTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedBatchTypeTotals, "")
                                  %endif
                                  %if (V_N1PBNO == "Y")
                                      @dtw_assign(checkedBatchNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedBatchNumberTotals, "")
                                  %endif
                                  %if (V_N1PBDT == "Y")
                                      @dtw_assign(checkedBatchDateTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedBatchDateTotals, "")
                                  %endif
                                  %if (V_N1PBNK == "Y")
                                      @dtw_assign(checkedBankNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedBankNumberTotals, "")
                                  %endif
                                  %if (V_N1PBST == "Y")
                                      @dtw_assign(checkedBatchStatusTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedBatchStatusTotals, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedAllBatchType, "CHECKED")
                                  @dtw_assign(checkedAllBatchNumber, "CHECKED")
                                  @dtw_assign(checkedAllBatchDate, "CHECKED")
                                  @dtw_assign(checkedAllBankNumber, "CHECKED")
                                  @dtw_assign(checkedAllBatchStatus, "CHECKED")
                              %endif

                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                                  <td class="colhdr">Print<br>Totals</td>
                              </tr>

                              @SetTextOvr(Err_N1FTYP)
                              %if (textOvr == "") @SetTextOvr(Err_N1STYP) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Batch Type</span></td>
                                  <td class="inputalph"><input type="text" name="fromBatchType" value="$(V_N1FTYP)" size="6" maxlength="1"></td>
                                  <td class="inputalph"><input type="text" name="toBatchType" value="$(V_N1TTYP)" size="6" maxlength="1"></td>
                                  <td class="inputalph"><input type="checkbox" name="allBatchType" value='ALL' $(checkedAllBatchType) onClick="if (this.checked) this.form.fromBatchType.value='', this.form.toBatchType.value='';"></td>
                                  @Build_Sort_Select("sortBatchType", "$(V_N1STYP)")
                                  <td align=center ><input type="checkbox" name="totalBatchType" $(checkedBatchTypeTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1STYP)

                              @SetTextOvr(Err_N1FBNO)
                              %if (textOvr == "") @SetTextOvr(Err_N1SBNO) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Batch</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromBatchNumber" value="$(V_N1FBNO)" size="6" maxlength="4"></td>
                                  <td class="inputnmbr"><input type="text" name="toBatchNumber" value="$(V_N1TBNO)" size="6" maxlength="4"></td>
                                  <td class="inputalph"><input type="checkbox" name="allBatchNumber" value='ALL' $(checkedAllBatchNumber) onClick="if (this.checked) this.form.fromBatchNumber.value='', this.form.toBatchNumber.value='';"></td>
                                  @Build_Sort_Select("sortBatchNumber", "$(V_N1SBNO)")
                                  <td align=center ><input type="checkbox" name="totalBatchNumber" $(checkedBatchNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1SBNO)

                              @SetTextOvr(Err_N1FBDT)
                              %if (textOvr == "") @SetTextOvr(Err_N1SBDT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Batch Date </span></td>
                                  <td class="inputnmbr"><input type="text" name="fromBatchDate" value="$(V_N1FBDT)" size="6" maxlength="6">
                                                        <a href="javascript:calWindow('fromBatchDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input type="text" name="toBatchDate" value="$(V_N1TBDT)" size="6" maxlength="6">
                                                        <a href="javascript:calWindow('toBatchDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input type="checkbox" name="allBatchDate" value='ALL' $(checkedAllBatchDate) onClick="if (this.checked) this.form.fromBatchDate.value='', this.form.toBatchDate.value='';"></td>
                                  @Build_Sort_Select("sortBatchDate", "$(V_N1SBDT)")
                                  <td align=center ><input type="checkbox" name="totalBatchDate" $(checkedBatchDateTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1SBDT)

                              @SetTextOvr(Err_N1FBNK)
                              %if (textOvr == "") @SetTextOvr(Err_N1SBNK) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Bank</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromBankNumber" value="$(V_N1FBNK)" size="6" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)BankSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromBankNumber&amp;fldDesc=bankName" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input name="bankName"  type="hidden"></td>
                                  <td class="inputnmbr"><input type="text" name="toBankNumber" value="$(V_N1TBNK)" size="6" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)BankSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toBankNumber&amp;fldDesc=bankName" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input name="bankName"  type="hidden"></td>
                                  <td class="inputalph"><input type="checkbox" name="allBankNumber" value='ALL' $(checkedAllBankNumber) onClick="if (this.checked) this.form.fromBankNumber.value='', this.form.toBankNumber.value='';"></td>
                                  @Build_Sort_Select("sortBankNumber", "$(V_N1SBNK)")
                                  <td align=center ><input type="checkbox" name="totalBankNumber" $(checkedBankNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1SBNK)

                              @SetTextOvr(Err_N1FBST)
                              %if (textOvr == "") @SetTextOvr(Err_N1SBST) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Batch Status</span></td>
                                  <td class="inputalph"><input type="text" name="fromBatchStatus" value="$(V_N1FBST)" size="6" maxlength="1"></td>
                                  <td class="inputalph"><input type="text" name="toBatchStatus" value="$(V_N1TBST)" size="6" maxlength="1"></td>
                                  <td class="inputalph"><input type="checkbox" name="allBatchStatus" value='ALL' $(checkedAllBatchStatus) onClick="if (this.checked) this.form.fromBatchStatus.value='', this.form.toBatchStatus.value='';"></td>
                                  @Build_Sort_Select("sortBatchStatus", "$(V_N1SBST)")
                                  <td align=center ><input type="checkbox" name="totalBatchStatus" $(checkedBatchStatusTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1SBST)

                          </table>
                          @dtw_assign(envProgram, "HARBCL")
                          @dtw_assign(envPrinter, "HARBCLPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HARBCS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {

  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(fromBatchType)
  @dtw_mUPPERCASE(toBatchType)
  @dtw_mUPPERCASE(allBatchType)
  @dtw_mUPPERCASE(allBatchNumber)
  @dtw_mUPPERCASE(allBatchDate)
  @dtw_mUPPERCASE(allBankNumber)
  @dtw_mUPPERCASE(fromBatchStatus)
  @dtw_mUPPERCASE(toBatchStatus)
  @dtw_mUPPERCASE(allBatchStatus)

  @dtw_assign(sortBatchType,@dtw_rstrip(sortBatchType))
  @dtw_assign(fromBatchNumber,@dtw_rstrip(fromBatchNumber))
  @dtw_assign(toBatchNumber,@dtw_rstrip(toBatchNumber))
  @dtw_assign(sortBatchNumber,@dtw_rstrip(sortBatchNumber))
  @dtw_assign(fromBatchDate,@dtw_rstrip(fromBatchDate))
  @dtw_assign(toBatchDate,@dtw_rstrip(toBatchDate))
  @dtw_assign(sortBatchDate,@dtw_rstrip(sortBatchDate))
  @dtw_assign(fromBankNumber,@dtw_rstrip(fromBankNumber))
  @dtw_assign(toBankNumber,@dtw_rstrip(toBankNumber))
  @dtw_assign(sortBankNumber,@dtw_rstrip(sortBankNumber))
  @dtw_assign(sortBatchStatus,@dtw_rstrip(sortBatchStatus))

  %if (allBatchType != "ALL")
      @dtw_assign(allBatchType, "")
  %endif
  %if (allBatchNumber != "ALL")
      @dtw_assign(allBatchNumber, "")
  %endif
  %if (allBatchDate != "ALL")
      @dtw_assign(allBatchDate, "")
  %endif
  %if (allBankNumber != "ALL")
      @dtw_assign(allBankNumber, "")
  %endif
  %if (allBatchStatus != "ALL")
      @dtw_assign(allBatchStatus, "")
  %endif

  %if (totalBatchType != "Y")
      @dtw_assign(totalBatchType, "N")
  %endif
  %if (totalBatchNumber != "Y")
      @dtw_assign(totalBatchNumber, "N")
  %endif
  %if (totalBatchDate != "Y")
      @dtw_assign(totalBatchDate, "N")
  %endif
  %if (totalBankNumber != "Y")
      @dtw_assign(totalBankNumber, "N")
  %endif
  %if (totalBatchStatus != "Y")
      @dtw_assign(totalBatchStatus, "N")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@ftyp", fromBatchType)
  @Concat_Field("@@ttyp", toBatchType)
  @Concat_Field("@@atyp", allBatchType)
  @Concat_Field("@@styp", sortBatchType)
  @Concat_Field("@@ptyp", totalBatchType)
  @Concat_Field("@@fbno", fromBatchNumber)
  @Concat_Field("@@tbno", toBatchNumber)
  @Concat_Field("@@abno", allBatchNumber)
  @Concat_Field("@@sbno", sortBatchNumber)
  @Concat_Field("@@pbno", totalBatchNumber)
  @Concat_Field("@@fbdt", fromBatchDate)
  @Concat_Field("@@tbdt", toBatchDate)
  @Concat_Field("@@abdt", allBatchDate)
  @Concat_Field("@@sbdt", sortBatchDate)
  @Concat_Field("@@pbdt", totalBatchDate)
  @Concat_Field("@@fbnk", fromBankNumber)
  @Concat_Field("@@tbnk", toBankNumber)
  @Concat_Field("@@abnk", allBankNumber)
  @Concat_Field("@@sbnk", sortBankNumber)
  @Concat_Field("@@pbnk", totalBankNumber)
  @Concat_Field("@@fbst", fromBatchStatus)
  @Concat_Field("@@tbst", toBatchStatus)
  @Concat_Field("@@abst", allBatchStatus)
  @Concat_Field("@@sbst", sortBatchStatus)
  @Concat_Field("@@pbst", totalBatchStatus)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}