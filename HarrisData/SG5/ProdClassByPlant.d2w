%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define{
  page_title              = "Product Class By Plant"
  d2wName                 = "ProdClassByPlant.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;productClass=@dtw_rurlescseq(productClass)&amp;productClassDesc=@dtw_rurlescseq(productClassDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HHDPCP"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "PRODCLASSBYPLT")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
					  @dtw_concat(stmtSQL, " Select a.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(PLNAME,'Product Class Default') as PLNAME ", stmtSQL)
                      @dtw_concat(fileSQL, " HDPCLP a ", fileSQL)
                      @dtw_concat(fileSQL, " left outer join HDPLNT on a.PPPLT=PLPLNT ", fileSQL)
					  %if ($(accountsByProdClass) == "Y")
                          @dtw_concat(stmtSQL, ", coalesce(CAFSIA,'0') as CAFSIA ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAFSIS,'0') as CAFSIS ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAVSVA,'0') as CAVSVA ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAVSVS,'0') as CAVSVS ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAUVRA,'0') as CAUVRA ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAUVRS,'0') as CAUVRS ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAWP1A,'0') as CAWP1A ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAWP1S,'0') as CAWP1S ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAWP2A,'0') as CAWP2A ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAWP2S,'0') as CAWP2S ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAWP3A,'0') as CAWP3A ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAWP3S,'0') as CAWP3S ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAWP4A,'0') as CAWP4A ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAWP4S,'0') as CAWP4S ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAWP5A,'0') as CAWP5A ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAWP5S,'0') as CAWP5S ", stmtSQL)
                          @dtw_concat(stmtSQL, ", coalesce(CAWV1A,'0') as CAWV1A ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAWV1S,'0') as CAWV1S ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAWV2A,'0') as CAWV2A ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAWV2S,'0') as CAWV2S ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAWV3A,'0') as CAWV3A ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAWV3S,'0') as CAWV3S ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAWV4A,'0') as CAWV4A ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAWV4S,'0') as CAWV4S ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAWV5A,'0') as CAWV5A ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAWV5S,'0') as CAWV5S ", stmtSQL) 	
					      @dtw_concat(stmtSQL, ", coalesce(CAMA1A,'0') as CAMA1A ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAMA1S,'0') as CAMA1S ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAMA2A,'0') as CAMA2A ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAMA2S,'0') as CAMA2S ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAMA3A,'0') as CAMA3A ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAMA3S,'0') as CAMA3S ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAMA4A,'0') as CAMA4A ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAMA4S,'0') as CAMA4S ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAMA5A,'0') as CAMA5A ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAMA5S,'0') as CAMA5S ", stmtSQL)
                          @dtw_concat(stmtSQL, ", coalesce(CAPA1A,'0') as CAPA1A ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAPA1S,'0') as CAPA1S ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAPA2A,'0') as CAPA2A ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAPA2S,'0') as CAPA2S ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAPA3A,'0') as CAPA3A ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAPA3S,'0') as CAPA3S ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAPA4A,'0') as CAPA4A ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAPA4S,'0') as CAPA4S ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAPA5A,'0') as CAPA5A ", stmtSQL) 
						  @dtw_concat(stmtSQL, ", coalesce(CAPA5S,'0') as CAPA5S ", stmtSQL) 			 					  
					      @dtw_concat(fileSQL, " left outer join HDPCLA on a.PPPLT=CAPLNT and a.PPPCLS=CAPCLS ", fileSQL)
					  %endif	   
                      @dtw_concat(selectSQL, "PPPCLS='$(productClass)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @ProdClassByPlant_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) ProdClassByPlant_Query (IN CHAR(64)    profileHandle,
                                              CHAR(2)     dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count == "0" && wildCardSearch=="")
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)ProdClassByPlantMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;plantNumber=0&amp;maintenanceCode=A">
      %else
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td ><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                      <td class="toolbar">
                          <a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&tblID=158" title="Back Home">$(portalHome)</a>
                          %if (sec_01 == "Y")
                              <a href="$(homeURL)$(cGIPath)ProdClassByPlantMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
          </table>

          <table $(contentTable)>
              @Format_Header_URL("Product Class", $(productClassDesc), $(productClass), "")
          </table>
          %INCLUDE "ConfMessageDisplay.icl"

          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Plant</th>
                      </tr>
                      <tr><td><input type="text" class="inputnmbr" name="srchPlant" size="4" maxlength="3">
                              <input type="hidden" name="operPlant" value="=">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchPlant.focus();
                  </script>
              </form>

              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              <tr>
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("PPPLT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Plant" title="Sequence By Plant">Plant</a></th>
                  <th class="colhdr">Name</th>
                  @OrderBy_Sort("PPSLAC", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SalesAccount" title="Sequence By Sales Account, Plant">Sales<br>Account</a></th>
                  @OrderBy_Sort("PPC1AC", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CostCat1Account" title="Sequence By Cost Category 1 Account, Plant">Cost Category 1<br>Account</a></th>
                  @OrderBy_Sort("PPC2AC", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CostCat2Account" title="Sequence By Cost Category 2 Account, Plant">Cost Category 2<br>Account</a></th>
                  @OrderBy_Sort("PPC3AC", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CostCat3Account" title="Sequence By Cost Category 3 Account, Plant">Cost Category 3<br>Account</a></th>
                  @OrderBy_Sort("PPC4AC", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CostCat4Account" title="Sequence By Cost Category 4 Account, Plant">Cost Category 4<br>Account</a></th>
                  @OrderBy_Sort("PPC5AC", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CostCat5Account" title="Sequence By Cost Category 5 Account, Plant">Cost Category 5<br>Account</a></th>
                  
				  %if ($(accountsByProdClass) == "Y")
				  
				      @OrderBy_Sort("CAFSIA", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FlrStkInvAccount" title="Sequence By Floorstock Inventory Account, Plant">FloorStock  Inv<br>Account</a></th>
                      @OrderBy_Sort("CAVSVA", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=VndSvcVarAccount" title="Sequence By Vendor Services Variance Account, Plant">Vnd Serv Var <br>Account</a></th>
                      @OrderBy_Sort("CAUVRA", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=UnvRecptAccount" title="Sequence By Unvouchered Receipts Account, Plant">Unv Receipts<br>Account</a></th>
				  
				      @OrderBy_Sort("CAWP1A", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=WipCostCat1Account" title="Sequence By WIP Cost Category 1 Account, Plant">WIP Cost Cat 1<br>Account</a></th>
                      @OrderBy_Sort("CAWP2A", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=WipCostCat2Account" title="Sequence By WIP Cost Category 2 Account, Plant">WIP Cost Cat 2<br>Account</a></th>
                      @OrderBy_Sort("CAWP3A", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=WipCostCat3Account" title="Sequence By WIP Cost Category 3 Account, Plant">WIP Cost Cat 3<br>Account</a></th>
                      @OrderBy_Sort("CAWP4A", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=WipCostCat4Account" title="Sequence By WIP Cost Category 4 Account, Plant">WIP Cost Cat 4<br>Account</a></th>
                      @OrderBy_Sort("CAWP5A", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=WipCostCat5Account" title="Sequence By WIP Cost Category 5 Account, Plant">WIP Cost Cat 5<br>Account</a></th>
					  
					  @OrderBy_Sort("CAWV1A", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=WipVarCostCat1Account" title="Sequence By WIP Variance Cost Category 1 Account, Plant">WIP Var Cost Cat 1<br>Account</a></th>
                      @OrderBy_Sort("CAWV2A", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=WipVarCostCat2Account" title="Sequence By WIP Variance Cost Category 2 Account, Plant">WIP Var Cost Cat 2<br>Account</a></th>
                      @OrderBy_Sort("CAWV3A", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=WipVarCostCat3Account" title="Sequence By WIP Variance Cost Category 3 Account, Plant">WIP Var Cost Cat 3<br>Account</a></th>
                      @OrderBy_Sort("CAWV4A", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=WipVarCostCat4Account" title="Sequence By WIP Variance Cost Category 4 Account, Plant">WIP Var Cost Cat 4<br>Account</a></th>
                      @OrderBy_Sort("CAWV5A", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=WipVarCostCat5Account" title="Sequence By WIP Variance Cost Category 5 Account, Plant">WIP Var Cost Cat 5<br>Account</a></th>
				  
				      @OrderBy_Sort("CAMA1A", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MfgCostAbsCat1Account" title="Sequence By Mfg Cost Absorption Category 1 Account, Plant">Mfg Cost Abs Cat 1<br>Account</a></th>
                      @OrderBy_Sort("CAMA2A", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MfgCostAbsCat2Account" title="Sequence By Mfg Cost Absorption Category 2 Account, Plant">Mfg Cost Abs Cat 2<br>Account</a></th>
                      @OrderBy_Sort("CAMA3A", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MfgCostAbsCat3Account" title="Sequence By Mfg Cost Absorption Category 3 Account, Plant">Mfg Cost Abs Cat 3<br>Account</a></th>
                      @OrderBy_Sort("CAMA4A", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MfgCostAbsCat4Account" title="Sequence By Mfg Cost Absorption Category 4 Account, Plant">Mfg Cost Abs Cat 4<br>Account</a></th>
                      @OrderBy_Sort("CAMA5A", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MfgCostAbsCat5Account" title="Sequence By Mfg Cost Absorption Category 5 Account, Plant">Mfg Cost Abs Cat 5<br>Account</a></th>
					  
					  @OrderBy_Sort("CAPA1A", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PurCostAbsCat1Account" title="Sequence By Pur Cost Absorption Category 1 Account, Plant">Pur Cost Abs Cat 1<br>Account</a></th>
                      @OrderBy_Sort("CAPA2A", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PurCostAbsCat2Account" title="Sequence By Pur Cost Absorption Category 2 Account, Plant">Pur Cost Abs Cat 2<br>Account</a></th>
                      @OrderBy_Sort("CAPA3A", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PurCostAbsCat3Account" title="Sequence By Pur Cost Absorption Category 3 Account, Plant">Pur Cost Abs Cat 3<br>Account</a></th>
                      @OrderBy_Sort("CAPA4A", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PurCostAbsCat4Account" title="Sequence By Pur Cost Absorption Category 4 Account, Plant">Pur Cost Abs Cat 4<br>Account</a></th>
                      @OrderBy_Sort("CAPA5A", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PurCostAbsCat5Account" title="Sequence By Pur Cost Absorption Category 5 Account, Plant">Pur Cost Abs Cat 5<br>Account</a></th>
					  
                  %endif
			  </tr>
              %INCLUDE "NoRecordsFound.icl"
      %endif

          %ROW{
              %if (sql_Record_Count>"0" || wildCardSearch!="")
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(V_PPPLT)&amp;plantName=@dtw_rurlescseq(V_PLNAME)")
                  %INCLUDE "SetRowClass.icl"
                  @Format_Confirm_Desc($(V_PLNAME), $(V_PPPLT), "", "", "", "", confirmDesc)
                  @dtw_assign(F_SalesAcct, "")
                  @dtw_assign(F_Cat1Acct, "")
                  @dtw_assign(F_Cat2Acct, "")
                  @dtw_assign(F_Cat3Acct, "")
                  @dtw_assign(F_Cat4Acct, "")
                  @dtw_assign(F_Cat5Acct, "")
                  @dtw_assign(H_SalesAcct, "")
                  @dtw_assign(H_Cat1Acct, "")
                  @dtw_assign(H_Cat2Acct, "")
                  @dtw_assign(H_Cat3Acct, "")
                  @dtw_assign(H_Cat4Acct, "")
                  @dtw_assign(H_Cat5Acct, "")
				  
                  %if (V_PPSLAC !="0")
                      @Format_Acct(V_PPSLAC, V_PPSLSB, "", F_SalesAcct)
                      @RtvFldDesc("CHACCT=$(V_PPSLAC) and CHSUB=$(V_PPSLSB) ", "HDCHRT", "CHCHDS", H_SalesAcct)
                  %endif
                  %if (V_PPC1AC !="0")
                      @Format_Acct(V_PPC1AC, V_PPC1SB, "", F_Cat1Acct)
                      @RtvFldDesc("CHACCT=$(V_PPC1AC) and CHSUB=$(V_PPC1SB) ", "HDCHRT", "CHCHDS", H_Cat1Acct)
                  %endif
                  %if (V_PPC2AC !="0")
                      @Format_Acct(V_PPC2AC, V_PPC2SB, "", F_Cat2Acct)
                      @RtvFldDesc("CHACCT=$(V_PPC2AC) and CHSUB=$(V_PPC2SB) ", "HDCHRT", "CHCHDS", H_Cat2Acct)
                  %endif
                  %if (V_PPC3AC !="0")
                      @Format_Acct(V_PPC3AC, V_PPC3SB, "", F_Cat3Acct)
                      @RtvFldDesc("CHACCT=$(V_PPC3AC) and CHSUB=$(V_PPC3SB) ", "HDCHRT", "CHCHDS", H_Cat3Acct)
                  %endif
                  %if (V_PPC4AC !="0")
                      @Format_Acct(V_PPC4AC, V_PPC4SB, "", F_Cat4Acct)
                      @RtvFldDesc("CHACCT=$(V_PPC4AC) and CHSUB=$(V_PPC4SB) ", "HDCHRT", "CHCHDS", H_Cat4Acct)
                  %endif
                  %if (V_PPC5AC !="0")
                      @Format_Acct(V_PPC5AC, V_PPC5SB, "", F_Cat5Acct)
                      @RtvFldDesc("CHACCT=$(V_PPC5AC) and CHSUB=$(V_PPC5SB) ", "HDCHRT", "CHCHDS", H_Cat5Acct)
                  %endif
				  
				  %if ($(accountsByProdClass) == "Y")
				  
				      @dtw_assign(F_FlrStkInvAcct, "")
					  @dtw_assign(H_FlrStkInvAcct, "")
                      @dtw_assign(F_VndSvcVarAcct, "")
					  @dtw_assign(H_VndSvcVarAcct, "")
                      @dtw_assign(F_UnvRcptAcct, "")
					  @dtw_assign(H_UnvRcptAcct, "")
                      				  
				      @dtw_assign(F_WipCostCat1Acct, "")
                      @dtw_assign(F_WipCostCat2Acct, "")
                      @dtw_assign(F_WipCostCat3Acct, "")
                      @dtw_assign(F_WipCostCat4Acct, "")
                      @dtw_assign(F_WipCostCat5Acct, "")
                      @dtw_assign(H_WipCostCat1Acct, "")
                      @dtw_assign(H_WipCostCat2Acct, "")
                      @dtw_assign(H_WipCostCat3Acct, "")
                      @dtw_assign(H_WipCostCat4Acct, "")
                      @dtw_assign(H_WipCostCat5Acct, "")		
				  
                      @dtw_assign(F_WipVarCat1Acct, "")
                      @dtw_assign(F_WipVarCat2Acct, "")
                      @dtw_assign(F_WipVarCat3Acct, "")
                      @dtw_assign(F_WipVarCat4Acct, "")
                      @dtw_assign(F_WipVarCat5Acct, "")
                      @dtw_assign(H_WipVarCat1Acct, "")
                      @dtw_assign(H_WipVarCat2Acct, "")
                      @dtw_assign(H_WipVarCat3Acct, "")
                      @dtw_assign(H_WipVarCat4Acct, "")
                      @dtw_assign(H_WipVarCat5Acct, "")				  
				  
				      @dtw_assign(F_MfgAbsCat1Acct, "")
                      @dtw_assign(F_MfgAbsCat2Acct, "")
                      @dtw_assign(F_MfgAbsCat3Acct, "")
                      @dtw_assign(F_MfgAbsCat4Acct, "")
                      @dtw_assign(F_MfgAbsCat5Acct, "")
                      @dtw_assign(H_MfgAbsCat1Acct, "")
                      @dtw_assign(H_MfgAbsCat2Acct, "")
