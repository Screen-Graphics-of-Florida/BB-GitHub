                      %endif
					  
                  %endif
 				  
                  <tr class="$(rowClass)">
                      %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                          <td class="opticon">
                              %if (sec_02 == "Y" || sec_03 == "Y")
                                  <a href="$(homeURL)$(cGIPath)ProdClassByPlantMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                              %endif
                              %if (sec_01=="Y" && sec_04=="Y")
                                  <a href="$(homeURL)$(cGIPath)ProdClassByPlantMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                              %endif
                              %if (sec_03 == "Y" && V_PPPLT>"0")
                                  <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)ProdClassByPlantMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                              %endif
                          </td>
                      %endif
                      <td class="colnmbr">$(V_PPPLT)</td>
                      <td class="colalph">$(V_PLNAME)</td>
                      <td class="colcode" $(helpCursor)><span title="$(H_SalesAcct)">$(F_SalesAcct)</span></td>
                      <td class="colcode" $(helpCursor)><span title="$(H_Cat1Acct)">$(F_Cat1Acct)</span></td>
                      <td class="colcode" $(helpCursor)><span title="$(H_Cat2Acct)">$(F_Cat2Acct)</span></td>
                      <td class="colcode" $(helpCursor)><span title="$(H_Cat3Acct)">$(F_Cat3Acct)</span></td>
                      <td class="colcode" $(helpCursor)><span title="$(H_Cat4Acct)">$(F_Cat4Acct)</span></td>
                      <td class="colcode" $(helpCursor)><span title="$(H_Cat5Acct)">$(F_Cat5Acct)</span></td>
					  %if ($(accountsByProdClass) == "Y")
					      <td class="colcode" $(helpCursor)><span title="$(H_FlrStkInvAcct)">$(F_FlrStkInvAcct)</span></td>
                          <td class="colcode" $(helpCursor)><span title="$(H_VndSvcVarAcct)">$(F_VndSvcVarAcct)</span></td>
                          <td class="colcode" $(helpCursor)><span title="$(H_UnvRcptAcct)">$(F_UnvRcptAcct)</span></td>
					      <td class="colcode" $(helpCursor)><span title="$(H_WipCostCat1Acct)">$(F_WipCostCat1Acct)</span></td>
                          <td class="colcode" $(helpCursor)><span title="$(H_WipCostCat2Acct)">$(F_WipCostCat2Acct)</span></td>
                          <td class="colcode" $(helpCursor)><span title="$(H_WipCostCat3Acct)">$(F_WipCostCat3Acct)</span></td>
                          <td class="colcode" $(helpCursor)><span title="$(H_WipCostCat4Acct)">$(F_WipCostCat4Acct)</span></td>
                          <td class="colcode" $(helpCursor)><span title="$(H_WipCostCat5Acct)">$(F_WipCostCat5Acct)</span></td>
						  <td class="colcode" $(helpCursor)><span title="$(H_WipVarCat1Acct)">$(F_WipVarCat1Acct)</span></td>
                          <td class="colcode" $(helpCursor)><span title="$(H_WipVarCat2Acct)">$(F_WipVarCat2Acct)</span></td>
                          <td class="colcode" $(helpCursor)><span title="$(H_WipVarCat3Acct)">$(F_WipVarCat3Acct)</span></td>
