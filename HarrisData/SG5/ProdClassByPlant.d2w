          $(hrTagAttr)
          %INCLUDE "Copyright.icl"
      %endif
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select a.*, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(PLNAME,'Plant Default') as PLNAME ", stmtSQL)
  @dtw_concat(fileSQL, " HDPCLP a ", fileSQL)
  @dtw_concat(fileSQL, " left outer join HDPLNT on a.PPPLT=PLPLNT ", fileSQL)
  %if ($(accountsByProdClass) == "Y")
      @dtw_concat(stmtSQL, ", coalesce(CAFSIA,'0') as CAFSIA ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAFSIS,'0') as CAFSIS ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAVSVA,'0') as CAVSVA ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAVSVS,'0') as CAVSVS ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAUVRA,'0') as CAUVRA ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAUVRS,'0') as CAUVRS ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAWP1A,'0') as CAWP1A ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAWP1S,'0') as CAWP1S ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAWP2A,'0') as CAWP2A ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAWP2S,'0') as CAWP2S ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAWP3A,'0') as CAWP3A ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAWP3S,'0') as CAWP3S ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAWP4A,'0') as CAWP4A ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAWP4S,'0') as CAWP4S ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAWP5A,'0') as CAWP5A ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAWP5S,'0') as CAWP5S ", stmtSQL)
      @dtw_concat(stmtSQL, ", coalesce(CAWV1A,'0') as CAWV1A ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAWV1S,'0') as CAWV1S ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAWV2A,'0') as CAWV2A ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAWV2S,'0') as CAWV2S ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAWV3A,'0') as CAWV3A ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAWV3S,'0') as CAWV3S ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAWV4A,'0') as CAWV4A ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAWV4S,'0') as CAWV4S ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAWV5A,'0') as CAWV5A ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAWV5S,'0') as CAWV5S ", stmtSQL) 	
	  @dtw_concat(stmtSQL, ", coalesce(CAMA1A,'0') as CAMA1A ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAMA1S,'0') as CAMA1S ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAMA2A,'0') as CAMA2A ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAMA2S,'0') as CAMA2S ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAMA3A,'0') as CAMA3A ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAMA3S,'0') as CAMA3S ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAMA4A,'0') as CAMA4A ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAMA4S,'0') as CAMA4S ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAMA5A,'0') as CAMA5A ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAMA5S,'0') as CAMA5S ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAPA1A,'0') as CAPA1A ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAPA1S,'0') as CAPA1S ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAPA2A,'0') as CAPA2A ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAPA2S,'0') as CAPA2S ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAPA3A,'0') as CAPA3A ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAPA3S,'0') as CAPA3S ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAPA4A,'0') as CAPA4A ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAPA4S,'0') as CAPA4S ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAPA5A,'0') as CAPA5A ", stmtSQL) 
	  @dtw_concat(stmtSQL, ", coalesce(CAPA5S,'0') as CAPA5S ", stmtSQL) 
	  @dtw_concat(fileSQL, " left outer join HDPCLA on a.PPPLT=CAPLNT and a.PPPCLS=CAPCLS ", fileSQL)
  %endif	   
  @dtw_concat(selectSQL, "PPPCLS='$(productClass)' ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @ProdClassByPlant_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) ProdClassByPlant_XMLQuery (IN CHAR(64)    profileHandle,
                                                 CHAR(2)     dataBaseID,
                                                 CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("ProductClassByPlantList")
          @XMLIDTag(productClass, "ProductClass ID")
      @XMLTag(productClass, "ProductClass")
      @XMLTag(productClassDesc, "ProductClassDesc")

          %ROW{
	       @XMLIDTag(V_PPPLT, "PlantNumber ID")
                  @XMLTag(V_PPPLT, "PlantNumber")
                  @XMLTag(V_PLNAME, "PlantName")
                  @XMLTag(V_PPSLAC, "SalesAccount")
                  @XMLTag(V_PPSLSB, "SalesSubaccount")
                  @XMLTag("$(V_PPSLAC)-$(V_PPSLSB)", "SalesAccountSub")
                  @XMLTag(V_PPC1AC, "CostCategory1Account")
                  @XMLTag(V_PPC1SB, "CostCategory1Subaccount")
                  @XMLTag("$(V_PPC1AC)-$(V_PPC1SB)", "CostCategory1AccountSub")
                  @XMLTag(V_PPC2AC, "CostCategory1Account")
                  @XMLTag(V_PPC2SB, "CostCategory2Subaccount")
                  @XMLTag("$(V_PPC2AC)-$(V_PPC2SB)", "CostCategory2AccountSub")
                  @XMLTag(V_PPC3AC, "CostCategory3Account")
                  @XMLTag(V_PPC3SB, "CostCategory3Subaccount")
                  @XMLTag("$(V_PPC3AC)-$(V_PPC3SB)", "CostCategory3AccountSub")
                  @XMLTag(V_PPC4AC, "CostCategory4Account")
                  @XMLTag(V_PPC4SB, "CostCategory4Subaccount")
                  @XMLTag("$(V_PPC4AC)-$(V_PPC4SB)", "CostCategory4AccountSub")
                  @XMLTag(V_PPC5AC, "CostCategory5Account")
                  @XMLTag(V_PPC5SB, "CostCategory5Subaccount")
                  @XMLTag("$(V_PPC5AC)-$(V_PPC5SB)", "CostCategory5AccountSub")
				  %if ("$(accountsByProdClass)" == "Y")
				      @XMLTag(V_CAFSIA, "FlrStkInvAccount")
                      @XMLTag(V_CAFSIS, "FlrStkInvSubaccount")
                      @XMLTag("$(V_CAFSIA)-$(V_CAFSIS)", "FlrStkInvAccountSub")
                      @XMLTag(V_CAVSVA, "VndSvcVarAccount")
                      @XMLTag(V_CAVSVS, "VndSvcVarSubaccount")
                      @XMLTag("$(V_CAVSVA)-$(V_CAVSVS)", "VndSvcVarAccountSub")
					  @XMLTag(V_CAUVRA, "UnvRecptAccount")
                      @XMLTag(V_CAUVRS, "UnvRecptSubaccount")
                      @XMLTag("$(V_CAUVRA)-$(V_CAUVRS)", "UnvRecptAccountSub")
				      @XMLTag(V_CAWP1A, "WipCostCategory1Account")
                      @XMLTag(V_CAWP1S, "WipCostCategory1Subaccount")
                      @XMLTag("$(V_CAWP1A)-$(V_CAWP1S)", "WipCostCategory1AccountSub")
                      @XMLTag(V_CAWP2A, "WipCostCategory2Account")
                      @XMLTag(V_CAWP2S, "WipCostCategory2Subaccount")
                      @XMLTag("$(V_CAWP2A)-$(V_CAWP2S)", "WipCostCategory2AccountSub")
					  @XMLTag(V_CAWP3A, "WipCostCategory3Account")
                      @XMLTag(V_CAWP3S, "WipCostCategory3Subaccount")
                      @XMLTag("$(V_CAWP3A)-$(V_CAWP3S)", "WipCostCategory3AccountSub")
					  @XMLTag(V_CAWP4A, "WipCostCategory4Account")
                      @XMLTag(V_CAWP4S, "WipCostCategory4Subaccount")
                      @XMLTag("$(V_CAWP4A)-$(V_CAWP4S)", "WipCostCategory4AccountSub")
					  @XMLTag(V_CAWP5A, "WipCostCategory5Account")
                      @XMLTag(V_CAWP5S, "WipCostCategory5Subaccount")
                      @XMLTag("$(V_CAWP5A)-$(V_CAWP5S)", "WipCostCategory5AccountSub")
					  @XMLTag(V_CAWV1A, "WipVarCategory1Account")
                      @XMLTag(V_CAWV1S, "WipVarCategory1Subaccount")
                      @XMLTag("$(V_CAWV1A)-$(V_CAWV1S)", "WipVarCategory1AccountSub")
                      @XMLTag(V_CAWV2A, "WipVarCategory2Account")
                      @XMLTag(V_CAWV2S, "WipVarCategory2Subaccount")
                      @XMLTag("$(V_CAWV2A)-$(V_CAWV2S)", "WipVarCategory2AccountSub")
					  @XMLTag(V_CAWV3A, "WipVarCategory3Account")
                      @XMLTag(V_CAWV3S, "WipVarCategory3Subaccount")
                      @XMLTag("$(V_CAWV3A)-$(V_CAWV3S)", "WipVarCategory3AccountSub")
					  @XMLTag(V_CAWV4A, "WipVarCategory4Account")
                      @XMLTag(V_CAWV4S, "WipVarCategory4Subaccount")
                      @XMLTag("$(V_CAWV4A)-$(V_CAWV4S)", "WipVarCategory4AccountSub")
					  @XMLTag(V_CAWV5A, "WipVarCategory5Account")
                      @XMLTag(V_CAWV5S, "WipVarCategory5Subaccount")
                      @XMLTag("$(V_CAWV5A)-$(V_CAWV5S)", "WipVarCategory5AccountSub")
				      @XMLTag(V_CAMA1A, "MfgCostAbsCategory1Account")
                      @XMLTag(V_CAMA1S, "MfgCostAbsCategory1Subaccount")
                      @XMLTag("$(V_CAMA1A)-$(V_CAMA1S)", "MfgCostAbsCategory1AccountSub")
                      @XMLTag(V_CAMA2A, "MfgCostAbsCategory2Account")
                      @XMLTag(V_CAMA2S, "MfgCostAbsCategory2Subaccount")
