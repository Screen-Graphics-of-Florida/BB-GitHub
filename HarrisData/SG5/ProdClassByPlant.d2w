%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("PPPLT", "Plant", $(srchPlant), "", operPlant, "N")
  @Build_WildCard ("PPSLAC", "Sales Account", $(srchSalesAcct), "", operSaleAcct, "N")
  @Build_WildCard ("PPSLSB", "Sales SubAccount", $(srchSalesSub), "", operSalesSub, "N")
  @Build_WildCard ("PPC1AC", "Cost Category 1 Account", $(srchCat1Acct), "", operCat1Acct, "N")
  @Build_WildCard ("PPC1SB", "Cost Category 1 SubAccount", $(srchCat1Sub), "", operCat1Sub, "N")
  @Build_WildCard ("PPC2AC", "Cost Category 2 Account", $(srchCat2Acct), "", operCat2Acct, "N")
  @Build_WildCard ("PPC2SB", "Cost Category 2 SubAccount", $(srchCat2Sub), "", operCat2Sub, "N")
  @Build_WildCard ("PPC3AC", "Cost Category 3 Account", $(srchCat3Acct), "", operCat3Acct, "N")
  @Build_WildCard ("PPC3SB", "Cost Category 3 SubAccount", $(srchCat3Sub), "", operCat3Sub, "N")
  @Build_WildCard ("PPC4AC", "Cost Category 4 Account", $(srchCat4Acct), "", operCat4Acct, "N")
  @Build_WildCard ("PPC4SB", "Cost Category 4 SubAccount", $(srchCat4Sub), "", operCat4Sub, "N")
  @Build_WildCard ("PPC5AC", "Cost Category 5 Account", $(srchCat5Acct), "", operCat5Acct, "N")
  @Build_WildCard ("PPC5SB", "Cost Category 5 SubAccount", $(srchCat5Sub), "", operCat5Sub, "N")
  %if ($(accountsByProdClass) == "Y")
      @Build_WildCard ("CAFSIA", "Floorstock Inventory Account", $(srchFlrStkInvAcct), "", operFlrStkInvAcct, "N")
      @Build_WildCard ("CAFSIS", "Floorstock Inventory SubAccount", $(srchFlrStkInvSub), "", operFlrStkInvSub, "N")     
      @Build_WildCard ("CAVSVA", "Vendor Services Var Account", $(srchVndSvcVarAcct), "", operVndSvcVarAcct, "N")
      @Build_WildCard ("CAVSVS", "Vendor Services Var SubAccount", $(srchVndSvcVarSub), "", operVndSvcVarSub, "N") 
	  @Build_WildCard ("CAUVRA", "Unvouchered Receipts Account", $(srchUnvRcptAcct), "", operUnvRcptAcct, "N")
      @Build_WildCard ("CAUVRS", "Unvouchered Receipts SubAccount", $(srchUnvRcptSub), "", operUnvRcptSub, "N") 
      
	  @Build_WildCard ("CAWP1A", "WIP Cost Cat 1 Account", $(srchWipCostCat1Acct), "", operWipCostCat1Acct, "N")
      @Build_WildCard ("CAWP1S", "WIP Cost Cat 1 SubAccount", $(srchWipCostCat1Sub), "", operWipCostCat1Sub, "N")     
      @Build_WildCard ("CAWP2A", "WIP Cost Cat 2 Account", $(srchWipCostCat2Acct), "", operWipCostCat2Acct, "N")
