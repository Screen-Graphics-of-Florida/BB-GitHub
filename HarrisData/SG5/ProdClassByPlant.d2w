                          <td class="colcode" $(helpCursor)><span title="$(H_PurAbsCat5Acct)">$(F_PurAbsCat5Acct)</span></td>
                      %endif   						  
                  </tr>
              %endif
          %}
      %if (sql_Record_Count>"0" || wildCardSearch!="")
          </table>
          %INCLUDE "PageBottom.icl"
