%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              function validate(searchForm) {
			     if ("$(accountsByProdClass)" == "Y"          &&
				    editNum(document.Search.srchSalesAcct, 4, 0) &&
                    editNum(document.Search.srchSalesSub, 4, 0)  &&
                    editNum(document.Search.srchCat1Acct, 4, 0) &&
                    editNum(document.Search.srchCat1Sub, 4, 0)  &&
                    editNum(document.Search.srchCat2Acct, 4, 0) &&
                    editNum(document.Search.srchCat2Sub, 4, 0)  &&
                    editNum(document.Search.srchCat3Acct, 4, 0) &&
                    editNum(document.Search.srchCat3Sub, 4, 0)  &&
                    editNum(document.Search.srchCat4Acct, 4, 0) &&
                    editNum(document.Search.srchCat4Sub, 4, 0)  &&
                    editNum(document.Search.srchCat5Acct, 4, 0) &&
                    editNum(document.Search.srchCat5Sub, 4, 0)  &&
				    editNum(document.Search.srchFlrStkInvAcct, 4, 0) &&
                    editNum(document.Search.srchFlrStkInvSub, 4, 0)  &&
                    editNum(document.Search.srchVndSvcVarAcct, 4, 0) &&
                    editNum(document.Search.srchVndSvcVarSub, 4, 0)  &&
                    editNum(document.Search.srchUnvRcptAcct, 4, 0) &&
                    editNum(document.Search.srchUnvRcptSub, 4, 0)  &&
				    editNum(document.Search.srchWipCostCat1Acct, 4, 0) &&
                    editNum(document.Search.srchWipCostCat1Sub, 4, 0)  &&
                    editNum(document.Search.srchWipCostCat2Acct, 4, 0) &&
                    editNum(document.Search.srchWipCostCat2Sub, 4, 0)  &&
                    editNum(document.Search.srchWipCostCat3Acct, 4, 0) &&
                    editNum(document.Search.srchWipCostCat3Sub, 4, 0)  &&
                    editNum(document.Search.srchWipCostCat4Acct, 4, 0) &&
                    editNum(document.Search.srchWipCostCat4Sub, 4, 0)  &&
                    editNum(document.Search.srchWipCostCat5Acct, 4, 0) &&
                    editNum(document.Search.srchWipCostCat5Sub, 4, 0)  &&
				    editNum(document.Search.srchWipVarCat1Acct, 4, 0) &&
                    editNum(document.Search.srchWipVarCat1Sub, 4, 0)  &&
                    editNum(document.Search.srchWipVarCat2Acct, 4, 0) &&
                    editNum(document.Search.srchWipVarCat2Sub, 4, 0)  &&
                    editNum(document.Search.srchWipVarCat3Acct, 4, 0) &&
                    editNum(document.Search.srchWipVarCat3Sub, 4, 0)  &&
                    editNum(document.Search.srchWipVarCat4Acct, 4, 0) &&
                    editNum(document.Search.srchWipVarCat4Sub, 4, 0)  &&
                    editNum(document.Search.srchWipVarCat5Acct, 4, 0) &&
                    editNum(document.Search.srchWipVarCat5Sub, 4, 0)  &&
				    editNum(document.Search.srchMfgAbsCat1Acct, 4, 0) &&
                    editNum(document.Search.srchMfgAbsCat1Sub, 4, 0)  &&
                    editNum(document.Search.srchMfgAbsCat2Acct, 4, 0) &&
                    editNum(document.Search.srchMfgAbsCat2Sub, 4, 0)  &&
                    editNum(document.Search.srchMfgAbsCat3Acct, 4, 0) &&
                    editNum(document.Search.srchMfgAbsCat3Sub, 4, 0)  &&
                    editNum(document.Search.srchMfgAbsCat4Acct, 4, 0) &&
                    editNum(document.Search.srchMfgAbsCat4Sub, 4, 0)  &&
                    editNum(document.Search.srchMfgAbsCat5Acct, 4, 0) &&
                    editNum(document.Search.srchMfgAbsCat5Sub, 4, 0)  &&
			    	editNum(document.Search.srchPurAbsCat1Acct, 4, 0) &&
                    editNum(document.Search.srchPurAbsCat1Sub, 4, 0)  &&
                    editNum(document.Search.srchPurAbsCat2Acct, 4, 0) &&
                    editNum(document.Search.srchPurAbsCat2Sub, 4, 0)  &&
                    editNum(document.Search.srchPurAbsCat3Acct, 4, 0) &&
                    editNum(document.Search.srchPurAbsCat3Sub, 4, 0)  &&
                    editNum(document.Search.srchPurAbsCat4Acct, 4, 0) &&
                    editNum(document.Search.srchPurAbsCat4Sub, 4, 0)  &&
                    editNum(document.Search.srchPurAbsCat5Acct, 4, 0) &&
                    editNum(document.Search.srchPurAbsCat5Sub, 4, 0))
                    return true;
				 if ("$(accountsByProdClass)" == "N"       &&
				    editNum(document.Search.srchSalesAcct, 4, 0) &&
                    editNum(document.Search.srchSalesSub, 4, 0)  &&
                    editNum(document.Search.srchCat1Acct, 4, 0) &&
                    editNum(document.Search.srchCat1Sub, 4, 0)  &&
                    editNum(document.Search.srchCat2Acct, 4, 0) &&
                    editNum(document.Search.srchCat2Sub, 4, 0)  &&
                    editNum(document.Search.srchCat3Acct, 4, 0) &&
                    editNum(document.Search.srchCat3Sub, 4, 0)  &&
                    editNum(document.Search.srchCat4Acct, 4, 0) &&
                    editNum(document.Search.srchCat4Sub, 4, 0)  &&
                    editNum(document.Search.srchCat5Acct, 4, 0) &&
                    editNum(document.Search.srchCat5Sub, 4, 0))
				    return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PRODCLASSBYPLTSEARCH")
