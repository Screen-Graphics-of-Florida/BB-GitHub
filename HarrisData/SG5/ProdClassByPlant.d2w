                          <td class="colcode" $(helpCursor)><span title="$(H_MfgAbsCat2Acct)">$(F_MfgAbsCat2Acct)</span></td>
                          <td class="colcode" $(helpCursor)><span title="$(H_MfgAbsCat3Acct)">$(F_MfgAbsCat3Acct)</span></td>
                          <td class="colcode" $(helpCursor)><span title="$(H_MfgAbsCat4Acct)">$(F_MfgAbsCat4Acct)</span></td>
                          <td class="colcode" $(helpCursor)><span title="$(H_MfgAbsCat5Acct)">$(F_MfgAbsCat5Acct)</span></td>
						  <td class="colcode" $(helpCursor)><span title="$(H_PurAbsCat1Acct)">$(F_PurAbsCat1Acct)</span></td>
