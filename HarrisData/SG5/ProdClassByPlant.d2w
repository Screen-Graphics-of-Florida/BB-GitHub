					  @XMLTag(V_CAMA4A, "MfgCostAbsCategory4Account")
                      @XMLTag(V_CAMA4S, "MfgCostAbsCategory4Subaccount")
                      @XMLTag("$(V_CAMA4A)-$(V_CAMA4S)", "MfgCostAbsCategory4AccountSub")
					  @XMLTag(V_CAMA5A, "MfgCostAbsCategory5Account")
                      @XMLTag(V_CAMA5S, "MfgCostAbsCategory5Subaccount")
                      @XMLTag("$(V_CAMA5A)-$(V_CAMA5S)", "MfgCostAbsCategory5AccountSub")
					  @XMLTag(V_CAPA1A, "PurCostAbsCategory1Account")
                      @XMLTag(V_CAPA1S, "PurCostAbsCategory1Subaccount")
                      @XMLTag("$(V_CAPA1A)-$(V_CAPA1S)", "PurCostAbsCategory1AccountSub")
                      @XMLTag(V_CAPA2A, "PurCostAbsCategory2Account")
                      @XMLTag(V_CAPA2S, "PurCostAbsCategory2Subaccount")
                      @XMLTag("$(V_CAPA2A)-$(V_CAPA2S)", "PurCostAbsCategory2AccountSub")
					  @XMLTag(V_CAPA3A, "PurCostAbsCategory3Account")
                      @XMLTag(V_CAPA3S, "PurCostAbsCategory3Subaccount")
                      @XMLTag("$(V_CAPA3A)-$(V_CAPA3S)", "PurCostAbsCategory3AccountSub")
					  @XMLTag(V_CAPA4A, "PurCostAbsCategory4Account")
                      @XMLTag(V_CAPA4S, "PurCostAbsCategory4Subaccount")
                      @XMLTag("$(V_CAPA4A)-$(V_CAPA4S)", "PurCostAbsCategory4AccountSub")
					  @XMLTag(V_CAPA5A, "PurCostAbsCategory5Account")
                      @XMLTag(V_CAPA5S, "PurCostAbsCategory5Subaccount")
                      @XMLTag("$(V_CAPA5A)-$(V_CAPA5S)", "PurCostAbsCategory5AccountSub")
                  %endif 					  
              @XMLEndTag("PlantNumber")
