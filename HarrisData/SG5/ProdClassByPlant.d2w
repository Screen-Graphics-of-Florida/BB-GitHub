                      %endif
					  %if (V_CAPA3A !="0")
					      @Format_Acct(V_CAPA3A, V_CAPA3S, "", F_PurAbsCat3Acct)
                          @RtvFldDesc("CHACCT=$(V_CAPA3A) and CHSUB=$(V_CAPA3S) ", "HDCHRT", "CHCHDS", H_PurAbsCat3Acct)
                      %endif
					  %if (V_CAPA4A !="0")
