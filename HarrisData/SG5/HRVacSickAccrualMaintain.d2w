%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Vacation/Sick Accrual Rates Maintenance"
  d2wName                 = "HRVacSickAccrualMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;vacSickCode=@dtw_rurlescseq(vacSickCode)&amp;monthsService=@dtw_rurlescseq(monthsService)&amp;maintenanceCode=D"
  programName             = "HPRVSM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  function validate(chgForm) {
                      if (document.Chg.vacSickCode=="" )
                         {alert("$(reqFieldError)"); return false;}
                      if (editNum(document.Chg.monthsService,            3, 0) &&
                          editNum(document.Chg.vacPPAccrualHours,        3, 2) &&
                          editNum(document.Chg.sicPPAccrualHours,        3, 2) &&
                          editNum(document.Chg.vacHourlyAccrualFactor,   0, 4) &&
                          editNum(document.Chg.sicHourlyAccrualFactor,   0, 4) &&
                          editNum(document.Chg.vacAnnualMaxHours,        3, 2) &&
                          editNum(document.Chg.sicAnnualMaxHours,        3, 2) &&
                          editNum(document.Chg.vacMaxRolloverHours,      3, 2) &&
                          editNum(document.Chg.sicMaxRolloverHours,      3, 2))
                          return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
	           %INCLUDE "numedit.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "VACSICACCRUALMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "SELECT * FROM PRACVS WHERE VSVSAC='$(vacSickCode)'", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "vacSickCode")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@vsac", "vacSickCode")              @dtw_assign(Err_VSVSAC, fieldValue)
                          @DecatErr_Field("@@svmo", "monthsService")            @dtw_assign(Err_VSSVMO, fieldValue)
                          @DecatErr_Field("@@vhrs", "vacPPAccrualHours")        @dtw_assign(Err_VSVHRS, fieldValue)
                          @DecatErr_Field("@@shrs", "sicPPAccrualHours")        @dtw_assign(Err_VSSHRS, fieldValue)
                          @DecatErr_Field("@@vfac", "vacHourlyAccrualFactor")   @dtw_assign(Err_VSVFAC, fieldValue)
                          @DecatErr_Field("@@sfac", "sicHourlyAccrualFactor")   @dtw_assign(Err_VSSFAC, fieldValue)
                          @DecatErr_Field("@@vmxa", "vacAnnualMaxHours")        @dtw_assign(Err_VSVMXA, fieldValue)
                          @DecatErr_Field("@@smxa", "sicAnnualMaxHours")        @dtw_assign(Err_VSSMXA, fieldValue)
                          @DecatErr_Field("@@vmxr", "vacMaxRolloverHours")      @dtw_assign(Err_VSVMXR, fieldValue)
                          @DecatErr_Field("@@smxr", "sicMaxRolloverHours")      @dtw_assign(Err_VSSMXR, fieldValue)
                          @DecatErr_Field("@@vyr@", "vacCalendarOrFiscal")      @dtw_assign(Err_VSVYR,  fieldValue)
                          @DecatErr_Field("@@syr@", "sicCalendarOrFiscal")      @dtw_assign(Err_VSSYR,  fieldValue)
                          @DecatErr_Field("@@vbal", "vacBalanceOption")         @dtw_assign(Err_VSVBAL, fieldValue)
                          @DecatErr_Field("@@sbal", "sicBalanceOption")         @dtw_assign(Err_VSSBAL, fieldValue)


                      %endif

                      @Decat_Field("@@vsac")   @dtw_assign(V_VSVSAC, fieldValue)
                      @Decat_Field("@@svmo")   @dtw_assign(V_VSSVMO, fieldValue)
                      @Decat_Field("@@vhrs")   @dtw_assign(V_VSVHRS, fieldValue)
                      @Decat_Field("@@shrs")   @dtw_assign(V_VSSHRS, fieldValue)
                      @Decat_Field("@@vfac")   @dtw_assign(V_VSVFAC, fieldValue)
                      @Decat_Field("@@sfac")   @dtw_assign(V_VSSFAC, fieldValue)
                      @Decat_Field("@@vmxa")   @dtw_assign(V_VSVMXA, fieldValue)
                      @Decat_Field("@@smxa")   @dtw_assign(V_VSSMXA, fieldValue)
                      @Decat_Field("@@vmxr")   @dtw_assign(V_VSVMXR, fieldValue)
                      @Decat_Field("@@smxr")   @dtw_assign(V_VSSMXR, fieldValue)
                      @Decat_Field("@@vyr@")   @dtw_assign(V_VSVYR,  fieldValue)
                      @Decat_Field("@@syr@")   @dtw_assign(V_VSSYR,  fieldValue)
                      @Decat_Field("@@vbal")   @dtw_assign(V_VSVBAL, fieldValue)
                      @Decat_Field("@@sbal")   @dtw_assign(V_VSSBAL, fieldValue)





                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "vacSickCode")
                      %endif

                      @dtw_assign(errFound, "")

                  %else
                      @dtw_assign(focusField, "vacPPAccrualHours")
                  %endif


                  @SetTextOvr(Err_VSVSAC)
                  <tr><td class="dsphdr"><span $(textOvr)>Vacation/Sick Accrual Code</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="vacSickCode" type="text" value="$(V_VSVSAC)" size="2" maxlength="2"> $(reqFieldChar) </td>
                      %else
                          <td class="inputalph"><input name="vacSickCode" type="hidden" value="$(V_VSVSAC)" size="2" maxlength="2">$(V_VSVSAC)</td>
                      %endif
                      @DspErrMsg(Err_VSVSAC)
                  </tr>

                  @Default_Zero(V_VSSVMO)
                  @SetTextOvr(Err_VSSVMO)
                  <tr><td class="dsphdr"><span $(textOvr)>Months Of Service</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input type="text" name="monthsService" value="$(V_VSSVMO)" size="3" maxlength="3"></td>
                      %else
                          <td class="inputnmbr"><input type="hidden" name="monthsService" value="$(V_VSSVMO)" size="3" maxlength="3">$(V_VSSVMO)</td>
                      %endif
                      @DspErrMsg(Err_VSSVMO)
                  </tr>


                  <table $(contentTable)>
                     <tr><td>&nbsp;</td>
                         <td class="colhdr">Vacation</td>
                         <td class="colhdr">Sick</td>
                     </tr>

                  @Default_Zero(V_VSVHRS)
                  @Default_Zero(V_VSSHRS)
                  @SetTextOvr(Err_VSVHRS)
                  @SetTextOvr(Err_VSSHRS)
                  <tr><td class="dsphdr"><span $(textOvr)>Pay Period Accrual Hours</span></td>
                      <td class="inputnmbr"><input type="text" name="vacPPAccrualHours" value="$(V_VSVHRS)" size="7" maxlength="7"></td>
                      <td class="inputnmbr"><input type="text" name="sicPPAccrualHours" value="$(V_VSSHRS)" size="7" maxlength="7"></td>
                      @DspErrMsg(Err_VSVHRS)
                      @DspErrMsg(Err_VSSHRS)
                  </tr>

                  <tr><td class="dsphdr"><span $(textOvr)>OR</span></td>
                  </tr>

                  @SetTextOvr(Err_VSVFAC)
                  @SetTextOvr(Err_VSSFAC)
                  <tr><td class="dsphdr"><span $(textOvr)>Hourly Accrual Factor</span></td>
                      <td class="inputnmbr"><input type="text" name="vacHourlyAccrualFactor" value="$(V_VSVFAC)" size="5" maxlength="5"></td>
                      <td class="inputnmbr"><input type="text" name="sicHourlyAccrualFactor" value="$(V_VSSFAC)" size="5" maxlength="5"></td>
                      @DspErrMsg(Err_VSVFAC)
                      @DspErrMsg(Err_VSSFAC)
                  </tr>

                  @Default_Zero(V_VSVMXA)
                  @Default_Zero(V_VSSMXA)
                  @SetTextOvr(Err_VSVMXA)
                  @SetTextOvr(Err_VSSMXA)
                  <tr><td class="dsphdr"><span $(textOvr)>Annual Maximum Hours</span></td>
                      <td class="inputnmbr"><input type="text" name="vacAnnualMaxHours" value="$(V_VSVMXA)" size="5" maxlength="5"></td>
                      <td class="inputnmbr"><input type="text" name="sicAnnualMaxHours" value="$(V_VSSMXA)" size="5" maxlength="5"></td>
                      @DspErrMsg(Err_VSVMXA)
                      @DspErrMsg(Err_VSSMXA)
                  </tr>


                  @Default_Zero(V_VSVMXR)
                  @Default_Zero(V_VSSMXR)
                  @SetTextOvr(Err_VSVMXR)
                  @SetTextOvr(Err_VSSMXR)
                  <tr><td class="dsphdr"><span $(textOvr)>Maximum Rollover Hours</span></td>
                      <td class="inputnmbr"><input type="text" name="vacMaxRolloverHours" value="$(V_VSVMXR)" size="7" maxlength="7"></td>
                      <td class="inputnmbr"><input type="text" name="sicMaxRolloverHours" value="$(V_VSSMXR)" size="7" maxlength="7"></td>
                      @DspErrMsg(Err_VSVMXR)
                      @DspErrMsg(Err_VSSMXR)
                  </tr>

                  @RtvFldDesc("FLTYPE='YEARTYPE' and FLVALU='$(V_VSVYR)'", "SYFLAG", "FLDESC", fieldVacYearTypeDesc)
                  @RtvFldDesc("FLTYPE='YEARTYPE' and FLVALU='$(V_VSSYR)'", "SYFLAG", "FLDESC", fieldSicYearTypeDesc)
                  @SetTextOvr(Err_VSVYR)
                  @SetTextOvr(Err_VSSYR)
                  <tr><td class="dsphdr"><span $(textOvr)>Calendar Or Fiscal Year</span></td>
                      <td class="inputalph"><input type="text" name="vacCalendarOrFiscal" value="$(V_VSVYR)" size="1" maxlength="1"><a href="$(homeURL)$(cGIPath)FlagSearch.d2w/REPORT$(genericVarBase)&amp;flagType=YEARTYPE&amp;flagSrchHdr=Calendar Or Fiscal&amp;docName=Chg&amp;fldName=vacCalendarOrFisacal&amp;fldDesc=yearTypeDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                          <input name="yearTypeDesc" value="$(fieldVacYearTypeDesc)" type="text" size="20" disabled></td>

                      <td class="inputalph"><input type="text" name="sicCalendarOrFiscal" value="$(V_VSSYR)" size="1" maxlength="1"><a href="$(homeURL)$(cGIPath)FlagSearch.d2w/REPORT$(genericVarBase)&amp;flagType=YEARTYPE&amp;flagSrchHdr=Calendar Or Fiscal&amp;docName=Chg&amp;fldName=sicCalendarOrFisccal&amp;fldDesc=yearTypeDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                          <input name="yearTypeDesc" value="$(fieldSicYearTypeDesc)" type="text" size="20" disabled></td>

                      @DspErrMsg(Err_VSVYR)
                      @DspErrMsg(Err_VSSYR)
                  </tr>

                  @RtvFldDesc("FLTYPE='BALMETHOD' and FLVALU='$(V_VSVBAL)'", "SYFLAG", "FLDESC", fieldVacBalOptDesc)
                  @RtvFldDesc("FLTYPE='BALMETHOD' and FLVALU='$(V_VSSBAL)'", "SYFLAG", "FLDESC", fieldSicBalOptDesc)
                  @SetTextOvr(Err_VSVBAL)
                  @SetTextOvr(Err_VSSBAL)
                  <tr><td class="dsphdr"><span $(textOvr)>Balance Option</span></td>
                      <td class="inputalph"><input type="text" name="vacBalanceOption" value="$(V_VSVBAL)" size="1" maxlength="1"><a href="$(homeURL)$(cGIPath)FlagSearch.d2w/REPORT$(genericVarBase)&amp;flagType=BALMETHOD&amp;flagSrchHdr=Balance Option&amp;docName=Chg&amp;fldName=vacBalanceOption&amp;fldDesc=vacBalanceOptionDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                          <input name="vacBalanceOptionDesc" value="$(fieldVacBalOptDesc)" type="text" size="27" disabled></td>

                      <td class="inputalph"><input type="text" name="sicBalanceOption" value="$(V_VSSBAL)" size="1" maxlength="1"><a href="$(homeURL)$(cGIPath)FlagSearch.d2w/REPORT$(genericVarBase)&amp;flagType=BALMETHOD&amp;flagSrchHdr=Balance Option&amp;docName=Chg&amp;fldName=sicBalanceOption&amp;fldDesc=sicBalanceOptionDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                          <input name="sicBalanceOptionDesc" value="$(fieldVacBalOptDesc)" type="text" size="27" disabled></td>

                      @DspErrMsg(Err_VSVBAL)
                      @DspErrMsg(Err_VSSBAL)
                  </tr>


              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)


{%EXEC {HPRVSM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if ((sec_02 == "N" && sec_03 == "N" && maintenanceCode != "A") || (sec_01 == "N" && maintenanceCode == "A") || (sec_04 == "N" && maintenanceCode == "Z"))
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)ProgOptSecError.d2w/DISPLAY$(genericVarBase)&amp;page_title=@dtw_rurlescseq(page_title)">
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(vacSickCode)
  @dtw_mUPPERCASE(vacCalendarOrFiscal)
  @dtw_mUPPERCASE(sicCalendarOrFiscal)

  @dtw_assign(vacSickCode,@dtw_rstrip(vacSickCode))
  @dtw_assign(monthsService,@dtw_rstrip(monthsService))
  @dtw_assign(vacPPAccrualHours,@dtw_rstrip(vacPPAccrualHours))
  @dtw_assign(sicPPAccrualHours,@dtw_rstrip(sicPPAccrualHours))
  @dtw_assign(vacHourlyAccrualFactor,@dtw_rstrip(vacHourlyAccrualFactor))
  @dtw_assign(sicHourlyAccrualFactor,@dtw_rstrip(sicHourlyAccrualFactor))
  @dtw_assign(vacAnnualMaximumHours,@dtw_rstrip(vacAnnualMaximumHours))
  @dtw_assign(sicAnnualMaximumHours,@dtw_rstrip(sicAnnualMaximumHours))
  @dtw_assign(vacMaxRolloverHours,@dtw_rstrip(vacMaxRolloverHours))
  @dtw_assign(sicMaxRolloverHours,@dtw_rstrip(sicMaxRolloverHours))
  @dtw_assign(vacCalendarOrFiscal,@dtw_rstrip(vacCalendarOrFiscal))
  @dtw_assign(sicCalendarOrFiscal,@dtw_rstrip(sicCalendarOrFiscal))
  @dtw_assign(vacBalanceOption,@dtw_rstrip(vacBalanceOption))
  @dtw_assign(sicBalanceOption,@dtw_rstrip(sicBalanceOption))


  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif


  @dtw_assign(edtVar, "")
  @Concat_Field("@@vsac", vacSickCode)
  @Concat_Field("@@svmo", monthsService)
  @Concat_Field("@@vhrs", vacPPAccrualHours)
  @Concat_Field("@@shrs", sicPPAccrualHours)
  @Concat_Field("@@vfac", vacHourlyAccrualFactor)
  @Concat_Field("@@sfac", sicHourlyAccrualFactor)
  @Concat_Field("@@vmxa", vacAnnualMaxHours)
  @Concat_Field("@@smxa", sicAnnualMaxHours)
  @Concat_Field("@@vmxr", vacMaxRolloverHours)
  @Concat_Field("@@smxr", sicMaxRolloverHours)
  @Concat_Field("@@vyr@", vacCalendarOrFiscal)
  @Concat_Field("@@syr@", sicCalendarOrFiscal)
  @Concat_Field("@@vbal", vacBalanceOption)
  @Concat_Field("@@sbal", sicBalanceOption)

  @dtw_concat(edtVar, "}{", edtVar)


  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(vacSickCode), "", "", "", "", "", confMessage)
      %if (maintenanceCode == "D" || fromD2w != "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)HRVacSickAccrual.d2w/REPORT$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)HRVacSickAccrual.d2w/REPORT$(genericVarBase)&amp;vacSickCode=@dtw_rurlescseq(vacSickCode)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %elseif (maintenanceCode == "D")
      @DecatErr_Field("@@vsac", "vacSickCode")
      @Format_ConfMsg_Desc($(vacSickCode), $(monthsService), "", "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)HRVacSickAccrual.d2w/REPORT$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;vacSickCode=@dtw_rurlescseq(vacSickCode)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}