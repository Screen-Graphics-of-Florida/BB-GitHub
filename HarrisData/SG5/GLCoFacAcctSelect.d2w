%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "General Ledger Account Summary"
  d2wName                 = "GLCoFacAcctSelect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;GLCompany=@dtw_rurlescseq(GLCompany)&amp;GLFacility=@dtw_rurlescseq(GLFacility)&amp;GLAcct=@dtw_rurlescseq(GLAcct)&amp;GLSub=@dtw_rurlescseq(GLSub)&amp;GLYear=@dtw_rurlescseq(GLYear)&amp;GLPlan=@dtw_rurlescseq(GLPlan)&amp;passedCompany=@dtw_rurlescseq(passedCompany)&amp;passedFacility=@dtw_rurlescseq(passedFacility)&amp;passedAcct=@dtw_rurlescseq(passedAcct)&amp;passedSub=@dtw_rurlescseq(passedSub)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
  tabID                   = "REVIEW"
  GLPlan                  = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  %if (GLPlan<="0")
      @RtvFldDesc("(CFCO#,CFFAC#)=($(GLCompany),$(GLFacility))", "HDCFAC", "Char(CFDBGT)", GLPlan)
  %endif

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "GLCOFACACCTSELECT")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select GLTROB.* ", stmtSQL)
                          @dtw_concat(stmtSQL, "       ,coalesce(TSPER#,0) as TSPER#, coalesce(TSEOYF,' ') as TSEOYF, coalesce(TSEAMT,0) as TSEAMT ", stmtSQL)
                          %if (GLPlan > "0")
                              @dtw_concat(stmtSQL, " ,coalesce(BDBDG,0) as BDBDG ", stmtSQL)
                          %else
                              @dtw_concat(stmtSQL, " ,0 as BDBDG ", stmtSQL)
                          %endif
                          @dtw_concat(fileSQL, " GLTROB ", fileSQL)
                          @dtw_concat(fileSQL, " left join GLTRSM on (TSCO,TSFAC,TSACCT,TSSUB,TSYEAR)=(OBCO,OBFAC,OBACCT,OBSUB,OBYEAR) ", fileSQL)
                          %if (GLPlan > "0")
                              @dtw_concat(fileSQL, " left join GLBGDT on (BDCO,BDFAC,BDACCT,BDSUB,BDYEAR,BDPER#,BDNMBR,' ')=(OBCO,OBFAC,OBACCT,OBSUB,OBYEAR,TSPER#,$(GLPlan),TSEOYF) ", fileSQL)
                          %endif
                          @dtw_concat(selectSQL, " (OBCO,OBFAC,OBACCT,OBSUB,OBYEAR)=($(GLCompany),$(GLFacility),$(GLAcct),$(GLSub),$(GLYear)) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By OBCO,OBFAC,OBACCT,OBSUB,OBYEAR,TSPER#,TSEOYF ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @Select_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Select_Query (IN CHAR(64)    profileHandle,
                                    CHAR(2)     dataBaseID,
                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("RRN(GLCTRL)=1 ", "GLCTRL", "CTCALV", V_CTCALV)
      @dtw_assign(firstRecord, "Y")
      @dtw_assign(subTSEAMT, "0")
      @dtw_assign(subBDBDG, "0")
      @dtw_assign(subTSVAR, "0")

      %ROW {
          %if (firstRecord == "Y")
              @dtw_assign(firstRecord, "N")
              %INCLUDE "GLCoFacAcctSelectTabs.icl"

              <table $(contentTable)>
                  <tr><th class="colhdr">G/L Account</th>
                      <th class="colhdr">Name</th>
                      <th class="colhdr">Usage</th>
                      %if (V_HDCMRL>"0")
                          @RtvFldDesc("RRN(GLCTRL)=1", "GLCTRL", "CTPRMC", V_CTPRMC)
                          %if (V_CTPRMC=="Y")
                              <th class="colhdr">Currency Type</th>
                          %endif
                      %endif
                  </tr>

                  @Format_CoFac("$(V_OBCO)", "$(V_OBFAC)", "", F_CoFac)
                  @Format_Acct("$(V_OBACCT)", "$(V_OBSUB)", "", F_AcctSub)
                  @dtw_assign(F_OBYEAR, V_OBYEAR)  @YearFromCYY(F_OBYEAR)

                  @RtvFldDesc("(CHACCT,CHSUB)=($(V_OBACCT),$(V_OBSUB))", "HDCHRT", "CHACSG", V_CHACSG)

                  <tr class="oddrow">
                      <td class="colnmbr">$(F_CoFac) $(F_AcctSub)</td>
                      <td class="colalph">$(V_OBGMNM)</td>
                      <td class="colalph">$(V_CHACSG)</td>
                      %if (V_HDCMRL>"0" && V_CTPRMC=="Y")
                          @RtvFldDesc("(CFCO#,CFFAC#)=($(V_OBCO),$(V_OBFAC))", "HDCFAC", "CFCURT", V_CFCURT)
                          @RtvFldDesc("CYTYPE='$(V_CFCURT)'", "HDCTYP", "CYDESC", V_CYDESC)
                          <td class="colalph" $(helpCursor)><span title="$(V_CFCURT)">$(V_CYDESC)</span></td>
                      %endif
                  </tr>
              </table>

              <table $(contentTable)>
                  <tr><th class="colhdr">Period</th>
                      <th class="colhdr">Actual</th>
                      <th class="colhdr">Budget</th>
                      <th class="colhdr">Variance</th>
                  </tr>

                  %INCLUDE "SetRowClass.icl"

                  @Format_Nbr(V_OBPBAL, F_OBPBAL, "2", $(amtEditCode), "Y", "", "")
                  @DTW_ADD(subTSEAMT, V_OBPBAL, "15", subTSEAMT)

                  <tr class="$(rowClass)">
                      <td class="colnmbr">Opening</td>
                      <td class="colnmbr">$(F_OBPBAL)</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                  </tr>
          %endif
                  %if (V_TSPER# > "0")
                      %INCLUDE "SetRowClass.icl"

                      @RtvFldDesc("(TDCO,TDFAC,TDACCT,TDSUB,TDPER#)=($(V_OBCO),$(V_OBFAC),$(V_OBACCT),$(V_OBSUB),$(V_TSPER#)) ", "GLTRDT inner join GLTRJL on (TJJRNL,TJPER#,TJTDTE,TJJSEQ,TJSTAT)=(TDJRNL,TDPER#,TDTDTE,TDJSEQ,'P') ", "CHAR(Count(*))", RecCount)
                      @dtw_assign(F_TSPER#, V_TSPER#)  @PeriodFromCYP(F_TSPER#)
                      %if (V_CTCALV=="1")
                          @DTW_SUBTRACT(V_TSEAMT, V_BDBDG, V_TSVAR)
                      %else
                          @DTW_SUBTRACT(V_BDBDG, V_TSEAMT, V_TSVAR)
                      %endif
                      @Format_Nbr(V_TSEAMT, F_TSEAMT, "2", $(amtEditCode), "Y", "", "")
                      @Format_Nbr(V_BDBDG, F_BDBDG, "2", $(amtEditCode), "Y", "", "")
                      @Format_Nbr(V_TSVAR, F_TSVAR, "2", $(amtEditCode), "Y", "", "")
                      @DTW_ADD(subTSEAMT, V_TSEAMT, "15", subTSEAMT)
                      @DTW_ADD(subBDBDG, V_BDBDG, "15", subBDBDG)
                      @DTW_ADD(subTSVAR, V_TSVAR, "15", subTSVAR)

                      <tr class="$(rowClass)">
                          <td class="colnmbr">$(F_TSPER#)</td>
                          %if (RecCount>"0")
                              <td class="colnmbr"><a href="$(homeURL)$(cGIPath)GLDDAcctJrnl.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;accountNumber=@dtw_rurlescseq(V_OBACCT)&amp;subAccount=@dtw_rurlescseq(V_OBSUB)&amp;coNumber=@dtw_rurlescseq(V_OBCO)&amp;facNumber=@dtw_rurlescseq(V_OBFAC)&amp;accountAmount=@dtw_rurlescseq(F_TSEAMT)&amp;fromPer=@dtw_rurlescseq(V_TSPER#)&amp;toPer=@dtw_rurlescseq(V_TSPER#)&amp;columnValue=@dtw_rurlescseq(columnValue)" title="View Account Journals" onclick="$(searchWinVar)">$(F_TSEAMT)</a></td>
                          %else
                              <td class="colnmbr">$(F_TSEAMT)</td>
                          %endif
                          <td class="colnmbr">$(F_BDBDG)</td>
                          <td class="colnmbr">$(F_TSVAR)</td>
                      </tr>
                  %endif
           %}

           @dtw_assign(colSpanValue, "10")

           @Format_Nbr(subTSEAMT, F_subTSEAMT, "2", $(amtEditCode), "Y", "", "")
           @Format_Nbr(subBDBDG, F_subBDBDG, "2", $(amtEditCode), "Y", "", "")
           @Format_Nbr(subTSVAR, F_subTSVAR, "2", $(amtEditCode), "Y", "", "")
           <tr>
               <td class="colnmbr">Total</td>
               <td class="coltotal">$(F_subTSEAMT)</td>
               <td class="coltotal">$(F_subBDBDG)</td>
               <td class="coltotal">$(F_subTSVAR)</td>
           </tr>
      </table>
      %INCLUDE "EndTabs.icl"
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}