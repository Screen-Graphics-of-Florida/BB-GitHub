%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Default Stock Location List"
  d2wName                 = "DefaultStockLocationList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)&amp;apid=@dtw_rurlescseq(apid)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %if (apid == "OE")
              @dtw_assign(sortSeqMax, "3")
              @dtw_assign(page_title, "O/E Default Stock Location List")
          %elif (apid == "PO")
              @dtw_assign(sortSeqMax, "2")
              @dtw_assign(page_title, "P/O Default Stock Location List")
          %else
              @dtw_assign(sortSeqMax, "2")
              @dtw_assign(page_title, "Shop Floor Default Stock Location List")
          %endif
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromWarehouse, 3, 0) &&
                      editNum(document.Chg.toWarehouse, 3, 0) &&
                      editFromToAll(document.Chg.fromWarehouse, document.Chg.toWarehouse, document.Chg.allWarehouse, 3) &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A")
                      %if (apid == "OE")
                          && editFromToAll(document.Chg.fromOrderType, document.Chg.toOrderType, document.Chg.allOrderType, "A")
                      %endif
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "DEFAULTSTOCKLOCATIONLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromWarehouse")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@swhs", "sortWarehouse")        @dtw_assign(Err_N1SWHS,  fieldValue)
                                  @DecatErr_Field("@@sitm", "sorttemNumber")        @dtw_assign(Err_N1SITM,  fieldValue)
                                  @DecatErr_Field("@@sotp", "sortOrderType")        @dtw_assign(Err_N1SOTP,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@fwhs")  @dtw_assign(V_N1FWHS,  fieldValue)
                                  @Decat_Field("@@twhs")  @dtw_assign(V_N1TWHS,  fieldValue)
                                  @Decat_Field("@@awhs")  @dtw_assign(V_N1AWHS,  fieldValue)
                                  @Decat_Field("@@swhs")  @dtw_assign(V_N1SWHS,  fieldValue)
                                  @Decat_Field("@@fitm")  @dtw_assign(V_N1FITM,  fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N1TITM,  fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N1AITM,  fieldValue)
                                  @Decat_Field("@@sitm")  @dtw_assign(V_N1SITM,  fieldValue)
                                  @Decat_Field("@@fotp")  @dtw_assign(V_N1FOTP,  fieldValue)
                                  @Decat_Field("@@totp")  @dtw_assign(V_N1TOTP,  fieldValue)
                                  @Decat_Field("@@aotp")  @dtw_assign(V_N1AOTP,  fieldValue)
                                  @Decat_Field("@@sotp")  @dtw_assign(V_N1SOTP,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}

                                  %if (V_N1AWHS == "ALL")
                                      @dtw_assign(checkedallWarehouse, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallWarehouse, "")
                                  %endif
                                  %if (V_N1AITM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_N1AOTP == "ALL")
                                      @dtw_assign(checkedallOrderType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallOrderType, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedallWarehouse, "CHECKED")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallOrderType, "CHECKED")
                              %endif
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                              </tr>

                              @SetTextOvr(Err_N1SWHS)
                              %if (textOvr == "") @SetTextOvr(Err_N1SWHS) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Warehouse </td>
                                  <td class="inputnmbr"><input name="fromWarehouse" value="$(V_N1FWHS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromWarehouse&amp;fldDesc=fwarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fwarehouseName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toWarehouse" value="$(V_N1TWHS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toWarehouse&amp;fldDesc=twarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="twarehouseName" type="hidden"></td>
                                  <td class="inputalph"><input name="allWarehouse" value='ALL' $(checkedallWarehouse) type="checkbox" onClick="if (this.checked) this.form.fromWarehouse.value='', this.form.toWarehouse.value='';"></td>
                                  @Build_Sort_Select("sortWarehouse", "$(V_N1SWHS)")
                              </tr>
                              @DspErrMsg(Err_N1SWHS)

                              @SetTextOvr(Err_N1FITM)
                              %if (textOvr == "") @SetTextOvr(Err_N1SITM) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N1FITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N1TITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                                  @Build_Sort_Select("sortItemNumber", "$(V_N1SITM)")
                              </tr>
                              @DspErrMsg(Err_N1SITM)

                              %if (apid == "OE")
                                  @SetTextOvr(Err_N1FOTP)
                                  %if (textOvr == "") @SetTextOvr(Err_N1SOTP) %endif
                                  <tr><td  class="dsphdr"><span $(textOvr)>Order Type</span></td>
                                      <td class="inputalph"><input name="fromOrderType" value="$(V_N1FOTP)" type="text" size="1" maxlength="1"><a href="$(homeURL)$(cGIPath)ordertypesearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromOrderType&amp;fldDesc=fromOrderTypeDescH&amp;appID=OE" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fromOrderTypeDescH" type="hidden"></td>
                                      <td class="inputalph"><input name="toOrderType" value="$(V_N1TOTP)" type="text" size="1" maxlength="1"><a href="$(homeURL)$(cGIPath)ordertypesearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toOrderType&amp;fldDesc=toOrderTypeDescH&amp;appID=OE" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toOrderTypeDescH" type="hidden"></td>
                                      <td class="inputalph"><input name="allOrderType" value='ALL' $(checkedallOrderType) type="checkbox" onClick="if (this.checked) this.form.fromOrderType.value='', this.form.toOrderType.value='';"></td>
                                      @Build_Sort_Select("sortOrderType", "$(V_N1SOTP)")
                                  </tr>
                                  @DspErrMsg(Err_N1SOTP)
                              %endif
                          </table>

                          @dtw_assign(envProgram, "HHDDLL")
                          @dtw_assign(envPrinter, "HHDDLLPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%MACRO_FUNCTION Select_Apid () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "DEFAULTSTOCKLOCATIONLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      <table $(contentTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1>$(page_title)</h1></td>
                              <td class="toolbar">
                                  %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                                      <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                                  %endif
                                  %INCLUDE "HelpPage.icl"
                              </td>
                          </tr>
                      </table>
                      $(hrTagAttr)

                      <form class="formClass" METHOD=POST name=Select ACTION="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)">
                          <table $(contentTable)>
                              <tr><td class="dsphdr">Application ID</td>
                                  %if (V_HDOERL > "0")
                                      @RtvFldDesc("AIAPID='OE'", "SYAPID", "AIAPDS", oeDesc)
                                      <td class="inputcode"><input onClick="javascript:document.Select.submit()" name="apid" type="radio" VALUE='OE'> $(oeDesc) </td>
                                  %endif
                                  %if (V_HDPORL > "0")
                                      @RtvFldDesc("AIAPID='PO'", "SYAPID", "AIAPDS", poDesc)
                                      <td class="inputcode"><input onClick="javascript:document.Select.submit()" name="apid" type="radio" VALUE='PO'> $(poDesc) </td>
                                  %endif
                                  %if (V_HDPDRL > "0")
                                      @RtvFldDesc("AIAPID='SI'", "SYAPID", "AIAPDS", siDesc)
                                      <td class="inputcode"><input onClick="javascript:document.Select.submit()" name="apid" type="radio" VALUE='SI'> $(siDesc) </td>
                                  %endif
                              </tr>
                          </table>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HHDDLS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  %if (errFound == "Y")
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @Decat_Field("@@apid")
      %if (apid != fieldValue)
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)&amp;apid=@dtw_rurlescseq(fieldValue)&amp;errFound=Y&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
      %endif
  %endif
  @Set_SQL()
%}

%HTML(SELECT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(apidCount, "0")
  %if (V_HDOERL > "0")
      @dtw_add(apidCount,"1",apidCount)
  %endif
  %if (V_HDPORL > "0")
      @dtw_add(apidCount,"1",apidCount)
  %endif
  %if (V_HDPDRL > "0")
      @dtw_add(apidCount,"1",apidCount)
  %endif
  %if (apidCount == "0")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)">
  %elif (apidCount == "1")
      %if (V_HDOERL > "0")
          @dtw_assign(apid, "OE")
      %elif (V_HDPORL > "0")
          @dtw_assign(apid, "PO")
      %else
          @dtw_assign(apid, "SI")
      %endif
      @Set_SQL()
  %else
      @Select_Apid()
  %endif

%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allWarehouse)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(fromOrderType)
  @dtw_mUPPERCASE(toOrderType)
  @dtw_mUPPERCASE(allOrderType)

  @dtw_assign(fromWarehouse,@dtw_rstrip(fromWarehouse))
  @dtw_assign(toWarehouse,@dtw_rstrip(toWarehouse))
  @dtw_assign(sortWarehouse,@dtw_rstrip(sortWarehouse))
  @dtw_assign(sortItemNumber,@dtw_rstrip(sortItemNumber))
  @dtw_assign(sortOrderType,@dtw_rstrip(sortOrderType))


  %if (allWarehouse != "ALL")
      @dtw_assign(allWarehouse, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allOrderType != "ALL")
      @dtw_assign(allOrderType, "")
  %endif


  @dtw_assign(edtVar, "")
  @Concat_Field("@@apid", apid)
  @Concat_Field("@@fwhs", fromWarehouse)
  @Concat_Field("@@twhs", toWarehouse)
  @Concat_Field("@@awhs", allWarehouse)
  @Concat_Field("@@swhs", sortWarehouse)
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@sitm", sortItemNumber)
  %if (apid == "OE")
      @Concat_Field("@@fotp", fromOrderType)
      @Concat_Field("@@totp", toOrderType)
      @Concat_Field("@@aotp", allOrderType)
      @Concat_Field("@@sotp", sortOrderType)
  %endif

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}