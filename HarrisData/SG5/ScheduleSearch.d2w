%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Schedule Search"
  d2wName                 = "ScheduleSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function selectSchedule(scheduleNumber, scheduleDescription){
                      window.opener.document.$(docName).$(fldName).value = scheduleNumber;
                      window.opener.document.$(docName).$(fldDesc).value = scheduleDescription;
                      window.opener.document.$(docName).$(fldName).focus();
                      window.close();
                  }
                  %INCLUDE "CheckEnterSearch.icl"
                  %INCLUDE "NoFormValidate.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "$(searchBanner)"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      <td class="content">
                          @dtw_assign(uv_ScheduleName, "SMSCHD")
                          %INCLUDE "userview.icl"

                          %INCLUDE "stmtSQLClear.icl"
                          %if (moreInfo == "Y")
                              @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          %else
                              @dtw_concat(stmtSQL, " Select SMSCHD,SMDESC,SMEFFS,SMEFFE, ", stmtSQL)
                              @dtw_concat(stmtSQL, " upper(SMDESC) as SMDESCU ", stmtSQL)
                          %endif
                          @dtw_concat(fileSQL, " HDSCHM ", fileSQL)
                          %if (moreInfo == "Y")
                              @dtw_concat(selectSQL, " SMSCHD=$(scheduleNumber) and SMEFFS=$(startDate)", selectSQL)
                          %elseif (wildCardSearch!="" || uv_Sql!="")
                              @dtw_concat(selectSQL, " SMSCHD>0 ", selectSQL)
                          %endif
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Process_Search(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "$(searchTrailer)"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Process_Search (IN  CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"

      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Description</th></tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="20" maxlength="20">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("SMSCHD", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Schedule" title="Sequence By Schedule">Schedule</a></th>
                  @OrderBy_Sort("SMDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Description, Schedule">Description</a></th>
                  @OrderBy_Sort("SMEFFS", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=StartDate" title="Sequence By Start Date, Schedule">Start<br>Date</a></th>
                  @OrderBy_Sort("SMEFFE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=EndDate" title="Sequence By End Date, Schedule">End<br>Date</a></th>
              </tr>
               %INCLUDE "NoRecordsFound.icl"
      %endif		

              %ROW{
                  @Format_Date(V_SMEFFS, "D", F_SMEFFS)
                  @Format_Date(V_SMEFFE, "D", F_SMEFFE)
                  @Format_Quote(V_SMDESC, F_SMDESC)

                  %if (moreInfo != "Y")	
                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          <td class="colalph">$(V_SMSCHD)</td>
                          <td class="colalph"><a href="javascript:selectSchedule($(V_SMSCHD),'$(F_SMDESC)')" title="Select Schedule">$(V_SMDESC)</a></td>
                          <td class="coldate">$(F_SMEFFS)</td>
                          <td class="coldate">$(F_SMEFFE)</td>
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;scheduleNumber=@dtw_rurlescseq(V_SMSCHD)&amp;startDate=@dtw_rurlescseq(V_SMEFFS)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                      </tr>

                  %else

                      <table $(contentTable)>
                          <tr><td><a href="javascript:selectSchedule($(V_SMSCHD),'$(F_SMDESC)')" title="Select Schedule">$(selectImageLrg)</a>
                             </td>
                          </tr>

                      </table>

                      <table $(contentTable)>
                          <tr><td class="dsphdr">Schedule</td>
                              <td class="dspnmbr">$(V_SMSCHD)</td>
                          </tr>

                          <tr><td class="dsphdr">Effectivity Start Date</td>
                              <td class="dspdate">$(F_SMEFFS)</td></tr>

                          <tr><td class="dsphdr">Effectivity End Date</td>
                              <td class="dspdate">$(F_SMEFFE)</td></tr>

                          <tr><td class="dsphdr">Description</td>
                              <td class="dspalph">$(V_SMDESC)</td></tr>

                          <tr><td class="dsphdr">Shift</td>
                              <td class="dspnmbr">$(V_SMSHFT)</td></tr>
                      </table>

                      <table $(contentTable)>
                          <tr><td class="dsphdr"></td>
                              <td class="colhdr">Shift<br>Start<br>Early</td>
                              <td class="colhdr">Shift<br>Start<br>Late</td>
                              <td class="colhdr">Shift<br>End<br>Early</td>
                              <td class="colhdr">Shift<br>End<br>Late</td>
                          </tr>

                          <tr><td class="dsphdr">Grace Period (Minutes)</td>
                              <td class="colnmbr">$(V_SMGPBS)</td>
                              <td class="colnmbr">$(V_SMGPAS)</td>
                              <td class="colnmbr">$(V_SMGPBE)</td>
                              <td class="colnmbr">$(V_SMGPAE)</td>
                          </tr>	

                          <tr><td class="dsphdr">Round To Schedule</td>
                              <td class="colcode">$(V_SMRTBS)</td>
                              <td class="colcode">$(V_SMRTAS)</td>
                              <td class="colcode">$(V_SMRTBE)</td>
                              <td class="colcode">$(V_SMRTAE)</td>
                          </tr>	

                          <tr><td class="dsphdr">Beyond Grace Period Exception</td>
                              <td class="colcode">$(V_SMPEBS)</td>
                              <td class="colcode">$(V_SMPEAS)</td>
                              <td class="colcode">$(V_SMPEBE)</td>
                              <td class="colcode">$(V_SMPEAE)</td>
                          </tr>	

                          <tr><td class="dsphdr">Round To Value</td>
                              <td class="colnmbr">$(V_SMRVBS)</td>
                              <td class="colnmbr">$(V_SMRVAS)</td>
                              <td class="colnmbr">$(V_SMRVBE)</td>
                              <td class="colnmbr">$(V_SMRVAE)</td>
                          </tr>	

                          <tr><td class="dsphdr">Rounding Split (Minutes)</td>
                              <td class="colnmbr">$(V_SMRSBS)</td>
                              <td class="colnmbr">$(V_SMRSAS)</td>
                              <td class="colnmbr">$(V_SMRSBE)</td>
                              <td class="colnmbr">$(V_SMRSAE)</td>
                          </tr>	
                      </table>
                  %endif
              %}
      %if (moreInfo != "Y")	
          </table>
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
      %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "SMDESCU,SMSCHD")
      @DTW_ASSIGN(orderByDisplay, "Description, Schedule")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(orderBy, "SMSCHD")
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Schedule")
      %if (orderBy == "SMSCHD")
          @DTW_ASSIGN(orderBy, "SMSCHD DESC")
          @DTW_ASSIGN(orderByDisplay, "Schedule (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SMSCHD")
          @DTW_ASSIGN(orderByDisplay, "Schedule")
      %endif
  %elseif (sequence == "Description")
      %if (orderBy == "SMDESCU,SMSCHD")
          @DTW_ASSIGN(orderBy, "SMDESCU DESC,SMSCHD")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Schedule")
      %else
          @DTW_ASSIGN(orderBy, "SMDESCU,SMSCHD")
          @DTW_ASSIGN(orderByDisplay, "Description, Schedule")
      %endif
  %elseif (sequence == "StartDate")
      %if (orderBy == "SMEFFS,SMSCHD")
          @DTW_ASSIGN(orderBy, "SMEFFS DESC,SMSCHD")
          @DTW_ASSIGN(orderByDisplay, "Start Date (descending), Schedule")
      %else
          @DTW_ASSIGN(orderBy, "SMEFFS,SMSCHD")
          @DTW_ASSIGN(orderByDisplay, "Start Date, Schedule")
      %endif
  %elseif (sequence == "EndDate")
      %if (orderBy == "SMEFFE,SMSCHD")
          @DTW_ASSIGN(orderBy, "SMEFFE DESC,SMSCHD")
          @DTW_ASSIGN(orderByDisplay, "End Date (descending), Schedule")
      %else
          @DTW_ASSIGN(orderBy, "SMEFFE,SMSCHD")
          @DTW_ASSIGN(orderByDisplay, "End Date, Schedule")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchSched, 3, 0) &&
                      editdate(document.Search.srchStartDate) &&
                      editdate(document.Search.srchEndDate) &&
                      editNum(document.Search.srchShift, 1, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "schedulesearch")
                  <td>
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Schedule</td>
                              @dtw_assign(operNbr, "operSched")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchSched" size="3" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Effectivity Start Date</td>
                              @dtw_assign(operNbr, "operStartDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchStartDate" size="6" maxlength="6"><a href="javascript:calWindow('srchStartDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Effectivity End Date</td>
                              @dtw_assign(operNbr, "operEndDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchEndDate" size="6" maxlength="6"><a href="javascript:calWindow('srchEndDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Shift</td>
                              @dtw_assign(operNbr, "operShift")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchShift" size="1" maxlength="1"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchSched.focus();
                          </script>
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("SMSCHD", "Schedule", $(srchSched), "", operSched, "N")
  @Build_WildCard ("upper(SMDESC)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("SMEFFS", "Start Date", $(srchStartDate), "", operStartDate, "D")
  @Build_WildCard ("SMEFFE", "End Date", $(srchEndDate), "", operEndDate, "D")
  @Build_WildCard ("SMSHFT", "Shift", $(srchShift), "", operShift, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
