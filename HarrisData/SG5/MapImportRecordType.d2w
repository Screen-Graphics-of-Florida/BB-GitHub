%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Import Row Type"
  d2wName                 = "MapImportRecordType.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;importKey=@dtw_rurlescseq(importKey)&amp;passedImportTable=@dtw_rurlescseq(passedImportTable)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HSYIRM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  noMsg                   = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "MAPIMPORTRECTYPE")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select SYMIRT.*,  ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(MFDESC,' ') as MFDESC, coalesce(MFDESCU,' ') as MFDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(FFDESC,' ') as FFDESC, coalesce(FFDESCU,' ') as FFDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " SYMIRT ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYMIHD on FHIMKY=FRIMKY ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYMMTB on MFMPKY=FHMPKY and MFMFIL=FRMFIL ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYMITB on FFIMKY=FRIMKY and FFIFIL=FRIFIL ", fileSQL)
                      @dtw_concat(selectSQL, " FRIMKY=$(importKey) ", selectSQL)
                      %if (passedImportTable != "")
                          @dtw_concat(selectSQL, " and FRIFIL='$(passedImportTable)' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (passedImportTable == "")
          @RtvFldDesc("FFIMKY=$(importKey)", "SYMITB", "CHAR(COUNT(*))", importTableCount)
          %if (importTableCount == "1")
              @RtvFldDesc("FFIMKY=$(importKey)", "SYMITB", "MAX(FFIFIL)", passedImportTable)
          %endif
      %endif

      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)MapImportRecordTypeMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      <table $(contentTable)>
          @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "FHDESC", V_FHDESC)
          @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "CHAR(FHMPKY)", V_FHMPKY)
          @Format_Header_URL("Import Definition", $(V_FHDESC), $(importKey), "$(homeURL)$(cGIPath)MapImportDefinitionSelect.d2w/REPORT$(d2wVarBase)")

          @RtvFldDesc("MHMPKY=$(V_FHMPKY)", "SYMMHD", "MHDESC", V_MHDESC)
          @RtvFldDesc("MHMPKY=$(V_FHMPKY)", "SYMMHD", "MHWPGM", V_MHWPGM)
          @Format_Header("Map Definition", $(V_MHDESC), $(V_MHWPGM))

          %if (passedImportTable != "")
              @RtvFldDesc("FFIMKY=$(importKey) and FFIFIL='$(passedImportTable)'", "SYMITB", "FFDESC", V_FFDESC)
              @Format_Header_URL("Import Table", $(V_FFDESC), $(passedImportTable), "$(homeURL)$(cGIPath)MapImportTableSelect.d2w/REPORT$(d2wVarBase)&amp;importTable=@dtw_rurlescseq(passedImportTable)")
          %endif
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint == "")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">Row Type</th>
                      %if (passedImportTable == "")
                          <th class="colhdr">Import Table</th>
                      %endif
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="15" maxlength="50">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchRecType" size="5" maxlength="5">
                          <input type="hidden" name="operRecType" value="LIKE">
                      </td>
                      %if (passedImportTable == "")
                          <td><input type="text" class="inputalph" name="srchTable" size="10" maxlength="10">
                              <input type="hidden" name="operTable" value="LIKE">
                          </td>
                      %endif
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("FRDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description"     title="Sequence By Description, Row Type">Description</a></th>
              @OrderBy_Sort("FRRTYP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RowType"         title="Sequence By Row Type">Row Type</a></th>
              @OrderBy_Sort("MFDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=InterfaceTable"  title="Sequence By Primary Interface Table, Row Type">Primary Interface Table</a></th>
              %if (passedImportTable == "")
                  @OrderBy_Sort("FFDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ImportTable" title="Sequence By Import Table, Row Type">Import Table</a></th>
              %endif
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;importTable=@dtw_rurlescseq(V_FRIFIL)&amp;importRecordType=@dtw_rurlescseq(V_FRRTYP)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;updRecNbr=@dtw_rurlescseq(START_ROW_NUM)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_FRDESC), "$(V_FRIFIL)-$(V_FRRTYP)", "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)MapImportRecordTypeMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)MapImportRecordTypeMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromImportTable=@dtw_rurlescseq(V_FRIFIL)&amp;fromImportRecordType=@dtw_rurlescseq(V_FRRTYP)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)MapImportRecordTypeMaintain.d2w/EDIT_DATA$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  %if (passedImportTable == "")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)MapImportRecordTypeSelect.d2w/REPORT$(d2wVarBase)&amp;passedImportTable=@dtw_rurlescseq(V_FRIFIL)&amp;passedRecordType=@dtw_rurlescseq(V_FRRTYP)" title="View Import Row Type">$(V_FRDESC)</a></td>
                  %else
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)MapImportRecordTypeSelect.d2w/REPORT$(d2wVarBase)&amp;passedRecordType=@dtw_rurlescseq(V_FRRTYP)" title="View Import Row Type">$(V_FRDESC)</a></td>
                  %endif
                  <td class="colalph">$(V_FRRTYP)</td>
                  <td class="colalph" $(helpCursor)><span title="$(V_FRMFIL)">$(V_MFDESC)</span></td>
                  %if (passedImportTable == "")
                      <td class="colalph" $(helpCursor)><span title="$(V_FRIFIL)">$(V_FFDESC)</span></td>
                  %endif
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select SYMIRT.*,  ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(MFDESC,' ') as MFDESC, coalesce(MFDESCU,' ') as MFDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(FFDESC,' ') as FFDESC, coalesce(FFDESCU,' ') as FFDESCU ", stmtSQL)
  @dtw_concat(fileSQL, " SYMIRT ", fileSQL)
  @dtw_concat(fileSQL, " left join SYMIHD on FHIMKY=FRIMKY ", fileSQL)
  @dtw_concat(fileSQL, " left join SYMMTB on MFMPKY=FHMPKY and MFMFIL=FRMFIL ", fileSQL)
  @dtw_concat(fileSQL, " left join SYMITB on FFIMKY=FRIMKY and FFIFIL=FRIFIL ", fileSQL)
  @dtw_concat(selectSQL, " FRIMKY=$(importKey) ", selectSQL)
  %if (passedImportTable != "")
      @dtw_concat(selectSQL, " and FRIFIL='$(passedImportTable)' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_XMLQuery (IN  CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("MapImportRowTypeList")
          %ROW{
              @XMLIDTag("$(V_FRIMKY)-$(V_FRIFIL)-$(V_FRRTYP)", "MapImportRowType ID")
                  @XMLTag(V_FRIMKY, "MapDefinition")
                  @XMLTag(V_FRIFIL, "ImportTable")
                  @XMLTag(V_FRRTYP, "RowType")
                  @XMLTag(V_FRDESC, "Description")
                  @XMLTag(V_FRMFIL, "PrimaryInterfaceTable")
              @XMLEndTag("MapImportRowType")
          %}
      @XMLEndTag("MapImportRowTypeList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "FRDESCU,FRRTYP,FRIFIL")
          @DTW_ASSIGN(orderByDisplay, "Description,  Row Type")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %if (updRecNbr > "0")
      @dtw_assign(START_ROW_NUM, updRecNbr)
      @dtw_assign(updRecNbr, "")
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Description")
      %if (orderBy == "FRDESCU,FRRTYP")
          @DTW_ASSIGN(orderBy, "FRDESCU DESC,FRRTYP")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Row Type")
      %else
          @DTW_ASSIGN(orderBy, "FRDESCU,FRRTYP")
          @DTW_ASSIGN(orderByDisplay, "Description, Row Type")
      %endif
  %elif (sequence == "RowType")
      %if (orderBy == "FRRTYP,FRIFIL")
          @DTW_ASSIGN(orderBy, "FRRTYP DESC,FRIFIL")
          @DTW_ASSIGN(orderByDisplay, "Row Type (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FRRTYP,FRIFIL")
          @DTW_ASSIGN(orderByDisplay, "Row Type")
      %endif
  %elif (sequence == "InterfaceTable")
      %if (orderBy == "MFDESCU,FRIFIL")
          @DTW_ASSIGN(orderBy, "MFDESCU DESC,FRIFIL")
          @DTW_ASSIGN(orderByDisplay, "Interface Table (descending), Row Type")
      %else
          @DTW_ASSIGN(orderBy, "MFDESCU,FRIFIL")
          @DTW_ASSIGN(orderByDisplay, "Interface Table, Row Type")
      %endif
  %elif (sequence == "ImportTable")
      %if (orderBy == "FFDESCU,FRRTYP")
          @DTW_ASSIGN(orderBy, "FFDESCU DESC,FRRTYP")
          @DTW_ASSIGN(orderByDisplay, "Import Table (descending), Row Type")
      %else
          @DTW_ASSIGN(orderBy, "FFDESCU,FRRTYP")
          @DTW_ASSIGN(orderByDisplay, "Import Table, Row Type")
      %endif
  %endif
	
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "MAPIMPORTRECTYPESEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Row Type</td>
                              @dtw_assign(operNbr, "operRecType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchRecType" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">Primary Interface Table</td>
                              @dtw_assign(operNbr, "operInterfaceTable")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchInterfaceTable" size="15" maxlength="50"></td>
                          </tr>

                          %if (passedImportTable == "")
                              <tr><td class="dsphdr">Import Table</td>
                                  @dtw_assign(operNbr, "operImportTable")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchImportTable" size="15" maxlength="50"></td>
                              </tr>
                          %endif

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDesc.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("FRDESCU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("FRRTYP", "Row Type", $(srchRecType), "U", operRecType, "A")
  @Build_WildCard ("MFDESCU", "Primary Interface Table", $(srchInterfaceTable), "U", operInterfaceTable, "A")
  @Build_WildCard ("FFDESCU", "Import Table", $(srchImportTable), "U", operImportTable, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}