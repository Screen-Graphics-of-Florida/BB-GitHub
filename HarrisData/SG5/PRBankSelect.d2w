%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title 		= "Bank"
  d2wName              = "PRBankSelect.d2w"
  d2wVarBase           = "$(genericVarBase)&amp;bankNumber=@dtw_rurlescseq(bankNumber)&amp;bankName=@dtw_rurlescseq(bankName)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName          = "HPRBKM"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  RPT_MAX_ROWS 	= "10"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext		= "1"
  totalPages		= "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@bankName", "@dtw_rurlescseq(bankName)", "1", "a", workURL)
  @dtw_replace(workURL, "@@bankNumber", "@dtw_rurlescseq(bankNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
  @dtw_replace(workURL, "@@prCompany", "@dtw_rurlescseq(prCompany)", "1", "a", workURL)
  @dtw_replace(workURL, "@@prFacility", "@dtw_rurlescseq(prFacility)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @PrBankUserView(profileHandle, dataBaseID, applicationID, userPass, bankNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
                  <table $(baseTable)>
                      <tr valign="top">
                          %if (formatToPrint == "")
                               @dtw_assign(pageID, "PRBANKSELECT")
                              <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                          %endif
                          <td class="content">
                              @dtw_assign(stmtSQL, "")
                              @dtw_concat(stmtSQL, " Select * From PRBANK ", stmtSQL)
                              @dtw_concat(stmtSQL, " Where BABKNO = $(bankNumber) ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              @Bank_Inquiry(profileHandle, dataBaseID, stmtSQL)
                          </td>
                      </tr>
                  </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Bank_Inquiry (IN CHAR(64)    profileHandle,
                                    CHAR(2)     dataBaseID,
                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @dtw_assign(maintainVar, "$(d2wVarBase)")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/prbank") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)&amp;prCompany=@dtw_rurlescseq(prCompany)&amp;prFacility=@dtw_rurlescseq(prFacility)" title="Return To Human Resource Administration">$(portalHome)</a>
                      %endif
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)PRBankMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (sec_01=="Y" && sec_04=="Y")
                          <a href="$(homeURL)$(cGIPath)PRBankMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageLrg)</a>
                      %endif
                      %if (sec_02 == "Y" || sec_03 == "Y")
                          <a href="$(homeURL)$(cGIPath)PRBankMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageLrg)</a>
                      %endif
                      %if (sec_03 == "Y")
                          @Format_Confirm_Desc($(bankName), $(bankNumber), "", "", "", "", confirmDesc)
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)PRBankMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)
	
      %ROW {

          <table $(contentTable)>
              <tr><td class="dsphdr">Bank Number</td>
                  <td class="dspalph">$(V_BABKNO)</td></tr>
              <tr><td class="dsphdr">Bank Name</td>
                  <td class="dspalph">$(V_BABKNM)</td></tr>
              <tr><td class="dsphdr">Bank Account Number</td>
                  <td class="dspalph">$(V_BAACCT)</td></tr>
              <tr><td class="dsphdr">Print Check # On The Check</td>
                  @RtvYNDesc($(V_BAPRCK), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td></tr>
              <tr><td class="dsphdr">Print Check # On The Stub</td>
                  @RtvYNDesc($(V_BAPCOS), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td></tr>
              <tr><td class="dsphdr">Number Of Leader Checks</td>
                  <td class="dspalph">$(V_BALEAD)</td></tr>
              <tr><td class="dsphdr">Name Format For Checks</td>
                  @RtvFldDesc("NFFMT=$(V_BAFMT)", "HRNFMT", "NFDESC", nameFormatDesc)
                  <td class="dspalph">$(nameFormatDesc)</td></tr>
              %if (@dtw_rlength(V_BASORT) == "1")
                  @dtw_insert("0", V_BASORT, V_BASORT)
              %endif
              <tr><td class="dsphdr">Sort Sequence For Checks</td>
                  @RtvFldDesc("FLTYPE='CHECKSORT' and FLVALU='$(V_BASORT)'", "SYFLAG", "FLDESC", syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td></tr>
              %if (V_BACMN1 != "")
                  <tr><td class="dsphdr">Check/Advice Comment 1</td>
                      <td class="dspalph">$(V_BACMN1)</td></tr>
              %endif
              %if (V_BACMN2 != "")
                  <tr><td class="dsphdr">Advice Comment 2</td>
                     <td class="dspalph">$(V_BACMN2)</td></tr>
              %endif
              <tr><td class="dsphdr">Print Check Total Hours</td>
                  @RtvYNDesc($(V_BATOTH), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td></tr>
              <tr><td class="dsphdr">Hourly Pay Rate Option</td>
                  @RtvFldDesc("FLTYPE='PAYRATEOPT' and FLVALU='$(V_BAPRT)'", "SYFLAG", "FLDESC", syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td></tr>
              <tr><td class="dsphdr">Round Rate To Two Decimal</td>
                  @RtvYNDesc($(V_BARND), syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td></tr>
              %if (V_BAFILE != "")
                  <tr><td class="dsphdr">Bank File Name</td>
                      <td class="dspalph">$(V_BAFILE)</td></tr>
              %endif
              %if (V_BAEXIT != "")
                  <tr><td class="dsphdr">Bank File Exit Program</td>
                      <td class="dspalph">$(V_BAEXIT)</td></tr>
              %endif
              <tr><td class="dsphdr">Next Available Check Number</td>
                  <td class="dspalph">$(V_BANACK)</td></tr>
              @Format_Date(V_BALSDT, "H", F_BALSDT)
              <tr><td class="dsphdr">Last Statement Date</td>
                  <td class="dspdate">$(F_BALSDT)</td></tr>
              <tr><td class="dsphdr">Direct Deposit Method</td>
                  @RtvFldDesc("FLTYPE='DIRDEP' and FLVALU='$(V_BAMETH)'", "SYFLAG", "FLDESC", syFlagDesc)
                  <td class="dspalph">$(syFlagDesc)</td></tr>
              %if (V_BAMETH != "")
                  <tr><td class="dsphdr">Immediate Destination</td>
                      <td class="dspalph">$(V_BAIMD#)</td></tr>
                  <tr><td class="dsphdr">Immediate Origin Value</td>
                      @RtvFldDesc("FLTYPE='IMMDORIGIN' and FLVALU='$(V_BAIOV)'", "SYFLAG", "FLDESC", syFlagDesc)
                      <td class="dspalph">$(syFlagDesc)</td></tr>
                  <tr><td class="dsphdr">File ID Modifier</td>
                      <td class="dspalph">$(V_BAFIDM)</td></tr>
                  <tr><td class="dsphdr">Pre-Notification Needed</td>
                      @RtvFldDesc("FLTYPE='BYN' and FLVALU='$(V_BAACH)'", "SYFLAG", "FLDESC", syFlagDesc)
                      <td class="dspalph">$(syFlagDesc)</td></tr>
                  <tr><td class="dsphdr">Beginning Batch Number</td>
                      <td class="dspalph">$(V_BABEGB)</td></tr>
                  <tr><td class="dsphdr">Output Filler Records</td>
                      @RtvFldDesc("FLTYPE='BYN' and FLVALU='$(V_BAFILL)'", "SYFLAG", "FLDESC", syFlagDesc)
                      <td class="dspalph">$(syFlagDesc)</td></tr>
                  <tr><td class="dsphdr">Employer Name Option</td>
                      @RtvFldDesc("FLTYPE='DIRDEPNAME' and FLVALU='$(V_BANMOP)'", "SYFLAG", "FLDESC", syFlagDesc)
                      <td class="dspalph">$(syFlagDesc)</td></tr>
                  <tr><td class="dsphdr">Direct Deposit Transmission File</td>
                      <td class="dspalph">$(V_BAACHT)</td></tr>
                  <tr><td class="dsphdr">Direct Deposit XSLT File</td>
                      <td class="dspalph">$(V_BAXSLT)</td></tr>
              %endif
          </table>
      %}
      $(hrTagAttr)	
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}