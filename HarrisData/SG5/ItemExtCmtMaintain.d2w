%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Item Extended Description Maintenance"
  d2wName                 = "ItemExtCmtMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;itemDescription=@dtw_rurlescseq(itemDescription)&amp;documentType=@dtw_rurlescseq(documentType)&amp;docDescription=@dtw_rurlescseq(docDescription)&amp;inquiryOnly=@dtw_rurlescseq(inquiryOnly)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
%}

%MACRO_FUNCTION Display_Comments () {	
  <html>
      <head>
          %INCLUDE "headcmt.icl"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "$(cmtBanner)"
          <!-- End Of Banner Code -->
          <table $(contentTable)>
              <tr valign="top">
                  <td>
                      @dtw_assign(comments, "")
                      @dtw_assign(comment, "")
                      %if (cmtSelection != "C")
                          @Get_Item_Comments(profileHandle, dataBaseID, itemNumber, documentType, comment)
                      %endif

                      %if (inquiryOnly == "Y")
                          @dtw_assign(page_title, "Item Extended Description")
                      %endif

                      <table $(contentTable)>
                  	   <colgroup>
                  	       <col width="80%">
                  	       <col width="15%">
                          <tr><td><h1>$(page_title)</h1></td>
                              <td class="toolbar">
                                  %if (inquiryOnly == "Y")
                                      %INCLUDE "CloseWindow.icl"
                                  %else
                                      <a href="javascript:check(document.Chg)">$(commentAcceptImage)</a>
                                      <a href="javascript:document.Chg.cmtSelection.value='R'; check(document.Chg)">$(commentResetImage)</a>
                                      <a href="$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;cmtSelection=C">$(commentClearImage)</a>
                                      <a href="$(homeURL)$(cGIPath)SpecSearch.d2w/REPORT$(genericVarBase)&amp;docName=Chg&amp;fldComment=comments" onclick="$(searchWinVar)"> $(searchSpecLrg)</a>
                                      @dtw_assign(medIcon, "Y")
                                      %INCLUDE "HelpPage.icl"
                                  %endif
                              </td>
                          </tr>
                      </table>

                      <table $(contentTable)>
                          @Format_Header("Item", $(itemDescription), $(itemNumber))
                          @Format_Header("Document", $(docDescription), $(documentType))
                      </table>

                      <table $(contentTable)>
                          <form class="formClass" METHOD=POST NAME=Chg ACTION="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)">
                              <tr><td><input type="hidden" name="cmtSelection"></td>
                                  <td>
                                      %if ("$(comment)" != "")
                                          <textarea name="comments" ROWS=20 COLS=60 WRAP="hard">$(comment)</textarea>
                                      %else
                                          <textarea name="comments" ROWS=20 COLS=60 WRAP="hard"></textarea>
                                      %endif
                                  </td>
                              </tr>
                      </table>
            	       <table $(contentTable)>
                          <tr>
                              <td valign="top">
                                  %if (inquiryOnly == "Y")
                                      %INCLUDE "CloseWindow.icl"
                                  %else
                                      <a href="javascript:check(document.Chg)">$(commentAcceptImage)</a>
                                      <a href="javascript:document.Chg.cmtSelection.value='R'; check(document.Chg)">$(commentResetImage)</a>
                                      <a href="$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;cmtSelection=C">$(commentClearImage)</a>
                                      <a href="$(homeURL)$(cGIPath)SpecSearch.d2w/REPORT$(genericVarBase)&amp;docName=Chg&amp;fldComment=comments" onclick="$(searchWinVar)"> $(searchSpecLrg)</a>
                                      @dtw_assign(medIcon, "Y")
                                      %INCLUDE "HelpPage.icl"
                                  %endif
                              </td>
                          </tr>
                      </table>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(cmtTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(DTW_directcall) Update_Comments (INOUT CHAR(64)     profileHandle,
				      		  CHAR(2)      dataBaseID,
				      		  CHAR(15)     itemNumber,
				      		  CHAR(3)      documentType,
				      		  char(32000)  comments)

{%EXEC {HHDEDM_W.PGM %}
%}

%FUNCTION(DTW_directcall) Get_Item_Comments(INOUT CHAR(64)     profileHandle,
				                   CHAR(2)      dataBaseID,
				                   CHAR(15)     itemNumber,	
				      	           CHAR(3)      documentType,
				                   char(32000)  comment)
{%EXEC {HHDEDM_P.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @Display_Comments ()
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  %if (cmtSelection == "R")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)">
  %else
      @Update_Comments(profileHandle, dataBaseID, itemNumber, documentType, comments)
      @dtw_assign(confMessage, "Confirm Update Of Document $(documentType) - $(docDescription)")
      <script TYPE="text/javascript">
          opener.location.href=opener.location.href;
          opener.focus();
          window.close();
      </script>
  %endif
%}