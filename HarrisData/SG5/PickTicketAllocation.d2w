%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Pick Ticket Allocation"
  d2wName                 = "PickTicketAllocation.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromWarehouseNumber, 3, 0) &&
                      editNum(document.Chg.toWarehouseNumber, 3, 0) &&
                      editdate(document.Chg.fromReqDate) &&
                      editdate(document.Chg.toReqDate) &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromProductClass, document.Chg.toProductClass, document.Chg.allProductClass, "A") &&
                      editFromToAll(document.Chg.fromProdGroup, document.Chg.toProdGroup, document.Chg.allProdGroup, "A") &&
                      editFromToAll(document.Chg.fromWarehouseNumber, document.Chg.toWarehouseNumber, document.Chg.allWarehouseNumber, 3) &&
                      editFromToAll(document.Chg.fromReqDate, document.Chg.toReqDate, document.Chg.allReqDate, "D"))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PICKTICKETALLOCATION")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromLocationNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@fitm", "fromItemNumber")          @dtw_assign(Err_N1FITM,  fieldValue)
                                  @DecatErr_Field("@@titm", "toItemNumber")          @dtw_assign(Err_N1TITM,  fieldValue)
                                  @DecatErr_Field("@@aitm", "allItemNumber")          @dtw_assign(Err_N1AITM,  fieldValue)
                                  @DecatErr_Field("@@fcls", "fromProductClass")          @dtw_assign(Err_N1FCLS,  fieldValue)
                                  @DecatErr_Field("@@tcls", "toProductClass")          @dtw_assign(Err_N1TCLS,  fieldValue)
                                  @DecatErr_Field("@@acls", "allProductClass")          @dtw_assign(Err_N1ACLS,  fieldValue)
                                  @DecatErr_Field("@@fpgp", "fromProdGroup")       @dtw_assign(Err_N1FPGP,  fieldValue)
                                  @DecatErr_Field("@@tpgp", "toProdGroup")       @dtw_assign(Err_N1TPGP,  fieldValue)
                                  @DecatErr_Field("@@apgp", "allProdGroup")       @dtw_assign(Err_N1APGP,  fieldValue)
                                  @DecatErr_Field("@@fwhs", "fromWarehouseNumber")       @dtw_assign(Err_N1FWHS,  fieldValue)
                                  @DecatErr_Field("@@twhs", "toWarehouseNumber")       @dtw_assign(Err_N1TWHS,  fieldValue)
                                  @DecatErr_Field("@@awhs", "allWarehouseNumber")       @dtw_assign(Err_N1AWHS,  fieldValue)
                                  @DecatErr_Field("@@fdte", "fromReqDate")       @dtw_assign(Err_N1FDTE,  fieldValue)
                                  @DecatErr_Field("@@tdte", "toReqDate")       @dtw_assign(Err_N1TDTE,  fieldValue)
                                  @DecatErr_Field("@@adte", "allReqDate")       @dtw_assign(Err_N1ADTE,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}

                                  @Decat_Field("@@fitm")  @dtw_assign(V_N1FITM,  fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N1TITM,  fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N1AITM,  fieldValue)
                                  @Decat_Field("@@fcls")  @dtw_assign(V_N1FCLS,  fieldValue)
                                  @Decat_Field("@@tcls")  @dtw_assign(V_N1TCLS,  fieldValue)
                                  @Decat_Field("@@acls")  @dtw_assign(V_N1ACLS,  fieldValue)
                                  @Decat_Field("@@fpgp")  @dtw_assign(V_N1FPGP,  fieldValue)
                                  @Decat_Field("@@tpgp")  @dtw_assign(V_N1TPGP,  fieldValue)
                                  @Decat_Field("@@apgp")  @dtw_assign(V_N1APGP,  fieldValue)
                                  @Decat_Field("@@fwhs")  @dtw_assign(V_N1FWHS,  fieldValue)
                                  @Decat_Field("@@twhs")  @dtw_assign(V_N1TWHS,  fieldValue)
                                  @Decat_Field("@@awhs")  @dtw_assign(V_N1AWHS,  fieldValue)
                                  @Decat_Field("@@fdte")  @dtw_assign(V_N1FDTE,  fieldValue)
                                  @Decat_Field("@@tdte")  @dtw_assign(V_N1TDTE,  fieldValue)
                                  @Decat_Field("@@adte")  @dtw_assign(V_N1ADTE,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}

                                  %if (V_N1AITM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif

                                  %if (V_N1AWHS == "ALL")
                                      @dtw_assign(checkedallWarehouseNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallWarehouseNumber, "")
                                  %endif

                                  %if (V_N1ACLS == "ALL")
                                      @dtw_assign(checkedallProductClass, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallProductClass, "")
                                  %endif

                                  %if (V_N1APGP == "ALL")
                                      @dtw_assign(checkedallProdGroup, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallProdGroup, "")
                                  %endif


                                  %if (V_N1ADTE == "ALL")
                                      @dtw_assign(checkedallReqDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallReqDate, "")
                                  %endif

                              %else
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallProductClass, "CHECKED")
                                  @dtw_assign(checkedallProdGroup, "CHECKED")
                                  @dtw_assign(checkedallWarehouseNumber, "CHECKED")
                                  @dtw_assign(checkedallReqDate, "CHECKED")
                              %endif
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_N1FITM)
                              %if (textOvr == "") @SetTextOvr(Err_N1TITM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AITM) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputnmbr"><input name="fromItemNumber" value="$(V_N1FITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(cGIPath)itemsearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toItemNumber" value="$(V_N1TITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(cGIPath)itemsearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=titemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="titemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FITM)
                              @DspErrMsg(Err_N1TITM)
                              @DspErrMsg(Err_N1AITM)

                              @SetTextOvr(Err_N1FWHS)
                              %if (textOvr == "") @SetTextOvr(Err_N1TWHS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AWHS) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Warehouse</span></td>
                                  <td class="inputnmbr"><input name="fromWarehouseNumber" value="$(V_N1FWHS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(cGIPath)warehousesearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromWarehouseNumber&amp;fldDesc=fwarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fwarehouseName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toWarehouseNumber" value="$(V_N1TWHS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(cGIPath)warehousesearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toWarehouseNumber&amp;fldDesc=twarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="twarehouseName" type="hidden"></td>
                                  <td class="inputalph"><input name="allWarehouseNumber" value='ALL' $(checkedallWarehouseNumber) type="checkbox" onClick="if (this.checked) this.form.fromWarehouseNumber.value='', this.form.toWarehouseNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FWHS)
                              @DspErrMsg(Err_N1TWHS)
                              @DspErrMsg(Err_N1AWHS)

                              @SetTextOvr(Err_N1FCLS)
                              %if (textOvr == "") @SetTextOvr(Err_N1TCLS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ACLS) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Product Class</span></td>
                                  <td class="inputalph"><input name="fromProductClass" value="$(V_N1FCLS)" type="text" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)prodclasssearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromProductClass&amp;fldDesc=fromProdClassDescH" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fromProdClassDescH" type="hidden"></td>
                                  <td class="inputalph"><input name="toProductClass" value="$(V_N1TCLS)" type="text" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)prodclasssearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toProductClass&amp;fldDesc=toProdClassDescH" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toProdClassDescH" type="hidden"></td>
                                  <td class="inputalph"><input name="allProductClass" value='ALL' $(checkedallProductClass) type="checkbox" onClick="if (this.checked) this.form.fromProductClass.value='', this.form.toProductClass.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FCLS)
                              @DspErrMsg(Err_N1TCLS)

                              @SetTextOvr(Err_N1FPGP)
                              %if (textOvr == "") @SetTextOvr(Err_N1TPGP) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1APGP) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Product Group</span></td>
                                  <td class="inputnmbr"><input name="fromProdGroup" value="$(V_N1FPGP)" type="text" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)ProductGroupSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromProdGroup&amp;fldDesc=fprodGroupDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fprodGroupDesc" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toProdGroup" value="$(V_N1TPGP)" type="text" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)ProductGroupSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toProdGroup&amp;fldDesc=tprodGroupDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="tprodGroupDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allProdGroup" value='ALL' $(checkedallProdGroup) type="checkbox" onClick="if (this.checked) this.form.fromProdGroup.value='', this.form.toProdGroup.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FPGP)
                              @DspErrMsg(Err_N1TPGP)
                              @DspErrMsg(Err_N1APGP)


                              @SetTextOvr(Err_N1FDTE)
                              %if (textOvr == "") @SetTextOvr(Err_N1TDTE) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ADTE) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Required Date</span></td>
                                  <td class="inputnmbr"><input name="fromReqDate" value="$(V_N1FDTE)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromReqDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toReqDate" value="$(V_N1TDTE)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toReqDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allReqDate" value='ALL' $(checkedallReqDate) type="checkbox" onClick="if (this.checked) this.form.fromReqDate.value='', this.form.toReqDate.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FDTE)
                              @DspErrMsg(Err_N1TDTE)
                              @DspErrMsg(Err_N1ADTE)
                          </table>

                          @dtw_assign(envProgram, "COEPAS")
                          @dtw_assign(envPrinter, "")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HOEPAS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(fromProductClass)
  @dtw_mUPPERCASE(toProductClass)
  @dtw_mUPPERCASE(allProductClass)
  @dtw_mUPPERCASE(fromProdGroup)
  @dtw_mUPPERCASE(toProdGroup)
  @dtw_mUPPERCASE(allProdGroup)
  @dtw_mUPPERCASE(allWarehouseNumber)
  @dtw_mUPPERCASE(allReqDate)

  %if (allLocationNumber != "ALL")
      @dtw_assign(allLocationNumber, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allProductClass != "ALL")
      @dtw_assign(allProductClass, "")
  %endif
  %if (allProdGroup != "ALL")
      @dtw_assign(allProdGroup, "")
  %endif
  %if (allWarehouseNumber != "ALL")
      @dtw_assign(allWarehouseNumber, "")
  %endif


  @dtw_assign(edtVar, "")
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@fcls", fromProductClass)
  @Concat_Field("@@tcls", toProductClass)
  @Concat_Field("@@acls", allProductClass)
  @Concat_Field("@@fpgp", fromProdGroup)
  @Concat_Field("@@tpgp", toProdGroup)
  @Concat_Field("@@apgp", allProdGroup)
  @Concat_Field("@@fwhs", fromWarehouseNumber)
  @Concat_Field("@@twhs", toWarehouseNumber)
  @Concat_Field("@@awhs", allWarehouseNumber)
  @Concat_Field("@@fdte", fromReqDate)
  @Concat_Field("@@tdte", toReqDate)
  @Concat_Field("@@adte", allReqDate)
  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  @dtw_assign(totalLocationNumber, "")
  %INCLUDE "SubmitScheduleUpdate.icl"
%}