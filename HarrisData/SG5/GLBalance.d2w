%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "General Ledger Balance"
  d2wName                 = "GLBalance.d2w"
  d2wVarBase              = "$(genericVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "GLCOMPANY")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
OBCO






OBGMNMU
                      @dtw_concat(stmtSQL, " Select OBCO, OBFAC, OBACCT, OBSUB, OBYEAR, OBGMNM, ",  stmtSQL)
                      @dtw_concat(stmtSQL, " OBPBAL+ (Select coalesce(SUM(TSEAMT),0) from GLTRSM Where TSCO=OBCO and TSFAC=OBFAC and TSACCT=OBACCT and TSSUB=OBSUB and TSYEAR=OBYEAR and TSPER#<=  ),",  stmtSQL)
                      @dtw_concat(fileSQL, " GLTROB ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, " COCO<>0 ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @GLCompanys_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) GLCompanys_Query (IN CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("CTCCLO='Y'", "GLCTRL", "CTCCLO", V_CTCCLO)

      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)GLCompanyMaintain.d2w/MAINTAIN$(genericVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr$(sortVar)">Name</th></tr>
                  <tr><td><input type="text" class="inputalph" name="srchName" size="30" maxlength="30">
                          <input type="hidden" name="operName" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchName.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
    %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("COCO", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=GLCompany" title="Sequence By Company"> Co</a></th>
              @OrderBy_Sort("CONAME", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Name" title="Sequence By Name, Company"> Name</a></th>
              %if (V_CTCCLO == "Y")
                  @OrderBy_Sort("COGLCP", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Period" title="Sequence By Period, Company"> Current Period</a></th>
              %endif
              @OrderBy_Sort("CODTES", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Started" title="Sequence By Date Started, Company"> Date Started</a></th>
              @OrderBy_Sort("CODTDE", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=OutOfBus" title="Sequence By Date Out Of Business, Company">Date Out Of Business</a></th>
              @OrderBy_Sort("COUSER", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=User" title="Sequence By User Profile, Company"> User Profile</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(genericVarBase)&amp;glcompany=@dtw_rurlescseq(V_COCO)&amp;glcompanyname=@dtw_rurlescseq(V_CONAME)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_CONAME), $(V_COCO), "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)GLCompanyMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)GLCompanyMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)GLCompanyMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_COCO)</td>
                  <td class="colalph">$(V_CONAME)</td>

                  %if (V_CTCCLO == "Y")
                      @PeriodFromCYP(V_COGLCP)
                      <td class="colcode">$(V_COGLCP)</td>
                  %endif

                  @Format_Date(V_CODTES, "D", F_CODTES)
                  @Format_Date(V_CODTDE, "D", F_CODTDE)

                  <td class="coldate">$(F_CODTES)</td>
                  <td class="coldate">$(F_CODTDE)</td>
                  <td class="colalph">$(V_COUSER)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select COCO, CONAME, COGLCP, COLPDC, CODTES, CODTDE, COUSER",  stmtSQL)
  @dtw_concat(fileSQL, " HDCOMP ", fileSQL)
  %if (wildCardSearch!="")
      @dtw_concat(selectSQL, " COCO<>0 ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @GLCompany_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) GLCompany_XMLQuery (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("GLCompanyList")
          %ROW{
	       @XMLIDTag(V_COCO, "GLCompany ID")
                  @XMLTag(V_COCO, "GLCompany")
                  @XMLTag(V_CONAME, "Name")
                  @XMLTag(V_COGLCP, "CurrentAcctPeriod")
                  @XMLTag(V_CODTES, "DateOutOfBusiness")
                  @XMLTag(V_CODTDE, "DateStarted")
                  @XMLTag(V_COUSER, "UserProfile")
              @XMLEndTag("GLCompany")
          %}
      @XMLEndTag("GLCompanyList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "CONAME,COCO")
          @DTW_ASSIGN(orderByDisplay, "Name, Company")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}
%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "GLCompany")
      %if (orderBy == "COCO")
          @DTW_ASSIGN(orderBy, "COCO DESC")
          @DTW_ASSIGN(orderByDisplay, "Company (descending)")
      %else
          @DTW_ASSIGN(orderBy, "COCO")
          @DTW_ASSIGN(orderByDisplay, "Company")
      %endif
  %elif (sequence == "Name")
      %if (orderBy == "CONAME,COCO")
          @DTW_ASSIGN(orderBy, "CONAME DESC,COCO")
          @DTW_ASSIGN(orderByDisplay, "Name (descending), Company")
      %else
          @DTW_ASSIGN(orderBy, "CONAME,COCO")
          @DTW_ASSIGN(orderByDisplay, "Name, Company")
      %endif
  %elif (sequence == "Period")
      %if (orderBy == "COGLCP,COCO")
          @DTW_ASSIGN(orderBy, "COGLCP DESC,COCO")
          @DTW_ASSIGN(orderByDisplay, "Period (descending), Company")
      %else
          @DTW_ASSIGN(orderBy, "COGLCP,COCO")
          @DTW_ASSIGN(orderByDisplay, "Period, Company")
      %endif
  %elif (sequence == "Started")
      %if (orderBy == "CODTES,COCO")
          @DTW_ASSIGN(orderBy, "CODTES DESC,COCO")
          @DTW_ASSIGN(orderByDisplay, "Date Started (descending), Company")
      %else
          @DTW_ASSIGN(orderBy, "CODTES,COCO")
          @DTW_ASSIGN(orderByDisplay, "Date Started, Company")
      %endif
  %elif (sequence == "OutOfBus")
      %if (orderBy == "CODTDE,COCO")
          @DTW_ASSIGN(orderBy, "CODTDE DESC,COCO")
          @DTW_ASSIGN(orderByDisplay, "Date Out Of Business (descending), Company")
      %else
          @DTW_ASSIGN(orderBy, "CODTDE,COCO")
          @DTW_ASSIGN(orderByDisplay, "Date Out Of Business, Company")
      %endif
  %elif (sequence == "User")
      %if (orderBy == "COUSER,COCO")
          @DTW_ASSIGN(orderBy, "COUSER DESC,COCO")
          @DTW_ASSIGN(orderByDisplay, "User Profile (descending), Company")
      %else
          @DTW_ASSIGN(orderBy, "COUSER,COCO")
          @DTW_ASSIGN(orderByDisplay, "User Profile, Company")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("CTCCLO='Y'", "GLCTRL", "CTCCLO", V_CTCCLO)
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchCo, 2, 0) &&
                      %if (V_CTCCLO == "Y")
                          editNum(document.Search.srchPeriod, 4, 0) &&
                      %endif
                      editdate(document.Search.srchStarted) &&
                      editdate(document.Search.srchOutOfBus))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "COSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Company</td>
                              @dtw_assign(operNbr, "operCo")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchCo" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Name</td>
                              @dtw_assign(operNbr, "operName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchName" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">User Profile</td>
                              @dtw_assign(operNbr, "operUser")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchUser" size="10" maxlength="10"></td>
                          </tr>

                          %if (V_CTCCLO == "Y")
                              <tr><td class="dsphdr">Period</td>
                                  @dtw_assign(operNbr, "operPeriod")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchPeriod" size="4" maxlength="4"></td>
                              </tr>
                          %endif

                          <tr><td class="dsphdr">Date Started</td>
                              @dtw_assign(operNbr, "operStarted")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchStarted" size="6" maxlength="6"><a href="javascript:calWindow('srchStarted');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Date Out Of Business</td>
                              @dtw_assign(operNbr, "operOutOfBus")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchOutOfBus" size="6" maxlength="6"><a href="javascript:calWindow('srchOutOfBus');">$(calendarImage)</a></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchCo.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("COCO", "Company", $(srchCo), "", operCo, "N")
  @Build_WildCard ("upper(CONAME)", "Name", $(srchName), "U", operName, "A")
  @Build_WildCard ("upper(COUSER)", "User Profile", $(srchUser), "U", operUser, "A")
  @Build_WildCard ("COGLCP", "Period", $(srchPeriod), "", operPeriod, "DP")
  @Build_WildCard ("CODTES", "Date Started", $(srchStarted), "", operStarted, "D")
  @Build_WildCard ("CODTDE", "Date Out Of Business", $(srchOutOfBus), "", operOutOfBus, "D")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
