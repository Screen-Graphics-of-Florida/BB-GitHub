%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Audit Purge"
  d2wName                 = "AuditFilePurge.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;grouping=@dtw_rurlescseq(grouping)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  programName             = "HHDAUD"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {

                  if (
                      editdate(document.Chg.fromDate) &&
                      editdate(document.Chg.toDate) &&
                      editFromToAll(document.Chg.fromActCode, document.Chg.toActCode, document.Chg.allActCode,"A") &&
                      editFromToAll(document.Chg.fromUsrPrf, document.Chg.toUsrPrf, document.Chg.allUsrPrf,"A") &&
                      editFromToAll(document.Chg.fromDate, document.Chg.toDate, document.Chg.allDate,"D")
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "AUDITFILEPURGE")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(backHome, "hdList.php$(altVarBase)&amp;tblID=159")
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                     <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                         <table $(contentTable)>
                             @dtw_assign(focusField, "fromActCode")
                             %if (errFound != "" || scheduleJobSwitch == "Y")
                                 @EdtVarErr(profileHandle, typeValue, edtVar)
                                 @dtw_assign(focusField, "")
                                 @ErrVarErr(profileHandle, typeError, errVar)
                                 @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                 @DecatErr_Field("@@fact", "fromActCode")      @dtw_assign(Err_SLFACT,  fieldValue)
                                 @DecatErr_Field("@@tact", "toActCode")        @dtw_assign(Err_SLTACT,  fieldValue)
                                 @DecatErr_Field("@@aact", "allActCode")       @dtw_assign(Err_SLAACT,  fieldValue)

                                 @DecatErr_Field("@@fupr", "fromUsrPrf")       @dtw_assign(Err_SLFUPR,  fieldValue)
                                 @DecatErr_Field("@@tupr", "toUsrPrf")         @dtw_assign(Err_SLTUPR,  fieldValue)
                                 @DecatErr_Field("@@aupr", "allUsrPrf")        @dtw_assign(Err_SLAUPR,  fieldValue)

                                 @DecatErr_Field("@@fdat", "fromDate")         @dtw_assign(Err_SLFDAT,  fieldValue)
                                 @DecatErr_Field("@@tdat", "toDate")           @dtw_assign(Err_SLTDAT,  fieldValue)
                                 @DecatErr_Field("@@adat", "allDate")          @dtw_assign(Err_SLADAT,  fieldValue)

                                 %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}

                                 @Decat_Field("@@fact")   @dtw_assign(V_SLFACT,  fieldValue)
                                 @Decat_Field("@@tact")   @dtw_assign(V_SLTACT,  fieldValue)
                                 @Decat_Field("@@aact")   @dtw_assign(V_SLAACT,  fieldValue)

                                 @Decat_Field("@@fupr")   @dtw_assign(V_SLFUPR,  fieldValue)
                                 @Decat_Field("@@tupr")   @dtw_assign(V_SLTUPR,  fieldValue)
                                 @Decat_Field("@@aupr")   @dtw_assign(V_SLAUPR,  fieldValue)

                                 @Decat_Field("@@fdat")   @dtw_assign(V_SLFDAT,  fieldValue)
                                 @Decat_Field("@@tdat")   @dtw_assign(V_SLTDAT,  fieldValue)
                                 @Decat_Field("@@adat")   @dtw_assign(V_SLADAT,  fieldValue)


                                 %INCLUDE "ScheduleJobValue.icl"  %{ Schedule Entries Values %}

                                 %if (V_SLAACT == "ALL")
                                     @dtw_assign(checkedActCode, "CHECKED")
                                 %else
                                     @dtw_assign(checkedActCode, "")
                                 %endif

                                 %if (V_SLAUPR == "ALL")
                                     @dtw_assign(checkedUsrPrf, "CHECKED")
                                 %else
                                     @dtw_assign(checkedUsrPrf, "")
                                 %endif

                                 %if (V_SLADAT == "ALL")
                                     @dtw_assign(checkedCheckDate, "CHECKED")
                                 %else
                                     @dtw_assign(checkedCheckDate, "")
                                 %endif

                             %else
                                 @dtw_assign(checkedActCode,   "CHECKED")
                                 @dtw_assign(checkedUsrPrf,    "CHECKED")
                                 @dtw_assign(checkedDate,      "CHECKED")

                             %endif


                              @dtw_assign(scheduleJobSwitch, "")
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_SLFACT)
                              %if (textOvr == "") @SetTextOvr(Err_SLTACT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SLAACT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Activity Code</span></td>
                                  <td class="inputalph"><input name="fromActCode" value="$(V_SLFACT)" type="text" size="1" maxlength="1"> <a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromHistDept&amp;fldDesc=fromDeptDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input  name="fromDeptDesc" value="$(fromDeptDesc)"  type="hidden" size="20" maxlength="20"></td>
                                  <td class="inputalph"><input name="toActCode"   value="$(V_SLTACT)" type="text" size="1" maxlength="1"> <a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toHistDept&amp;fldDesc=toDeptDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input  name="toDeptDesc" value="$(toDeptDesc)"  type="hidden" size="20" maxlength="20"></td>
                                  <td class="inputalph"><input name="allActCode" VALUE='ALL' $(checkedActCode) type="checkbox" onClick="if (this.checked) this.form.fromActCode.value='', this.form.toActCode.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_SLFACT)
                              @DspErrMsg(Err_SLTACT)
                              @DspErrMsg(Err_SLAACT)


                              @SetTextOvr(Err_SLFUPR)
                              %if (textOvr == "") @SetTextOvr(Err_SLTUPR) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SLAUPR) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>User Profile</span></td>
                                  <td class="inputalph"><input name="fromUsrPrf" value="$(V_SLFUPR)" type="text" size="10" maxlength="10"> <a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromHistDept&amp;fldDesc=fromDeptDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input  name="fromDeptDesc" value="$(fromDeptDesc)"  type="hidden" size="20" maxlength="20"></td>
                                  <td class="inputalph"><input name="toUsrPrf"   value="$(V_SLTUPR)" type="text" size="10" maxlength="10"> <a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toHistDept&amp;fldDesc=toDeptDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input  name="toDeptDesc" value="$(toDeptDesc)"  type="hidden" size="20" maxlength="20"></td>
                                  <td class="inputalph"><input name="allUsrPrf" VALUE='ALL' $(checkedUsrPrf) type="checkbox" onClick="if (this.checked) this.form.fromUsrPrf.value='', this.form.toUsrPrf.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_SLFUPR)
                              @DspErrMsg(Err_SLTUPR)
                              @DspErrMsg(Err_SLAUPR)


                              @SetTextOvr(Err_SLFDAT)
                              %if (textOvr == "") @SetTextOvr(Err_SLTDAT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SLADAT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Date</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromDate" VALUE="$(V_SLFDAT)" size="5" maxlength="6"> 		
                                      <a href="javascript:calWindow('fromDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input type="text" name="toDate" VALUE="$(V_SLTDAT)" size="5" maxlength="6"> 		
                                      <a href="javascript:calWindow('toDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="allDate" VALUE='ALL' $(checkedCheckDate) type="checkbox" onClick="if (this.checked) this.form.fromDate.value='', this.form.toDate.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_SLFDAT)
                              @DspErrMsg(Err_SLTDAT)
                              @DspErrMsg(Err_SLADAT)

                          </table>


                          @dtw_assign(envProgram, "HHDAFP")
                          @dtw_assign(envPrinter, "")

                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HHDAPS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL()
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"

  @dtw_mUPPERCASE(fromActCode)
  @dtw_mUPPERCASE(toActCode)
  @dtw_mUPPERCASE(allActCode)
  %if (allActCode != "ALL")
      @dtw_assign(allActCode, "")
  %endif

  @dtw_mUPPERCASE(fromUsrPrf)
  @dtw_mUPPERCASE(toUsrPrf)
  @dtw_mUPPERCASE(allUsrPRf)
  %if (allUsrPrf != "ALL")
      @dtw_assign(allUsrPrf, "")
  %endif

  @dtw_mUPPERCASE(allDate)
  @dtw_assign(fromDate,@dtw_rstrip(fromDate))
  @dtw_assign(toDate,@dtw_rstrip(toDate))
  %if (allDate != "ALL")
      @dtw_assign(allDate, "")
  %endif


  @dtw_assign(edtVar, "")
  @Concat_Field("@@grp@", grouping)

  @Concat_Field("@@fact", fromActCode)
  @Concat_Field("@@tact", toActCode)
  @Concat_Field("@@aact", allActCode)

  @Concat_Field("@@fupr", fromUsrPrf)
  @Concat_Field("@@tupr", toUsrPrf)
  @Concat_Field("@@aupr", allUsrPrf)

  @Concat_Field("@@fdat", fromDate)
  @Concat_Field("@@tdat", toDate)
  @Concat_Field("@@adat", allDate)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}