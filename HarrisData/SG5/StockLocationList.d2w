%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Stock Location List"
  d2wName                 = "StockLocationList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)&amp;apid=@dtw_rurlescseq(apid)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromWarehouse, 3, 0) &&
                      editNum(document.Chg.toWarehouse, 3, 0) &&
                      editFromToAll(document.Chg.fromWarehouse, document.Chg.toWarehouse, document.Chg.allWarehouse, 3) &&
                      editFromToAll(document.Chg.fromStockroom, document.Chg.toStockroom, document.Chg.allStockroom, "A")  &&
                      editFromToAll(document.Chg.fromAisle, document.Chg.toAisle, document.Chg.allAisle, "A") &&
                      editFromToAll(document.Chg.fromLocation, document.Chg.toLocation, document.Chg.allLocation, "A"))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "STOCKLOCATIONLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromWarehouse")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@fwhs")  @dtw_assign(V_N1FWHS,  fieldValue)
                                  @Decat_Field("@@twhs")  @dtw_assign(V_N1TWHS,  fieldValue)
                                  @Decat_Field("@@awhs")  @dtw_assign(V_N1AWHS,  fieldValue)
                                  @Decat_Field("@@fskr")  @dtw_assign(V_N1FSKR, fieldValue)
                                  @Decat_Field("@@tskr")  @dtw_assign(V_N1TSKR, fieldValue)
                                  @Decat_Field("@@askr")  @dtw_assign(V_N1ASKR, fieldValue)
                                  @Decat_Field("@@fale")  @dtw_assign(V_N1FALE, fieldValue)
                                  @Decat_Field("@@tale")  @dtw_assign(V_N1TALE, fieldValue)
                                  @Decat_Field("@@aale")  @dtw_assign(V_N1AALE, fieldValue)
                                  @Decat_Field("@@floc")  @dtw_assign(V_N1FLOC, fieldValue)
                                  @Decat_Field("@@tloc")  @dtw_assign(V_N1TLOC, fieldValue)
                                  @Decat_Field("@@aloc")  @dtw_assign(V_N1ALOC, fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1AWHS == "ALL")
                                      @dtw_assign(checkedAllWarehouse, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllWarehouse, "")
                                  %endif
                                  %if (V_N1ASKR == "ALL")
                                      @dtw_assign(checkedAllStockroom, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllStockroom, "")
                                  %endif
                                  %if (V_N1AALE == "ALL")
                                      @dtw_assign(checkedAllAisle, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllAisle, "")
                                  %endif
                                  %if (V_N1ALOC == "ALL")
                                      @dtw_assign(checkedAllLocation, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllLocation, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedAllWarehouse, "CHECKED")
                                  @dtw_assign(checkedAllStockroom, "CHECKED")
                                  @dtw_assign(checkedAllAisle, "CHECKED")
                                  @dtw_assign(checkedAllLocation, "CHECKED")
                              %endif

                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              <tr><td class="dsphdr"><span $(textOvr)>Warehouse</span></td>
                                  <td class="inputnmbr"><input name="fromWarehouse" value="$(V_N1FWHS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromWarehouse&amp;fldDesc=fwarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fwarehouseName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toWarehouse" value="$(V_N1TWHS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toWarehouse&amp;fldDesc=twarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="twarehouseName" type="hidden"></td>
                                  <td class="inputalph"><input name="allWarehouse" value='ALL' $(checkedAllWarehouse) type="checkbox" onClick="if (this.checked) this.form.fromWarehouse.value='', this.form.toWarehouse.value='';"></td>

                                   <tr><td class="dsphdr"><span $(textOvr)>Stockroom</span></td>
                                     <td class="inputalph"><input name="fromStockroom" value="$(V_N1FSKR)" type="text" size="5" maxlength="3"><a href="$(homeURL)$(phpPath)StockLocSearch.php$(altVarBase)&amp;docName=Chg&amp;forWhs=@dtw_rurlescseq(fromWarehouse)&amp;fldStkr=fromStockroom&amp;fldAisle=fromAisle&amp;fldLoc=fromLocation&amp;fldStkID=stockLocId" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stockLocId" type="hidden"></td>
                                     <td class="inputalph"><input name="toStockroom" value="$(V_N1TSKR)" type="text" size="5" maxlength="3"><a href="$(homeURL)$(phpPath)StockLocSearch.php$(altVarBase)&amp;docName=Chg&amp;forWhs=@dtw_rurlescseq(toWarehouse)&amp;fldStkr=toStockroom&amp;fldAisle=toAisle&amp;fldLoc=toLocation&amp;fldStkID=stockLocId" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stockLocId" type="hidden"></td>
                                     <td class="inputalph"><input name="allStockroom" value='ALL' $(checkedAllStockroom) type="checkbox" onClick="if (this.checked) this.form.fromStockroom.value='', this.form.toStockroom.value='';"></td>
                                 </tr>

                                 <tr><td class="dsphdr"><span $(textOvr)>Aisle</span></td>
                                     <td class="inputalph"><input name="fromAisle" value="$(V_N1FALE)" type="text" size="6" maxlength="4"><a href="$(homeURL)$(phpPath)StockLocSearch.php$(altVarBase)&amp;docName=Chg&amp;forWhs=@dtw_rurlescseq(fromWarehouse)&amp;fldStkr=fromStockroom&amp;fldAisle=fromAisle&amp;fldLoc=fromLocation&amp;fldStkID=stockLocId" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stockLocId" type="hidden"></td>
                                     <td class="inputalph"><input name="toAisle" value="$(V_N1TALE)" type="text" size="6" maxlength="4"><a href="$(homeURL)$(phpPath)StockLocSearch.php$(altVarBase)&amp;docName=Chg&amp;forWhs=@dtw_rurlescseq(toWarehouse)&amp;fldStkr=toStockroom&amp;fldAisle=toAisle&amp;fldLoc=toLocation&amp;fldStkID=stockLocId" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stockLocId" type="hidden"></td>
                                     <td class="inputalph"><input name="allAisle" value='ALL' $(checkedAllAisle) type="checkbox" onClick="if (this.checked) this.form.fromAisle.value='', this.form.toAisle.value='';"></td>
                                 </tr>

                                 <tr><td class="dsphdr"><span $(textOvr)>Location</span></td>
                                     <td class="inputalph"><input name="fromLocation" value="$(V_N1FLOC)" type="text" size="12" maxlength="8"><a href="$(homeURL)$(phpPath)StockLocSearch.php$(altVarBase)&amp;docName=Chg&amp;forWhs=@dtw_rurlescseq(fromWarehouse)&amp;fldStkr=fromStockroom&amp;fldAisle=fromAisle&amp;fldLoc=fromLocation&amp;fldStkID=stockLocId" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stockLocId" type="hidden"></td>
                                     <td class="inputalph"><input name="toLocation" value="$(V_N1TLOC)" type="text" size="12" maxlength="8"><a href="$(homeURL)$(phpPath)StockLocSearch.php$(altVarBase)&amp;docName=Chg&amp;forWhs=@dtw_rurlescseq(toWarehouseNumber)&amp;fldStkr=toStockroom&amp;fldAisle=toAisle&amp;fldLoc=toLocation&amp;fldStkID=stockLocId" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stockLocId" type="hidden"></td>
                                     <td class="inputalph"><input name="allLocation" value='ALL' $(checkedAllLocation) type="checkbox" onClick="if (this.checked) this.form.fromLocation.value='', this.form.toLocation.value='';"></td>
                                 </tr>
                          </table>

                          @dtw_assign(envProgram, "HHDSKL")
                          @dtw_assign(envPrinter, "HHDSKLPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HHDSKS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allWarehouse)
  @dtw_mUPPERCASE(fromStockroom)
  @dtw_mUPPERCASE(toStockroom)
  @dtw_mUPPERCASE(allStockroom)
  @dtw_mUPPERCASE(fromAisle)
  @dtw_mUPPERCASE(toAisle)
  @dtw_mUPPERCASE(allAisle)
  @dtw_mUPPERCASE(fromLocation)
  @dtw_mUPPERCASE(toLocation)
  @dtw_mUPPERCASE(allLocation)

  @dtw_assign(fromWarehouse,@dtw_rstrip(fromWarehouse))
  @dtw_assign(toWarehouse,@dtw_rstrip(toWarehouse))

  %if (allWarehouse != "ALL")
      @dtw_assign(allWarehouse, "")
  %endif
  %if (allStockroom != "ALL")
      @dtw_assign(allStockroom, "")
  %endif
  %if (allAisle != "ALL")
      @dtw_assign(allAisle, "")
  %endif
  %if (allLocation != "ALL")
      @dtw_assign(allLocation, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@apid", apid)
  @Concat_Field("@@fwhs", fromWarehouse)
  @Concat_Field("@@twhs", toWarehouse)
  @Concat_Field("@@awhs", allWarehouse)
  @Concat_Field("@@fskr", fromStockroom)
  @Concat_Field("@@tskr", toStockroom)
  @Concat_Field("@@askr", allStockroom)
  @Concat_Field("@@fale", fromAisle)
  @Concat_Field("@@tale", toAisle)
  @Concat_Field("@@aale", allAisle)
  @Concat_Field("@@floc", fromLocation)
  @Concat_Field("@@tloc", toLocation)
  @Concat_Field("@@aloc", allLocation)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}