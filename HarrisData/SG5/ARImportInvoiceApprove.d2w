%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "A/R Invoice Import Approve"
  d2wName                 = "ARImportInvoiceApprove.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfInstance=@dtw_rurlescseq(wfInstance)&amp;wfInstanceDate=@dtw_rurlescseq(wfInstanceDate)&amp;wfWorkItem=@dtw_rurlescseq(wfWorkItem)&amp;wfWorkItemSequence=@dtw_rurlescseq(wfWorkItemSequence)&amp;wfParticipantId=@dtw_rurlescseq(wfParticipantId)&amp;wfProcess=@dtw_rurlescseq(wfProcess)&amp;wfPoint=@dtw_rurlescseq(wfPoint)&amp;wfSequence=@dtw_rurlescseq(wfSequence)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  maintainVar             = ""
  showIconPassWith        = ""
  showIconPassWithout     = ""
  recordCount             = ""
  V_FIWITM                = ""
  V_FIWISQ                = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @RtvFldDesc("(WIINST,WIINDT,WIWITM,WIWISQ,WIMODE,WPPTID,WPPART)=($(wfInstance),$(wfInstanceDate),$(wfWorkItem),$(wfWorkItemSequence),'M',$(wfParticipantId),'$(userProfile)') and WPRVWS in ('Y',' ') ", "WFWITM inner join WFWIPT on (WPINST,WPINDT,WPWITM,WPWISQ)=(WIINST,WIINDT,WIWITM,WIWISQ) ", "char(count(*))", recCount)	
  %if (recCount<="0")
      @dtw_assign(userPass,"N")
  %else
      @RtvFldDesc("(FIINST,FIINDT,FICLOS)=($(wfInstance),$(wfInstanceDate),' ') ", "ARIVIV", "char(FIBLTO)", V_FIBLTO)	
      %if (V_FIBLTO>"0")
          @CustomerUserView(profileHandle, dataBaseID, userPass, V_FIBLTO, "Y")
      %else
          @dtw_assign(userPass, "")
      %endif
  %endif
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
     	   %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
                  function submitForm(action) {document.Chg.action = action; return true;}
                  function confirmFail(text) {return confirm("$(wfFailConf)" + "\n" + "\n" + text);}
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "ARINVOICEAPPROVE")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, "Select ARIVIV.*, coalesce(FIIVAM-FISTAX-FIFRT-FISPC,0) as FISALE,  ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(a.CMCNA1,' ') as bltoCMCNA1, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(b.CMCNA1,' ') as custCMCNA1, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(LOLNA1,' ') as LOLNA1, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(LOCO#,0) as LOCO#,coalesce(LOFAC#,0) as LOFAC#, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(CFCFNM,' ') as CFCFNM, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(SMSNA1,' ') as SMSNA1, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(TMCTDS,' ') as TMCTDS ", stmtSQL)
                          @dtw_concat(stmtSQL, " From ARIVIV ", stmtSQL)
                          @dtw_concat(stmtSQL, " left join HDCUST a on a.CMCUST=FIBLTO ", stmtSQL)
                          @dtw_concat(stmtSQL, " left join HDCUST b on b.CMCUST=FICUST ", stmtSQL)
                          @dtw_concat(stmtSQL, " left join HDLCTN on LOLOC#=FILOC ", stmtSQL)
                          @dtw_concat(stmtSQL, " left join HDCFAC on (CFCO#,CFFAC#)=(LOCO#,LOFAC#) ", stmtSQL)
                          @dtw_concat(stmtSQL, " left join HDSLSM on SMSLSM=FISLSM ", stmtSQL)
                          @dtw_concat(stmtSQL, " left join HDTRMS on TMCTRM=FITRMS ", stmtSQL)
                          @dtw_concat(stmtSQL, " Where (FIINST,FIINDT,FICLOS)=($(wfInstance),$(wfInstanceDate),' ') ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Header(profileHandle, dataBaseID, stmtSQL)

                          @RtvFldDesc("(FIINST,FIINDT,FICLOS)=($(wfInstance),$(wfInstanceDate),' ') ", "ARIVIV", "char(Max(FIWITM))", V_FIWITM)	
                          @RtvFldDesc("(FIINST,FIINDT,FICLOS)=($(wfInstance),$(wfInstanceDate),' ') ", "ARIVIV", "char(Max(FIWISQ))", V_FIWISQ)	
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select ARIVDS.*,  ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(FILOC,0) as FILOC, coalesce(FIIVAM-FISTAX-FIFRT-FISPC,0) as FISALE, coalesce(FIIVCT,0) as FIIVCT, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(LOCO#,0) as LOCO#,coalesce(LOFAC#,0) as LOFAC# ", stmtSQL)
                          @dtw_concat(stmtSQL, " From ARIVDS ", stmtSQL)
                          @dtw_concat(stmtSQL, " left join ARIVIV on (FIINST,FIINDT,FIWITM,FIWISQ)=($(wfInstance),$(wfInstanceDate),$(V_FIWITM),$(V_FIWISQ)) ", stmtSQL)
                          @dtw_concat(stmtSQL, " left join HDLCTN on LOLOC#=FILOC ", stmtSQL)
                          @dtw_concat(stmtSQL, " Where (FDINST,FDINDT,FDWITM,FDWISQ)=($(wfInstance),$(wfInstanceDate),$(V_FIWITM),$(V_FIWISQ)) and FDARTY in ('S','C','I') ", stmtSQL)
                          @dtw_concat(stmtSQL, " Order By FDARTY,FDLINE ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)

                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Header (IN CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(hrTagAttr)

      @dtw_assign(errorMessage, "")
      @dtw_assign(showIconPassWith, "Y")
      @dtw_assign(showIconPassWithout, "")

      @dtw_assign(maintainVar, "$(d2wVarBase)")
      %INCLUDE "WFWorkListOptions.icl"

      %ROW {
          <table $(contentTable)>
              @Format_Code(V_FICUST, F_FICUST)
              <tr><td class="dsphdr">Ship-To Customer</td>
                  <td class="dspnmbr">$(V_custCMCNA1) $(F_FICUST)</td>
              </tr>

              @Format_Code(V_FIBLTO, F_FIBLTO)
              <tr><td class="dsphdr">Bill-To Customer</td>
                  <td class="dspnmbr">$(V_bltoCMCNA1) $(F_FIBLTO)</td>
              </tr>
	   		
              <tr><td class="dsphdr">Invoice</td>
                  <td class="dspnmbr">$(V_FIAINV)</td>
              </tr>

              @Format_Date(V_FIIVDT, "D", F_FIIVDT)
              <tr><td class="dsphdr">Invoice Date</td>
                  <td class="dspnmbr">$(F_FIIVDT)</td>
              </tr>

              @PeriodFromCYP(V_FIPER)
              <tr><td  class="dsphdr">Distribution Period</td>
                  <td class="dspnmbr">$(V_FIPER)</td>
              </tr>

              @Format_Code(V_FILOC, F_FILOC)
              @Format_CoFac("$(V_LOCO#)", "$(V_LOFAC#)", "", F_CoFac) @Format_Code(F_CoFac, F_CoFac)
              <tr><td class="dsphdr">Location</td>
                  <td class="dspnmbr">$(V_LOLNA1) $(F_FILOC)</td>
                  <td class="dsphdr">Company/Facility</td>
                  <td class="dspalph">$(V_CFCFNM) $(F_CoFac)</td>
              </tr>

              @Format_Code(V_FISLSM, F_FISLSM)
              <tr><td class="dsphdr">Salesman</td>
                  <td class="dspnmbr">$(V_SMSNA1) $(F_FISLSM)</td>
              </tr>
	   		     		
              @Format_Code(V_FITRMS, F_FITRMS)
              <tr><td class="dsphdr">Terms Code</td>
                  <td class="dspalph">$(V_TMCTDS) $(F_FITRMS)</td>
              </tr>

              <tr><td class="dsphdr">or Days Till Due</td>
                  <td class="dspalph">$(V_FICTDT)</td>
              </tr>

              @Format_Date_ISO(V_FIDUED, "D", F_FIDUED)
              <tr><td class="dsphdr">Due Date</td>
                  <td class="dspnmbr">$(F_FIDUED)</td>
              </tr>

              @Format_Date_ISO(V_FIDSCD, "D", F_FIDSCD)
              <tr><td class="dsphdr">Discount Date</td>
                  <td class="dspnmbr">$(F_FIDSCD)</td>
              </tr>

              <tr><td class="dsphdr">Discount</td>
                  <td class="dspnmbr">$(V_FIDSCT)</td>
              </tr>
              
              <tr><td class="dsphdr">Reference Number</td>
                  <td class="dspalph">$(V_FIARPO)</td>
              </tr>

              <tr><td class="dsphdr">Order Number</td>
                  <td class="dspalph">$(V_FIORD)</td>
              </tr>

              @Format_Date(V_FIORDT, "D", F_FIORDT)
              <tr><td class="dsphdr">Order Date</td>
                  <td class="dspnmbr">$(F_FIORDT)</td>
              </tr>

              <tr><td class="dsphdr">Batch</td>
                  <td class="dspalph">$(V_FIBCH)</td>
              </tr>
          </table>
	   		
          <table $(contentTable)>
              <tr><td>&nbsp;</td>
                  <td class="colhdr">Amount</td>
                  <td class="colhdr">Account</td>
                  <td class="colhdr">Description</td>
              </tr>

              @Format_Acct("$(V_FIARAC)", "$(V_FIARSB)", "", F_AcctSub)
              @RtvFldDesc("(CHACCT,CHSUB)=($(V_FIARAC),$(V_FIARSB)) ", "HDCHRT", "CHCHDS", fieldDesc)
              <tr><td class="dsphdr">Invoice</td>
                  <td class="dspnmbr">$(V_FIIVAM)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              <tr><td class="dsphdr">Cost</td>
                  <td class="dspnmbr">$(V_FIIVCT)</td>
              </tr>

              @Format_Acct("$(V_FISTXA)", "$(V_FISTXS)", "", F_AcctSub)
              @RtvFldDesc("(CHACCT,CHSUB)=($(V_FISTXA),$(V_FISTXS)) ", "HDCHRT", "CHCHDS", fieldDesc)
              <tr><td class="dsphdr">Sales Tax</td>
                  <td class="dspnmbr">$(V_FISTAX)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              @Format_Acct("$(V_FIFRTA)", "$(V_FIFRTS)", "", F_AcctSub)
              @RtvFldDesc("(CHACCT,CHSUB)=($(V_FIFRTA),$(V_FIFRTS)) ", "HDCHRT", "CHCHDS", fieldDesc)
              <tr><td class="dsphdr">Freight</td>
                  <td class="dspnmbr">$(V_FIFRT)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              @Format_Acct("$(V_FISPCA)", "$(V_FISPCS)", "", F_AcctSub)
              @RtvFldDesc("(CHACCT,CHSUB)=($(V_FISPCA),$(V_FISPCS)) ", "HDCHRT", "CHCHDS", fieldDesc)
              <tr><td class="dsphdr">Special Charge</td>
                  <td class="dspnmbr">$(V_FISPC)</td>
                  <td class="dspnmbr">$(F_AcctSub)</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>
          </table>
      %}
  %}
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(tranType, "")
		
      %ROW {
          %if (tranType != "" && tranType != V_FDARTY)
              </table>
              </fieldset>
          %endif
          %if (tranType != V_FDARTY)
              @dtw_assign(tranType, V_FDARTY)
              @RtvFldDesc("(FLTYPE,FLVALU)=('ARDISTTYPE','$(V_FDARTY)') ", "SYFLAG", "FLDESC", fieldDesc)
              %if (V_FDARTY!="Y")
                  @RtvFldDesc("(FDINST,FDINDT,FDWITM,FDWISQ,FDARTY)=($(wfInstance),$(wfInstanceDate),$(V_FIWITM),$(V_FIWISQ),'$(V_FDARTY)') ", "ARIVDS", "CHAR(SUM(FDAMT))", sumFDAMT)
                  %if (V_FDARTY=="S")
                      @dtw_subtract(V_FISALE, sumFDAMT, leftAmt)
                  %else
                      @dtw_subtract(V_FIIVCT, sumFDAMT, leftAmt)
                  %endif
                  @dtw_assign(sumFDAMT, "(Posted: $(sumFDAMT))")
                  %if (leftAmt!="0")
                      @dtw_assign(leftAmt, "(Remaining: $(leftAmt))")
                  %else
                      @dtw_assign(leftAmt, "")
                  %endif
              %endif
              <fieldset class="legendBody">
              <legend class="legendTitle">$(fieldDesc) $(sumFDAMT) $(leftAmt)</legend>
                  <table $(contentTable)>
                     <tr>
                         <td class="colhdr">Amount</td>
                         <td class="colhdr">Co/Fac</td>
                         <td class="colhdr">Account</td>
                         <td class="colhdr">Description</td>
                     </tr>
          %endif
          @RtvFldDesc("(CHACCT,CHSUB) =($(V_FDACCT),$(V_FDSACT)) ", "HDCHRT", "CHCHDS", acctDesc)
          @Format_CoFac("$(V_FDCO)", "$(V_FDFAC)", "", F_CoFac)
          @Format_Acct("$(V_FDACCT)", "$(V_FDSACT)", "", F_AcctSub)
          <tr>
              <td class="colnmbr">$(V_FDAMT)</td>
              <td class="colnmbr">$(F_CoFac)</td>
              <td class="colnmbr">$(F_AcctSub)</td>
              <td class="colalph">$(acctDesc)</td>
          </tr>
      %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_directcall) SetApprove_Data(IN    CHAR(64)    profileHandle,
                                                CHAR(2)     dataBaseID,
                                                CHAR(1)     approveCode,
                                                CHAR(32000) edtVar)
{%EXEC {HWFWIA_S.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(setFlag, "Y")
  @dtw_assign(edtVar, "")
  @Concat_Field("@@inst", wfInstance)
  @Concat_Field("@@indt", wfInstanceDate)
  @Concat_Field("@@witm", wfWorkItem)
  @Concat_Field("@@wisq", wfWorkItemSequence)
  @Concat_Field("@@ptid", wfParticipantId)
  @dtw_concat(edtVar, "}{", edtVar)
  @SetApprove_Data(profileHandle, dataBaseID, setFlag, edtVar)
  @Set_SQL(stmtSQL)
%}
