%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Vendor Terms Code Search"
  d2wName                 = "VendorTermsCodeSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function selectTermsCode(termsCode, termsDesc){
                      window.opener.document.$(docName).$(fldName).value = termsCode;
                      window.opener.document.$(docName).$(fldDesc).value = termsDesc;
                      window.opener.document.$(docName).$(fldName).focus();
                      window.close();
                  }
                  %INCLUDE "CheckEnterSearch.icl"
                  %INCLUDE "NoFormValidate.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "$(searchBanner)"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select APVTRM.*, ", stmtSQL)
                          @dtw_concat(stmtSQL, " upper(VTVTDS) as VTVTDSU ", stmtSQL)
                          @dtw_concat(fileSQL, " APVTRM ", fileSQL)
                          %if (moreInfo == "Y")
                              @dtw_concat(selectSQL, " VTRMS='$(termsCode)'", selectSQL)
                          %elseif (wildCardSearch!="")
                              @dtw_concat(selectSQL, " VTRMS<>' ' ", selectSQL)
                          %endif
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Process_Search(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "$(searchTrailer)"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Process_Search (IN  CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Description</th>
                      <th class="colhdr">Terms<br>Code</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="12" maxlength="10">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchTerm" size="5" maxlength="2">
                          <input type="hidden" name="operTerm" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("VTRMS", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TermsCode" title="Sequence By Terms Code"> Terms<br>Code</a></th>
                  @OrderBy_Sort("VTVTDSU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Name, Terms Code"> Description</a></th>
                  @OrderBy_Sort("VTDAYS", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DaysDue" title="Sequence By Days Till Due, Terms Code">Days<br>Till<br>Due</a></th>
                  @OrderBy_Sort("VTDISD", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DaysDsc" title="Sequence By Days For Discount, Terms Code">Days<br>For<br>Discount</a></th>
                  @OrderBy_Sort("VTDISP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DscPct" title="Sequence By Discount Percent, Terms Code">Discount<br>Percent</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %endif		

              %ROW{
                  %INCLUDE "SetRowClass.icl"
                  @Format_Quote(V_VTRMS, F_VTRMS)
                  @Format_Quote(V_VTVTDS, F_VTVTDS)

                  %if (moreInfo != "Y")	
                      <tr class="$(rowClass)">
                          <td class="colcode">$(V_VTRMS)</td>
                          <td class="colalph"><a href="javascript:selectTermsCode('$(F_VTRMS)','$(F_VTVTDS)')" title="Select Terms Code">$(V_VTVTDS)</a></td>
                          <td class="colnmbr">$(V_VTDAYS)</td>
                          <td class="colnmbr">$(V_VTDISD)</td>
                          <td class="colnmbr">$(V_VTDISP)</td>
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;termsCode=@dtw_rurlescseq(V_VTRMS)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                      </tr>

                  %else

                      <table $(contentTable)>
                          <tr><td><a href="javascript:selectTermsCode('$(F_VTRMS)','$(F_VTVTDS)')" title="Select Terms Code">$(selectImageLrg)</a>
                              </td>
                          </tr>

                          <tr><td class="dsphdr">Terms Code</td>
                              <td class="dspalph">$(V_VTRMS)</td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              <td class="dspalph">$(V_VTVTDS)</td></tr>

                          <tr><td class="dsphdr">Days Till Due</td>
                              <td class="dspnmbr">$(V_VTDAYS)</td></tr>	

                          <tr><td class="dsphdr">Days For Discount</td>
                              <td class="dspnmbr">$(V_VTDISD)</td></tr>

                          <tr><td class="dsphdr">Discount Percent</td>
                              <td class="dspnmbr">$(V_VTDISP)</td></tr>
                      </table>
                  %endif
              %}
      %if (moreInfo != "Y")	
          </table>
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
      %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "VTVTDSU,VTRMS")
      @DTW_ASSIGN(orderByDisplay, "Description, Terms Code")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(orderBy, "VTRMS")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "TermsCode")
      %if (orderBy == "VTRMS")
          @DTW_ASSIGN(orderBy, "VTRMS DESC")
          @DTW_ASSIGN(orderByDisplay, "Terms Code (descending)")
      %else
          @DTW_ASSIGN(orderBy, "VTRMS")
          @DTW_ASSIGN(orderByDisplay, "Terms Code")
      %endif
  %elseif (sequence == "Description")
      %if (orderBy == "VTVTDSU,VTRMS")
          @DTW_ASSIGN(orderBy, "VTVTDSU DESC,VTRMS")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Terms Code")
      %else
          @DTW_ASSIGN(orderBy, "VTVTDSU,VTRMS")
          @DTW_ASSIGN(orderByDisplay, "Description, Terms Code")
      %endif
  %elseif (sequence == "DaysDue")
      %if (orderBy == "VTDAYS,VTRMS")
          @DTW_ASSIGN(orderBy, "VTDAYS DESC,VTRMS")
          @DTW_ASSIGN(orderByDisplay, "Days Till Due (descending), Terms Code")
      %else
          @DTW_ASSIGN(orderBy, "VTDAYS,VTRMS")
          @DTW_ASSIGN(orderByDisplay, "Days Till Due, Terms Code")
      %endif
  %elseif (sequence == "DaysDsc")
      %if (orderBy == "VTDISD,VTRMS")
          @DTW_ASSIGN(orderBy, "VTDISD DESC,VTRMS")
          @DTW_ASSIGN(orderByDisplay, "Days For Discount (descending), Terms Code")
      %else
          @DTW_ASSIGN(orderBy, "VTDISD,VTRMS")
          @DTW_ASSIGN(orderByDisplay, "Days For Discount, Terms Code")
      %endif
  %elseif (sequence == "DscPct")
      %if (orderBy == "VTDISP,VTRMS")
          @DTW_ASSIGN(orderBy, "VTDISP DESC,VTRMS")
          @DTW_ASSIGN(orderByDisplay, "Discount Percent (descending), Terms Code")
      %else
          @DTW_ASSIGN(orderBy, "VTDISP,VTRMS")
          @DTW_ASSIGN(orderByDisplay, "Discount Percent, Terms Code")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "dateedit.icl"
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchDaysDue, 3, 0) &&
                      editNum(document.Search.srchDaysDsc, 3, 0) &&
                      editdate(document.Search.srchDueDate))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "termsCodesearch")
                  <td>
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Terms Code</td>
                              @dtw_assign(operNbr, "operTerm")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchTerm" size="2" maxlength="2"></td>	
                          </tr>

                          <tr><td class="dsphdr">Days Till Due</td>
                              @dtw_assign(operNbr, "operDaysDue")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchDaysDue" size="3" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Days For Discount</td>
                              @dtw_assign(operNbr, "operDaysDsc")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchDaysDsc" size="3" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Due Date</td>
                              @dtw_assign(operNbr, "operDueDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchDueDate" size="6" maxlength="6"><a href="javascript:calWindow('srchDueDate');">$(calendarImage)</a></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDesc.focus();
                          </script>
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("upper(VTVTDS)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("VTRMS", "Terms Code", $(srchTerm), "U", operTerm, "A")
  @Build_WildCard ("VTDAYS", "Days Till Due", $(srchDaysDue), "", operDaysDue, "N")
  @Build_WildCard ("VTDISD", "Days For Discount", $(srchDaysDsc), "", operDaysDsc, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
