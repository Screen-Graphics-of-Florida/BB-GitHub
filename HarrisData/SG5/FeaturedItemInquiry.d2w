%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Product Configuration Inquiry"
  d2wName                 = "FeaturedItemInquiry.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;featuredItem=@dtw_rurlescseq(featuredItem)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "1000"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "1000"
  prtMaxRows              = "1000"
  rowIndexNext            = "1"
  totalPages              = "0"
  imageExists             = ""
  itemNumber              = ""
  itemDesc                = ""
  mandatory               = ""
  allowMultiple           = ""
  variableQty             = ""
  popUpWin                = "Y"
  displayCloseIcon        = "Y"
%}
	
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">

                      @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                      @dtw_assign(SAVE_MAX_ROWS, RPT_MAX_ROWS)
                      @dtw_assign(START_ROW_NUM, "1")
                      @dtw_assign(RPT_MAX_ROWS, "9999")
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select FIFEAT, FIIMQT, FIVARQ, FIMAND, FINS, FIMULT, FIFDSC ", stmtSQL)
                      @dtw_concat(fileSQL, " HDMFIT left join HDIGPD on 'F'=DGTYPE and FIFPRT=DGIGRP and FIPLT=DGPLT ", fileSQL)
                      @dtw_concat(selectSQL, " FIPLT=$(plantNumber) and (FIFPRT='$(featuredItem)' or DGITEM='$(featuredItem)') ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      @Link_Query(profileHandle, dataBaseID, stmtSQL)
                      @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                      @dtw_assign(RPT_MAX_ROWS, SAVE_MAX_ROWS)

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select FIFEAT,FIFDSC as WKDESC,FIIMQT,FIVARQ,FIMAND,FINS,FIMULT,", stmtSQL)
                      @dtw_concat(stmtSQL, " ' ' as FOOPTN,0.00000 as FOXCHG,' ' as FOXFLG,' ' as FODFLT,", stmtSQL)
                      @dtw_concat(stmtSQL, " ' ' as WKBLVL,' ' as WKBLDS,' ' as WKBLDF", stmtSQL)
                      @dtw_concat(stmtSQL, " From HDMFIT left join HDIGPD on 'F'=DGTYPE and FIFPRT=DGIGRP and FIPLT=DGPLT ", stmtSQL)
                      @dtw_concat(stmtSQL, " Where FIPLT=$(plantNumber) and (FIFPRT='$(featuredItem)' or DGITEM='$(featuredItem)') ", stmtSQL)

                      @dtw_concat(stmtSQL, " Union All ", stmtSQL)
                      @dtw_concat(stmtSQL, " Select FIFEAT,FOODSC as WKDESC,0.0000 as FIIMQT,' ' as FIVARQ,' ' as FIMAND,' ' as FINS,' ' as FIMULT,", stmtSQL)
                      @dtw_concat(stmtSQL, " FOOPTN,FOXCHG,FOXFLG,FODFLT,", stmtSQL)
                      @dtw_concat(stmtSQL, " ' ' as WKBLVL,' ' as WKBLDS,' ' as WKBLDF", stmtSQL)
                      @dtw_concat(stmtSQL, " From HDMFIT a left join HDIGPD on 'F'=DGTYPE and FIFPRT=DGIGRP and FIPLT=DGPLT ", stmtSQL)
                      @dtw_concat(stmtSQL, " join HDMFOP b on FIPLT=FOPLT and FIFEAT=FOFEAT and ' '=FOBLOP", stmtSQL)
                      @dtw_concat(stmtSQL, " Where FIPLT=$(plantNumber) and (FIFPRT='$(featuredItem)' or DGITEM='$(featuredItem)')", stmtSQL)
                      @dtw_concat(stmtSQL, " and b.FOFPRT=(Select coalesce(max(c.FOFPRT),' ')", stmtSQL)
                      @dtw_concat(stmtSQL,               " From HDMFOP c left join HDIGPD e on 'F'=e.DGTYPE and c.FOFPRT=e.DGIGRP and c.FOPLT=e.DGPLT", stmtSQL)
                      @dtw_concat(stmtSQL,               " Where c.FOPLT=$(plantNumber) and c.FOFEAT=a.FIFEAT and (c.FOFPRT='$(featuredItem)' or e.DGITEM='$(featuredItem)'))", stmtSQL)

                      @dtw_concat(stmtSQL, " Union All ", stmtSQL)
                      @dtw_concat(stmtSQL, " Select FIFEAT,c.FOODSC as WKDESC,0.0000 as FIIMQT,' ' as FIVARQ,' ' as FIMAND,' ' as FINS,' ' as FIMULT,", stmtSQL)
                      @dtw_concat(stmtSQL, " c.FOOPTN,c.FOXCHG,c.FOXFLG,c.FODFLT,", stmtSQL)
                      @dtw_concat(stmtSQL, " b.FOOPTN as WKBLVL,b.FOODSC as WKBLDS,b.FODFLT as WKBLDF", stmtSQL)
                      @dtw_concat(stmtSQL, " From HDMFIT a left join HDIGPD on 'F'=DGTYPE and FIFPRT=DGIGRP and FIPLT=DGPLT ", stmtSQL)
                      @dtw_concat(stmtSQL, " join HDMFOP b on FIPLT=b.FOPLT and FIFEAT=b.FOFEAT and 'Y'=b.FOBLOP", stmtSQL)
                      @dtw_concat(stmtSQL, " left join HDMFOP c on FIPLT=c.FOPLT and b.FOOPTN=c.FOFEAT and b.FOFPRT=c.FOFPRT", stmtSQL)
                      @dtw_concat(stmtSQL, " Where FIPLT=$(plantNumber) and (FIFPRT='$(featuredItem)' or DGITEM='$(featuredItem)')", stmtSQL)
                      @dtw_concat(stmtSQL, " and b.FOFPRT=(Select coalesce(max(d.FOFPRT),' ')", stmtSQL)
                      @dtw_concat(stmtSQL,               " From HDMFOP d left join HDIGPD f on 'F'=f.DGTYPE and d.FOFPRT=f.DGIGRP and d.FOPLT=f.DGPLT", stmtSQL)
                      @dtw_concat(stmtSQL,               " Where d.FOPLT=$(plantNumber) and d.FOFEAT=a.FIFEAT and (d.FOFPRT='$(featuredItem)' or f.DGITEM='$(featuredItem)'))", stmtSQL)

                      @dtw_concat(stmtSQL, " Order by FIFEAT,WKBLVL,FOOPTN", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Feature_Item_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Link_Query (IN CHAR(64)    profileHandle,
                                  CHAR(2)     dataBaseID,
                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="top"></a>
      <table $(contentTable)>
  	       <colgroup>
  	           <col width="80%">
  	           <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  <a href="$(homeURL)$(cGIPath)FeatureRoutingInquiry.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(featuredItem)&amp;fromD2W=@dtw_rurlescseq(d2wName)" onclick="$(inquiryWinVar)">$(featRtgImageLrg)</a>
                  %INCLUDE "HelpPage.icl"
                  %if (displayCloseIcon == "Y")
                      &nbsp;<a href="javascript:window.close()">$(closeImageMed)</a>
                  %endif
              </td>
          </tr>
      </table>

      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      @RtvFldDesc("IMITEM='$(featuredItem)'", "HDIMST", "IMIMDS", itemDescription)
      <table $(contentTable)>
          @Format_Header("Plant", $(plantName), $(plantNumber))
          @Format_Header("Item", $(itemDescription), $(featuredItem))
      </table>

      $(inquiryhrTagAttr)

      <table $(contentTable)>
          <tr>
              <th class="colhdr">Feature</th>
              <th class="colhdr">Quantity</th>
              <th class="colhdr">Variable</th>
              <th class="colhdr">Mandatory</th>
              <th class="colhdr">N/S</th>
              <th class="colhdr">Multiple</th>
          </tr>

      %ROW{
          @Format_Nbr($(V_FIIMQT), F_FIIMQT, $(qtyNbrDec), $(qtyEditCode), "", "", "")
          <tr>
              <td class="dspalph"><a href="#$(V_FIFEAT)">$(V_FIFDSC)</a></td>
              <td class="colnmbr">$(F_FIIMQT)</td>
              <td class="colcode">$(V_FIVARQ)</td>
              <td class="colcode">$(V_FIMAND)</td>
              <td class="colcode">$(V_FINS)</td>
              <td class="colcode">$(V_FIMULT)</td>
          </tr>
      %}
      </table>
  %}
%}

%FUNCTION(dtw_sql) Feature_Item_Query (IN  CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      @dtw_assign(saveFeature, "")
		
      %ROW{
          %if (saveFeature != "" && saveFeature != V_FIFEAT)
              %if (noOptions == "Y")
                  No Options Found
                  </td></tr>
              %else
                  %if (saveBiLevel != "" && V_WKBLVL != "")
                      </td></tr>
                  %endif
                  </table>
                  %if (saveBiLevel != "")
                      </fieldset>
                  %endif
              %endif
              </table>
              </fieldset>
          %endif
          %if (saveFeature != V_FIFEAT)
              @dtw_assign(mandatory, V_FIMAND)
              %if (mandatory == "Y")
                  @dtw_assign(reqField, $(reqFieldChar))
              %else
                  @dtw_assign(reqField, "")
              %endif
              @dtw_assign(allowMultiple, V_FIMULT)
              @dtw_assign(variableQty, V_FIVARQ)
              @dtw_assign(saveFeature, V_FIFEAT)
              <a name="$(V_FIFEAT)"></a>
              <fieldset class="legendBodyFO">
              <legend class="legendTitleFO">$(V_WKDESC) $(reqField)</legend>
              <table $(contentTable)>
                  <colgroup>
                      <col width="90%">
                      <col width="10%">
                  <tr>
                      <td>&nbsp;</td>
                      <td><a href="#top">$(topOfFormImage)</a> <a href="#bottom">$(botOfFormImage)</a></td>
                  </tr>
                  @dtw_assign(saveBiLevel, "beginNewLevel")
                  @dtw_assign(noOptions, "Y")
                  <tr><td>
          %else
              %if (saveBiLevel != V_WKBLVL)
                  %if (saveBiLevel != "beginNewLevel")
                      </table>
                      %if (saveBiLevel != "")
                          </fieldset>
                      %endif
                  %endif
                  @dtw_assign(saveBiLevel, V_WKBLVL)
                  %if (saveBiLevel != "")
                      <fieldset class="legendSubBodyFO">
                      <legend class="legendSubTitleFO">$(V_WKBLDS)</legend>
                  %endif
                  <table $(contentTable)>
                      <colgroup>
                          <col width="10%">
                          <col width="30%">
                          <col width="25%">
                          <col width="25%">
                          <col width="10%">
                      <tr><td>&nbsp;</td>
                          <td>&nbsp;</td>
                          <td class="colnmbr">Extra Charge</td>
                          <td class="colcode">Default</td>
                      </tr>
                      <tr><td>
              %endif

              @dtw_assign(noOptions, "")
              <tr>
                  @Check_Item_Comments(profileHandle, dataBaseID, V_FOOPTN, "", customerNumber, "WEB", headerTrailer, itemComments)
                  @dtw_assign(itemImage, "$(V_FOOPTN)$(itemImageExt)")
                  @dtwf_exists(itemImage, imageExists)
                  <td class="colicon">
                      %if (imageExists == "Y")
                          <a href="$(homeURL)$(cGIPath)ImageDisplay.d2w/DISPLAY$(genericVarBase)&amp;imageDisplayPath=$(homeURL)$(itemImage)&amp;imageDesc=@dtw_rurlescseq(V_WKDESC)" onclick="$(itemImageWinVar)">$(foundImage)</a>
                      %endif
                      @dtw_assign(commentVar, "$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(V_FOOPTN)&amp;vendCustItemNumber=&amp;itemDesc=@dtw_rurlescseq(V_WKDESC)&amp;vendCustNumber=@dtw_rurlescseq(customerNumber)&amp;vendCustFlag=C")
                      %if (itemComments == "Y")
                          <a href="$(homeURL)$(cGIPath)ItemComments.d2w/REPORT$(commentVar)" onclick="$(commentWinVar)">$(commentExistImage)</a>
                      %elif (itemComments != "")
                          <a href="$(homeURL)$(cGIPath)VendCustItemComments.d2w/REPORT$(commentVar)" onclick="$(commentWinVar)">$(commentExistImage)</a>
                      %endif
                  </td>
                  <td class="colalph">$(V_WKDESC)</td>
                  @Format_Nbr(V_FOXCHG, F_FOXCHG, "5", "4", "Y", "$", "")
                  <td class="colnmbr">$(F_FOXCHG)</td>
                  <td class="colcode">
                      %if ((V_WKBLVL == "" && V_FODFLT == "Y") || (V_WKBLVL != " " && V_WKBLDF == "Y" && V_FODFLT == "Y"))
                          $(V_FODFLT)
                      %else
                          &nbsp;
                      %endif
                  </td>
              </tr>
          %endif
      %}
      </table>
      %if (noOptions == "Y")
         No Options Found
      %else
          %if (saveBiLevel != "")
              </fieldset>
          %endif
          </table>
      %endif
      </fieldset>
      <a name="bottom"></a>
      $(inquiryhrTagAttr)
      %INCLUDE "CloseWindow.icl"
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}
