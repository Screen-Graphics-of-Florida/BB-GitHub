%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"

%Define {	
  page_title              = "Salesman Inquiry"
  d2wName                 = "SalesmanInquiry.d2w"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
%}
	
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onLoad="window.focus()" onBlur="window.close()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " HDSLSM ", fileSQL)
                      @dtw_concat(selectSQL, "SMSLSM=$(salesmanNumber) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By SMSLSM ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Display_Inquiry(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Display_Inquiry (IN CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"

      $(inquiryhrTagAttr)

      <table $(contentTable)>
          %ROW{
              @EditPhoneNumber(V_SMPHON)
              <tr><td class="dsphdr">Salesman Number</td>
                  <td class="dspalph">$(V_SMSLSM)</td></tr>

              <tr><td class="dsphdr">Salesman Name</td>
                  <td class="dspalph">$(V_SMSNA1)</td></tr>

              <tr><td class="dsphdr">Address</td>
                  <td class="dspalph">$(V_SMSNA2)</td></tr>	

              %if (V_SMSNA3 != "")
                  <tr><td class="dsphdr"></td>
                      <td class="dspalph">$(V_SMSNA3)</td></tr>	
              %endif

              %if (V_SMSNA4 != "")
                  <tr><td class="dsphdr"></td>
                      <td class="dspalph">$(V_SMSNA4)</td></tr>	
              %endif

              <tr><td class="dsphdr">City</td>
                  <td class="dspalph">$(V_SMSCTY)</td></tr>

              @RtvFldDesc("STID='$(V_SMST)'", "HDSTID", "STDESC", fieldDesc)
              <tr><td class="dsphdr">State</td>
                  <td class="dspalph">$(fieldDesc)</td></tr>

              <tr><td class="dsphdr">Zip</td>
                  <td class="dspalph">$(V_SMZIP)</td></tr>

              <tr><td class="dsphdr">Phone Number</td>
                  <td class="dspnmbr">$(V_SMPHON)</td></tr>

              @RtvFldDesc("CNCTCD='$(V_SMCTRY)'", "HDCTRY", "CNCDES", fieldDesc)
              <tr><td class="dsphdr">Country</td>
                  <td class="dspalph">$(fieldDesc)</td></tr>

              @RtvFldDesc("RGCRGN='$(V_SMREGN)'", "HDCRGN", "RGCRDS", fieldDesc)
              <tr><td class="dsphdr">Region</td>
                  <td class="dspalph">$(fieldDesc)</td></tr>
          %}
      </table>
      $(inquiryhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}