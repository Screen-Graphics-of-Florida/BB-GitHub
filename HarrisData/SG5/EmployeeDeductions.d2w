%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title 		= "Employee Deductions"
  d2wName              = "EmployeeDeductions.d2w"
  d2wVarBase           = "$(genericVarBase)$(employeeVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(d2wName)"
  nextPrevVar          = "$(d2wVarBase)"
  programName          = "HHREDM"
  wildDftVar           = "REPORT$(d2wVarBase)"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  DTW_PAD_PGM_PARMS    = "YES"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext		= "1"
  totalPages		= "0"	
  advanceSearch           = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
  @dtw_replace(workURL, "@@fromD2w", "@dtw_rurlescseq(fromD2w)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterSearch.icl"
                  %INCLUDE "Menu.js"
                  %INCLUDE "NoFormValidate.icl"
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "EMPLDEDUCTIONS")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select EDCOMP, EDFACL, EDEMPL, EDDDNO, EDAMT, EDPCT, EDMTHD, EDLIMT, EDACUM, EDITD, EDYTD, EDEFDT, EDEXDT, HVDDNM, ", stmtSQL)
                          @dtw_concat(stmtSQL, " HVPRTY, HVCYCL, upper(HVDDNM) as HVDDNMU", stmtSQL)
                          @dtw_concat(fileSQL, " HREDED inner join HRDEDM on EDDDNO=HVDDNO  ", fileSQL)
                          @dtw_concat(selectSQL, "EDCOMP=$(prCompany) and EDFACL=$(prFacility) and EDEMPL=$(prEmployee) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @EmplDeductions_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) EmplDeductions_Query (IN CHAR(64)    profileHandle,
				             CHAR(2)     dataBaseID,
                                            CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
          @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
          @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMTYPE", PAYTYPECODE)
          %if ((sec_06 == "N" && PAYTYPECODE == "H") || (sec_07 == "N" && PAYTYPECODE != "H"))
              @dtw_assign(sec_01, "")
              @dtw_assign(sec_02, "")
              @dtw_assign(sec_03, "")
              @dtw_assign(sec_04, "")
          %endif
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="BackHome">$(portalHome)</a>
                          %endif
                          %if (sec_01 == "Y")
                              <a href="$(homeURL)$(cGIPath)EmplMaintainDed.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                          %endif
                          <a href="$(homeURL)$(cGIPath)EmployeeMaintainSelect.d2w/REPORT$(d2wVarBase)">$(emplMaintImage)</a>
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>

              @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
              <tr><td><h2>$(F_EmpName)</h2></td></tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"	
          $(hrTagAttr)	

              %if (formatToPrint != "Y")
                  <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                      <table $(quickSearchTable)>
                          <tr><th class="colhdr">Deduction<br>Name</th>
                              <th class="colhdr">Deduction<br>Number</th>
                          </tr>
                          <tr><td><input type="text" class="inputalph" name="srchName" size="20" maxlength="20">
                                  <input type="hidden" name="operName" value="LIKE">
                              </td>
                              <td><input type="text" class="inputnmbr" name="srchNumber" size="3" maxlength="3">
                                  <input type="hidden" name="operNumber" value="=">
                              </td>
                              <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                          </tr>
                      </table>
                      <script TYPE="text/javascript">
                          document.Search.srchName.focus();
                      </script>
                  </form>

                  %INCLUDE "WildCardPage.icl"
              %endif
          <table $(contentTable)>
              <tr>
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("EDDDNO", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Deduction" title="Sequence By Deduction Number">Deduction<br>Number</a></th>
                  @OrderBy_Sort("HVDDNM", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Name" title="Sequence By Deduction Name">Deduction<br>Name</a></th>
    	           <th class="colhdr">Calculation<br>Method</th>
     	           <th class="colhdr">Priority</th>    	
    	           <th class="colhdr">Cycle</th>    	              	
                  <th class="colhdr">Deduction<br>Amt/Pct</th>
                  %if ((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_07 == "Y"))
                      <th class="colhdr">Year To Date</th>
    	           <th class="colhdr">Inception To Date</th>
                  %endif
    	           <th class="colhdr">Limit</th>
    	           <th class="colhdr">Effective<br>Date</th>
                  <th class="colhdr">Expiration<br>Date</th>
    	           <th class="colhdr">Accumulated<br>Amount Due</th>
              </tr>		
          %INCLUDE "NoRecordsFound.icl"
      %ROW{
              @Format_Date(V_EDEFDT, "D", F_EDEFDT)
              @Format_Date(V_EDEXDT, "D", F_EDEXDT)
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_PRDESC), "", $(V_ODDESC), $(V_EDDDNO), "", "", confirmDesc)
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;deductionNumber=@dtw_rurlescseq(V_EDDDNO)")
	       <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)EmplMaintainDed.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)EmplMaintainDed.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)EmplMaintainDed.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
    	           <td class="colcode">$(V_EDDDNO)</td>

                  <td class="colalph"><a href="$(homeURL)$(cGIPath)EmployeeDedSelect.d2w/report$(d2wVarBase)&amp;deductionNumber=@dtw_rurlescseq(V_EDDDNO)" title="View Deduction">$(V_HVDDNM)</a></td>
                  @dtw_assign(cMethod,$(V_EDMTHD))
                  %while(@dtw_rlength(cMethod) != "2") {@dtw_insert("0", cMethod, cMethod)%}
 	              @RtvFldDesc("FLTYPE='DEDCALCMTH' and FLVALU='$(cMethod)'", "SYFLAG", "FLDESC", fieldDesc) 	
    	          <td class="colcode" $(helpCursor)><span title="$(fieldDesc)">$(V_EDMTHD)</td>    	
    	          <td class="colnmbr">$(V_HVPRTY)</td>
    	          <td class="colnmbr">$(V_HVCYCL)</td>                      	              	
    	
                  %if (V_EDAMT > ".00")
                      @Format_Nbr($(V_EDAMT), F_EDAMT, "2", $(amtEditCode), "", "$", "")
    	               <td class="colnmbr">$(F_EDAMT)</td>
                  %else
                      @Format_Nbr("@dtw_rmultiply(V_EDPCT, "100")", F_EDPCT, "3", $(pctEditCode), "", "", "%")
    	               <td class="colnmbr">$(F_EDPCT)</td>
                  %endif
                  %if ((PAYTYPECODE == "H" && sec_06 == "Y") || (PAYTYPECODE != "H" && sec_07 == "Y"))
                      @Format_Nbr($(V_EDYTD), F_EDYTD, "2", $(amtEditCode), "", "", "")
    	               <td class="colnmbr">$(F_EDYTD)</td>
                      @Format_Nbr($(V_EDITD), F_EDITD, "2", $(amtEditCode), "", "", "")
    	               <td class="colnmbr">$(F_EDITD)</td>
                  %endif
                  @Format_Nbr($(V_EDLIMT), F_EDLIMT, "2", $(amtEditCode), "", "", "")
    	           <td class="colnmbr">$(F_EDLIMT)</td>
    	           <td class="coldate">$(F_EDEFDT)</td>
    	           <td class="coldate">$(F_EDEXDT)</td>
                  @Format_Nbr($(V_EDACUM), F_EDACUM, "2", $(amtEditCode), "", "", "")
    	           <td class="colnmbr">$(F_EDACUM)</td>
	       </tr>
	   %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "HVDDNMU")
              @DTW_ASSIGN(orderByDisplay, "Deduction Name")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Deduction")
      %if (orderBy == "EDDDNO")
          @DTW_ASSIGN(orderBy, "EDDDNO DESC")
          @DTW_ASSIGN(orderByDisplay, "Deduction Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "EDDDNO")
          @DTW_ASSIGN(orderByDisplay, "Deduction Number")
      %endif
  %elif (sequence == "Name")
      %if (orderBy == "HVDDNMU")
          @DTW_ASSIGN(orderBy, "HVDDNMU DESC")
          @DTW_ASSIGN(orderByDisplay, "Deduction Name (descending)")
      %else
          @DTW_ASSIGN(orderBy, "HVDDNMU")
          @DTW_ASSIGN(orderByDisplay, "Deduction Name")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("upper(HVDDNM)", "Deduction Name", $(srchName), "U", operName, "A")
  @Build_WildCard ("EDDDNO", "Deduction Number", $(srchNumber), "", operNumber, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}