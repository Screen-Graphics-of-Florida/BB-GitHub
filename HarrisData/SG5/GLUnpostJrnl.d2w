%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Unposted Journal"
  d2wName                 = "GLUnpostJrnl.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  noMsg                   = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "DateEdit.icl"
              %INCLUDE "Menu.js"
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchPeriod, 4, 0) &&
                      editdate(document.Search.srchDate))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "GLUNPOSTJRNL")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select GLTRJL.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(a.FLDESC,' ') as statusFLDESC, upper(coalesce(a.FLDESC,' ')) as statusFLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(b.FLDESC,' ') as transFLDESC, upper(coalesce(b.FLDESC,' ')) as transFLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(USDESC,' ') as USDESC, coalesce(USDESCU,' ') as USDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " GLTRJL ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG a on a.FLTYPE='GLTRANSTAT' and a.FLVALU=TJSTAT ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG b on b.FLTYPE='GLTRANTYP' and b.FLVALU=TJTTYP ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYUSER on USUSER=TJUSER ", fileSQL)
                      @dtw_concat(selectSQL, "TJSTAT<>'P' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64) profileHandle,
                                   CHAR(2)   dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      $(hrTagAttr)

      %if (formatToPrint == "")
          <form class="formClass" METHOD=POST name="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Journal</th>
                      <th class="colhdr">Type</th>
                      <th class="colhdr">Period</th>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">Date</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchJrnl" size="6" maxlength="6">
                          <input type="hidden" name="operJrnl" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchType" size="2" maxlength="2">
                          <input type="hidden" name="operType" value="LIKE">
                      </td>
                      <td><input type="text" class="inputnmbr"  name="srchPeriod" size="4" maxlength="4">
                          <input type="hidden" name="operPeriod" value="=">
                      </td>
                      <td><input type="text" class="inputalph" name="srchDesc" size="20" maxlength="20">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputnmbr"  name="srchDate" size="6" maxlength="6">
                          <input type="hidden" name="operDate" value="=">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchJrnl.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
     %endif

      <table $(contentTable)>
          <tr>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("TJPER#", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Period" title="Sequence By Period, Date, Journal">Period</a></th>
              @OrderBy_Sort("TJJRNL", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Journal" title="Sequence By Journal, Date">Journal</a></th>
              @OrderBy_Sort("TJDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Description, Date, Journal">Description</a></th>
              @OrderBy_Sort("TJTDTE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Date" title="Sequence By Date, Journal">Transaction Date</a></th>
              @OrderBy_Sort("statusFLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Status" title="Sequence By Status, Date, Journal">Status</a></th>
              @OrderBy_Sort("transFLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Type" title="Sequence By Transaction Type, Date, Journal">Transaction Type</a></th>
              @OrderBy_Sort("USDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=User" title="Sequence By User, Date, Journal">User</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"

              @dtw_assign(F_TJPER#, V_TJPER#)
              @PeriodFromCYP(F_TJPER#)
              @Format_Date(V_TJTDTE, "D", F_TJTDTE)
              <tr class="$(rowClass)">
                  <td class="colnmbr">$(F_TJPER#)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)GLDDGLJrnl.d2w/ENTRY$(genericVarBase)&amp;glJrnl=@dtw_rurlescseq(V_TJJRNL)&amp;glPer=@dtw_rurlescseq(V_TJPER#)&amp;glDate=@dtw_rurlescseq(V_TJTDTE)&amp;glJrnlSeq=@dtw_rurlescseq(V_TJJSEQ)" onclick="$(drillDownWinVar)" title="View General Ledger Journal">$(V_TJJRNL)</a></td>
                  <td class="colalph">$(V_TJDESC)</td>
                  <td class="colnmbr">$(F_TJTDTE)</td>
                  <td class="colalph" $(helpCursor)><span title="$(V_TJSTAT)">$(V_statusFLDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_TJTTYP)">$(V_transFLDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_TJUSER)">$(V_USDESC)</span></td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select GLTRJL.*, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(a.FLDESC,' ') as statusFLDESC, upper(coalesce(a.FLDESC,' ')) as statusFLDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(b.FLDESC,' ') as transFLDESC, upper(coalesce(b.FLDESC,' ')) as transFLDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(USDESC,' ') as USDESC, coalesce(USDESCU,' ') as USDESCU ", stmtSQL)
  @dtw_concat(fileSQL, " GLTRJL ", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG a on a.FLTYPE='GLTRANSTAT' and a.FLVALU=TJSTAT ", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG b on b.FLTYPE='GLTRANTYP' and b.FLVALU=TJTTYP ", fileSQL)
  @dtw_concat(fileSQL, " left join SYUSER on USUSER=TJUSER ", fileSQL)
  @dtw_concat(selectSQL, "TJSTAT<>'P' ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_XMLQuery (IN  CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("UnpostJournalList")
          %ROW{
              @EditPhoneNumber(V_CMPHON)

              @XMLIDTag("$(V_TJJRNL)-$(V_TJPER#)-$(V_TJTDTE)-$(V_TJJSEQ)", "UnpostJournal ID")
                  @XMLTag(V_TJJRNL, "Journal")
                  @XMLTag(V_TJPER#, "Period")
                  @XMLTag(V_TJTDTE, "TransactionDate")
                  @XMLTag(V_TJJSEQ, "JournalSequenceNumber")
                  @XMLTag(V_TJTTYP, "TransactionType")
                  @XMLTag(V_TJYEND, "YearEndJournal")
                  @XMLTag(V_TJFCUR, "CurrencyType")
                  @XMLTag(V_TJSTAT, "Status")
                  @XMLTag(V_TJDESC, "Description")
                  @XMLTag(V_TJHMS,  "TimeUpdated")
                  @XMLTag(V_TJMDY,  "DateUpdated")
                  @XMLTag(V_TJUSER, "UserProfile")
                  @XMLTag(V_TJWSID, "Workstation")
              @XMLEndTag("UnpostJournal")
          %}
      @XMLEndTag("UnpostJournalList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "TJPER#,TJTDTE,TJJRNL,TJJSEQ")
          @DTW_ASSIGN(orderByDisplay, "Period, Date, Journal")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Period")
      %if (orderBy == "TJPER#,TJTDTE,TJJRNL,TJJSEQ")
          @DTW_ASSIGN(orderBy, "TJPER# DESC,TJTDTE DESC,TJJRNL,TJJSEQ")
          @DTW_ASSIGN(orderByDisplay, "Period (descending), Date (descending), Journal")
      %else
          @DTW_ASSIGN(orderBy, "TJPER#,TJTDTE,TJJRNL,TJJSEQ")
          @DTW_ASSIGN(orderByDisplay, "Period, Date, Journal")
      %endif
  %elif (sequence == "Journal")
      %if (orderBy == "TJJRNL,TJTDTE,TJJSEQ")
          @DTW_ASSIGN(orderBy, "TJJRNL DESC,TJTDTE DESC,TJJSEQ")
          @DTW_ASSIGN(orderByDisplay, "Journal (descending), Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "TJJRNL,TJTDTE,TJJSEQ")
          @DTW_ASSIGN(orderByDisplay, "Journal, Date")
      %endif
  %elif (sequence == "Description")
      %if (orderBy == "TJDESCU,TJTDTE,TJJRNL,TJJSEQ")
          @DTW_ASSIGN(orderBy, "TJDESCU DESC,TJTDTE DESC,TJJRNL,TJJSEQ")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Date (descending), Journal")
      %else
          @DTW_ASSIGN(orderBy, "TJDESCU,TJTDTE,TJJRNL,TJJSEQ")
          @DTW_ASSIGN(orderByDisplay, "Description, Date, Journal")
      %endif
  %elif (sequence == "Date")
      %if (orderBy == "TJTDTE,TJJRNL,TJJSEQ")
          @DTW_ASSIGN(orderBy, "TJTDTE DESC,TJJRNL,TJJSEQ")
          @DTW_ASSIGN(orderByDisplay, "Date (descending), Journal")
      %else
          @DTW_ASSIGN(orderBy, "TJTDTE,TJJRNL,TJJSEQ")
          @DTW_ASSIGN(orderByDisplay, "Date, Journal")
      %endif
  %elif (sequence == "Status")
      %if (orderBy == "statusFLDESCU,TJTDTE,TJJRNL,TJJSEQ")
          @DTW_ASSIGN(orderBy, "statusFLDESCU DESC,TJTDTE DESC,TJJRNL,TJJSEQ")
          @DTW_ASSIGN(orderByDisplay, "Status (descending), Date (descending), Journal")
      %else
          @DTW_ASSIGN(orderBy, "statusFLDESCU,TJTDTE,TJJRNL,TJJSEQ")
          @DTW_ASSIGN(orderByDisplay, "Status, Date, Journal")
      %endif
  %elif (sequence == "Type")
      %if (orderBy == "transFLDESCU,TJTDTE,TJJRNL,TJJSEQ")
          @DTW_ASSIGN(orderBy, "transFLDESCU DESC,TJTDTE DESC,TJJRNL,TJJSEQ")
          @DTW_ASSIGN(orderByDisplay, "Transaction Type (descending), Date (descending), Journal")
      %else
          @DTW_ASSIGN(orderBy, "transFLDESCU,TJTDTE,TJJRNL,TJJSEQ")
          @DTW_ASSIGN(orderByDisplay, "Transaction Type, Date, Journal")
      %endif
  %elif (sequence == "User")
      %if (orderBy == "USDESCU,TJTDTE,TJJRNL,TJJSEQ")
          @DTW_ASSIGN(orderBy, "USDESCU DESC,TJTDTE DESC,TJJRNL,TJJSEQ")
          @DTW_ASSIGN(orderByDisplay, "User (descending), Date (descending), Journal")
      %else
          @DTW_ASSIGN(orderBy, "USDESCU,TJTDTE,TJJRNL,TJJSEQ")
          @DTW_ASSIGN(orderByDisplay, "User, Date, Journal")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          @dtw_assign(formName, "Search")
          %INCLUDE "$(headInclude)"
          <link rel=stylesheet type="text/css" href="$(homeURL)$(homePath)$(GLDDStyleSheet)">
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchPeriod, 4, 0) &&
                      editdate(document.Search.srchDate))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "GLUNPOSTJRNLSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Period</td>
                              @dtw_assign(operNbr, "operPeriod")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchPeriod" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Journal</td>
                              @dtw_assign(operNbr, "operJrnl")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchJrnl" size="6" maxlength="6"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Transaction Date</td>
                              @dtw_assign(operNbr, "operDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchDate" size="6" maxlength="6"><a href="javascript:calWindow('srchDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Status</td>
                              @dtw_assign(operNbr, "operStatus")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchStatus" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">User</td>
                              @dtw_assign(operNbr, "operUser")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchUser" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Transaction Type</td>
                              @dtw_assign(operNbr, "operType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchType" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Year End Journal</td>
                              @dtw_assign(operNbr, "operYrEnd")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchYrEnd" size="1" maxlength="1"></td>
                          </tr>

                          %if (V_HDMCRL>"0")
                              <tr><td class="dsphdr">Currency Type</td>
                                  @dtw_assign(operNbr, "operCurrency")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchCurrency" size="3" maxlength="3"></td>
                              </tr>
                          %endif

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchPeriod.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("TJPER#", "Period", $(srchPeriod), "", operPeriod, "DP")
  @Build_WildCard ("TJJRNL", "Journal", $(srchJrnl), "U", operJrnl, "A")
  @Build_WildCard ("TJDESCU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("TJTDTE", "Transaction Date", $(srchDate), "", operDate, "D")
  @Build_WildCard ("upper(coalesce(a.FLDESC,' '))", "Status", $(srchStatus), "U", operStatus, "A")
  @Build_WildCard ("coalesce(USDESCU,' ')", "User", $(srchUser), "U", operUser, "A")
  @Build_WildCard ("upper(coalesce(b.FLDESC,' '))", "Transaction Type", $(srchType), "U", operType, "A")
  @Build_WildCard ("TJYEND", "Year End Journal", $(srchYrEnd), "U", operYrEnd, "A")
  @Build_WildCard ("TJFCUR", "Currency Type", $(srchCurrency), "U", operCurrency, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}