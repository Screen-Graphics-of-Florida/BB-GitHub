%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Event"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  dspMaxRows              = "$(dspMaxRowsDft)"
  RPT_MAX_ROWS            = "1000"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
  contactCustomer	   = "0"	
  fileName                = "CRCEVU"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              function gotosite(site) {
                  if (site != "") {
                      self.location=site;
                  }
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- Start Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "EVENT")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " CRCEVM ", fileSQL)
                          @dtw_concat(selectSQL, "EMUSER='$(userProfile)' and EMCMPD<>'0001-01-01' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By EMEVTD, EMEVTT ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Customer_Event_Query(profileHandle, dataBaseID, stmtSQL)

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " SRCEVM ", fileSQL)
                          @dtw_concat(selectSQL, "RMUSER='$(userProfile)' and RMCMPD<>'0001-01-01' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By RMEVTD, RMEVTT ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Supplier_Event_Query(profileHandle, dataBaseID, stmtSQL)

                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Customer_Event_Query (IN CHAR(64) profileHandle,
				             CHAR(2)   dataBaseID,
                                            CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

    %if (sql_Record_Count != "0")
        <h3>Customer Events</h3>
    %endif

    <table $(contentTable)>
        <colgroup>
            <col width="10%">
            <col width="50%">
            <col width="40%">
        </colgroup>
        	
        %if (sql_Record_Count != "0")
            <tr><th class="colhdr">Number</th>
                <th class="colhdr">Customer </th>
                <th class="colhdr">Location</th>
            </tr>
        %endif

        %ROW {
            %INCLUDE "SetRowClass.icl"

            <tr class="$(rowClass)">
                <td class="colnmbr">$(V_CMCUST)</td>
                <td class="colalph"><a href="$(homeURL)$(cGIPath)CustomerSelect.d2w/REPORT?baseVar=@dtw_rurlescseq(baseVar)&amp;eID=@dtw_rurlescseq(eID)&amp;portal=CUSTOMER&amp;customerNumber=@dtw_rurlescseq(V_CMCUST)&amp;customerName=@dtw_rurlescseq(V_CMCNA1)" title="View Related Entity">$(V_CMCNA1)</a></td>
                <td class="colalph">$(V_CMCCTY), $(V_CMST) $(V_CMZIP)</td>
            </tr>
        %}
    </table>

    %if (sql_Record_Count != "0")
        $(hrTagAttr)	
    %endif
  %}
%}

%FUNCTION(dtw_sql) Related_Contacts (IN  CHAR(64) profileHandle,
				          CHAR(2)   dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count != "0")
          <h3>Related Contacts</h3>
      %endif

      <table $(contentTable)>
          <colgroup>
              <col width="5%">
              <col width="10%">
              <col width="35%">
              <col width="10%">
              <col width="25%">

          %if (sql_Record_Count != "0")
              <tr><th class="colhdr">Number</th>
                  <th class="colhdr">Contact</th>
                  <th class="colhdr">Company</th>
                  <th class="colhdr">Title</th>
                  <th class="colhdr">Location</th>
              </tr>
          %endif

          %ROW {
              %if (sql_Record_Count != "0")
                  %INCLUDE "SetRowClass.icl"

                  <tr class="$(rowClass)">
                      <td class="colnmbr">$(V_CRCONT)</td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)CustomerContactselect.d2w/REPORT$(genericVarBase)&amp;contactNumber=@dtw_rurlescseq(V_CRCONT)" title="View Related Entity">$(V_CRFNAM) $(V_CRLNAM)</a></td>
                      <td class="colalph">$(V_CRCNAM)</td>
                      <td class="colalph">$(V_CRTITL)</td>
                      <td class="colalph">$(V_CRCITY), $(V_CRST) $(V_CRZIP)</td>
                  </tr>
              %endif
          %}
      </table>

      %if (sql_Record_Count != "0" )
          $(hrTagAttr)	
      %endif
  %}
%}

%HTML(CONTACT) {
  %INCLUDE "setLibraryList.icl"
  @UserDefined_Query(profileHandle, dataBaseID, "CRCNTU    ", "          ", userDefinedTable)	
  @CustContactUser_Query(profileHandle, dataBaseID, contactNumber, custContactUserTable)	

  @Set_SQL(stmtSQL)
%}