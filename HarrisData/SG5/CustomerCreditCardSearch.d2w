%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Credit Card Search"
  d2wName                 = "CustomerCreditCardSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldCCTP=@dtw_rurlescseq(fldCCTP)&amp;fldCCDS=@dtw_rurlescseq(fldCCDS)&amp;fldCCNO=@dtw_rurlescseq(fldCCNO)&amp;fldCCEN=@dtw_rurlescseq(fldCCEN)&amp;fldCCNM=@dtw_rurlescseq(fldCCNM)&amp;fldEXMM=@dtw_rurlescseq(fldEXMM)&amp;fldEXYY=@dtw_rurlescseq(fldEXYY)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "9999"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldCCTP                 = ""
  fldCCDS                 = ""
  fldCCNO                 = ""
  fldCCEN                 = ""
  fldCCNM                 = ""
  fldEXMM                 = ""
  fldEXYY                 = ""
  advanceSearch           = "N"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectCreditCard(creditCardType, desc, creditCardNumber, creditCardEntry, name, expMM, expYY){
                  window.opener.document.$(docName).$(fldCCTP).value = creditCardType;
                  window.opener.document.$(docName).$(fldCCDS).value = desc;
                  window.opener.document.$(docName).$(fldCCNO).value = creditCardNumber;
                  window.opener.document.$(docName).$(fldCCEN).value = creditCardEntry;
                  window.opener.document.$(docName).$(fldCCNM).value = name;
                  window.opener.document.$(docName).$(fldEXMM).value = expMM;
                  window.opener.document.$(docName).$(fldEXYY).value = expYY;
                  window.opener.document.$(docName).$(fldCCEN).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " HDCCCM inner join OECCTM on CCCCTP=OECCTP ", fileSQL)
                      @dtw_concat(selectSQL, "CCCUST=$(customerNumber) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By OECCDS,CCCCNO ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Customer_Credit_Card_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Customer_Credit_Card_Search (IN CHAR(64) profileHandle,
				                    CHAR(2)   dataBaseID,
                                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)

      <table $(contentTable)>
          <tr>	
              <th class="colhdr">Credit Card<br>Type</th>
              <th class="colhdr">Credit Card<br>Number</th>
              <th class="colhdr">Name On Card</th>
              <th class="colhdr">Expiration<br>Date</th>
          </tr>
           %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Quote(V_CCCCTP, F_CCCCTP)
              @Format_Quote(V_CCCCNO, F_CCCCNO)
              @dtw_assign(V_CCCCNO, "************@dtw_rsubstr(V_CCCCNO, "13", "4")")
              @Format_Quote(V_CCCCNO, F_CCCCEN)
              @Format_Quote(V_OECCDS, F_OECCDS)
              @Format_Quote(V_CCNOCC, F_CCNOCC)
              @dtw_assign(ccmm, @dtw_rsubstr(V_CCCCED, "4", "2"))
              @Format_Quote(ccmm, F_ccmm)
              @dtw_assign(ccyy, @dtw_rsubstr(V_CCCCED, "2", "2"))
              @Format_Quote(ccyy, F_ccyy)

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="javascript:selectCreditCard('$(F_CCCCTP)', '$(F_OECCDS)', '$(F_CCCCNO)', '$(F_CCCCEN)', '$(F_CCNOCC)', '$(F_ccmm)', '$(F_ccyy)')" title="Select Credit Card">$(V_OECCDS)</a></td>
                  <td class="colcode">$(V_CCCCNO)</td>
                  <td class="colcode">$(V_CCNOCC)</td>
                  <td class="colnmbr">$(ccmm) / $(ccyy)</td>
              </tr>
          %}
      </table>
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}