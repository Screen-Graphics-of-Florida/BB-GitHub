                                                    <input type="text" disabled name="AFPCharacter1Desc" value="$(fieldDesc)" size="35"></td>
                              <td></td>
                              <td class="inputalph">(Name, ...)</td>
                          </tr>
                          @DspErrMsg(Err_JSAFP1)

                          @SetTextOvr(Err_JSAFP2)
                          <tr><td class="dsphdr"><span $(textOvr)>Two</span></td>
                              <td class="inputalph"><input type="text" name="AFPCharacter2" value="$(V_JSAFP2)" size="10" maxlength="5"></td>
                          </tr>
                          @DspErrMsg(Err_JSAFP2)

                          @SetTextOvr(Err_JSAFP3)
                          <tr><td class="dsphdr"><span $(textOvr)>Three</span></td>
                              <td class="inputalph"><input type="text" name="AFPCharacter3" value="$(V_JSAFP3)" size="10" maxlength="5"></td>
                          </tr>
                          @DspErrMsg(Err_JSAFP3)

                          @SetTextOvr(Err_JSAFP4)
                          <tr><td class="dsphdr"><span $(textOvr)>Four</span></td>
                              <td class="inputalph"><input type="text" name="AFPCharacter4" value="$(V_JSAFP4)" size="10" maxlength="5"></td>
                          </tr>
                          @DspErrMsg(Err_JSAFP4)
                      </table>
                  </fieldset>

                  <a name="dbcsParameter"></a>
                  <fieldset class="legendBody">
                      <legend class="legendTitle">DBCS</legend>
                      <div class="quickLinksTop">
                          <a href="#top">$(topOfFormImage)</a>
                      </div>
                      <table $(contentTable)>
                          @RtvFldDesc("FLTYPE='*NOYES' and FLVALU='$(V_JSUSDB)'", "SYFLAG", "FLDESC", fieldDesc)
                          @SetTextOvr(Err_JSUSDB)
                          <tr><td class="dsphdr"><span $(textOvr)>User Specified DBCS Data</span></td>
                              <td class="inputalph"><input type="text" name="UserSpecifiedDBCSData" value="$(V_JSUSDB)" size="10" maxlength="4">
                                                    <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=*NOYES&amp;flagSrchHdr=@dtw_rurlescseq("User Specified DBCS Data")&amp;docName=Chg&amp;fldName=UserSpecifiedDBCSData&amp;fldDesc=UserSpecifiedDBCSDataDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                    <input type="text" disabled name="UserSpecifiedDBCSDataDesc" value="$(fieldDesc)" size="35"></td>
                          </tr>
                          @DspErrMsg(Err_JSUSDB)

                          @RtvFldDesc("FLTYPE='*NOYES' and FLVALU='$(V_JSDBEX)'", "SYFLAG", "FLDESC", fieldDesc)
                          @SetTextOvr(Err_JSDBEX)
                          <tr><td class="dsphdr"><span $(textOvr)>DBCS Extension Characters</span></td>
                              <td class="inputalph"><input type="text" name="DBCSExtensionCharacters" value="$(V_JSDBEX)" size="10" maxlength="4">
                                                    <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=*NOYES&amp;flagSrchHdr=@dtw_rurlescseq("DBCS Extension Characters")&amp;docName=Chg&amp;fldName=DBCSExtensionCharacters&amp;fldDesc=DBCSExtensionCharactersDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                    <input type="text" disabled name="DBCSExtensionCharactersDesc" value="$(fieldDesc)" size="35"></td>
                          </tr>
                          @DspErrMsg(Err_JSDBEX)

                          @RtvFldDesc("FLTYPE='*NOYES' and FLVALU='$(V_JSDBRT)'", "SYFLAG", "FLDESC", fieldDesc)
                          @SetTextOvr(Err_JSDBRT)
                          <tr><td class="dsphdr"><span $(textOvr)>DBCS Character Rotation</span></td>
                              <td class="inputalph"><input type="text" name="DBCSCharacterRotation" value="$(V_JSDBRT)" size="10" maxlength="4">
                                                    <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=*NOYES&amp;flagSrchHdr=@dtw_rurlescseq("DBCS Character Rotation")&amp;docName=Chg&amp;fldName=DBCSCharacterRotation&amp;fldDesc=DBCSCharacterRotationDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                    <input type="text" disabled name="DBCSCharacterRotationDesc" value="$(fieldDesc)" size="35"></td>
                          </tr>
                          @DspErrMsg(Err_JSDBRT)

                          @RtvFldDesc("FLTYPE='OVR_DBCP' and FLVALU='$(V_JSDBCP)'", "SYFLAG", "FLDESC", fieldDesc)
                          @SetTextOvr(Err_JSDBCP)
                          <tr><td class="dsphdr"><span $(textOvr)>DBCS Characters Per Inch</span></td>
                              <td class="inputalph"><input type="text" name="DBCSCharactersPerInch" value="$(V_JSDBCP)" size="10" maxlength="10">
                                                    <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=OVR_DBCP&amp;flagSrchHdr=@dtw_rurlescseq("DBCS Characters Per Inch")&amp;docName=Chg&amp;fldName=DBCSCharactersPerInch&amp;fldDesc=DBCSCharactersPerInchDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                    <input type="text" disabled name="DBCSCharactersPerInchDesc" value="$(fieldDesc)" size="35"></td>
                          </tr>
                          @DspErrMsg(Err_JSDBCP)

                          @RtvFldDesc("FLTYPE='OVR_DBSO' and FLVALU='$(V_JSDBSO)'", "SYFLAG", "FLDESC", fieldDesc)
                          @SetTextOvr(Err_JSDBSO)
                          <tr><td class="dsphdr"><span $(textOvr)>DBCS SO/SI Spacing</span></td>
                              <td class="inputalph"><input type="text" name="DBCSSOSISpacing" value="$(V_JSDBSO)" size="10" maxlength="6">
                                                    <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=OVR_DBSO&amp;flagSrchHdr=@dtw_rurlescseq("DBCS SO/SI Spacing")&amp;docName=Chg&amp;fldName=DBCSSOSISpacing&amp;fldDesc=DBCSSOSISpacingDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                    <input type="text" disabled name="DBCSSOSISpacingDesc" value="$(fieldDesc)" size="35"></td>
                          </tr>
                          @DspErrMsg(Err_JSDBSO)
                      </table>

                      <a name="dbcsCodedFont"></a>
                      <fieldset class="legendBody">
                          <legend class="legendTitle">DBCS Coded Font</legend>
                          <div class="quickLinksTop">
                              <a href="#top">$(topOfFormImage)</a>
                          </div>
                          <table $(contentTable)>
                              @RtvFldDesc("FLTYPE='OVR_DBFT' and FLVALU='$(V_JSDBFT)'", "SYFLAG", "FLDESC", fieldDesc)
                              @SetTextOvr(Err_JSDBFT)
                              <tr><td class="dsphdr"><span $(textOvr)>Coded Font</span></td>
                                  <td class="inputalph"><input type="text" name="DBCSCodedFont" value="$(V_JSDBFT)" size="10" maxlength="10">
                                                        <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=OVR_DBFT&amp;flagSrchHdr=@dtw_rurlescseq("DBCS Coded Font")&amp;docName=Chg&amp;fldName=DBCSCodedFont&amp;fldDesc=DBCSCodedFontDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="text" disabled name="DBCSCodedFontDesc" value="$(fieldDesc)" size="35"></td>
                                  <td></td>
                                  <td class="inputalph">(Name, ...)</td>
                              </tr>
                              @DspErrMsg(Err_JSDBFT)

                              @RtvFldDesc("FLTYPE='OVR_CURLIB' and FLVALU='$(V_JSDBFL)'", "SYFLAG", "FLDESC", fieldDesc)
                              @SetTextOvr(Err_JSDBFL)
                              <tr><td class="dsphdr"><span $(textOvr)>Schema</span></td>
                                  <td class="inputalph"><input type="text" name="DBCSCodedFontLibrary" value="$(V_JSDBFL)" size="10" maxlength="10">
                                                    <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=OVR_CURLIB&amp;flagSrchHdr=@dtw_rurlescseq("Schema")&amp;docName=Chg&amp;fldName=DBCSCodedFontLibrary&amp;fldDesc=DBCSCodedFontLibraryDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                    <input type="text" disabled name="DBCSCodedFontLibraryDesc" value="$(fieldDesc)" size="35"></td>
                                  <td></td>
                                  <td class="inputalph">(Name, ...)</td>
                              </tr>
                              @DspErrMsg(Err_JSDBFL)

                              @RtvFldDesc("FLTYPE='OVR_DBFP' and FLVALU='$(V_JSDBFP)'", "SYFLAG", "FLDESC", fieldDesc)
                              @SetTextOvr(Err_JSDBFP)
                              <tr><td class="dsphdr"><span $(textOvr)>Point Size</span></td>
                                  <td class="inputalph"><input type="text" name="DBCSCodedFontPointSize" value="$(V_JSDBFP)" size="10" maxlength="6">
                                                        <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=OVR_DBFP&amp;flagSrchHdr=@dtw_rurlescseq("DBCS Coded Font Point Size")&amp;docName=Chg&amp;fldName=DBCSCodedFontPointSize&amp;fldDesc=DBCSCodedFontPointSizeDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="text" disabled name="DBCSCodedFontPointSizeDesc" value="$(fieldDesc)" size="35"></td>
                                  <td></td>
                                  <td class="inputalph">(0.1-999.9, ...)</td>
                              </tr>
                              @DspErrMsg(Err_JSDBFP)
                          </table>
                      </fieldset>
                  </fieldset>
              </fieldset>
          %}

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar,
                                        INOUT CHAR(32000) wrnVar)
{%EXEC {HHDJSU_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif
  %if (JobName=="")
      @RtvFldDesc("JSAPID='$(EnvOvrApId)' and JSUSER='$(EnvOvrUser)' and JSWS='$(EnvOvrWS)' and JSPGID='$(EnvOvrPgm)' and JSPRTF='$(EnvOvrPrtf)' ", "HDJSBO", "JSJNAM", JobName)
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@frm1", fromApId)
  @Concat_Field("@@frm2", fromUser)
  @Concat_Field("@@frm3", fromWS)
  @Concat_Field("@@frm4", fromPgm)
  @Concat_Field("@@frm5", fromPrtf)
  @dtw_mUPPERCASE(EnvOvrApId)                     @Concat_Field("@@apid", EnvOvrApId)
  @dtw_mUPPERCASE(EnvOvrUser)                     @Concat_Field("@@user", EnvOvrUser)
  @dtw_mUPPERCASE(EnvOvrWS)                       @Concat_Field("@@ws@@", EnvOvrWS)
  @dtw_mUPPERCASE(EnvOvrPgm)                      @Concat_Field("@@pgid", EnvOvrPgm)
  @dtw_mUPPERCASE(EnvOvrPrtf)                     @Concat_Field("@@prtf", EnvOvrPrtf)

  @dtw_mUPPERCASE(AllowUpdateUpgrade)             @Concat_Field("@@updt", AllowUpdateUpgrade)
  @dtw_mUPPERCASE(JobName)                        @Concat_Field("@@jnam", JobName)
  @dtw_mUPPERCASE(JobDescription)                 @Concat_Field("@@jobd", JobDescription)
  @dtw_mUPPERCASE(JobQueue)                       @Concat_Field("@@jobq", JobQueue)
  @dtw_mUPPERCASE(JobPriority)                    @Concat_Field("@@jobp", JobPriority)
  @dtw_mUPPERCASE(LogCL)                          @Concat_Field("@@logc", LogCL)
  @dtw_mUPPERCASE(HoldJobQueue)                   @Concat_Field("@@hljq", HoldJobQueue)
  @dtw_mUPPERCASE(OutputQueue)                    @Concat_Field("@@outq", OutputQueue)
  @dtw_mUPPERCASE(OutputPriority)                 @Concat_Field("@@prty", OutputPriority)
                                                  @Concat_Field("@@copy", Copies)
  @dtw_mUPPERCASE(HoldSpooled)                    @Concat_Field("@@hold", HoldSpooled)
  @dtw_mUPPERCASE(SaveSpooled)                    @Concat_Field("@@save", SaveSpooled)
  @dtw_mUPPERCASE(MaxSpooledRecords)              @Concat_Field("@@mxrc", MaxSpooledRecords)
  @dtw_mUPPERCASE(UserData)                       @Concat_Field("@@udta", UserData)
  @dtw_mUPPERCASE(SpoolFile)                      @Concat_Field("@@spnm", SpoolFile)
  @dtw_mUPPERCASE(UserDefined)                    @Concat_Field("@@usdf", UserDefined)
                                                  @Concat_Field("@@pgln", PageLength)
                                                  @Concat_Field("@@pgwd", PageWidth)
                                                  @Concat_Field("@@ovfl", OverflowLine)
                                                  @Concat_Field("@@lpi@", LinesPerInch)
                                                  @Concat_Field("@@cpi@", CharPerInch)
  @dtw_mUPPERCASE(AlignPage)                      @Concat_Field("@@alpg", AlignPage)
  @dtw_mUPPERCASE(FormType)                       @Concat_Field("@@form", FormType)
  @dtw_mUPPERCASE(PrinterDevice)                  @Concat_Field("@@devt", PrinterDevice)
  @dtw_mUPPERCASE(ConvertLineData)                @Concat_Field("@@cvld", ConvertLineData)
  @dtw_mUPPERCASE(DegreePageRotation)             @Concat_Field("@@dgpr", DegreePageRotation)
  @dtw_mUPPERCASE(FrontSideOverlay)               @Concat_Field("@@frov", FrontSideOverlay)
  @dtw_mUPPERCASE(FrontSideOverlayLibrary)        @Concat_Field("@@frlb", FrontSideOverlayLibrary)
                                                  @Concat_Field("@@frdw", FrontSideOffsetDown)
                                                  @Concat_Field("@@frac", FrontSideOffsetAcross)
  @dtw_mUPPERCASE(BackSideOverlay)                @Concat_Field("@@bcov", BackSideOverlay)
  @dtw_mUPPERCASE(BackSideOverlayLibrary)         @Concat_Field("@@bclb", BackSideOverlayLibrary)
                                                  @Concat_Field("@@bcdw", BackSideOffsetDown)
                                                  @Concat_Field("@@bcac", BackSideOffsetAcross)
  @dtw_mUPPERCASE(BackSideConstantBack)           @Concat_Field("@@bccb", BackSideConstantBack)
  @dtw_mUPPERCASE(PageDefinition)                 @Concat_Field("@@pgdf", PageDefinition)
  @dtw_mUPPERCASE(PageDefinitionLibrary)          @Concat_Field("@@pglb", PageDefinitionLibrary)
  @dtw_mUPPERCASE(FormDefinition)                 @Concat_Field("@@fmdf", FormDefinition)
  @dtw_mUPPERCASE(FormDefinitionLibrary)          @Concat_Field("@@fmlb", FormDefinitionLibrary)
  @dtw_mUPPERCASE(UnitOfMeasure)                  @Concat_Field("@@uom@", UnitOfMeasure)
  @dtw_mUPPERCASE(FrontMarginOffsetDown)          @Concat_Field("@@frmd", FrontMarginOffsetDown)
  @dtw_mUPPERCASE(FrontMarginOffsetAcross)        @Concat_Field("@@frma", FrontMarginOffsetAcross)
  @dtw_mUPPERCASE(BackMarginOffsetDown)           @Concat_Field("@@bkmd", BackMarginOffsetDown)
  @dtw_mUPPERCASE(BackMarginOffsetAcross)         @Concat_Field("@@bkma", BackMarginOffsetAcross)
  @dtw_mUPPERCASE(PrintQuality)                   @Concat_Field("@@prql", PrintQuality)
  @dtw_mUPPERCASE(DeferWrite)                     @Concat_Field("@@dfwr", DeferWrite)
  @dtw_mUPPERCASE(SpoolData)                      @Concat_Field("@@spdt", SpoolData)
  @dtw_mUPPERCASE(ReduceOutput)                   @Concat_Field("@@redc", ReduceOutput)
  @dtw_mUPPERCASE(PrintBothSides)                 @Concat_Field("@@prsd", PrintBothSides)
  @dtw_mUPPERCASE(PagesPerSide)                   @Concat_Field("@@pgsd", PagesPerSide)
  @dtw_mUPPERCASE(SourceDrawer)                   @Concat_Field("@@scdr", SourceDrawer)
  @dtw_mUPPERCASE(OutputBin)                      @Concat_Field("@@obin", OutputBin)
  @dtw_mUPPERCASE(FormFeed)                       @Concat_Field("@@feed", FormFeed)
  @dtw_mUPPERCASE(CornerStaple)                   @Concat_Field("@@cnrs", CornerStaple)
  @dtw_mUPPERCASE(HardwareJustification)          @Concat_Field("@@just", HardwareJustification)
  @dtw_mUPPERCASE(UserResourceLibrary1)           @Concat_Field("@@rcl1", UserResourceLibrary1)
  @dtw_mUPPERCASE(UserResourceLibrary2)           @Concat_Field("@@rcl2", UserResourceLibrary2)
  @dtw_mUPPERCASE(UserResourceLibrary3)           @Concat_Field("@@rcl3", UserResourceLibrary3)
  @dtw_mUPPERCASE(UserResourceLibrary4)           @Concat_Field("@@rcl4", UserResourceLibrary4)
  @dtw_mUPPERCASE(EdgeStitchReferenceEdge)        @Concat_Field("@@erfe", EdgeStitchReferenceEdge)
  @dtw_mUPPERCASE(EdgeStitchReferenceEdgeOffset)  @Concat_Field("@@erfo", EdgeStitchReferenceEdgeOffset)
  @dtw_mUPPERCASE(EdgeStitchNumberOfStaples)      @Concat_Field("@@estp", EdgeStitchNumberOfStaples)
  @dtw_mUPPERCASE(EdgeStitchStapleOffset1)        @Concat_Field("@@eso1", EdgeStitchStapleOffset1)
  @dtw_mUPPERCASE(EdgeStitchStapleOffset2)        @Concat_Field("@@eso2", EdgeStitchStapleOffset2)
  @dtw_mUPPERCASE(EdgeStitchStapleOffset3)        @Concat_Field("@@eso3", EdgeStitchStapleOffset3)
  @dtw_mUPPERCASE(EdgeStitchStapleOffset4)        @Concat_Field("@@eso4", EdgeStitchStapleOffset4)
  @dtw_mUPPERCASE(SaddleStitchReferenceEdge)      @Concat_Field("@@srfe", SaddleStitchReferenceEdge)
  @dtw_mUPPERCASE(SaddleStitchNumberStaples)      @Concat_Field("@@sstp", SaddleStitchNumberStaples)
  @dtw_mUPPERCASE(SaddleStitchStapleOffset1)      @Concat_Field("@@sso1", SaddleStitchStapleOffset1)
  @dtw_mUPPERCASE(SaddleStitchStapleOffset2)      @Concat_Field("@@sso2", SaddleStitchStapleOffset2)
  @dtw_mUPPERCASE(SaddleStitchStapleOffset3)      @Concat_Field("@@sso3", SaddleStitchStapleOffset3)
  @dtw_mUPPERCASE(SaddleStitchStapleOffset4)      @Concat_Field("@@sso4", SaddleStitchStapleOffset4)
  @dtw_mUPPERCASE(FontIdentifier)                 @Concat_Field("@@ftid", FontIdentifier)
                                                  @Concat_Field("@@ftps", FontPointSize)
  @dtw_mUPPERCASE(FontCharacterSet)               @Concat_Field("@@chst", FontCharacterSet)
  @dtw_mUPPERCASE(FontCharacterSetLibrary)        @Concat_Field("@@chsl", FontCharacterSetLibrary)
  @dtw_mUPPERCASE(FontCodePage)                   @Concat_Field("@@cdpg", FontCodePage)
  @dtw_mUPPERCASE(FontCodePageLibrary)            @Concat_Field("@@cdpl", FontCodePageLibrary)
  @dtw_mUPPERCASE(CodedFont)                      @Concat_Field("@@cdft", CodedFont)
  @dtw_mUPPERCASE(CodedFontLibrary)               @Concat_Field("@@cdfl", CodedFontLibrary)
  @dtw_mUPPERCASE(FileSeparators)                 @Concat_Field("@@fsep", FileSeparators)
  @dtw_mUPPERCASE(AFPCharacter1)                  @Concat_Field("@@afp1", AFPCharacter1)
  @dtw_mUPPERCASE(AFPCharacter2)                  @Concat_Field("@@afp2", AFPCharacter2)
  @dtw_mUPPERCASE(AFPCharacter3)                  @Concat_Field("@@afp3", AFPCharacter3)
  @dtw_mUPPERCASE(AFPCharacter4)                  @Concat_Field("@@afp4", AFPCharacter4)
  @dtw_mUPPERCASE(TableReferenceCharacters)       @Concat_Field("@@tchr", TableReferenceCharacters)
  @dtw_mUPPERCASE(UserSpecifiedDBCSData)          @Concat_Field("@@usdb", UserSpecifiedDBCSData)
  @dtw_mUPPERCASE(DBCSExtensionCharacters)        @Concat_Field("@@dbex", DBCSExtensionCharacters)
  @dtw_mUPPERCASE(DBCSCharacterRotation)          @Concat_Field("@@dbrt", DBCSCharacterRotation)
  @dtw_mUPPERCASE(DBCSCharactersPerInch)          @Concat_Field("@@dbcp", DBCSCharactersPerInch)
  @dtw_mUPPERCASE(DBCSSOSISpacing)                @Concat_Field("@@dbso", DBCSSOSISpacing)
  @dtw_mUPPERCASE(DBCSCodedFont)                  @Concat_Field("@@dbft", DBCSCodedFont)
  @dtw_mUPPERCASE(DBCSCodedFontLibrary)           @Concat_Field("@@dbfl", DBCSCodedFontLibrary)
  @dtw_mUPPERCASE(DBCSCodedFontPointSize)         @Concat_Field("@@dbfp", DBCSCodedFontPointSize)
  @dtw_mUPPERCASE(NonSupportedOverride)           @Concat_Field("@@nsup", NonSupportedOverride)

  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar, wrnVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(JobName), "$(EnvOvrApId)-$(EnvOvrUser)-$(EnvOvrWS)-$(EnvOvrPgm)-$(EnvOvrPrtf)", "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@apid", "EnvOvrApId")
          @Format_ConfMsg_Desc("", $(JobName), "$(EnvOvrApId)-$(EnvOvrUser)-$(EnvOvrWS)-$(EnvOvrPgm)-$(EnvOvrPrtf)", "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=138&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;EnvOvrApId=@dtw_rurlescseq(EnvOvrApId)&amp;EnvOvrUser=@dtw_rurlescseq(EnvOvrUser)&amp;EnvOvrWS=@dtw_rurlescseq(EnvOvrWS)&amp;EnvOvrPgm=@dtw_rurlescseq(EnvOvrPgm)&amp;EnvOvrPrtf=@dtw_rurlescseq(EnvOvrPrtf)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
