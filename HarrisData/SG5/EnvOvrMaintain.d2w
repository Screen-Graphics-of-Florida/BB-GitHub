%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Environment Override Maintenance"
  d2wName                 = "EnvOvrMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromApId=@dtw_rurlescseq(fromApId)&amp;fromUser=@dtw_rurlescseq(fromUser)&amp;fromWS=@dtw_rurlescseq(fromWS)&amp;fromPgm=@dtw_rurlescseq(fromPgm)&amp;fromPrtf=@dtw_rurlescseq(fromPrtf)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;wrnVar=@dtw_rurlescseq(wrnVar)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;EnvOvrApId=@dtw_rurlescseq(EnvOvrApId)&amp;EnvOvrUser=@dtw_rurlescseq(EnvOvrUser)&amp;EnvOvrWS=@dtw_rurlescseq(EnvOvrWS)&amp;EnvOvrPgm=@dtw_rurlescseq(EnvOvrPgm)&amp;EnvOvrPrtf=@dtw_rurlescseq(EnvOvrPrtf)&amp;maintenanceCode=D"
  programName             = "HHDJSU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "UpperCase.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (editNum(document.Chg.Copies, 3, 0) &&
                      editNum(document.Chg.PageLength, 3, 3) &&
                      editNum(document.Chg.PageWidth, 3, 3) &&
                      editNum(document.Chg.OverflowLine, 3, 0) &&
                      editNum(document.Chg.LinesPerInch, 2, 1) &&
                      editNum(document.Chg.CharPerInch, 2, 1) &&
                      editNum(document.Chg.FrontSideOffsetDown, 2, 3) &&
                      editNum(document.Chg.FrontSideOffsetAcross, 2, 3) &&
                      editNum(document.Chg.BackSideOffsetDown, 2, 3) &&
                      editNum(document.Chg.BackSideOffsetAcross, 2, 3) &&
                      editNum(document.Chg.FontPointSize, 3, 1))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
              %INCLUDE "calendar.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "numedit.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ENVOVRMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From HDJSBO Where JSAPID='$(EnvOvrApId)' and JSUSER='$(EnvOvrUser)' and JSWS='$(EnvOvrWS)' and JSPGID='$(EnvOvrPgm)' and JSPRTF='$(EnvOvrPrtf)' ", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=138")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      <a NAME="top"></a>
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)

      <table $(quickLinkTable)>
          <tr>
              <td class="quickLinkTabs"><a href="#jobParameter">Job Parameters</a></td>
              <td class="quickLinkTabs"><a href="#printerParameter">Printer Parameters</a></td>
              <td class="quickLinkTabs"><a href="#pageParameter">Page</a></td>
              <td class="quickLinkTabs"><a href="#frontSideOverlay">Front Side Overlay</a></td>
              <td class="quickLinkTabs"><a href="#backSideOverlay">Back Side Overlay</a></td>
          </tr>
          <tr>
              <td class="quickLinkTabs"><a href="#pageDefinition">Page Definition</a></td>
              <td class="quickLinkTabs"><a href="#formDefinition">Form Definition</a></td>
              <td class="quickLinkTabs"><a href="#frontMargin">Front Margin</a></td>
              <td class="quickLinkTabs"><a href="#backMargin">Back Margin</a></td>
              <td class="quickLinkTabs"><a href="#additionalParameter">Additional Parameters</a></td>
          </tr>
          <tr>
              <td class="quickLinkTabs"><a href="#edgeStitch">Edge Stitch</a></td>
              <td class="quickLinkTabs"><a href="#saddleStitch">Saddle Stitch</a></td>
              <td class="quickLinkTabs"><a href="#fontIdentifier">Font Identifier</a></td>
              <td class="quickLinkTabs"><a href="#fontCharacterSet">Font Character Set</a></td>
              <td class="quickLinkTabs"><a href="#codedFont">Coded Font</a></td>
          </tr>
          <tr>
              <td class="quickLinkTabs"><a href="#afpCharacter">AFP Characters</a></td>
              <td class="quickLinkTabs"><a href="#dbcsParameter">DBCS</a></td>
              <td class="quickLinkTabs"><a href="#dbcsCodedFont">DBCS Coded Font</a></td>
          </tr>
      </table>

      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
		
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          %ROW {
              %if (errFound != "" || maintenanceCode=="A")
                  @dtw_assign(focusField, "EnvOvrApId")
                  %if (errFound=="" && maintenanceCode=="A")
                      @dtw_assign(edtVar, "")
                  %elif (errFound != "")
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@apid", "EnvOvrApId")                    @dtw_assign(Err_JSAPID, fieldValue)
                      @DecatErr_Field("@@user", "EnvOvrUser")                    @dtw_assign(Err_JSUSER, fieldValue)
                      @DecatErr_Field("@@ws@@", "EnvOvrWS")                      @dtw_assign(Err_JSWS, fieldValue)
                      @DecatErr_Field("@@pgid", "EnvOvrPgm")                     @dtw_assign(Err_JSPGID, fieldValue)
                      @DecatErr_Field("@@prtf", "EnvOvrPrtf")                    @dtw_assign(Err_JSPRTF, fieldValue)

                      @DecatErr_Field("@@updt", "AllowUpdateUpgrade")            @dtw_assign(Err_JSUPDT, fieldValue)
                      @DecatErr_Field("@@jnam", "JobName")                       @dtw_assign(Err_JSJNAM, fieldValue)
                      @DecatErr_Field("@@jobd", "JobDescription")                @dtw_assign(Err_JSJOBD, fieldValue)
                      @DecatErr_Field("@@jobq", "JobQueue")                      @dtw_assign(Err_JSJOBQ, fieldValue)
                      @DecatErr_Field("@@jobp", "JobPriority")                   @dtw_assign(Err_JSJOBP, fieldValue)
                      @DecatErr_Field("@@logc", "LogCL")                         @dtw_assign(Err_JSLOGC, fieldValue)
                      @DecatErr_Field("@@hljq", "HoldJobQueue")                  @dtw_assign(Err_JSHLJQ, fieldValue)
                      @DecatErr_Field("@@outq", "OutputQueue")                   @dtw_assign(Err_JSOUTQ, fieldValue)
                      @DecatErr_Field("@@prty", "OutputPriority")                @dtw_assign(Err_JSPRTY, fieldValue)
                      @DecatErr_Field("@@copy", "Copies")                        @dtw_assign(Err_JSCOPY, fieldValue)
                      @DecatErr_Field("@@hold", "HoldSpooled")                   @dtw_assign(Err_JSHOLD, fieldValue)
                      @DecatErr_Field("@@save", "SaveSpooled")                   @dtw_assign(Err_JSSAVE, fieldValue)
                      @DecatErr_Field("@@mxrc", "MaxSpooledRecords")             @dtw_assign(Err_JSMXRC, fieldValue)
                      @DecatErr_Field("@@udta", "UserData")                      @dtw_assign(Err_JSUDTA, fieldValue)
                      @DecatErr_Field("@@spnm", "SpoolFile")                     @dtw_assign(Err_JSSPNM, fieldValue)
                      @DecatErr_Field("@@usdf", "UserDefined")                   @dtw_assign(Err_JSUSDF, fieldValue)
                      @DecatErr_Field("@@pgln", "PageLength")                    @dtw_assign(Err_JSPGLN, fieldValue)
                      @DecatErr_Field("@@pgwd", "PageWidth ")                    @dtw_assign(Err_JSPGWD, fieldValue)
                      @DecatErr_Field("@@ovfl", "OverflowLine")                  @dtw_assign(Err_JSOVFL, fieldValue)
                      @DecatErr_Field("@@lpi@", "LinesPerInch")                  @dtw_assign(Err_JSLPI , fieldValue)
                      @DecatErr_Field("@@cpi@", "CharPerInch")                   @dtw_assign(Err_JSCPI , fieldValue)
                      @DecatErr_Field("@@alpg", "AlignPage")                     @dtw_assign(Err_JSALPG, fieldValue)
                      @DecatErr_Field("@@form", "FormType")                      @dtw_assign(Err_JSFORM, fieldValue)
                      @DecatErr_Field("@@devt", "PrinterDevice")                 @dtw_assign(Err_JSDEVT, fieldValue)
                      @DecatErr_Field("@@cvld", "ConvertLineData")               @dtw_assign(Err_JSCVLD, fieldValue)
                      @DecatErr_Field("@@dgpr", "DegreePageRotation")            @dtw_assign(Err_JSDGPR, fieldValue)
                      @DecatErr_Field("@@frov", "FrontSideOverlay")              @dtw_assign(Err_JSFROV, fieldValue)
                      @DecatErr_Field("@@frlb", "FrontSideOverlayLibrary")       @dtw_assign(Err_JSFRLB, fieldValue)
                      @DecatErr_Field("@@frdw", "FrontSideOffsetDown")           @dtw_assign(Err_JSFRDW, fieldValue)
                      @DecatErr_Field("@@frac", "FrontSideOffsetAcross")         @dtw_assign(Err_JSFRAC, fieldValue)
                      @DecatErr_Field("@@bcov", "BackSideOverlay")               @dtw_assign(Err_JSBCOV, fieldValue)
                      @DecatErr_Field("@@bclb", "BackSideOverlayLibrary")        @dtw_assign(Err_JSBCLB, fieldValue)
                      @DecatErr_Field("@@bcdw", "BackSideOffsetDown ")           @dtw_assign(Err_JSBCDW, fieldValue)
                      @DecatErr_Field("@@bcac", "BackSideOffsetAcross")          @dtw_assign(Err_JSBCAC, fieldValue)
                      @DecatErr_Field("@@bccb", "BackSideConstantBack")          @dtw_assign(Err_JSBCCB, fieldValue)
                      @DecatErr_Field("@@pgdf", "PageDefinition")                @dtw_assign(Err_JSPGDF, fieldValue)
                      @DecatErr_Field("@@pglb", "PageDefinitionLibrary")         @dtw_assign(Err_JSPGLB, fieldValue)
                      @DecatErr_Field("@@fmdf", "FormDefinition")                @dtw_assign(Err_JSFMDF, fieldValue)
                      @DecatErr_Field("@@fmlb", "FormDefinitionLibrary")         @dtw_assign(Err_JSFMLB, fieldValue)
                      @DecatErr_Field("@@uom@", "UnitOfMeasure")                 @dtw_assign(Err_JSUOM , fieldValue)
                      @DecatErr_Field("@@frmd", "FrontMarginOffsetDown")         @dtw_assign(Err_JSFRMD, fieldValue)
                      @DecatErr_Field("@@frma", "FrontMarginOffsetAcross")       @dtw_assign(Err_JSFRMA, fieldValue)
                      @DecatErr_Field("@@bkmd", "BackMarginOffsetDown")          @dtw_assign(Err_JSBKMD, fieldValue)
                      @DecatErr_Field("@@bkma", "BackMarginOffsetAcross")        @dtw_assign(Err_JSBKMA, fieldValue)
                      @DecatErr_Field("@@prql", "PrintQuality")                  @dtw_assign(Err_JSPRQL, fieldValue)
                      @DecatErr_Field("@@dfwr", "DeferWrite")                    @dtw_assign(Err_JSDFWR, fieldValue)
                      @DecatErr_Field("@@spdt", "SpoolData")                     @dtw_assign(Err_JSSPDT, fieldValue)
                      @DecatErr_Field("@@redc", "ReduceOutput")                  @dtw_assign(Err_JSREDC, fieldValue)
                      @DecatErr_Field("@@prsd", "PrintBothSides")                @dtw_assign(Err_JSPRSD, fieldValue)
                      @DecatErr_Field("@@pgsd", "PagesPerSide")                  @dtw_assign(Err_JSPGSD, fieldValue)
                      @DecatErr_Field("@@scdr", "SourceDrawer")                  @dtw_assign(Err_JSSCDR, fieldValue)
                      @DecatErr_Field("@@obin", "OutputBin")                     @dtw_assign(Err_JSOBIN, fieldValue)
                      @DecatErr_Field("@@feed", "FormFeed")                      @dtw_assign(Err_JSFEED, fieldValue)
                      @DecatErr_Field("@@cnrs", "CornerStaple")                  @dtw_assign(Err_JSCNRS, fieldValue)
                      @DecatErr_Field("@@just", "HardwareJustification")         @dtw_assign(Err_JSJUST, fieldValue)
                      @DecatErr_Field("@@rcl1", "UserResourceLibrary1")          @dtw_assign(Err_JSRCL1, fieldValue)
                      @DecatErr_Field("@@rcl2", "UserResourceLibrary2")          @dtw_assign(Err_JSRCL2, fieldValue)
                      @DecatErr_Field("@@rcl3", "UserResourceLibrary3")          @dtw_assign(Err_JSRCL3, fieldValue)
                      @DecatErr_Field("@@rcl4", "UserResourceLibrary4")          @dtw_assign(Err_JSRCL4, fieldValue)
                      @DecatErr_Field("@@erfe", "EdgeStitchReferenceEdge")       @dtw_assign(Err_JSERFE, fieldValue)
                      @DecatErr_Field("@@erfo", "EdgeStitchReferenceEdgeOffset") @dtw_assign(Err_JSERFO, fieldValue)
                      @DecatErr_Field("@@estp", "EdgeStitchNumberOfStaples")     @dtw_assign(Err_JSESTP, fieldValue)
                      @DecatErr_Field("@@eso1", "EdgeStitchStapleOffset1")       @dtw_assign(Err_JSESO1, fieldValue)
                      @DecatErr_Field("@@eso2", "EdgeStitchStapleOffset2")       @dtw_assign(Err_JSESO2, fieldValue)
                      @DecatErr_Field("@@eso3", "EdgeStitchStapleOffset3")       @dtw_assign(Err_JSESO3, fieldValue)
                      @DecatErr_Field("@@eso4", "EdgeStitchStapleOffset4")       @dtw_assign(Err_JSESO4, fieldValue)
                      @DecatErr_Field("@@srfe", "SaddleStitchReferenceEdge")     @dtw_assign(Err_JSSRFE, fieldValue)
                      @DecatErr_Field("@@sstp", "SaddleStitchNumberStaples")     @dtw_assign(Err_JSSSTP, fieldValue)
                      @DecatErr_Field("@@sso1", "SaddleStitchStapleOffset1")     @dtw_assign(Err_JSSSO1, fieldValue)
                      @DecatErr_Field("@@sso2", "SaddleStitchStapleOffset2")     @dtw_assign(Err_JSSSO2, fieldValue)
                      @DecatErr_Field("@@sso3", "SaddleStitchStapleOffset3")     @dtw_assign(Err_JSSSO3, fieldValue)
                      @DecatErr_Field("@@sso4", "SaddleStitchStapleOffset4")     @dtw_assign(Err_JSSSO4, fieldValue)
                      @DecatErr_Field("@@ftid", "FontIdentifier")                @dtw_assign(Err_JSFTID, fieldValue)
                      @DecatErr_Field("@@ftps", "FontPointSize")                 @dtw_assign(Err_JSFTPS, fieldValue)
                      @DecatErr_Field("@@chst", "FontCharacterSet")              @dtw_assign(Err_JSCHST, fieldValue)
                      @DecatErr_Field("@@chsl", "FontCharacterSetLibrary")       @dtw_assign(Err_JSCHSL, fieldValue)
                      @DecatErr_Field("@@cdpg", "FontCodePage")                  @dtw_assign(Err_JSCDPG, fieldValue)
                      @DecatErr_Field("@@cdpl", "FontCodePageLibrary")           @dtw_assign(Err_JSCDPL, fieldValue)
                      @DecatErr_Field("@@cdft", "CodedFont")                     @dtw_assign(Err_JSCDFT, fieldValue)
                      @DecatErr_Field("@@cdfl", "CodedFontLibrary")              @dtw_assign(Err_JSCDFL, fieldValue)
                      @DecatErr_Field("@@fsep", "FileSeparators")                @dtw_assign(Err_JSFSEP, fieldValue)
                      @DecatErr_Field("@@afp1", "AFPCharacter1")                 @dtw_assign(Err_JSAFP1, fieldValue)
                      @DecatErr_Field("@@afp2", "AFPCharacter2")                 @dtw_assign(Err_JSAFP2, fieldValue)
                      @DecatErr_Field("@@afp3", "AFPCharacter3")                 @dtw_assign(Err_JSAFP3, fieldValue)
                      @DecatErr_Field("@@afp4", "AFPCharacter4")                 @dtw_assign(Err_JSAFP4, fieldValue)
                      @DecatErr_Field("@@tchr", "TableReferenceCharacters")      @dtw_assign(Err_JSTCHR, fieldValue)
                      @DecatErr_Field("@@usdb", "UserSpecifiedDBCSData")         @dtw_assign(Err_JSUSDB, fieldValue)
                      @DecatErr_Field("@@dbex", "DBCSExtensionCharacters")       @dtw_assign(Err_JSDBEX, fieldValue)
                      @DecatErr_Field("@@dbrt", "DBCSCharacterRotation")         @dtw_assign(Err_JSDBRT, fieldValue)
                      @DecatErr_Field("@@dbcp", "DBCSCharactersPerInch")         @dtw_assign(Err_JSDBCP, fieldValue)
                      @DecatErr_Field("@@dbso", "DBCSSO/SISpacing")              @dtw_assign(Err_JSDBSO, fieldValue)
                      @DecatErr_Field("@@dbft", "DBCSCodedFont")                 @dtw_assign(Err_JSDBFT, fieldValue)
                      @DecatErr_Field("@@dbfl", "DBCSCodedFontLibrary")          @dtw_assign(Err_JSDBFL, fieldValue)
                      @DecatErr_Field("@@dbfp", "DBCSCodedFontPointSize")        @dtw_assign(Err_JSDBFP, fieldValue)
                      @DecatErr_Field("@@nsup", "NonSupportedOverride")          @dtw_assign(Err_JSNSUP, fieldValue)
                  %endif

                  @Decat_Field("@@cust")   @dtw_assign(V_CMCUST, fieldValue)
                  @Decat_Field("@@apid")   @dtw_assign(V_JSAPID, fieldValue)
                  @Decat_Field("@@user")   @dtw_assign(V_JSUSER, fieldValue)
                  @Decat_Field("@@ws@@")   @dtw_assign(V_JSWS,   fieldValue)
                  @Decat_Field("@@pgid")   @dtw_assign(V_JSPGID, fieldValue)
                  @Decat_Field("@@prtf")   @dtw_assign(V_JSPRTF, fieldValue)

                  @Decat_Field("@@updt")   @dtw_assign(V_JSUPDT, fieldValue)
                  @Decat_Field("@@jnam")   @dtw_assign(V_JSJNAM, fieldValue)
                  @Decat_Field("@@jobd")   @dtw_assign(V_JSJOBD, fieldValue)
                  @Decat_Field("@@jobq")   @dtw_assign(V_JSJOBQ, fieldValue)
                  @Decat_Field("@@jobp")   @dtw_assign(V_JSJOBP, fieldValue)
                  @Decat_Field("@@logc")   @dtw_assign(V_JSLOGC, fieldValue)
                  @Decat_Field("@@hljq")   @dtw_assign(V_JSHLJQ, fieldValue)
                  @Decat_Field("@@outq")   @dtw_assign(V_JSOUTQ, fieldValue)
                  @Decat_Field("@@prty")   @dtw_assign(V_JSPRTY, fieldValue)
                  @Decat_Field("@@copy")   @dtw_assign(V_JSCOPY, fieldValue)
                  @Decat_Field("@@hold")   @dtw_assign(V_JSHOLD, fieldValue)
                  @Decat_Field("@@save")   @dtw_assign(V_JSSAVE, fieldValue)
                  @Decat_Field("@@mxrc")   @dtw_assign(V_JSMXRC, fieldValue)
                  @Decat_Field("@@udta")   @dtw_assign(V_JSUDTA, fieldValue)
                  @Decat_Field("@@spnm")   @dtw_assign(V_JSSPNM, fieldValue)
                  @Decat_Field("@@usdf")   @dtw_assign(V_JSUSDF, fieldValue)
                  @Decat_Field("@@pgln")   @dtw_assign(V_JSPGLN, fieldValue)
                  @Decat_Field("@@pgwd")   @dtw_assign(V_JSPGWD, fieldValue)
                  @Decat_Field("@@ovfl")   @dtw_assign(V_JSOVFL, fieldValue)
                  @Decat_Field("@@lpi@")   @dtw_assign(V_JSLPI , fieldValue)
                  @Decat_Field("@@cpi@")   @dtw_assign(V_JSCPI , fieldValue)
                  @Decat_Field("@@alpg")   @dtw_assign(V_JSALPG, fieldValue)
                  @Decat_Field("@@form")   @dtw_assign(V_JSFORM, fieldValue)
                  @Decat_Field("@@devt")   @dtw_assign(V_JSDEVT, fieldValue)
                  @Decat_Field("@@cvld")   @dtw_assign(V_JSCVLD, fieldValue)
                  @Decat_Field("@@dgpr")   @dtw_assign(V_JSDGPR, fieldValue)
                  @Decat_Field("@@frov")   @dtw_assign(V_JSFROV, fieldValue)
                  @Decat_Field("@@frlb")   @dtw_assign(V_JSFRLB, fieldValue)
                  @Decat_Field("@@frdw")   @dtw_assign(V_JSFRDW, fieldValue)
                  @Decat_Field("@@frac")   @dtw_assign(V_JSFRAC, fieldValue)
                  @Decat_Field("@@bcov")   @dtw_assign(V_JSBCOV, fieldValue)
                  @Decat_Field("@@bclb")   @dtw_assign(V_JSBCLB, fieldValue)
                  @Decat_Field("@@bcdw")   @dtw_assign(V_JSBCDW, fieldValue)
                  @Decat_Field("@@bcac")   @dtw_assign(V_JSBCAC, fieldValue)
                  @Decat_Field("@@bccb")   @dtw_assign(V_JSBCCB, fieldValue)
                  @Decat_Field("@@pgdf")   @dtw_assign(V_JSPGDF, fieldValue)
                  @Decat_Field("@@pglb")   @dtw_assign(V_JSPGLB, fieldValue)
                  @Decat_Field("@@fmdf")   @dtw_assign(V_JSFMDF, fieldValue)
                  @Decat_Field("@@fmlb")   @dtw_assign(V_JSFMLB, fieldValue)
                  @Decat_Field("@@uom@")   @dtw_assign(V_JSUOM , fieldValue)
                  @Decat_Field("@@frmd")   @dtw_assign(V_JSFRMD, fieldValue)
                  @Decat_Field("@@frma")   @dtw_assign(V_JSFRMA, fieldValue)
                  @Decat_Field("@@bkmd")   @dtw_assign(V_JSBKMD, fieldValue)
                  @Decat_Field("@@bkma")   @dtw_assign(V_JSBKMA, fieldValue)
                  @Decat_Field("@@prql")   @dtw_assign(V_JSPRQL, fieldValue)
                  @Decat_Field("@@dfwr")   @dtw_assign(V_JSDFWR, fieldValue)
                  @Decat_Field("@@spdt")   @dtw_assign(V_JSSPDT, fieldValue)
                  @Decat_Field("@@redc")   @dtw_assign(V_JSREDC, fieldValue)
                  @Decat_Field("@@prsd")   @dtw_assign(V_JSPRSD, fieldValue)
                  @Decat_Field("@@pgsd")   @dtw_assign(V_JSPGSD, fieldValue)
                  @Decat_Field("@@scdr")   @dtw_assign(V_JSSCDR, fieldValue)
                  @Decat_Field("@@obin")   @dtw_assign(V_JSOBIN, fieldValue)
                  @Decat_Field("@@feed")   @dtw_assign(V_JSFEED, fieldValue)
                  @Decat_Field("@@cnrs")   @dtw_assign(V_JSCNRS, fieldValue)
                  @Decat_Field("@@just")   @dtw_assign(V_JSJUST, fieldValue)
                  @Decat_Field("@@rcl1")   @dtw_assign(V_JSRCL1, fieldValue)
                  @Decat_Field("@@rcl2")   @dtw_assign(V_JSRCL2, fieldValue)
                  @Decat_Field("@@rcl3")   @dtw_assign(V_JSRCL3, fieldValue)
                  @Decat_Field("@@rcl4")   @dtw_assign(V_JSRCL4, fieldValue)
                  @Decat_Field("@@erfe")   @dtw_assign(V_JSERFE, fieldValue)
                  @Decat_Field("@@erfo")   @dtw_assign(V_JSERFO, fieldValue)
                  @Decat_Field("@@estp")   @dtw_assign(V_JSESTP, fieldValue)
