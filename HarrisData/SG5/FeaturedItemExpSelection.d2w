%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Featured Item Explosion"
  d2wName                 = "FeaturedItemExpSelection.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if  (document.Chg.plantNumber.value <="0")
                       {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.plantNumber, 3, 0)
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "FEATUREDITEMEXP")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            	       %INCLUDE "RequiredField.icl"

                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "plantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule, fieldValue)
                                  @DecatErr_Field("@@plt@", "plantNumber")        @dtw_assign(Err_PLT,  fieldValue)
                                  @DecatErr_Field("@@ffam", "featureFamily")      @dtw_assign(Err_FFAM, fieldValue)
                                  @DecatErr_Field("@@item", "itemNumber")         @dtw_assign(Err_ITEM, fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@plt@")  @dtw_assign(V_PLT,  fieldValue)
                                  @Decat_Field("@@ffam")  @dtw_assign(V_FFAM, fieldValue)
                                  @Decat_Field("@@item")  @dtw_assign(V_ITEM, fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                              %else
                                  %if (plantNumber == "")
                                      @RtvDftPlant(plantNumber, plantName)
                                  %endif
                                  %if (plantNumber > "0")
                                      @dtw_assign(V_PLT, plantNumber)
                                  %endif
                                  %if (featureFamily == "F" && featuredItem != "")
                                      @dtw_assign(V_FFAM, featuredItem)
                                  %elif (featuredItem != "")
                                      @dtw_assign(V_ITEM, featuredItem)
                                  %endif
                              %endif

                          </table>

                          <table $(contentTable)>
                              @dtw_assign(fieldDesc, "")
                              %if (V_PLT != "0" && V_PLT != "")
                                  @RtvFldDesc("PLPLNT=$(V_PLT)", "HDPLNT", "PLNAME", fieldDesc)
                              %endif

                              @SetTextOvr(Err_PLT)
                              <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                  <td class="inputnmbr"><input name="plantNumber" value="$(V_PLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=plantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input name="plantName" value="$(fieldDesc)" type="text" size="30" disabled></td>
                              </tr>
                              @DspErrMsg(Err_PLT)

                              @dtw_assign(fieldDesc, "")
                              @RtvFldDesc("IGTYPE='F' and IGIGRP='$(V_FFAM)'", "HDIGPH", "IGDESC", fieldDesc)
                              @SetTextOvr(Err_FFAM)
	                       <tr><td class="dsphdr"><span $(textOvr)>Feature Family</span></td>
                                  <td class="inputalph"><input name="featureFamily" type="text" value="$(V_FFAM)" size="15" maxlength="15"><a href="$(homeURL)$(cGIPath)ItemGroupSearch.d2w/ENTRY$(genericVarBase)&amp;groupType=F&amp;docName=Chg&amp;fldName=featureFamily&amp;fldDesc=featureFamilyDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="featureFamilyDesc" value="$(fieldDesc)" type="text" size="30" disabled></td>
                              </tr>
                              @DspErrMsg(Err_FFAM)

                              @dtw_assign(fieldDesc, "")
                              @RtvFldDesc("IMITEM='$(V_ITEM)'", "HDIMST", "IMIMDS", fieldDesc)
                              @SetTextOvr(Err_ITEM)
                              <tr><td class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="itemNumber" value="$(V_ITEM)"  type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=itemNumber&amp;fldDesc=itemDescription" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="itemDescription" value="$(fieldDesc)" type="text" size="30" disabled></td>
                              </tr>
                              @DspErrMsg(Err_ITEM)
                          </table>

                          @dtw_assign(envProgram, "HHDFOX")
                          @dtw_assign(envPrinter, "")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HHDFOX_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"

  @dtw_assign(plantNumber,@dtw_rstrip(plantNumber))
  @dtw_mUPPERCASE(itemNumber)
  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@ffam", featureFamily)
  @Concat_Field("@@item", itemNumber)
  @Concat_Field("@@user", userProfile)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}