%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Feature / Bi-Level Options"
  d2wName                 = "FeatureBiLevel.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPDFOM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
  plantNumber             = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @dtw_assign(userPass, "")
  %if (plantNumber > "0")
      @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %endif
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
             %INCLUDE "$(headInclude)"
             <script TYPE="text/javascript">
                 %INCLUDE "CheckEnterSearch.icl"
                 %INCLUDE "Menu.js"
                 %INCLUDE "NoFormValidate.icl"
                 function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
             </script>
             %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
             <!-- Start Of Banner Code -->
             %INCLUDE "banner.icl"
             <!-- End Of Banner Code -->
             <table $(baseTable)>
                 <tr valign="top">
                     %if (formatToPrint == "")
                         @dtw_assign(pageID, "FEATUREBILEVEL")
                         <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                     %endif
                     <td class="content">
                         @dtw_assign(uv_PlantName, "FOPLT")
                         %INCLUDE "userview.icl"

                         %INCLUDE "stmtSQLClear.icl"
                         @dtw_concat(distinctSQL, "digits(FOPLT) concat FOFEAT concat FOFPRT concat FOFDSC", distinctSQL)
                         @dtw_concat(stmtSQL, " Select FOPLT, FOFEAT, FOFPRT, FOFDSC, ", stmtSQL)
                         @dtw_concat(stmtSQL, "upper(FOFDSC) as FOFDSCU " , stmtSQL)
                         %if (plantNumber == "")
                             @dtw_concat(stmtSQL, " , coalesce(PLNAME,' ') as PLNAME, ", stmtSQL)
                             @dtw_concat(stmtSQL, " coalesce(upper(PLNAME),' ') as PLNAMEU ", stmtSQL)
                         %endif
                         @dtw_concat(fileSQL, " HDMFOP", fileSQL)
                         %if (plantNumber == "")
                             @dtw_concat(fileSQL, " left join HDPLNT on FOPLT=PLPLNT ", fileSQL)
                         %endif
                         %if (wildCardSearch!="" || plantNumber>"0" || uv_Sql!="")
                             @dtw_concat(selectSQL, "FOFEAT>' ' ", selectSQL)
                         %endif
                         %if (plantNumber > "0")
                         @dtw_concat(selectSQL, " and FOPLT=$(plantNumber)", selectSQL)
                         %endif
                         %INCLUDE "stmtSQLSelect.icl"
                         @dtw_concat(stmtSQL, " Group By FOPLT, FOFEAT, FOFPRT, FOFDSC", stmtSQL)
                         %if (plantNumber == "")
                             @dtw_concat(stmtSQL, " , PLNAME", stmtSQL)
                         %endif
                         @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                         %INCLUDE "stmtSQLEnd.icl"
                         %INCLUDE "stmtSQLTotalRows.icl"
                         @FeatureBiLevel_Query(profileHandle, dataBaseID, stmtSQL)
                     </td>
                 </tr>
             </table>
             <!-- Start Of Trailer Code -->
             %INCLUDE "trailer.icl"
             <!-- End Of Trailer Code -->
        </body>
     </html>
  %endif
%}

%FUNCTION(dtw_sql) FeatureBiLevel_Query (IN CHAR(64)    profileHandle,
                                            CHAR(2)     dataBaseID,
                                            CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                         <a href="$(homeURL)$(cGIPath)FeatureOptionMaintain.d2w/ADD$(genericVarBase)&amp;selectPlant=@dtw_rurlescseq(plantNumber)&amp;maintenanceCodeFB=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      %if (plantNumber > "0")
          @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
          <table $(contentTable)>
              @Format_Header_URL("Plant", $(plantName), $(plantNumber), "$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(d2wVarBase)")
          </table>
      %endif
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search"   onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr"> Feature /<br>Bi-Level </th>
                      <th class="colhdr"> Featured Item/<br>Family </th>
                      <th class="colhdr"> Description </th>
                      %if (plantNumber == "")
                          <th class="colhdr">Plant</th>
                      %endif
                  </tr>
                  <tr><td><input type="text" class="inputalph"  name="srchFeature" size="15" maxlength="15">
                          <input type="hidden" name="operFeature" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph"  name="srchItem" size="15" maxlength="15">
                          <input type="hidden" name="operItem" value="LIKE">
                      </td>
                      <td align=center><input type="text" class="inputalph"  name="srchDesc" size="15" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      %if (plantNumber == "")
                          <td><input type="text" class="inputnmbr" name="srchPlant" size="5" maxlength="3">
                              <input type="hidden" name="operPlant" value="=">
                          </td>
                      %endif
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchFeature.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @OrderBy_Sort("FOFEAT", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=feature" title="Sequence By Feature/Bi-Level"> Feature /<br>Bi-Level</a></th>
              @OrderBy_Sort("FOFPRT", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=featuredItem" title="Sequence By Featured Item"> Featured Item/<br>Family </a></th>
              @OrderBy_Sort("FOFDSCU", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=featureDesc" title="Sequence By Description"> Description</a></th>
              %if (plantNumber == "")
                  @OrderBy_Sort("FOPLT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlantNumber" title="Sequence By Plant">Plant</a></th>
                  @OrderBy_Sort("PLNAMEU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlantName" title="Sequence By Plant Name">Plant Name</a></th>
              %endif
              <th class="colhdr">B/L</th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(genericVarBase)&amp;selectPlant=@dtw_rurlescseq(plantNumber)&amp;plantNumber=@dtw_rurlescseq(V_FOPLT)&amp;feature=@dtw_rurlescseq(V_FOFEAT)&amp;featuredItem=@dtw_rurlescseq(V_FOFPRT)&amp;featureDesc=@dtw_rurlescseq(V_FOFDSC)")
              %INCLUDE "SetRowClass.icl"
              %if (V_FOFPRT == "")
                  @Format_Confirm_Desc($(V_FOFEAT), "", "", "", "", "", confirmDesc)
              %else
                  @Format_Confirm_Desc($(V_FOFEAT), "", $(V_FOFPRT), "", "", "", confirmDesc)
              %endif
              @RtvFldDesc("FOPLT=$(V_FOPLT) and FOOPTN='$(V_FOFEAT)'", "HDMFOP","FOBLOP", biLevel)
              %if (V_FOFPRT != "")
                  @RtvFldDesc("FIPLT=$(V_FOPLT) and FIFEAT='$(V_FOFEAT)' and FIFPRT='$(V_FOFPRT)'", "HDMFIT","CHAR(COUNT(FIFEAT))", featureAssigned)
              %else
                  @RtvFldDesc("FIPLT=$(V_FOPLT) and FIFEAT='$(V_FOFEAT)'", "HDMFIT","CHAR(COUNT(FIFEAT))", featureAssigned)
              %endif

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || (sec_03 == "Y" && biLevel != "Y" && featureAssigned == "0"))
                              <a href="$(homeURL)$(cGIPath)FeatureOption.d2w/BUILD$(maintainVar)&amp;maintenanceCodeFB=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)FeatureOptionMaintain.d2w/ADD$(genericVarBase)&amp;selectPlant=@dtw_rurlescseq(plantNumber)&amp;fromPlant=@dtw_rurlescseq(V_FOPLT)&amp;fromFeature=@dtw_rurlescseq(V_FOFEAT)&amp;fromFeaturedItem=@dtw_rurlescseq(V_FOFPRT)&amp;maintenanceCodeFB=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y" && biLevel != "Y" && featureAssigned == "0")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)FeatureOption.d2w/ACCEPT$(maintainVar)&amp;maintenanceCodeFB=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">
                      %if (sec_02 == "Y" || sec_03 == "Y")
                          <a href="$(homeURL)$(cGIPath)FeatureOptionMaintain.d2w/CHANGE$(maintainVar)&amp;maintenanceCodeFB=C" title="Change Feature / Bi-Level Description">$(V_FOFEAT)</a>
                      %else
                          $(V_FOFEAT)
                      %endif
                  </td>
                  <td class="colalph">$(V_FOFPRT)</td>
                  <td class="colalph">$(V_FOFDSC)</td>
                  %if (plantNumber == "")
                      <td class="colnmbr">$(V_FOPLT)</td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(V_FOPLT)&amp;plantName=@dtw_rurlescseq(V_PLNAME)" title="View Plant">$(V_PLNAME)</a></td>
                  %endif
                  <td class="colcode">$(biLevel)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (plantNumber > "0" && orderBy == "PLNAMEU,FOFEAT,FOFPRT")
          @dtw_assign(orderBy, "")
      %endif
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "FOFEAT, FOFPRT")
          @DTW_ASSIGN(orderByDisplay, "Feature")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "feature")
      %if (orderBy == "FOFEAT, FOFPRT")
          @DTW_ASSIGN(orderBy, "FOFEAT DESC, FOFPRT")
          @DTW_ASSIGN(orderByDisplay, "Feature/Bi-Level (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FOFEAT, FOFPRT")
          @DTW_ASSIGN(orderByDisplay, "Feature/Bi-Level")
      %endif
  %elif (sequence == "featuredItem")
      %if (orderBy == "FOFPRT, FOFEAT")
          @DTW_ASSIGN(orderBy, "FOFPRT DESC, FOFEAT")
          @DTW_ASSIGN(orderByDisplay, "Featured Item/Family (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FOFPRT, FOFEAT")
          @DTW_ASSIGN(orderByDisplay, "Featured Item/Family")
      %endif
  %elif (sequence == "featureDesc")
      %if (orderBy == "FOFDSCU, FOFEAT, FOFPRT")
          @DTW_ASSIGN(orderBy, "FOFDSCU DESC, FOFEAT, FOFPRT")
          @DTW_ASSIGN(orderByDisplay, "Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FOFDSCU, FOFEAT, FOFPRT")
          @DTW_ASSIGN(orderByDisplay, "Description")
      %endif
  %elif (sequence == "PlantNumber")
      %if (orderBy == "FOPLT,FOFEAT,FOFPRT")
          @DTW_ASSIGN(orderBy, "FOPLT DESC,FOFEAT,FOFPRT")
          @DTW_ASSIGN(orderByDisplay, "Plant Number (descending), Feature, Featured Item")
      %else
          @DTW_ASSIGN(orderBy, "FOPLT,FOFEAT,FOFPRT")
          @DTW_ASSIGN(orderByDisplay, "Plant Number, Feature, Featured Item")
      %endif
  %elif (sequence == "PlantName")
      %if (orderBy == "PLNAMEU,FOFEAT,FOFPRT")
          @DTW_ASSIGN(orderBy, "PLNAMEU DESC,FOFEAT,FOFPRT")
          @DTW_ASSIGN(orderByDisplay, "Plant Name (descending), Feature, Featured Item")
      %else
          @DTW_ASSIGN(orderBy, "PLNAMEU,FOFEAT,FOFPRT")
          @DTW_ASSIGN(orderByDisplay, "Plant Name, Feature, Featured Item")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("FOFEAT", "Feature/Bi-Level", $(srchFeature), "U", operFeature, "A")
  @Build_WildCard ("FOFPRT", "Featured Item/Family", $(srchItem), "U", operItem, "A")
  @Build_WildCard ("upper(FOFDSC)", "Description", $(srchDesc), "U", operDesc, "A")
  %if (plantNumber == "")
      @Build_WildCard ("FOPLT", "Plant Number", $(srchPlant), "", operPlant, "N")
      @Build_WildCard ("upper(PLNAME)", "Plant Name", $(srchName), "U", operName, "A")
  %endif

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
