%Define {
  page_title              = "Labor Update Audit Report"
  d2wName                 = "LaborUpdateAuditReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  forPlant                = ""
  sortSeqMax              = "9"
  sortPlantNumber         = "1"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {

                  if (editNum(document.Chg.fromPlantNumber, 3, 0) &&
                      editNum(document.Chg.toPlantNumber, 3, 0) &&
                      editNum(document.Chg.fromRoutingSequence, 3, 0) &&
                      editNum(document.Chg.toRoutingSequence, 3, 0) &&
                      editNum(document.Chg.fromEmployeeNumber, 5, 0) &&
                      editNum(document.Chg.toEmployeeNumber, 5, 0) &&
                      editdate(document.Chg.fromDateWorked) &&
                      editdate(document.Chg.toDateWorked) &&
                      editNum(document.Chg.fromShiftWorked, 1, 0) &&
                      editNum(document.Chg.toShiftWorked, 1, 0) &&
                      editFromToAll(document.Chg.fromPlantNumber, document.Chg.toPlantNumber, document.Chg.allPlantNumber, 3) &&
                      editFromToAll(document.Chg.fromDepartment, document.Chg.toDepartment, document.Chg.allDepartment, "A") &&
                      editFromToAll(document.Chg.fromWorkCenter, document.Chg.toWorkCenter, document.Chg.allWorkCenter, "A") &&
                      editFromToAll(document.Chg.fromOrderNumber, document.Chg.toOrderNumber, document.Chg.allOrderNumber, "A") &&
                      editFromToAll(document.Chg.fromRoutingSequence, document.Chg.toRoutingSequence, document.Chg.allRoutingSequence, 3) &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromEmployeeNumber, document.Chg.toEmployeeNumber, document.Chg.allEmployeeNumber, 5) &&
                      editFromToAll(document.Chg.fromDateWorked, document.Chg.toDateWorked, document.Chg.allDateWorked, "D") &&
                      editFromToAll(document.Chg.fromShiftWorked, document.Chg.toShiftWorked, document.Chg.allShiftWorked, 1)
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "LABORUPDATEAUDITREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromPlantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@fplt", "fromPlantNumber")        @dtw_assign(Err_N2FPLT,  fieldValue)
                                  @DecatErr_Field("@@splt", "sortPlantNumber")        @dtw_assign(Err_N2SPLT,  fieldValue)
                                  @DecatErr_Field("@@sdpt", "sortDepartment")        @dtw_assign(Err_N2SDPT,  fieldValue)
                                  @DecatErr_Field("@@sdwc", "sortWorkCenter")        @dtw_assign(Err_N2SDWC,  fieldValue)
                                  @DecatErr_Field("@@sord", "sortOrderNumber")        @dtw_assign(Err_N2SORD,  fieldValue)
                                  @DecatErr_Field("@@srsq", "sortRoutingSequence")        @dtw_assign(Err_N2SRSQ,  fieldValue)
                                  @DecatErr_Field("@@sitm", "sortItemNumber")        @dtw_assign(Err_N2SITM,  fieldValue)
                                  @DecatErr_Field("@@semp", "sortEmployeeNumber")        @dtw_assign(Err_N2SEMP,  fieldValue)
                                  @DecatErr_Field("@@sldt", "sortDateWorked")        @dtw_assign(Err_N2SLDT,  fieldValue)
                                  @DecatErr_Field("@@ssft", "sortShiftWorked")        @dtw_assign(Err_N2SSFT,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@seln")  @dtw_assign(V_N1SELN,  fieldValue)

                                  @Decat_Field("@@fplt")  @dtw_assign(V_N2FPLT,  fieldValue)
                                  @Decat_Field("@@tplt")  @dtw_assign(V_N2TPLT,  fieldValue)
                                  @Decat_Field("@@aplt")  @dtw_assign(V_N2APLT,  fieldValue)
                                  @Decat_Field("@@splt")  @dtw_assign(V_N2SPLT,  fieldValue)
                                  @Decat_Field("@@pplt")  @dtw_assign(V_N2PPLT,  fieldValue)

                                  @Decat_Field("@@fdpt")  @dtw_assign(V_N2FDPT,  fieldValue)
                                  @Decat_Field("@@tdpt")  @dtw_assign(V_N2TDPT,  fieldValue)
                                  @Decat_Field("@@adpt")  @dtw_assign(V_N2ADPT,  fieldValue)
                                  @Decat_Field("@@sdpt")  @dtw_assign(V_N2SDPT,  fieldValue)
                                  @Decat_Field("@@pdpt")  @dtw_assign(V_N2PDPT,  fieldValue)

                                  @Decat_Field("@@fdwc")  @dtw_assign(V_N2FDWC,  fieldValue)
                                  @Decat_Field("@@tdwc")  @dtw_assign(V_N2TDWC,  fieldValue)
                                  @Decat_Field("@@adwc")  @dtw_assign(V_N2ADWC,  fieldValue)
                                  @Decat_Field("@@sdwc")  @dtw_assign(V_N2SDWC,  fieldValue)
                                  @Decat_Field("@@pdwc")  @dtw_assign(V_N2PDWC,  fieldValue)

                                  @Decat_Field("@@ford")  @dtw_assign(V_N2FORD,  fieldValue)
                                  @Decat_Field("@@tord")  @dtw_assign(V_N2TORD,  fieldValue)
                                  @Decat_Field("@@aord")  @dtw_assign(V_N2AORD,  fieldValue)
                                  @Decat_Field("@@sord")  @dtw_assign(V_N2SORD,  fieldValue)
                                  @Decat_Field("@@pord")  @dtw_assign(V_N2PORD,  fieldValue)

                                  @Decat_Field("@@frsq")  @dtw_assign(V_N2FRSQ,  fieldValue)
                                  @Decat_Field("@@trsq")  @dtw_assign(V_N2TRSQ,  fieldValue)
                                  @Decat_Field("@@arsq")  @dtw_assign(V_N2ARSQ,  fieldValue)
                                  @Decat_Field("@@srsq")  @dtw_assign(V_N2SRSQ,  fieldValue)
                                  @Decat_Field("@@prsq")  @dtw_assign(V_N2PRSQ,  fieldValue)

                                  @Decat_Field("@@fitm")  @dtw_assign(V_N2FITM, fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N2TITM, fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N2AITM, fieldValue)
                                  @Decat_Field("@@sitm")  @dtw_assign(V_N2SITM, fieldValue)
                                  @Decat_Field("@@pitm")  @dtw_assign(V_N2PITM, fieldValue)

                                  @Decat_Field("@@femp")  @dtw_assign(V_N2FEMP, fieldValue)
                                  @Decat_Field("@@temp")  @dtw_assign(V_N2TEMP, fieldValue)
                                  @Decat_Field("@@aemp")  @dtw_assign(V_N2AEMP, fieldValue)
                                  @Decat_Field("@@semp")  @dtw_assign(V_N2SEMP, fieldValue)
                                  @Decat_Field("@@pemp")  @dtw_assign(V_N2PEMP, fieldValue)

                                  @Decat_Field("@@fldt")  @dtw_assign(V_N2FLDT, fieldValue)
                                  @Decat_Field("@@tldt")  @dtw_assign(V_N2TLDT, fieldValue)
                                  @Decat_Field("@@aldt")  @dtw_assign(V_N2ALDT, fieldValue)
                                  @Decat_Field("@@sldt")  @dtw_assign(V_N2SLDT, fieldValue)
                                  @Decat_Field("@@pldt")  @dtw_assign(V_N2PLDT, fieldValue)

                                  @Decat_Field("@@fsft")  @dtw_assign(V_N2FSFT, fieldValue)
                                  @Decat_Field("@@tsft")  @dtw_assign(V_N2TSFT, fieldValue)
                                  @Decat_Field("@@asft")  @dtw_assign(V_N2ASFT, fieldValue)
                                  @Decat_Field("@@ssft")  @dtw_assign(V_N2SSFT, fieldValue)
                                  @Decat_Field("@@psft")  @dtw_assign(V_N2PSFT, fieldValue)


                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries
 Values %}
                                  %if (V_N1SELN == "02")
                                      @dtw_assign(no, "")
                                      @dtw_assign(yes, "CHECKED")
                                  %else
                                      @dtw_assign(no, "CHECKED")
                                      @dtw_assign(yes, "")
                                  %endif
                                  %if (V_N2APLT == "ALL")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPlantNumber, "")
                                  %endif
                                  %if (V_N2ADPT == "ALL")
                                      @dtw_assign(checkedallDepartment, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallDepartment, "")
                                  %endif
                                  %if (V_N2ADWC == "ALL")
                                      @dtw_assign(checkedallWorkCenter, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallWorkCenter, "")
                                  %endif
                                  %if (V_N2AORD == "ALL")
                                      @dtw_assign(checkedallOrderNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallOrderNumber, "")
                                  %endif
                                  %if (V_N2ARSQ == "ALL")
                                      @dtw_assign(checkedallRoutingSequence, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallRoutingSequence, "")
                                  %endif
                                  %if (V_N2AITM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_N2AEMP == "ALL")
                                      @dtw_assign(checkedallEmployeeNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallEmployeeNumber, "")
                                  %endif
                                  %if (V_N2ALDT == "ALL")
                                      @dtw_assign(checkedallDateWorked, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallDateWorked, "")
                                  %endif
                                  %if (V_N2ASFT == "ALL")
                                      @dtw_assign(checkedallShiftWorked, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallShiftWorked, "")
                                  %endif

                                  %if (V_N2PPLT == "Y")
                                      @dtw_assign(checkedPlantNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedPlantNumberTotals, "")
                                  %endif
                                  %if (V_N2PDPT == "Y")
                                      @dtw_assign(checkedDepartmentTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedDepartmentTotals, "")
                                  %endif
                                  %if (V_N2PDWC == "Y")
                                      @dtw_assign(checkedWorkCenterTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedWorkCenterTotals, "")
                                  %endif
                                  %if (V_N2PORD == "Y")
                                      @dtw_assign(checkedOrderNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedOrderNumberTotals, "")
                                  %endif
                                  %if (V_N2PRSQ == "Y")
                                      @dtw_assign(checkedRoutingSequenceTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedRoutingSequenceTotals, "")
                                  %endif
                                  %if (V_N2PITM == "Y")
                                      @dtw_assign(checkedItemNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedItemNumberTotals, "")
                                  %endif
                                  %if (V_N2PEMP == "Y")
                                      @dtw_assign(checkedEmployeeNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedEmployeeNumberTotals, "")
                                  %endif
                                  %if (V_N2PLDT == "Y")
                                      @dtw_assign(checkedDateWorkedTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedDateWorkedTotals, "")
                                  %endif
                                  %if (V_N2PSFT == "Y")
                                      @dtw_assign(checkedShiftWorkedTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedShiftWorkedTotals, "")
                                  %endif
                              %else
                                  @dtw_assign(no, "CHECKED")
                                  @dtw_assign(yes, "")
                                  @RtvDftPlant(plantNumber, plantName)
                                  %if (plantNumber == "0")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(V_N2FPLT, plantNumber)
                                      @dtw_assign(V_N2TPLT, plantNumber)
                                      @dtw_assign(checkedallPlantNumber, "")
                                      @dtw_assign(focusField, "fromDepartment")
                                  %endif
                                  @dtw_assign(checkedallDepartment, "CHECKED")
                                  @dtw_assign(checkedallWorkCenter, "CHECKED")
                                  @dtw_assign(checkedallOrderNumber, "CHECKED")
                                  @dtw_assign(checkedallRoutingSequence, "CHECKED")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallEmployeeNumber, "CHECKED")
                                  @dtw_assign(checkedallDateWorked, "CHECKED")
                                  @dtw_assign(checkedallShiftWorked, "CHECKED")

                                  @dtw_assign(checkedPlantNumberTotals, "CHECKED")
                                  @dtw_assign(checkedDepartmentTotals, "")
                                  @dtw_assign(checkedWorkCenterTotals, "")
                                  @dtw_assign(checkedOrderNumberTotals, "")
                                  @dtw_assign(checkedRoutingSequenceTotals, "")
                                  @dtw_assign(checkedItemNumberTotals, "")
                                  @dtw_assign(checkedEmployeeNumberTotals, "")
                                  @dtw_assign(checkedDateWorkedTotals, "")
                                  @dtw_assign(checkedShiftWorkedTotals, "")
                              %endif

                          <tr><td class="dsphdr"><span $(textOvr)>Print Previously Printed Transactions </span></td>
                                  <td class="inputnmbr"><input name="previouslyPrinted" type="radio" VALUE='01' $(no)>No</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="previouslyPrinted" type="radio" VALUE='02' $(yes)>Yes</td>
                          </tr>

                          </table>

                          <table $(contentTable)>

                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                                  <td class="colhdr">Print<br>Totals</td>
                              </tr>

                              @SetTextOvr(Err_N2FPLT)
                              %if (textOvr == "") @SetTextOvr(Err_N2SPLT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                  <td class="inputnmbr"><input name="fromPlantNumber" value="$(V_N2FPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromPlantNumber&amp;fldDesc=fplantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fplantName"  type="hidden"></td>
                                  <td class="inputnmbr"><input name="toPlantNumber" value="$(V_N2TPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toPlantNumber&amp;fldDesc=tplantName" onclick="$(searchWinVar)">  $(searchImage) </a><input name="tplantName"  type="hidden"></td>
                                  <td class="inputalph"><input name="allPlantNumber" value='ALL' $(checkedallPlantNumber) type="checkbox" onClick="if (this.checked) this.form.fromPlantNumber.value='', this.form.toPlantNumber.value='';"></td>
                                  <td class="colcode"><input name="sortPlantNumber" type="hidden"  Value="$(sortPlantNumber)" size="1" maxlength="1">$(sortPlantNumber)</td>
                                  <td align=center ><input name="totalPlantNumber" type="checkbox" $(checkedPlantNumberTotals) disabled VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2FPLT)
                              @DspErrMsg(Err_N2SPLT)

                              @SetTextOvr(Err_N2SDPT)
                              <tr><td class="dsphdr"><span $(textOvr)>Department </span></td>
                                  <td class="inputalph"><input name="fromDepartment" value="$(V_N2FDPT)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=fromDepartment&amp;fldWC=fromWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="toDepartment" value="$(V_N2TDPT)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=toDepartment&amp;fldWC=toWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="allDepartment" value='ALL' $(checkedallDepartment) type="checkbox" onClick="if (this.checked) this.form.fromDepartment.value='', this.form.toDepartment.value='';"></td>
                                  @Build_Sort_Select("sortDepartment", "$(V_N2SDPT)")
                                  <td align=center ><input name="totalDepartment" type="checkbox" $(checkedDepartmentTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2SDPT)

                              @SetTextOvr(Err_N2SDWC)
                              <tr><td class="dsphdr"><span $(textOvr)>Work Center </span></td>
                                  <td class="inputalph"><input name="fromWorkCenter" value="$(V_N2FDWC)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=fromDepartment&amp;fldWC=fromWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="toWorkCenter" value="$(V_N2TDWC)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=toDepartment&amp;fldWC=toWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="allWorkCenter" value='ALL' $(checkedallWorkCenter) type="checkbox" onClick="if (this.checked) this.form.fromWorkCenter.value='', this.form.toWorkCenter.value='';"></td>
                                  @Build_Sort_Select("sortWorkCenter", "$(V_N2SDWC)")
                                  <td align=center ><input name="totalWorkCenter" type="checkbox" $(checkedWorkCenterTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2SDWC)

                              @SetTextOvr(Err_N2SORD)
                              <tr><td class="dsphdr"><span $(textOvr)>Order Number</span></td>
                                  <td class="inputalph"><input name="fromOrderNumber" value="$(V_N2FORD)" type="text" size="15" maxlength="9"><a href="$(homeURL)$(phpPath)MfgOrderSearch.php$(altVarBase)&amp;docName=Chg&amp;forPlant=$(forPlant)&amp;fldorder=fromOrderNumber" onclick="$(searchWinVar)">  $(searchImage) </a></td>
                                  <td class="inputalph"><input name="toOrderNumber" value="$(V_N2TORD)" type="text" size="15" maxlength="9"><a href="$(homeURL)$(phpPath)MfgOrderSearch.php$(altVarBase)&amp;docName=Chg&amp;forPlant=$(forPlant)&amp;fldorder=toOrderNumber" onclick="$(searchWinVar)">  $(searchImage) </a></td>
                                  <td class="inputalph"><input name="allOrderNumber" value='ALL' $(checkedallOrderNumber) type="checkbox" onClick="if (this.checked) this.form.fromOrderNumber.value='', this.form.toOrderNumber.value='';"></td>
                                  @Build_Sort_Select("sortOrderNumber", "$(V_N2SORD)")
                                  <td align=center ><input name="totalOrderNumber" type="checkbox" $(checkedOrderNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2SORD)

                              @SetTextOvr(Err_N2SRSQ)
                              <tr><td class="dsphdr"><span $(textOvr)>Routing Sequence</span></td>
                                  <td class="inputalph"><input name="fromRoutingSequence" value="$(V_N2FRSQ)" type="text" size="3" maxlength="3"></td>
                                  <td class="inputalph"><input name="toRoutingSequence" value="$(V_N2TRSQ)" type="text" size="3" maxlength="3"></td>
                                  <td class="inputalph"><input name="allRoutingSequence" value='ALL' $(checkedallRoutingSequence) type="checkbox" onClick="if (this.checked) this.form.fromRoutingSequence.value='', this.form.toRoutingSequence.value='';"></td>
                                  @Build_Sort_Select("sortRoutingSequence", "$(V_N2SRSQ)")
                                  <td align=center ><input name="totalRoutingSequence" type="checkbox" $(checkedRoutingSequenceTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2SRSQ)

                              @SetTextOvr(Err_N2SITM)
                              <tr><td class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N2FITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N2TITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                                  @Build_Sort_Select("sortItemNumber", "$(V_N2SITM)")
                                  <td align=center ><input name="totalItemNumber" type="checkbox" $(checkedItemNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2SITM)

                              @SetTextOvr(Err_N2SEMP)
                              <tr><td class="dsphdr"><span $(textOvr)>Employee Number</span></td>
                                  <td class="inputalph"><input name="fromEmployeeNumber" value="$(V_N2FEMP)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)EmployeeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=prCompany&amp;fldFacl=prFacility&amp;fldEmpl=fromEmployeeNumber&amp;fldHRCo=hrCompany&amp;fldHREmpl=hrEmployee&amp;fldEmplName=prName&amp;fldCoName=coFacDescription" onclick="$(searchWinVar)">$(searchImage)</a><input name="prCompany" type="hidden"><input name="prFacility" type="hidden"><input name="hrEmployee" type="hidden"><input name="hrCompany"  type="hidden"><input name="prName"  type="hidden"><input name="coFacDescription"  type="hidden"></td>
                                  <td class="inputalph"><input name="toEmployeeNumber" value="$(V_N2TEMP)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)EmployeeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=prCompany&amp;fldFacl=prFacility&amp;fldEmpl=toEmployeeNumber&amp;fldHRCo=hrCompany&amp;fldHREmpl=hrEmployee&amp;fldEmplName=prName&amp;fldCoName=coFacDescription" onclick="$(searchWinVar)">$(searchImage)</a><input name="prCompany" type="hidden"><input name="prFacility" type="hidden"><input name="hrEmployee" type="hidden"><input name="hrCompany"  type="hidden"><input name="prName"  type="hidden"><input name="coFacDescription"  type="hidden"></td>
                                  <td class="inputalph"><input name="allEmployeeNumber" value='ALL' $(checkedallEmployeeNumber) type="checkbox" onClick="if (this.checked) this.form.fromEmployeeNumber.value='', this.form.toEmployeeNumber.value='';"></td>
                                  @Build_Sort_Select("sortEmployeeNumber", "$(V_N2SEMP)")
                                  <td align=center ><input name="totalEmployeeNumber" type="checkbox" $(checkedEmployeeNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2SEMP)

                              @SetTextOvr(Err_N2SLDT)
                              <tr><td class="dsphdr"><span $(textOvr)>Date Worked</span></td>
                                  <td class="inputnmbr"><input name="fromDateWorked" value="$(V_N2FLDT)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromDateWorked');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toDateWorked" value="$(V_N2TLDT)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toDateWorked');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allDateWorked" value='ALL' $(checkedallDateWorked) type="checkbox" onClick="if (this.checked) this.form.fromDateWorked.value='', this.form.toDateWorked.value='';"></td>
                                  @Build_Sort_Select("sortDateWorked", "$(V_N2SLDT)")
                                  <td align=center ><input name="totalDateWorked" type="checkbox" $(checkedDateWorkedTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2SLDT)

                              @SetTextOvr(Err_N2SSFT)
                              <tr><td class="dsphdr"><span $(textOvr)>Shift Worked</span></td>
                                  <td class="inputalph"><input name="fromShiftWorked" value="$(V_N2FSFT)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="toShiftWorked" value="$(V_N2TSFT)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="allShiftWorked" value='ALL' $(checkedallShiftWorked) type="checkbox" onClick="if (this.checked) this.form.fromShiftWorked.value='', this.form.toShiftWorked.value='';"></td>
                                  @Build_Sort_Select("sortShiftWorked", "$(V_N2SSFT)")
                                  <td align=center ><input name="totalShiftWorked" type="checkbox" $(checkedShiftWorkedTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N2SSFT)

                          </table>

                          @dtw_assign(envProgram, "HSILAL")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSILAS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allPlantNumber)
  @dtw_mUPPERCASE(fromDepartment)
  @dtw_mUPPERCASE(toDepartment)
  @dtw_mUPPERCASE(allDepartment)
  @dtw_mUPPERCASE(fromWorkCenter)
  @dtw_mUPPERCASE(toWorkCenter)
  @dtw_mUPPERCASE(allWorkCenter)
  @dtw_mUPPERCASE(fromOrderNumber)
  @dtw_mUPPERCASE(toOrderNumber)
  @dtw_mUPPERCASE(allOrderNumber)
  @dtw_mUPPERCASE(allRoutingSequence)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(allEmployeeNumber)
  @dtw_mUPPERCASE(allDateWorked)
  @dtw_mUPPERCASE(allShiftWorked)

  @dtw_assign(fromPlantNumber,@dtw_rstrip(fromPlantNumber))
  @dtw_assign(toPlantNumber,@dtw_rstrip(toPlantNumber))
  @dtw_assign(sortPlantNumber,@dtw_rstrip(sortPlantNumber))
  @dtw_assign(sortDepartment,@dtw_rstrip(sortDepartment))
  @dtw_assign(sortWorkCenter,@dtw_rstrip(sortWorkCenter))
  @dtw_assign(sortOrderNumber,@dtw_rstrip(sortOrderNumber))
  @dtw_assign(fromRoutingSequence,@dtw_rstrip(fromRoutingSequence))
  @dtw_assign(toRoutingSequence,@dtw_rstrip(toRoutingSequence))
  @dtw_assign(sortRoutingSequence,@dtw_rstrip(sortRoutingSequence))
  @dtw_assign(sortItemNumber,@dtw_rstrip(sortItemNumber))
  @dtw_assign(fromEmployeeNumber,@dtw_rstrip(fromEmployeeNumber))
  @dtw_assign(toEmployeeNumber,@dtw_rstrip(toEmployeeNumber))
  @dtw_assign(sortEmployeeNumber,@dtw_rstrip(sortEmployeeNumber))
  @dtw_assign(fromDateWorked,@dtw_rstrip(fromDateWorked))
  @dtw_assign(toDateWorked,@dtw_rstrip(toDateWorked))
  @dtw_assign(sortDateWorked,@dtw_rstrip(sortDateWorked))
  @dtw_assign(fromShiftWorked,@dtw_rstrip(fromShiftWorked))
  @dtw_assign(toShiftWorked,@dtw_rstrip(toShiftWorked))
  @dtw_assign(sortShiftWorked,@dtw_rstrip(sortShiftWorked))

  %if (allPlantNumber != "ALL")
      @dtw_assign(allPlantNumber, "")
  %endif
  %if (allDepartment != "ALL")
      @dtw_assign(allDepartment, "")
  %endif
  %if (allWorkCenter != "ALL")
      @dtw_assign(allWorkCenter, "")
  %endif
  %if (allOrderNumber != "ALL")
      @dtw_assign(allOrderNumber, "")
  %endif
  %if (allRoutingSequence != "ALL")
      @dtw_assign(allRoutingSequence, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allEmployeeNumber != "ALL")
      @dtw_assign(allEmployeeNumber, "")
  %endif
  %if (allDateWorked != "ALL")
      @dtw_assign(allDateWorked, "")
  %endif
  %if (allShiftWorked != "ALL")
      @dtw_assign(allShiftWorked, "")
  %endif

  @dtw_assign(totalPlantNumber, "Y")

  %if (totalDepartment != "Y")
      @dtw_assign(totalDepartment, "N")
  %endif
  %if (totalWorkCenter != "Y")
      @dtw_assign(totalWorkCenter, "N")
  %endif
  %if (totalOrderNumber != "Y")
      @dtw_assign(totalOrderNumber, "N")
  %endif
  %if (totalRoutingSequence != "Y")
      @dtw_assign(totalRoutingSequence, "N")
  %endif
  %if (totalItemNumber != "Y")
      @dtw_assign(totalItemNumber, "N")
  %endif
  %if (totalEmployeeNumber != "Y")
      @dtw_assign(totalEmployeeNumber, "N")
  %endif
  %if (totalDateWorked != "Y")
      @dtw_assign(totalDateWorked, "N")
  %endif
  %if (totalShiftWorked != "Y")
      @dtw_assign(totalShiftWorked, "N")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@seln", previouslyPrinted)

  @Concat_Field("@@fplt", fromPlantNumber)
  @Concat_Field("@@tplt", toPlantNumber)
  @Concat_Field("@@aplt", allPlantNumber)
  @Concat_Field("@@splt", sortPlantNumber)
  @Concat_Field("@@pplt", totalPlantNumber)

  @Concat_Field("@@fdpt", fromDepartment)
  @Concat_Field("@@tdpt", toDepartment)
  @Concat_Field("@@adpt", allDepartment)
  @Concat_Field("@@sdpt", sortDepartment)
  @Concat_Field("@@pdpt", totalDepartment)

  @Concat_Field("@@fdwc", fromWorkCenter)
  @Concat_Field("@@tdwc", toWorkCenter)
  @Concat_Field("@@adwc", allWorkCenter)
  @Concat_Field("@@sdwc", sortWorkCenter)
  @Concat_Field("@@pdwc", totalWorkCenter)

  @Concat_Field("@@ford", fromOrderNumber)
  @Concat_Field("@@tord", toOrderNumber)
  @Concat_Field("@@aord", allOrderNumber)
  @Concat_Field("@@sord", sortOrderNumber)
  @Concat_Field("@@pord", totalOrderNumber)

  @Concat_Field("@@frsq", fromRoutingSequence)
  @Concat_Field("@@trsq", toRoutingSequence)
  @Concat_Field("@@arsq", allRoutingSequence)
  @Concat_Field("@@srsq", sortRoutingSequence)
  @Concat_Field("@@prsq", totalRoutingSequence)

  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@sitm", sortItemNumber)
  @Concat_Field("@@pitm", totalItemNumber)

  @Concat_Field("@@femp", fromEmployeeNumber)
  @Concat_Field("@@temp", toEmployeeNumber)
  @Concat_Field("@@aemp", allEmployeeNumber)
  @Concat_Field("@@semp", sortEmployeeNumber)
  @Concat_Field("@@pemp", totalEmployeeNumber)

  @Concat_Field("@@fldt", fromDateWorked)
  @Concat_Field("@@tldt", toDateWorked)
  @Concat_Field("@@aldt", allDateWorked)
  @Concat_Field("@@sldt", sortDateWorked)
  @Concat_Field("@@pldt", totalDateWorked)

  @Concat_Field("@@fsft", fromShiftWorked)
  @Concat_Field("@@tsft", toShiftWorked)
  @Concat_Field("@@asft", allShiftWorked)
  @Concat_Field("@@ssft", sortShiftWorked)
  @Concat_Field("@@psft", totalShiftWorked)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}