%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Import Cross Reference"
  d2wName                 = "MapXRef.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HSYIXM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  noMsg                   = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "MAPXREF")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select SYMXRF.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(PMPRMD,' ') as PMPRMD, ifnull(PMPRMDU,' ') as PMPRMDU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(a.FLDESC,' ') as fldtFLDESC, ifnull(upper(a.FLDESC),' ') as fldtFLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(b.FLDESC,' ') as upprFLDESC, ifnull(upper(b.FLDESC),' ') as upprFLDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " SYMXRF ", fileSQL)
                      @dtw_concat(fileSQL, " left join WFPARM on PMPARM=MXPARM ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG a on a.FLTYPE='XRFFLDTYP' and a.FLVALU=MXFLDT ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG b on b.FLTYPE='BY' and b.FLVALU=MXUPPR ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, " MXXREF>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)MapXRefMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint == "")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">Work Flow Parameter</th>
                      <th class="colhdr">Import Table</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="10" maxlength="50">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchMapParm" size="10" maxlength="50">
                          <input type="hidden" name="operMapParm" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchTable" size="10" maxlength="10">
                          <input type="hidden" name="operTable" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("MXDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description"        title="Sequence By Description, Cross Reference">Description</a></th>
              @OrderBy_Sort("MXXREF", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CrossReference"     title="Sequence By Cross Reference, Import Table">Cross Reference</a></th>
              @OrderBy_Sort("MXIFIL", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Table"              title="Sequence By Import Table, Cross Reference">Import Table</a></th>
              @OrderBy_Sort("fldtFLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FieldType"          title="Sequence By Field Type, Cross Reference">Field Type</a></th>
              @OrderBy_Sort("MXSIZE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=WholePrecision"     title="Sequence By Whole Number Precision, Cross Reference">Whole Number Precision</a></th>
              @OrderBy_Sort("MXDECM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DecimalPrecision"   title="Sequence By Decimal Precision, Cross Reference">Decimal Precision</a></th>
              @OrderBy_Sort("upprFLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Upper"              title="Sequence By Convert To Upper, Cross Reference">Convert To Upper</a></th>
              @OrderBy_Sort("PMPRMDU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Parameter"          title="Sequence By Work Flow Parameter, Cross Reference">Work Flow Parameter</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;crossReference=@dtw_rurlescseq(V_MXXREF)&amp;mapImportTable=@dtw_rurlescseq(V_MXIFIL)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;updRecNbr=@dtw_rurlescseq(START_ROW_NUM)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_MXDESC), "$(V_MXXREF)-$(V_MXIFIL)", "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)MapXRefMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_04 == "Y")
                              <a href="$(homeURL)$(cGIPath)MapXRefMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromCrossReference=@dtw_rurlescseq(V_MXXREF)&amp;fromImportTable=@dtw_rurlescseq(V_MXIFIL)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)MapXRefMaintain.d2w/EDIT_DATA$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)MapXRefSelect.d2w/REPORT$(d2wVarBase)&amp;crossReference=@dtw_rurlescseq(V_MXXREF)&amp;mapImportTable=@dtw_rurlescseq(V_MXIFIL)" title="View Import Cross Reference">$(V_MXDESC)</a></td>
                  <td class="colalph">$(V_MXXREF)</td>                                      	
                  <td class="colalph">$(V_MXIFIL)</td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_MXFLDT)">$(V_fldtFLDESC)</span></td>
                  <td class="colnmbr">$(V_MXSIZE)</td>                                      	
                  <td class="colnmbr">$(V_MXDECM)</td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_MXUPPR)">$(V_upprFLDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_MXPARM)">$(V_PMPRMD)</span></td>                                      	
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select SYMXRF.*, ", stmtSQL)
  @dtw_concat(stmtSQL, " ifnull(PMPRMD,' ') as PMPRMD, ifnull(PMPRMDU,' ') as PMPRMDU, ", stmtSQL)
  @dtw_concat(stmtSQL, " ifnull(a.FLDESC,' ') as fldtFLDESC, ifnull(upper(a.FLDESC),' ') as fldtFLDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " ifnull(b.FLDESC,' ') as upprFLDESC, ifnull(upper(b.FLDESC),' ') as upprFLDESCU ", stmtSQL)
  @dtw_concat(fileSQL, " SYMXRF ", fileSQL)
  @dtw_concat(fileSQL, " left join WFPARM on PMPARM=MXPARM ", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG a on a.FLTYPE='XRFFLDTYP' and a.FLVALU=MXFLDT ", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG b on b.FLTYPE='BY' and b.FLVALU=MXUPPR ", fileSQL)
  %if (wildCardSearch!="")
      @dtw_concat(selectSQL, " MXXREF>' ' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_XMLQuery (IN  CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("ImportCrossReferenceList")
          %ROW{
              @XMLIDTag("V_MXXREF-V_MXIFIL)", "ImportCrossReference ID")
                  @XMLTag(V_MXXREF, "CrossRefernce")
                  @XMLTag(V_MXIFIL, "ImportTable")
                  @XMLTag(V_MXDESC, "Description")
                  @XMLTag(V_MXPARM, "WorkFlowParameter")
                  @XMLTag(V_MXFLDT, "FieldType")
                  @XMLTag(V_MXSIZE, "WholeNumberPrecision")
                  @XMLTag(V_MXDECM, "DecimalPrecision")
                  @XMLTag(V_MXUPPR, "ConvertToUpper")
              @XMLEndTag("ImportCrossReference")
          %}
      @XMLEndTag("ImportCrossReferenceList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "MXDESCU,MXXREF,MXIFIL")
          @DTW_ASSIGN(orderByDisplay, "Description, Cross Reference, Import Table")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %if (updRecNbr > "0")
      @dtw_assign(START_ROW_NUM, updRecNbr)
      @dtw_assign(updRecNbr, "")
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Description")
      %if (orderBy == "MXDESCU,MXXREF,MXIFIL")
          @DTW_ASSIGN(orderBy, "MXDESCU DESC,MXXREF,MXIFIL")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Cross Reference, Import Table")
      %else
          @DTW_ASSIGN(orderBy, "MXDESCU,MXXREF,MXIFIL")
          @DTW_ASSIGN(orderByDisplay, "Description, Cross Reference, Import Table")
      %endif
  %elseif (sequence == "CrossReference")
      %if (orderBy == "MXXREF,MXIFIL")
          @DTW_ASSIGN(orderBy, "MXXREF DESC,MXIFIL")
          @DTW_ASSIGN(orderByDisplay, "Cross Reference (descending), Import Table")
      %else
          @DTW_ASSIGN(orderBy, "MXXREF,MXIFIL")
          @DTW_ASSIGN(orderByDisplay, "Cross Reference, Import Table")
      %endif
  %elseif (sequence == "Table")
      %if (orderBy == "MXIFIL,MXXREF")
          @DTW_ASSIGN(orderBy, "MXIFIL DESC,MXXREF")
          @DTW_ASSIGN(orderByDisplay, "Import Table (descending), Cross Reference")
      %else
          @DTW_ASSIGN(orderBy, "MXIFIL,MXXREF")
          @DTW_ASSIGN(orderByDisplay, "Import Table, Cross Reference")
      %endif
  %elseif (sequence == "FieldType")
      %if (orderBy == "fldtFLDESCU,MXXREF,MXIFIL")
          @DTW_ASSIGN(orderBy, "fldtFLDESCU DESC,MXXREF,MXIFIL")
          @DTW_ASSIGN(orderByDisplay, "Field Type (descending), Cross Reference, Import Table")
      %else
          @DTW_ASSIGN(orderBy, "fldtFLDESCU,MXXREF,MXIFIL")
          @DTW_ASSIGN(orderByDisplay, "Field Type, Cross Reference, Import Tabler")
      %endif
  %elseif (sequence == "WholePrecision")
      %if (orderBy == "MXSIZE,MXXREF,MXIFIL")
          @DTW_ASSIGN(orderBy, "MXSIZE DESC,MXXREF,MXIFIL")
          @DTW_ASSIGN(orderByDisplay, "Whole Number Precision (descending), Cross Reference, Import Table")
      %else
          @DTW_ASSIGN(orderBy, "MXSIZE,MXXREF,MXIFIL")
          @DTW_ASSIGN(orderByDisplay, "Whole Number Precision, Cross Reference, Import Table")
      %endif
  %elseif (sequence == "DecimalPrecision")
      %if (orderBy == "MXDECM,MXXREF,MXIFIL")
          @DTW_ASSIGN(orderBy, "MXDECM DESC,MXXREF,MXIFIL")
          @DTW_ASSIGN(orderByDisplay, "Decimal Precision (descending), Cross Reference, Import Table")
      %else
          @DTW_ASSIGN(orderBy, "MXDECM,MXXREF,MXIFIL")
          @DTW_ASSIGN(orderByDisplay, "Decimal Precision, Cross Reference, Import Table")
      %endif
  %elseif (sequence == "Upper")
      %if (orderBy == "upprFLDESCU,MXXREF,MXIFIL")
          @DTW_ASSIGN(orderBy, "upprFLDESCU DESC,MXXREF,MXIFIL")
          @DTW_ASSIGN(orderByDisplay, "Convert To Upper (descending), Cross Reference, Import Table")
      %else
          @DTW_ASSIGN(orderBy, "upprFLDESCU,MXXREF,MXIFIL")
          @DTW_ASSIGN(orderByDisplay, "Convert To Upper, Cross Reference, Import Table")
      %endif
  %elseif (sequence == "Parameter")
      %if (orderBy == "PMPRMDU,MXXREF,MXIFIL")
          @DTW_ASSIGN(orderBy, "PMPRMDU DESC,MXXREF,MXIFIL")
          @DTW_ASSIGN(orderByDisplay, "Work Flow Parameter (descending), Cross Reference, Import Table")
      %else
          @DTW_ASSIGN(orderBy, "PMPRMDU,MXXREF,MXIFIL")
          @DTW_ASSIGN(orderByDisplay, "Work Flow Parameter, Cross Reference, Import Table")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchWhole, 5, 0) &&
                      editNum(document.Search.srchDecimal, 2, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "MAPDEFINITIONSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Cross Reference</td>
                              @dtw_assign(operNbr, "operXRef")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchXRef" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Import Table</td>
                              @dtw_assign(operNbr, "operTable")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchTable" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Field Type</td>
                              @dtw_assign(operNbr, "operFieldType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchFieldType" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Whole Number Precision</td>
                              @dtw_assign(operNbr, "operWhole")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchWhole" size="5" maxlength="5"></td>
                          </tr>	

                          <tr><td class="dsphdr">Decimal Precision</td>
                              @dtw_assign(operNbr, "operDecimal")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchDecimal" size="1" maxlength="1"></td>
                          </tr>	

                          <tr><td class="dsphdr">Convert To Upper</td>
                              @dtw_assign(operNbr, "operUpper")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchUpper" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Work Flow Parameter</td>
                              @dtw_assign(operNbr, "operMapParm")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchMapParm" size="15" maxlength="50"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDesc.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("MXDESCU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("MXXREF",  "Cross Reference", $(srchXRef), "U", operXRef, "A")
  @Build_WildCard ("MXIFIL",  "Import Table", $(srchTable), "U", operTable, "A")
  @Build_WildCard ("ifnull(upper(a.FLDESC),' ')",  "Field Type", $(srchFieldType), "U", operFieldType, "A")
  @Build_WildCard ("MXSIZE",  "Whole Number Precision", $(srchWhole), "", operWhole, "N")
  @Build_WildCard ("MXDECM",  "Decimal Precision", $(srchDecimal), "", operDecimal, "N")
  @Build_WildCard ("ifnull(upper(b.FLDESC),' ')",  "Convert To Upper", $(srchUpper), "U", operUpper, "A")
  @Build_WildCard ("PMPRMDU", "Work Flow Parameter", $(srchMapParm), "U", operMapParm, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}