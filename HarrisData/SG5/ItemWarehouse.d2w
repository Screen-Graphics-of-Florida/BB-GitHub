      %endif
  %elseif (sequence == "qtyOnHandRecv")
      %if (orderBy == "IWOHRC,WHWHNMU,IWWHS")
          @DTW_ASSIGN(orderBy, "IWOHRC DESC,WHWHNMU,IWWHS")
          @DTW_ASSIGN(orderByDisplay, "Quantity On Hand Receiving (descending), Warehouse Name, Warehouse")
      %else
          @DTW_ASSIGN(orderBy, "IWOHRC,WHWHNMU,IWWHS")
          @DTW_ASSIGN(orderByDisplay, "Quantity On Hand Receiving, Warehouse Name, Warehouse")
      %endif
  %elseif (sequence == "qtyHeldInStock")
      %if (orderBy == "IWQHSR,WHWHNMU,IWWHS")
          @DTW_ASSIGN(orderBy, "IWQHSR DESC,WHWHNMU,IWWHS")
          @DTW_ASSIGN(orderByDisplay, "Quantity Held In Stock (descending), Warehouse Name, Warehouse")
      %else
          @DTW_ASSIGN(orderBy, "IWQHSR,WHWHNMU,IWWHS")
          @DTW_ASSIGN(orderByDisplay, "Quantity Held In Stock, Warehouse Name, Warehouse")
      %endif
  %elseif (sequence == "qtyReserved")
      %if (orderBy == "IWRESQ,WHWHNMU,IWWHS")
          @DTW_ASSIGN(orderBy, "IWRESQ DESC,WHWHNMU,IWWHS")
          @DTW_ASSIGN(orderByDisplay, "Quantity Reserved (descending), Warehouse Name, Warehouse")
      %else
          @DTW_ASSIGN(orderBy, "IWRESQ,WHWHNMU,IWWHS")
          @DTW_ASSIGN(orderByDisplay, "Quantity Reserved, Warehouse Name, Warehouse")
      %endif
  %elseif (sequence == "qtyOnOrder")
      %if (orderBy == "IWQOO,WHWHNMU,IWWHS")
          @DTW_ASSIGN(orderBy, "IWQOO DESC,WHWHNMU,IWWHS")
          @DTW_ASSIGN(orderByDisplay, "Quantity On Order (descending), Warehouse Name, Warehouse")
      %else
          @DTW_ASSIGN(orderBy, "IWQOO,WHWHNMU,IWWHS")
