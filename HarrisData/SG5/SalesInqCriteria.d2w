%INCLUDE "$(baseVar)"
%INCLUDE "ARControl$(dataBaseID).icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"

%Define {
  page_title              = "Sales Inquiry Selection Criteria"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  selectName              = "SALESINQ"
%}

%INCLUDE "opersel_dspfield.icl"

%FUNCTION(dtw_directcall) Retrieve_User_Selection(INOUT CHAR(64) profileHandle,
                                                  INOUT CHAR(2)  dataBaseID,
                                                  INOUT CHAR(1)  maintCode,
                                                  INOUT CHAR(10) userProfile,
                                                  INOUT CHAR(10) selectName,
                                                  INOUT DEC(5,0) selectSequence,
                                                  INOUT CHAR(50) selectDesc,
                                                  INOUT CHAR(10) selectTotals,
                                                  INOUT CHAR(500) selectGroupBy,
                                                  INOUT CHAR(3000) selectCriteria)
{%EXEC {HSYUSL_W.PGM %}
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"

  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onLoad="window.focus()" onBlur="window.close()">
          <table $(contentTable)>
              <tr><td><h1>$(page_title)</h1></td>
                  <td class="toolbar">
                      %INCLUDE "CloseWindow.icl"
                  </td>
              </tr>
          </table>

          $(hrTagAttr)

          @dtw_assign(maintCode, "R")
          @Retrieve_User_Selection(profileHandle, dataBaseID, maintCode, userProfile, selectName, selectSequence, selectDesc, selectTotals, selectGroupBy, selectCriteria)

          <table $(contentTable)>
              <tr><td class="dsphdr">Description</td>
                  <td class="dspalph">$(selectDesc)</td>
              </tr>
              %if (@dtw_rsubstr(selectTotals, "1", "1") == "Y" || @dtw_rsubstr(selectTotals, "2", "1") == "Y")
                  <tr><td class="dsphdr">Display Totals By</td><td class="dspalph">
                      %if (@dtw_rsubstr(selectTotals, "1", "1") == "Y")
                           Quantity &nbsp; &nbsp;
                      %endif
                      %if (@dtw_rsubstr(selectTotals, "2", "1") == "Y")
                           Amount &nbsp; &nbsp;
                      %endif
                      %if (@dtw_rsubstr(selectTotals, "3", "1") == "Y")
                           Count
                      %endif
                      </td>
                  </tr>
              %endif
          </table>
          <table $(contentTable)>
              <tr><td>&nbsp;</td>
                  <td class="colhdr">Operand</td>
                  <td class="colhdr">From</td>
                  <td class="colhdr">&nbsp; To &nbsp;</td>
                  <td class="colhdr">Group<br>By</td>
              </tr>
              @Build_Selection("DHITEM", "Item Number", "A")
              @Build_Selection("DHIMDS", "Item Description", "A")
              @Build_Selection("DHBLTO", "Bill-To Number", "N")
              @Build_Selection("DHSHTO", "Ship-To Number", "N")
              @Build_Selection("CMCNA1", "Ship-To Name", "A")
              @Build_Selection("CMCNA2", "Address 1", "A")
              @Build_Selection("CMCNA3", "Address 2", "A")
              @Build_Selection("CMCNA4", "Address 3", "A")
              @Build_Selection("CMCCTY", "City", "A")
              @Build_Selection("CMST",   "State", "A")
              @Build_Selection("CMZIP",  "Zip Code", "A")
              @Build_Selection("DHDTLI", "Invoice Date", "D")
              @Build_Selection("@@LIYR", "Invoice Year", "N")
              @Build_Selection("@@LIQT", "Invoice Quarter", "N")
              @Build_Selection("@@LIMO", "Invoice Month", "N")
              @Build_Selection("@@LIWK", "Invoice Week", "N")
              @Build_Selection("DHPCLS", "Product Class", "A")
              @Build_Selection("DHPGRP", "Product Group", "A")
              @Build_Selection("IMITC",  "Inventory Type", "A")
              @Build_Selection("HHDOTS", "Shipped Date", "D")
              @Build_Selection("@@SDYR", "Shipped Year", "N")
              @Build_Selection("@@SDQT", "Shipped Quarter", "N")
              @Build_Selection("@@SDMO", "Shipped Month", "N")
              @Build_Selection("@@SDWK", "Shipped Week", "N")
              @Build_Selection("DHSLPR", "Selling Price", "N")
              @Build_Selection("DHQSTC", "Quantity Sold", "N")
              @Build_Selection("HHSLSM", "Salesman Number", "N")
              @Build_Selection("CMCCLS", "Customer Class", "A")
              @Build_Selection("CMCRGN", "Region", "A")
              @Build_Selection("DHLOC#", "Location Number", "N")
              @Build_Selection("DHWH",   "Warehouse Number", "N")
              @Build_Selection("DHSVSV", "Ship Via Code", "A")
              @Build_Selection("DHSVDS", "Ship Via Description", "A")
              @Build_Selection("HHORTY", "Order Type", "A")
              @Build_Selection("CMUDF1", "$(V_CRSCR1)", "A")
              @Build_Selection("CMUDF2", "$(V_CRSCR2)", "A")
              @Build_Selection("CMUDF3", "$(V_CRSCR3)", "A")
              @Build_Selection("CMUDF4", "$(V_CRSCR4)", "A")
              @Build_Selection("CMUDF5", "$(V_CRSCR5)", "A")
              @Build_Selection("IMUDA1", "$(V_CIIAS1)", "A")
              @Build_Selection("IMUDA2", "$(V_CIIAS2)", "A")
              @Build_Selection("IMUDA3", "$(V_CIIAS3)", "A")
              @Build_Selection("IMUDA4", "$(V_CIIAS4)", "A")
              @Build_Selection("IMUDA5", "$(V_CIIAS5)", "A")
              @Build_Selection("IMUDN1", "$(V_CIINS1)", "N")
              @Build_Selection("IMUDN2", "$(V_CIINS2)", "N")
              @Build_Selection("IMUDN3", "$(V_CIINS3)", "N")
              @Build_Selection("IMUDN4", "$(V_CIINS4)", "N")
              @Build_Selection("IMUDN5", "$(V_CIINS5)", "N")
          </table>
          $(hrTagAttr)
      </body>
  </html>
%}