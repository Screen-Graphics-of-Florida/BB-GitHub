%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Employee Education/Skills"
  d2wName                 = "Education.d2w"
  d2wVarBase              = "$(genericVarBase)$(employeeVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPEEDU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                          @dtw_assign(pageID, "EDUCATION")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
	                   %INCLUDE "UserViewEmpl.icl"
	                   %INCLUDE "UserView.icl"

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, "SELECT DCCOMP, DCEMPL, DCSEQ, DCSCHL, DCDUR, DCDGRE, DCSUBJ, DCSKIL, DCRFND, DCDTCM, DCSCHLU, DCSUBJU, DCSKILU, EMCOMP, EMFACL, EMEMPL, EMPECP, EMPEMP, EMDEPT, EMLOC, EMTYPE ", stmtSQL)
                          @dtw_concat(fileSQL, " PEEDUC inner join HREMPL on DCCOMP=EMPECP and DCEMPL=EMPEMP", fileSQL)
                          @dtw_concat(selectSQL, " DCCOMP=$(hrCompany) and DCEMPL=$(hrEmployee)", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Education_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
%}

%FUNCTION(dtw_sql) Education_Query (IN  CHAR(64) profileHandle,
                                        CHAR(2)   dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count != "1")
          <table $(contentTable)>
              <colgroup>
                 <col width="80%">
                 <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                          %endif
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
              @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
              <tr><td><h2>$(F_EmpName)</h2></td></tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"

          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Skill</th></tr>
                      <tr><td><input type="text" class="inputalph" name="srchSkill" size="15" maxlength="15">
                              <input type="hidden" name="operSkill" value="LIKE">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchSkill.focus();
                  </script>
              </form>
              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("DCSUBJU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Subject" title="Sequence By Subject">Subject</a></th>
                  @OrderBy_Sort("DCSKILU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Skill" title="Sequence By Skill"> Skill</a></th>
                  @OrderBy_Sort("DCSCHLU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SchoolCourse" title="Sequence By School/Course">School/Course</a></th>
                  @OrderBy_Sort("DCDUR", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Duration" title="Sequence By Time/Duration">Time/<br>Duration</a></th>
                  @OrderBy_Sort("DCDGRE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Degree" title="Sequence By Degree"> Degree</a></th>
                  @OrderBy_Sort("DCDTCM", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DateCompleted" title="Sequence By Date Completed">Date<br>Completed</a></th>
                  <th class="colhdr"> Tuition<br>Refund</th>
              </tr>
          %INCLUDE "NoRecordsFound.icl"
      %endif

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;sequenceNbr=@dtw_rurlescseq(V_DCSEQ)")
              %if (sql_Record_Count == "1")
                  @Save_WebReg(webRegCurFile, profileHandle, d2wName, "", orderBy, orderByDisplay, "")
                  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)EmplSkillSelect.d2w/REPORT$(maintainVar)">
              %else
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)EmplSkillSelect.d2w/REPORT$(maintainVar)" title="Display Employee Education/Skill">$(V_DCSUBJ)</a></td>
                      <td class="colalph">$(V_DCSKIL)</td>
                      <td class="colalph">$(V_DCSCHL)</td>
                      <td class="colcode">$(V_DCDUR)</td>
                      <td class="colcode">$(V_DCDGRE)</td>
                      @Format_Date(V_DCDTCM, "D", F_DCDTCM)
                      <td class="coldate">$(F_DCDTCM)</td>
                      %if (V_DCRFND == ".00")
                          @dtw_assign(V_DCRFND, "")
                          <td class="colnmbt">$(V_DCRFND)</td>
                      %else
                          @Format_Nbr($(V_DCRFND), F_DCRFND, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_DCRFND)</td>
                      %endif
                  </tr>
              %endif
          %}
          </table>
          %if (sql_Record_Count != "1")
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
      %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint == "Y")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else

          %if (orderBy == "")
         @DTW_ASSIGN(orderBy, "DCSUBJU")
         @DTW_ASSIGN(orderByDisplay, "Subject")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      %INCLUDE "SearchReturn.icl"
  %endif
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY){
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Subject")
     %if (orderBy == "DCSUBJU")
         @DTW_ASSIGN(orderBy, "DCSUBJU DESC")
         @DTW_ASSIGN(orderByDisplay, "Subject (descending)")
     %else
         @DTW_ASSIGN(orderBy, "DCSUBJU")
         @DTW_ASSIGN(orderByDisplay, "Subject")
     %endif
  %elif (sequence == "Skill")
     %if (orderBy == "DCSKILU")
         @DTW_ASSIGN(orderBy, "DCSKILU DESC")
         @DTW_ASSIGN(orderByDisplay, "Skill (descending)")
     %else
         @DTW_ASSIGN(orderBy, "DCSKILU")
         @DTW_ASSIGN(orderByDisplay, "Skill")
     %endif
  %elif (sequence == "SchoolCourse")
     %if (orderBy == "DCSCHLU")
         @DTW_ASSIGN(orderBy, "DCSCHLU DESC")
         @DTW_ASSIGN(orderByDisplay, "School/Course (descending)")
     %else
         @DTW_ASSIGN(orderBy, "DCSCHLU")
         @DTW_ASSIGN(orderByDisplay, "School/Course")
     %endif
  %elif (sequence == "Duration")
     %if (orderBy == "DCDUR")
         @DTW_ASSIGN(orderBy, "DCDUR DESC")
         @DTW_ASSIGN(orderByDisplay, "Duration (descending)")
     %else
         @DTW_ASSIGN(orderBy, "DCDUR")
         @DTW_ASSIGN(orderByDisplay, "Duration")
     %endif
  %elif (sequence == "Degree")
     %if (orderBy == "DCDGRE")
         @DTW_ASSIGN(orderBy, "DCDGRE DESC")
         @DTW_ASSIGN(orderByDisplay, "Degree (descending)")
     %else
         @DTW_ASSIGN(orderBy, "DCDGRE")
         @DTW_ASSIGN(orderByDisplay, "Degree")
     %endif
  %elif (sequence == "DateCompleted")
     %if (orderBy == "DCDTCM")
         @DTW_ASSIGN(orderBy, "DCDTCM DESC")
         @DTW_ASSIGN(orderByDisplay, "Date Completed (descending)")
     %else
         @DTW_ASSIGN(orderBy, "DCDTCM")
         @DTW_ASSIGN(orderByDisplay, "Date Completed")
     %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
	       %INCLUDE "numedit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editdate(document.Search.srchDate))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "EDUCATIONSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">School/Course</td>
                              @dtw_assign(operNbr, "operSchool")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchSchool" size="15" maxlength="15"></td>
                          </tr>

                         <tr><td class="dsphdr">Subject</td>
                              @dtw_assign(operNbr, "operSubject")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchSubject" size="15" maxlength="15"></td>
                          </tr>

                         <tr><td class="dsphdr">Skill</td>
                              @dtw_assign(operNbr, "operSkill")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchSkill" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">Date Completed</td>
                              @dtw_assign(operNbr, "operDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchDate" size="6" maxlength="6"> 		
                                  <a href="javascript:calWindow('srchDate');">$(calendarImage)</a></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchSchool.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("upper(DCSCHL)", "School/Course", $(srchSchool), "U", operSchool, "A")
  @Build_WildCard ("upper(DCSUBJ)", "Subject", $(srchSubject), "U", operSubject, "A")
  @Build_WildCard ("upper(DCSKIL)", "Skill", $(srchSkill), "U", operSkill, "A")
  @Build_WildCard ("DCDTCM", "Date Completed", $(srchDate), "", operDate, "D")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}