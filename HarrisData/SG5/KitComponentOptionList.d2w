%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Kit/Component Option List"
  d2wName                 = "KitComponentOptionList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)&amp;apid=@dtw_rurlescseq(apid)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if  (editFromToAll(document.Chg.fromKitItem, document.Chg.toKitItem, document.Chg.allKitItem, "A") &&
                       editFromToAll(document.Chg.fromComponentItem, document.Chg.toComponentItem, document.Chg.allComponentItem, "A") &&
                       editFromToAll(document.Chg.fromOptionalItem, document.Chg.toOptionalItem, document.Chg.allOptionalItem, "A"))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "KITCOMPONENTOPTIONLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromKitItem")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@fkit")  @dtw_assign(V_N1FKIT,  fieldValue)
                                  @Decat_Field("@@tkit")  @dtw_assign(V_N1TKIT,  fieldValue)
                                  @Decat_Field("@@akit")  @dtw_assign(V_N1AKIT,  fieldValue)
                                  @Decat_Field("@@fcit")  @dtw_assign(V_N1FCIT,  fieldValue)
                                  @Decat_Field("@@tcit")  @dtw_assign(V_N1TCIT,  fieldValue)
                                  @Decat_Field("@@acit")  @dtw_assign(V_N1ACIT,  fieldValue)
                                  @Decat_Field("@@foit")  @dtw_assign(V_N1FOIT,  fieldValue)
                                  @Decat_Field("@@toit")  @dtw_assign(V_N1TOIT,  fieldValue)
                                  @Decat_Field("@@aoit")  @dtw_assign(V_N1AOIT,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1AKIT == "ALL")
                                      @dtw_assign(checkedallKitItem, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallKitItem, "")
                                  %endif
                                  %if (V_N1ACIT == "ALL")
                                      @dtw_assign(checkedallComponentItem, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallComponentItem, "")
                                  %endif
                                  %if (V_N1AOIT == "ALL")
                                      @dtw_assign(checkedallOptionalItem, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallOptionalItem, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedallKitItem, "CHECKED")
                                  @dtw_assign(checkedallComponentItem, "CHECKED")
                                  @dtw_assign(checkedallOptionalItem, "CHECKED")
                              %endif

                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              <tr><td class="dsphdr"><span $(textOvr)>Kit Item</span></td>
                                  <td class="inputalph"><input name="fromKitItem" value="$(V_N1FKIT)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(cGIPath)KitItemSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromKitItem&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toKitItem" value="$(V_N1TKIT)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(cGIPath)KitItemSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toKitItem&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allKitItem" value='ALL' $(checkedallKitItem) type="checkbox" onClick="if (this.checked) this.form.fromKitItem.value='', this.form.toKitItem.value='';"></td>
                              </tr>

                              <tr><td class="dsphdr"><span $(textOvr)>Component Item</span></td>
                                  <td class="inputalph"><input name="fromComponentItem" value="$(V_N1FCIT)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromComponentItem&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toComponentItem" value="$(V_N1TCIT)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toComponentItem&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allComponentItem" value='ALL' $(checkedallComponentItem) type="checkbox" onClick="if (this.checked) this.form.fromComponentItem.value='', this.form.toComponentItem.value='';"></td>
                              </tr>

                              <tr><td class="dsphdr"><span $(textOvr)>Optional Item</span></td>
                                  <td class="inputalph"><input name="fromOptionalItem" value="$(V_N1FOIT)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromOptionalItem&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toOptionalItem" value="$(V_N1TOIT)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toOptionalItem&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allOptionalItem" value='ALL' $(checkedallOptionalItem) type="checkbox" onClick="if (this.checked) this.form.fromOptionalItem.value='', this.form.toOptionalItem.value='';"></td>
                              </tr>

                          </table>

                          @dtw_assign(envProgram, "HHDKOL")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HHDKOS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(fromKitItem)
  @dtw_mUPPERCASE(toKitItem)
  @dtw_mUPPERCASE(allKitItem)
  @dtw_mUPPERCASE(fromComponentItem)
  @dtw_mUPPERCASE(toComponentItem)
  @dtw_mUPPERCASE(allComponentItem)
  @dtw_mUPPERCASE(fromOptionalItem)
  @dtw_mUPPERCASE(toOptionalItem)
  @dtw_mUPPERCASE(allOptionalItem)

  %if (allKitItem != "ALL")
      @dtw_assign(allKitItem, "")
  %endif
  %if (allComponentItem != "ALL")
      @dtw_assign(allComponentItem, "")
  %endif
  %if (allOptionalItem != "ALL")
      @dtw_assign(allOptionalItem, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@apid", apid)
  @Concat_Field("@@fkit", fromKitItem)
  @Concat_Field("@@tkit", toKitItem)
  @Concat_Field("@@akit", allKitItem)
  @Concat_Field("@@fcit", fromComponentItem)
  @Concat_Field("@@tcit", toComponentItem)
  @Concat_Field("@@acit", allComponentItem)
  @Concat_Field("@@foit", fromOptionalItem)
  @Concat_Field("@@toit", toOptionalItem)
  @Concat_Field("@@aoit", allOptionalItem)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}