%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title           = "Benefit Group"
  d2wName              = "HRBenefitGroupSelect.d2w"
  attachFolder         = "HRBenefitGroup"
  d2wVarBase           = "$(genericVarBase)$(hrCoFacVarBase)&amp;benefitGroup=@dtw_rurlescseq(benefitGroup)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar          = "$(d2wVarBase)"
  wildDftVar           = "REPORT$(d2wVarBase)"
  programName          = "HPEBGM"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  RPT_MAX_ROWS         = "10"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext         = "1"
  totalPages           = "0"
  advanceSearch        = "N"
  attachVarKey         = ""
  attachForDesc        = ""
  quickLinksInUse      = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "HrCoFacURL.icl"
  @dtw_replace(workURL, "@@benefitGroup", "@dtw_rurlescseq(benefitGroup)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "BENEFITGRP")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      @dtw_assign(uv_CompanyName, "BHCOMP")
                      @dtw_assign(uv_FacilityName, "BHFACL")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " HRBGRH inner join HRBGRD on BHCOMP=BDCOMP and BHFACL=BDFACL and BHBGRP=BDBGRP ", fileSQL)
                      @dtw_concat(fileSQL, "        inner join CBCOVR on BDCOMP=CVCOMP and BDFACL=CVFACL and BDCOVR=CVCOVR and BDPLAN=CVPLAN ", fileSQL)
                      @dtw_concat(selectSQL, "BHCOMP=$(prCompany) and BHFACL=$(prFacility) and BHBGRP='$(benefitGroup)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @BenefitGroup_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) BenefitGroup_Query (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RetHrCompNam(profileHandle, dataBaseID, prCompany, prFacility, coFacName)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              @dtw_assign(hrCompanyFilled, "$(hrCompany)")
              %while(@dtw_rlength(hrCompanyFilled) != "2") {@dtw_insert("0", hrCompanyFilled, hrCompanyFilled)%}
              @dtw_assign(attachVarKey, "$(hrCompanyFilled)_$(benefitGroup)")
              @dtw_assign(attachForDesc, "$(coFacName) Benefit Group $(benefitGroup)")
              @dtw_assign(attachPrg1, "HRBGRH Where BHCOMP=$(prCompany) and BHFACL=$(prFacility) and BHBGRP='$(benefitGroup)'")
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/report") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %INCLUDE "Attachment.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>

          <tr><td><h2>$(coFacName)</h2></td></tr>

          @RtvFldDesc("BHBGRP='$(benefitGroup)'", "HRBGRH", "BHNAME", benefitGroupName)
          <tr><td><h2>$(benefitGroupName)</h2></td></tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"
      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Benefit Description</th></tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="15" maxlength="15">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              %if (formatToPrint != "Y")
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @OrderBy_Sort("BDCOVR", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BenefitCode" title="Sequence By Benefit Code, Plan Code">Benefit Code</a></th>
              @OrderBy_Sort("CVDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BenefitDesc" title="Sequence By Benefit Description, Plan Code">Benefit Description</a></th>
              @OrderBy_Sort("BDPLAN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlanCode" title="Sequence By Plan Code">Plan Code</a></th>
              <th class="colhdr">Plan Description</th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y")
                      %if ($(V_CVURLI) != "")
                          <td class="opticon"><a href="$(V_CVURLI)">$(planDocImage)</a></td>
                      %else
                          <td class="opticon"> </td>
                      %endif
                  %endif
                  <td class="colcode">$(V_BDCOVR)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)hrbenefitSelect.d2w/REPORT$(d2wVarBase)&amp;benefitCode=@dtw_rurlescseq(V_CVCOVR)&amp;planCode=@dtw_rurlescseq(V_CVPLAN)" title="View Benefit">$(V_CVDESC)</a></td>
                  <td class="colcode">$(V_BDPLAN)</td>
                  @RtvFldDesc("CCCODE='$(V_BDPLAN)' AND CCTYPE='P'", "CBCODE", "CCDESC", planDesc)
                  <td class="colalph">$(planDesc)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "AttachmentSQL.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%INCLUDE "AttachmentSelect.icl"

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "BDCOVR,BDPLAN")
              @DTW_ASSIGN(orderByDisplay, "Benefit Code, Plan Code")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "BenefitCode")
      %if (orderBy == "BDCOVR,BDPLAN")
          @DTW_ASSIGN(orderBy, "BDCOVR DESC,BDPLAN")
          @DTW_ASSIGN(orderByDisplay, "Benefit Code (descending), Plan Code")
      %else
          @DTW_ASSIGN(orderBy, "BDCOVR,BDPLAN")
          @DTW_ASSIGN(orderByDisplay, "Benefit Code, Plan Code")
      %endif
  %elif (sequence == "BenefitDesc")
      %if (orderBy == "CVDESCU,BDPLAN")
          @DTW_ASSIGN(orderBy, "CVDESCU DESC,BDPLAN")
          @DTW_ASSIGN(orderByDisplay, "Benefit Description (descending), Plan Code")
      %else
          @DTW_ASSIGN(orderBy, "CVDESCU,BDPLAN")
          @DTW_ASSIGN(orderByDisplay, "Benefit Description, Plan Code")
      %endif
  %elif (sequence == "PlanCode")
      %if (orderBy == "BDPLAN")
          @DTW_ASSIGN(orderBy, "BDPLAN DESC")
          @DTW_ASSIGN(orderByDisplay, "Plan Code (descending)")
      %else
          @DTW_ASSIGN(orderBy, "BDPLAN")
          @DTW_ASSIGN(orderByDisplay, "Plan Code")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("CVDESCU", "Benefit Description", $(srchDesc), "U", operDesc, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}