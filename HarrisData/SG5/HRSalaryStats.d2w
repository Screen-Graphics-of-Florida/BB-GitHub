%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title 	        = "Salary Statistics"
  d2wName              = "HRSalaryStats.d2w"
  d2wVarBase           = "$(genericVarBase)&amp;hrCompany=@dtw_rurlescseq(hrCompany)"
  nextPrevVar          = "$(d2wVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  wildDftVar           = "REPORT$(d2wVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  advSrchVar           = "&amp;backHome=@dtw_rurlescseq(backHome)"
  programName          = "HPESSW"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  facilityZero         = "0000"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext		= "1"
  totalPages		= "0"
  advanceSearch        = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@hrCompany", "@dtw_rurlescseq(hrCompany)", "1", "a", workURL)
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                       @dtw_assign(pageID, "HRSALARYSTATS")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " PEWWRK ", fileSQL)
                      @dtw_concat(selectSQL, " SWPECP = $(hrCompany) and SWXHND = '$(profileHandle)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @SalaryStats_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) SalaryStats_Query (IN CHAR(64)    profileHandle,
				           CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if ((backHome != "")  && (backHome != "$(d2wName)/REPORT"))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)&amp;backHome=@dtw_rurlescseq(backHome)" title="Return To Company">$(portalHome)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
              @RetHrCompNam(profileHandle, dataBaseID, hrCompany, facilityZero, coFacName)
              <tr><td><h2>$(coFacName)</h2></td>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"
          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" Method=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Job Code</th><th class="colhdr">Description</th></tr>
                      <tr><td><input type="text" class="inputalph" name="srchJobCode" size="4" maxlength="4">
                              <input type="hidden" name="operJobCode" value="LIKE">
                          </td>
                          <td><input type="text" class="inputalph" name="srchJobName" size="20" maxlength="20">
                              <input type="hidden" name="operJobName" value="LIKE">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchJobCode.focus();
                  </script>
              </form>

              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)&amp;backHome=@dtw_rurlescseq(backHome)")
                  @OrderBy_Sort("SWJOB", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=JobCode" title="Sequence By Job Code">Job Code</a></th>
                  @OrderBy_Sort("SWJNAM", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=JobName" title="Sequence By Job Code Description">Description</a></th>
                  <th class="colhdr">Number Of<br>Employees</th>
                  <th class="colhdr">Combined<br>Low</th>
                  <th class="colhdr">Combined<br>Median</th>
                  <th class="colhdr">Combined<br>High</th>
                  <th class="colhdr">Male<br>Employees</th>
                  <th class="colhdr">Male<br>Median</th>
                  <th class="colhdr">Female<br>Employees</th>
                  <th class="colhdr">Female<br>Median</th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"		
		
              %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;backHome=@dtw_rurlescseq(backHome)")
                      %INCLUDE "SetRowClass.icl"
                      %IF (V_SWJEMP != "0")
                          @dtw_divide(V_SWJTOT, V_SWJEMP, JAVG)
                      %else
                          @dtw_ASSIGN(JAVG, "0")
                      %ENDIF
                      %IF (V_SWMEMP != "0")
                          @dtw_divide(V_SWMTOT, V_SWMEMP, MAVG)
                      %else
                          @dtw_ASSIGN(MAVG, "0")
                      %ENDIF
                      %IF (V_SWFEMP != "0")
                          @dtw_divide(V_SWFTOT, V_SWFEMP, FAVG)
                      %else
                          @dtw_ASSIGN(FAVG, "0")
                      %ENDIF
                      @Format_Nbr(V_SWJEMP, F_SWJEMP, "0", $(qtyEditCode), "", "", "")
                      @Format_Nbr(V_SWJLO, F_SWJLO, "0", $(amtEditCode), "", "$", "")
                      @Format_Nbr(V_SWJHI, F_SWJHI, "0", $(amtEditCode), "", "$", "")
                      @Format_Nbr(V_SWMEMP, F_SWMEMP, "0", $(qtyEditCode), "", "", "")
                      @Format_Nbr(V_SWFEMP, F_SWFEMP, "0", $(qtyEditCode), "", "", "")
                      @Format_Nbr(JAVG, F_JAVG, "0", $(amtEditCode), "Y", "$", "")
                      @Format_Nbr(MAVG, F_MAVG, "0", $(amtEditCode), "Y", "$", "")
                      @Format_Nbr(FAVG, F_FAVG, "0", $(amtEditCode), "Y", "$", "")
                      <tr class="$(rowClass)">
                          <td class="colalph">$(V_SWJOB)</td>
                          <td class="colalph">$(V_SWJNAM)</td>
                          <td class="colnmbr">$(F_SWJEMP)</td>
                          <td class="colnmbr">$(F_SWJLO)</td>
                          <td class="colnmbr">$(F_JAVG)</td>
                          <td class="colnmbr">$(F_SWJHI)</td>
                          <td class="colnmbr">$(F_SWMEMP)</td>
                          <td class="colnmbr">$(F_MAVG)</td>
                          <td class="colnmbr">$(F_SWFEMP)</td>
                          <td class="colnmbr">$(F_FAVG)</td>
                      </tr>
               %}
	   </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "Select * ", stmtSQL)
  @dtw_concat(fileSQL, " PEWWRK ", fileSQL)
  @dtw_concat(selectSQL, " SWPECP = $(hrCompany) and SWXHND = '$(profileHandle)' ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @SalaryStats_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) SalaryStats_XMLQuery (IN CHAR(64) profileHandle,
				           CHAR(2)   dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @RetHrCompNam(profileHandle, dataBaseID, hrCompany, facilityZero, coFacName)
      @XMLBeginTag("SalaryStatsList")
          %ROW{
               %if (V_SWJEMP != "0")
                   @dtw_divide(V_SWJTOT, V_SWJEMP, JAVG)
               %else
                   @dtw_ASSIGN(JAVG, "0")
               %endif
               %if (V_SWMEMP != "0")
                   @dtw_divide(V_SWMTOT, V_SWMEMP, MAVG)
               %else
                   @dtw_ASSIGN(MAVG, "0")
               %endif
               %if (V_SWFEMP != "0")
                   @dtw_divide(V_SWFTOT, V_SWFEMP, FAVG)
               %else
                   @dtw_ASSIGN(FAVG, "0")
               %endif

               @XMLIDTag(@DTW_rCONCAT(V_SWPECP, @DTW_rCONCAT("/", coFacName)), "Company ID")
                   @XMLTag(V_SWPECP, "CompanyNumber")
                   @XMLTag(coFacName, "CompanyName")
                   @XMLTag(V_SWJOB, "JobCode")
                   @XMLTag(V_SWJNAM, "JobName")
                   @XMLTag(V_SWJEMP, "NumberOfEmployees")
                   @XMLTag(V_SWJLO, "CombinedLow")
                   @XMLTag(JAVG, "CombinedMedian")
                   @XMLTag(V_SWJHI, "CombinedHigh")
                   @XMLTag(V_SWMEMP, "MaleEmployees")
                   @XMLTag(MAVG, "MaleMedian")
                   @XMLTag(V_SWFEMP, "FemaleEmployees")
                   @XMLTag(FAVG, "FemaleMedian")

               @XMLEndTag("Company")
          %}
      @XMLEndTag("SalaryStatsList")
  %}
%}
%FUNCTION(DTW_directcall) Fill_Work_File (INOUT CHAR(64) profileHandle,
                                                CHAR(2)  dataBaseID,
                                                CHAR(2)  hrcompany)
{%EXEC {CPESSW_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "SWJOB")
              @DTW_ASSIGN(orderByDisplay, "Job Code")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      @Fill_Work_File(profileHandle, dataBaseID, hrCompany)
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "JobCode")
      %if (orderBy == "SWJOB")
          @DTW_ASSIGN(orderBy, "SWJOB DESC")
          @DTW_ASSIGN(orderByDisplay, "Job Code (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SWJOB")
          @DTW_ASSIGN(orderByDisplay, "Job Code")
      %endif
  %elif (sequence == "JobName")
      %if (orderBy == "SWJNAM")
          @DTW_ASSIGN(orderBy, "SWJNAM DESC")
          @DTW_ASSIGN(orderByDisplay, "Job Code Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SWJNAM")
          @DTW_ASSIGN(orderByDisplay, "Job Code Description")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("SWJOB", "Job Code", $(srchJobCode), "U", operJobCode, "A")
  @Build_WildCard ("upper(SWJNAM)", "Job Code Description", $(srchJobName), "U", operJobName, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}