%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "G/L Drill Down"
  d2wName                 = "GLDrillDown.d2w"
  d2wVarBase              = "$(genericVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "GLDRILLDOWN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select DDGRSN,DDGRSD,DDPERD,DDLPRC,DDLPTM,DDCMNT,DDGHCT,DDGHUS,DDGRSDU,DDSTAT", stmtSQL)
                      @dtw_concat(fileSQL, " GLDDRP ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, "DDGRSN <> ' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64) profileHandle,
                                   CHAR(2)   dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      <a href="$(homeURL)$(cGIPath)$(d2wName)/ENTRY$(d2wVarBase)&amp;formatToPrint=Y" target=_blank>$(formatPrintDesc)</a>
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST name="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr"> Selection Name</th>
                      <th class="colhdr"> Selection Category</th>
                      <th class="colhdr"> User ID</th>
                      <th class="colhdr"> Description</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchSelc" size="10" maxlength="10">
                          <input type="hidden" name="operSelc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchCat" size="4" maxlength="4">
                          <input type="hidden" name="operCat" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchUser" size="10" maxlength="10">
                          <input type="hidden" name="operUser" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchDesc" size="30" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchSelc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")

          <tr>
              @OrderBy_Sort("DDGRSN", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Selection" title="Sequence By Selection Name"> Selection Name</a></th>
              @OrderBy_Sort("DDGRSDU", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Description, Selection Name"> Description</a></th>
              @OrderBy_Sort("DDPERD", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PeriodOfSelection" title="Sequence By Period Of Selection, Selection Name"> Period Of Selection</a></th>
              @OrderBy_Sort("DDLPRC", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DateProcess" title="Sequence By Date Last Processed, Time Last Processed, Selection Name"> Date Last Processed</a></th>
              @OrderBy_Sort("DDLPTM", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TimeProcess" title="Sequence By Time Last Processed, Date Last Processed, Selection Name"> Time Last Processed</a></th>
              @OrderBy_Sort("DDGHCT", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Category" title="Sequence By Selection Category, Selection Name"> Selection Category</a></th>
              @OrderBy_Sort("DDGHUS", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=UserId" title="Sequence By User ID, Selection Name"> User ID</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"

              @PeriodFromCYP(V_DDPERD)
              @EditHrsMinSec(V_DDLPTM)
              @Format_Date(V_DDLPRC, "D", F_DDLPRC)

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)GLDrillDownSelection.d2w/ENTRY$(genericVarBase)&amp;ddReport=@dtw_rurlescseq(V_DDGRSN)&amp;ddDescr=@dtw_rurlescseq(V_DDGRSD)" onclick="$(drillDownWinVar)" title="View Selection">$(V_DDGRSN)</a></td>
                  %if (V_DDSTAT == "")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)GLDDCoFac.d2w/ENTRY$(genericVarBase)&amp;ddReport=@dtw_rurlescseq(V_DDGRSN)&amp;ddDescr=@dtw_rurlescseq(V_DDGRSD)" title="View Drill Down Report">$(V_DDGRSD)</a></td>
                  %else
                      <td class="colalph">$(V_DDGRSD)</td>
                  %endif
                  <td class="colnmbr">$(V_DDPERD)</td>
                  <td class="coldate">$(F_DDLPRC)</td>
                  <td class="colnmbr">$(V_DDLPTM)</td>
                  <td class="colalph">$(V_DDGHCT)</td>
                  <td class="colalph">$(V_DDGHUS)</td>
                  %if (V_DDCMNT == "Y" && formatToPrint == "")
                      <td class="colicon"><a href="$(homeURL)$(cGIPath)GLDrillDownComments.d2w/ENTRY$(genericVarBase)&amp;ddReport=@dtw_rurlescseq(V_DDGRSN)&amp;ddDescr=@dtw_rurlescseq(V_DDGRSD)" onclick="$(commentWinVar)" title="View Comments">$(commentExistImage)</a></td>
                  %endif
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"

  %if (formatToPrint == "Y")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "DDGRSDU,DDGRSN")
          @DTW_ASSIGN(orderByDisplay, "Description, Selection Name")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Selection")
      %if (orderBy == "DDGRSN")
          @DTW_ASSIGN(orderBy, "DDGRSN DESC")
          @DTW_ASSIGN(orderByDisplay, "Selection Name (descending)")
      %else
          @DTW_ASSIGN(orderBy, "DDGRSN")
          @DTW_ASSIGN(orderByDisplay, "Selection Name")
      %endif
  %elif (sequence == "Description")
      %if (orderBy == "DDGRSDU,DDGRSN")
          @DTW_ASSIGN(orderBy, "DDGRSDU DESC,DDGRSN")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Selection Name")
      %else
          @DTW_ASSIGN(orderBy, "DDGRSDU,DDGRSN")
          @DTW_ASSIGN(orderByDisplay, "Description, Selection Name")
      %endif
  %elif (sequence == "PeriodOfSelection")
      %if (orderBy == "DDPERD,DDGRSN")
          @DTW_ASSIGN(orderBy, "DDPERD DESC,DDGRSN")
          @DTW_ASSIGN(orderByDisplay, "Period Of Selection (descending), Selection Name")
      %else
          @DTW_ASSIGN(orderBy, "DDPERD,DDGRSN")
          @DTW_ASSIGN(orderByDisplay, "Period Of Selection, Selection Name")
      %endif
  %elif (sequence == "DateProcess")
      %if (orderBy == "DDLPRC,DDLPTM,DDGRSN")
          @DTW_ASSIGN(orderBy, "DDLPRC DESC,DDLPTM DESC,DDGRSN")
          @DTW_ASSIGN(orderByDisplay, "Date Last Processed (descending), Time Last Processed (descending), Selection Name")
      %else
          @DTW_ASSIGN(orderBy, "DDLPRC,DDLPTM,DDGRSN")
          @DTW_ASSIGN(orderByDisplay, "Date Last Processed, Time Last Processed, Selection Name")
      %endif
  %elif (sequence == "TimeProcess")
      %if (orderBy == "DDLPTM,DDLPRC,DDGRSN")
          @DTW_ASSIGN(orderBy, "DDLPTM DESC,DDLPRC DESC,DDGRSN")
          @DTW_ASSIGN(orderByDisplay, "Time Last Processed (descending), Date Last Processed (descending), Selection Name")
      %else
          @DTW_ASSIGN(orderBy, "DDLPTM,DDLPRC,DDGRSN")
          @DTW_ASSIGN(orderByDisplay, "Time Last Processed, Date Last Processed, Selection Name")
      %endif
  %elif (sequence == "Category")
      %if (orderBy == "DDGHCT,DDGRSN")
          @DTW_ASSIGN(orderBy, "DDGHCT DESC,DDGRSN")
          @DTW_ASSIGN(orderByDisplay, "Selection Category (descending), Selection Name")
      %else
          @DTW_ASSIGN(orderBy, "DDGHCT,DDGRSN")
          @DTW_ASSIGN(orderByDisplay, "Selection Category, Selection Name")
      %endif
  %elif (sequence == "UserId")
      %if (orderBy == "DDGHUS,DDGRSN")
          @DTW_ASSIGN(orderBy, "DDGHUS DESC,DDGRSN")
          @DTW_ASSIGN(orderByDisplay, "User ID (descending), Selection Name")
      %else
          @DTW_ASSIGN(orderBy, "DDGHUS,DDGRSN")
          @DTW_ASSIGN(orderByDisplay, "User ID, Selection Name")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editdate(document.Search.srchDate) &&
                      editNum(document.Search.srchTime, 6, 0) &&
                      editNum(document.Search.srchPeriod, 4, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "GLDRILLDOWNSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Selection Name</td>
                              @dtw_assign(operNbr, "operSelc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchSelc" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Selection Category</td>
                              @dtw_assign(operNbr, "operCat")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCat" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">User ID</td>
                              @dtw_assign(operNbr, "operUser")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchUser" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Report</td>
                              @dtw_assign(operNbr, "operRpt")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchReport" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Output Option</td>
                              @dtw_assign(operNbr, "operOutput")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchOutput" size="1" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Date Last Processed</td>
                              @dtw_assign(operNbr, "operDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchDate" size="6" maxlength="6"><a href="javascript:calWindow('srchDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Time Last Processed</td>
                              @dtw_assign(operNbr, "operTime")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchTime" size="6" maxlength="6"></td>
                          </tr>

                          <tr><td class="dsphdr">Period Of Selection</td>
                              @dtw_assign(operNbr, "operPeriod")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchPeriod" size="4" maxlength="4"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchSelc.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("DDGRSN", "Selection Name", $(srchSelc), "U", operSelc, "A")
  @Build_WildCard ("DDGHCT", "Category", $(srchCat), "U", operCat, "A")
  @Build_WildCard ("DDGHUS", "User", $(srchUser), "U", operUser, "A")
  @Build_WildCard ("DDGRSDU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("DDGRRN", "Report", $(srchReport), "U", operRpt, "A")
  @Build_WildCard ("DDOOPT", "Output Option", $(srchOutput), "U", operOutput, "A")
  @Build_WildCard ("DDLPRC", "Date Last Processed", $(srchDate), "", operDate, "D")
  @Build_WildCard ("DDLPTM", "Time Last Processed", $(srchTime), "", operTime, "N")
  @Build_WildCard ("DDPERD", "Period Of Selection", $(srchPeriod), "", operPeriod, "DP")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
