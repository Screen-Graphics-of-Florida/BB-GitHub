%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title 	           = "Federal EIN Search"
  d2wName                 = "EINSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_SET_TOTAL_ROWS      = "YES"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script type="text/javascript">
              function selectCode(fedEIN, EINName){
                  window.opener.document.$(docName).$(fldName).value = fedEIN;
                  window.opener.document.$(docName).$(fldDesc).value = EINName;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(uv_FederalEINName, "YDEIN")
                      %INCLUDE "userview.icl"
                      @dtw_assign(stmtSQL, "")
                      @dtw_concat(stmtSQL, "Select YDNAME, YDEIN FROM PRYDFL ", stmtSQL)
                      @dtw_concat(stmtSQL, " Where YDNAME<>' ' ", stmtSQL)
                      @dtw_concat(stmtSQL, " $(wildCardSearch)", stmtSQL)
                      @dtw_concat(stmtSQL, " Group By YDNAME, YDEIN Having (YDNAME<>' ') ", stmtSQL)
                      %if (uv_Sql != "")
                          @dtw_concat(stmtSQL, " and ($(uv_Sql))", stmtSQL)
                      %endif
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @EIN_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) EIN_Search (IN CHAR(64)    profileHandle,
				   CHAR(2)     dataBaseID,
                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"

      $(searchhrTagAttr)
      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr">Employer Name</th>
                  <th class="colhdr">EIN</th>
              </tr>
              <tr><td class="inputalph"><input type="text" name="srchName" size="30" maxlength="57">
                      <input type="hidden" name="operName" value="LIKE">
                  </td>
                  <td class="inputalph"><input type="text" name="srchEIN" size="9" maxlength="9">
                      <input type="hidden" name="operEIN" value="=">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
          <script TYPE="text/javascript">
              document.Search.srchName.focus();
          </script>
      </form>
	
      %INCLUDE "WildCardPage.icl"

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              @OrderBy_Sort("YDNAME", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=name" title="Sequence By Employer Name, EIN"> Employer Name</a></th>
              @OrderBy_Sort("YDEIN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ein" title="Sequence By EIN, Employer Name"> EIN</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"
          @Format_Quote(V_YDNAME, F_YDNAME)

          %ROW{
              %INCLUDE "SetRowClass.icl"

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="javascript:selectCode('$(V_YDEIN)','$(F_YDNAME)')" title="Select EIN">$(V_YDNAME)</a></td>
                  <td class="colalph">$(V_YDEIN)</td>
              </tr>
      %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "YDNAME,YDEIN")
      @DTW_ASSIGN(orderByDisplay, "Employer Name, EIN")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "name")
      %if (orderBy == "YDNAME,YDEIN")
          @DTW_ASSIGN(orderBy, "YDNAME DESC,YDEIN")
          @DTW_ASSIGN(orderByDisplay, "Employer Name (descending), EIN")
      %else
          @DTW_ASSIGN(orderBy, "YDNAME,YDEIN")
          @DTW_ASSIGN(orderByDisplay, "Employer Name, EIN")
      %endif
  %elif (sequence == "ein")
      %if (orderBy == "YDEIN,YDNAME")
          @DTW_ASSIGN(orderBy, "YDEIN DESC,YDNAME")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Code")
      %else
          @DTW_ASSIGN(orderBy, "YDEIN,YDNAME")
          @DTW_ASSIGN(orderByDisplay, "Description, Code")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("YDEIN", "Federal EIN", $(srchEIN), "", operEIN, "N")
  @Build_WildCard ("YDNAME", "Description", $(srchName), "U", operName, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}