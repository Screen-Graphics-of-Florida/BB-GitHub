%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title 		= "Employee Property"
  d2wName              = "EmployeeProperty.d2w"
  d2wVarBase           = "$(genericVarBase)$(employeeVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(d2wName)"
  nextPrevVar          = "$(d2wVarBase)"
  programName          = "HPEPRO"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  DTW_PAD_PGM_PARMS    = "YES"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext		= "1"
  totalPages		= "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
  @dtw_replace(workURL, "@@fromD2w", "@dtw_rurlescseq(fromD2w)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                       @dtw_assign(pageID, "EMPLPROPERTY")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "UserViewEmpl.icl"
                      %INCLUDE "UserView.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select PRSEQ, PRTYPR, PRDESC, PRISSU, PRRENW, ODDESC, EMCOMP, EMFACL, EMEMPL, EMPECP, EMPEMP, EMDEPT, EMLOC, EMTYPE,", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(PRDESC) as PRDESCU", stmtSQL)
                      @dtw_concat(fileSQL, " PEPROP inner join HREMPL on PRCOMP=EMPECP and PREMPL=EMPEMP ", fileSQL)
                      @dtw_concat(fileSQL, "        inner join PECODE on PRCOMP=ODCOMP and PRTYPR=ODCODE and ODTYPE='N' ", fileSQL)
                      @dtw_concat(selectSQL, " PRCOMP=$(hrCompany) and PREMPL=$(hrEmployee)", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Property_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Property_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="BackHome">$(portalHome)</a>
                          %endif
                          %if (sec_01 == "Y")
                              <a href="$(homeURL)$(cGIPath)EmplPropertyMaintain.d2w/REPORT$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                          %endif
                          <a href="$(homeURL)$(cGIPath)EmployeeMaintainSelect.d2w/REPORT$(d2wVarBase)">$(emplMaintImage)</a>
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>

              @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
              <tr><td><h2>$(F_EmpName)</h2></td></tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"	
          $(hrTagAttr)	

          %if (formatToPrint != "Y")
              <table $(contentTable)>
                  <tr><td> %INCLUDE "AssignPageValue.icl" </td></tr>
              </table>
          %endif

          <table $(contentTable)>
              <tr>
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("PRTYPR", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PropCode" title="Sequence By Property Type, Property Description, and Issue Date (descending)"> Property<br>Type</a></th>
                  <th class="colhdr">Type<br>Description</th>
                  @OrderBy_Sort("PRDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PropName" title="Sequence By Property Description, Property Type, and Issue Date (descending)"> Property<br>Description</a></th>	
                  @OrderBy_Sort("PRISSU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=IssueDate" title="Sequence By Issue Date (descending), Property Type"> Issue<br>Date</a></th>
                  @OrderBy_Sort("PRRENW", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RenewalDate" title="Sequence By Renewal Date (descending), Property Type"> Renewal<br>Date</a></th>
              </tr>		
              %INCLUDE "NoRecordsFound.icl"

      %ROW{
              @Format_Date(V_PRISSU, "D", F_PRISSU)
              @Format_Date(V_PRRENW, "D", F_PRRENW)

              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_PRDESC), "", $(V_ODDESC), $(V_PRTYPR), "", "", confirmDesc)
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;sequenceNumber=@dtw_rurlescseq(V_PRSEQ)&amp;propertyType=@dtw_rurlescseq(V_PRTYPR)&amp;propertyTypeDesc=@dtw_rurlescseq(V_ODDESC)&amp;propertyDesc=@dtw_rurlescseq(V_PRDESC)")
	       <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)EmplPropertyMaintain.d2w/REPORT$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)EmplPropertyMaintain.d2w/REPORT$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href=$(homeURL)$(cGIPath)EmplPropertyMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D>$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colcode">$(V_PRTYPR)</td>
                  <td class="colalph">$(V_ODDESC)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)EmplPropertySelect.d2w/REPORT$(maintainVar)" title="View Property Row">$(V_PRDESC)</a></td>
	           <td class="coldate">$(F_PRISSU)</td>
	           <td class="coldate">$(F_PRRENW)</td>
	       </tr>
	   %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "PRISSU,PRTYPR,PRDESCU")
              @DTW_ASSIGN(orderByDisplay, "Issue Date, Property Type, Property Description")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "PropCode")
      %if (orderBy == "PRTYPR,PRDESCU,PRISSU DESC")
          @DTW_ASSIGN(orderBy, "PRTYPR DESC,PRDESCU,PRISSU DESC")
          @DTW_ASSIGN(orderByDisplay, "Property Type (descending), Property Description, Issue Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PRTYPR,PRDESCU,PRISSU DESC")
          @DTW_ASSIGN(orderByDisplay, "Property Type, Property Description, Issue Date (descending)")
      %endif
  %elif (sequence == "PropName")
      %if (orderBy == "PRDESCU,PRTYPR,PRISSU DESC")
          @DTW_ASSIGN(orderBy, "PRDESCU DESC,PRTYPR,PRISSU DESC")
          @DTW_ASSIGN(orderByDisplay, "Property Description (descending), Property Type, Issue Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PRDESCU,PRTYPR,PRISSU DESC")
          @DTW_ASSIGN(orderByDisplay, "Property Description, Property Type, Issue Date (descending)")
      %endif
  %elif (sequence == "IssueDate")
      %if (orderBy == "PRISSU,PRTYPR")
          @DTW_ASSIGN(orderBy, "PRISSU DESC,PRTYPR")
          @DTW_ASSIGN(orderByDisplay, "Issue Date (descending), Property Type")
      %else
          @DTW_ASSIGN(orderBy, "PRISSU,PRTYPR")
          @DTW_ASSIGN(orderByDisplay, "Issue Date, Property Type")
      %endif
  %elif (sequence == "RenewalDate")
      %if (orderBy == "PRRENW,PRTYPR")
          @DTW_ASSIGN(orderBy, "PRRENW DESC,PRTYPR")
          @DTW_ASSIGN(orderByDisplay, "Renewal Date (descending), Property Type")
      %else
          @DTW_ASSIGN(orderBy, "PRRENW,PRTYPR")
          @DTW_ASSIGN(orderByDisplay, "Renewal Date, Property Type")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}