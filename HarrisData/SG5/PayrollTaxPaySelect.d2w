%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title		= "Payroll Tax Payment"
  d2wName              = "PayrollTaxPaySelect.d2w"
  d2wVarBase           = "$(genericVarBase)&amp;federalEin=@dtw_rurlescseq(federalEin)&amp;otherEin=@dtw_rurlescseq(otherEin)&amp;taxId=@dtw_rurlescseq(taxId)&amp;taxType=@dtw_rurlescseq(taxType)&amp;datePaid=@dtw_rurlescseq(datePaid)&amp;checkNumber=@dtw_rurlescseq(checkNumber)&amp;paymentSequence=@dtw_rurlescseq(paymentSequence)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar          = "$(d2wVarBase)&amp;taxTypeTwo=@dtw_rurlescseq(taxTypeTwo)"
  programName          = "HPRTPI"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  RPT_MAX_ROWS 	= "10"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext		= "1"
  totalPages		= "0"	
  taxTypeTwo           = ""
	
  advanceSearch        = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@federalEin", "@dtw_rurlescseq(federalEin)", "1", "a", workURL)
  @dtw_replace(workURL, "@@otherEin", "@dtw_rurlescseq(otherEin)", "1", "a", workURL)
  @dtw_replace(workURL, "@@taxId", "@dtw_rurlescseq(taxId)", "1", "a", workURL)
  @dtw_replace(workURL, "@@taxType", "@dtw_rurlescseq(taxType)", "1", "a", workURL)
  @dtw_replace(workURL, "@@datePaid", "@dtw_rurlescseq(datePaid)", "1", "a", workURL)
  @dtw_replace(workURL, "@@checkNumber", "@dtw_rurlescseq(checkNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@paymentSequence", "@dtw_rurlescseq(paymentSequence)", "1", "a", workURL)
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function goToPage(selectedPage) {if (selectedPage != "") {self.location=selectedPage;}}
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Trailer Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Trailer Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "TAXPAYMENT ")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                      @dtw_assign(START_ROW_NUM, "1")
                      <td class="content">

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " PRTXPH ", fileSQL)
                      @dtw_concat(selectSQL, " XPFEIN = $(federalEin) and XPSEIN = '$(otherEin)' and XPTXID = '$(taxId)' and XPTYPE = $(taxType) and XPPAID = $(datePaid) and XPCKNO = $(checkNumber) and XPSEQ = $(paymentSequence)", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      @Payment_Inquiry(profileHandle, dataBaseID, stmtSQL)
                      @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " PRTXDT ", fileSQL)
                      %if (taxType == "1")
                          @dtw_concat(selectSQL, " (XDFEIN = $(federalEin) and XDSEIN = '$(otherEin)' and XDTXID = '$(taxId)' and XDTYPE = $(taxType) and XDPAID = $(datePaid) and XDCKNO = $(checkNumber) and XDDPSQ = $(paymentSequence))", selectSQL)
                          @dtw_concat(selectSQL, " OR (XDFEIN = $(federalEin) and XDSEIN = '$(otherEin)' and XDTXID = '$(taxId)' and XDTYPE = $(taxTypeTwo) and XDPAID = $(datePaid) and XDCKNO = $(checkNumber) and XDDPSQ = $(paymentSequence))", selectSQL)
                      %else
                          @dtw_concat(selectSQL, " (XDFEIN = $(federalEin) and XDSEIN = '$(otherEin)' and XDTXID = '$(taxId)' and XDTYPE = $(taxType) and XDPAID = $(datePaid) and XDCKNO = $(checkNumber) and XDDPSQ = $(paymentSequence))", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Payment_Inquiry2(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Payment_Inquiry (IN CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/report") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Return To Company/Facility Select">$(portalHome)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>

          @RtvFldDesc("YDEIN=$(federalEin)", "PRYDFL", "YDNAME", einName)
          <tr><td><h2>$(einName)</h2></td></tr>

      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      <table $(contentTable)>
          %ROW {
              @dtw_assign(taxTypeTwo, "0")
              @dtw_add(V_XPTYPE, "1", taxTypeTwo)
              @Format_Date(V_XPDUE, "D", F_XDDUE)

              <tr><td class="dsphdr">Federal EIN</td>
                  <td class="dspalph">$(V_XPFEIN)</td></tr>
              %if (V_XPSEIN != "")
                  <tr><td class="dsphdr">State, SUI Or Local EIN</td>
                      <td class="dspalph">$(V_XPSEIN)</td></tr>
              %endif
              <tr><td class="dsphdr">Tax ID</td>
                  <td class="dspalph">$(V_XPTXID)</td></tr>
              <tr><td class="dsphdr">Tax Type</td>
                  @RtvFldDesc("XTTYPE=$(V_XPTYPE)", "PRTXTY", "XTDESC", taxTypeDesc)
                  <td class="dspalph">$(taxTypeDesc)</td></tr>
              <tr><td class="dsphdr">From Liability Date</td>
                  @Format_Date(V_XPFDAT, "D", F_XPFDAT)
                  <td class="dspalph">$(F_XPFDAT)</td></tr>
              <tr><td class="dsphdr">To Liability Date</td>
                  @Format_Date(V_XPTDAT, "D", F_XPTDAT)
                  <td class="dspalph">$(F_XPTDAT)</td></tr>
              %if(V_XPDUE != "0")
                  <tr><td class="dsphdr">Payment Due Date</td>
                      @Format_Date(V_XPDUE, "D", F_XPDUE)
                      <td class="dspalph">$(F_XPDUE)</td></tr>
              %endif
              <tr><td class="dsphdr">Date Paid</td>
                  @Format_Date(V_XPPAID, "D", F_XPPAID)
                  <td class="dspalph">$(F_XPPAID)</td></tr>
              <tr><td class="dsphdr">Amount Paid</td>
                  @Format_Nbr($(V_XPPAMT), F_XPPAMT, "2", $(amtEditCode), "", "", "")
                  <td class="dspalph">$(F_XPPAMT)</td></tr>
              <tr><td class="dsphdr">Paid To</td>
                  @RtvFldDesc("VMVEND=$(V_XPVEND)", "HDVEND", "VMVNA1", paidName)
                  <td class="dspalph">$(paidName)</td></tr>
              <tr><td class="dsphdr">Bank Number</td>
                  <td class="dspalph">$(V_XPBKNO)</td></tr>
              <tr><td class="dsphdr">Check Number</td>
                  %if(V_XPCKNO != "0")
                      @Format_Nbr($(V_XPCKNO), F_XPCKNO, "0", $(amtEditCode), "", "", "")
                      <td class="dspalph">$(F_XPCKNO)</td></tr>
                  %else
                      <td class="dspalph">EFT</td></tr>
                  %endif
              %if (V_XPCMN1 != "")
                  <tr><td class="dsphdr">Comment</td>
                      <td class="dspalph">$(V_XPCMN1)</td></tr>
              %endif
              %if (V_XPCMN2 != "")
                  <tr><td class="dsphdr">Comment 2</td>
                      <td class="dspalph">$(V_XPCMN2)</td></tr>
              %endif

          %}
      </table>
      $(hrTagAttr)
  %}
%}

%FUNCTION(dtw_sql) Payment_Inquiry2 (IN CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)

      <h3>Payroll Tax Liability Detail</h3>
          %if (formatToPrint != "Y")
              <table $(contentTable)>
                  <tr><td> %INCLUDE "AssignPageValue.icl" </td>
              </table>
          %endif

      <table $(contentTable)>
          <tr>
              <th class="colhdr">Check Date</th>
              %if ((taxType == "1") || (taxType == "11"))
                  <th class="colhdr">Tax<br>Type</th>
              %endif
              %if ((taxType == "5") || (taxType == "6") || (taxType == "15") || (taxType == "16"))
                  <th class="colhdr">Gross<br>SUI Wages</th>
              %else
                  <th class="colhdr">Taxable<br>Wages</th>
              %endif
              %if ((taxType == "1") || (taxType == "11"))
                  <th class="colhdr">FICA OASDI<br>Wages</th>
              %endif
              %if ((taxType == "5") || (taxType == "6") || (taxType == "15") || (taxType == "16"))
                  <th class="colhdr">SUI Basis<br>Wages</th>
              %endif
              <th class="colhdr">Employer<br>Tax</th>
              <th class="colhdr">Employee<br>Tax</th>
              %if ((taxType == "1") || (taxType == "11"))
                  <th class="colhdr">EIC</th>
              %endif
              <th class="colhdr">Payment<br>Due Date</th>
              <th class="colhdr">Amount<br>Paid</th>
              <th class="colhdr">Override<br>Payment Amount</th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;detailTaxType=@dtw_rurlescseq(V_XDTYPE)&amp;checkDate=@dtw_rurlescseq(V_XDDATE)&amp;sequenceNumber=@dtw_rurlescseq(V_XDSEQ)")
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  @Format_Date(V_XDDATE, "D", F_XDDATE)
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)PayrollTaxDtlSelect.d2w/REPORT$(maintainVar)" title="View Payroll Tax Liability Detail">$(F_XDDATE)</a></td>
                  %if ((V_XDTYPE == "1")  || (V_XDTYPE == "2") || (V_XDTYPE == "11") || (V_XDTYPE == "12"))
                      @RtvFldDesc("XTTYPE=$(V_XDTYPE)", "PRTXTY", "XTDESC", dtlTypeDesc)
                      <td class="colalph">$(dtlTypeDesc)</td>
                  %endif
                  @Format_Nbr($(V_XDTWG1), F_WAGES, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_WAGES)</td>
                  %if ((V_XDTYPE == "5") || (V_XDTYPE == "6") || (V_XDTYPE == "15") || (V_XDTYPE == "16"))
                      @Format_Nbr($(V_XDTWG2), F_WAGES, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_WAGES)</td>
                  %endif
                  @dtw_assign(workWages, "0")
                  %if ((V_XDTYPE == "2") || (V_XDTYPE == "12"))
                      @dtw_add(V_XDTWG2, V_XDTWG3, workWages)
                      @Format_Nbr($(workWages), F_WAGES2, "2", $(amtEditCode), "", "", "")
                  %endif
                  %if ((V_XDTYPE == "1")  || (V_XDTYPE == "2") || (V_XDTYPE == "11") || (V_XDTYPE == "12"))
                      %if (V_XDTYPE == "2" || V_XDTYPE == "12")
                          <td class="colnmbr">$(F_WAGES2)</td>
                      %else
                          <td class="colnmbr">&nbsp;</td>
                      %endif
                  %endif
                  @Format_Nbr($(V_XDRAMT), F_XDRAMT, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_XDRAMT)</td>
                  @Format_Nbr($(V_XDEAMT), F_XDEAMT, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_XDEAMT)</td>
                  %if ((V_XDTYPE == "1")  || (V_XDTYPE == "2") || (V_XDTYPE == "11") || (V_XDTYPE == "12"))
                      @Format_Nbr($(V_XDEIC), F_XDEIC, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_XDEIC)</td>
                  %endif
                  @Format_Date(V_XDDUE, "D", F_XDDUE)
                  <td class="colalph">$(F_XDDUE)</td>
                  @Format_Nbr($(V_XDPAMT), F_XDPAMT, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_XDPAMT)</td>
                  @Format_Nbr($(V_XDOPAM), F_XDOPAM, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_XDOPAM)</td>
              </tr>
          %}
      </table>
      $(hrTagAttr)
      %INCLUDE "PageBottom.icl"
      %INCLUDE "Copyright.icl"
  %}
%}
%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"

  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      @Set_SQL(stmtSQL)
  %endif
%}