%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "QuickLink.icl"

%Define {	
  page_title              = "Cost Simulation"
  d2wName                 = "CostSimulatorDisplay.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(fromPlant)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)"
  programName             = "HSCSIM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
  customerNumber          = "0"	
  itemDescription         = ""	
  orderQuantity           = "0"	
  percentSM               = "0"	
  percentGA               = "0"	
  calcPrice               = "0"	
  sellPrice               = "0"	
  addonTotal              = "0"	
  amountMiscTwo           = "0"	
  percentOne              = "0"	
  percentTwo              = "0"	
  percentThree            = "0"	
  percentFour             = "0"	
  wareHouse               = "0"	
  listPrice               = "0"	
  quickLinkByUser         = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}
	
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                          @dtw_assign(pageID, "COSTSIMULATORDISPLAY")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">

%{ QuickLink Table %}     %INCLUDE "QuickLinkTable.icl"

%{ Featured Item %}
                          @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMKIT", V_IMKIT)
                          %if (V_IMKIT != "F")		
                              @Remove_Quick_Link("featuresandoptions")
                          %endif

%{ QuickLink By User %}   %INCLUDE "QuickLinkByUser.icl"

%{ Cost Simulator Heading %}
                          @dtw_assign(RPT_MAX_ROWS, "99")
                          @dtw_assign(dspMaxRows, "10")
                          @dtw_assign(stmtSQL, "")
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(stmtSQL, " From WRKSIM Where WKXHND='$(profileHandle)' ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @Cost_Simulator_Header(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Begin %}     %INCLUDE "QuickLinkBegLoop.icl"

        %{ Cost Summary %}
                              %if (quicklinkRef == "costsummary")
                                  @dtw_assign(stmtSQL, "")
                                  @dtw_concat(stmtSQL, "SELECT * FROM HDPLNT ", stmtSQL)
                                  @dtw_concat(stmtSQL, " WHERE PLPLNT=$(plantNumber) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Cost_Simulator_Summary(profileHandle, dataBaseID, stmtSQL)

        %{ Routing %}
                              %elif (quicklinkRef == "routing")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " WRKRTM ", fileSQL)
                                  @dtw_concat(selectSQL, " WKXHND='$(profileHandle)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_concat(stmtSQL, " Order By WKDEPT, WKWC ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Cost_Simulator_Routing(profileHandle, dataBaseID, stmtSQL)

        %{ Product Structure %}
                              %elif (quicklinkRef == "productstructure")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select *  ", stmtSQL)
                                  @dtw_concat(fileSQL, " WRKPSM ", fileSQL)
                                  @dtw_concat(selectSQL, " WKXHND='$(profileHandle)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_concat(stmtSQL, " Order By WKCPN ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Cost_Simulator_Product_Structure(profileHandle, dataBaseID, stmtSQL)

        %{ Part Class Summary %}
                              %elif (quicklinkRef == "partclasssummary")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(distinctSQL, "WKCLAS||WKCDES", distinctSQL)
                                  @dtw_concat(stmtSQL, "Select WKCLAS, WKCDES, Sum((WKSCPP + 1) * WKQPER * WKUCST * $(orderQuantity)) as extCost", stmtSQL)
                                  @dtw_concat(fileSQL, " WRKPSM ", fileSQL)
                                  @dtw_concat(selectSQL, " WKXHND='$(profileHandle)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_concat(stmtSQL, " Group By WKCLAS, WKCDES ", stmtSQL)
                                  @dtw_concat(stmtSQL, " Order By WKCLAS ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Cost_Simulator_Part_Class(profileHandle, dataBaseID, stmtSQL)

        %{ Variable Costs %}
                              %elif (quicklinkRef == "variablecosts")
                                  @dtw_assign(stmtSQL, "")
                                  @dtw_concat(stmtSQL, "SELECT * FROM HDPLNT ", stmtSQL)
                                  @dtw_concat(stmtSQL, " WHERE PLPLNT=$(plantNumber) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Cost_Simulator_Variable_Cost(profileHandle, dataBaseID, stmtSQL)

        %{ Features And Options %}
                              %elif (quicklinkRef == "featuresandoptions")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "Select a.*,coalesce(b.FXPRIC,0) as FXPRIC ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDFOPW a left join HDFPOP b on FXPLT=$(plantNumber) and (FXFPRT=' ' or '$(itemNumber)'=FXFPRT) and SAFEAT=FXFEAT and SAOPTN=FXOPTN", fileSQL)
                                  @dtw_concat(selectSQL, " SAXHND='$(profileHandle)' and SAMNCD='S' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Cost_Simulator_Features_Options(profileHandle, dataBaseID, stmtSQL)
                              %endif

%{ Quicklink End %}       %INCLUDE "QuickLinkEndLoop.icl"

                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Cost_Simulator_Header (IN  CHAR(64)    profileHandle,
                                              CHAR(2)     dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
                      %if (backURL != "")
                          <a href="$(backURL)" title="BackHome">$(portalHome)</a>
                      %else
                          <a href="$(homeURL)$(cGIPath)ItemPlantSelect.d2w/REPORT$(d2wVarBase)" title="BackHome">$(portalHome)</a>
                      %endif
                      <a href="$(homeURL)$(cGIPath)CostSimulatorVariableMaintain.d2w/MAINTAIN$(d2wVarBase)">$(changeImageLrg)</a>
                      <a href="$(homeURL)$(cGIPath)ProductStructureInquiry.d2w/DISPLAY$(d2wVarBase)" onclick="$(inquiryWinVar)">$(prodStrImageLrg)</a>
                      <a href="$(homeURL)$(cGIPath)ReferenceRoutingInquiry.d2w/DISPLAY$(d2wVarBase)" onclick="$(inquiryWinVar)">$(refRtgImageLrg)</a>
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      %ROW{

          @dtw_assign(itemImage, "$(itemNumber)$(itemImageExt)")
          @dtwf_exists(itemImage, imageExists)
          @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
          @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
          @RtvFldDesc("STCSET=$(V_WKCSET)", "SCMSTM", "STCSLD", costSetDesc)
          <table $(contentTable)>
              <colgroup>
                  <col width="70%">
                  <col width="25%">
              <tr>
                  <td>
                      <table $(contentTable)>
                          @Format_Header_URL("Plant", $(plantName), $(plantNumber), "$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)")
                          %if (formatToPrint != "Y")
                              @Format_Header_URL("Item", $(itemDescription), $(itemNumber), "$(homeURL)$(cGIPath)ItemSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;itemDescription=@dtw_rurlescseq(itemDescription)")
				          %else
				              <tr><td class="hdrtitl">Item:</td> <td class="inputalph">&nbsp;<input name="desc" type="text"  style="color:red;font-weight: bold" value="$(itemDescription)" size="30" maxlength="30"><input name="item" type="text" style="color:red;font-weight: bold" value="$(itemNumber)" size="15" maxlength="15"></td></tr>
				          %endif
                          @Format_Header("Cost Set", "$(costSetDesc)", $(V_WKCSET))
                          %if (V_WKCUST != "0")
                              @RtvFldDesc("CMCUST=$(V_WKCUST)", "HDCUST", "CMCNA1", customerName)
                              @Format_Header("Customer Number", "$(customerName)", $(V_WKCUST))
                          %endif
                          @Format_Header("Quantity", "$(V_WKQTY)", "")
                          %if (V_WKRQDT != "0")
                          	  @DateFromCYMD(V_WKRQDT)
                              @Format_Header("Date", $(V_WKRQDT), "")
                          %endif
                          %if (V_WKWHS != "0")
                              @RtvFldDesc("WHWHS=$(V_WKWHS)", "HDWHSM", "WHWHNM", fieldDesc)
                              @Format_Header("Warehouse", "$(fieldDesc)", $(V_WKWHS))
                          %endif
                          %if (V_WKCCLSX != "")
                              @RtvFldDesc("CCCCLS='$(V_WKCCLSX)'", "HDCCLS", "CCCCDS", fieldDesc)
                              @Format_Header("Customer Class", "$(fieldDesc)", $(V_WKCCLSX))
                          %endif
                          %if (V_WKCRGNX != "")
                              @RtvFldDesc("RGCRGN='$(V_WKCRGNX)'", "HDCRGN", "RGCRDS", fieldDesc)
                              @Format_Header("Region", "$(fieldDesc)", $(V_WKCRGNX))
                          %endif
                          %if (V_WKPCLSX != "")
                              @RtvFldDesc("PCPCLS='$(V_WKPCLSX)'", "HDPCLS", "PCPCDS", fieldDesc)
                              @Format_Header("Product Class", "$(fieldDesc)", $(V_WKPCLSX))
                          %endif
                          %if (V_WKPGRPX != "")
                              @RtvFldDesc("PGPGRP='$(V_WKPGRPX)'", "HDPRGM", "PGDESC", fieldDesc)
                              @Format_Header("Product Group", "$(fieldDesc)", $(V_WKPGRPX))
                          %endif
                      </table>
                  </td>
                  %if (imageExists == "Y")
                      <td>
                          <table $(contentTable)>
                              <tr rowspan="8"><td><a href="$(homeURL)$(cGIPath)imageDisplay.d2w/DISPLAY$(genericVarBase)&amp;imageDisplayPath=$(homeURL)$(itemImage)&amp;imageDesc=@dtw_rurlescseq(itemDescription)" onclick="$(itemImageWinVar)"><img src="$(homeURL)$(itemImage)" border="0" height="150" width="150" title="Click here to view larger image"></a></td></tr>
                          </table>
                      </td>
                  %endif
              </tr>
          </table>

          @dtw_assign(customerNumber, "$(V_WKCUST)")
          @dtw_assign(orderQuantity,  "$(V_WKQTY)")
          @dtw_assign(percentSM,      "$(V_WKSPCT)")
          @dtw_assign(percentGA,      "$(V_WKGPCT)")
          @RtvFldDesc("IWITEM='$(itemNumber)' and IWWHS=$(V_WKWHS)", "HDIWHS", "coalesce(IWPCPP,1)", IWPCPP)
          @dtw_assign(calcPrice,      @dtw_rdivide(@dtw_rMultiply(V_WKCALC, V_WKQTY),IWPCPP))
          @dtw_assign(sellPrice,      @dtw_rdivide(@dtw_rMultiply(V_WKSELL, V_WKQTY),IWPCPP))
          @dtw_assign(addonTotal,     "$(V_WKUDA1)")
          @dtw_assign(amountMiscTwo,  "$(V_WKUDA2)")
          @dtw_assign(percentOne,     "$(V_WKPCA1)")
          @dtw_assign(percentTwo,     "$(V_WKPCA2)")
          @dtw_assign(percentThree,   "$(V_WKPCA3)")
          @dtw_assign(percentFour,    "$(V_WKPCA4)")
          @dtw_assign(wareHouse,      "$(V_WKWHS)")
      %}

      $(hrTagAttr)
      %INCLUDE "QuickLinkDisplay.icl"
	   		
  %}
%}

%FUNCTION(dtw_sql) Cost_Simulator_Summary (IN  CHAR(64)    profileHandle,
                                               CHAR(2)     dataBaseID,
                                               CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="costsummary"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          <tr>
              <th></th>
              <th class="colhdr">MFG Overhead</th>
              <th class="colhdr">Total MFG Cost</th>
              <th class="colhdr">S&M % MFG</th>
              <th class="colhdr">G&A % MFG</th>
              <th class="colhdr">Variable Costs</th>
              <th class="colhdr">Total Cost</th>
              <th class="colhdr">Sell Price</th>
              <th class="colhdr">Profit $</th>
              <th class="colhdr">Profit %</th>
          </tr>

          %ROW{
              @RtvFldDesc("WKXHND='$(profileHandle)'", "WRKRTM", "char(coalesce(round(sum(WKMHRS*$(orderQuantity)*WKSLR),5),0))", V_TLLCST)
              @RtvFldDesc("WKXHND='$(profileHandle)'", "WRKRTM", "char(coalesce(round(sum(WKMHRS*$(orderQuantity)*WKSLR*WKVAR/100),5),0))", V_TLVOVH)
              @RtvFldDesc("WKXHND='$(profileHandle)'", "WRKRTM", "char(coalesce(round(sum(WKMHRS*$(orderQuantity)*WKSLR*WKFIX/100),5),0))", V_TLFOVH)
              @RtvFldDesc("WKXHND='$(profileHandle)'", "WRKPSM", "char(coalesce(round(sum((1+WKSCPP)*WKQPER*WKUCST*$(orderQuantity)),5),0))", V_TLMCST)
              @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMKIT", V_IMKIT)
              @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMPCLS", V_IMPCLS)
              @RtvFldDesc("IWITEM='$(itemNumber)' and IWWHS=$(wareHouse)", "HDIWHS", "IWPGRP", V_IWPGRP)

              @dtw_assign(totalOverhead, @dtw_rAdd(V_TLVOVH, V_TLFOVH))
              @dtw_assign(variableMFGCost, @dtw_rAdd(@dtw_rAdd(V_TLLCST, V_TLVOVH), V_TLMCST))
              @dtw_assign(totalMFGCost, @dtw_rAdd(variableMFGCost, V_TLFOVH))
              @dtw_assign(totalSM, @dtw_rdivide(@dtw_rMultiply(totalMFGCost, percentSM), "100"))
              @dtw_assign(totalGA, @dtw_rdivide(@dtw_rMultiply(totalMFGCost, percentGA), "100"))
              @dtw_assign(totalVariable, @dtw_rAdd(addonTotal, amountMiscTwo))
              @dtw_assign(totalVariable, @dtw_rAdd(totalVariable, @dtw_rDivide(@dtw_rMultiply(percentOne, sellPrice), "100")))
              @dtw_assign(totalVariable, @dtw_rAdd(totalVariable, @dtw_rDivide(@dtw_rMultiply(percentTwo, sellPrice), "100")))
              @dtw_assign(totalVariable, @dtw_rAdd(totalVariable, @dtw_rDivide(@dtw_rMultiply(percentThree, sellPrice), "100")))
              @dtw_assign(totalVariable, @dtw_rAdd(totalVariable, @dtw_rDivide(@dtw_rMultiply(percentFour, sellPrice), "100")))
              @dtw_assign(variableTotal, @dtw_rAdd(variableMFGCost, totalVariable))
              @dtw_assign(fixedTotal, @dtw_rAdd(@dtw_rAdd(V_TLFOVH, totalSM), totalGA))
              @dtw_assign(grandTotal, @dtw_rAdd(fixedTotal, variableTotal))
              @dtw_assign(profitVarDol, @dtw_rSubtract(sellPrice, variableTotal))
              @dtw_assign(profitTotDol, @dtw_rSubtract(sellPrice, grandTotal))
              @dtw_assign(profitVarPct, @dtw_rMultiply(@dtw_rDivide(profitVarDol, sellPrice), "100"))
              @dtw_assign(profitTotPct, @dtw_rMultiply(@dtw_rDivide(profitTotDol, sellPrice), "100"))

              @Format_Nbr(V_TLVOVH, F_TLVOVH, $(cstNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Nbr(V_TLFOVH, F_TLFOVH, $(cstNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Nbr(totalOverhead, totalOverhead, $(cstNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Nbr(variableMFGCost, variableMFGCost, $(cstNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Nbr(totalMFGCost, totalMFGCost, $(cstNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Nbr($(percentSM), F_PLSPCT, "2", $(pctEditCode), "", "", "%")
              @Format_Nbr($(percentGA), F_PLGPCT, "2", $(pctEditCode), "", "", "%")
              @Format_Nbr(totalSM, totalSM, $(cstNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Nbr(totalGA, totalGA, $(cstNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Nbr(totalVariable, F_totalVariable, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr(variableTotal, variableTotal, $(cstNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Nbr(fixedTotal, fixedTotal, $(cstNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Nbr(grandTotal, grandTotal, $(cstNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Nbr(sellPrice, F_sellPrice, $(prcNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Nbr(profitVarDol, profitVarDol, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr(profitTotDol, profitTotDol, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr(profitVarPct, profitVarPct, "2", $(pctEditCode), "Y", "", "%")
              @Format_Nbr(profitTotPct, profitTotPct, "2", $(pctEditCode), "Y", "", "%")

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Variable</td>
                  <td class="colnmbr"><a href="#routing" title="Click here to go to Routing">$(F_TLVOVH)</a></td>
                  <td class="colnmbr">$(variableMFGCost)</td>
                  <td></td>
                  <td></td>
                  <td class="colnmbr"><a href="#variablecosts" title="Click here to go to Variable Costs">$(F_totalVariable)</a></td>
                  <td class="colnmbr">$(variableTotal)</td>
                  %if (V_IMKIT != "F")		
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)PricingInquiry.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;itemDescription=@dtw_rurlescseq(itemDescription)&amp;warehouseNumber=@dtw_rurlescseq(wareHouse)&amp;productClass=@dtw_rurlescseq(V_IMPCLS)&amp;productGroup=@dtw_rurlescseq(V_IWPGRP)&amp;quantity=@dtw_rurlescseq(orderQuantity)" onclick="$(inquiryWinVar)" title="View Pricing">$(F_sellPrice)</a></td>
                  %else
                      <td class="colnmbr">$(F_sellPrice)</td>
                  %endif
                  <td class="colnmbr">$(profitVarDol)</td>
                  <td class="colnmbr">$(profitVarPct)</td>
              </tr>
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Fixed</td>
                  <td class="colnmbr"><a href="#routing" title="Click here to go to Routing">$(F_TLFOVH)</a></td>
                  <td class="colnmbr"><a href="#routing" title="Click here to go to Routing">$(F_TLFOVH)</a></td>
                  <td class="colnmbr" $(helpCursor)><span title="$(F_PLSPCT) of $(totalMFGCost) (Total MFG Cost)">$(totalSM)</span></td>
                  <td class="colnmbr" $(helpCursor)><span title="$(F_PLGPCT) of $(totalMFGCost) (Total MFG Cost)">$(totalGA)</span></td>
                  <td></td>
                  <td class="colnmbr">$(fixedTotal)</td>
                  <td></td>
                  <td></td>
                  <td></td>
              </tr>
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Total</td>
                  <td class="coltotal">$(totalOverhead)</td>
                  <td class="coltotal">$(totalMFGCost)</td>
                  <td class="coltotal" $(helpCursor)><span title="$(F_PLSPCT) of $(totalMFGCost) (Total MFG Cost)">$(totalSM)</span></td>
                  <td class="coltotal" $(helpCursor)><span title="$(F_PLGPCT) of $(totalMFGCost) (Total MFG Cost)">$(totalGA)</span></td>
                  <td class="coltotal"><a href="#variablecosts" title="Click here to go to Variable Costs">$(F_totalVariable)</a></td>
                  <td class="coltotal">$(grandTotal)</td>
                  %if (V_IMKIT != "F")		
                      <td class="coltotal"><a href="$(homeURL)$(cGIPath)PricingInquiry.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;itemDescription=@dtw_rurlescseq(itemDescription)&amp;warehouseNumber=@dtw_rurlescseq(wareHouse)&amp;productClass=@dtw_rurlescseq(V_IMPCLS)&amp;productGroup=@dtw_rurlescseq(V_IWPGRP)&amp;quantity=@dtw_rurlescseq(orderQuantity)" onclick="$(inquiryWinVar)" title="View Pricing">$(F_sellPrice)</a></td>
                  %else
                      <td class="coltotal">$(F_sellPrice)</td>
                  %endif
                  <td class="coltotal">$(profitTotDol)</td>
                  <td class="coltotal">$(profitTotPct)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Cost_Simulator_Routing (IN  CHAR(64)    profileHandle,
                                               CHAR(2)     dataBaseID,
                                               CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="routing"></a>
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)CostSimulatorRoutingMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=A")
      @dtw_assign(moreInfoImage, "$(addImageMed)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  %if (formatToPrint != "Y")
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @Format_Column_Header("WKDEPT", "Department")
                  @Format_Column_Header("WKWC", "Work<br>Center")
                  @Format_Column_Header("WCDesc", "Work Center<br>Description")
                  @Format_Column_Header("WKMHRS", "Hours/<br>Piece")
                  @Format_Column_Header("WKSLR", "Rate/<br>Hour")
                  @Format_Column_Header("labAmount", "Labor<br>Cost")
                  @Format_Column_Header("varAmount", "Variable")
                  @Format_Column_Header("fixAmount", "Fixed")
                  @Format_Column_Header("totAmount", "Total")
              </tr>
          %endif

          @dtw_assign(totalLaborCost, "0")
          @dtw_assign(totalVarCost, "0")
          @dtw_assign(totalFixCost, "0")
          @dtw_assign(totalLabor, "0")

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @RtvFldDesc("WCPLT=$(plantNumber) and WCDEPT='$(V_WKDEPT)' and WCWC='$(V_WKWC)'", "HDMWCM", "WCDESC", WCDesc)

              @dtw_assign(labAmount, @dtw_rMultiply(@dtw_rMultiply(V_WKMHRS, orderQuantity), V_WKSLR))
              @dtw_assign(totalLaborCost, @dtw_rAdd(totalLaborCost, labAmount))
              @dtw_assign(varAmount, @dtw_rdivide(@dtw_rMultiply(labAmount, V_WKVAR), "100"))
              @dtw_assign(totalVarCost, @dtw_rAdd(totalVarCost, varAmount))
              @dtw_assign(fixAmount, @dtw_rdivide(@dtw_rMultiply(labAmount, V_WKFIX), "100"))
              @dtw_assign(totalFixCost, @dtw_rAdd(totalFixCost, fixAmount))
              @dtw_assign(totAmount, @dtw_rAdd(@dtw_rAdd(labAmount, varAmount), fixAmount))

              @Format_Nbr($(V_WKMHRS), F_WKMHRS, "6", $(hrsEditCode), "", "", "")
              @Format_Nbr($(V_WKSLR), F_WKSLR, "3", $(rteEditCode), "", "", "")
              @Format_Nbr($(V_WKVAR), F_WKVAR, "3", $(pctEditCode), "", "", "%")
              @Format_Nbr($(V_WKFIX), F_WKFIX, "3", $(pctEditCode), "", "", "%")
              @Format_Nbr(orderQuantity, F_WKQTY, "4", $(qtyEditCode), "", "", "")
              @Format_Nbr(labAmount, labAmount, $(cstNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Nbr(varAmount, varAmount, $(cstNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Nbr(fixAmount, fixAmount, $(cstNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Nbr(totAmount, totAmount, $(cstNbrDec), $(amtEditCode), "Y", "", "")

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y")
                      <td class="opticon">
                          <a href="$(homeURL)$(cGIPath)CostSimulatorRoutingMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;department=@dtw_rurlescseq(V_WKDEPT)&amp;workCenter=@dtw_rurlescseq(V_WKWC)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          <a href="$(homeURL)$(cGIPath)CostSimulatorRoutingMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;department=@dtw_rurlescseq(V_WKDEPT)&amp;workCenter=@dtw_rurlescseq(V_WKWC)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          <a href="$(homeURL)$(cGIPath)CostSimulatorRoutingMaintain.d2w/Edit_Data$(d2wVarBase)&amp;department=@dtw_rurlescseq(V_WKDEPT)&amp;workCenter=@dtw_rurlescseq(V_WKWC)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                      </td>
                  %endif
                  <td class="colalph">$(V_WKDEPT)</td>
                  <td class="colalph">$(V_WKWC)</td>
                  <td class="colalph">$(WCDesc)</td>
                  <td class="colnmbr">$(F_WKMHRS)</td>
                  <td class="colnmbr">$(F_WKSLR)</td>
                  <td class="colnmbr" $(helpCursor)><span title="$(F_WKMHRS) (Hours/Piece) x $(F_WKSLR) (Rate/Hour) x $(F_WKQTY) (Quantity)">$(labAmount)</span></td>
                  <td class="colnmbr" $(helpCursor)><span title="$(F_WKVAR) of $(labAmount) (Labor Cost)">$(varAmount)</span></td>
                  <td class="colnmbr" $(helpCursor)><span title="$(F_WKFIX) of $(labAmount) (Labor Cost)">$(fixAmount)</span></td>
                  <td class="colnmbr">$(totAmount)</td>
              </tr>
          %}
          %if (sql_Record_Count != "0")
              %if (formatToPrint != "Y")
                  @dtw_assign(totalSpan, "6")
              %else
                  @dtw_assign(totalSpan, "5")
              %endif
              %INCLUDE "SetRowClass.icl"
              @dtw_assign(totalLabor, @dtw_rAdd(@dtw_rAdd(totalLaborCost, totalVarCost), totalFixCost))

              @Format_Nbr(totalLaborCost, F_totalLaborCost, $(cstNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Nbr(totalVarCost, F_totalVarCost, $(cstNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Nbr(totalFixCost, F_totalFixCost, $(cstNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Nbr(totalLabor, F_totalLabor, $(cstNbrDec), $(amtEditCode), "Y", "", "")
              <tr class="$(rowClass)">
                  <td class="colnmbr" colspan="$(totalSpan)">Total Labor Cost</td>
                  <td class="coltotal">$(F_totalLaborCost)</td>
                  <td class="coltotal">$(F_totalVarCost)</td>
                  <td class="coltotal">$(F_totalFixCost)</td>
                  <td class="coltotal">$(F_totalLabor)</td>
              </tr>
              %if (formatToPrint != "Y")
                  @dtw_assign(totalSpan, "9")
              %else
                  @dtw_assign(totalSpan, "8")
              %endif
              %INCLUDE "SetRowClass.icl"
              @dtw_assign(percentLabor, @dtw_rMultiply(@dtw_rDivide(totalLabor, sellPrice), "100"))
              @Format_Nbr(percentLabor, percentLabor, "2", $(pctEditCode), "Y", "", "")
              <tr class="$(rowClass)">
                  <td class="colnmbr" colspan="$(totalSpan)">Labor Cost/Selling Price %</td>
                  <td class="colnmbr">$(percentLabor)</td>
              </tr>
          %endif
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Cost_Simulator_Product_Structure (IN  CHAR(64)    profileHandle,
                                                         CHAR(2)     dataBaseID,
                                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="productstructure"></a>
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)CostSimulatorProductStructureMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=A")
      @dtw_assign(moreInfoImage, "$(addImageMed)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  %if (formatToPrint != "Y")
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @Format_Column_Header("WKCPN", "Component<br>Item")
                  @Format_Column_Header("itemDescription", "Component Description")
                  @Format_Column_Header("WKQPER", "Quantity<br>Per")
                  @Format_Column_Header("WKCLAS", "Part<br>Class")
                  @Format_Column_Header("WKPTYP", "Part<br>Type")
                  @Format_Column_Header("WKUOMS", "Unit Of<br>Measure")
                  @Format_Column_Header("WKSCPP", "Scrap<br>Percent")
                  @Format_Column_Header("WKUCST", "Unit Cost")
                  @Format_Column_Header("extCost", "Extended<br>Unit Cost")
              </tr>
          %endif

          @dtw_assign(totalMaterial, "0")

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @RtvFldDesc("IMITEM='$(V_WKCPN)'", "HDIMST", "IMIMDS", itemDescription)
              @RtvFldDesc("FLTYPE='PARTTYPE' and FLVALU='$(V_WKPTYP)'", "SYFLAG", "FLDESC", partTypeDesc)
              @RtvFldDesc("UMUOM='$(V_WKUOMS)'", "HDUOM", "UMUMLD", uomDesc)

              @dtw_assign(extCost, @dtw_rMultiply(@dtw_rMultiply(@dtw_rMultiply(@dtw_rAdd(V_WKSCPP,"1"),V_WKQPER), V_WKUCST), orderQuantity))
              @dtw_assign(totalMaterial, @dtw_rAdd(totalMaterial, extCost))

              @Format_Nbr(orderQuantity, F_WKQTY, "4", $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_WKQPER), F_WKQPER, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr("@dtw_rMultiply(V_WKSCPP, "100")", F_WKSCPP, "0", $(pctEditCode), "", "", "%")
              @Format_Nbr($(V_WKUCST), F_WKUCST, $(cstNbrDec), $(amtEditCode), "Y", "", "")
              @Format_Nbr(extCost, extCost, $(cstNbrDec), $(amtEditCode), "Y", "", "")
              @dtw_assign(F_TXSCPP, "")
              %if (V_WKSCPP != ".00")
                  @Format_Nbr("@dtw_rMultiply(@dtw_rAdd(V_WKSCPP, "1"),"100")", F_TXSCPP, "2", $(pctEditCode), "", "", "%")
                  @dtw_concat("$(F_TXSCPP)", " of", F_TXSCPP)
              %endif
              @dtw_assign(itemImage, "$(V_WKCPN)$(itemImageExt)")
              @dtwf_exists(itemImage, imageExists)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y")
                      <td class="opticon">
                          <a href="$(homeURL)$(cGIPath)CostSimulatorProductStructureMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;componentNumber=@dtw_rurlescseq(V_WKCPN)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          <a href="$(homeURL)$(cGIPath)CostSimulatorProductStructureMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;componentNumber=@dtw_rurlescseq(V_WKCPN)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          <a href="$(homeURL)$(cGIPath)CostSimulatorProductStructureMaintain.d2w/Edit_Data$(d2wVarBase)&amp;componentNumber=@dtw_rurlescseq(V_WKCPN)&amp;maintenanceCode=D">$(deleteImageSml)</a>
    		           %if (imageExists == "Y")
                              <a href="$(homeURL)$(cGIPath)imageDisplay.d2w/DISPLAY$(genericVarBase)&amp;imageDisplayPath=$(homeURL)$(itemImage)&amp;imageDesc=@dtw_rurlescseq(itemDescription)" onclick="$(itemImageWinVar)">$(foundImage)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemInquiry.d2w/DISPLAY$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq($(V_WKCPN))" onclick="$(inquiryWinVar)" title="Item Quickview">$(V_WKCPN)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_WKCPN)&amp;itemDescription=@dtw_rurlescseq(itemDescription)" title="View Item">$(itemDescription)</a></td>
                  <td class="colnmbr">$(F_WKQPER)</td>
                  <td class="colcode" $(helpCursor)><span title="$(V_WKCDES)">$(V_WKCLAS)</span></td>
                  <td class="colcode" $(helpCursor)><span title="$(partTypeDesc)">$(V_WKPTYP)</span></td>
                  <td class="colcode" $(helpCursor)><span title="$(uomDesc)">$(V_WKUOMS)</span></td>
                  <td class="colnmbr">$(F_WKSCPP)</td>
                  <td class="colnmbr">$(F_WKUCST)</td>
                  <td class="colnmbr" $(helpCursor)><span title="$(F_TXSCPP) $(F_WKQPER) (Quantity Per) x $(V_WKUCST) (Unit Cost) x $(F_WKQTY) (Quantity)">$(extCost)</span></td>
              </tr>
          %}
          %if (sql_Record_Count != "0")
              %if (formatToPrint != "Y")
                  @dtw_assign(totalSpan, "9")
              %else
                  @dtw_assign(totalSpan, "8")
              %endif
              %INCLUDE "SetRowClass.icl"
              @Format_Nbr(totalMaterial, F_totalMaterial, $(cstNbrDec), $(amtEditCode), "Y", "", "")
              <tr class="$(rowClass)">
                  <td class="colnmbr" colspan="$(totalSpan)">Total Material Cost</td>
                  <td class="coltotal">$(F_totalMaterial)</td>
              </tr>
              %INCLUDE "SetRowClass.icl"
              @dtw_assign(percentMaterial, @dtw_rMultiply(@dtw_rDivide(totalMaterial, sellPrice), "100"))
              @Format_Nbr(percentMaterial, percentMaterial, "2", $(pctEditCode), "Y", "", "")
              <tr class="$(rowClass)">
                  <td class="colnmbr" colspan="$(totalSpan)">Material Cost/Selling Price %</td>
                  <td class="colnmbr">$(percentMaterial)</td>
              </tr>
          %endif
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Cost_Simulator_Part_Class (IN  CHAR(64)    profileHandle,
                                                  CHAR(2)     dataBaseID,
                                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="partclasssummary"></a>
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("WKCLAS", "Part<br>Class")
                  @Format_Column_Header("WKCDES", "Description")
                  @Format_Column_Header("WKUCST", "Summary<br>Cost")
              </tr>
	   %endif
          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Nbr($(V_extCost), F_extCost, $(cstNbrDec), $(qtyEditCode), "Y", "", "")
              <tr class="$(rowClass)">
                  <td class="colalph">$(V_WKCLAS)</td>                                      	
                  <td class="colalph">$(V_WKCDES)</td>                                      	
                  <td class="colnmbr">$(F_extCost)</td>                                      	
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Cost_Simulator_Variable_Cost (IN  CHAR(64)    profileHandle,
                                                     CHAR(2)     dataBaseID,
                                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="variablecosts"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
   			
          %ROW{
              <tr>
                  <th class="colhdr">$(V_PLDOL1)</th>
                  <th class="colhdr">$(V_PLDOL2)</th>
                  <th class="colhdr">$(V_PLPCT1)</th>
                  <th class="colhdr">$(V_PLPCT2)</th>
                  <th class="colhdr">$(V_PLPCT3)</th>
                  <th class="colhdr">$(V_PLPCT4)</th>
                  <th class="colhdr">Total</th>
              </tr>

              %INCLUDE "SetRowClass.icl"
              @dtw_assign(amountOne, @dtw_rDivide(@dtw_rMultiply(percentOne, sellPrice), "100"))
              @dtw_assign(amountTwo, @dtw_rDivide(@dtw_rMultiply(percentTwo, sellPrice), "100"))
              @dtw_assign(amountThree, @dtw_rDivide(@dtw_rMultiply(percentThree, sellPrice), "100"))
              @dtw_assign(amountFour, @dtw_rDivide(@dtw_rMultiply(percentFour, sellPrice), "100"))
              @dtw_assign(totalVariable, @dtw_rAdd(addonTotal, amountMiscTwo))
              @dtw_assign(totalVariable, @dtw_rAdd(totalVariable, @dtw_rDivide(@dtw_rMultiply(percentOne, sellPrice), "100")))
              @dtw_assign(totalVariable, @dtw_rAdd(totalVariable, @dtw_rDivide(@dtw_rMultiply(percentTwo, sellPrice), "100")))
              @dtw_assign(totalVariable, @dtw_rAdd(totalVariable, @dtw_rDivide(@dtw_rMultiply(percentThree, sellPrice), "100")))
              @dtw_assign(totalVariable, @dtw_rAdd(totalVariable, @dtw_rDivide(@dtw_rMultiply(percentFour, sellPrice), "100")))

              @Format_Nbr(sellPrice, F_sellPrice, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr($(percentOne), F_PLPCA1, "2", $(pctEditCode), "", "", "%")
              @Format_Nbr($(percentTwo), F_PLPCA2, "2", $(pctEditCode), "", "", "%")
              @Format_Nbr($(percentThree), F_PLPCA3, "2", $(pctEditCode), "", "", "%")
              @Format_Nbr($(percentFour), F_PLPCA4, "2", $(pctEditCode), "", "", "%")
              @Format_Nbr(addonTotal, F_addonTotal, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr(amountMiscTwo, F_amountMiscTwo, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr(amountOne, amountOne, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr(amountTwo, amountTwo, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr(amountThree, amountThree, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr(amountFour, amountFour, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr(totalVariable, F_totalVariable, "2", $(amtEditCode), "Y", "", "")

              <tr class="$(rowClass)">
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)CostSimulatorAddOnCost.d2w/REPORT$(d2wVarBase)" onclick="$(inquiryWinVar)" title="Click here to view the Add On Cost">$(F_addonTotal)</a></td>
                  <td class="colnmbr">$(F_amountMiscTwo)</td>
                  <td class="colnmbr" $(helpCursor)><span title="$(F_PLPCA1) of $(F_sellPrice) (Sell Price)">$(amountOne)</span></td>
                  <td class="colnmbr" $(helpCursor)><span title="$(F_PLPCA2) of $(F_sellPrice) (Sell Price)">$(amountTwo)</span></td>
                  <td class="colnmbr" $(helpCursor)><span title="$(F_PLPCA3) of $(F_sellPrice) (Sell Price)">$(amountThree)</span></td>
                  <td class="colnmbr" $(helpCursor)><span title="$(F_PLPCA4) of $(F_sellPrice) (Sell Price)">$(amountFour)</span></td>
                  <td class="colnmbr">$(F_totalVariable)</td>
              </tr>
          %}
          %INCLUDE "SetRowClass.icl"
          @dtw_assign(percentVariable, @dtw_rMultiply(@dtw_rDivide(totalVariable, sellPrice), "100"))
          @Format_Nbr(percentVariable, percentVariable, "2", $(pctEditCode), "Y", "", "")
          <tr class="$(rowClass)">
              <td class="colnmbr" colspan="6">Variable Cost/Selling Price %</td>
              <td class="colnmbr">$(percentVariable)</td>
          </tr>

          @RtvFldDesc("IWITEM='$(itemNumber)' and IWWHS=$(wareHouse)", "HDIWHS", "char(round(IWLIST*$(orderQuantity),5))", listPrice)
          @dtw_assign(priceDiff, @dtw_rDivide(@dtw_rMultiply(@dtw_rSubtract(listPrice, sellPrice), "100"), listPrice))

          @Format_Nbr(listPrice, F_listPrice, "2", $(amtEditCode), "Y", "", "")
          @Format_Nbr(priceDiff, priceDiff, "2", $(pctEditCode), "Y", "", "%")
          <tr>
              <td class="dsphdr">List Price</td>
              <td class="colnmbr">$(F_listPrice)</td>
              <td class="dsphdr">Sell Price Diff %</td>
              <td class="colnmbr">$(priceDiff)</td>
          </tr>

          @Format_Nbr(calcPrice, F_calcPrice, "2", $(amtEditCode), "Y", "", "")
          @dtw_assign(priceDiff, @dtw_rDivide(@dtw_rMultiply(@dtw_rSubtract(calcPrice, sellPrice), "100"), calcPrice))
          @Format_Nbr(priceDiff, priceDiff, "2", $(pctEditCode), "Y", "", "%")
          <tr>
              <td class="dsphdr">Calc Price</td>
              <td class="colnmbr">$(F_calcPrice)</td>
              <td class="dsphdr">Sell Price Diff %</td>
              <td class="colnmbr">$(priceDiff)</td>
          </tr>
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Cost_Simulator_Features_Options (IN  CHAR(64)    profileHandle,
                                                        CHAR(2)     dataBaseID,
                                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="featuresandoptions"></a>
      %if (productCfgFormat == "O")
          @dtw_assign(moreURL, "$(homeURL)$(cGIPath)CostSimulatorFeatureOption2.d2w/DISPLAY$(d2wVarBase)")
      %else      
          @dtw_assign(moreURL, "$(homeURL)$(cGIPath)CostSimulatorFeatureOption.d2w/DISPLAY$(d2wVarBase)")
      %endif
      @dtw_assign(moreInfoImage, "$(changeImageMed)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("SAFEAT", "Feature")
                  @Format_Column_Header("SAOPTN", "Option")
                  @Format_Column_Header("SADESC", "Description")
                  @Format_Column_Header("SAOQTY", "Quantity")
                  @Format_Column_Header("SAXCHG", "Extra Charge")
                  @Format_Column_Header("SASLPR", "Price")
              </tr>
          %endif

          @dtw_assign(saveFeature, "")

          %ROW{
              %if (saveFeature != V_SAFEAT)
                  %INCLUDE "SetRowClass.icl"
                  @dtw_assign(saveFeature, V_SAFEAT)
                  @dtw_assign(newFeature, V_SAFEAT)
              %else
                  @dtw_assign(newFeature, "")
              %endif
              <tr class="$(rowClass)">
                  <td class="colalph">$(newFeature)</td>
                  <td class="colalph">$(V_SAOPTN)</td>
                  <td class="colalph">$(V_SADESC)</td>
                  @Format_Nbr(V_SAOQTY, F_SAOQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  <td class="colnmbr">$(F_SAOQTY)</td>
                  @Format_Nbr(V_SAXCHG, F_SAXCHG, $(prcNbrDec), $(amtEditCode), "", "$", "")
                  <td class="colnmbr">$(F_SAXCHG)</td>
                  %if (V_FXPRIC > "0")
                      @dtw_assign(V_SASLPR, "0")
                  %endif
                  @Format_Nbr(V_SASLPR, F_SASLPR, $(prcNbrDec), $(amtEditCode), "Y", "$", "")
                  <td class="colnmbr">$(F_SASLPR)</td>
                  %if (V_FXPRIC > "0")
                      @Format_Nbr(V_FXPRIC, F_FXPRIC, $(prcNbrDec), $(amtEditCode), "Y", "$", "")
                      <td class="colnmbr">Fixed Charge: $(F_FXPRIC)</td>
                  %endif
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_directcall) Update_Work_File (INOUT CHAR(64)      profileHandle,
                                                  CHAR(10)      callSubr,
                                                  CHAR(1)       maintenanceCode,
                                                  CHAR(32000)   edtVar,
                                                  CHAR(32000)   errVar,
                                                  CHAR(1)       error)

{%EXEC {HSCSIM_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %if (updateRowNum > "0")
      @dtw_assign(START_ROW_NUM,  "$(updateRowNum)")
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(BUILD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@item", itemNumber)
  @Concat_Field("@@pcfc", productCfgFormat)
  @dtw_concat(edtVar, "}{", edtVar)

  @dtw_assign(callSubr, "FILL")

  @Update_Work_File (profileHandle, callSubr, maintenanceCode, edtVar, errVar, error)

  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;updateRowNum=@dtw_rurlescseq(updateRowNum)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}