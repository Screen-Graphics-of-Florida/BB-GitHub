%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Configuration Header Maintenance"
  d2wName                 = "ConfigurationHeaderMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(fromPlant)&amp;fromName=@dtw_rurlescseq(fromName)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;configurationType=@dtw_rurlescseq(configurationType)&amp;configurationID=@dtw_rurlescseq(configurationID)&amp;configurationTypeDescription=@dtw_rurlescseq(configurationTypeDescription)&amp;maintenanceCode=D"
  programName             = "HPD023"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
	       %INCLUDE "numedit.icl"
              function validate(chgForm) {
                  if (document.Chg.plantNumber.value =="" ||
                      document.Chg.itemNumber.value =="" ||
                      document.Chg.configurationType.value =="" ||
                      document.Chg.configurationID.value =="" ||
                      document.Chg.configurationTypeDescription.value =="" ||
                      document.Chg.effStartDate.value =="" ||
                      document.Chg.effStopDate.value =="")
                     {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.plantNumber, 3, 0) &&
                      editNum(document.Chg.effStartDate, 6, 0) &&
                      editNum(document.Chg.effStopDate, 6, 0) &&
                      editNum(document.Chg.approvalDate, 6, 0) &&
                      editNum(document.Chg.releaseDate, 6, 0)
                      %if (numeric1Desc != "")
                           && editNum(document.Chg.userDefNum1, 13, 5)
                      %endif
                      %if (numeric2Desc != "")
                           && editNum(document.Chg.userDefNum2, 13, 5)
                      %endif
                      %if (numeric3Desc != "")
                           && editNum(document.Chg.userDefNum3, 13, 5)
                      %endif
                      %if (date1Desc != "")
                           && editNum(document.Chg.userDefDate1, 6, 0)
                      %endif
                      %if (date2Desc != "")
                           && editNum(document.Chg.userDefDate2, 6, 0)
                      %endif
                      %if (date3Desc != "")
                           && editNum(document.Chg.userDefDate3, 6, 0)
                      %endif
                      )
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CONFIGURATIONHEADERMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "SELECT * FROM HDCFGH ", stmtSQL)
                          @dtw_concat(stmtSQL, "WHERE CHPLT = $(plantNumber) and CHITEM = '$(itemNumber)' and CHCFGT = '$(configurationType)' and CHCFGI = '$(configurationID)' ", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      %if (maintenanceCode == "C")
          @RtvFldDesc("CHPLT=$(plantNumber) and CHITEM = '$(itemNumber)' and CHCFGT = '$(configurationType)' and CHCFGI = '$(configurationID)' ", "HDCFGH", "CHDATC", V_CHDATC)
          @Format_Date(V_CHDATC, "H", F_CHDATC)
          @RtvFldDesc("CHPLT=$(plantNumber) and CHITEM = '$(itemNumber)' and CHCFGT = '$(configurationType)' and CHCFGI = '$(configurationID)' ", "HDCFGH", "CAST(CHTSTP as Date)", V_CHTSTP)
          @Format_Date_ISO(V_CHTSTP, "H", F_CHTSTP)
          @RtvFldDesc("CHPLT=$(plantNumber) and CHITEM = '$(itemNumber)' and CHCFGT = '$(configurationType)' and CHCFGI = '$(configurationID)' ", "HDCFGH", "CHDATU", V_CHDATU)
          @Format_Date(V_CHDATU, "H", F_CHDATU)
          <table $(contentTable)>
              @Format_Header("Date Created", $(F_CHDATC), "")
              @Format_Header("Date Last Maintained", $(F_CHTSTP), "")
              @Format_Header("Date Last Used", $(F_CHDATU), "")
          </table>
      %endif
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "itemNumber")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@plt@", "plantNumber")         @dtw_assign(Err_CHPLT,  fieldValue)
                          @DecatErr_Field("@@item", "itemNumber")          @dtw_assign(Err_CHITEM, fieldValue)
                          @DecatErr_Field("@@cfgt", "configurationType")   @dtw_assign(Err_CHCFGT, fieldValue)
                          @DecatErr_Field("@@cfgi", "configurationID")     @dtw_assign(Err_CHCFGI, fieldValue)
                          @DecatErr_Field("@@cdsc", "configurationTypeDescription") @dtw_assign(Err_CHCDSC, fieldValue)
                          @DecatErr_Field("@@dati", "effStartDate")        @dtw_assign(Err_CHDATI, fieldValue)
                          @DecatErr_Field("@@dato", "effStopDate")         @dtw_assign(Err_CHDATO, fieldValue)
                          @DecatErr_Field("@@ecn@", "ECN")                 @dtw_assign(Err_CHECN, fieldValue)
                          @DecatErr_Field("@@dwgn", "drawNumber")          @dtw_assign(Err_CHDWGN, fieldValue)
                          @DecatErr_Field("@@dsgp", "designPhase")         @dtw_assign(Err_CHDSGP, fieldValue)
                          @DecatErr_Field("@@apdt", "approvalDate")        @dtw_assign(Err_CHAPDT, fieldValue)
                          @DecatErr_Field("@@apcd", "approvalCode")        @dtw_assign(Err_CHAPCD, fieldValue)
                          @DecatErr_Field("@@apby", "approvedBy")          @dtw_assign(Err_CHAPBY, fieldValue)
                          @DecatErr_Field("@@isoc", "ISOCode")             @dtw_assign(Err_CHISOC, fieldValue)
                          @DecatErr_Field("@@rel@", "releasedProd")        @dtw_assign(Err_CHREL, fieldValue)
                          @DecatErr_Field("@@reld", "releaseDate")         @dtw_assign(Err_CHRELD, fieldValue)
                          @DecatErr_Field("@@upsm", "useAltProd")          @dtw_assign(Err_CHUPSM, fieldValue)
                          @DecatErr_Field("@@urtg", "useAltRtg")           @dtw_assign(Err_CHURTG, fieldValue)
                          @DecatErr_Field("@@uda1", "userDefAlph1")        @dtw_assign(Err_CHUDA1, fieldValue)
                          @DecatErr_Field("@@uda2", "userDefAlph2")        @dtw_assign(Err_CHUDA2, fieldValue)
                          @DecatErr_Field("@@uda3", "userDefAlph3")        @dtw_assign(Err_CHUDA3, fieldValue)
                          @DecatErr_Field("@@udn1", "userDefNum1")         @dtw_assign(Err_CHUDN1, fieldValue)
                          @DecatErr_Field("@@udn2", "userDefNum2")         @dtw_assign(Err_CHUDN2, fieldValue)
                          @DecatErr_Field("@@udn3", "userDefNum3")         @dtw_assign(Err_CHUDN3, fieldValue)
                          @DecatErr_Field("@@udd1", "userDefDate1")        @dtw_assign(Err_CHUDD1, fieldValue)
                          @DecatErr_Field("@@udd2", "userDefDate2")        @dtw_assign(Err_CHUDD2, fieldValue)
                          @DecatErr_Field("@@udd3", "userDefDate3")        @dtw_assign(Err_CHUDD3, fieldValue)
                      %endif

                      @Decat_Field("@@plt@")   @dtw_assign(V_CHPLT,  fieldValue)
                      @Decat_Field("@@item")   @dtw_assign(V_CHITEM, fieldValue)
                      @Decat_Field("@@cfgt")   @dtw_assign(V_CHCFGT, fieldValue)
                      @Decat_Field("@@cfgi")   @dtw_assign(V_CHCFGI, fieldValue)
                      @Decat_Field("@@cdsc")   @dtw_assign(V_CHCDSC, fieldValue)
                      @Decat_Field("@@dati")   @dtw_assign(V_CHDATI, fieldValue)
                      @Decat_Field("@@dato")   @dtw_assign(V_CHDATO, fieldValue)
                      @Decat_Field("@@ecn@")   @dtw_assign(V_CHECN, fieldValue)
                      @Decat_Field("@@dwgn")   @dtw_assign(V_CHDWGN, fieldValue)
                      @Decat_Field("@@dsgp")   @dtw_assign(V_CHDSGP, fieldValue)
                      @Decat_Field("@@apdt")   @dtw_assign(V_CHAPDT, fieldValue)
                      @Decat_Field("@@apcd")   @dtw_assign(V_CHAPCD, fieldValue)
                      @Decat_Field("@@apby")   @dtw_assign(V_CHAPBY, fieldValue)
                      @Decat_Field("@@isoc")   @dtw_assign(V_CHISOC, fieldValue)
                      @Decat_Field("@@rel@")   @dtw_assign(V_CHREL, fieldValue)
                      @Decat_Field("@@reld")   @dtw_assign(V_CHRELD, fieldValue)
                      @Decat_Field("@@upsm")   @dtw_assign(V_CHUPSM, fieldValue)
                      @Decat_Field("@@urtg")   @dtw_assign(V_CHURTG, fieldValue)
                      @Decat_Field("@@uda1")   @dtw_assign(V_CHUDA1, fieldValue)
                      @Decat_Field("@@uda2")   @dtw_assign(V_CHUDA2, fieldValue)
                      @Decat_Field("@@uda3")   @dtw_assign(V_CHUDA3, fieldValue)
                      @Decat_Field("@@udn1")   @dtw_assign(V_CHUDN1, fieldValue)
                      @Decat_Field("@@udn2")   @dtw_assign(V_CHUDN2, fieldValue)
                      @Decat_Field("@@udn3")   @dtw_assign(V_CHUDN3, fieldValue)
                      @Decat_Field("@@udd1")   @dtw_assign(V_CHUDD1, fieldValue)
                      @Decat_Field("@@udd2")   @dtw_assign(V_CHUDD2, fieldValue)
                      @Decat_Field("@@udd3")   @dtw_assign(V_CHUDD3, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          %if (fromPlant > "0")
                              @dtw_assign(V_CHPLT, fromPlant)
                          %else
                              @RtvDftPlant(V_CHPLT, plantName)
                          %endif
                          %if (V_CHPLT > "0")
                              @dtw_assign(focusField, "itemNumber")
                          %else
                              @dtw_assign(focusField, "plantNumber")
                          %endif
                          @dtw_assign(V_CHITEM, "")
                          @dtw_assign(V_CHCFGT, "")
                          @dtw_assign(V_CHCFGI, "")
                          @dtw_assign(V_CHDATI, "0")
                          @dtw_assign(V_CHDATO, "999999")
                          @dtw_assign(V_CHDSGP, "1")
                          @dtw_assign(V_CHREL,  "N")
                      %endif

                      @dtw_assign(errFound, "")

                  %else
                      @DateInputFromCYMD(V_CHDATI)
                      %if (V_CHDATO == "9999999")
                          @dtw_assign(V_CHDATO, "999999")
                      %else
                          @DateInputFromCYMD(V_CHDATO)
                      %endif
                      @DateInputFromCYMD(V_CHRELD)
                      @DateInputFromCYMD(V_CHAPDT)
                      @DateInputFromCYMD(V_CHUDD1)
                      @DateInputFromCYMD(V_CHUDD2)
                      @DateInputFromCYMD(V_CHUDD3)
                      %if (maintenanceCode == "Z")
                          @dtw_assign(V_CHITEM, "")
                          @dtw_assign(V_CHCFGT, "")
                          @dtw_assign(V_CHCFGI, "")
                          @dtw_assign(focusField, "itemNumber")
                      %else
                          @dtw_assign(focusField, "configurationTypeDescription")
                      %endif
                  %endif

                  @Default_Zero(V_CHPLT)
                  @RtvFldDesc("PLPLNT=$(V_CHPLT)", "HDPLNT", "PLNAME", plantName)
                  @SetTextOvr(Err_CHPLT)
                  <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="plantNumber" type="text" value="$(V_CHPLT)" size="5" maxlength="3"> $(reqFieldChar) <a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=plantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="plantName" value="$(plantName)" type="text" size="25"></td>
                      %else
                          <td class="inputnmbr"><input name="plantNumber" type="hidden" value="$(V_CHPLT)">$(V_CHPLT) &nbsp; $(plantName)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_CHPLT)

                  @RtvFldDesc("IMITEM='$(V_CHITEM)'", "HDIMST", "IMIMDS", itemdesc)
                  @SetTextOvr(Err_CHITEM)
                  <tr><td class="dsphdr"><span $(textOvr)>Item Number</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="itemNumber" type="text" value="$(V_CHITEM)" size="15" maxlength="15"> $(reqFieldChar) <a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=itemNumber&amp;fldDesc=itemdesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input disabled name="itemdesc" value="$(itemdesc)" type="text" size="30"></td>
                      %else
                          <td class="inputalph"><input name="itemNumber" type="hidden" value="$(V_CHITEM)">$(V_CHITEM) &nbsp; $(itemdesc)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_CHITEM)

                  @dtw_assign(configdesc, "")
                  @RtvFldDesc("CYPLT=$(plantNumber) and CYCFGT='$(V_CHCFGT)'", "HDCFGT", "CYLDSC", configdesc)
                  @SetTextOvr(Err_CHCFGT)
                  <tr><td class="dsphdr"><span $(textOvr)>Configuration Type</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="configurationType" type="text" value="$(V_CHCFGT)" size="5" maxlength="5"> $(reqFieldChar) <a href="$(homeURL)$(cGIPath)ConfigurationTypeSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=configurationType&amp;fldDesc=configdesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input disabled name="configdesc" value="$(configdesc)"  type="text" size="30"></td>
                      %else
                          <td class="inputalph"><input name="configurationType" type="hidden" value="$(V_CHCFGT)">$(V_CHCFGT) &nbsp; $(configdesc)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_CHCFGT)

                  @SetTextOvr(Err_CHCFGI)
                  <tr><td class="dsphdr"><span $(textOvr)>Configuration ID</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="configurationID" type="text" value="$(V_CHCFGI)" size="5" maxlength="5"> $(reqFieldChar) </td>
                      %else
                          <td class="inputalph"><input name="configurationID" type="hidden" value="$(V_CHCFGI)">$(V_CHCFGI)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_CHCFGI)

                  @SetTextOvr(Err_CHCDSC)
                  <tr><td class="dsphdr"><span $(textOvr)>Type Description</span></td>
                      <td class="inputalph"><input name="configurationTypeDescription" type="text" value="$(V_CHCDSC)" size="30" maxlength="30"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_CHCDSC)

                  @SetTextOvr(Err_CHDATI)
                  <tr><td class="dsphdr"><span $(textOvr)>Effectivity In Date</span></td>
                      <td class="inputnmbr"><input type="text" name="effStartDate" value="$(V_CHDATI)" size="6" maxlength="6"> <a href="javascript:calWindow('effStartDate');">$(calendarImage) $(reqFieldChar)</a></td>
                  </tr>
                  @DspErrMsg(Err_CHDATI)

                  @SetTextOvr(Err_CHDATO)
                  <tr><td class="dsphdr"><span $(textOvr)>Effectivity Out Date</span></td>
                      <td class="inputnmbr"><input type="text" name="effStopDate" value="$(V_CHDATO)" size="6" maxlength="6"> <a href="javascript:calWindow('effStopDate');">$(calendarImage) $(reqFieldChar)</a></td>
                  </tr>
                  @DspErrMsg(Err_CHDATO)

                  @SetTextOvr(Err_CHUPSM)
                  <tr><td class="dsphdr"><span $(textOvr)>Use Alternate Product Structure</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_CHUPSM) && (x < maxRows))
                            {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "useAltProd", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_CHUPSM)

                  @SetTextOvr(Err_CHURTG)
                  <tr><td class="dsphdr"><span $(textOvr)>Use Alternate Routing</span></td>
                      @dtw_tb_rows(yn02Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn02Table, x, "1") != V_CHURTG) && (x < maxRows))
                            {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn02Table, "useAltRtg", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_CHURTG)

                  @SetTextOvr(Err_CHECN)
                  <tr><td class="dsphdr"><span $(textOvr)>ECN Number</span></td>
                      <td class="inputalph"><input type="text" name="ECN" value="$(V_CHECN)" size="5" maxlength="5"></td>
                  </tr>
                  @DspErrMsg(Err_CHECN)
    	      		
                  @SetTextOvr(Err_CHDWGN)
                  <tr><td class="dsphdr"><span $(textOvr)>Drawing Number</span></td>
                      <td class="inputalph"><input type="text" name="drawNumber" value="$(V_CHDWGN)" size="15" maxlength="15"></td>
                  </tr>
                  @DspErrMsg(Err_CHDWGN)

                  @SetTextOvr(Err_CHDSGP)
                  <tr><td class="dsphdr"><span $(textOvr)>Design Phase</span></td>
                      @dtw_tb_rows(designPhaseTable, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(designPhaseTable, x, "1") != V_CHDSGP) && (x < maxRows)) {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(designPhaseTable, "designPhase", "2", "1", "N", "", x, "1") $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_CHDSGP)

                  @SetTextOvr(Err_CHAPDT)
                  <tr><td class="dsphdr"><span $(textOvr)>Final Approval Date</span></td>
                      <td class="inputnmbr"><input type="text" name="approvalDate" value="$(V_CHAPDT)" size="6" maxlength="6"> <a href="javascript:calWindow('approvalDate');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_CHAPDT)
    	      		
                  @SetTextOvr(Err_CHAPCD)
                  <tr><td class="dsphdr"><span $(textOvr)>Approval Code</span></td>
                      <td class="inputalph"><input type="text" name="approvalCode" value="$(V_CHAPCD)" size="5" maxlength="5"></td>
                  </tr>
                  @DspErrMsg(Err_CHAPCD)
    	      		
                  @SetTextOvr(Err_CHAPBY)
                  <tr><td class="dsphdr"><span $(textOvr)>Approved By</span></td>
                      <td class="inputalph"><input type="text" name="approvedBy" value="$(V_CHAPBY)" size="26" maxlength="26"></td>
                  </tr>
                  @DspErrMsg(Err_CHAPBY)
    	      		
                  @SetTextOvr(Err_CHISOC)
                  <tr><td class="dsphdr"><span $(textOvr)>ISO Code</span></td>
                      <td class="inputalph"><input type="text" name="ISOCode" value="$(V_CHISOC)" size="15" maxlength="15"></td>
                  </tr>
                  @DspErrMsg(Err_CHISOC)

                  @SetTextOvr(Err_CHREL)
                  <tr><td class="dsphdr"><span $(textOvr)>Released To Production</span></td>
                      @dtw_tb_rows(yn03Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn03Table, x, "1") != V_CHREL) && (x < maxRows))
                            {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn03Table, "releasedProd", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_CHREL)
    	      		
                  @SetTextOvr(Err_CHRELD)
                  <tr><td class="dsphdr"><span $(textOvr)>Release Date</span></td>
                      <td class="inputnmbr"><input type="text" name="releaseDate" value="$(V_CHRELD)" size="6" maxlength="6"><a href="javascript:calWindow('releaseDate');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_CHRELD)

                  @RtvFldDesc("CYPLT=$(plantNumber) and CYCFGT='$(V_CHCFGT)'", "HDCFGT", "CYAS11", alpha1Desc)
                  %if (alpha1Desc != "")		
                      <tr><td class="dsphdr"><span $(textOvr)>$(alpha1Desc)</span></td>
                          <td class="inputalph"><input type="text" name="userDefAlph1" value="$(V_CHUDA1)" size="15" maxlength="15"></td>
                      </tr>
                  %endif

                  @RtvFldDesc("CYPLT=$(plantNumber) and CYCFGT='$(V_CHCFGT)'", "HDCFGT", "CYAS21", alpha2Desc)
                  %if (alpha2Desc != "")		
                      <tr><td class="dsphdr"><span $(textOvr)>$(alpha2Desc)</span></td>
                          <td class="inputalph"><input type="text" name="userDefAlph2" value="$(V_CHUDA2)" size="15" maxlength="15"></td>
                      </tr>
                  %endif

                  @RtvFldDesc("CYPLT=$(plantNumber) and CYCFGT='$(V_CHCFGT)'", "HDCFGT", "CYAS31", alpha3Desc)
                  %if (alpha3Desc != "")		
                      <tr><td class="dsphdr"><span $(textOvr)>$(alpha3Desc)</span></td>
                          <td class="inputalph"><input type="text" name="userDefAlph3" value="$(V_CHUDA3)" size="15" maxlength="15"></td>
                      </tr>
                  %endif

                  @RtvFldDesc("CYPLT=$(plantNumber) and CYCFGT='$(V_CHCFGT)'", "HDCFGT", "CYNS11", numeric1Desc)
                  %if (numeric1Desc != "")		
                      <tr><td class="dsphdr"><span $(textOvr)>$(numeric1Desc)</span></td>
                          <td class="inputnmbr"><input type="text" name="userDefNum1" value="$(V_CHUDN1)" size="13" maxlength="13"></td>
                      </tr>
                  %endif

                  @RtvFldDesc("CYPLT=$(plantNumber) and CYCFGT='$(V_CHCFGT)'", "HDCFGT", "CYNS21", numeric2Desc)
                  %if (numeric2Desc != "")		
                      <tr><td class="dsphdr"><span $(textOvr)>$(numeric2Desc)</span></td>
                          <td class="inputnmbr"><input type="text" name="userDefNum2" value="$(V_CHUDN2)" size="13" maxlength="13"></td>
                      </tr>
                  %endif

                  @RtvFldDesc("CYPLT=$(V_CHPLT) and CYCFGT='$(V_CHCFGT)'", "HDCFGT", "CYNS31", numeric3Desc)
                  %if (numeric3Desc != "")		
                      <tr><td class="dsphdr"><span $(textOvr)>$(numeric3Desc)</span></td>
                          <td class="inputnmbr"><input type="text" name="userDefNum3" value="$(V_CHUDN3)" size="13" maxlength="13"></td>
                      </tr>
                  %endif

                  @RtvFldDesc("CYPLT=$(plantNumber) and CYCFGT='$(V_CHCFGT)'", "HDCFGT", "CYDS11", date1Desc)
                  %if (date1Desc != "")		
                      @SetTextOvr(Err_CHUDD1)
                      <tr><td class="dsphdr"><span $(textOvr)>$(date1Desc)</span></td>
                          <td class="inputdate"><input type="text" name="userDefDate1" value="$(V_CHUDD1)" size="6" maxlength="6"><a href="javascript:calWindow('userDefDate1');">$(calendarImage)</a></td>
                      </tr>
                      @DspErrMsg(Err_CHUDD1)
                  %endif

                  @RtvFldDesc("CYPLT=$(plantNumber) and CYCFGT='$(V_CHCFGT)'", "HDCFGT", "CYDS21", date2Desc)
                  %if (date2Desc != "")		
                      @SetTextOvr(Err_CHUDD2)
                      <tr><td class="dsphdr"><span $(textOvr)>$(date2Desc)</span></td>
                          <td class="inputdate"><input type="text" name="userDefDate2" value="$(V_CHUDD2)" size="6" maxlength="6"><a href="javascript:calWindow('userDefDate2');">$(calendarImage)</a></td>
                      </tr>
                      @DspErrMsg(Err_CHUDD2)
                  %endif

                  @RtvFldDesc("CYPLT=$(plantNumber) and CYCFGT='$(V_CHCFGT)'", "HDCFGT", "CYDS31", date3Desc)
                  %if (date3Desc != "")		
                      @SetTextOvr(Err_CHUDD3)
                      <tr><td class="dsphdr"><span $(textOvr)>$(date3Desc)</span></td>
                          <td class="inputdate"><input type="text" name="userDefDate3" value="$(V_CHUDD3)" size="6" maxlength="6"><a href="javascript:calWindow('userDefDate3');">$(calendarImage)</a></td>
                      </tr>
                      @DspErrMsg(Err_CHUDD3)
                  %endif

              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HPD023_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @DesignPhase_Query(profileHandle, dataBaseID, "DSGNPHASE ", designPhaseTable)
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @yn02_Table_Query(profileHandle, dataBaseID, "YORN      ", yn02Table)
      @yn03_Table_Query(profileHandle, dataBaseID, "YORN      ", yn03Table)

      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(itemNumber)
  @dtw_mUPPERCASE(configurationType)
  @dtw_mUPPERCASE(configurationID)

  @dtw_assign(plantNumber, @dtw_rstrip(plantNumber))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@item", itemNumber)
  @Concat_Field("@@cfgt", configurationType)
  @Concat_Field("@@cfgi", configurationID)
  @Concat_Field("@@cdsc", configurationTypeDescription)
  @Concat_Field("@@dati", effStartDate)
  @Concat_Field("@@dato", effStopDate)
  @Concat_Field("@@ecn@", ECN)
  @Concat_Field("@@dwgn", drawNumber)
  @Concat_Field("@@dsgp", designPhase)
  @Concat_Field("@@apdt", approvalDate)
  @Concat_Field("@@apcd", approvalCode)
  @Concat_Field("@@apby", approvedBy)
  @Concat_Field("@@isoc", ISOCode)
  @Concat_Field("@@rel@", releasedProd)
  @Concat_Field("@@reld", releaseDate)
  @Concat_Field("@@upsm", useAltProd)
  @Concat_Field("@@urtg", useAltRtg)
  @Concat_Field("@@uda1", userDefAlph1)
  @Concat_Field("@@uda2", userDefAlph2)
  @Concat_Field("@@uda3", userDefAlph3)
  @Concat_Field("@@udn1", userDefNum1)
  @Concat_Field("@@udn2", userDefNum2)
  @Concat_Field("@@udn3", userDefNum3)
  @Concat_Field("@@udd1", userDefDate1)
  @Concat_Field("@@udd2", userDefDate2)
  @Concat_Field("@@udd3", userDefDate3)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(configurationTypeDescription), "$(itemNumber) / $(configurationType) / $(configurationID)", $(plantName), $(plantNumber), "", "", confMessage)
      %if (maintenanceCode == "D" || fromD2w != "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ConfigurationHeader.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(fromPlant)&amp;plantName=@dtw_rurlescseq(fromName)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ConfigurationHeaderSelect.d2w/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;configurationType=@dtw_rurlescseq(configurationType)&amp;configurationID=@dtw_rurlescseq(configurationID)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %elif (maintenanceCode == "D" || maintenanceCode == "R")
      %if (maintenanceCode == "D")
          @DecatErr_Field("@@item", "itemNumber")
      %else
          @DecatErr_Field("@@rel@", "releasedProd")
      %endif
      @Format_ConfMsg_Desc("", $(configurationTypeDescription), "$(itemNumber) / $(configurationType) / $(configurationID)", $(plantName), $(plantNumber), "<br>$(fieldValue)", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ConfigurationHeader.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(fromPlant)&amp;plantName=@dtw_rurlescseq(fromName)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;configurationType=@dtw_rurlescseq(configurationType)&amp;configurationID=@dtw_rurlescseq(configurationID)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}

%FUNCTION(dtw_directcall) Validate_COPYALL(INOUT CHAR(64)    profileHandle,
                                           INOUT CHAR(2)     dataBaseID,
                                           INOUT CHAR(1)     maintenanceCode,
                                           INOUT CHAR(1)     errFound,
                                           INOUT CHAR(32000) edtVar,
                                           INOUT CHAR(32000) errVar)
{%EXEC {HPD023_W.PGM %}
%}

%HTML(COPYALL) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
	       %INCLUDE "numedit.icl"
              %INCLUDE "NewWindowOpen.icl"
              function validate(chgForm) {
                 if (document.Chg.toplantNumber.value =="" ||
                     document.Chg.toitemNumber.value =="" ||
                     document.Chg.toconfigurationType.value =="" ||
                     document.Chg.toconfigurationID.value =="")
                     {alert("$(reqFieldError)"); return false;}
                 if (editNum(document.Chg.toplantNumber, 3, 0))
                     return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CONFIGURATIONHEADERMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      <table $(contentTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1> Configuration Header - Copy All</h1></td>
                              <td class="toolbar">
                              %INCLUDE "MaintainTopNoTable.icl"
                              </td>
                          </tr>
                      </table>

                      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
                      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemdesc)
                      @RtvFldDesc("CYPLT=$(plantNumber) and CYCFGT='$(configurationType)'", "HDCFGT", "CYLDSC", configdesc)
                      <table $(contentTable)>
                          @Format_Header("Plant", $(plantName), $(plantNumber))
                          @Format_Header("Item", $(itemdesc), $(itemNumber))
                          @Format_Header("Type/ID", $(configdesc), "$(configurationType)/$(configurationID)")
                      </table>

                      $(hrTagAttr)
                      %INCLUDE "RequiredField.icl"
                      %INCLUDE "ErrorDisplay.icl"

                      <form class="formClass" METHOD=POST name=Chg ACTION="$(homeURL)$(cGIPath)$(d2wName)/EDIT_COPYALL$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;configurationType=@dtw_rurlescseq(configurationType)&amp;configurationID=@dtw_rurlescseq(configurationID)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "toplantNumber")
                              %if (errFound != "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @DecatErr_Field("@@tplt", "toplantNumber")        @dtw_assign(Err_TOPLT, fieldValue)
                                  @DecatErr_Field("@@titm", "toitemNumber")         @dtw_assign(Err_TOPN,  fieldValue)
                                  @DecatErr_Field("@@tcft", "toconfigurationType")  @dtw_assign(Err_TOCFT, fieldValue)
                                  @DecatErr_Field("@@tcfi", "toconfigurationID")    @dtw_assign(Err_TOCFI, fieldValue)

                                  @Decat_Field("@@tplt")   @dtw_assign(toplantNumber,       fieldValue)
                                  @Decat_Field("@@titm")   @dtw_assign(toitemNumber,        fieldValue)
                                  @Decat_Field("@@tcft")   @dtw_assign(toconfigurationType, fieldValue)
                                  @Decat_Field("@@tcfi")   @dtw_assign(toconfigurationID,   fieldValue)

                                  @dtw_assign(errFound, "")
                              %else
                                  @dtw_assign(edtVar, "")
                              %endif

                              %if (toplantNumber == "")
                                  @dtw_assign(toplantNumber, "$(plantNumber)")
                              %endif
                              @RtvFldDesc("PLPLNT=$(toplantNumber)", "HDPLNT", "PLNAME", toplantName)
                              @SetTextOvr(Err_TOPLT)
                              <tr><td class="dsphdr"><span $(textOvr)>To Plant Number</span></td>
                                  <td class="inputnmbr"><input name="toplantNumber" value="$(toplantNumber)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toplantNumber&amp;fldDesc=toplantName" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="toplantName" value="$(toplantName)" type="text" size="30"></td>
                              </tr>
                              @DspErrMsg(Err_TOPLT)

                              %if (toitemNumber == "")
                                  @dtw_assign(toitemNumber, "$(itemNumber)")
                              %endif
                              @RtvFldDesc("IMITEM='$(toitemNumber)'", "HDIMST", "IMIMDS", toitemdescription)
                              @SetTextOvr(Err_TOPN)
	                       <tr><td class="dsphdr"><span $(textOvr)>To Item Number</span></td>
                                  <td class="inputalph"><input name="toitemNumber" value="$(toitemNumber)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toitemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="toitemDescription" value="$(toitemdescription)" type="text" size="30"></td>
                              </tr>
                              @DspErrMsg(Err_TOPN)

                              @dtw_assign(configdesc, "")
                              %if (toconfigurationType == "")
                                  @dtw_assign(toconfigurationType, "$(configurationType)")
                              %endif
                              @RtvFldDesc("CYPLT=$(toplantNumber) and CYCFGT='$(toconfigurationType)'", "HDCFGT", "CYLDSC", configdesc)
                              @SetTextOvr(Err_TOCFT)
                              <tr><td class="dsphdr"><span $(textOvr)>To Type</span></td>
                                  <td class="inputalph"><input name="toconfigurationType" type="text" value="$(toconfigurationType)" size="5" maxlength="5"> $(reqFieldChar) <a href="$(homeURL)$(cGIPath)ConfigurationTypeSearch.d2w/ENTRY$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;docName=Chg&amp;fldName=toconfigurationType&amp;fldDesc=configdesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input disabled name="configdesc" value="$(configdesc)"  type="text" size="30"></td>
                              </tr>
                              @DspErrMsg(Err_TOCFT)

                              %if (toconfigurationID == "")
                                  @dtw_assign(toconfigurationID, "$(configurationID)")
                              %endif
                              @SetTextOvr(Err_TOCFI)
                              <tr><td class="dsphdr"><span $(textOvr)>To ID</span></td>
                                  <td class="inputalph"><input name="toconfigurationID" type="text" value="$(toconfigurationID)" size="5" maxlength="5"> $(reqFieldChar) </td>
                              </tr>
                              @DspErrMsg(Err_TOCFI)
                          </table>
                          %INCLUDE "MaintainBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </form>
                  </td>
              </tr>
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(EDIT_COPYALL) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(toitemNumber)
  @dtw_mUPPERCASE(toconfigurationType)
  @dtw_mUPPERCASE(toconfigurationID)
  @dtw_assign(toplantNumber,@dtw_rstrip(toplantNumber))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@item", itemNumber)
  @Concat_Field("@@cfgt", configurationType)
  @Concat_Field("@@cfgi", configurationID)

  @Concat_Field("@@tplt", toplantNumber)
  @Concat_Field("@@titm", toitemNumber)
  @Concat_Field("@@tcft", toconfigurationType)
  @Concat_Field("@@tcfi", toconfigurationID)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_COPYALL(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc("A", $(toitemDescription), "$(toitemNumber) / $(toconfigurationType) / $(toconfigurationID)", $(toplantName), $(toplantNumber), "", "", confMessage)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)ConfigurationHeader.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(fromPlant)&amp;plantName=@dtw_rurlescseq(fromName)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/COPYALL$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;configurationType=@dtw_rurlescseq(configurationType)&amp;configurationID=@dtw_rurlescseq(configurationID)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}

%FUNCTION(dtw_directcall) Validate_COPYSTD(INOUT CHAR(64)    profileHandle,
                                           INOUT CHAR(2)     dataBaseID,
                                           INOUT CHAR(1)     maintenanceCode,
                                           INOUT CHAR(1)     errFound,
                                           INOUT CHAR(32000) edtVar,
                                           INOUT CHAR(32000) errVar)
{%EXEC {HPD023_W.PGM %}
%}

%HTML(COPYSTD) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
	       %INCLUDE "numedit.icl"
              %INCLUDE "NewWindowOpen.icl"
              function validate(chgForm) {
                 if (document.Chg.plantNumber.value =="" ||
                     document.Chg.itemNumber.value =="" ||
                     document.Chg.toplantNumber.value =="" ||
                     document.Chg.toitemNumber.value =="" ||
                     document.Chg.toconfigurationType.value =="" ||
                     document.Chg.toconfigurationID.value =="")
                     {alert("$(reqFieldError)"); return false;}
                 if (editNum(document.Chg.plantNumber, 3, 0) &&
                     editNum(document.Chg.toplantNumber, 3, 0))
                     return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CONFIGURATIONHEADERMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      <table $(contentTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1> Configuration Header - Copy All From Standard</h1></td>
                              <td class="toolbar">
                              %INCLUDE "MaintainTopNoTable.icl"
                              </td>
                          </tr>
                      </table>

                      $(hrTagAttr)
                      %INCLUDE "RequiredField.icl"
                      %INCLUDE "ErrorDisplay.icl"

                      <form class="formClass" METHOD=POST name=Chg ACTION="$(homeURL)$(cGIPath)$(d2wName)/EDIT_COPYSTD$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
                          <table $(contentTable)>
                              %if (errFound != "")
                                  @dtw_assign(focusField, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @DecatErr_Field("@@plt@", "plantNumber")          @dtw_assign(Err_CHPLT,  fieldValue)
                                  @DecatErr_Field("@@item", "itemNumber")           @dtw_assign(Err_CHITEM, fieldValue)
                                  @DecatErr_Field("@@tplt", "toplantNumber")        @dtw_assign(Err_TOPLT,  fieldValue)
                                  @DecatErr_Field("@@titm", "toitemNumber")         @dtw_assign(Err_TOPN,   fieldValue)
                                  @DecatErr_Field("@@tcft", "toconfigurationType")  @dtw_assign(Err_TOCFT,  fieldValue)
                                  @DecatErr_Field("@@tcfi", "toconfigurationID")    @dtw_assign(Err_TOCFI,  fieldValue)

                                  @Decat_Field("@@plt@")   @dtw_assign(plantNumber,         fieldValue)
                                  @Decat_Field("@@item")   @dtw_assign(itemNumber,          fieldValue)
                                  @Decat_Field("@@tplt")   @dtw_assign(toplantNumber,       fieldValue)
                                  @Decat_Field("@@titm")   @dtw_assign(toitemNumber,        fieldValue)
                                  @Decat_Field("@@tcft")   @dtw_assign(toconfigurationType, fieldValue)
                                  @Decat_Field("@@tcfi")   @dtw_assign(toconfigurationID,   fieldValue)

                                  @dtw_assign(errFound, "")
                              %else
                                  @dtw_assign(edtVar, "")
                                  @dtw_assign(plantNumber, "0")
                                  @dtw_assign(itemNumber, "")
                                  @dtw_assign(toplantNumber, "0")
                                  @dtw_assign(toitemNumber, "")
                                  @dtw_assign(toconfigurationType, "")
                                  @dtw_assign(toconfigurationID, "")
                                  @dtw_assign(focusField, "plantNumber")
                              %endif

                              @dtw_assign(plantName, "")
                              @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
                              @SetTextOvr(Err_CHPLT)
                              <tr><td class="dsphdr"><span $(textOvr)>From Plant Number</span></td>
                                  <td class="inputnmbr"><input name="plantNumber" value="$(plantNumber)" type="text" size="10" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=plantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="plantName" value="$(plantName)" type="text" size="30"></td>
                              </tr>
                              @DspErrMsg(Err_CHPLT)

                              @dtw_assign(itemdesc, "")
                              @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemdesc)
                              @SetTextOvr(Err_CHITEM)
                              <tr><td class="dsphdr"><span $(textOvr)>From Item Number</span></td>
                                  <td class="inputalph"><input name="itemNumber" type="text" value="$(itemNumber)" size="10" maxlength="15"> $(reqFieldChar) <a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=itemNumber&amp;fldDesc=itemdesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input disabled name="itemdesc" value="$(itemdesc)"  type="text" size="30"></td>
                              </tr>
                              @DspErrMsg(Err_CHITEM)

                              <tr><td> &nbsp; </td></tr>

                              @RtvFldDesc("PLPLNT=$(toplantNumber)", "HDPLNT", "PLNAME", toplantName)
                              @SetTextOvr(Err_TOPLT)
                              <tr><td class="dsphdr"><span $(textOvr)>To Plant Number</span></td>
                                  <td class="inputnmbr"><input name="toplantNumber" value="$(toplantNumber)" type="text" size="10" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toplantNumber&amp;fldDesc=toplantName" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="toplantName" value="$(toplantName)" type="text" size="30"></td>
                              </tr>
                              @DspErrMsg(Err_TOPLT)

                              @dtw_assign(toitemdescription, "")
                              @RtvFldDesc("IMITEM='$(toitemNumber)'", "HDIMST", "IMIMDS", toitemdescription)
                              @SetTextOvr(Err_TOPN)
	                                 <tr><td class="dsphdr"><span $(textOvr)>To Item Number</span></td>
                                  <td class="inputalph"><input name="toitemNumber" value="$(toitemNumber)" type="text" size="10" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toitemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="toitemDescription" value="$(toitemdescription)" type="text" size="30"></td>
                              </tr>
                              @DspErrMsg(Err_TOPN)

                              @dtw_assign(configdesc, "")
                              @RtvFldDesc("CYPLT=$(toplantNumber) and CYCFGT='$(toconfigurationType)'", "HDCFGT", "CYLDSC", configdesc)
                              @SetTextOvr(Err_TOCFT)
                              <tr><td class="dsphdr"><span $(textOvr)>To Type</span></td>
                                  <td class="inputalph"><input name="toconfigurationType" type="text" value="$(toconfigurationType)" size="10" maxlength="5"> $(reqFieldChar) <a href="$(homeURL)$(cGIPath)ConfigurationTypeSearch.d2w/ENTRY$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;docName=Chg&amp;fldName=toconfigurationType&amp;fldDesc=configdesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input disabled name="configdesc" value="$(configdesc)"  type="text" size="30"></td>
                              </tr>
                              @DspErrMsg(Err_TOCFT)

                              @SetTextOvr(Err_TOCFI)
                              <tr><td class="dsphdr"><span $(textOvr)>To ID</span></td>
                                  <td class="inputalph"><input name="toconfigurationID" type="text" value="$(toconfigurationID)" size="10" maxlength="5"> $(reqFieldChar) </td>
                              </tr>
                              @DspErrMsg(Err_TOCFI)
                          </table>
                          %INCLUDE "MaintainBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </form>
                  </td>
              </tr>
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(EDIT_COPYSTD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(itemNumber)
  @dtw_assign(configurationType, "")
  @dtw_assign(configurationID, "")
  @dtw_mUPPERCASE(toitemNumber)
  @dtw_mUPPERCASE(toconfigurationType)
  @dtw_mUPPERCASE(toconfigurationID)
  @dtw_assign(plantNumber,@dtw_rstrip(plantNumber))
  @dtw_assign(toplantNumber,@dtw_rstrip(toplantNumber))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@item", itemNumber)
  @Concat_Field("@@cfgt", configurationType)
  @Concat_Field("@@cfgi", configurationID)

  @Concat_Field("@@tplt", toplantNumber)
  @Concat_Field("@@titm", toitemNumber)
  @Concat_Field("@@tcft", toconfigurationType)
  @Concat_Field("@@tcfi", toconfigurationID)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_COPYSTD(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc("A", $(toitemDescription), "$(toitemNumber) / $(toconfigurationType) / $(toconfigurationID)", $(toplantName), $(toplantNumber), "", "", confMessage)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)ConfigurationHeader.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(fromPlant)&amp;plantName=@dtw_rurlescseq(fromName)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/COPYSTD$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}