%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Fax/E-mail Maintenance"
  d2wName                 = "VendCustFaxMaint.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;vendCustNumber=@dtw_rurlescseq(vendCustNumber)&amp;vendCustName=@dtw_rurlescseq(vendCustName)&amp;contactNumber=@dtw_rurlescseq(contactNumber)&amp;contactName=@dtw_rurlescseq(contactName)&amp;vendCustFlag=@dtw_rurlescseq(vendCustFlag)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;documentType=@dtw_rurlescseq(documentType)&amp;maintenanceCode=D"
  programName             = "HHDFMM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  helpExt                 = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (vendCustFlag == "C")
      @dtw_assign(helpExt, " (Customer)")
      @dtw_assign(customerNumber, $(vendCustNumber))
      @CustomerUserView(profileHandle, dataBaseID, userPass, customerNumber, " ")
  %else
      @dtw_assign(helpExt, " (Vendor)")
      @dtw_assign(vendorNumber, $(vendCustNumber))
      @VendorUserView(profileHandle, dataBaseID, userPass, vendorNumber)
  %endif

  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  function validate(chgForm) {
                      if (document.Chg.documentType.value =="")
                             {alert("$(reqFieldError)"); return false;}

                      if (isEmail(document.Chg.emailAddress.value) == false && document.Chg.emailAddress.value !="") {
                          alert("Please enter a valid email address.");
                          document.Chg.emailAddress.focus();
                          return false;
                      }
                      return true;
                  }
                  function isEmail(string) {
				      var emails = string.split(',');
                      for (var i in emails) {
                          if (emails[i].search(/^[a-zA-Z0-9.!#$%&'*+\/=?^_`{|}~-]+@[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(?:\.[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)*$/) != -1) {
                              continue;
                          } else {return false;}
                      }
                      return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "VENDCUSTFAXMAINT")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, " Select * From HDVCFM Where FMVCF='$(vendCustFlag)' and FMVNCS=$(vendCustNumber) ", stmtSQL)
                              @dtw_concat(stmtSQL, " and FMCONT=$(contactNumber) and FMDOCT='$(documentType)'", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          %if (vendCustFlag == "C")
              @Format_Header("Customer", $(vendCustName), $(vendCustNumber))
          %else
              @Format_Header("Vendor", $(vendCustName), $(vendCustNumber))
          %endif
          %if (contactNumber > "0")
              @Format_Header("Contact", $(contactName), $(contactNumber))
          %endif
      </table>

      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "documentType")
                      %else
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @dtw_assign(focusField, "")
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@vcf@", "vendCustFlag")     @dtw_assign(Err_VCVCF,  fieldValue)
                          @DecatErr_Field("@@cont", "addContactNumber") @dtw_assign(Err_FMCONT, fieldValue)
                          @DecatErr_Field("@@doct", "documentType")     @dtw_assign(Err_FMDOCT, fieldValue)
                          @DecatErr_Field("@@fax@", "faxNumber")        @dtw_assign(Err_FMFAX,  fieldValue)
                          @DecatErr_Field("@@cptl", "titleLine")        @dtw_assign(Err_FMCPTL, fieldValue)
                          @DecatErr_Field("@@cpt1", "toLine1")          @dtw_assign(Err_FMCPT1, fieldValue)
                          @DecatErr_Field("@@cpt2", "toLine2")          @dtw_assign(Err_FMCPT2, fieldValue)
                          @DecatErr_Field("@@cpt3", "toLine3")          @dtw_assign(Err_FMCPT3, fieldValue)
                          @DecatErr_Field("@@cpf1", "fromLine1")        @dtw_assign(Err_FMCPF1, fieldValue)
                          @DecatErr_Field("@@cpf2", "fromLine2")        @dtw_assign(Err_FMCPF2, fieldValue)
                          @DecatErr_Field("@@cpf3", "fromLine3")        @dtw_assign(Err_FMCPF3, fieldValue)
                          @DecatErr_Field("@@cpcl", "commentLine")      @dtw_assign(Err_FMCPCL, fieldValue)
                          @DecatErr_Field("@@emal", "emailAddress")     @dtw_assign(Err_FMEMAL, fieldValue)
                          @DecatErr_Field("@@bcc@", "emailBCC")         @dtw_assign(Err_FMBCC,  fieldValue)
                      %endif

                      @Decat_Field("@@cont")   @dtw_assign(V_FMCONT, fieldValue)
                      @Decat_Field("@@doct")   @dtw_assign(V_FMDOCT, fieldValue)
                      @Decat_Field("@@fax@")   @dtw_assign(V_FMFAX,  fieldValue)
                      @Decat_Field("@@cptl")   @dtw_assign(V_FMCPTL, fieldValue)
                      @Decat_Field("@@cpt1")   @dtw_assign(V_FMCPT1, fieldValue)
                      @Decat_Field("@@cpt2")   @dtw_assign(V_FMCPT2, fieldValue)
                      @Decat_Field("@@cpt3")   @dtw_assign(V_FMCPT3, fieldValue)
                      @Decat_Field("@@cpf1")   @dtw_assign(V_FMCPF1, fieldValue)
                      @Decat_Field("@@cpf2")   @dtw_assign(V_FMCPF2, fieldValue)
                      @Decat_Field("@@cpf3")   @dtw_assign(V_FMCPF3, fieldValue)
                      @Decat_Field("@@cpcl")   @dtw_assign(V_FMCPCL, fieldValue)
                      @Decat_Field("@@emal")   @dtw_assign(V_FMEMAL, fieldValue)
                      @Decat_Field("@@bcc@")   @dtw_assign(V_FMBCC,  fieldValue)
                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "documentType")
                      @dtw_assign(V_FMDOCT,  "")

                  %else
                      @dtw_assign(focusField, "faxNumber")
                  %endif

                  %if ((maintenanceCode == "A" || maintenanceCode == "Z") && V_HDCMRL > "0")
                      @SetTextOvr(Err_FMCONT)
                      <tr><td class="dsphdr"><span $(textOvr)>Contact Number</span></td>
                          %if (vendCustFlag == "C")
                              @RtvCustCont(profileHandle, dataBaseID, V_FMCONT, lastName, firstName, salutation, companyName)
                              @Format_EmplName(firstName, lastName, "", "", "", "H", addContactName)
                              <td class="inputnmbr"><input name="addContactNumber" type="text" value="$(V_FMCONT)" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)customercontactsearch.d2w/ENTRY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(vendCustNumber)&amp;customerName=@dtw_rurlescseq(vendCustName)&amp;docName=Chg&amp;fldName=addContactNumber&amp;fldDesc=addContactName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="addContactName" value="$(addContactName)" type="text" disabled></td>
                          %else
                              @RtvSuppCont(profileHandle, dataBaseID, V_FMCONT, lastName, firstName, salutation, companyName)
                              @Format_EmplName(firstName, lastName, "", "", "", "H", addContactName)
                              <td class="inputnmbr"><input name="addContactNumber" type="text" value="$(V_FMCONT)" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)suppliercontactsearch.d2w/ENTRY$(genericVarBase)&amp;vendorNumber=@dtw_rurlescseq(vendCustNumber)&amp;vendorName=@dtw_rurlescseq(vendCustName)&amp;docName=Chg&amp;fldName=addContactNumber&amp;fldDesc=addContactName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="addContactName" value="$(addContactName)" type="text" disabled></td>
                          %endif
                      </tr>
                      @DspErrMsg(Err_FMCONT)
                  %endif

                  @RtvFldDesc("DODOCT='$(V_FMDOCT)' ", "HDDOCT", "DODESC", fieldDesc)
                  @SetTextOvr(Err_FMDOCT)
                  <tr><td class="dsphdr"><span $(textOvr)>Document Type</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="documentType" value="$(V_FMDOCT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(cGIPath)DocumentTypeSearch.d2w/ENTRY$(genericVarBase)&amp;vendCustFlag=@dtw_rurlescseq(vendCustFlag)&amp;docName=Chg&amp;fldName=documentType&amp;fldDesc=documentTypeDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input name="documentTypeDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                      %else
                          <td class="inputalph"><input name="documentType" type="hidden" value="$(V_FMDOCT)" size="3" maxlength="3">$(V_FMDOCT) &nbsp; $(fieldDesc)
                      %endif
                  </tr>
                  @DspErrMsg(Err_FMDOCT)

                  @SetTextOvr(Err_FMEMAL)
                  <tr><td class="dsphdr"><span $(textOvr)>E-mail Address</span></td>
                      <td class="inputalph"><input name="emailAddress" type="text" value="$(V_FMEMAL)" size="50" maxlength="256"></td>
                  </tr>
                  @DspErrMsg(Err_FMEMAL)

	           @Field_Checked(V_FMBCC, "Y", emailBCCChecked)
                  @SetTextOvr(Err_FMBCC)
                  <tr><td class="dsphdr"><span $(textOvr)>BCC</span></td>
                      <td><input type="checkbox" name="emailBCC" value="Y" $(emailBCCChecked)>
                  </tr>
                  @DspErrMsg(Err_FMBCC)
              </table>
			
              <fieldset class="legendBody">
                  <legend class="legendTitle">Fax</legend>
                  <table $(contentTable)>

                  @SetTextOvr(Err_FMFAX)
                  <tr><td class="dsphdr"><span $(textOvr)>Fax Number</span></td>
                      <td class="inputalph"><input name="faxNumber" type="text" value="$(V_FMFAX)" size="50" maxlength="32"></td>
                  </tr>
                  @DspErrMsg(Err_FMFAX)

                  @SetTextOvr(Err_FMCPTL)
                  <tr><td class="dsphdr"><span $(textOvr)>Title Line</span></td>
                      <td class="inputalph"><input name="titleLine" type="text" value="$(V_FMCPTL)" size="50" maxlength="40"></td>
                  </tr>
                  @DspErrMsg(Err_FMCPTL)
	   		
                  @SetTextOvr(Err_FMCPT1)
                  <tr><td class="dsphdr"><span $(textOvr)>To Line 1</span></td>
                      <td class="inputalph"><input name="toLine1" type="text" value="$(V_FMCPT1)" size="50" maxlength="40"></td>
                  </tr>
                  @DspErrMsg(Err_FMCPT1)
	   		
                  @SetTextOvr(Err_FMCPT2)
                  <tr><td class="dsphdr"><span $(textOvr)>To Line 2</span></td>
                      <td class="inputalph"><input name="toLine2" type="text" value="$(V_FMCPT2)" size="50" maxlength="40"></td>
                  </tr>
                  @DspErrMsg(Err_FMCPT2)
	   		
                  @SetTextOvr(Err_FMCPT3)
                  <tr><td class="dsphdr"><span $(textOvr)>To Line 3</span></td>
                      <td class="inputalph"><input name="toLine3" type="text" value="$(V_FMCPT3)" size="50" maxlength="40"></td>
                  </tr>
                  @DspErrMsg(Err_FMCPT3)
	   		
                  @SetTextOvr(Err_FMCPF1)
                  <tr><td class="dsphdr"><span $(textOvr)>From Line 1</span></td>
                      <td class="inputalph"><input name="fromLine1" type="text" value="$(V_FMCPF1)" size="50" maxlength="40"></td>
                  </tr>
                  @DspErrMsg(Err_FMCPF1)
	   		
                  @SetTextOvr(Err_FMCPF2)
                  <tr><td class="dsphdr"><span $(textOvr)>From Line 2</span></td>
                      <td class="inputalph"><input name="fromLine2" type="text" value="$(V_FMCPF2)" size="50" maxlength="40"></td>
                  </tr>
                  @DspErrMsg(Err_FMCPF2)
	   		
                  @SetTextOvr(Err_FMCPF3)
                  <tr><td class="dsphdr"><span $(textOvr)>From Line 3</span></td>
                      <td class="inputalph"><input name="fromLine3" type="text" value="$(V_FMCPF3)" size="50" maxlength="40"></td>
                  </tr>
                  @DspErrMsg(Err_FMCPF3)
	   		
                  @SetTextOvr(Err_FMCPCL)
                  <tr><td class="dsphdr"><span $(textOvr)>Comment Line</span></td>
                      <td class="inputalph"><input name="commentLine" type="text" value="$(V_FMCPCL)" size="50" maxlength="40"></td>
                  </tr>
                  @DspErrMsg(Err_FMCPCL)
              %}	
          </table>
          </fieldset>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HHDFMM_W.PGM %}
  %}

%HTML(FAX) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(documentType)
  @dtw_mUPPERCASE(faxNumber)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif
  %if (maintenanceCode == "A")
      @dtw_assign(contactNumber, addContactNumber)
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@vcf@", vendCustFlag)
  @Concat_Field("@@vncs", vendCustNumber)
  @Concat_Field("@@cont", contactNumber)
  @Concat_Field("@@doct", documentType)
  @Concat_Field("@@fax@", faxNumber)
  @Concat_Field("@@cptl", titleLine)
  @Concat_Field("@@cpt1", toLine1)
  @Concat_Field("@@cpt2", toLine2)
  @Concat_Field("@@cpt3", toLine3)
  @Concat_Field("@@cpf1", fromLine1)
  @Concat_Field("@@cpf2", fromLine2)
  @Concat_Field("@@cpf3", fromLine3)
  @Concat_Field("@@cpcl", commentLine)
  @Concat_Field("@@emal", emailAddress)
  %if (emailBCC != "Y") @dtw_assign(emailBCC, "") %endif
  @Concat_Field("@@bcc@", emailBCC)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  @RtvFldDesc("DODOCT='$(documentType)' ", "HDDOCT", "DODESC", fieldDesc)
  %if (errFound == "")
      %if (contactNumber > "0")
          @Format_ConfMsg_Desc(maintenanceCode, $(fieldDesc), $(documentType), "For $(contactName)", $(contactNumber), "", "", confMessage)
      %else
          @Format_ConfMsg_Desc(maintenanceCode, $(fieldDesc), $(documentType), "", "", "", "", confMessage)
      %endif
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)vendcustfax.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@doct", "documentType")
      @Format_ConfMsg_Desc("", $(fieldDesc), $(documentType), "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)vendcustfax.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/FAX$(d2wVarBase)&amp;documentType=@dtw_rurlescseq(documentType)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
