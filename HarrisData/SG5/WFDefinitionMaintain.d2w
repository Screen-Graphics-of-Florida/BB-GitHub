%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Point Definition Maintenance"
  d2wName                 = "WFDefinitionMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfProcess=@dtw_rurlescseq(wfProcess)&amp;passedWfPoint=@dtw_rurlescseq(passedWfPoint)&amp;passedWfSequence=@dtw_rurlescseq(passedWfSequence)&amp;fromPoint=@dtw_rurlescseq(fromPoint)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;updRecNbr=@dtw_rurlescseq(updRecNbr)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;wfPoint=@dtw_rurlescseq(wfPoint)&amp;maintenanceCode=D"
  programName             = "HWFDFM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function confirmDelete() {return confirm("$(delRecordConf)")}
              function validate(chgForm) {
                  if (document.Chg.wfPoint.value =="" ||
                      document.Chg.wfPointDescription.value =="")
                         {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.wfPoint, 4, 3)
                      )
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFDEFINITIONMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " WFPRDF ", fileSQL)
                          @dtw_concat(selectSQL, " PPPROC='$(wfProcess)' and PPPONT=$(wfPoint) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          @RtvFldDesc("PRPROC='$(wfProcess)'", "WFPRHD", "PRDESC", wfProcessDescription)
          @Format_Header("", $(wfProcessDescription), $(wfProcess))
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          %ROW {
              %if (errFound != "" || maintenanceCode == "A")
                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(edtVar, "")
                      @dtw_assign(focusField, "wfPoint")
                  %else
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@pont", "wfPoint")                @dtw_assign(Err_PPPONT, fieldValue)
                      @DecatErr_Field("@@desc", "wfPointDescription")     @dtw_assign(Err_PPDESC, fieldValue)
                      @DecatErr_Field("@@join", "andJoin")                @dtw_assign(Err_PPJOIN, fieldValue)
                  %endif

                  @Decat_Field("@@pont")   @dtw_assign(V_PPPONT, fieldValue)
                  @Decat_Field("@@desc")   @dtw_assign(V_PPDESC, fieldValue)
                  @Decat_Field("@@join")   @dtw_assign(V_PPJOIN, fieldValue)

                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(focusField, "wfPoint")
                  %endif

                  @dtw_assign(errFound, "")

              %elif (maintenanceCode == "Z")
                  @dtw_assign(focusField, "wfPoint")
              %else
                  @dtw_assign(focusField, "wfPointDescription")
              %endif

              <table $(contentTable)>
                  @SetTextOvr(Err_PPPONT)
                  <tr><td class="dsphdr"><span $(textOvr)>Point</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input type="text" name="wfPoint" value="$(V_PPPONT)" size="8" maxlength="8">$(reqFieldChar)</td>
                      %else
                          <td class="inputnmbr"><input type="hidden" name="wfPoint" value="$(V_PPPONT)">$(V_PPPONT)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_PPPONT)

                  @SetTextOvr(Err_PPDESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input type="text" name="wfPointDescription" value="$(V_PPDESC)" size="50" maxlength="50">$(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_PPDESC)

                  @RtvFldDesc("FLTYPE='BY' and FLVALU='$(V_PPJOIN)'", "SYFLAG", "FLDESC", fieldDesc)
                  @SetTextOvr(Err_PPJOIN)
                  <tr><td class="dsphdr"><span $(textOvr)>And Join</span></td>
                      <td class="inputalph"><input type="text" name="andJoin" value="$(V_PPJOIN)" size="1" maxlength="1">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=BY&amp;flagSrchHdr=@dtw_rurlescseq("And Join")&amp;docName=Chg&amp;fldName=andJoin&amp;fldDesc=andJoinDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                            <input type="text" disabled name="andJoinDesc" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_PPJOIN)
              </table>
          %}

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HWFDFM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  %if (wfPointDescription == "")
      @RtvFldDesc("PPPROC='$(wfProcess)' and PPPONT=$(wfPoint)", "WFPRDF", "PPDESC", wfPointDescription)
  %endif

  @dtw_mUPPERCASE(wfProcess)
  @dtw_mUPPERCASE(andJoin)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@frm1", fromPoint)
  @Concat_Field("@@proc", wfProcess)
  @Concat_Field("@@pont", wfPoint)
  @Concat_Field("@@desc", wfPointDescription)
  @Concat_Field("@@join", andJoin)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(wfPointDescription), $(wfPoint), "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@pont", "wfPoint")
      @Format_ConfMsg_Desc("", $(wfPointDescription), $(wfPoint), "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;wfPoint=@dtw_rurlescseq(wfPoint)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
