%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Application ID Search"
  d2wName                 = "ApIdSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectApIdCode(apIdCode, apIdDesc){
                  window.opener.document.$(docName).$(fldName).value = apIdCode;
                  window.opener.document.$(docName).$(fldDesc).value = apIdDesc;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select SYAPID.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(AIAPDS) as AIAPDSU ", stmtSQL)
                      @dtw_concat(fileSQL, " SYAPID ", fileSQL)
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, " AIAPID='$(apIdCode)'", selectSQL)
                      %elseif (wildCardSearch!="")
                          @dtw_concat(selectSQL, " AIAPID<>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Process_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Process_Search (IN  CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Description</th>
                      <th class="colhdr">Application ID</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="20" maxlength="20">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchApId" size="4" maxlength="2">
                          <input type="hidden" name="operApId" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("AIAPID", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApIdCode" title="Sequence By Application ID">Application ID</a></th>
                  @OrderBy_Sort("AIAPDSU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Description, Application ID">Description</a></th>
                  @OrderBy_Sort("AIMOPT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MenuOpt" title="Sequence By Menu Option Of HHDM00, Application ID">Menu Option Of HHDM00</a></th>
                  @OrderBy_Sort("AIPGM ", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Program" title="Sequence By Program To Call, Application ID">Program To Call</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %endif		

              %ROW{
                  %INCLUDE "SetRowClass.icl"
                  @Format_Quote(V_AIAPID, F_AIAPID)
                  @Format_Quote(V_AIAPDS, F_AIAPDS)

                  %if (moreInfo != "Y")	
                      <tr class="$(rowClass)">
                          <td class="colcode">$(V_AIAPID)</td>
                          <td class="colalph"><a href="javascript:selectApIdCode('$(F_AIAPID)','$(F_AIAPDS)')" title="Select Application ID">$(V_AIAPDS)</a></td>
                          <td class="colnmbr">$(V_AIMOPT)</td>
                          <td class="colalph">$(V_AIPGM )</td>
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;apIdCode=@dtw_rurlescseq(V_AIAPID)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                      </tr>

                  %else

                      <table $(contentTable)>
                          <tr><td><a href="javascript:selectApIdCode('$(F_AIAPID)','$(F_AIAPDS)')" title="Select Application ID">$(selectImageLrg)</a>
                              </td>
                          </tr>

                          <tr><td class="dsphdr">Application ID</td>
                              <td class="dspalph">$(V_AIAPID)</td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              <td class="dspalph">$(V_AIAPDS)</td></tr>

                          <tr><td class="dsphdr">Menu Option Of HHDM00</td>
                              <td class="dspnmbr">$(V_AIMOPT)</td></tr>	

                          <tr><td class="dsphdr">Program To Call</td>
                              <td class="dspalph">$(V_AIPGM )</td></tr>
                      </table>
                  %endif
              %}
      %if (moreInfo != "Y")	
          </table>
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
      %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "AIAPDSU,AIAPID")
      @DTW_ASSIGN(orderByDisplay, "Description, Application ID")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(orderBy, "AIAPID")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "ApIdCode")
      %if (orderBy == "AIAPID")
          @DTW_ASSIGN(orderBy, "AIAPID DESC")
          @DTW_ASSIGN(orderByDisplay, "Application ID (descending)")
      %else
          @DTW_ASSIGN(orderBy, "AIAPID")
          @DTW_ASSIGN(orderByDisplay, "Application ID")
      %endif
  %elseif (sequence == "Description")
      %if (orderBy == "AIAPDSU,AIAPID")
          @DTW_ASSIGN(orderBy, "AIAPDSU DESC,AIAPID")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Application ID")
      %else
          @DTW_ASSIGN(orderBy, "AIAPDSU,AIAPID")
          @DTW_ASSIGN(orderByDisplay, "Description, Application ID")
      %endif
  %elseif (sequence == "MenuOpt")
      %if (orderBy == "AIMOPT,AIAPID")
          @DTW_ASSIGN(orderBy, "AIMOPT DESC,AIAPID")
          @DTW_ASSIGN(orderByDisplay, "Menu Option Of HHDM00 (descending), Application ID")
      %else
          @DTW_ASSIGN(orderBy, "AIMOPT,AIAPID")
          @DTW_ASSIGN(orderByDisplay, "Menu Option Of HHDM00, Application ID")
      %endif
  %elseif (sequence == "Program")
      %if (orderBy == "AIPGM ,AIAPID")
          @DTW_ASSIGN(orderBy, "AIPGM  DESC,AIAPID")
          @DTW_ASSIGN(orderByDisplay, "Program To Call (descending), Application ID")
      %else
          @DTW_ASSIGN(orderBy, "AIPGM ,AIAPID")
          @DTW_ASSIGN(orderByDisplay, "Program To Call, Application ID")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchMenuOpt, 2, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "APIDSEARCH")
                  <td>
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="20" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Application ID</td>
                              @dtw_assign(operNbr, "operApId")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchApId" size="2" maxlength="2"></td>	
                          </tr>

                          <tr><td class="dsphdr">Menu Option Of HHDM00</td>
                              @dtw_assign(operNbr, "operMenuOpt")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchMenuOpt" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Program To Call</td>
                              @dtw_assign(operNbr, "operProgram")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchProgram" size="10" maxlength="10"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDesc.focus();
                          </script>
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("upper(AIAPDS)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("AIAPID", "Application ID", $(srchApId), "U", operApId, "A")
  @Build_WildCard ("AIMOPT", "Menu Option Of HHDM00", $(srchMenuOpt), "", operMenuOpt, "N")
  @Build_WildCard ("AIPGM ", "Program To Call", $(srchProgram), "U", operProgram, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
