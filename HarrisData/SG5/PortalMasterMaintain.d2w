%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Portal Maintenance"
  d2wName                 = "PortalMasterMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromUrlPortal=@dtw_rurlescseq(fromUrlPortal)&amp;fromUrlPage=@dtw_rurlescseq(fromUrlPage)&amp;fromUrlSequence=@dtw_rurlescseq(fromUrlSequence)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;urlPortal=@dtw_rurlescseq(urlPortal)&amp;urlPage=@dtw_rurlescseq(urlPage)&amp;urlSequence=@dtw_rurlescseq(urlSequence)&amp;urlDesc=@dtw_rurlescseq(urlDesc)&amp;maintenanceCode=D"
  programName             = "HSYPRM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
	          %INCLUDE "numedit.icl"
              function confirmDelete() {return confirm("$(delRecordConf)")}
              function validate(chgForm) {
                  if (document.Chg.urlPortal.value =="" ||
                      document.Chg.urlSequence.value =="" ||
                      document.Chg.urlID.value =="")
                     {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.urlSequence, 5, 2))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PORTALMASTERMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                          @dtw_concat(fileSQL, "SYPORT ", fileSQL)
                          @dtw_concat(selectSQL, "FPPORT='$(urlPortal)' and FPPAGE='$(urlPage)' and FPSEQ=$(urlSequence) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=199")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
	   <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "urlPortal")
                      %else
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @dtw_assign(focusField, "")
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@port", "urlPortal")   @dtw_assign(Err_FPPORT, fieldValue)
                          @DecatErr_Field("@@page", "urlPage")   @dtw_assign(Err_FPPAGE, fieldValue)
                          @DecatErr_Field("@@seq@", "urlSequence")   @dtw_assign(Err_FPSEQ, fieldValue)
                          @DecatErr_Field("@@id@@", "urlID")   @dtw_assign(Err_FPID, fieldValue)
                          @DecatErr_Field("@@desc", "urlDesc")   @dtw_assign(Err_FPDESC, fieldValue)
                          @DecatErr_Field("@@titl", "title")   @dtw_assign(Err_FPTITL, fieldValue)
                      %endif

                      @Decat_Field("@@port")   @dtw_assign(V_FPPORT, fieldValue)
                      @Decat_Field("@@page")   @dtw_assign(V_FPPAGE, fieldValue)
                      @Decat_Field("@@seq@")   @dtw_assign(V_FPSEQ, fieldValue)
                      @Decat_Field("@@id@@")   @dtw_assign(V_FPID, fieldValue)
                      @Decat_Field("@@desc")   @dtw_assign(V_FPDESC, fieldValue)
                      @Decat_Field("@@titl")   @dtw_assign(V_FPTITL, fieldValue)
                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "urlPortal")
                  %else
                      @dtw_assign(focusField, "urlID")
                  %endif

                  @SetTextOvr(Err_FPPORT)
                  <tr><td class="dsphdr"><span $(textOvr)>Portal</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="urlPortal" type="text" value="$(V_FPPORT)"size="25" maxlength="20"> $(reqFieldChar) </td>
                      %else
                          <td class="inputalph"><input name="urlPortal" type="hidden" value="$(V_FPPORT)" size="25" maxlength="20">$(V_FPPORT)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_FPPORT)

                  @SetTextOvr(Err_FPPAGE)
                  <tr><td class="dsphdr"><span $(textOvr)>Page</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="urlPage" type="text" value="$(V_FPPAGE)"size="25" maxlength="20"></td>
                      %else
                          <td class="inputalph"><input name="urlPage" type="hidden" value="$(V_FPPAGE)" size="25" maxlength="20">$(V_FPPAGE)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_FPPAGE)

                  @SetTextOvr(Err_FPSEQ)
                  <tr><td class="dsphdr"><span $(textOvr)>Sequence</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="urlSequence" type="text" value="$(V_FPSEQ)" size="9" maxlength="9"> $(reqFieldChar) </td>
                      %else
                          <td class="inputnmbr"><input name="urlSequence" type="hidden" value="$(V_FPSEQ)" size="9" maxlength="9">$(V_FPSEQ)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_FPSEQ)

                  @RtvFldDesc("FUID='$(V_FPID)'", "SYURLM", "FUDESC", fieldDesc)
                  @SetTextOvr(Err_FPID)
                  <tr><td class="dsphdr"><span $(textOvr)>URL ID</span></td>
                      <td class="inputalph"><input name="urlID" type="text" value="$(V_FPID)" size="50" maxlength="55"><a href="$(homeURL)$(cGIPath)URLSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=urlID&amp;fldDesc=urlIDDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input name="urlIDDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_FPID)
	   		
                  @SetTextOvr(Err_FPDESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Override Description</span></td>
                      <td class="inputalph"><input name="urlDesc" type="text" value="$(V_FPDESC)" size="20" maxlength="20"></td>
                  </tr>
                  @DspErrMsg(Err_FPDESC)
	   		
                  @SetTextOvr(Err_FPTITL)
                  <tr><td class="dsphdr"><span $(textOvr)>Title</span></td>
                      <td class="inputalph"><input name="title" type="text" value="$(V_FPTITL)" size="50" maxlength="50"></td>
                  </tr>
                  @DspErrMsg(Err_FPTITL)
              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSYPRM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(urlPortal)
  @dtw_mUPPERCASE(urlPage)
  @dtw_mUPPERCASE(urlID)
  @dtw_assign(urlSequence,@dtw_rstrip(urlSequence))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@frm1", fromUrlPortal)
  @Concat_Field("@@frm2", fromUrlPage)
  @Concat_Field("@@frm3", fromUrlSequence)
  @Concat_Field("@@port", urlPortal)
  @Concat_Field("@@page", urlPage)
  @Concat_Field("@@seq@", urlSequence)
  @Concat_Field("@@id@@", urlID)
  @Concat_Field("@@desc", urlDesc)
  @Concat_Field("@@titl", title)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, "Portal", $(urlPortal), "Page", $(urlPage), "Sequence", $(urlSequence), confMessage)
      %else
          @DecatErr_Field("@@port", "urlPortal")
          @Format_ConfMsg_Desc("", "Portal", $(urlPortal), "Page", $(urlPage), "<br>$(fieldValue)", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=199&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;urlPortal=@dtw_rurlescseq(urlPortal)&amp;urlPage=@dtw_rurlescseq(urlPage)&amp;urlSequence=@dtw_rurlescseq(urlSequence)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
