%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Work Center"
  d2wName                 = "WorkCenterSelect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(fromPlant)&amp;fromName=@dtw_rurlescseq(fromName)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;department=@dtw_rurlescseq(department)&amp;workCenter=@dtw_rurlescseq(workCenter)&amp;description=@dtw_rurlescseq(description)&amp;fromSel=Y"
  programName             = "HPD016"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %if (userPass == "Y")
      @WorkCenterUserView(profileHandle, dataBaseID, userPass, plantNumber, department, workCenter)
  %endif
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script type="text/javascript">
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                          @dtw_assign(pageID, "WORKCENTERSELECT")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " HDMWCM ", fileSQL)
                          @dtw_concat(selectSQL, "WCPLT=$(plantNumber) and WCDEPT='$(department)' and WCWC='$(workCenter)'  ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                          @workCenter_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) workCenter_Query (IN  CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td>&nbsp;</td>
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)WorkCentermaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (sec_04 == "Y")
                          <a href="$(homeURL)$(cGIPath)WorkCentermaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=Z">$(copyImageLrg)</a>
                      %endif
                      %if (sec_02 == "Y" || sec_03 == "Y")
                          <a href="$(homeURL)$(cGIPath)WorkCentermaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=C">$(changeImageLrg)</a>
                      %endif
                      %if (sec_03 == "Y")
                          @Format_Confirm_Desc($(description), "$(department) - $(workCenter)", "", "", "", "", confirmDesc)
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)WorkCentermaintain.d2w/Edit_Data$(d2wVarBase)&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      <table $(contentTable)>
          %ROW {
              @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
              <tr><td class="dsphdr">Plant</td>
                  <td class="dspnmbr">$(V_WCPLT)</td>
                  <td class="dspalph">$(plantName)</td>
              </tr>

              <tr><td class="dsphdr">Department</td>
                  <td class="dspalph">$(V_WCDEPT)</td>
                  <td class="dspalph">$(V_WCDESC)</td>
              </tr>

              <tr><td class="dsphdr">Work Center</td>
                  <td class="dspalph">$(V_WCWC)</td>
              </tr>
    	   		
              <tr><td class="dsphdr">Key Load Code</td>
                  <td class="dspalph">$(V_WCKLCD)</td>
              </tr>

              @RtvFldDesc("SMSCHD=$(V_WCSCHD)", "HDSCHM", "SMDESC", fieldDesc)	    		
              <tr><td class="dsphdr">Schedule</td>
                  <td class="dspnmbr">$(V_WCSCHD)</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              @Format_CoFac("$(V_WCCO)", "$(V_WCFAC)", "", F_CoFac)
              @RtvFldDesc("CFCO#=$(V_WCCO) and CFFAC#=$(V_WCFAC)", "HDCFAC", "CFCFNM", cofacName)
              <tr><td class="dsphdr">Company/Facility</td>
                  <td class="dspalph">$(F_CoFac)</td>
                  <td class="dspalph">$(cofacName)</td>
              </tr>
          %}
      </table>
      $(hrTagAttr)	
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}