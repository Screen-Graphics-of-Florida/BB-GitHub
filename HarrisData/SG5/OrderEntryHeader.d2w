                      @DspErrMsg(Err_H1UDF5)

                  %elif (V_UMFSEQ == "341" && userAlphaDesc6 != "")
                      %if (errFound != "")
                          @DecatErr_Field("@@udf6", "userAlpha6")  @dtw_assign(Err_H1UDF6, fieldValue)
                          @Decat_Field("@@udf6")                   @dtw_assign(V_H1UDF6, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1UDF6)
                      <tr>
    	   	           <td class="dsphdr"><span $(textOvr)>$(userAlphaDesc6)</span></td>
                          <td class="inputalph"><input type="text" name="userAlpha6" value="$(V_H1UDF6)" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_H1UDF6)

                  %elif (V_UMFSEQ == "342" && userAlphaDesc7 != "")
                      %if (errFound != "")
                          @DecatErr_Field("@@udf7", "userAlpha7")  @dtw_assign(Err_H1UDF7, fieldValue)
                          @Decat_Field("@@udf7")                   @dtw_assign(V_H1UDF7, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1UDF7)
                      <tr>
    	   	           <td class="dsphdr"><span $(textOvr)>$(userAlphaDesc7)</span></td>
                          <td class="inputalph"><input type="text" name="userAlpha7" value="$(V_H1UDF7)" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_H1UDF7)

                  %elif (V_UMFSEQ == "343" && userAlphaDesc8 != "")
                      %if (errFound != "")
                          @DecatErr_Field("@@udf8", "userAlpha8")  @dtw_assign(Err_H1UDF8, fieldValue)
                          @Decat_Field("@@udf8")                   @dtw_assign(V_H1UDF8, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1UDF8)
                      <tr>
    	   	           <td class="dsphdr"><span $(textOvr)>$(userAlphaDesc8)</span></td>
                          <td class="inputalph"><input type="text" name="userAlpha8" value="$(V_H1UDF8)" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_H1UDF8)

                  %elif (V_UMFSEQ == "344" && userAlphaDesc9 != "")
                      %if (errFound != "")
                          @DecatErr_Field("@@udf9", "userAlpha9")  @dtw_assign(Err_H1UDF9, fieldValue)
                          @Decat_Field("@@udf9")                   @dtw_assign(V_H1UDF9, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1UDF9)
                      <tr>
    	   	           <td class="dsphdr"><span $(textOvr)>$(userAlphaDesc9)</span></td>
                          <td class="inputalph"><input type="text" name="userAlpha9" value="$(V_H1UDF9)" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_H1UDF9)

                  %elif (V_UMFSEQ == "345" && userAlphaDesc0 != "")
                      %if (errFound != "")
                          @DecatErr_Field("@@udf0", "userAlpha0")  @dtw_assign(Err_H1UDF0, fieldValue)
                          @Decat_Field("@@udf0")                   @dtw_assign(V_H1UDF0, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1UDF0)
                      <tr>
    	   	           <td class="dsphdr"><span $(textOvr)>$(userAlphaDesc0)</span></td>
                          <td class="inputalph"><input type="text" name="userAlpha0" value="$(V_H1UDF0)" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_H1UDF0)

                  %elif (V_UMFSEQ == "370" && userNumDesc1 != "")
                      %if (errFound != "")
                          @DecatErr_Field("@@udn1", "userNumeric1")  @dtw_assign(Err_H1UDN1, fieldValue)
                          @Decat_Field("@@udn1")                     @dtw_assign(V_H1UDN1, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1UDN1)
                      <tr>
    		       <td class="dsphdr"><span $(textOvr)>$(userNumDesc1)</span></td>
                          <td class="inputnmbr"><input type="text" name="userNumeric1" value="$(V_H1UDN1)" size="22" maxlength="15"></td>
                      </tr>
                      @DspErrMsg(Err_H1UDN1)

                  %elif (V_UMFSEQ == "371" && userNumDesc2 != "")
                      %if (errFound != "")
                          @DecatErr_Field("@@udn2", "userNumeric2")  @dtw_assign(Err_H1UDN2, fieldValue)
                          @Decat_Field("@@udn2")                     @dtw_assign(V_H1UDN2, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1UDN2)
                      <tr>
    		       <td class="dsphdr"><span $(textOvr)>$(userNumDesc2)</span></td>
                          <td class="inputnmbr"><input type="text" name="userNumeric2" value="$(V_H1UDN2)" size="22" maxlength="15"></td>
                      </tr>
                      @DspErrMsg(Err_H1UDN2)

                  %elif (V_UMFSEQ == "372" && userNumDesc3 != "")
                      %if (errFound != "")
                          @DecatErr_Field("@@udn3", "userNumeric3")  @dtw_assign(Err_H1UDN3, fieldValue)
                          @Decat_Field("@@udn3")                     @dtw_assign(V_H1UDN3, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1UDN3)
                      <tr>
    		       <td class="dsphdr"><span $(textOvr)>$(userNumDesc3)</span></td>
                          <td class="inputnmbr"><input type="text" name="userNumeric3" value="$(V_H1UDN3)" size="22" maxlength="15"></td>
                      </tr>
                      @DspErrMsg(Err_H1UDN3)

                  %elif (V_UMFSEQ == "373" && userNumDesc4 != "")
                      %if (errFound != "")
                          @DecatErr_Field("@@udn4", "userNumeric4")  @dtw_assign(Err_H1UDN4, fieldValue)
                          @Decat_Field("@@udn4")                     @dtw_assign(V_H1UDN4, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1UDN4)
                      <tr>
    		       <td class="dsphdr"><span $(textOvr)>$(userNumDesc4)</span></td>
                          <td class="inputnmbr"><input type="text" name="userNumeric4" value="$(V_H1UDN4)" size="22" maxlength="15"></td>
                      </tr>
                      @DspErrMsg(Err_H1UDN4)

                  %elif (V_UMFSEQ == "374" && userNumDesc5 != "")
                      %if (errFound != "")
                          @DecatErr_Field("@@udn5", "userNumeric5")  @dtw_assign(Err_H1UDN5, fieldValue)
                          @Decat_Field("@@udn5")                     @dtw_assign(V_H1UDN5, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1UDN5)
                      <tr>
    		       <td class="dsphdr"><span $(textOvr)>$(userNumDesc5)</span></td>
                          <td class="inputnmbr"><input type="text" name="userNumeric5" value="$(V_H1UDN5)" size="22" maxlength="15"></td>
                      </tr>
                      @DspErrMsg(Err_H1UDN5)

                  %elif (V_UMFSEQ == "350")
                      %if (errFound != "")
                          @DecatErr_Field("@@hold", "holdCode")  @dtw_assign(Err_H1HOLD, fieldValue)
                          @Decat_Field("@@hold")                 @dtw_assign(V_H1HOLD, fieldValue)
                      %endif
                      @RtvFldDesc("HCTYPE='O' and HCHLCD='$(V_H1HOLD)'", "HDHLCD", "HCDESC", fieldDesc)
                      @SetTextOvr(Err_H1HOLD)
                      <tr>
                          <td class="dsphdr"><span $(textOvr)>Hold Code</span></td>
                          <td class="inputalph"><input name="holdCode" type="text" value="$(V_H1HOLD)" size="4" maxlength="4"><a href="$(homeURL)$(phpPath)HoldCodeSearch.php$(altVarBase)&amp;fldType=O&amp;docName=Chg&amp;fldName=holdCode&amp;fldDesc=holdCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="holdCodeDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                      </tr>
                      @DspErrMsg(Err_H1HOLD)
                  %endif
                  @dtw_add(recCnt, "1", recCnt)
              %}
              <tr><td class="inputalph"><input type="hidden" name="octl" value="$(orderControlNumber)"></td>
              	  <td class="inputalph"><input type="hidden" id="checkCCL" name="checkCCL" value="">
              </tr>
      %}
      </table>
      %if (focusField != "")
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      %endif
      </form>
      @dtw_assign(errFound, "")
      %if (firstTime == "Y")
          %if (defaultOrderTab == "4")
	          <script TYPE="text/javascript">
	              document.getElementById('checkCCL').value='Y';
	          </script>
          %endif
          @dtw_assign(firstTime, "")
          <script TYPE="text/javascript">
              javascript:check(document.Chg);
          </script>
      %endif
      <div>
          <a href="javascript:check(document.Chg)">$(acceptImageLrg)</a>
          <a href="$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)">$(selectResetImage)</a>
      </div>
      %INCLUDE "EndTabs.icl"
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HOEUHW_W.PGM %}
%}

%HTML(HEADER) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultOrderTab == "4" && checkCCL == "Y")
      @dtw_assign(firstHeader, "Y")
  %endif
  %INCLUDE "OrderEntryRetInfo.icl"
  %if (hdrError == "Y")
      @dtw_assign(firstTime, "Y")
  %endif
  @Set_SQL(stmtSQL)
  %}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(referenceNumber)
  @dtw_mUPPERCASE(termsCode)
  @dtw_mUPPERCASE(mailingCode)
  @dtw_mUPPERCASE(shipVia)
  @dtw_mUPPERCASE(fobCode)
  @dtw_mUPPERCASE(taxCode)
  @dtw_mUPPERCASE(creditCardType)
  @dtw_mUPPERCASE(creditCardAuth)
  @dtw_mUPPERCASE(store)
  @dtw_mUPPERCASE(userCustAlpha1)
  @dtw_mUPPERCASE(userCustAlpha2)
  @dtw_mUPPERCASE(userCustAlpha3)
  @dtw_mUPPERCASE(userCustAlpha4)
  @dtw_mUPPERCASE(userCustAlpha5)
  @dtw_mUPPERCASE(userAlpha1)
  @dtw_mUPPERCASE(userAlpha2)
  @dtw_mUPPERCASE(userAlpha3)
  @dtw_mUPPERCASE(userAlpha4)
  @dtw_mUPPERCASE(userAlpha5)
  @dtw_mUPPERCASE(userAlpha6)
  @dtw_mUPPERCASE(userAlpha7)
  @dtw_mUPPERCASE(userAlpha8)
  @dtw_mUPPERCASE(userAlpha9)
  @dtw_mUPPERCASE(userAlpha0)
  @dtw_mUPPERCASE(holdCode)

  @dtw_assign(bank,@dtw_rstrip(bank))
  @dtw_assign(location,@dtw_rstrip(location))
  @dtw_assign(reqDate,@dtw_rstrip(reqDate))
  @dtw_assign(orderDate,@dtw_rstrip(orderDate))
  @dtw_assign(discountPercent,@dtw_rstrip(discountPercent))
  @dtw_assign(salesmanNumber,@dtw_rstrip(salesmanNumber))
  @dtw_assign(commissionPercent,@dtw_rstrip(commissionPercent))
  @dtw_assign(splitSalesmanNumber,@dtw_rstrip(splitSalesmanNumber))
  @dtw_assign(splitCommissionPercent,@dtw_rstrip(splitCommissionPercent))
  @dtw_assign(creditCardExpMonth,@dtw_rstrip(creditCardExpMonth))
  @dtw_assign(creditCardExpYear,@dtw_rstrip(creditCardExpYear))
  @dtw_assign(userDate2,@dtw_rstrip(userDate2))
  @dtw_assign(userDate3,@dtw_rstrip(userDate3))
  @dtw_assign(userDate4,@dtw_rstrip(userDate4))
  @dtw_assign(userNumeric1,@dtw_rstrip(userNumeric1))
  @dtw_assign(userNumeric2,@dtw_rstrip(userNumeric2))
  @dtw_assign(userNumeric3,@dtw_rstrip(userNumeric3))
  @dtw_assign(userNumeric4,@dtw_rstrip(userNumeric4))
  @dtw_assign(userNumeric5,@dtw_rstrip(userNumeric5))
  @dtw_assign(contact,@dtw_rstrip(contact))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@octl", orderControlNumber)
  @Concat_Field("@@shto", customerNumber)
  %if (orderType == "R")
      @Concat_Field("@@orry", recurDays)
  %endif
  %if (orderType == "R" || orderType == "X")
      @Concat_Field("@@rsdt", startDate)
      @Concat_Field("@@redt", endDate)
  %endif
  %if (@dtw_rpos("@@040", userHeaderFields) > "0")
      @Concat_Field("@@rqdt", reqDate)
  %endif
  %if (@dtw_rpos("@@360", userHeaderFields) > "0")
      @Concat_Field("@@ordt", orderDate)
  %endif
  %if (@dtw_rpos("@@015", userHeaderFields) > "0" && V_HDCMRL > "0")
      @Concat_Field("@@cont", contact)
  %endif
  %if (@dtw_rpos("@@016", userHeaderFields) > "0")
      @Concat_Field("@@stor", store)
  %endif
  %if (@dtw_rpos("@@020", userHeaderFields) > "0")
      @Concat_Field("@@loc#", location)
  %endif
  %if (@dtw_rpos("@@030", userHeaderFields) > "0")
      @Concat_Field("@@bank", bank)
  %endif
  %if (@dtw_rpos("@@055", userHeaderFields) > "0")
      @Concat_Field("@@attn", attention)
  %endif
  %if (@dtw_rpos("@@050", userHeaderFields) > "0")
      @Concat_Field("@@orrf", referenceNumber)
  %endif
  %if (@dtw_rpos("@@060", userHeaderFields) > "0")
      @Concat_Field("@@ctrm", termsCode)
  %endif
  %if (@dtw_rpos("@@070", userHeaderFields) > "0")
      @Concat_Field("@@boal", allowBackorders)
  %endif
  %if (@dtw_rpos("@@080", userHeaderFields) > "0")
      @Concat_Field("@@dspc", discountPercent)
  %endif
  %if (@dtw_rpos("@@090", userHeaderFields) > "0")
      @Concat_Field("@@svsv", shipVia)
  %endif
  %if (@dtw_rpos("@@095", userHeaderFields) > "0")
      @Concat_Field("@@svac", shipViaAcct)
  %endif
  %if (@dtw_rpos("@@100", userHeaderFields) > "0" && oe_sec_09 == "Y")
      @Concat_Field("@@slsm", salesmanNumber)
  %endif
  %if (@dtw_rpos("@@110", userHeaderFields) > "0" && oe_sec_09 == "Y")
      @Concat_Field("@@smpc", commissionPercent)
  %endif
  %if (@dtw_rpos("@@120", userHeaderFields) > "0" && oe_sec_09 == "Y")
      @Concat_Field("@@sls1", splitSalesmanNumber)
  %endif
  %if (@dtw_rpos("@@130", userHeaderFields) > "0" && oe_sec_09 == "Y")
      @Concat_Field("@@sspc", splitCommissionPercent)
  %endif
  %if (@dtw_rpos("@@140", userHeaderFields) > "0")
      @Concat_Field("@@ctxc", taxCode)
  %endif
  %if (@dtw_rpos("@@150", userHeaderFields) > "0")
      @Concat_Field("@@sttx", stateCode)
      @Concat_Field("@@cntx", countyTaxCode)
      @Concat_Field("@@cttx", cityTaxCode)
      @Concat_Field("@@loc1", loc1Code)
      @Concat_Field("@@loc2", loc2Code)
      @Concat_Field("@@loc3", loc3Code)
  %endif
  %if (@dtw_rpos("@@210", userHeaderFields) > "0")
      @Concat_Field("@@mail", mailingCode)
  %endif
  %if (@dtw_rpos("@@260", userHeaderFields) > "0")
      @Concat_Field("@@fbcd", fobCode)
  %endif
  %if (@dtw_rpos("@@380", userHeaderFields) > "0")
      @Concat_Field("@@uca1", userCustAlpha1)
  %endif
  %if (@dtw_rpos("@@381", userHeaderFields) > "0")
      @Concat_Field("@@uca2", userCustAlpha2)
  %endif
  %if (@dtw_rpos("@@382", userHeaderFields) > "0")
      @Concat_Field("@@uca3", userCustAlpha3)
  %endif
  %if (@dtw_rpos("@@383", userHeaderFields) > "0")
      @Concat_Field("@@uca4", userCustAlpha4)
  %endif
  %if (@dtw_rpos("@@384", userHeaderFields) > "0")
      @Concat_Field("@@uca5", userCustAlpha5)
  %endif
  %if (@dtw_rpos("@@270", userHeaderFields) > "0")
      @Concat_Field("@@dte2", userDate2)
  %endif
  %if (@dtw_rpos("@@280", userHeaderFields) > "0")
      @Concat_Field("@@dte3", userDate3)
  %endif
  %if (@dtw_rpos("@@290", userHeaderFields) > "0")
      @Concat_Field("@@dte4", userDate4)
  %endif
  %if (@dtw_rpos("@@300", userHeaderFields) > "0")
      @Concat_Field("@@udf1", userAlpha1)
  %endif
  %if (@dtw_rpos("@@310", userHeaderFields) > "0")
      @Concat_Field("@@udf2", userAlpha2)
  %endif
  %if (@dtw_rpos("@@320", userHeaderFields) > "0")
      @Concat_Field("@@udf3", userAlpha3)
  %endif
  %if (@dtw_rpos("@@330", userHeaderFields) > "0")
      @Concat_Field("@@udf4", userAlpha4)
  %endif
  %if (@dtw_rpos("@@340", userHeaderFields) > "0")
      @Concat_Field("@@udf5", userAlpha5)
  %endif
  %if (@dtw_rpos("@@341", userHeaderFields) > "0")
      @Concat_Field("@@udf6", userAlpha6)
  %endif
  %if (@dtw_rpos("@@342", userHeaderFields) > "0")
      @Concat_Field("@@udf7", userAlpha7)
  %endif
  %if (@dtw_rpos("@@343", userHeaderFields) > "0")
      @Concat_Field("@@udf8", userAlpha8)
  %endif
  %if (@dtw_rpos("@@344", userHeaderFields) > "0")
      @Concat_Field("@@udf9", userAlpha9)
  %endif
  %if (@dtw_rpos("@@345", userHeaderFields) > "0")
      @Concat_Field("@@udf0", userAlpha0)
  %endif
  %if (@dtw_rpos("@@370", userHeaderFields) > "0")
      @Concat_Field("@@udn1", userNumeric1)
  %endif
  %if (@dtw_rpos("@@371", userHeaderFields) > "0")
      @Concat_Field("@@udn2", userNumeric2)
  %endif
  %if (@dtw_rpos("@@372", userHeaderFields) > "0")
      @Concat_Field("@@udn3", userNumeric3)
  %endif
  %if (@dtw_rpos("@@373", userHeaderFields) > "0")
      @Concat_Field("@@udn4", userNumeric4)
  %endif
  %if (@dtw_rpos("@@374", userHeaderFields) > "0")
      @Concat_Field("@@udn5", userNumeric5)
  %endif
  %if (@dtw_rpos("@@350", userHeaderFields) > "0")
      @Concat_Field("@@hold", holdCode)
  %endif
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, errFound, edtVar, errVar)

  %if (errFound == "")
      @DTW_ASSIGN(updateTotal, "Y")
      @Update_Misc_Charges (profileHandle, dataBaseID, orderControlNumber, freightCharge, specialCharge, updateTotal)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)&amp;confUpdate=Y">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      %if (checkCCL != "Y")
          @dtw_assign(checkCCL, "")
      %endif
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;checkCCL=@dtw_rurlescseq(checkCCL)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}