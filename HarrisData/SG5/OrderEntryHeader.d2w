%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Order Entry - Header Information"
  d2wName                 = "OrderEntryHeader.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
  userHeaderCount         = ""
  userHeaderFields        = ""
  oe_sec_09               = ""
  tabID                   = "HEADER"
  dataType                = "CCNO"
  mode                    = "D"
  firstTime               = ""
  firstHeader             = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@customerName", "@dtw_rurlescseq(customerName)", "1", "a", workURL)
  @dtw_replace(workURL, "@@customerNumber", "@dtw_rurlescseq(customerNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@orderBy", "@dtw_rurlescseq(orderBy)", "1", "a", workURL)
  @dtw_replace(workURL, "@@orderControlNumber", "@dtw_rurlescseq(orderControlNumber)", "1", "a", workURL)
%}

%MACRO_FUNCTION Remove_User_Field (IN CHAR(100) fieldSeq)
{
  @dtw_assign(z, "1")
  %while((@dtw_tb_rgetv(userHeaderTable, z, "1") != "$(fieldSeq)") && (z < userHeaderCount))
      {@dtw_add(z, "1", z)%}
  %if (@dtw_tb_rgetv(userHeaderTable, z, "1") == "$(fieldSeq)")
       @dtw_tb_deleterow(userHeaderTable, z, "1")
       @dtw_subtract(userHeaderCount, "1", userHeaderCount)
  %endif
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "OrderEntryProgOpt.icl"
          %if (firstHeader == "Y")
              @dtw_assign(checkCCL, "Y")
              @dtw_assign(firstHeader, "")
          %endif
          %INCLUDE "OrderEntryRetInfo.icl"
          @RtvFldDesc("H1OCTL=$(orderControlNumber)", "OEHDWK", "H1ORTY", orderType)
          @User_Header_Query(userProfile, H1ORTY, userHeaderTable)
          @dtw_tb_rows(userHeaderTable, userHeaderCount)
          %if (userNumDesc1 == "")
              @Remove_User_Field("370")
          %endif
          %if (userNumDesc2 == "")
              @Remove_User_Field("371")
          %endif
          %if (userNumDesc3 == "")
              @Remove_User_Field("372")
          %endif
          %if (userNumDesc4 == "")
              @Remove_User_Field("373")
          %endif
          %if (userNumDesc5 == "")
              @Remove_User_Field("374")
          %endif
          @dtw_assign(recCnt, "1")
          @dtw_assign(userHeaderFields, "")
          %while(recCnt <= userHeaderCount) {
              @dtw_tb_getv(userHeaderTable, recCnt, "1", V_UMFSEQ)
              %while(@dtw_rlength(V_UMFSEQ) != "3") {@dtw_insert("0", V_UMFSEQ, V_UMFSEQ)%}
              @dtw_concat(userHeaderFields, "@@$(V_UMFSEQ)", userHeaderFields)
              @dtw_add(recCnt, "1", recCnt)
          %}
	   %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "ShowHideSelCriteria.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "OrderEntryConfirm.icl"
              function validate(chgForm) {
                  %if (firstTime != "Y")
                  if (
                      %if (H1ORTY == "X")
                          document.Chg.startDate.value =="" ||
                          document.Chg.startDate.value =="0" ||
                          document.Chg.endDate.value =="" ||
                          document.Chg.endDate.value =="0" ||
                      %endif
                      %if (@dtw_rpos("@@060", userHeaderFields) > "0")
                          document.Chg.termsCode.value =="" ||
                      %endif
                      %if (@dtw_rpos("@@090", userHeaderFields) > "0")
                          document.Chg.shipVia.value =="" ||
                      %endif
                      %if (@dtw_rpos("@@100", userHeaderFields) > "0" && oe_sec_09 == "Y")
                          document.Chg.salesmanNumber.value =="" ||
                      %endif
                      %if (@dtw_rpos("@@140", userHeaderFields) > "0")
                          document.Chg.taxCode.value =="" ||
                      %endif
                      %if (@dtw_rpos("@@260", userHeaderFields) > "0")
                          document.Chg.fobCode.value =="" ||
                      %endif
                      %if (refNbrReq == "Y" && @dtw_rpos("@@050", userHeaderFields) > "0")
                          document.Chg.referenceNumber.value =="" ||
                      %endif
                      %if (storeNbrReq == "Y" && @dtw_rpos("@@016", userHeaderFields) > "0")
                          document.Chg.store.value =="" ||
                      %endif
                      document.Chg.octl.value ==""
                      )
                     {alert("$(reqFieldError)"); return false;}
                  if (
                      editNum(document.Chg.octl, 8, 0)
                      %if (H1ORTY == "X")
                          && editdate(document.Chg.startDate)
                          && editdate(document.Chg.endDate)
                      %endif
                      %if (orderType == "R")
                          && editZero(document.Chg.recurDays, 3, 0)
                          && editdate(document.Chg.startDate)
                          && editdate(document.Chg.endDate)
                      %endif
                      %if (@dtw_rpos("@@040", userHeaderFields) > "0")
                          && editdate(document.Chg.reqDate)
                      %endif
                      %if (@dtw_rpos("@@360", userHeaderFields) > "0")
                          && editdate(document.Chg.orderDate)
                      %endif
                      %if (@dtw_rpos("@@080", userHeaderFields) > "0")
                          && editNum(document.Chg.discountPercent, 3, 4)
                      %endif
                      %if (@dtw_rpos("@@100", userHeaderFields) > "0" && oe_sec_09 == "Y")
                          && editNum(document.Chg.salesmanNumber, 7, 0)
                      %endif
                      %if (@dtw_rpos("@@110", userHeaderFields) > "0" && oe_sec_09 == "Y")
                          && editNum(document.Chg.commissionPercent, 3, 4)
                      %endif
                      %if (@dtw_rpos("@@120", userHeaderFields) > "0" && oe_sec_09 == "Y")
                          && editNum(document.Chg.splitSalesmanNumber, 7, 0)
                      %endif
                      %if (@dtw_rpos("@@130", userHeaderFields) > "0" && oe_sec_09 == "Y")
                          && editNum(document.Chg.splitCommissionPercent, 3, 4)
                      %endif
                      %if (@dtw_rpos("@@270", userHeaderFields) > "0" && userDateDesc1 != "")
                          && editdate(document.Chg.userDate2)
                      %endif
                      %if (@dtw_rpos("@@280", userHeaderFields) > "0" && userDateDesc2 != "")
                          && editdate(document.Chg.userDate3)
                      %endif
                      %if (@dtw_rpos("@@290", userHeaderFields) > "0" && userDateDesc3 != "")
                          && editdate(document.Chg.userDate4)
                      %endif
                      %if (@dtw_rpos("@@370", userHeaderFields) > "0")
                          && editNum(document.Chg.userNumeric1, 8, 5)
                      %endif
                      %if (@dtw_rpos("@@371", userHeaderFields) > "0")
                          && editNum(document.Chg.userNumeric2, 8, 5)
                      %endif
                      %if (@dtw_rpos("@@372", userHeaderFields) > "0")
                          && editNum(document.Chg.userNumeric3, 8, 5)
                      %endif
                      %if (@dtw_rpos("@@373", userHeaderFields) > "0")
                          && editNum(document.Chg.userNumeric4, 8, 5)
                      %endif
                      %if (@dtw_rpos("@@374", userHeaderFields) > "0")
                          && editNum(document.Chg.userNumeric5, 8, 5)
                      %endif
                      )
                      %endif
                      return true;
              }
              %INCLUDE "Menu.js"
              %INCLUDE "NumZero.icl"
              %INCLUDE "numedit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ORDERHEADER")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "Select * From OEHDWK Where H1OCTL=$(orderControlNumber)")
                      %INCLUDE "stmtSQLEnd.icl"
                      @Order_Header_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Order_Header_Query (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(inclRetInfo, "N")
      %INCLUDE "OrderEntryTabs.icl"
      %INCLUDE "RequiredField.icl"
      <div class="quickLinksTop">
          <a href="javascript:check(document.Chg)">$(acceptImageLrg)</a>
          <a href="$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)">$(selectResetImage)</a>
      </div>

      %ROW {

          %if (errFound != "")
              @dtw_assign(focusField, "")
              @EdtVarErr(profileHandle, typeValue, edtVar)
              @ErrVarErr(profileHandle, typeError, errVar)
              @dtw_assign(errDesc, errVar)
              @dtw_pos("}{@@", "$(errDesc)", pos)
              %while(pos > "0") {
                  @dtw_substr(errDesc, @dtw_radd(pos,"2"), "6", errFld)
                  @dtw_assign(fldName, "")
                  %if   (errFld == "@@orrf") @dtw_assign(fldName, "Reference Number")
                  %elif (errFld == "@@svsv") @dtw_assign(fldName, "Ship Via")
                  %elif (errFld == "@@svac") @dtw_assign(fldName, "Ship Via Account")
                  %elif (errFld == "@@hold") @dtw_assign(fldName, "Hold Code")
                  %elif (errFld == "@@cont") @dtw_assign(fldName, "Contact Number")
                  %elif (errFld == "@@stor") @dtw_assign(fldName, "Store")
                  %elif (errFld == "@@loc#") @dtw_assign(fldName, "Location")
                  %elif (errFld == "@@attn") @dtw_assign(fldName, "Attention")
                  %elif (errFld == "@@bank") @dtw_assign(fldName, "Bank")
                  %elif (errFld == "@@ctrm") @dtw_assign(fldName, "Terms Code")
                  %elif (errFld == "@@boal") @dtw_assign(fldName, "Allow Backorders")
                  %elif (errFld == "@@dspc") @dtw_assign(fldName, "Discount Percent")
                  %elif (errFld == "@@slsm") @dtw_assign(fldName, "Salesman")
                  %elif (errFld == "@@smpc") @dtw_assign(fldName, "Commission Percent")
                  %elif (errFld == "@@sls1") @dtw_assign(fldName, "Split Salesman")
                  %elif (errFld == "@@sspc") @dtw_assign(fldName, "Split Commission Percent")
                  %elif (errFld == "@@ctxc") @dtw_assign(fldName, "Tax Code")
                  %elif (errFld == "@@taxd" || errFld == "@@cntx" || errFld == "@@cttx" || errFld == "@@loc1" || errFld == "@@loc2" || errFld == "@@loc3") @dtw_assign(fldName, "Tax Definition")
                  %elif (errFld == "@@mail") @dtw_assign(fldName, "Mailing Code")
                  %elif (errFld == "@@fbcd") @dtw_assign(fldName, "FOB Code")
                  %elif (errFld == "@@uca1") @dtw_assign(fldName, "$(userCustAlpha1)")
                  %elif (errFld == "@@uca2") @dtw_assign(fldName, "$(userCustAlpha2)")
                  %elif (errFld == "@@uca3") @dtw_assign(fldName, "$(userCustAlpha3)")
                  %elif (errFld == "@@uca4") @dtw_assign(fldName, "$(userCustAlpha4)")
                  %elif (errFld == "@@uca5") @dtw_assign(fldName, "$(userCustAlpha5)")
                  %elif (errFld == "@@dte2") @dtw_assign(fldName, "$(userDateDesc1)")
                  %elif (errFld == "@@dte3") @dtw_assign(fldName, "$(userDateDesc2)")
                  %elif (errFld == "@@dte4") @dtw_assign(fldName, "$(userDateDesc3)")
                  %elif (errFld == "@@udf1") @dtw_assign(fldName, "$(userAlphaDesc1)")
                  %elif (errFld == "@@udf2") @dtw_assign(fldName, "$(userAlphaDesc2)")
                  %elif (errFld == "@@udf3") @dtw_assign(fldName, "$(userAlphaDesc3)")
                  %elif (errFld == "@@udf4") @dtw_assign(fldName, "$(userAlphaDesc4)")
                  %elif (errFld == "@@udf5") @dtw_assign(fldName, "$(userAlphaDesc5)")
                  %elif (errFld == "@@udf6") @dtw_assign(fldName, "$(userAlphaDesc6)")
                  %elif (errFld == "@@udf7") @dtw_assign(fldName, "$(userAlphaDesc7)")
                  %elif (errFld == "@@udf8") @dtw_assign(fldName, "$(userAlphaDesc8)")
                  %elif (errFld == "@@udf9") @dtw_assign(fldName, "$(userAlphaDesc9)")
                  %elif (errFld == "@@udf0") @dtw_assign(fldName, "$(userAlphaDesc10)")
                  %elif (errFld == "@@udn1") @dtw_assign(fldName, "$(userNumDesc1)")
                  %elif (errFld == "@@udn2") @dtw_assign(fldName, "$(userNumDesc2)")
                  %elif (errFld == "@@udn3") @dtw_assign(fldName, "$(userNumDesc3)")
                  %elif (errFld == "@@udn4") @dtw_assign(fldName, "$(userNumDesc4)")
                  %elif (errFld == "@@udn5") @dtw_assign(fldName, "$(userNumDesc5)")
                  %endif
                  @DTW_DELSTR(errDesc, pos, "8", errDesc)
                  @DTW_INSERT("<br> $(fldName) -- ", errDesc, @dtw_rsubtract(pos,"1"), errDesc)
                  @dtw_pos("}{@@", "$(errDesc)", pos)
              %}
              @DTW_REPLACE(errDesc, "}{", "", errDesc)
              <a href="javascript:void+0" onMouseOver="showSel('selData')" onMouseOut="hideSel('selData')"><span class="error"> &nbsp; &nbsp; Please correct all errors</span></a>
             <div id="selData" class="searchHover"><table $(quickSearchTable)><tr><td valign="top" class="colalph">$(errDesc)</td></tr></table></div>
          %endif

      <form class="formClass" METHOD=POST name="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintCode=@dtw_rurlescseq(V_H1MNCD)&amp;userHeaderFields=@dtw_rurlescseq(userHeaderFields)&amp;orderType=@dtw_rurlescseq(V_H1ORTY)&amp;oe_sec_09=@dtw_rurlescseq(oe_sec_09)">
          <table $(contentTable)>
              %if (confUpdate == "Y")
                  <tr>
                      <td>&nbsp;</td>
                      <td class="dspalph"><span class="error">Confirm Update Of Header</span></td>
                  </tr>
              %endif

              %if (V_H1ORTY == "R")
                  %if (errFound != "")
                      @DecatErr_Field("@@orry", "recurDays")  @dtw_assign(Err_H1ORRY, fieldValue)
                      @Decat_Field("@@orry")                  @dtw_assign(V_H1ORRY, fieldValue)
                  %endif
                  @SetTextOvr(Err_H1ORRY)
                  <tr><td class="dsphdr"><span $(textOvr)>Recurring Days</span></td>
                      <td class="inputnmbr"><input name="recurDays" type="text" value="$(V_H1ORRY)" size="3" maxlength="3"> $(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_H1ORRY)
              %endif

              %if (V_H1ORTY == "R" || V_H1ORTY == "X")
                  @dtw_assign(reqChar, "")
                  %if (V_H1ORTY == "X") @dtw_assign(reqChar, $(reqFieldChar)) %endif
                  %if (errFound != "")
                      @DecatErr_Field("@@rsdt", "startDate")  @dtw_assign(Err_H1RSDT, fieldValue)
                      @Decat_Field("@@rsdt")                  @dtw_assign(V_H1RSDT, fieldValue)
                  %else
                      @DateInputFromCYMD(V_H1RSDT)
                  %endif
                  @SetTextOvr(Err_H1RSDT)
                  <tr><td class="dsphdr"><span $(textOvr)>Start Date</span></td>
                      <td class="inputalph"><input name="startDate" type="text" value="$(V_H1RSDT)" size="6" maxlength="6">
                          <a href="javascript:calWindow('startDate');"> $(reqChar) $(calendarImage)</a>
                      </td>
                  </tr>
                  @DspErrMsg(Err_H1RSDT)

                  %if (errFound != "")
                      @DecatErr_Field("@@redt", "endDate")  @dtw_assign(Err_H1REDT, fieldValue)
                      @Decat_Field("@@redt")                @dtw_assign(V_H1REDT, fieldValue)
                  %else
                      @DateInputFromCYMD(V_H1REDT)
                  %endif
                  @SetTextOvr(Err_H1REDT)
                  <tr><td class="dsphdr"><span $(textOvr)>Expiration Date</span></td>
                      <td class="inputalph"><input name="endDate" type="text" value="$(V_H1REDT)" size="6" maxlength="6">
                          <a href="javascript:calWindow('endDate');"> $(reqChar) $(calendarImage) </a>
                      </td>
                  </tr>
                  @DspErrMsg(Err_H1REDT)
              %endif

              @dtw_assign(recCnt, "1")
              %while(recCnt <= userHeaderCount) {
                  @dtw_tb_getv(userHeaderTable, recCnt, "1", V_UMFSEQ)
                  %while(@dtw_rlength(V_UMFSEQ) != "3") {@dtw_insert("0", V_UMFSEQ, V_UMFSEQ)%}

                  %if (V_UMFSEQ == "040")
                      %if (errFound != "")
                          @DecatErr_Field("@@rqdt", "reqDate")    @dtw_assign(Err_H1RQDT, fieldValue)
                          @Decat_Field("@@rqdt")                  @dtw_assign(V_H1RQDT, fieldValue)
                      %else
                          @DateInputFromCYMD(V_H1RQDT)
                      %endif
                      @SetTextOvr(Err_H1RQDT)
                      <tr>
                          <td class="dsphdr"><span $(textOvr)>Required Date</span></td>
                          <td class="inputnmbr"><input type="text" name="reqDate" value="$(V_H1RQDT)" size="6" maxlength="6">
                              <a href="javascript:calWindow('reqDate');"> $(reqFieldChar) $(calendarImage) </a>
                          </td>
                      </tr>
                      @DspErrMsg(Err_H1RQDT)

                  %elif (V_UMFSEQ == "360")
                      %if (errFound != "")
                          @DecatErr_Field("@@ordt", "orderDate")  @dtw_assign(Err_H1BDTE, fieldValue)
                          @Decat_Field("@@ordt")                  @dtw_assign(V_H1BDTE, fieldValue)
                      %else
                          @DateInputFromCYMD(V_H1BDTE)
                      %endif
                      @SetTextOvr(Err_H1BDTE)
                      <tr>
                          <td class="dsphdr"><span $(textOvr)>Order Date</span></td>
                          <td class="inputnmbr"><input type="text" name="orderDate" value="$(V_H1BDTE)" size="6" maxlength="6">
                              <a href="javascript:calWindow('orderDate');"> $(reqFieldChar) $(calendarImage) </a>
                          </td>
                      </tr>
                      @DspErrMsg(Err_H1BDTE)

                  %elif (V_UMFSEQ == "050")
                      %if (errFound != "")
                          @DecatErr_Field("@@orrf", "referenceNumber")  @dtw_assign(Err_H1ORRF, fieldValue)
                          @Decat_Field("@@orrf")                        @dtw_assign(V_H1ORRF, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1ORRF)
                      %if (refNbrReq == "Y")
                          @dtw_assign(refReq,  "$(reqFieldChar)")
                      %else
                          @dtw_assign(refReq,  "")
                      %endif
                      <tr>
    	   	           <td class="dsphdr"><span $(textOvr)>Reference Number</span></td>
                          <td class="inputalph"><input type="text" name="referenceNumber" value="$(V_H1ORRF)" size="31" maxlength="22"> $(refReq)</td>
                      </tr>
                      @DspErrMsg(Err_H1ORRF)

                  %elif (V_UMFSEQ == "055")
                      %if (errFound != "")
                          @DecatErr_Field("@@attn", "attention")  @dtw_assign(Err_H1ATTN, fieldValue)
                          @Decat_Field("@@attn")                  @dtw_assign(V_H1ATTN, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1ATTN)
                      <tr>
    	   	           <td class="dsphdr"><span $(textOvr)>Attention</span></td>
                          <td class="inputalph"><input type="text" name="attention" value="$(V_H1ATTN)" size="31" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_H1ATTN)

                  %elif (V_UMFSEQ == "015" && V_HDCMRL > "0")
                      %if (errFound != "")
                          @DecatErr_Field("@@cont", "contact")    @dtw_assign(Err_H1CONT, fieldValue)
                          @Decat_Field("@@cont")                  @dtw_assign(V_H1CONT, fieldValue)
                      %endif
                      @SetTextOvr(Err_H1CONT)
                      <tr>
                          @RtvCustCont(profileHandle, dataBaseID, V_H1CONT, lastName, firstName, salutation, companyName)
                          @Format_EmplName(firstName, lastName, "", "", "", "H", contactName)
    	   	           <td class="dsphdr"><span $(textOvr)>Contact Number</span></td>
                          <td class="inputnmbr"><input name="contact" type="text" value="$(V_H1CONT)" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)CustomerContactSearch.d2w/ENTRY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(H1SHTO)&amp;customerName=@dtw_rurlescseq(shipToName)&amp;docName=Chg&amp;fldName=contact&amp;fldDesc=contactName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="contactName" value="$(contactName)" size="35" type="text" disabled></td>
                      </tr>
                      @DspErrMsg(Err_H1CONT)

                  %elif (V_UMFSEQ == "016")
                      %if (storeNbrReq == "Y")
                          @dtw_assign(storeReq,  "$(reqFieldChar)")
                      %else
                          @dtw_assign(storeReq,  "")
                      %endif
                      %if (errFound != "")
                          @DecatErr_Field("@@stor", "store")      @dtw_assign(Err_H1STOR, fieldValue)
                          @Decat_Field("@@stor")                  @dtw_assign(V_H1STOR, fieldValue)
                      %endif

                      @RtvFldDesc("COSHTO=$(H1SHTO) and COSTOR='$(V_H1STOR)'", "HDCSTR", "CONAME", fieldDesc)
                      @SetTextOvr(Err_H1STOR)
                      <tr><td class="dsphdr"><span $(textOvr)>Store</span></td>
                          <td class="inputalph"><input name="store" type="text" value="$(V_H1STOR)" size="20" maxlength="20"><a href="$(homeURL)$(cGIPath)CustomerStoreSearch.d2w/REPORT$(d2wVarBase)&amp;docName=Chg&amp;fldName=store&amp;fldDesc=storeName" onclick="$(searchWinVar)"> $(storeReq) $(searchImage) </a><input name="storeName" type="text" value="$(fieldDesc)" size="35" disabled></td>
                      </tr>
                      @DspErrMsg(Err_H1STOR)

                  %elif (V_UMFSEQ == "020")
                      %if (errFound != "")
                          @DecatErr_Field("@@loc#", "location")  @dtw_assign(Err_H1LOC#, fieldValue)
                          @Decat_Field("@@loc#")                 @dtw_assign(V_H1LOC#, fieldValue)
                      %endif

                      @RtvFldDesc("LOLOC#=$(V_H1LOC#)", "HDLCTN", "LOLNA1", fieldDesc)
                      @SetTextOvr(Err_H1LOC#)
                      <tr><td class="dsphdr"><span $(textOvr)>Location</span></td>
