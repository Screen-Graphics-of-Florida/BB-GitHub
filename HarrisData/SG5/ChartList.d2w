%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Chart Of Accounts List"
  d2wName                 = "ChartList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;reportSelType=@dtw_rurlescseq(reportSelType)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromAccount, 4, 0) &&
                      editNum(document.Chg.toAccount, 4, 0) &&
                      editNum(document.Chg.fromSubaccount, 4, 0) &&
                      editNum(document.Chg.toSubaccount, 4, 0) &&
                      editFromToAll(document.Chg.fromAccount, document.Chg.toAccount, document.Chg.allAccount, 4) &&
                      editFromToAll(document.Chg.fromSubaccount, document.Chg.toSubaccount, document.Chg.allSubaccount, 4))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CHARTLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromAccount")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)

                                  @DecatErr_Field("@@selc", "longDescription") @dtw_assign(Err_N2SELC,  fieldValue)
                                  @DecatErr_Field("@@actv", "activeAccount")   @dtw_assign(Err_N3ACTV,  fieldValue)
                                  @DecatErr_Field("@@deac", "deactiveAccount") @dtw_assign(Err_N3DEAC,  fieldValue)
                                  @DecatErr_Field("@@fact", "fromAccount")     @dtw_assign(Err_N4FACT,  fieldValue)
                                  @DecatErr_Field("@@tact", "toAccount")       @dtw_assign(Err_N4TACT,  fieldValue)
                                  @DecatErr_Field("@@aact", "allAccount")      @dtw_assign(Err_N4AACT,  fieldValue)
                                  @DecatErr_Field("@@fsub", "fromSubaccount")  @dtw_assign(Err_N4FSUB,  fieldValue)
                                  @DecatErr_Field("@@tsub", "toSubaccount")    @dtw_assign(Err_N4TSUB,  fieldValue)
                                  @DecatErr_Field("@@asub", "allSubaccount")   @dtw_assign(Err_N4ASUB,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}

                                  @Decat_Field("@@selc")   @dtw_assign(V_N2SELC,  fieldValue)
                                  @Decat_Field("@@actv")   @dtw_assign(V_N3ACTV,  fieldValue)
                                  @Decat_Field("@@deac")   @dtw_assign(V_N3DEAC,  fieldValue)
                                  @Decat_Field("@@fact")   @dtw_assign(V_N4FACT,  fieldValue)
                                  @Decat_Field("@@tact")   @dtw_assign(V_N4TACT,  fieldValue)
                                  @Decat_Field("@@aact")   @dtw_assign(V_N4AACT,  fieldValue)
                                  @Decat_Field("@@fsub")   @dtw_assign(V_N4FSUB,  fieldValue)
                                  @Decat_Field("@@tsub")   @dtw_assign(V_N4TSUB,  fieldValue)
                                  @Decat_Field("@@asub")   @dtw_assign(V_N4ASUB,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}

                                  %if (V_N2SELC == "02")
                                      @dtw_assign(noLongDescription, "")
                                      @dtw_assign(yesLongDescription, "CHECKED")
                                  %else
                                      @dtw_assign(noLongDescription, "CHECKED")
                                      @dtw_assign(yesLongDescription, "")
                                  %endif
                                  %if (V_N3ACTV == "1")
                                      @dtw_assign(checkedActiveAccount, "CHECKED")
                                  %else
                                      @dtw_assign(checkedActiveAccount, "")
                                  %endif
                                  %if (V_N3DEAC == "1")
                                      @dtw_assign(checkedDeactiveAccount, "CHECKED")
                                  %else
                                      @dtw_assign(checkedDeactiveAccount, "")
                                  %endif
                                  %if (V_N4AACT == "ALL")
                                      @dtw_assign(checkedAccount, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAccount, "")
                                  %endif
                                  %if (V_N4ASUB == "ALL")
                                      @dtw_assign(checkedSubaccount, "CHECKED")
                                  %else
                                      @dtw_assign(checkedSubaccount, "")
                                  %endif
                              %else
                                  @dtw_assign(noLongDescription, "")
                                  @dtw_assign(yesLongDescription, "CHECKED")
                                  @dtw_assign(checkedActiveAccount, "CHECKED")
                                  @dtw_assign(checkedDeactiveAccount, "CHECKED")
                                  @dtw_assign(checkedAccount, "CHECKED")
                                  @dtw_assign(checkedSubaccount, "CHECKED")
                              %endif

                              @SetTextOvr(Err_N2SELC)
                              <tr><td class="dsphdr"><span $(textOvr)>Include Long Description</span></td>
                                  <td class="inputnmbr"><input name="longDescription" type="radio" VALUE='01' $(noLongDescription)>No</td>
                              </tr>
                              @DspErrMsg(Err_N2SELC)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="longDescription" type="radio" VALUE='02' $(yesLongDescription)>Yes</td>
                              </tr>

                              @SetTextOvr(Err_N3ACTV)
                              <tr><td class="dsphdr"><span $(textOvr)>Select Options</span></td>
                                  <td class="inputnmbr"><input name="activeAccount" type="checkbox" VALUE='1' $(checkedActiveAccount)>Include Active Rows</td>
                              </tr>
                              @DspErrMsg(Err_N3ACTV)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="deactiveAccount" type="checkbox" VALUE='1' $(checkedDeactiveAccount)>Include Deactivated Rows</td>
                              </tr>
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_N4FACT)
                              %if (textOvr == "") @SetTextOvr(Err_N4TACT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N4AACT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Account Number</span></td>
                                  <td class="inputnmbr"><input name="fromAccount" value="$(V_N4FACT)" type="text" size="4" maxlength="4"><a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=fromAccount&amp;subFld=fromSubaccount&amp;descFld=accountDesc" onclick="$(searchWinVar)">$(searchImage) </a> <input name="accountDesc" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toAccount" value="$(V_N4TACT)" type="text" size="4" maxlength="4"><a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=toAccount&amp;subFld=toSubaccount&amp;descFld=accountDesc" onclick="$(searchWinVar)">$(searchImage) </a> <input name="accountDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allAccount" value='ALL' $(checkedAccount) type="checkbox" onClick="if (this.checked) this.form.fromAccount.value='', this.form.toAccount.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N4FACT)
                              @DspErrMsg(Err_N4TACT)
                              @DspErrMsg(Err_N4AACT)

                              @SetTextOvr(Err_N4FSUB)
                              %if (textOvr == "") @SetTextOvr(Err_N4TSUB) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N4ASUB) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Subaccount Number</span></td>
                                  <td class="inputnmbr"><input name="fromSubaccount" value="$(V_N4FSUB)" type="text" size="4" maxlength="4"><a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=fromAccount&amp;subFld=fromSubaccount&amp;descFld=accountDesc" onclick="$(searchWinVar)">$(searchImage) </a> <input name="accountDesc" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toSubaccount" value="$(V_N4TSUB)" type="text" size="4" maxlength="4"><a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=toAccount&amp;subFld=toSubaccount&amp;descFld=accountDesc" onclick="$(searchWinVar)">$(searchImage) </a> <input name="accountDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allSubaccount" value='ALL' $(checkedSubaccount) type="checkbox" onClick="if (this.checked) this.form.fromSubaccount.value='', this.form.toSubaccount.value='';"></td>
                              </tr>  			
                              @DspErrMsg(Err_N4FSUB)
                              @DspErrMsg(Err_N4TSUB)
                              @DspErrMsg(Err_N4ASUB)
                          </table>
                          @dtw_assign(envProgram, "HHDCHL")
                          @dtw_assign(envPrinter, "HHDCHLPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HHDCTS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allAccount)
  @dtw_mUPPERCASE(allSubaccount)

  @dtw_assign(fromAccount,@dtw_rstrip(fromAccount))
  @dtw_assign(toAccount,@dtw_rstrip(toAccount))
  @dtw_assign(fromSubaccount,@dtw_rstrip(fromSubaccount))
  @dtw_assign(toSubaccount,@dtw_rstrip(toSubaccount))

  %if (activeAccount != "1")
      @dtw_assign(activeAccount, "0")
  %endif

  %if (deactiveAccount != "1")
      @dtw_assign(deactiveAccount, "0")
  %endif

  %if (allAccount != "ALL")
      @dtw_assign(allAccount, "")
  %endif

  %if (allSubaccount != "ALL")
      @dtw_assign(allSubaccount, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@sel1", "1")
  @Concat_Field("@@selc", longDescription)
  @Concat_Field("@@actv", activeAccount)
  @Concat_Field("@@deac", deactiveAccount)
  @Concat_Field("@@fact", fromAccount)
  @Concat_Field("@@tact", toAccount)
  @Concat_Field("@@aact", allAccount)
  @Concat_Field("@@fsub", fromSubaccount)
  @Concat_Field("@@tsub", toSubaccount)
  @Concat_Field("@@asub", allSubaccount)
  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}