%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Document Type Maintenance"
  d2wName                 = "DocumentTypeMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromAPID=@dtw_rurlescseq(fromAPID)&amp;fromDocType=@dtw_rurlescseq(fromDocType)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;documentType=@dtw_rurlescseq(documentType)&amp;documentApplication=@dtw_rurlescseq(documentApplication)&amp;description=@dtw_rurlescseq(description)&amp;maintenanceCode=D"
  programName             = "HHDDTM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  editCode1Table          = %table
  editCode2Table          = %table
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.documentType.value =="" ||
                      document.Chg.description.value =="")
                     {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.quantityDecimal, 1, 0) &&
                      editNum(document.Chg.priceDecimal, 1, 0))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "DOCUMENTTYPEMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, " Select * From HDDOCT ", stmtSQL)
                          @dtw_concat(stmtSQL, " Where DODOCT = '$(documentType)'" , stmtSQL)
                          @dtw_concat(stmtSQL, " and DOAPID='$(documentApplication)'", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @DocType_Maintain(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(DTW_SQL) EditCode1_Query (IN  CHAR(64) profileHandle,
                                        char(2)  dataBaseID,
                                        char(10) type,
                                    OUT editCode1Table)
{call $(pgmLibrary)hsyfvp_w
%}				

%FUNCTION(DTW_SQL) EditCode2_Query (IN  CHAR(64) profileHandle,
                                        char(2)  dataBaseID,
                                        char(10) type,
                                    OUT editCode2Table)
{call $(pgmLibrary)hsyfvp_w
%}

%FUNCTION(dtw_sql) DocType_Maintain (IN CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %ROW {
          @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
          %if (backURL == "")
              @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=197")
          %endif
          @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
          %if (V_DORESD == "Y")
              @dtw_assign(sec_03, "N")
          %endif
          %INCLUDE "MaintainTop.icl"
          $(hrTagAttr)
          %INCLUDE "RequiredField.icl"
          %INCLUDE "ErrorDisplay.icl"
    			
          <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
			
              %if (errFound != "" || maintenanceCode == "A")
                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(edtVar, "")
                      @dtw_assign(focusField, "documentType")
                  %else
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@apid", "documentApplication")    @dtw_assign(Err_DOAPID, fieldValue)
                      @DecatErr_Field("@@doct", "documentType")           @dtw_assign(Err_DODOCT, fieldValue)
                      @DecatErr_Field("@@desc", "description")            @dtw_assign(Err_DODESC, fieldValue)
                      @DecatErr_Field("@@pgid", "docProgramName")         @dtw_assign(Err_DOPGID, fieldValue)
                      @DecatErr_Field("@@pseg", "pageSegment")            @dtw_assign(Err_DOPSEG, fieldValue)
                      @DecatErr_Field("@@plod", "printLocationDocument")  @dtw_assign(Err_DOPLOD, fieldValue)
                      @DecatErr_Field("@@ploc", "printLocationFax")       @dtw_assign(Err_DOPLOC, fieldValue)
                      @DecatErr_Field("@@fcpy", "printFileCopy")          @dtw_assign(Err_DOFCPY, fieldValue)
                      @DecatErr_Field("@@satt", "saveAttachment")         @dtw_assign(Err_DOSATT, fieldValue)
                      @DecatErr_Field("@@pbcd", "printBarCodes")          @dtw_assign(Err_DOPBCD, fieldValue)
                      @DecatErr_Field("@@qdec", "quantityDecimal")        @dtw_assign(Err_DOQDEC, fieldValue)
                      @DecatErr_Field("@@qedt", "quantityEdit")           @dtw_assign(Err_DOQEDT, fieldValue)
                      @DecatErr_Field("@@pdec", "priceDecimal")           @dtw_assign(Err_DOPDEC, fieldValue)
                      @DecatErr_Field("@@pedt", "priceEdit")              @dtw_assign(Err_DOPEDT, fieldValue)
                      @DecatErr_Field("@@subj", "emailSubject")           @dtw_assign(Err_DOSUBJ, fieldValue)
                      @DecatErr_Field("@@msgt", "emailMsgText")           @dtw_assign(Err_DOMSGT, fieldValue)
                      @DecatErr_Field("@@bcc@", "emailBCC")               @dtw_assign(Err_DOBCC,  fieldValue)
                      @DecatErr_Field("@@rply", "emailReplyTo")           @dtw_assign(Err_DORPLY, fieldValue)
                      @DecatErr_Field("@@cptl", "titleLine")              @dtw_assign(Err_DOCPTL, fieldValue)
                      @DecatErr_Field("@@cpt1", "toLine1")                @dtw_assign(Err_DOCPT1, fieldValue)
                      @DecatErr_Field("@@cpt2", "toLine2")                @dtw_assign(Err_DOCPT2, fieldValue)
                      @DecatErr_Field("@@cpt3", "toLine3")                @dtw_assign(Err_DOCPT3, fieldValue)
                      @DecatErr_Field("@@cpf1", "fromLine1")              @dtw_assign(Err_DOCPF1, fieldValue)
                      @DecatErr_Field("@@cpf2", "fromLine2")              @dtw_assign(Err_DOCPF2, fieldValue)
                      @DecatErr_Field("@@cpf3", "fromLine3")              @dtw_assign(Err_DOCPF3, fieldValue)
                      @DecatErr_Field("@@cpcl", "commentLine")            @dtw_assign(Err_DOCPCL, fieldValue)
                      @DecatErr_Field("@@aphc", "printHdrCmts")           @dtw_assign(Err_DOAPHC, fieldValue)
                      @DecatErr_Field("@@aptc", "printTrlCmts")           @dtw_assign(Err_DOAPTC, fieldValue)
                  %endif

                  @Decat_Field("@@doct")   @dtw_assign(V_DODOCT, fieldValue)
                  @Decat_Field("@@apid")   @dtw_assign(V_DOAPID, fieldValue)
                  @Decat_Field("@@desc")   @dtw_assign(V_DODESC, fieldValue)
                  @Decat_Field("@@pgid")   @dtw_assign(V_DOPGID, fieldValue)
                  @Decat_Field("@@pseg")   @dtw_assign(V_DOPSEG, fieldValue)
                  @Decat_Field("@@plod")   @dtw_assign(V_DOPLOD, fieldValue)
                  @Decat_Field("@@ploc")   @dtw_assign(V_DOPLOC, fieldValue)
                  @Decat_Field("@@fcpy")   @dtw_assign(V_DOFCPY, fieldValue)
                  @Decat_Field("@@satt")   @dtw_assign(V_DOSATT, fieldValue)
                  @Decat_Field("@@pbcd")   @dtw_assign(V_DOPBCD, fieldValue)
                  @Decat_Field("@@qdec")   @dtw_assign(V_DOQDEC, fieldValue)
                  @Decat_Field("@@qedt")   @dtw_assign(V_DOQEDT, fieldValue)
                  @Decat_Field("@@pdec")   @dtw_assign(V_DOPDEC, fieldValue)
                  @Decat_Field("@@pedt")   @dtw_assign(V_DOPEDT, fieldValue)
                  @Decat_Field("@@subj")   @dtw_assign(V_DOSUBJ, fieldValue)
                  @Decat_Field("@@msgt")   @dtw_assign(V_DOMSGT, fieldValue)
                  @Decat_Field("@@bcc@")   @dtw_assign(V_DOBCC,  fieldValue)
                  @Decat_Field("@@rply")   @dtw_assign(V_DORPLY, fieldValue)
                  @Decat_Field("@@cptl")   @dtw_assign(V_DOCPTL, fieldValue)
                  @Decat_Field("@@cpt1")   @dtw_assign(V_DOCPT1, fieldValue)
                  @Decat_Field("@@cpt2")   @dtw_assign(V_DOCPT2, fieldValue)
                  @Decat_Field("@@cpt3")   @dtw_assign(V_DOCPT3, fieldValue)
                  @Decat_Field("@@cpf1")   @dtw_assign(V_DOCPF1, fieldValue)
                  @Decat_Field("@@cpf2")   @dtw_assign(V_DOCPF2, fieldValue)
                  @Decat_Field("@@cpf3")   @dtw_assign(V_DOCPF3, fieldValue)
                  @Decat_Field("@@cpcl")   @dtw_assign(V_DOCPCL, fieldValue)
                  @Decat_Field("@@aphc")   @dtw_assign(V_DOAPHC, fieldValue)
                  @Decat_Field("@@aptc")   @dtw_assign(V_DOAPTC, fieldValue)

                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(V_DOPLOD, "N")
                      @dtw_assign(V_DOPLOC, "N")
                      @dtw_assign(V_DOFCPY, "N")
                      @dtw_assign(V_DOSATT, "N")
                      @dtw_assign(V_DOPBCD, "N")
                      @dtw_assign(V_DOQDEC, "2")
                      @dtw_assign(V_DOQEDT, "L")
                      @dtw_assign(V_DOPDEC, "2")
                      @dtw_assign(V_DOPEDT, "L")
                      @dtw_assign(focusField, "documentApplication")
                  %endif

                  @dtw_assign(errFound, "")

              %elif (maintenanceCode == "Z")
                  @dtw_assign(V_DODOCT, "")
                     @dtw_assign(focusField, "documentApplication")
              %else
                  @dtw_assign(focusField, "description")
              %endif

              <table $(contentTable)>
                  @RtvFldDesc("AIAPID='$(V_DOAPID)'", "SYAPID", "AIAPDS", apidDesc)
                  @SetTextOvr(Err_DOAPID)
                  <tr><td class="dsphdr"><span $(textOvr)>Application ID</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="documentApplication" type="text" value="$(V_DOAPID)" size="3" maxlength="2"><a href="$(homeURL)$(cGIPath)ApplicationIDSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=documentApplication&amp;fldDesc=documentApplicationDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="documentApplicationDesc" value="$(apidDesc)" type="text" size="35" disabled></td>
                      %else
                          @Format_Code(V_DOAPID, F_DOAPID)
                          <td class="inputalph"><input name="documentApplication" type="hidden" value="$(V_DOAPID)">$(apidDesc) &nbsp; $(F_DOAPID)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_DOAPID)

                  @SetTextOvr(Err_DODOCT)
                  <tr><td class="dsphdr"><span $(textOvr)>Document Type</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="documentType" type="text"  value="$(V_DODOCT)" size="3" maxlength="3"> $(reqFieldChar)</td>
                      %else
                          <td class="inputalph"><input name="documentType" type="hidden" value="$(V_DODOCT)">$(V_DODOCT)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_DODOCT)

                  @SetTextOvr(Err_DODESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="description" type="text" value="$(V_DODESC)" size="30" maxlength="30"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_DODESC)
    			
                  @SetTextOvr(Err_DOPGID)
                  <tr><td class="dsphdr"><span $(textOvr)>Program Name</span></td>
                      <td class="inputalph"><input name="docProgramName" type="text" value="$(V_DOPGID)" size="10" maxlength="10"></td>
                  </tr>
                  @DspErrMsg(Err_DOPGID)
    			
                  @SetTextOvr(Err_DOPSEG)
                  <tr><td class="dsphdr"><span $(textOvr)>Page Segment Name</span></td>
                      <td class="inputalph"><input type="text" name="pageSegment" value="$(V_DOPSEG)" size="10" maxlength="8"></td>
                  </tr>
                  @DspErrMsg(Err_DOPSEG)
    		
	           @Field_Checked(V_DOPLOD, "Y", printLocationDocumentChecked)
                  @SetTextOvr(Err_DOPLOD)
                  <tr><td class="dsphdr"><span $(textOvr)>Print Location On Document</span></td>
                      <td><input type="checkbox" name="printLocationDocument" value="Y" $(printLocationDocumentChecked)>
                  </tr>
                  @DspErrMsg(Err_DOPLOD)
               			
	           @Field_Checked(V_DOPLOC, "Y", printLocationFaxChecked)
                  @SetTextOvr(Err_DOPLOC)
                  <tr><td class="dsphdr"><span $(textOvr)>Print Location On Faxed Document</span></td>
                      <td><input type="checkbox" name="printLocationFax" value="Y" $(printLocationFaxChecked)>
                  </tr>
                  @DspErrMsg(Err_DOPLOC)
               			
	           @Field_Checked(V_DOFCPY, "Y", printFileCopyChecked)
                  @SetTextOvr(Err_DOFCPY)
                  <tr><td class="dsphdr"><span $(textOvr)>Print Hard Copy</span></td>
                      <td><input type="checkbox" name="printFileCopy" value="Y" $(printFileCopyChecked)>
                  </tr>
                  @DspErrMsg(Err_DOFCPY)
               			
	           @Field_Checked(V_DOSATT, "Y", saveAttachmentChecked)
                  @SetTextOvr(Err_DOSATT)
                  <tr><td class="dsphdr"><span $(textOvr)>Save Copy as Attachment</span></td>
                      <td><input type="checkbox" name="saveAttachment" value="Y" $(saveAttachmentChecked)>
                  </tr>
                  @DspErrMsg(Err_DOSATT)
               			
	           @Field_Checked(V_DOPBCD, "Y", printBarCodesChecked)
                  @SetTextOvr(Err_DOPBCD)
                  <tr><td class="dsphdr"><span $(textOvr)>Print Bar Codes</span></td>
                      <td><input type="checkbox" name="printBarCodes" value="Y" $(printBarCodesChecked)>
                  </tr>
                  @DspErrMsg(Err_DOPBCD)
               			
	           @Field_Checked(V_DOAPHC, "Y", printHdrCmtsChecked)
                  @SetTextOvr(Err_DOAPHC)
                  <tr><td class="dsphdr"><span $(textOvr)>Always Print Header Comments</span></td>
                      <td><input type="checkbox" name="printHdrCmts" value="Y" $(printHdrCmtsChecked)>
                  </tr>
                  @DspErrMsg(Err_DOAPHC)
               			
	           @Field_Checked(V_DOAPTC, "Y", printTrlCmtsChecked)
                  @SetTextOvr(Err_DOAPTC)
                  <tr><td class="dsphdr"><span $(textOvr)>Always Print Trailer Comments</span></td>
                      <td><input type="checkbox" name="printTrlCmts" value="Y" $(printTrlCmtsChecked)>
                  </tr>
                  @DspErrMsg(Err_DOAPTC)
              </table>
			
              <fieldset class="legendBody">
                  <legend class="legendTitle">Print Editing</legend>
                  <table $(contentTable)>
                      <tr><td>&nbsp;</td>
                          <td class="colhdr">Number Of<br>Decimals</td>
                          <td class="colhdr">Edit Code</td>
                      </tr>
    	      		
                      @SetTextOvr(Err_DOQDEC)
                      <tr><td class="dsphdr"><span $(textOvr)>Quantity</span></td>
                          <td class="inputnmbr"><input type="text" name="quantityDecimal" value="$(V_DOQDEC)" size="1" maxlength="1"></td>
                          @dtw_tb_rows(editCode1Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(editCode1Table, x, "1") != V_DOQEDT) && (x < maxRows))
                              {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(editCode1Table, "quantityEdit", "2", "1", "N", "", x, "1")</td>
                      </tr>
                      @DspErrMsg(Err_DOQDEC)
    	   		
                      @SetTextOvr(Err_DOPDEC)
                      <tr><td class="dsphdr"><span $(textOvr)>Price/Cost</span></td>
                          <td class="inputnmbr"><input type="text" name="priceDecimal" value="$(V_DOPDEC)" size="1" maxlength="1"></td>
                          @dtw_tb_rows(editCode2Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(editCode2Table, x, "1") != V_DOPEDT) && (x < maxRows))
                              {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(editCode2Table, "priceEdit", "2", "1", "N", "", x, "1")</td>
                      </tr>
                      @DspErrMsg(Err_DOPDEC)
                  </table>       			
              </fieldset>

              <fieldset class="legendBody">
                  <legend class="legendTitle">E-mail</legend>
  	           <table $(contentTable)>
	   		
                      @SetTextOvr(Err_DOSUBJ)
                      <tr><td class="dsphdr"><span $(textOvr)>Subject</span></td>
                          <td class="inputalph"><input name="emailSubject" type="text" value="$(V_DOSUBJ)" size="100" maxlength="100"></td>
                      </tr>
                      @DspErrMsg(Err_DOSUBJ)
    	   		
                      @SetTextOvr(Err_DOMSGT)
                      <tr><td class="dsphdr"><span $(textOvr)>Message Text</span></td>
                          <td class="inputalph"><input name="emailMsgText" type="text" value="$(V_DOMSGT)" size="100" maxlength="250"></td>
                      </tr>
                      @DspErrMsg(Err_DOMSGT)
    	   		
                      @SetTextOvr(Err_DOBCC)
                      <tr><td class="dsphdr"><span $(textOvr)>BCC</span></td>
                          <td class="inputalph"><input name="emailBCC" type="text" value="$(V_DOBCC)" size="100" maxlength="100"></td>
                      </tr>
                      @DspErrMsg(Err_DOBCC)
    	   		
                      @SetTextOvr(Err_DORPLY)
                      <tr><td class="dsphdr"><span $(textOvr)>Reply To</span></td>
                          <td class="inputalph"><input name="emailReplyTo" type="text" value="$(V_DORPLY)" size="100" maxlength="100"></td>
                      </tr>
                      @DspErrMsg(Err_DORPLY)
                 </table>
              </fieldset>

              <fieldset class="legendBody">
                  <legend class="legendTitle">Fax Cover Page</legend>
  	           <table $(contentTable)>
	   		
                      @SetTextOvr(Err_DOCPTL)
                      <tr><td class="dsphdr"><span $(textOvr)>Title Line</span></td>
                          <td class="inputalph"><input name="titleLine" type="text" value="$(V_DOCPTL)" size="40" maxlength="40"></td>
                      </tr>
                      @DspErrMsg(Err_DOCPTL)
    	   		
                      @SetTextOvr(Err_DOCPT1)
                      <tr><td class="dsphdr"><span $(textOvr)>To Line 1</span></td>
                          <td class="inputalph"><input name="toLine1" type="text" value="$(V_DOCPT1)" size="40" maxlength="40"></td>
                      </tr>
                      @DspErrMsg(Err_DOCPT1)
    	   		
                      @SetTextOvr(Err_DOCPT2)
                      <tr><td class="dsphdr"><span $(textOvr)>To Line 2</span></td>
                          <td class="inputalph"><input name="toLine2" type="text" value="$(V_DOCPT2)" size="40" maxlength="40"></td>
                      </tr>
                      @DspErrMsg(Err_DOCPT2)
    	   		
                      @SetTextOvr(Err_DOCPT3)
                      <tr><td class="dsphdr"><span $(textOvr)>To Line 3</span></td>
                          <td class="inputalph"><input name="toLine3" type="text" value="$(V_DOCPT3)" size="40" maxlength="40"></td>
                      </tr>
                      @DspErrMsg(Err_DOCPT3)
    	   		
                      @SetTextOvr(Err_DOCPF1)
                      <tr><td class="dsphdr"><span $(textOvr)>From Line 1</span></td>
                          <td class="inputalph"><input name="fromLine1" type="text" value="$(V_DOCPF1)" size="40" maxlength="40"></td>
                      </tr>
                      @DspErrMsg(Err_DOCPF1)
    	   		
                      @SetTextOvr(Err_DOCPF2)
                      <tr><td class="dsphdr"><span $(textOvr)>From Line 2</span></td>
                          <td class="inputalph"><input name="fromLine2" type="text" value="$(V_DOCPF2)" size="40" maxlength="40"></td>
                      </tr>
                      @DspErrMsg(Err_DOCPF2)
    	   		
                      @SetTextOvr(Err_DOCPF3)
                      <tr><td class="dsphdr"><span $(textOvr)>From Line 3</span></td>
                          <td class="inputalph"><input name="fromLine3" type="text" value="$(V_DOCPF3)" size="40" maxlength="40"></td>
                      </tr>
                      @DspErrMsg(Err_DOCPF3)
    	   		
                      @SetTextOvr(Err_DOCPCL)
                      <tr><td class="dsphdr"><span $(textOvr)>Comment Line</span></td>
                          <td class="inputalph"><input name="commentLine" type="text" value="$(V_DOCPCL)" size="40" maxlength="40"></td>
                      </tr>
                      @DspErrMsg(Err_DOCPCL)
                 </table>
              </fieldset>
          %}
	
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64) profileHandle,
                                        INOUT CHAR(2) dataBaseID,
                                        INOUT CHAR(1) maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDDTM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @EditCode1_Query(profileHandle, dataBaseID, "EDITCODE  ", editCode1Table)
      @EditCode2_Query(profileHandle, dataBaseID, "EDITCODE  ", editCode2Table)
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(documentApplication)
  @dtw_mUPPERCASE(documentType)
  @dtw_mUPPERCASE(docProgramName)
  @dtw_mUPPERCASE(pageSegment)

  @dtw_assign(quantityDecimal,@dtw_rstrip(quantityDecimal))
  @dtw_assign(priceDecimal,@dtw_rstrip(priceDecimal))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  %if (printLocationDocument != "Y") @dtw_assign(printLocationDocument, "N") %endif
  %if (printLocationFax != "Y")      @dtw_assign(printLocationFax, "N") %endif
  %if (printFileCopy != "Y")         @dtw_assign(printFileCopy, "N") %endif
  %if (saveAttachment != "Y")        @dtw_assign(saveAttachment, "") %endif
  %if (printBarCodes != "Y")         @dtw_assign(printBarCodes, "N") %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@fapl", fromAPID)
  @Concat_Field("@@fdoc", fromDocType)
  @Concat_Field("@@doct", documentType)
  @Concat_Field("@@apid", documentApplication)
  @Concat_Field("@@desc", description)
  @Concat_Field("@@pgid", docProgramName)
  @Concat_Field("@@pseg", pageSegment)
  @Concat_Field("@@plod", printLocationDocument)
  @Concat_Field("@@ploc", printLocationFax)
  @Concat_Field("@@fcpy", printFileCopy)
  @Concat_Field("@@pbcd", printBarCodes)
  @Concat_Field("@@qdec", quantityDecimal)
  @Concat_Field("@@qedt", quantityEdit)
  @Concat_Field("@@pdec", priceDecimal)
  @Concat_Field("@@pedt", priceEdit)
  @Concat_Field("@@cptl", titleLine)
  @Concat_Field("@@cpt1", toLine1)
  @Concat_Field("@@cpt2", toLine2)
  @Concat_Field("@@cpt3", toLine3)
  @Concat_Field("@@cpf1", fromLine1)
  @Concat_Field("@@cpf2", fromLine2)
  @Concat_Field("@@cpf3", fromLine3)
  @Concat_Field("@@cpcl", commentLine)
  @Concat_Field("@@satt", saveAttachment)
  @Concat_Field("@@subj", emailSubject)
  @Concat_Field("@@msgt", emailMsgText)
  @Concat_Field("@@bcc@", emailBCC)
  @Concat_Field("@@rply", emailReplyTo)
  @Concat_Field("@@aphc", printHdrCmts)
  @Concat_Field("@@aptc", printTrlCmts)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          %if (documentApplication != "")
              @RtvFldDesc("AIAPID='$(documentApplication)'", "SYAPID", "AIAPDS", apidDesc)
              @Format_ConfMsg_Desc(maintenanceCode, $(description), $(documentType), "For $(apidDesc)", "$(documentApplication)", "", "", confMessage)
          %else
              @Format_ConfMsg_Desc(maintenanceCode, $(description), $(documentType), "", "", "", "", confMessage)
          %endif
      %else
          @DecatErr_Field("@@doct", "documentType")
          @Format_ConfMsg_Desc("", $(description), $(documentType), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=197&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;documentType=@dtw_rurlescseq(documentType)&amp;documentApplication=@dtw_rurlescseq(documentApplication)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
