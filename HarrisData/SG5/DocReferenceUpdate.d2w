%INCLUDE "$(baseVar)"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"

%Define {	
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  START_ROW_NUM           = "1"
  doubleQuote             = """"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  <html>
      <head>
      </head>
      <body $(bodyTagAttr)>
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " PIPRD2W ", fileSQL)
                      @dtw_concat(selectSQL, " PWTYPE IN ('D','P')", selectSQL)
                      @dtw_concat(selectSQL, " and PWD2WMU Not LIKE 'PROGSECURITYUSAGEUPDATE%'", selectSQL)
                      @dtw_concat(selectSQL, " and PWD2WMU Not LIKE 'DOCREFERENCEUPDATE%'", selectSQL)
                      @dtw_concat(selectSQL, " and PWRLS<>'O'", selectSQL)
                      @dtw_concat(selectSQL, " and not exists (Select * From SYDOCR Where PWD2WMU=DRPGNMU)", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By PWD2WMU ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Doc_Ref_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Doc_Ref_Query (IN CHAR(64)    profileHandle,
                                     CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
          <table $(baseTable)>
              %ROW{
                  @dtw_assign(progName, "")
                  @dtw_assign(progNameDesc, "")
                  @dtw_assign(progName, "$(V_PWD2WM)")
                  @dtwf_readfile(V_PWD2WM, text)
                  %if (text == "")
                      <tr><td>$(V_PWD2WM)</td></tr>
                  %else
                      @dtw_assign(progPos, @dtw_rpos("page_title", text))
                      %if (progPos > "0")
                          @dtw_assign(x, "1")
                          %while(x < "50") {
                              %if (@dtw_rsubstr(text, progPos, "1") == doubleQuote)
                                  @dtw_add(progPos, "1", progPos)
                                  @dtw_assign(quotePos, @dtw_rpos(doubleQuote, text, progPos))
                                  @dtw_assign(progNameDesc, @dtw_rsubstr(text, progPos, @dtw_rsubtract(quotePos, progPos)))
                                  @dtw_assign(x, "99")
                              %else
                                  @dtw_add(x, "1", x)
                                  @dtw_add(progPos, "1", progPos)
                              %endif
                          %}
                      %endif

                      @dtw_assign(maintenanceCode, "U")
                      @dtw_assign(edtVar, "")
                      @Concat_Field("@@pgnm", progName)
                      @Concat_Field("@@desc", progNameDesc)
                      @dtw_concat(edtVar, "}{", edtVar)

                      @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)
                  %endif
              %}
          </table>
      %}
  %}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                              CHAR(2)     dataBaseID,
                                              CHAR(1)     maintenanceCode,
                                              CHAR(1)     errFound,
                                              CHAR(32000) edtVar,                             	
                                              CHAR(32000) errVar)
{%EXEC {HSYDOC_W.PGM %}
%}

%HTML(UPDATE) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}
