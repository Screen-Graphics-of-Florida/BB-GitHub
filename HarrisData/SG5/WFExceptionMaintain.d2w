%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Validation Exception Maintenance"
  d2wName                 = "WFExceptionMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfProcess=@dtw_rurlescseq(wfProcess)&amp;fromVldProgram=@dtw_rurlescseq(fromVldProgram)&amp;fromValidationId=@dtw_rurlescseq(fromValidationId)&amp;fromRole=@dtw_rurlescseq(fromRole)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;updRecNbr=@dtw_rurlescseq(updRecNbr)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;vldProgram=@dtw_rurlescseq(vldProgram)&amp;validationId=@dtw_rurlescseq(validationId)&amp;role=@dtw_rurlescseq(role)&amp;maintenanceCode=D"
  programName             = "HWFVEM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function confirmDelete() {return confirm("$(delRecordConf)")}
              function validate(chgForm) {
                  if (document.Chg.vldProgram.value =="" ||
                      document.Chg.validationId.value =="")
                         {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.validationId, 15, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFEXCEPTIONMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select *  ", stmtSQL)
                          @dtw_concat(fileSQL, "WFPRVE ", fileSQL)
                          @dtw_concat(selectSQL, " VEPROC='$(wfProcess)' and VEVPGM='$(vldProgram)' and VEVLID=$(validationId) and VEROLE='$(role)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"

      <table $(contentTable)>
          @RtvFldDesc("PRPROC='$(wfProcess)'", "WFPRHD", "PRDESC", wfProcessDescription)
          @Format_Header("", $(wfProcessDescription), $(wfProcess))
      </table>

      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "vldProgram")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@vpgm", "vldProgram")            @dtw_assign(Err_VEVPGM, fieldValue)
                          @DecatErr_Field("@@vlid", "validationId")          @dtw_assign(Err_VEVLID, fieldValue)
                          @DecatErr_Field("@@role", "role")                  @dtw_assign(Err_VEROLE, fieldValue)
                          @DecatErr_Field("@@byps", "byPassValidation")      @dtw_assign(Err_VEBYPS, fieldValue)
                      %endif

                      @Decat_Field("@@vpgm")   @dtw_assign(V_VEVPGM, fieldValue)
                      @Decat_Field("@@vlid")   @dtw_assign(V_VEVLID, fieldValue)
                      @Decat_Field("@@role")   @dtw_assign(V_VEROLE, fieldValue)
                      @Decat_Field("@@byps")   @dtw_assign(V_VEBYPS, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "vldProgram")
                          @dtw_assign(V_VEVLID, "0")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "vldProgram")
                  %else
                      @dtw_assign(focusField, "byPassValidation")
                  %endif

                  @SetTextOvr(Err_VEVPGM)
                  @RtvFldDesc("VPVPGM='$(V_VEVPGM)' ", "WFVLPG", "VPDESC", fieldDesc)
                  <tr><td class="dsphdr"><span $(textOvr)>Validation Program</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input type="text" name="vldProgram" value="$(V_VEVPGM)" size="15" maxlength="10">
                                                <a href="$(homeURL)$(cGIPath)WFValidationProgramSearch.d2w/REPORT$(genericVarBase)&amp;specificWFProcess=@dtw_rurlescseq(wfProcess)&amp;docName=Chg&amp;fldName=vldProgram&amp;fldDesc=vldProgramName" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage)</a>
                                                <input type="text" disabled name="vldProgramName" value="$(fieldDesc)" size="30"></td>
                      %else
                          <td class="inputnmbr"><input type="hidden" name="vldProgram" value="$(V_VEVPGM)">$(V_VEVPGM) $(fieldDesc)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_VEVPGM)

                  @SetTextOvr(Err_VEVLID)
                  @RtvFldDesc("VIVPGM='$(V_VEVPGM)' and VIVLID=$(V_VEVLID)", "WFVLID", "VIDESC", fieldDesc)
                  <tr><td class="dsphdr"><span $(textOvr)>Validation ID</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input type="text" name="validationId" value="$(V_VEVLID)" size="15" maxlength="15">
                                                <a href="$(homeURL)$(cGIPath)WFValidationIdSearch.d2w/REPORT$(genericVarBase)&amp;specificWFProcess=@dtw_rurlescseq(wfProcess)&amp;docName=Chg&amp;fldVldProgram=vldProgram&amp;fldVldId=validationId&amp;fldDesc=validationIdDesc" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage)</a>
                                                <input type="text" disabled name="validationIdDesc" value="$(fieldDesc)" size="30"></td>
                      %else
                          <td class="inputnmbr"><input type="hidden" name="validationId" value="$(V_VEVLID)">$(V_VEVLID) $(fieldDesc)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_VEVLID)

                  @RtvFldDesc("RMROLE='$(V_VEROLE)'", "SYROLM", "RMDESC", fieldDesc)
                  @SetTextOvr(Err_VEROLE)
                  <tr><td class="dsphdr"><span $(textOvr)>Role</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input type="text" name="role" value="$(V_VEROLE)" size="15" maxlength="10">
                                                <a href="$(homeURL)$(phpPath)RoleSearch.php$(altVarBase)&amp;docName=Chg&amp;roleFld=role&amp;descFld=roleDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                <input type="text" disabled name="roleDesc" value="$(fieldDesc)" size="30"></td>
                      %else
                          <td class="inputalph"><input type="hidden" name="role" value="$(V_VEROLE)">$(V_VEROLE) $(fieldDesc)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_VEROLE)
               			
                  @RtvFldDesc("FLTYPE='WFBYPASSVL' and FLVALU='$(V_VEBYPS)'", "SYFLAG", "FLDESC", fieldDesc)
                  @SetTextOvr(Err_VEBYPS)
                  <tr><td class="dsphdr"><span $(textOvr)>Bypass Validation</span></td>
                      <td class="inputalph"><input type="text" name="byPassValidation" value="$(V_VEBYPS)" size="15" maxlength="1">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=WFBYPASSVL&amp;flagSrchHdr=@dtw_rurlescseq("Bypass Validation")&amp;docName=Chg&amp;fldName=byPassValidation&amp;fldDesc=byPassValidationDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                            <input type="text" disabled name="byPassValidationDesc" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_VEBYPS)
             %}
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HWFVEM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @dtw_mUPPERCASE(vldProgram)
  @dtw_mUPPERCASE(role)
  @dtw_mUPPERCASE(byPassValidation)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@frm1", fromVldProgramd)
  @Concat_Field("@@frm2", fromValidationId)
  @Concat_Field("@@frm3", fromRole)
  @Concat_Field("@@proc", wfProcess)
  @Concat_Field("@@vpgm", vldProgram)
  @Concat_Field("@@vlid", validationId)
  @Concat_Field("@@role", role)
  @Concat_Field("@@byps", byPassValidation)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  @RtvFldDesc("VIVPGM='$(vldProgram)' and VIVLID=$(validationId) ", "WFVLID", "VIDESC", validationDescription)
  @RtvFldDesc("RMROLE='$(role)' ", "SYROLM", "RMDESC", roleDescription)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, "$(validationDescription)-$(roleDescription)", $(validationId), "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)WFException.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@vlid", "validationId")
      @Format_ConfMsg_Desc("", "$(validationDescription)-$(roleDescription)", $(validationId), "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)WFException.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;validationId=@dtw_rurlescseq(validationId)&amp;role=@dtw_rurlescseq(role)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
