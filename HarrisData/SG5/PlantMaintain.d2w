                      </tr>
                      <tr><td class="dsphdr"><span $(textOvr)>Default Work Center</span></td>
                          <td class="inputalph"><input name="dfltWC" type="text" value="$(V_PEDWC)" size="5" maxlength="5"></td>
                      </tr>
                      @DspErrMsg(Err_PEDDPT)
                  </table>
              </fieldset>

              %if (V_HDSCRL>"0")		
              <a name="costManagement"></a>
