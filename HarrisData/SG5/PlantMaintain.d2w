                              <td class="inputnmbr"><input type="text"  name="currentFiscalPeriod" value="$(V_PLFCM)" size="4" maxlength="4"> $(reqFieldChar)
                              		<a href="$(homeURL)$(phpPath)PeriodSearch.php$(altVarBase)&amp;docName=Chg&amp;periodFld=currentFiscalPeriod" onclick="$(searchWinVar)"> $(searchImage) </a></td> 		
                          </tr>
                          @DspErrMsg(Err_PLFCM)

