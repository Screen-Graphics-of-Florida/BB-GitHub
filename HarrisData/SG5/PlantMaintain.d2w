                              <td class="inputnmbr"><input type="text" name="percentPercentTwo" value="$(V_PLPCA2)" size="7" maxlength="7"></td>
                          </tr>
                          @DspErrMsg(Err_PLPCT2)
                          @DspErrMsg(Err_PLPCA2)

                          @SetTextOvr(Err_PLPCT3)
                          %if (textOvr == "")
                              @SetTextOvr(Err_PLPCA3)
                          %endif
                          <tr><td class="dsphdr"><span $(textOvr)>Percent Three</span></td>
                              <td class="inputalph"><input type="text" name="descriptionPercentThree" value="$(V_PLPCT3)" size="10" maxlength="10"></td>
                              <td class="inputnmbr"><input type="text" name="percentPercentThree" value="$(V_PLPCA3)" size="7" maxlength="7"></td>
