                          <td class="inputnmbr"><input type="text" name="defaultRtgSeq" value="$(V_PLRSEQ)" size="3" maxlength="3"></td>
                      </tr>
                      @DspErrMsg(Err_PLRSEQ)
	   		        		
                      @SetTextOvr(Err_PLRSF)
                      <tr><td class="dsphdr"><span $(textOvr)>Product Structure Interfaces With Routing Table</span></td>
                          @dtw_tb_rows(yn01Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_PLRSF) && (x < maxRows))
                                {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(yn01Table, "prodStrInterToRouting", "2", "1", "N", "", x, "1")</td>
                      </tr>
                      @DspErrMsg(Err_PLRSF)
                  </table>
              </fieldset>

              <a name="defaultRouting"></a>
