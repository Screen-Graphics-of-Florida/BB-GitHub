                              <td class="inputnmbr"><input type="text" name="weeksWeeklyPeriod" value="$(V_PL#WWD)" size="2" maxlength="2"></td>
                          </tr>
                          @DspErrMsg(Err_PL#WWD)

                          @SetTextOvr(Err_PLSHR)
                          <tr><td class="dsphdr"><span $(textOvr)>Standard Hours/Day</span></td>
                              <td class="inputnmbr"><input type="text" name="standardHoursDay" value="$(V_PLSHR)" size="7" maxlength="7"> $(reqFieldChar) </td>
                          </tr>
                          @DspErrMsg(Err_PLSHR)

                          @SetTextOvr(Err_PLPL)
                          <tr><td class="dsphdr"><span $(textOvr)>Period Length In Days</span></td>
                              <td class="inputnmbr"><input type="text" name="periodLengthDays" value="$(V_PLPL)" size="2" maxlength="2"> $(reqFieldChar) </td>
                          </tr>
                          @DspErrMsg(Err_PLPL)

                          @SetTextOvr(Err_PLNTP)
                          <tr><td class="dsphdr"><span $(textOvr)>Fixed Time Periods Weeks</span></td>
                              <td class="inputnmbr"><input type="text" name="fixedTimePeriodWeeks" value="$(V_PLNTP)" size="2" maxlength="2"> $(reqFieldChar) </td>
                          </tr>
                          @DspErrMsg(Err_PLNTP)

                          @SetTextOvr(Err_PLSSS)
                          <tr><td class="dsphdr"><span $(textOvr)>Include Safety Stock</span></td>
                              @dtw_tb_rows(yn02Table, maxRows)
                              @dtw_assign(x, "1")
                              %while((@dtw_tb_rgetv(yn02Table, x, "1") != V_PLSSS) && (x < maxRows))
                                    {@dtw_add(x, "1", x)%}
                              <td>@dtw_tb_select(yn02Table, "includeSafetyStock", "2", "1", "N", "", x, "1")</td>
                          </tr>
                          @DspErrMsg(Err_PLSSS)

                          @SetTextOvr(Err_PLSCS)
                          <tr><td class="dsphdr"><span $(textOvr)>Include Scrap Percent</span></td>
                              @dtw_tb_rows(yn03Table, maxRows)
                              @dtw_assign(x, "1")
                              %while((@dtw_tb_rgetv(yn03Table, x, "1") != V_PLSCS) && (x < maxRows))
                                    {@dtw_add(x, "1", x)%}
                              <td>@dtw_tb_select(yn03Table, "includeScrapPercent", "2", "1", "N", "", x, "1")</td>
                          </tr>
                          @DspErrMsg(Err_PLSCS)

                          @SetTextOvr(Err_PLSPS)
                          <tr><td class="dsphdr"><span $(textOvr)>Increase Order Quantities<br>By Shrinkage Percentage</span></td>
                              @dtw_tb_rows(yn04Table, maxRows)
                              @dtw_assign(x, "1")
                              %while((@dtw_tb_rgetv(yn04Table, x, "1") != V_PLSPS) && (x < maxRows))
                                    {@dtw_add(x, "1", x)%}
                              <td>@dtw_tb_select(yn04Table, "increaseShrinkagePercent", "2", "1", "N", "", x, "1")</td>
                          </tr>
                          @DspErrMsg(Err_PLSPS)

                          @SetTextOvr(Err_PLPEGR)
                          <tr><td class="dsphdr"><span $(textOvr)>Create Pegged Requirements<br>For Non MRP Items</span></td>
                              @dtw_tb_rows(yn14Table, maxRows)
                              @dtw_assign(x, "1")
                              %while((@dtw_tb_rgetv(yn14Table, x, "1") != V_PLPEGR) && (x < maxRows))
                                    {@dtw_add(x, "1", x)%}
                              <td>@dtw_tb_select(yn14Table, "pegNonMRP", "2", "1", "N", "", x, "1")</td>
                          </tr>
