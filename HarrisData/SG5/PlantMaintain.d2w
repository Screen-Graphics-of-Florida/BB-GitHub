                              <td class="inputnmbr"><input type="text" name="mfgOrderActionPeriods" value="$(V_PLMOA)" size="2" maxlength="2"> $(reqFieldChar) </td>
                              <td class="inputnmbr"><input type="text" name="poOrderActionPeriods" value="$(V_PLPOA)" size="2" maxlength="2"> $(reqFieldChar) </td>
                          </tr>
                          @DspErrMsg(Err_PLMOA)
                          @DspErrMsg(Err_PLPOA)

                          @SetTextOvr(Err_PLMDD)
