                      </table>

                      <table $(contentTable)>
                          <tr><td>&nbsp;</td>
                              <td class="colhdr">Mfg</td>
                              <td class="colhdr">Purchasing</td>
                          </tr>

                          @SetTextOvr(Err_PLMOA)
