                      @Default_Zero(V_PLPA5A)
                      @Default_Zero(V_PLPA5S)
                      @RtvFldDesc("CHACCT=$(V_PLPA5A) and CHSUB=$(V_PLPA5S) ", "HDCHRT", "CHCHDS", acctDesc)
                      @SetTextOvr(Err_PLPA5A)
                      <tr><td class="dsphdr"><span $(textOvr)>Purchased<br>Cost Absorption</span></td>
                          <td class="inputnmbr"><input name="poCost05AcctNbr" value="$(V_PLPA5A)" type="text" size="4" maxlength="4"> - <input name="poCost05SubNbr" value="$(V_PLPA5S)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=poCost05AcctNbr&amp;subFld=poCost05SubNbr&amp;descFld=poCost05AcctDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="poCost05AcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_PLPA5A)
                  </table>
              </fieldset>

              <a NAME="userDefined"></a>
              <fieldset class="legendBody">
                  <legend class="legendTitle">User-Defined Data</legend>
                  <div class="quickLinksTop">
                      <a href="#top">$(topOfFormImage)</a>
