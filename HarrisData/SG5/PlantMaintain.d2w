%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%INCLUDE "PlantMaintain.icl"

%Define {
  page_title              = "Plant Maintenance"
  d2wName                 = "PlantMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromSel=@dtw_rurlescseq(fromSel)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;plantName=@dtw_rurlescseq(plantName)&amp;maintenanceCode=D"
  programName             = "HHDPLU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (maintenanceCode == "A")
      @dtw_assign(userPass, "Y")
  %else
      @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %endif
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
                  %INCLUDE "dateedit.icl"
                  %INCLUDE "Menu.js"
                  %INCLUDE "numedit.icl"
                  %INCLUDE "numzero.icl"
                  %INCLUDE "calendar.icl"
                  %INCLUDE "CheckEnterChg.icl"
                  function validate(chgForm) {
                      if (document.Chg.plantNumber.value =="" ||
                          document.Chg.plantName.value =="" ||
                          document.Chg.addressLineOne.value =="" ||
                          document.Chg.city.value =="" ||
                          document.Chg.schedule.value ==""
                          %if (V_HDSCRL>"0")
                              || document.Chg.fixedOverheadCategory.value ==""
                          %endif
                          %if (V_HDMPRL>"0")
                              || document.Chg.timeFenceDefinition.value ==""
                              || document.Chg.periodsRetainForecast.value ==""
                              || document.Chg.periodsConsumeForecast.value ==""
                          %endif
                          )
                          {alert("$(reqFieldError)"); return false;}
                      if (document.Chg.companyNumber.value != document.Chg.piecesPayCodeCompany.value ||
                          document.Chg.facilityNumber.value != document.Chg.piecesPayCodeFacility.value)
                             {alert("Piece Rate Pay Code Default selected is not valid for Company/Facility selected." + "\n" + "You must use the Pay Code Search to retrieve a valid Pay Code.");
                              return false;}
                      if (document.Chg.companyNumber.value != document.Chg.hoursPayCodeCompany.value ||
                          document.Chg.facilityNumber.value != document.Chg.hoursPayCodeFacility.value)
                             {alert("Piece Rate Hours Pay Code selected is not valid for Company/Facility selected." + "\n" + "You must use the Pay Code Search to retrieve a valid Pay Code.");
                              return false;}
                      if (editNum(document.Chg.plantNumber, 3, 0) &&
                          editNum(document.Chg.companyNumber, 2, 0) &&
                          editNum(document.Chg.facilityNumber, 4, 0) &&
                          editZero(document.Chg.schedule, 3, 0) &&
                          editNum(document.Chg.defaultRtgSeq, 3, 0) &&
                          %if (V_HDSCRL>"0")
                              editNum(document.Chg.percentPercentOne, 3, 2) &&
                              editNum(document.Chg.percentPercentTwo, 3, 2) &&
                              editNum(document.Chg.percentPercentThree, 3, 2) &&
                              editNum(document.Chg.percentPercentFour, 3, 2) &&
                              editNum(document.Chg.smPercent, 3, 2) &&
                              editNum(document.Chg.gaPercent, 3, 2) &&
                          %endif
                          %if (V_HDMPRL>"0")
                              editZero(document.Chg.horizonDate,6,0) &&
                              editdate(document.Chg.horizonDate) &&
                              editNum(document.Chg.currentFiscalPeriod, 4, 0) &&
                              editNum(document.Chg.weeksDailyPeriod, 2, 0) &&
                              editNum(document.Chg.weeksWeeklyPeriod, 2, 0) &&
                              editNum(document.Chg.standardHoursDay, 3, 2) &&
                              editNum(document.Chg.periodLengthDays, 2, 0) &&
                              editNum(document.Chg.fixedTimePeriodWeeks, 2, 0) &&
                              editNum(document.Chg.mfgOrderActionPeriods, 2, 0) &&
                              editNum(document.Chg.poOrderActionPeriods, 2, 0) &&
                              editNum(document.Chg.mfgDeferDamperPeriods, 2, 0) &&
                              editNum(document.Chg.poDeferDamperPeriods, 2, 0) &&
                              editNum(document.Chg.periodsRetainForecast, 1, 0) &&
                              editNum(document.Chg.periodsConsumeForecast, 1, 0) &&
                          %endif
                          editNum(document.Chg.nextLaborSequence, 6, 0) &&
                          editNum(document.Chg.lastMfgOrder, 8, 0) &&
                          editNum(document.Chg.dfltMgmtPriority, 2, 1) &&
                          editNum(document.Chg.acceptanceLimitA, 2, 1) &&
                          editNum(document.Chg.acceptanceLimitB, 2, 1) &&
                          editNum(document.Chg.acceptanceLimitC, 2, 1) &&
                          editNum(document.Chg.cycleDaysA, 5, 0) &&
                          editNum(document.Chg.cycleDaysB, 5, 0) &&
                          editNum(document.Chg.cycleDaysC, 5, 0) &&
                          editNum(document.Chg.percentA, 2, 0) &&
                          editNum(document.Chg.percentB, 2, 0) &&
                          editNum(document.Chg.floorstockAcctNbr, 4, 0) &&
                          editNum(document.Chg.floorstockSubNbr, 4, 0) &&
                          editNum(document.Chg.unvoucherAcctNbr, 4, 0) &&
                          editNum(document.Chg.unvoucherSubNbr, 4, 0) &&
                          editNum(document.Chg.vendorServiceAcctNbr, 4, 0) &&
                          editNum(document.Chg.vendorServiceSubNbr, 4, 0) &&
                          editNum(document.Chg.wip01AcctNbr, 4, 0) &&
                          editNum(document.Chg.wip01SubNbr, 4, 0) &&
                          editNum(document.Chg.wipVariance01AcctNbr, 4, 0) &&
                          editNum(document.Chg.wipVariance01SubNbr, 4, 0) &&
                          editNum(document.Chg.mfgCost01AcctNbr, 4, 0) &&
                          editNum(document.Chg.mfgCost01SubNbr, 4, 0) &&
                          editNum(document.Chg.poCost01AcctNbr, 4, 0) &&
                          editNum(document.Chg.poCost01SubNbr, 4, 0) &&
                          editNum(document.Chg.wip02AcctNbr, 4, 0) &&
                          editNum(document.Chg.wip02SubNbr, 4, 0) &&
                          editNum(document.Chg.wipVariance02AcctNbr, 4, 0) &&
                          editNum(document.Chg.wipVariance02SubNbr, 4, 0) &&
                          editNum(document.Chg.mfgCost02AcctNbr, 4, 0) &&
                          editNum(document.Chg.mfgCost02SubNbr, 4, 0) &&
                          editNum(document.Chg.poCost02AcctNbr, 4, 0) &&
                          editNum(document.Chg.poCost02SubNbr, 4, 0) &&
                          editNum(document.Chg.wip03AcctNbr, 4, 0) &&
                          editNum(document.Chg.wip03SubNbr, 4, 0) &&
                          editNum(document.Chg.wipVariance03AcctNbr, 4, 0) &&
                          editNum(document.Chg.wipVariance03SubNbr, 4, 0) &&
                          editNum(document.Chg.mfgCost03AcctNbr, 4, 0) &&
                          editNum(document.Chg.mfgCost03SubNbr, 4, 0) &&
                          editNum(document.Chg.poCost03AcctNbr, 4, 0) &&
                          editNum(document.Chg.poCost03SubNbr, 4, 0) &&
                          editNum(document.Chg.wip04AcctNbr, 4, 0) &&
                          editNum(document.Chg.wip04SubNbr, 4, 0) &&
                          editNum(document.Chg.wipVariance04AcctNbr, 4, 0) &&
                          editNum(document.Chg.wipVariance04SubNbr, 4, 0) &&
                          editNum(document.Chg.mfgCost04AcctNbr, 4, 0) &&
                          editNum(document.Chg.mfgCost04SubNbr, 4, 0) &&
                          editNum(document.Chg.poCost04AcctNbr, 4, 0) &&
                          editNum(document.Chg.poCost04SubNbr, 4, 0) &&
                          editNum(document.Chg.wip05AcctNbr, 4, 0) &&
                          editNum(document.Chg.wip05SubNbr, 4, 0) &&
                          editNum(document.Chg.wipVariance05AcctNbr, 4, 0) &&
                          editNum(document.Chg.wipVariance05SubNbr, 4, 0) &&
                          editNum(document.Chg.mfgCost05AcctNbr, 4, 0) &&
                          editNum(document.Chg.mfgCost05SubNbr, 4, 0) &&
                          editNum(document.Chg.poCost05AcctNbr, 4, 0) &&
                          editNum(document.Chg.poCost05SubNbr, 4, 0))
                          return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "PLANTMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "SELECT HDPLNT.*, HDPLTE.* ", stmtSQL)
                              @dtw_concat(fileSQL, " HDPLNT left join HDPLTE on PLPLNT=PEPLT ", fileSQL)
                              @dtw_concat(selectSQL, "PLPLNT='$(plantNumber)' ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN  CHAR(64) profileHandle,
                                       CHAR(2)   dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=14")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      <a NAME="top"></a>
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)

      <table $(quickLinkTable)>
          <tr>
              <td class="quickLinkTabs"><a href="#generalData">General Data</a></td>
              <td class="quickLinkTabs"><a href="#productDataBase">Product Data Base</a></td>
              <td class="quickLinkTabs"><a href="#defaultRouting">Default Routing</a></td>
               %if (V_HDSCRL>"0") <td class="quickLinkTabs"><a href="#costManagement">Cost Management</a></td>%endif
              <td class="quickLinkTabs"><a href="#MPSMRP">MPS/MRP</a></td>
          </tr>
          <tr>
              <td class="quickLinkTabs"><a href="#shopFloor">Shop Floor Control</a></td>
              <td class="quickLinkTabs"><a href="#cycleCount">Cycle Count</a></td>
              <td class="quickLinkTabs"><a href="#accountNumbers">Accounts</a></td>
              <td class="quickLinkTabs"><a href="#userDefined">User-Defined</a></td>
          </tr>
      </table>

      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          %ROW {
              %if (errFound != "" || maintenanceCode == "A")
                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(edtVar, "")
                      @dtw_assign(focusField, "plantNumber")
                  %else
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @dtw_assign(focusField, "")
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@plnt", "plantNumber")              @dtw_assign(Err_PLPLNT, fieldValue)
                      @DecatErr_Field("@@co@@", "companyNumber")            @dtw_assign(Err_PLCO#, fieldValue)
                      @DecatErr_Field("@@fac@", "facilityNumber")           @dtw_assign(Err_PLFAC#, fieldValue)
                      @DecatErr_Field("@@name", "plantName")                @dtw_assign(Err_PLNAME, fieldValue)
                      @DecatErr_Field("@@adr1", "addressLineOne")           @dtw_assign(Err_PLADR1, fieldValue)
                      @DecatErr_Field("@@adr2", "addressLineTwo")           @dtw_assign(Err_PLADR2, fieldValue)
                      @DecatErr_Field("@@city", "city")                     @dtw_assign(Err_PLCITY, fieldValue)
                      @DecatErr_Field("@@st@@", "state")                    @dtw_assign(Err_PLST, fieldValue)
                      @DecatErr_Field("@@zip@", "zip")                      @dtw_assign(Err_PLZIP, fieldValue)
                      @DecatErr_Field("@@alph", "alphaSequence")            @dtw_assign(Err_PLALPH, fieldValue)
                      @DecatErr_Field("@@ctry", "country")                  @dtw_assign(Err_PLCTRY, fieldValue)
                      @DecatErr_Field("@@schd", "schedule")                 @dtw_assign(Err_PLSCHD, fieldValue)
                      @DecatErr_Field("@@rseq", "defaultRtgSeq")            @dtw_assign(Err_PLRSEQ, fieldValue)
                      @DecatErr_Field("@@rsf@", "prodStrInterToRouting")    @dtw_assign(Err_PLRSF, fieldValue)
                      @DecatErr_Field("@@ddpt", "dfltDept")                 @dtw_assign(Err_PEDDPT, fieldValue)
                      @DecatErr_Field("@@dwc@", "dfltWC")                   @dtw_assign(Err_PEDWC, fieldValue)
                      @DecatErr_Field("@@cc1d", "shortCostOne")             @dtw_assign(Err_PLCC1D, fieldValue)
                      @DecatErr_Field("@@c1ld", "longCostOne")              @dtw_assign(Err_PLC1LD, fieldValue)
                      @DecatErr_Field("@@cc2d", "shortCostTwo")             @dtw_assign(Err_PLCC2D, fieldValue)
                      @DecatErr_Field("@@c2ld", "longCostTwo")              @dtw_assign(Err_PLC2LD, fieldValue)
                      @DecatErr_Field("@@cc3d", "shortCostThree")           @dtw_assign(Err_PLCC3D, fieldValue)
                      @DecatErr_Field("@@c3ld", "longCostThree")            @dtw_assign(Err_PLC3LD, fieldValue)
                      @DecatErr_Field("@@cc4d", "shortCostFour")            @dtw_assign(Err_PLCC4D, fieldValue)
                      @DecatErr_Field("@@c4ld", "longCostFour")             @dtw_assign(Err_PLC4LD, fieldValue)
                      @DecatErr_Field("@@cc5d", "shortCostFive")            @dtw_assign(Err_PLCC5D, fieldValue)
                      @DecatErr_Field("@@c5ld", "longCostFive")             @dtw_assign(Err_PLC5LD, fieldValue)
                      @DecatErr_Field("@@dol1", "descriptionDollarOne")     @dtw_assign(Err_PLDOL1, fieldValue)
                      @DecatErr_Field("@@dol2", "descriptionDollarTwo")     @dtw_assign(Err_PLDOL2, fieldValue)
                      @DecatErr_Field("@@pct1", "descriptionPercentOne")    @dtw_assign(Err_PLPCT1, fieldValue)
                      @DecatErr_Field("@@pca1", "percentPercentOne")        @dtw_assign(Err_PLPCA1, fieldValue)
                      @DecatErr_Field("@@pct2", "descriptionPercentTwo")    @dtw_assign(Err_PLPCT2, fieldValue)
                      @DecatErr_Field("@@pca2", "percentPercentTwo")        @dtw_assign(Err_PLPCA2, fieldValue)
                      @DecatErr_Field("@@pct3", "descriptionPercentThree")  @dtw_assign(Err_PLPCT3, fieldValue)
                      @DecatErr_Field("@@pca3", "percentPercentThree")      @dtw_assign(Err_PLPCA3, fieldValue)
                      @DecatErr_Field("@@pct4", "descriptionPercentFour")   @dtw_assign(Err_PLPCT4, fieldValue)
                      @DecatErr_Field("@@pca4", "percentPercentFour")       @dtw_assign(Err_PLPCA4, fieldValue)
                      @DecatErr_Field("@@spct", "smPercent")                @dtw_assign(Err_PLSPCT, fieldValue)
                      @DecatErr_Field("@@gpct", "gaPercent")                @dtw_assign(Err_PLGPCT, fieldValue)
                      @DecatErr_Field("@@fxel", "fixedOverheadCategory")    @dtw_assign(Err_PLFXEL, fieldValue)
                      @DecatErr_Field("@@dcp@", "horizonDate")              @dtw_assign(Err_PLDCP, fieldValue)
                      @DecatErr_Field("@@fcm@", "currentFiscalPeriod")      @dtw_assign(Err_PLFCM, fieldValue)
                      @DecatErr_Field("@@wdd@", "weeksDailyPeriod")         @dtw_assign(Err_PL#WDD, fieldValue)
                      @DecatErr_Field("@@wwd@", "weeksWeeklyPeriod")        @dtw_assign(Err_PL#WWD, fieldValue)
                      @DecatErr_Field("@@shr@", "standardHoursDay")         @dtw_assign(Err_PLSHR, fieldValue)
                      @DecatErr_Field("@@pl@@", "periodLengthDays")         @dtw_assign(Err_PLPL, fieldValue)
                      @DecatErr_Field("@@ntp@", "fixedTimePeriodWeeks")     @dtw_assign(Err_PLNTP, fieldValue)
                      @DecatErr_Field("@@sss@", "includeSafetyStock")       @dtw_assign(Err_PLSSS, fieldValue)
                      @DecatErr_Field("@@scs@", "includeScrapPercent")      @dtw_assign(Err_PLSCS, fieldValue)
                      @DecatErr_Field("@@sps@", "increaseShrinkagePercent") @dtw_assign(Err_PLSPS, fieldValue)
                      @DecatErr_Field("@@pegr", "pegNonMRP")                @dtw_assign(Err_PLPEGR, fieldValue)
                      @DecatErr_Field("@@moa@", "mfgOrderActionPeriods")    @dtw_assign(Err_PLMOA, fieldValue)
                      @DecatErr_Field("@@poa@", "poOrderActionPeriods")     @dtw_assign(Err_PLPOA, fieldValue)
                      @DecatErr_Field("@@mdd@", "mfgDeferDamperPeriods")    @dtw_assign(Err_PLMDD, fieldValue)
                      @DecatErr_Field("@@pdd@", "poDeferDamperPeriods")     @dtw_assign(Err_PLPDD, fieldValue)
                      @DecatErr_Field("@@mrpf", "forecastMRPInput")         @dtw_assign(Err_PLMRPF, fieldValue)
                      @DecatErr_Field("@@fdtf", "forecastDateFormat")       @dtw_assign(Err_PLFDTF, fieldValue)
                      @DecatErr_Field("@@fspr", "forecastSpreaders")        @dtw_assign(Err_PLFSPR, fieldValue)
                      @DecatErr_Field("@@tfnd", "timeFenceDefinition")      @dtw_assign(Err_PLTFND, fieldValue)
                      @DecatErr_Field("@@pfct", "periodsRetainForecast")    @dtw_assign(Err_PLPFCT, fieldValue)
                      @DecatErr_Field("@@cfct", "periodsConsumeForecast")   @dtw_assign(Err_PLCFCT, fieldValue)
                      @DecatErr_Field("@@hrsf", "stdMilHours")              @dtw_assign(Err_PLHRSF, fieldValue)
                      @DecatErr_Field("@@tef@", "timeEntryFormat")          @dtw_assign(Err_PLTEF, fieldValue)
                      @DecatErr_Field("@@bkop", "backflushComponents")      @dtw_assign(Err_PLBKOP, fieldValue)
                      @DecatErr_Field("@@lesq", "nextLaborSequence")        @dtw_assign(Err_PLLESQ, fieldValue)
                      @DecatErr_Field("@@nmo@", "lastMfgOrder")             @dtw_assign(Err_PLNMO, fieldValue)
                      @DecatErr_Field("@@dfta", "dateAnchorDefault")        @dtw_assign(Err_PLDFTA, fieldValue)
                      @DecatErr_Field("@@mgtp", "dfltMgmtPriority")         @dtw_assign(Err_PEMGTP, fieldValue)
                      @DecatErr_Field("@@umfg", "updateMfgOrderDate")       @dtw_assign(Err_PLUMFG, fieldValue)
                      @DecatErr_Field("@@orcl", "closeOrderReceiptEntry")   @dtw_assign(Err_PLORCL, fieldValue)
                      @DecatErr_Field("@@dprw", "displayPiecesRework")      @dtw_assign(Err_PLDPRW, fieldValue)
                      @DecatErr_Field("@@hwkf", "HoursWorkedFormat")        @dtw_assign(Err_PLHWKF, fieldValue)
                      @DecatErr_Field("@@cpdf", "completedDefault")         @dtw_assign(Err_PLCPDF, fieldValue)
                      @DecatErr_Field("@@rcpp", "recalcCompletedPieces")    @dtw_assign(Err_PLRCPP, fieldValue)
                      @DecatErr_Field("@@bcdc", "barCodeDataCollection")    @dtw_assign(Err_PLBCDC, fieldValue)
                      @DecatErr_Field("@@prcd", "addOrderProcessDay")       @dtw_assign(Err_PLPRCD, fieldValue)
                      @DecatErr_Field("@@acpo", "autoExplodePO")            @dtw_assign(Err_PLACPO, fieldValue)
                      @DecatErr_Field("@@aelv", "autoExplodeAll")           @dtw_assign(Err_PLAELV, fieldValue)
                      @DecatErr_Field("@@aent", "autoExplodeNet")           @dtw_assign(Err_PLAENT, fieldValue)
                      @DecatErr_Field("@@kpoc", "kanbanPOCode")             @dtw_assign(Err_PLKPOC, fieldValue)
                      @DecatErr_Field("@@kbdd", "kanbanDocument")           @dtw_assign(Err_PLKBDD, fieldValue)
                      @DecatErr_Field("@@abci", "abcByInvType")             @dtw_assign(Err_PLABCI, fieldValue)
                      @DecatErr_Field("@@vla@", "acceptanceLimitA")         @dtw_assign(Err_PLVLA, fieldValue)
                      @DecatErr_Field("@@vlb@", "acceptanceLimitB")         @dtw_assign(Err_PLVLB, fieldValue)
                      @DecatErr_Field("@@vlc@", "acceptanceLimitC")         @dtw_assign(Err_PLVLC, fieldValue)
                      @DecatErr_Field("@@caw@", "cycleDaysA")               @dtw_assign(Err_PLCAW, fieldValue)
                      @DecatErr_Field("@@cbw@", "cycleDaysB")               @dtw_assign(Err_PLCBW, fieldValue)
                      @DecatErr_Field("@@ccw@", "cycleDaysC")               @dtw_assign(Err_PLCCW, fieldValue)
                      @DecatErr_Field("@@pcac", "percentA")                 @dtw_assign(Err_PLPCA, fieldValue)
                      @DecatErr_Field("@@pcbc", "percentB")                 @dtw_assign(Err_PLPCB, fieldValue)
                      @DecatErr_Field("@@fsia", "floorstockAcctNbr")        @dtw_assign(Err_PLFSIA, fieldValue)
                      @DecatErr_Field("@@fsis", "floorstockSubNbr")         @dtw_assign(Err_PLFSIS, fieldValue)
                      @DecatErr_Field("@@uvra", "unvoucherAcctNbr")         @dtw_assign(Err_PLUVRA, fieldValue)
                      @DecatErr_Field("@@uvrs", "unvoucherSubNbr")          @dtw_assign(Err_PLUVRS, fieldValue)
                      @DecatErr_Field("@@vsva", "vendorServiceAcctNbr")     @dtw_assign(Err_PLVSVA, fieldValue)
                      @DecatErr_Field("@@vsvs", "vendorServiceSubNbr")      @dtw_assign(Err_PLVSVS, fieldValue)
                      @DecatErr_Field("@@wp1a", "wip01AcctNbr")             @dtw_assign(Err_PLWP1A, fieldValue)
                      @DecatErr_Field("@@wp1s", "wip01SubNbr")              @dtw_assign(Err_PLWP1S, fieldValue)
                      @DecatErr_Field("@@wv1a", "wipVariance01AcctNbr")     @dtw_assign(Err_PLWV1A, fieldValue)
                      @DecatErr_Field("@@wv1s", "wipVariance01SubNbr")      @dtw_assign(Err_PLWV1S, fieldValue)
                      @DecatErr_Field("@@ma1a", "mfgCost01AcctNbr")         @dtw_assign(Err_PLMA1A, fieldValue)
                      @DecatErr_Field("@@ma1s", "mfgCost01SubNbr")          @dtw_assign(Err_PLMA1S, fieldValue)
                      @DecatErr_Field("@@pa1a", "poCost01AcctNbr")          @dtw_assign(Err_PLPA1A, fieldValue)
