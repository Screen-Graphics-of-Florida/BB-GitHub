                          <td class="inputnmbr"><input name="wipVariance05AcctNbr" value="$(V_PLWV5A)" type="text" size="4" maxlength="4"> - <input name="wipVariance05SubNbr" value="$(V_PLWV5S)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=wipVariance05AcctNbr&amp;subFld=wipVariance05SubNbr&amp;descFld=wipVariance05AcctDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="wipVariance05AcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                      </tr>
