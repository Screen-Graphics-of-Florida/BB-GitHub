              <a name="MPSMRP"></a>
              <fieldset class="legendBody">
                  <legend class="legendTitle">MPS/MRP</legend>
                  %if (V_HDMPRL>"0")		
                      <div class="quickLinksTop">
                          <a href="#top">$(topOfFormImage)</a>
                      </div>
                      <table $(contentTable)>
                          @SetTextOvr(Err_PLDCP)
                          <tr><td class="dsphdr"><span $(textOvr)>Planning Horizon Date</span></td>
                              <td class="inputnmbr"><input type="text" name="horizonDate" value="$(V_PLDCP)" size="6" maxlength="6"> $(reqFieldChar) 		
                                  <a href="javascript:calWindow('horizonDate');">$(calendarImage)</a></td>
                          </tr>
                          @DspErrMsg(Err_PLDCP)

                          @SetTextOvr(Err_PLFCM)
                          @PeriodInputFromCYP(V_PLFCM)
