                              <td class="inputalph"><input type="text" name="descriptionPercentOne" value="$(V_PLPCT1)" size="10" maxlength="10"></td>
                              <td class="inputnmbr"><input type="text" name="percentPercentOne" value="$(V_PLPCA1)" size="7" maxlength="7"></td>
