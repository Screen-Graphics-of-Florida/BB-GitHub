                              <td class="inputnmbr"><input type="text" name="weeksDailyPeriod" value="$(V_PL#WDD)" size="2" maxlength="2"></td>
                          </tr>
                          @DspErrMsg(Err_PL#WDD)

                          @SetTextOvr(Err_PL#WWD)
