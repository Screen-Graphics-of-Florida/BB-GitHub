                  @dtw_assign(V_PLPLNT,  "")
                  @DateInputFromISO("$(V_PLDCP)", V_PLDCP)
                  @dtw_assign(focusField, "plantNumber")
              %else
                  @DateInputFromISO("$(V_PLDCP)", V_PLDCP)
                  @dtw_assign(focusField, "companyNumber")
              %endif

              <a name="generalData"></a>
              <fieldset class="legendBody">
                  <legend class="legendTitle">General Data</legend>
                  <div class="quickLinksTop">
                      <a href="#top">$(topOfFormImage)</a>
                  </div>
                  <table $(contentTable)>
                      @SetTextOvr(Err_PLPLNT)
                      <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                          %if (maintenanceCode == "A" || maintenanceCode == "Z")
                              <td class="inputnmbr"><input name="plantNumber" type="text" value="$(V_PLPLNT)" size="3" maxlength="3"> $(reqFieldChar) </td>
                          %else
                              <td class="inputnmbr"><input name="plantNumber" type="hidden" value="$(V_PLPLNT)" size="3" maxlength="3">$(V_PLPLNT)</td>
                              @dtw_assign(dfltPlant, $(V_PLPLNT))
                          %endif
                      </tr>
                      @DspErrMsg(Err_PLPLNT)

                      @Default_Zero(V_PLCO#)
                      @Default_Zero(V_PLFAC#)
                      @RtvFldDesc("CFCO#=$(V_PLCO#) and CFFAC#=$(V_PLFAC#)", "HDCFAC", "CFCFNM", fieldDesc)
                      @SetTextOvr(Err_PLCO#)
                      <tr><td class="dsphdr"><span $(textOvr)>Company/Facility</span></td>
                          <td class="inputnmbr"><input name="companyNumber" value="$(V_PLCO#)" type="text" size="2" maxlength="2"> / <input name="facilityNumber" value="$(V_PLFAC#)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)CoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=companyNumber&amp;fldFac=facilityNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="coFacDesc" value="$(fieldDesc)"  type="text" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_PLCO#)

                      @SetTextOvr(Err_PLNAME)
                      <tr><td class="dsphdr"><span $(textOvr)>Plant Name</span></td>
                          <td class="inputalph"><input name="plantName" type="text" value="$(V_PLNAME)" size="26" maxlength="26"> $(reqFieldChar) </td>
                      </tr>
                      @DspErrMsg(Err_PLNAME)

                      @SetTextOvr(Err_PLADR1)
                      <tr><td class="dsphdr"><span $(textOvr)>Address Line One</span></td>
                          <td class="inputalph"><input name="addressLineOne" type="text" value="$(V_PLADR1)" size="26" maxlength="26"> $(reqFieldChar) </td>
                      </tr>
                      @DspErrMsg(Err_PLADR1)

                      @SetTextOvr(Err_PLADR2)
                      <tr><td class="dsphdr"><span $(textOvr)>Address Line Two</span></td>
                          <td class="inputalph"><input type="text" name="addressLineTwo" value="$(V_PLADR2)" size="26" maxlength="26"></td>
                      </tr>
                      @DspErrMsg(Err_PLADR2)
    				
                      @SetTextOvr(Err_PLCITY)
                      <tr><td class="dsphdr"><span $(textOvr)>City</span></td>
                          <td class="inputalph"><input type="text" name="city" value="$(V_PLCITY)" size="26" maxlength="26"> $(reqFieldChar) </td>
                      </tr>
                      @DspErrMsg(Err_PLCITY)

                      @RtvFldDesc("STID='$(V_PLST)'", "HDSTID", "STDESC", fieldDesc)
                      @SetTextOvr(Err_PLST)
                      <tr><td class="dsphdr"><span $(textOvr)>State</span></td>
                          <td class="inputalph"><input name="state" type="text" value="$(V_PLST)" size="3" maxlength="2"><a href="$(homeURL)$(phpPath)StateSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=state&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stateDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                      </tr>
                      @DspErrMsg(Err_PLST)

                      @SetTextOvr(Err_PLZIP)
                      <tr><td class="dsphdr"><span $(textOvr)>Zip</span></td>
                          <td class="inputalph"><input type="text" name="zip" value="$(V_PLZIP)" size="13" maxlength="13"></td>
                      </tr>
                      @DspErrMsg(Err_PLZIP)

                      @RtvFldDesc("CNCTCD='$(V_PLCTRY)'", "HDCTRY", "CNCDES", fieldDesc)
                      @SetTextOvr(Err_PLCTRY)
                      <tr><td class="dsphdr"><span $(textOvr)>Country</span></td>
                          <td class="inputalph"><input name="country" type="text" value="$(V_PLCTRY)" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)CountrySearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=country&amp;fldDesc=countryDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="countryDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                      </tr>
                      @DspErrMsg(Err_PLCTRY)

                      @SetTextOvr(Err_PLALPH)
                      <tr><td class="dsphdr"><span $(textOvr)>Alpha Sequence</span></td>
                          <td class="inputalph"><input type="text" name="alphaSequence" value="$(V_PLALPH)" size="4" maxlength="4"></td>
                      </tr>
                      @DspErrMsg(Err_PLALPH)
    			
                      @RtvFldDesc("SMSCHD=$(V_PLSCHD)", "HDSCHM", "SMDESC", fieldDesc)
                      @SetTextOvr(Err_PLSCHD)
                      <tr><td class="dsphdr"><span $(textOvr)>Schedule</span></td>
                          <td class="inputnmbr"><input name="schedule" type="text" value="$(V_PLSCHD)" size="3" maxlength="3"> $(reqFieldChar) <a href="$(homeURL)$(phpPath)ScheduleSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=schedule&amp;fldDesc=scheduleDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="scheduleDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                      </tr>
                      @DspErrMsg(Err_PLSCHD)
                  </table>
              </fieldset>

              <a name="productDataBase"></a>
              <fieldset class="legendBody">
                  <legend class="legendTitle">Product Data Base</legend>
                  <div class="quickLinksTop">
                      <a href="#top">$(topOfFormImage)</a>
                  </div>
                  <table $(contentTable)>
                      @SetTextOvr(Err_PLRSEQ)
