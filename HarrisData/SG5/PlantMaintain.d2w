%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDPLU_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @dtw_assign(eventCode, "X")
      @Supervisor_Query(profileHandle, dataBaseID, eventCode, supervisorTable)
          @dtw_tb_insertrow(supervisorTable, "0", "1")

      @dtw_assign(companyNumber, "00")
      @dtw_assign(facilityNumber, "0000")

      @AutoExplodePO_Query(profileHandle, dataBaseID, "AUTOEXPLPO", autoExplodePOTable)
      @CompletedDefault_Query(profileHandle, dataBaseID, "COMPLPIECE", completedDefaultTable)
      @HaltError_Query(profileHandle, dataBaseID, "HALTERROR ", haltErrorTable)
      @HoursWorked_Query(profileHandle, dataBaseID, "HOURWRKFMT", hoursWorkedTable)
      @KanbanDocument_Query(profileHandle, dataBaseID, "KANBANDOC ", kanbanDocumentTable)
      @KanbanPO_Query(profileHandle, dataBaseID, "KANBANPO  ", kanbanPOTable)
      @LaborRateUsage_Query(profileHandle, dataBaseID, "LBRRATEUSG", laborRateTable)
      @PiecesRework_Query(profileHandle, dataBaseID, "PIECEREWRK", piecesReworkTable)
      @StdMilitary_Query(profileHandle, dataBaseID, "STDMILITRY", stdMilTable)
      @TimeEntryFormat_Query(profileHandle, dataBaseID, "TIMEENTFMT", timeEntryTable)
      @ForecastDateFormat_Query(profileHandle, dataBaseID, "FORECASTDF", forecastDateTable)
      @ForecastSpreaders_Query(profileHandle, dataBaseID, "FORECASTSP", forecastSpreadersTable)
      @DefaultDateAnchor_Query(profileHandle, dataBaseID, "DATANCHDFT", defaultDateAnchorTable)
      @UpdateMfgOrder_Query(profileHandle, dataBaseID, "BY", updateMfgOrderTable)

      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @yn02_Table_Query(profileHandle, dataBaseID, "YORN      ", yn02Table)
      @yn03_Table_Query(profileHandle, dataBaseID, "YORN      ", yn03Table)
      @yn04_Table_Query(profileHandle, dataBaseID, "YORN      ", yn04Table)
      @yn06_Table_Query(profileHandle, dataBaseID, "YORN      ", yn06Table)
      @yn07_Table_Query(profileHandle, dataBaseID, "YORN      ", yn07Table)
      @yn08_Table_Query(profileHandle, dataBaseID, "YORN      ", yn08Table)
      @yn09_Table_Query(profileHandle, dataBaseID, "YORN      ", yn09Table)
      @yn10_Table_Query(profileHandle, dataBaseID, "YORN      ", yn10Table)
      @yn11_Table_Query(profileHandle, dataBaseID, "YORN      ", yn11Table)
      @yn12_Table_Query(profileHandle, dataBaseID, "YORN      ", yn12Table)
      @yn13_Table_Query(profileHandle, dataBaseID, "YORN      ", yn13Table)
      @yn14_Table_Query(profileHandle, dataBaseID, "YORN      ", yn14Table)
      @yn15_Table_Query(profileHandle, dataBaseID, "YORN      ", yn15Table)
      @yn16_Table_Query(profileHandle, dataBaseID, "YORN      ", yn16Table)
      @yn17_Table_Query(profileHandle, dataBaseID, "YORN      ", yn17Table)
      @yn18_Table_Query(profileHandle, dataBaseID, "YORN      ", yn18Table)

      @Set_SQL(stmtSQL)
  %endif
%}

