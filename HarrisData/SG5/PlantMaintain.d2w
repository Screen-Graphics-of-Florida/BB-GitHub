                              <td class="inputalph"><input type="text" name="descriptionDollarOne" value="$(V_PLDOL1)" size="10" maxlength="10"></td>
                          </tr>
                          @DspErrMsg(Err_PLDOL1)

                          @SetTextOvr(Err_PLDOL2)
                          <tr><td class="dsphdr"><span $(textOvr)>Dollar Two</span></td>
                              <td class="inputalph"><input type="text" name="descriptionDollarTwo" value="$(V_PLDOL2)" size="10" maxlength="10"></td>
                          </tr>
