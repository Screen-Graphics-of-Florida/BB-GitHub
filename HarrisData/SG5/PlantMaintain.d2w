                              <td class="inputnmbr"><input type="text" name="mfgDeferDamperPeriods" value="$(V_PLMDD)" size="2" maxlength="2"></td>
                              <td class="inputnmbr"><input type="text" name="poDeferDamperPeriods" value="$(V_PLPDD)" size="2" maxlength="2"></td>
                          </tr>
                          @DspErrMsg(Err_PLMDD)
                          @DspErrMsg(Err_PLPDD)
                      </table>

