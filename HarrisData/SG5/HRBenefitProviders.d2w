%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title 	        = "Benefit Providers"
  d2wName              = "HRBenefitProviders.d2w"
  d2wVarBase           = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar          = "$(d2wVarBase)"
  wildDftVar           = "REPORT$(d2wVarBase)"
  programName          = "HPECRU"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  DTW_PRINT_HEADER     = "NO"
  RPT_MAX_ROWS 	= "10"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext		= "1"
  totalPages		= "0"	
  country              = "US"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "BENPROVIDER")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select CRCODE, CRNAME, CRADD1, CRADD2, CRCITY, CRSTAT, CRPHON, ", stmtSQL)
                      @dtw_concat(stmtSQL, " CRZIP, upper(CRNAME) as CRNAMEU, upper(CRADD1) as CRADD1U, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(CRADD2) as CRADD2U, upper(CRCITY) as CRCITYU ", stmtSQL)
                      @dtw_concat(fileSQL, " CBCARR ", fileSQL)
                      %if (wildCardSearch!="" || uv_Sql!="")
                          @dtw_concat(selectSQL, "CRCODE<>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Providers_Inquiry(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Providers_Inquiry (IN CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count != "1")
          <table $(contentTable)>
	       <colgroup>
	           <col width="80%">
	   	   <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/report") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"	
          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Name</th></tr>
                      <tr><td><input type="text" class="inputalph" name="srchName" size="30" maxlength="30">
                              <input type="hidden" name="operName" value="LIKE">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchName.focus();
                  </script>
              </form>

              %INCLUDE "WildCardPage.icl"
          %endif
	   		
          <table $(contentTable)>
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("CRCODE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Code" title="Sequence By Provider Code"> Provider<br>Code</a></th>
                  @OrderBy_Sort("CRNAMEU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Name" title="Sequence By Name"> Name</a></th>
                  @OrderBy_Sort("CRADD1U", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Address1" title="Sequence By Address 1"> Address 1</a></th>
                  @OrderBy_Sort("CRADD2U", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Address2" title="Sequence By Address 2"> Address 2</a></th>
                  @OrderBy_Sort("CRCITYU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=City" title="Sequence By City"> City</a></th>
                  @OrderBy_Sort("CRSTAT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=State" title="Sequence By State, City"> State</a></th>
                  @OrderBy_Sort("CRZIP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Zip" title="Sequence By Zip, City"> Zip</a></th>
                  @OrderBy_Sort("CRPHON", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Phone" title="Sequence By Phone Number"> Phone<br>Number</a></th>
              </tr>
          %INCLUDE "NoRecordsFound.icl"
      %endif

              %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;providerCode=@dtw_rurlescseq(V_CRCODE)")
                  %if (sql_Record_Count == "1")
                      @Save_WebReg(webRegCurFile, profileHandle, d2wName, "", orderBy, orderByDisplay, "")
                      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)HRBenProviderSelect.d2w/REPORT$(maintainVar)">
                  %else
                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          <td class="colcode">$(V_CRCODE)</td>
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)HRBenProviderSelect.d2w/REPORT$(maintainVar)" title="View Provider And Benefits">$(V_CRNAME)</a></td>
                          <td class="colalph">$(V_CRADD1)</td>
                          <td class="colalph">$(V_CRADD2)</td>
                          <td class="colalph">$(V_CRCITY)</td>
                          <td class="colcode">$(V_CRSTAT)</td>
                          <td class="colalph">$(V_CRZIP)</td>
	   	           %if (V_CRPHON > "0")
                              @EditPhoneNumber(V_CRPHON)
                          %endif
                          <td class="colalph">$(V_CRPHON)</td>
                      </tr>
                  %endif
              %}
          </table>
          %if (sql_Record_Count != "1")
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "Select CRCODE, CRNAME, CRADD1, CRADD2, CRCITY, CRSTAT, CRPHON, ", stmtSQL)
  @dtw_concat(stmtSQL, " CRZIP, upper(CRNAME) as CRNAMEU, upper(CRADD1) as CRADD1U, ", stmtSQL)
  @dtw_concat(stmtSQL, " upper(CRADD2) as CRADD2U, upper(CRCITY) as CRCITYU ", stmtSQL)
  @dtw_concat(fileSQL, " CBCARR ", fileSQL)
  %if (wildCardSearch!="" || uv_Sql!="")
      @dtw_concat(selectSQL, "CRCODE<>' ' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @Provider_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) Provider_XMLQuery (IN CHAR(64)    profileHandle,
			                  CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
       @XMLBeginTag("BenefitProviderList")
           %ROW{

		    @XMLIDTag(V_CRCODE, "BenefitProvider ID")
                       @XMLTag(V_CRCODE, "ProviderCode")
                       @XMLTag(V_CRNAME, "ProviderName")
                       @XMLTag(V_CRPHON, "PhoneNumber")


               @XMLEndTag("BenefitProvider")
           %}
       @XMLEndTag("BenefitProviderList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (sec_05 == "N")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)progOptSecError.d2w/DISPLAY$(genericVarBase)&amp;page_title=@dtw_rurlescseq(page_title)">
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "CRNAMEU")
              @DTW_ASSIGN(orderByDisplay, "Name")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      %INCLUDE "SearchReturn.icl"
  %endif
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Code")
      %if (orderBy == "CRCODE")
          @DTW_ASSIGN(orderBy, "CRCODE DESC")
          @DTW_ASSIGN(orderByDisplay, "Provider Code (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CRCODE")
          @DTW_ASSIGN(orderByDisplay, "Provider Code")
      %endif
  %elseif (sequence == "Name")
      %if (orderBy == "CRNAMEU")
          @DTW_ASSIGN(orderBy, "CRNAMEU DESC")
          @DTW_ASSIGN(orderByDisplay, "Name (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CRNAMEU")
          @DTW_ASSIGN(orderByDisplay, "Name")
      %endif
  %elseif (sequence == "Address1")
      %if (orderBy == "CRADD1U")
          @DTW_ASSIGN(orderBy, "CRADD1U DESC")
          @DTW_ASSIGN(orderByDisplay, "Address 1 (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CRADD1U")
          @DTW_ASSIGN(orderByDisplay, "Address 1")
      %endif
  %elseif (sequence == "Address2")
      %if (orderBy == "CRADD2U")
          @DTW_ASSIGN(orderBy, "CRADD2U DESC")
          @DTW_ASSIGN(orderByDisplay, "Address 2 (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CRADD2U")
          @DTW_ASSIGN(orderByDisplay, "Address 2")
      %endif
  %elseif (sequence == "City")
      %if (orderBy == "CRCITYU")
          @DTW_ASSIGN(orderBy, "CRCITYU DESC")
          @DTW_ASSIGN(orderByDisplay, "City (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CRCITYU")
          @DTW_ASSIGN(orderByDisplay, "City")
      %endif
  %elseif (sequence == "State")
      %if (orderBy == "CRSTAT,CRCITYU")
          @DTW_ASSIGN(orderBy, "CRSTAT DESC,CRCITYU")
          @DTW_ASSIGN(orderByDisplay, "State (descending), City")
      %else
          @DTW_ASSIGN(orderBy, "CRSTAT,CRCITYU")
          @DTW_ASSIGN(orderByDisplay, "State, City")
      %endif
  %elseif (sequence == "Zip")
      %if (orderBy == "CRZIP,CRCITYU")
          @DTW_ASSIGN(orderBy, "CRZIP DESC,CRCITYU")
          @DTW_ASSIGN(orderByDisplay, "Zip (descending), City")
      %else
          @DTW_ASSIGN(orderBy, "CRZIP,CRCITYU")
          @DTW_ASSIGN(orderByDisplay, "Zip, City")
      %endif
  %elseif (sequence == "Phone")
      %if (orderBy == "CRPHON")
          @DTW_ASSIGN(orderBy, "CRPHON DESC")
          @DTW_ASSIGN(orderByDisplay, "Phone Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CRPHON")
          @DTW_ASSIGN(orderByDisplay, "Phone Number")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchPhone, 10, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "BENPROVSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Provider Code</td>
                              @dtw_assign(operNbr, "operCode")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCode" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Name</td>
                              @dtw_assign(operNbr, "operName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchName" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">City</td>
                              @dtw_assign(operNbr, "operCity")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCity" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">State</td>
                              @dtw_assign(operNbr, "operState")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchState" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)StateSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Search&amp;fldName=srchState&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stateDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Zip</td>
                              @dtw_assign(operNbr, "operZip")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchZip" size="14" maxlength="14"></td>
                          </tr>

                          <tr><td class="dsphdr">Phone Number</td>
                              <td>&nbsp;</td>
                              <td class="inputnmbr"><input type="text" name="srchPhone" size="10" maxlength="10"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchCode.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("CRCODE", "Provider Code", $(srchCode), "U", operCode, "A")
  @Build_WildCard ("upper(CRNAME)", "Name", $(srchName), "U", operName, "A")
  @Build_WildCard ("upper(CRCITY)", "City", $(srchCity), "U", operCity, "A")
  @Build_WildCard ("CRSTAT", "State", $(srchState), "U", operState, "A")
  @Build_WildCard ("CRZIP", "Zip", $(srchZip), "", operZip, "A")
  @Build_WildCard ("CRPHON", "Phone Number", $(srchPhone), "", "", "P")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}