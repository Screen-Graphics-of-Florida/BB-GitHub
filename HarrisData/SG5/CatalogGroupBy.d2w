%INCLUDE "catalog.icl"

%HTML(UPDATE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @Concat_Field("@@ex01", excl1)
  @Concat_Field("@@ex02", excl2)
  @Concat_Field("@@ex03", excl3)
  @Concat_Field("@@ex04", excl4)
  @Concat_Field("@@ex05", excl5)
  @Concat_Field("@@ex06", excl6)
  @Concat_Field("@@ex07", excl7)
  @Concat_Field("@@ex08", excl8)
  @Concat_Field("@@ex09", excl9)
  @Concat_Field("@@ex10", excl10)
  @Concat_Field("@@vk01", vrky1)
  @Concat_Field("@@vk02", vrky2)
  @Concat_Field("@@vk03", vrky3)
  @Concat_Field("@@vk04", vrky4)
  @Concat_Field("@@vk05", vrky5)
  @Concat_Field("@@vk06", vrky6)
  @Concat_Field("@@vk07", vrky7)
  @Concat_Field("@@vk08", vrky8)
  @Concat_Field("@@vk09", vrky9)
  @Concat_Field("@@vk10", vrky10)
  @dtw_concat(edtVar, "}{", edtVar)

  @Update_Exclusion (profileHandle, dataBaseID, catalog, recordSequence, edtVar)

  @dtw_assign(START_ROW_NUM,  "$(updateRowNum)")
  @Set_SQL(stmtSQL)
%}

%HTML(PROCESS) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(maintCode, "R")
  @Catalog_Selection(profileHandle, dataBaseID, maintCode, catalog, recordSequence, orderSequence, selectDesc, newPage, selectGroupBy, selectCriteria)

  @dtw_assign(selectRecSQL, "WHERE IWIWAC=' ' and IMPTYP<>'B' and IMPTYP<>'S' and IXCDYN<>'N' ")
  @dtw_assign(selectGroupWork, "")
  @dtw_assign(groupBy, "")
  @Build_SQL("IXCTG1", "A")
  @Build_SQL("IXCTG2", "A")
  @Build_SQL("IXCTG3", "A")
  @Build_SQL("IXCTG4", "A")
  @Build_SQL("IXCTG5", "A")
  @Build_SQL("IXUXA1", "A")
  @Build_SQL("IXUXA2", "A")
  @Build_SQL("IXUXA3", "A")
  @Build_SQL("IXUXA4", "A")
  @Build_SQL("IXUXA5", "A")
  @Build_SQL("IXUXN1", "N")
  @Build_SQL("IXUXN2", "N")
  @Build_SQL("IXUXN3", "N")
  @Build_SQL("IXUXN4", "N")
  @Build_SQL("IXUXN5", "N")
  @Build_SQL("IXUXD1", "I")
  @Build_SQL("IXUXD2", "I")
  @Build_SQL("IXUXD3", "I")
  @Build_SQL("IXUXD4", "I")
  @Build_SQL("IXUXD5", "I")
  @Build_SQL("IMUDA1", "A")
  @Build_SQL("IMUDA2", "A")
  @Build_SQL("IMUDA3", "A")
  @Build_SQL("IMUDA4", "A")
  @Build_SQL("IMUDA5", "A")
  @Build_SQL("IMUDN1", "N")
  @Build_SQL("IMUDN2", "N")
  @Build_SQL("IMUDN3", "N")
  @Build_SQL("IMUDN4", "N")
  @Build_SQL("IMUDN5", "N")
  @Build_SQL("IMPCLS", "A")
  @Build_SQL("IWPGRP", "A")
  @Build_SQL("IMITC", "A")
  @Build_SQL("IWWHS", "N")
  @Build_SQL("IMITEM", "A")
  @Build_SQL("IMIMDS", "A")

  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, groupBy)
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
	
  @Set_SQL(stmtSQL)
%}

%HTML(SAVE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(maintCode, "U")
  @Catalog_Selection(profileHandle, dataBaseID, maintCode, catalog, recordSequence, orderSequence, selectDesc, newPage, selectGroupBy, selectCriteria)
  @Format_ConfMsg_Desc("C", $(selectDesc), "", "", "", "", "", confMessage)
  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)CatalogSequence.d2w/SELECT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

