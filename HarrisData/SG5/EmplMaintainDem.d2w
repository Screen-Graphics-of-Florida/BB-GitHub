%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "Employee.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Employee Demographics Maintenance"
  d2wName                 = "EmplMaintainDem.d2w"
  d2wVarBase              = "$(genericVarBase)$(employeeVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;reportName=@dtw_rurlescseq(reportName)&amp;maintenanceCode=D"
  deactivateURL           = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;reportName=@dtw_rurlescseq(reportName)&amp;maintenanceCode=Y"
  programName             = "HHREMU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  dataType                = "SSNO"
  modeD                   = "D"
  modeI                   = "I"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              @RtvFldDesc("PRU1DS<>' '", "PRCTRL", "PRU1DS", UDF1)
              @RtvFldDesc("PRU2DS<>' '", "PRCTRL", "PRU2DS", UDF2)
              @RtvFldDesc("PRU3DS<>' '", "PRCTRL", "PRU3DS", UDF3)
              @RtvFldDesc("PRU4DS<>' '", "PRCTRL", "PRU4DS", UDF4)
              @RtvFldDesc("PRU5DS<>' '", "PRCTRL", "PRU5DS", UDF5)
              @RtvFldDesc("PRU6DS<>' '", "PRCTRL", "PRU6DS", UDF6)
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  function validate(chgForm) {
                      %if (prEmployee != "99999")
                          if (
                              document.Chg.reportName.value =="" ||
                              document.Chg.lastName.value =="" ||
                              document.Chg.firstName.value =="" ||
                              document.Chg.addressOne.value =="" ||
                              document.Chg.city.value =="" ||
                              document.Chg.zipCode.value =="" ||
                              document.Chg.country.value =="" ||
                              document.Chg.citizen.value =="" ||
                              document.Chg.dateOfBirth.value =="" ||
                              document.Chg.maritalStatus.value =="" ||
                              document.Chg.gender.value =="" ||
                              document.Chg.hireDate.value =="" ||
                              document.Chg.startDate.value =="" ||
                              document.Chg.department.value =="" ||
                              document.Chg.jobCode.value =="" ||
                              document.Chg.eeoCategory.value =="" ||
                              document.Chg.standardAnnualHours.value =="")
                          {alert("$(reqFieldError)"); return false;}
                      %endif
                      if (
                          editNumPos(document.Chg.socSecNumber, 9, 0) &&
                          editNum(document.Chg.numberOfDependents, 2, 0) &&
                          editNum(document.Chg.homePhone, 10, 0) &&
                          editNum(document.Chg.eeoCategory, 2, 3) &&
                          editNum(document.Chg.schedule, 3, 0) &&
                          editNum(document.Chg.plantNumber, 3, 0) &&
                          editNum(document.Chg.groupNumber, 5, 0) &&
                          editNum(document.Chg.standardAnnualHours, 4, 0) &&
                          editdate(document.Chg.dateOfBirth) &&
                          editdate(document.Chg.hireDate) &&
                          editdate(document.Chg.startDate) &&
                          editdate(document.Chg.seniorityDate)
                          %if($(UDF1) != "")
                              && editNum(document.Chg.userField1, 7, 2)
                          %endif
                          %if($(UDF2) != "")
                              && editNum(document.Chg.userField2, 7, 2)
                          %endif
                          %if($(UDF3) != "")
                              && editNum(document.Chg.userField3, 7, 2)
                          %endif
                          )
                      return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
	           %INCLUDE "numedit.icl"
                  %INCLUDE "dateedit.icl"
                  %INCLUDE "calendar.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "EMPLMAINTAINDEM")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          @dtw_concat(stmtSQL, "SELECT *", stmtSQL)
                          @dtw_concat(stmtSQL, " FROM HREMPL ", stmtSQL)
                          @dtw_concat(stmtSQL, " WHERE EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMPECP=$(hrCompany) and EMEMPL=$(prEmployee) and EMPEMP=$(hrEmployee)", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if(maintenanceCode == "")
          @dtw_assign(maintenanceCode, "C")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      <table $(contentTable)>
	       <colgroup>
	           <col width="80%">
	           <col width="15%">
          <tr><td align="justify"><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  @dtw_assign(sec_03, "")
                  @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMTSUS", DEMPROFILE)
                  <a href="javascript:check(document.Chg)">$(acceptImageMed)</a>
                  %if (DEMPROFILE != "DEFAULT")
                      <a href="javascript:history.back()">$(cancelImageMed)</a>
                  %endif
                  %if (sec_03 == "Y" && maintenanceCode == "C")
                      <a onClick="return confirmDelete()" href="$(deleteURL)">$(deleteImageMed)</a>
                  %endif
                  %if (DEMPROFILE == "DEFAULT")
                      <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)EmplMaintainDem.d2w/Edit_Data$(d2wVarBase)&amp;maintenanceCode=D">$(deleteImageMed)</a>
                  %endif
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>
      <table $(contentTable)>
	   <colgroup>
	       <col width="80%">
	       <col width="15%">
          @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
          <tr><td><h2>$(F_EmpName)</h2></td></tr>
      </table>
      $(hrTagAttr)

      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"		

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;SSWarningFlag=@dtw_rurlescseq(SSWarningFlag)&amp;EEOWarningFlag=@dtw_rurlescseq(EEOWarningFlag)">
          <table $(contentTable)>
              %ROW {

                  %if (prEmployee == "99999")
                      @dtw_assign(reqFieldChar, "")
                  %endif
                  %if (errFound != "")
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@comp", "prCompany")           @dtw_assign(Err_EMCOMP, fieldValue)
                      @DecatErr_Field("@@facl", "prFacility")          @dtw_assign(Err_EMFACL, fieldValue)
                      @DecatErr_Field("@@empl", "prEmployee")          @dtw_assign(Err_EMEMPL, fieldValue)
                      @DecatErr_Field("@@pecp", "hrCompany")           @dtw_assign(Err_EMPECP, fieldValue)
                      @DecatErr_Field("@@pemp", "hrEmployee")          @dtw_assign(Err_EMPEMP, fieldValue)
                      @DecatErr_Field("@@rnam", "reportName")          @dtw_assign(Err_EMRNAM, fieldValue)
                      @DecatErr_Field("@@lnam", "lastName")            @dtw_assign(Err_EMLNAM, fieldValue)
                      @DecatErr_Field("@@fnam", "firstName")           @dtw_assign(Err_EMFNAM, fieldValue)
                      @DecatErr_Field("@@midi", "middleInitial")       @dtw_assign(Err_EMMIDI, fieldValue)
                      @DecatErr_Field("@@adr1", "addressOne")          @dtw_assign(Err_EMADR1, fieldValue)
                      @DecatErr_Field("@@adr2", "addressTwo")          @dtw_assign(Err_EMADR2, fieldValue)
                      @DecatErr_Field("@@city", "city")                @dtw_assign(Err_EMCITY, fieldValue)
                      @DecatErr_Field("@@stat", "state")               @dtw_assign(Err_EMSTAT, fieldValue)
                      @DecatErr_Field("@@zip@", "zipCode")             @dtw_assign(Err_EMZIP,  fieldValue)
                      @DecatErr_Field("@@cntr", "country")             @dtw_assign(Err_EMCNTR, fieldValue)
                      @DecatErr_Field("@@prov", "canadianProvince")    @dtw_assign(Err_EMPROV, fieldValue)
                      @DecatErr_Field("@@phon", "homePhone")           @dtw_assign(Err_EMPHON, fieldValue)
                      @DecatErr_Field("@@loc@", "location")            @dtw_assign(Err_EMLOC,  fieldValue)
                      @DecatErr_Field("@@dept", "department")          @dtw_assign(Err_EMDEPT, fieldValue)
                      @DecatErr_Field("@@dob@", "dateOfBirth")         @dtw_assign(Err_EMDOB,  fieldValue)
                      @DecatErr_Field("@@ssno", "socSecNumber")        @dtw_assign(Err_EMSSNO, fieldValue)
                      @DecatErr_Field("@@sssf", "socSecSuffix")        @dtw_assign(Err_EMSSSF, fieldValue)
                      @DecatErr_Field("@@gndr", "gender")              @dtw_assign(Err_EMGNDR, fieldValue)
                      @DecatErr_Field("@@msta", "maritalStatus")       @dtw_assign(Err_EMMSTA, fieldValue)
                      @DecatErr_Field("@@nodp", "numberOfDependents")  @dtw_assign(Err_EMNODP, fieldValue)
                      @DecatErr_Field("@@hire", "hireDate")            @dtw_assign(Err_EMHIRE, fieldValue)
                      @DecatErr_Field("@@strt", "startDate")           @dtw_assign(Err_EMSTRT, fieldValue)
                      @DecatErr_Field("@@senr", "seniorityDate")       @dtw_assign(Err_EMSENR, fieldValue)
                      @DecatErr_Field("@@ctzn", "citizen")             @dtw_assign(Err_EMCTZN, fieldValue)
                      @DecatErr_Field("@@alrg", "alienRegNumber")      @dtw_assign(Err_EMALRG, fieldValue)
                      @DecatErr_Field("@@job@", "jobCode")             @dtw_assign(Err_EMJOB,  fieldValue)
                      @DecatErr_Field("@@eeo@", "eeoCategory")         @dtw_assign(Err_EMEEO,  fieldValue)
                      @DecatErr_Field("@@uncd", "union")               @dtw_assign(Err_EMUNCD, fieldValue)
                      @DecatErr_Field("@@unmn", "unionMemNumber")      @dtw_assign(Err_EMUNMN, fieldValue)
                      @DecatErr_Field("@@shft", "shift")               @dtw_assign(Err_EMSHFT, fieldValue)
                      @DecatErr_Field("@@anhr", "standardAnnualHours") @dtw_assign(Err_EMANHR, fieldValue)
                      @DecatErr_Field("@@schd", "schedule")            @dtw_assign(Err_EMSCHD, fieldValue)
                      @DecatErr_Field("@@plnt", "plantNumber")         @dtw_assign(Err_EMPLNT, fieldValue)
                      @DecatErr_Field("@@mdpt", "mfgDepartment")       @dtw_assign(Err_EMMDPT, fieldValue)
                      @DecatErr_Field("@@wc@@", "workCenter")          @dtw_assign(Err_EMWC,   fieldValue)
                      @DecatErr_Field("@@hgrp", "groupNumber")         @dtw_assign(Err_EMHGRP, fieldValue)
                      @DecatErr_Field("@@usr1", "userField1")          @dtw_assign(Err_EMUSR1, fieldValue)
                      @DecatErr_Field("@@usr2", "userField2")          @dtw_assign(Err_EMUSR2, fieldValue)
                      @DecatErr_Field("@@usr3", "userField3")          @dtw_assign(Err_EMUSR3, fieldValue)
                      @DecatErr_Field("@@usr4", "userField4")          @dtw_assign(Err_EMUSR4, fieldValue)
                      @DecatErr_Field("@@usr5", "userField5")          @dtw_assign(Err_EMUSR5, fieldValue)
                      @DecatErr_Field("@@usr6", "userField6")          @dtw_assign(Err_EMUSR6, fieldValue)
                      @DecatErr_Field("@@tstp", "timeStamp")           @dtw_assign(Err_TSTP, fieldValue)

                      @Decat_Field("@@comp")    @dtw_assign(V_EMCOMP, fieldValue)
                      @Decat_Field("@@facl")    @dtw_assign(V_EMFACL, fieldValue)
                      @Decat_Field("@@empl")    @dtw_assign(V_EMEMPL, fieldValue)
                      @Decat_Field("@@pecp")    @dtw_assign(V_EMPECP, fieldValue)
                      @Decat_Field("@@pemp")    @dtw_assign(V_EMPEMP, fieldValue)
                      @Decat_Field("@@rnam")    @dtw_assign(V_EMRNAM, fieldValue)
                      @Decat_Field("@@lnam")    @dtw_assign(V_EMLNAM, fieldValue)
                      @Decat_Field("@@fnam")    @dtw_assign(V_EMFNAM, fieldValue)
                      @Decat_Field("@@midi")    @dtw_assign(V_EMMIDI, fieldValue)
                      @Decat_Field("@@adr1")    @dtw_assign(V_EMADR1, fieldValue)
                      @Decat_Field("@@adr2")    @dtw_assign(V_EMADR2, fieldValue)
                      @Decat_Field("@@city")    @dtw_assign(V_EMCITY, fieldValue)
                      @Decat_Field("@@stat")    @dtw_assign(V_EMSTAT, fieldValue)
                      @Decat_Field("@@zip@")    @dtw_assign(V_EMZIP,  fieldValue)
                      @Decat_Field("@@cntr")    @dtw_assign(V_EMCNTR, fieldValue)
                      @Decat_Field("@@prov")    @dtw_assign(V_EMPROV, fieldValue)
                      @Decat_Field("@@phon")    @dtw_assign(V_EMPHON, fieldValue)
                      @Decat_Field("@@loc@")    @dtw_assign(V_EMLOC,  fieldValue)
                      @Decat_Field("@@dept")    @dtw_assign(V_EMDEPT, fieldValue)
                      @Decat_Field("@@dob@")    @dtw_assign(V_EMDOB,  fieldValue)
                      @Decat_Field("@@ssno")    @dtw_assign(V_EMSSNO, fieldValue)
                      @Decat_Field("@@sssf")    @dtw_assign(V_EMSSSF, fieldValue)
                      @Decat_Field("@@gndr")    @dtw_assign(V_EMGNDR, fieldValue)
                      @Decat_Field("@@msta")    @dtw_assign(V_EMMSTA, fieldValue)
                      @Decat_Field("@@nodp")    @dtw_assign(V_EMNODP, fieldValue)
                      @Decat_Field("@@hire")    @dtw_assign(V_EMHIRE, fieldValue)
                      @Decat_Field("@@strt")    @dtw_assign(V_EMSTRT, fieldValue)
                      @Decat_Field("@@senr")    @dtw_assign(V_EMSENR, fieldValue)
                      @Decat_Field("@@ctzn")    @dtw_assign(V_EMCTZN, fieldValue)
                      @Decat_Field("@@alrg")    @dtw_assign(V_EMALRG, fieldValue)
                      @Decat_Field("@@job@")    @dtw_assign(V_EMJOB,  fieldValue)
                      @Decat_Field("@@eeo@")    @dtw_assign(V_EMEEO,  fieldValue)
                      @Decat_Field("@@uncd")    @dtw_assign(V_EMUNCD, fieldValue)
                      @Decat_Field("@@unmn")    @dtw_assign(V_EMUNMN, fieldValue)
                      @Decat_Field("@@shft")    @dtw_assign(V_EMSHFT, fieldValue)
                      @Decat_Field("@@anhr")    @dtw_assign(V_EMANHR, fieldValue)
                      @Decat_Field("@@schd")    @dtw_assign(V_EMSCHD, fieldValue)
                      @Decat_Field("@@plnt")    @dtw_assign(V_EMPLNT, fieldValue)
                      @Decat_Field("@@mdpt")    @dtw_assign(V_EMMDPT, fieldValue)
                      @Decat_Field("@@wc@@")    @dtw_assign(V_EMWC,   fieldValue)
                      @Decat_Field("@@hgrp")    @dtw_assign(V_EMHGRP, fieldValue)
                      @Decat_Field("@@usr1")    @dtw_assign(V_EMUSR1, fieldValue)
                      @Decat_Field("@@usr2")    @dtw_assign(V_EMUSR2, fieldValue)
                      @Decat_Field("@@usr3")    @dtw_assign(V_EMUSR3, fieldValue)
                      @Decat_Field("@@usr4")    @dtw_assign(V_EMUSR4, fieldValue)
                      @Decat_Field("@@usr5")    @dtw_assign(V_EMUSR5, fieldValue)
                      @Decat_Field("@@usr6")    @dtw_assign(V_EMUSR6, fieldValue)
                      @Decat_Field("@@tstp")    @dtw_assign(V_EMTSTP, fieldValue)

                      @dtw_assign(errFound, "")

                  %else

                  	  %if (V_EMSSNO != "" && V_EMSSNO != "000000000")
                  	  	  	
                  	      @RtvColVal("EMEMID='$(V_EMEMID)'", "HREMPL", "(EMSSNO)", "I", xsocsec)
                          @dtw_assign(V_H1SSEN, xsocsec)

                          @RtvColVal("EMEMID='$(V_EMEMID)'", "HREMPL", "(EMSSNO)", "D", xsocsec)
                          @dtw_assign(V_EMSSNO, xsocsec)

                      %endif

                      @dtw_assign(focusField, "reportName")
                      @DateBirthFromCYMD(V_EMDOB)
                      @DateInputFromCYMD(V_EMHIRE)
                      @DateInputFromCYMD(V_EMSTRT)
                      @DateInputFromCYMD(V_EMSENR)
                  %endif

                  @SetTextOvr(Err_TSTP)
                  <tr><td class="dsphdr"><span $(textOvr)>.</span></td>
                  	  <td><input name="timeStamp" type="hidden" value="$(V_EMTSTP)"></td>
                  </tr>
                  @DspErrMsg(Err_TSTP)

                  <tr><td class="dsphdr">Company/Facility</td>
                      @Format_HRCoFac("$(V_EMCOMP)", "$(V_EMFACL)", "", F_CoFac)
                      @Format_Code(F_CoFac, F2_CoFac)
                      @RetHrCompNam(profileHandle, dataBaseID, prCompany, prFacility, coFacName)
                      <td class="dspalph">$(coFacName)</td>
                      <td class="dspalph">$(F2_CoFac)</td>
                  </tr>
                  <tr><td class="dsphdr"><span $(textOvr)>Employee Number</span></td>
                      <td class="dspalph">$(prEmployee)</td>
                  </tr>

                  <tr><td class="dsphdr"><span $(textOvr)>H/R Company Number</span></td>
                      <td class="dspalph">$(hrCompany)</td>
                  </tr>

                  <tr><td class="dsphdr"><span $(textOvr)>H/R Employee Number</span></td>
                      <td class="dspalph">$(hrEmployee)</td>
                  </tr>

                  @SetTextOvr(Err_EMRNAM)
                  <tr><td class="dsphdr"><span $(textOvr)>Report Name</span></td>
                      <td class="inputalph"><input name="reportName" type="text" value="$(V_EMRNAM)" size="23" maxlength="23"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_EMRNAM)
                  			
                  @SetTextOvr(Err_EMLNAM)
                  <tr><td class="dsphdr"><span $(textOvr)>Last Name</span></td>
                      <td class="inputalph"><input name="lastName" type="text" value="$(V_EMLNAM)" size="18" maxlength="18"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_EMLNAM)

                  @SetTextOvr(Err_EMFNAM)
                  <tr><td class="dsphdr"><span $(textOvr)>First Name</span></td>
                      <td class="inputalph"><input name="firstName" type="text" value="$(V_EMFNAM)" size="18" maxlength="18"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_EMFNAM)

                  @SetTextOvr(Err_EMMIDI)
                  <tr><td class="dsphdr"><span $(textOvr)>Middle Initial</span></td>
                      <td class="inputalph"><input name="middleInitial" type="text" value="$(V_EMMIDI)" size="1" maxlength="1"> </td>
                  </tr>
                  @DspErrMsg(Err_EMMIDI)

                  @SetTextOvr(Err_EMADR1)
                  <tr><td class="dsphdr"><span $(textOvr)>Address 1</span></td>
                      <td class="inputalph"><input name="addressOne" type="text" value="$(V_EMADR1)" size="30" maxlength="30"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_EMADR1)

                  @SetTextOvr(Err_EMADR2)
                  <tr><td class="dsphdr"><span $(textOvr)>Address 2</span></td>
                      <td class="inputalph"><input name="addressTwo" type="text" value="$(V_EMADR2)" size="30" maxlength="30"> </td>
                  </tr>
                  @DspErrMsg(Err_EMADR2)

                  @SetTextOvr(Err_EMCITY)
                  <tr><td class="dsphdr"><span $(textOvr)>City</span></td>
                      <td class="inputalph"><input name="city" type="text" value="$(V_EMCITY)" size="16" maxlength="16"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_EMCITY)

                  @RtvFldDesc("STID='$(V_EMSTAT)'", "PRSTID", "CHAR(STDESC)", stateDesc)
                  @SetTextOvr(Err_EMSTAT)
                  <tr><td class="dsphdr"><span $(textOvr)>State</span></td>
                      <td class="inputalph"><input name="state" type="text" value="$(V_EMSTAT)" size="3" maxlength="2"><a href="$(homeURL)$(cGIPath)StateSearchHr.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=state&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stateDesc" value="$(stateDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_EMSTAT)

                  @SetTextOvr(Err_EMPROV)
                  <tr><td class="dsphdr"><span $(textOvr)>Canadian Province</span></td>
                      <td class="inputalph"><input name="canadianProvince" type="text" value="$(V_EMPROV)" size="3" maxlength="2"></td>
                  </tr>
                  @DspErrMsg(Err_EMPROV)

                  @SetTextOvr(Err_EMZIP)
                  <tr><td class="dsphdr"><span $(textOvr)>Zip Code</span></td>
                      <td class="inputalph"><input name="zipCode" type="text" value="$(V_EMZIP)" size="10" maxlength="10"> $(reqFieldChar)  </td>
                  </tr>
                  @DspErrMsg(Err_EMZIP)

                  @SetTextOvr(Err_EMCNTR)
                  <tr><td class="dsphdr"><span $(textOvr)>Country</span></td>
                      <td class="inputalph"><input name="country" type="text" value="$(V_EMCNTR)" size="2" maxlength="2"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_EMCNTR)

                  @SetTextOvr(Err_EMPHON)
                  <tr><td class="dsphdr"><span $(textOvr)>Home Phone Number</span></td>
                      <td class="inputnmbr"><input name="homePhone" type="text" value="$(V_EMPHON)" size="10" maxlength="10"> </td>
                  </tr>
                  @DspErrMsg(Err_EMPHON)

                  @RtvFldDesc("ODCOMP=$(V_EMPECP) and ODTYPE='O' and ODCODE='$(V_EMLOC)' ", "PECODE", "CHAR(ODDESC)", codeDesc)
                  @SetTextOvr(Err_EMLOC)
                  <tr><td class="dsphdr"><span $(textOvr)>Location</span></td>
                      <td class="inputalph"><input name="location" type="text" value="$(V_EMLOC)" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Chg&amp;fldComp=@dtw_rurlescseq(hrCompany)&amp;fldType=O&amp;fldName=location&amp;fldDesc=LocationDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="LocationDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                  </tr>
                  @DspErrMsg(Err_EMLOC)

                  @RtvFldDesc("EADEPT='$(V_EMDEPT)' ", "PREXAC", "EANAME", deptDesc)
                  @SetTextOvr(Err_EMDEPT)
                  <tr><td class="dsphdr"><span $(textOvr)>Department</span></td>
                      <td class="inputalph"><input name="department" type="text" value="$(V_EMDEPT)" size="5" maxlength="5"> <a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=department&amp;fldDesc=deptDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="deptDesc" value="$(deptDesc)"  type="hidden" size="20" maxlength="20"></td>
                  </tr>
                  @DspErrMsg(Err_EMDEPT)

                  @SetTextOvr(Err_EMDOB)
	           <tr><td class="dsphdr"><span $(textOvr)>Date Of Birth</span></td>
                      <td class="inputnmbr"><input type="text" name="dateOfBirth" value="$(V_EMDOB)" size="6" maxlength="6"> 		
                          <a href="javascript:calWindow('dateOfBirth');"> $(reqFieldChar) $(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_EMDOB)

                  @SetTextOvr(Err_EMSSNO)
                  %while(@dtw_rlength(V_EMSSNO) != "9") {@dtw_insert("0", V_EMSSNO, V_EMSSNO)%}
                  <tr><td class="dsphdr"><span $(textOvr)>Social Security Number</span></td>
                      <td class="inputnmbr"><input name="socSecNumber" type="text" value="$(V_EMSSNO)" size="9" maxlength="9"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_EMSSNO)

                  @SetTextOvr(Err_EMSSSF)
                  <tr><td class="dsphdr"><span $(textOvr)>Social Security Suffix</span></td>
                      <td class="inputalph"><input name="socSecSuffix" type="text" value="$(V_EMSSSF)" size="1" maxlength="1"> </td>
                  </tr>
                  @DspErrMsg(Err_EMSSSF)

                  @SetTextOvr(Err_EMGNDR)
                  <tr><td class="dsphdr"><span $(textOvr)>Gender</span></td>
                      @dtw_tb_rows(genderTable, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(genderTable, x, "1") != V_EMGNDR) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(genderTable, "gender", "2", "1", "N", "", x, "1")  $(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_EMGNDR)
                  	   		
                  @SetTextOvr(Err_EMMSTA)
                  <tr><td class="dsphdr"><span $(textOvr)>Marital Status</span></td>
                      @dtw_tb_rows(maritalStsTable, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(maritalStsTable, x, "1") != V_EMMSTA) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(maritalStsTable, "maritalStatus", "2", "1", "N", "", x, "1")  $(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_EMMSTA)
                  	
                  @SetTextOvr(Err_EMNODP)
                  <tr><td class="dsphdr"><span $(textOvr)>Number Of Dependents</span></td>
                      <td class="inputnmbr"><input name="numberOfDependents" type="text" value="$(V_EMNODP)" size="2" maxlength="2"> </td>
                  </tr>
                  @DspErrMsg(Err_EMNODP)

                  @SetTextOvr(Err_EMHIRE)
	              <tr><td class="dsphdr"><span $(textOvr)>Hire Date</span></td>
                  %if (DEMPROFILE == "DEFAULT" || prEmployee == "99999")
	                <td class="inputnmbr"><input type="text" name="hireDate" value="$(V_EMHIRE)" size="6" maxlength="6"> 		
                          <a href="javascript:calWindow('hireDate');"> $(reqFieldChar) $(calendarImage)</a></td>
                  %else
                    @dtw_assign(F_EMHIRE, V_EMHIRE)
                    @DateMDYCYMD(F_EMHIRE)
                    @Format_Date(F_EMHIRE, "H", F_EMHIRE)
	                <td class="inputnmbr">$(F_EMHIRE)<input type="hidden" name="hireDate" value="$(V_EMHIRE)" size="6" maxlength="6"></td>
                  %endif                    
                  </tr>
                  @DspErrMsg(Err_EMHIRE)

                  @SetTextOvr(Err_EMSTRT)
	           <tr><td class="dsphdr"><span $(textOvr)>Start Date</span></td>
                      <td class="inputnmbr"><input type="text" name="startDate" value="$(V_EMSTRT)" size="6" maxlength="6"> 		
                          <a href="javascript:calWindow('startDate');"> $(reqFieldChar) $(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_EMSTRT)

                  @SetTextOvr(Err_EMSENR)
	           <tr><td class="dsphdr"><span $(textOvr)>Seniority Date</span></td>
                      <td class="inputnmbr"><input type="text" name="seniorityDate" value="$(V_EMSENR)" size="6" maxlength="6"> 		
                          <a href="javascript:calWindow('seniorityDate');"> $(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_EMSENR)

                  @RtvFldDesc("FLTYPE='CITIZENSHP' and FLVALU='$(V_EMCTZN)'", "SYFLAG", "FLDESC", fieldCitizenDesc)
                  @SetTextOvr(Err_EMCTZN)
                  <tr><td class="dsphdr"><span $(textOvr)>Citizenship</span></td>
                      <td class="inputalph"><input name="citizen" type="text" value="$(V_EMCTZN)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=CITIZENSHP&amp;flagSrchHdr=Citizen&amp;docName=Chg&amp;fldName=citizen&amp;fldDesc=citizenDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage)</a>
                          <input name="citizenDesc" value="$(fieldCitizenDesc)" type="text" size="25" disabled></td>
                      @DspErrMsg(Err_EMCTZN)
                  </tr>

                  @SetTextOvr(Err_EMALRG)
                  <tr><td class="dsphdr"><span $(textOvr)>Alien Registration Number</span></td>
                      <td class="inputalph"><input type="text" name="alienRegNumber" value="$(V_EMALRG)" size="10" maxlength="10"></td>
                  </tr>
                  @DspErrMsg(Err_EMALRG)

                  @RtvFldDesc("ODCOMP=$(V_EMPECP) and ODTYPE='J' and ODCODE='$(V_EMJOB)' ", "PECODE", "CHAR(ODDESC)", codeDesc)
                  @SetTextOvr(Err_EMJOB)
                  <tr><td class="dsphdr"><span $(textOvr)>Job Code</span></td>
                      <td class="inputalph"><input name="jobCode" type="text" value="$(V_EMJOB)" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Chg&amp;fldComp=@dtw_rurlescseq(hrCompany)&amp;fldType=J&amp;fldName=jobCode&amp;fldDesc=JobCodeDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="JobCodeDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                  </tr>
                  @DspErrMsg(Err_EMJOB)

                  @dtw_assign(T_EEO, "")
                  @CvtEEO(V_EMEEO, T_EEO)
                  @RtvFldDesc("ODCOMP=$(V_EMPECP) and ODTYPE='Y' and ODCODE='$(T_EEO)' ", "PECODE", "CHAR(ODDESC)", eeoDesc)
                  @SetTextOvr(Err_EMEEO)
                  <tr><td class="dsphdr"><span $(textOvr)>EEO-1 Job Category</span></td>
                      <td class="inputnmbr"><input name="eeoCategory" type="text" value="$(V_EMEEO)" size="6" maxlength="6"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Chg&amp;fldComp=@dtw_rurlescseq(hrCompany)&amp;fldType=Y&amp;fldName=eeoCategory&amp;fldDesc=eeoDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="eeoDesc" value="$(eeoDesc)"  type="text" size="20" maxlength="20">  </td>
                  </tr>
                  @DspErrMsg(Err_EMEEO)

                  @RtvFldDesc("ODCOMP=$(V_EMPECP) and ODTYPE='U' and ODCODE='$(V_EMUNCD)' ", "PECODE", "CHAR(ODDESC)", codeDesc)
                  @SetTextOvr(Err_EMUNCD)
                  <tr><td class="dsphdr"><span $(textOvr)>Union</span></td>
                      <td class="inputalph"><input name="union" type="text" value="$(V_EMUNCD)" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Chg&amp;fldComp=@dtw_rurlescseq(hrCompany)&amp;fldType=U&amp;fldName=union&amp;fldDesc=unionDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="unionDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                  </tr>
                  @DspErrMsg(Err_EMUNCD)

                  @SetTextOvr(Err_EMUNMN)
                  <tr><td class="dsphdr"><span $(textOvr)>Union Membership Number</span></td>
                      <td class="inputalph"><input name="unionMemNumber" type="text" value="$(V_EMUNMN)" size="8" maxlength="8"></td>
                  </tr>
                  @DspErrMsg(Err_EMUNMN)

                  @RtvFldDesc("PPCOMP=$(V_EMCOMP) and PPFACL=$(V_EMFACL) and PPDEPT='$(V_EMDEPT)' and PPSHFT='$(V_EMSHFT)' ", "PRPREM", "CHAR(PPDESC)", codeDesc)
                  %if (shiftDesc =="")
                      @RtvFldDesc("PPCOMP=$(V_EMCOMP) and PPFACL=$(V_EMFACL) and PPDEPT=' ' and PPSHFT='$(V_EMSHFT)' ", "PRPREM", "CHAR(PPDESC)", codeDesc)
                  %endif
                  @SetTextOvr(Err_EMSHFT)
                  <tr><td class="dsphdr"><span $(textOvr)>Shift</span></td>
                      <td class="inputalph"><input name="shift" type="text" value="$(V_EMSHFT)" size="2" maxlength="2"> <a href="$(homeURL)$(cGIPath)ShiftSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Chg&amp;fldName=shift&amp;fldDesc=shiftDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="shiftDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                  </tr>
                  @DspErrMsg(Err_EMSHFT)

                  @SetTextOvr(Err_EMANHR)
                  <tr><td class="dsphdr"><span $(textOvr)>Standard Annual Hours</span></td>
                      <td class="inputnmbr"><input type="text" name="standardAnnualHours" value="$(V_EMANHR)" size="4" maxlength="4"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_EMANHR)

                  @RtvFldDesc("SMSCHD=$(V_EMSCHD)", "HDSCHM", "SMDESC", fieldDesc)
                  @SetTextOvr(Err_EMSCHD)
                  <tr><td class="dsphdr"><span $(textOvr)>Schedule</span></td>
                      <td class="inputnmbr"><input name="schedule" type="text" value="$(V_EMSCHD)" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)ScheduleSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=schedule&amp;fldDesc=scheduleDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="scheduleDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_EMSCHD)

                  @RtvFldDesc("PLPLNT=$(V_EMPLNT)", "HDPLNT", "PLNAME", fieldDesc)
                  @SetTextOvr(Err_EMPLNT)
                  <tr><td class="dsphdr"><span $(textOvr)>Home Plant Number</span></td>
                      <td class="inputnmbr"><input name="plantNumber" type="text" value="$(V_EMPLNT)" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=plantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName" value="$(fieldDesc)" type="text" size="30" disabled></td>
                  </tr>
                  @DspErrMsg(Err_EMPLNT)

                  @dtw_assign(deptwcDesc, "")
                  @RtvFldDesc("WCPLT=$(V_EMPLNT) and WCDEPT='$(V_EMMDPT)' and WCWC='$(V_EMWC)'", "HDMWCM", "WCDESC", deptwcDesc)
                  @SetTextOvr(Err_EMMDPT)
                  <tr><td class="dsphdr"><span $(textOvr)>Mfg Department / Work Center</span></td>
                      <td class="inputalph"><input name="mfgDepartment" value="$(V_EMMDPT)" type="text" size="5" maxlength="5"> / <input name="workCenter" value="$(V_EMWC)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(plantNumber)&amp;docName=Chg&amp;fldPlant=plantNumber&amp;fldPltName=plantName&amp;flddept=mfgDepartment&amp;fldWC=workCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">$(searchImage) </a> <input disabled name="WCDesc" value="$(deptwcDesc)"  type="text" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_EMMDPT)

                  @SetTextOvr(Err_EMHGRP)
                  @RtvFldDesc("BBGRP#=$(V_EMHGRP) ", "HDGRPM", "BBDESC", groupName)
                  <tr><td class="dsphdr"><span $(textOvr)>Home Group Number</span></td>
                      <td class="inputnmbr"><input name="groupNumber" VALUE="$(V_EMHGRP)" type="text" size="5" maxlength="5"> <a href="$(homeURL)$(phpPath)GroupNumberSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=groupNumber&amp;fldDesc=groupName" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="groupName" value="$(groupName)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_EMHGRP)

                  @RtvFldDesc("PRU1DS<>' '", "PRCTRL", "PRU1DS", UDF1)
                  @RtvFldDesc("PRU2DS<>' '", "PRCTRL", "PRU2DS", UDF2)
                  @RtvFldDesc("PRU3DS<>' '", "PRCTRL", "PRU3DS", UDF3)
                  @RtvFldDesc("PRU4DS<>' '", "PRCTRL", "PRU4DS", UDF4)
                  @RtvFldDesc("PRU5DS<>' '", "PRCTRL", "PRU5DS", UDF5)
                  @RtvFldDesc("PRU6DS<>' '", "PRCTRL", "PRU6DS", UDF6)
                  %if($(UDF1) != "")
                      @SetTextOvr(Err_EMUSR1)
                      <tr><td class="dsphdr"><span $(textOvr)>$(UDF1)</span></td>
                          <td class="inputnmbr"><input name="userField1" type="text" value="$(V_EMUSR1)" size="9" maxlength="10"></td>
                      </tr>
                      @DspErrMsg(Err_EMUSR1)
                  %endif
                  %if($(UDF2) != "")
                      @SetTextOvr(Err_EMUSR2)
                      <tr><td class="dsphdr"><span $(textOvr)>$(UDF2)</span></td>
                          <td class="inputnmbr"><input name="userField2" type="text" value="$(V_EMUSR2)" size="9" maxlength="10"></td>
                      </tr>
                      @DspErrMsg(Err_EMUSR2)
                  %endif
                  %if($(UDF3) != "")
                      @SetTextOvr(Err_EMUSR3)
                      <tr><td class="dsphdr"><span $(textOvr)>$(UDF3)</span></td>
                          <td class="inputnmbr"><input name="userField3" type="text" value="$(V_EMUSR3)" size="9" maxlength="10"></td>
                      </tr>
                      @DspErrMsg(Err_EMUSR3)
                  %endif
                  %if($(UDF4) != "")
                      @SetTextOvr(Err_EMUSR4)
                      <tr><td class="dsphdr"><span $(textOvr)>$(UDF4)</span></td>
                          <td class="inputnmbr"><input name="userField4" type="text" value="$(V_EMUSR4)" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_EMUSR4)
                  %endif
                  %if($(UDF5) != "")
                      @SetTextOvr(Err_EMUSR5)
                      <tr><td class="dsphdr"><span $(textOvr)>$(UDF5)</span></td>
                          <td class="inputnmbr"><input name="userField5" type="text" value="$(V_EMUSR5)" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_EMUSR5)
                  %endif
                  %if($(UDF6) != "")
                      @SetTextOvr(Err_EMUSR6)
                      <tr><td class="dsphdr"><span $(textOvr)>$(UDF6)</span></td>
                          <td class="inputnmbr"><input name="userField6" type="text" value="$(V_EMUSR6)" size="30" maxlength="30"></td>
                      </tr>
                      @DspErrMsg(Err_EMUSR6)
                  %endif

              %}
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      <table $(contentTable)>
            <tr>
                <td class="toolbar">
                    @dtw_assign(sec_03, "")
                    @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMTSUS", DEMPROFILE)
                    <a href="javascript:check(document.Chg)">$(acceptImageMed)</a>
                    %if (DEMPROFILE != "DEFAULT")
                        <a href="javascript:history.back()">$(cancelImageMed)</a>
                    %endif
                    %if (sec_03 == "Y" && maintenanceCode == "C")
                        <a onClick="return confirmDelete()" href="$(deleteURL)">$(deleteImageMed)</a>
                    %endif
                    %if (DEMPROFILE == "DEFAULT")
                        <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)EmplMaintainDem.d2w/Edit_Data$(d2wVarBase)&amp;maintenanceCode=D">$(deleteImageMed)</a>
                    %endif
                    @dtw_assign(medIcon, "Y")
                    %INCLUDE "HelpPage.icl"
                </td>
            </tr>
      </table>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     SSWarningFlag,
                                        INOUT CHAR(1)     EEOWarningFlag,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHREMD_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (sec_02 == "N")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @gender_Query(profileHandle, dataBaseID, "GENDER    ", genderTable)
          @dtw_tb_insertrow(genderTable, "0", "1")
	   @dtw_tb_setv(genderTable, "", "1", "2")
      @marital_Sts_Query(profileHandle, dataBaseID, "MARITALSTS", maritalStsTable)
          @dtw_tb_insertrow(maritalStsTable, "0", "1")
	   @dtw_tb_setv(maritalStsTable, "", "1", "2")
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
          @dtw_tb_insertrow(yn01Table, "0", "1")
	   @dtw_tb_setv(yn01Table, "", "1", "2")
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(middleInitial)
  @dtw_mUPPERCASE(state)
  @dtw_mUPPERCASE(country)
  @dtw_mUPPERCASE(canadianProvince)
  @dtw_mUPPERCASE(location)
  @dtw_mUPPERCASE(department)
  @dtw_mUPPERCASE(socSecSuffix)
  @dtw_mUPPERCASE(gender)
  @dtw_mUPPERCASE(maritalStatus)
  @dtw_mUPPERCASE(citizen)
  @dtw_mUPPERCASE(alienRegNumber)
  @dtw_mUPPERCASE(jobCode)
  @dtw_mUPPERCASE(union)
  @dtw_mUPPERCASE(unionMemNumber)
  @dtw_mUPPERCASE(shift)
  @dtw_mUPPERCASE(mfgDepartment)
  @dtw_mUPPERCASE(workCenter)
  @dtw_assign(prCompany,@dtw_rstrip(prCompany))
  @dtw_assign(prFacility,@dtw_rstrip(prFacility))
  @dtw_assign(prEmployee,@dtw_rstrip(prEmployee))
  @dtw_assign(hrCompany,@dtw_rstrip(hrCompany))
  @dtw_assign(hrEmployee,@dtw_rstrip(hrEmployee))
  @dtw_assign(dateOfBirth,@dtw_rstrip(dateOfBirth))
  @dtw_assign(socSecNumber,@dtw_rstrip(socSecNumber))
  @dtw_assign(numberOfDependents,@dtw_rstrip(numberOfDependents))
  @dtw_assign(hireDate,@dtw_rstrip(hireDate))
  @dtw_assign(startDate,@dtw_rstrip(startDate))
  @dtw_assign(seniorityDate,@dtw_rstrip(seniorityDate))
  @dtw_assign(eeoCategory,@dtw_rstrip(eeoCategory))
  @dtw_assign(standardAnnualHours,@dtw_rstrip(standardAnnualHours))
  @dtw_assign(schedule,@dtw_rstrip(schedule))
  @dtw_assign(plantNumber,@dtw_rstrip(plantNumber))
  @dtw_assign(groupNumber,@dtw_rstrip(groupNumber))
  @dtw_assign(userField1,@dtw_rstrip(userField1))
  @dtw_assign(userField2,@dtw_rstrip(userField2))
  @dtw_assign(userField3,@dtw_rstrip(userField3))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@comp", prCompany)
  @Concat_Field("@@facl", prFacility)
  @Concat_Field("@@empl", prEmployee)
  @Concat_Field("@@pecp", hrCompany)
  @Concat_Field("@@pemp", hrEmployee)
  @Concat_Field("@@rnam", reportName)
  @Concat_Field("@@lnam", lastName)
  @Concat_Field("@@fnam", firstName)
  @Concat_Field("@@midi", middleInitial)
  @Concat_Field("@@adr1", addressOne)
  @Concat_Field("@@adr2", addressTwo)
  @Concat_Field("@@city", city)
  @Concat_Field("@@stat", state)
  @Concat_Field("@@zip@", zipCode)
  @Concat_Field("@@cntr", country)
  @Concat_Field("@@prov", canadianProvince)
  @Concat_Field("@@phon", homePhone)
  @Concat_Field("@@loc@", location)
  @Concat_Field("@@dept", department)
  @Concat_Field("@@dob@", dateOfBirth)
  @Concat_Field("@@ssno", socSecNumber)
  @Concat_Field("@@sssf", socSecSuffix)
  @Concat_Field("@@gndr", gender)
  @Concat_Field("@@msta", maritalStatus)
  @Concat_Field("@@nodp", numberOfDependents)
  @Concat_Field("@@hire", hireDate)
  @Concat_Field("@@strt", startDate)
  @Concat_Field("@@senr", seniorityDate)
  @Concat_Field("@@ctzn", citizen)
  @Concat_Field("@@alrg", alienRegNumber)
  @Concat_Field("@@job@", jobCode)
  @Concat_Field("@@eeo@", eeoCategory)
  @Concat_Field("@@uncd", union)
  @Concat_Field("@@unmn", unionMemNumber)
  @Concat_Field("@@shft", shift)
  @Concat_Field("@@anhr", standardAnnualHours)
  @Concat_Field("@@schd", schedule)
  @Concat_Field("@@plnt", plantNumber)
  @Concat_Field("@@mdpt", mfgDepartment)
  @Concat_Field("@@wc@@", workCenter)
  @Concat_Field("@@hgrp", groupNumber)
  @Concat_Field("@@usr1", userField1)
  @Concat_Field("@@usr2", userField2)
  @Concat_Field("@@usr3", userField3)
  @Concat_Field("@@usr4", userField4)
  @Concat_Field("@@usr5", userField5)
  @Concat_Field("@@usr6", userField6)
  @Concat_Field("@@tstp", timeStamp)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, SSWarningFlag, EEOWarningFlag, errFound, edtVar, errVar)

  %if (errFound == "")
      @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
      @Format_ConfMsg_Desc(maintenanceCode, $(F_EmpName), $(prEmployee), "Demographics", "", "", "", confMessage)
      %if (maintenanceCode == "D" || maintenanceCode == "Y")
          @Format_ConfMsg_Desc(maintenanceCode, $(F_EmpName), $(prEmployee), "Employee Defaults", "", "", "", confMessage)
          @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
          %if (backURL == "")
              <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=181&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %else
              <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %endif
      %elif (fromD2w != "")
          @Format_ConfMsg_Desc(maintenanceCode, $(F_EmpName), $(prEmployee), "Demographics", "", "", "", confMessage)
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          @Format_ConfMsg_Desc(maintenanceCode, $(F_EmpName), $(prEmployee), "Demographics", "", "", "", confMessage)
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)EmployeeMaintainSelect.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      %if (maintenanceCode != "D" && maintenanceCode != "Y")
          @EdtVarErr(profileHandle, typeValue, edtVar)
          @ErrVarErr(profileHandle, typeError, errVar)
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;SSWarningFlag=@dtw_rurlescseq(SSWarningFlag)&amp;EEOWarningFlag=@dtw_rurlescseq(EEOWarningFlag)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
      %elif (fromD2w != "")
          @DecatErr_Field("@@rnam", "prEmployee")
          @Format_ConfMsg_Desc(maintenanceCode, "Employee", $(prEmployee), "<br>$(fieldValue)", "", "", "", confMessage)
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %elif (maintenanceCode == "Y")
          @DecatErr_Field("@@rnam", "prEmployee")
          @Format_ConfMsg_Desc(maintenanceCode, "Employee", $(prEmployee), "<br>$(fieldValue)", "", "", "", confMessage)
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)EmployeeMaintainSelect.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          @DecatErr_Field("@@rnam", "prEmployee")
          @Format_ConfMsg_Desc(maintenanceCode, "Employee", $(prEmployee), "<br>$(fieldValue)", "", "", "", confMessage)
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)EmployeeMaintainSelect.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %endif
%}