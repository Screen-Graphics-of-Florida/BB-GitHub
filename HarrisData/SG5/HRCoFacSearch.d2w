%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Company/Facility Search"
  d2wName                 = "HRCoFacSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldCo=@dtw_rurlescseq(fldCo)&amp;fldFac=@dtw_rurlescseq(fldFac)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldCo                   = ""
  fldFac                  = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function selectCoFac(companyNumber, facilityNumber, desc){
                      window.opener.document.$(docName).$(fldCo).value = companyNumber;
                      window.opener.document.$(docName).$(fldFac).value = facilityNumber;
                      window.opener.document.$(docName).$(fldDesc).value = desc;
                      window.opener.document.$(docName).$(fldCo).focus();
                      window.close();
                  }
    	           %INCLUDE "NumEdit.icl"
                  %INCLUDE "CheckEnterSearch.icl"
                  function validate(searchForm) {
                      if (editNum(document.Search.srchCo, 2, 0) &&
                          editNum(document.Search.srchFac, 4, 0))
                          return true;
                  }
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "$(searchBanner)"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      <td class="content">
                          @dtw_assign(uv_CompanyName, "CFCOMP")
                          @dtw_assign(uv_FacilityName, "CFFACL")
                          %INCLUDE "userview.icl"

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, "Select CFCOMP, CFFACL, CFNAME, CFADR1, CFCITY, CFSTID, CFZIP, CFPHON, CFNAMEU, CFHRXR", stmtSQL)
                          @dtw_concat(stmtSQL, ", upper(CFADR1) as CFADR1U", stmtSQL)
                          @dtw_concat(stmtSQL, ", upper(CFCITY) as CFCITYU", stmtSQL)
                          @dtw_concat(fileSQL, " HRCOFC ", fileSQL)
                          @dtw_concat(selectSQL, " CFFACL>0 and CFPRAC=' ' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @CoFac_Search(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "$(searchTrailer)"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}
%FUNCTION(dtw_sql) CoFac_Search (IN CHAR(64)    profileHandle,
     	                             CHAR(2)     dataBaseID,
                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Name</th>
                      <th class="colhdr">Co / Fac</th>
                  </tr>
                  <tr>
                      <td class="inputalph">
                          <input type="text" name="srchName" size="30" maxlength="30">
                          <input type="hidden" name="operName" value="LIKE">
                      </td>
                       <td class="inputnmbr"><input name="srchCo" type="text" size="2" maxlength="2"> / <input name="srchFac" type="text" size="4" maxlength="4">
                          <input type="hidden" name="operCo" value="=">
                          <input type="hidden" name="operFac" value="=">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchName.focus();
              </script>
          </form>
	
          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("CFCOMP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Number" title="Sequence By Co/Fac"> Co/Fac</a></th>
                  @OrderBy_Sort("CFNAMEU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Name" title="Sequence By Name, Co/Fac"> Name</a></th>
                  @OrderBy_Sort("CFADR1U", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Address" title="Sequence By Address, Name"> Address</a></th>
                  @OrderBy_Sort("CFCITYU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=City" title="Sequence By City, State, Name"> City</a></th>
                  @OrderBy_Sort("CFSTID", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=State" title="Sequence By State, City, Name"> State</a></th>
                  @OrderBy_Sort("CFZIP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Zip" title="Sequence By Zip, City, Name"> Zip</a></th>
                  @OrderBy_Sort("CFPHON", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Phone" title="Sequence By Phone Number, Name"> Phone<br>Number</a></th>
              </tr>

              %INCLUDE "NoRecordsFound.icl"

              %ROW{
                  %INCLUDE "SetRowClass.icl"
                  @Format_CoFac("$(V_CFCOMP)", "$(V_CFFACL)", "", F_CoFac)
                  @Format_Quote(V_CFNAME, F_CFNAME)

                  <tr class="$(rowClass)">
                      <td class="colnmbr">$(F_CoFac)</td>
                      <td class="colalph"><a href="javascript:selectCoFac($(V_CFCOMP),$(V_CFFACL),'$(F_CFNAME)')" title="Select Company/Facility">$(V_CFNAME)</a></td>
                      <td class="colalph">$(V_CFADR1)</td>
                      <td class="colalph">$(V_CFCITY)</td>
                      <td class="colcode">$(V_CFSTID)</td>
                      <td class="colalph">$(V_CFZIP)</td>
                      %if (V_CFPHON > "0")
                          @EditPhoneNumber(V_CFPHON)
                      %endif
                      <td class="colalph">$(V_CFPHON)</td>
                  </tr>

              %}
          </table>
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "CFNAMEU,CFCOMP,CFFACL")
      @DTW_ASSIGN(orderByDisplay, "Name, Number")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY)
{
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Number")
      %if (orderBy == "CFCOMP,CFFACL")
          @DTW_ASSIGN(orderBy, "CFCOMP DESC,CFFACL")
          @DTW_ASSIGN(orderByDisplay, "Co/Fac (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CFCOMP,CFFACL")
          @DTW_ASSIGN(orderByDisplay, "Co/Fac")
      %endif
  %elseif (sequence == "Name")
      %if (orderBy == "CFNAMEU,CFCOMP,CFFACL")
          @DTW_ASSIGN(orderBy, "CFNAMEU DESC,CFCOMP,CFFACL")
          @DTW_ASSIGN(orderByDisplay, "Name (descending), Co/Fac")
      %else
          @DTW_ASSIGN(orderBy, "CFNAMEU,CFCOMP,CFFACL")
          @DTW_ASSIGN(orderByDisplay, "Name, Co/Fac")
      %endif
  %elseif (sequence == "Address")
      %if (orderBy == "CFADR1U,CFNAMEU")
          @DTW_ASSIGN(orderBy, "CFADR1U DESC,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "Address (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "CFADR1U,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "Address, Name")
      %endif
  %elseif (sequence == "City")
      %if (orderBy == "CFCITYU,CFSTID,CFNAMEU")
          @DTW_ASSIGN(orderBy, "CFCITYU DESC,CFSTID,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "City (descending), State, Name")
      %else
          @DTW_ASSIGN(orderBy, "CFCITYU,CFSTID,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "City, State, Name")
      %endif
  %elseif (sequence == "State")
      %if (orderBy == "CFSTID,CFCITYU,CFNAMEU")
          @DTW_ASSIGN(orderBy, "CFSTID DESC,CFCITYU,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "State (descending), City, Name")
      %else
          @DTW_ASSIGN(orderBy, "CFSTID,CFCITYU,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "State, City, Name")
      %endif
  %elseif (sequence == "Zip")
      %if (orderBy == "CFZIP,CFCITYU,CFNAMEU")
          @DTW_ASSIGN(orderBy, "CFZIP DESC,CFCITYU,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "Zip (descending), City, Name")
      %else
          @DTW_ASSIGN(orderBy, "CFZIP,CFCITYU,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "Zip, City, Name")
      %endif
  %elseif (sequence == "Phone")
      %if (orderBy == "CFPHON,CFNAMEU")
          @DTW_ASSIGN(orderBy, "CFPHON DESC,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "Phone Number (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "CFPHON,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "Phone Number, Name")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH)
{
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchPhone, 10, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Name</td>
                              @dtw_assign(operNbr, "operName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchName" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Address</td>
                              @dtw_assign(operNbr, "operAddr")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchAddr" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">City</td>
                              @dtw_assign(operNbr, "operCity")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCity" size="16" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">State</td>
                              @dtw_assign(operNbr, "operState")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchState" size="2" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Zip</td>
                              @dtw_assign(operNbr, "operZip")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchZip" size="10" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Phone Number</td>
                              <td>&nbsp;</td>
                              <td class="inputnmbr"><input type="text" name="srchPhone" size="10" maxlength="30"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchName.focus();
                          </script>
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD)
{
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("CFCOMP", "Company", $(srchCo), "", operCo, "N")
  @Build_WildCard ("CFFACL", "Facility", $(srchFac), "", operFac, "N")
  @Build_WildCard ("CFNAMEU", "Name", $(srchName), "U", operName, "A")
  @Build_WildCard ("upper(CFADR1)", "Address", $(srchAddr), "U", operAddr, "A")
  @Build_WildCard ("upper(CFCITY)", "City", $(srchCity), "U", operCity, "A")
  @Build_WildCard ("CFSTID", "State", $(srchState), "U", operState, "A")
  @Build_WildCard ("CFZIP", "Zip", $(srchZip), "", operZip, "A")
  @Build_WildCard ("CFPHON", "Phone Number", $(srchPhone), "", "", "PA")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}