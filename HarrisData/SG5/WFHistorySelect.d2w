%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Work Item History"
  d2wName                 = "WFHistorySelect.d2w"
  attachFolder            = "WorkFlowWorkList"
  d2wVarBase              = "$(genericVarBase)&amp;wfInstance=@dtw_rurlescseq(wfInstance)&amp;wfInstanceDate=@dtw_rurlescseq(wfInstanceDate)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;displayWFIcons=@dtw_rurlescseq(displayWFIcons)&amp;inclMyItem=@dtw_rurlescseq(inclMyItem)&amp;inclPass=@dtw_rurlescseq(inclPass)&amp;inclFail=@dtw_rurlescseq(inclFail)&amp;inclActv=@dtw_rurlescseq(inclActv)&amp;expireDate=@dtw_rurlescseq(expireDate)&amp;specWfInstance=@dtw_rurlescseq(specWfInstance)&amp;specWfInstanceDate=@dtw_rurlescseq(specWfInstanceDate)&amp;specWfWorkItem=@dtw_rurlescseq(specWfWorkItem)&amp;specWfWorkItemSequence=@dtw_rurlescseq(specWfWorkItemSequence)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  noMsg                   = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Check_Sel_UserView (INOUT alertMessage) {
  @dtw_assign(edtVar, "")
  @Concat_Field("@@inst", wfInstance)
  @Concat_Field("@@indt", wfInstanceDate)
  @dtw_concat(edtVar, "}{", edtVar)
  @WFWrkItmUserView(profileHandle, dataBaseID, userPass, edtVar)
  %if (userPass == "N")
      @Rtv_Error_Desc("HHD0247", alertMessage)
      %if (fromD2w == "WelcomePage.d2w")
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(fromD2w)/WELCOME$(d2wVarBase)&amp;alertMessage=@dtw_rurlescseq(alertMessage)">
      %else
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;alertMessage=@dtw_rurlescseq(alertMessage)">
      %endif
  %else
      @dtw_assign(alertMessage, "")
  %endif
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {

  @Check_Sel_UserView(alertMessage)
  %if (alertMessage == "")
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterSearch.icl"
                  %INCLUDE "Menu.js"
                  %INCLUDE "NoFormValidate.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                          @dtw_assign(pageID, "WFHISTORYSELECT")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select WFWIHS.*, WFWIPT.*,  ", stmtSQL)
                          @dtw_concat(stmtSQL, " Date(WPCMPL)-Date(WPTSTP) as WPDuration, ", stmtSQL)
                          @dtw_concat(stmtSQL, " Time(WPTSTP) as WPTimeStart, ", stmtSQL)
                          @dtw_concat(stmtSQL, " Time(WPCMPL) as WPTimeCompl, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(PDDESC,' ') as PDDESC, coalesce(PDDESCU,' ') as PDDESCU, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(a.USDESC,' ') as a_USDESC, coalesce(a.USDESCU,' ') as a_USDESCU, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(b.USDESC,' ') as b_USDESC, coalesce(b.USDESCU,' ') as b_USDESCU  ", stmtSQL)
                          @dtw_concat(fileSQL, " WFWIHS ", fileSQL)
                          @dtw_concat(fileSQL, " inner join WFWIPT on WPINST=WHINST and WPINDT=WHINDT and WPWITM=WHWITM and WPWISQ=WHWISQ  ", fileSQL)
                          @dtw_concat(fileSQL, " inner join WFINST on ININST=WHINST and ININDT=WHINDT ", fileSQL)
                          @dtw_concat(fileSQL, " left join WFPRDT on PDPROC=INPROC and PDPONT=WHPONT and PDSEQ=WHSEQ ", fileSQL)
                          @dtw_concat(fileSQL, " left join SYUSER a on a.USUSER=WPIPRT ", fileSQL)
                          @dtw_concat(fileSQL, " left join SYUSER b on b.USUSER=WPPART ", fileSQL)
                          @dtw_concat(selectSQL, " WHINST=$(wfInstance) and WHINDT=$(wfInstanceDate) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl" 
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @List_Query(profileHandle, dataBaseID, stmtSQL)

                          %INCLUDE "PageBottom.icl"
                          %INCLUDE "WildCardPrint.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitleWithPrint.icl"
      <table $(contentTable)>
          @RtvFldDesc("ININST=$(wfInstance) and ININDT=$(wfInstanceDate)", "WFINST", "INDESC", V_INDESC)
          @Format_Code(wfInstance, F_wfInstance)
          <tr><td><h2> $(V_INDESC) $(F_wfInstance)</h2></td></tr>
          @RtvFldDesc("ININST=$(wfInstance) and ININDT=$(wfInstanceDate)", "WFINST", "INPROC", V_INPROC)
          @RtvFldDesc("PRPROC='$(V_INPROC)' ", "WFPRHD", "PRDESC", V_PRDESC)
          @Format_Code(V_INPROC, F_INPROC)
          <tr><td><h2> $(V_PRDESC) $(F_INPROC)</h2></td></tr>
      </table>

      $(hrTagAttr)

      %if (formatToPrint == "")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Reason</th>
                      <th class="colhdr">Participant</th>
                      <th class="colhdr">Detail Point</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchReason" size="15" maxlength="5120">
                          <input type="hidden" name="operReason" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchParticipant" size="15" maxlength="30">
                          <input type="hidden" name="operParticipant" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchDetailPoint" size="15" maxlength="50">
                          <input type="hidden" name="operDetailPoint" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchReason.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" || displayWFIcons=="Y")
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("WHWITM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=WorkItem"  title="Sequence By Work Item">Work Item</a></th>
              @OrderBy_Sort("PDDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DetailPoint"  title="Sequence By Detail Point, Work Item">Detail Point</a></th>
              @OrderBy_Sort("WHMODE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=StartMode" title="Sequence By Start Mode, Work Item">Start Mode</a></th>
              @OrderBy_Sort("WHDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Reason, Work Item">Reason</a></th>
              @OrderBy_Sort("a_USDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=InitialParticipant" title="Sequence By Initial Participant, Work Item">Initial Participant</a></th>
              @OrderBy_Sort("b_USDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Participant" title="Sequence By Participant, Work Item">Participant</a></th>
              @OrderBy_Sort("WPRVWS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Review" title="Sequence By Review, Work Item">Review</a></th>
              @OrderBy_Sort("WPFAIL", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Fail" title="Sequence By Pass/Fail, Work Item">Pass/<br>Fail</a></th>
              @OrderBy_Sort("WPDuration", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Duration"    title="Sequence By Days To Complete, Work Item">Days To Complete</a></th>
              @OrderBy_Sort("WPPRTY", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Priority"  title="Sequence By Priority, Work Item">Priority</a></th>
              @OrderBy_Sort("WPEXDT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ExpireDate"  title="Sequence By Expiration Date, Work Item">Expiration Date</a></th>
              @OrderBy_Sort("WPTSTP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DateStart"    title="Sequence By Date Started, Work Item">Date Started</a></th>
              @OrderBy_Sort("WPTimeStart", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TimeStart"    title="Sequence By Time Started, Work Item">Time Started</a></th>
              @OrderBy_Sort("WPCMPL", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DateCompl"    title="Sequence By Date Completed, Work Item">Date Completed</a></th>
              @OrderBy_Sort("WPTimeCompl", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TimeCompl"    title="Sequence By Time Completed, Work Item">Time Completed</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          @dtw_assign(displayWorkItem, "")
          @dtw_assign(displayParticipant, "")
          @dtw_assign(Check_WHINST, "")
          @dtw_assign(Check_WHINDT, "")
          @dtw_assign(Check_WHWITM, "")
          @dtw_assign(Check_WHWISQ, "")
          @dtw_assign(Check_WPIPRT, "")

          %ROW{
              @RtvFldDesc("FLTYPE='WFMODE' and FLVALU='$(V_WHMODE)'", "SYFLAG", "FLDESC", modeDesc)
              @RtvFldDesc("FLTYPE='WFREVIEW' and FLVALU='$(V_WPRVWS)'", "SYFLAG", "FLDESC", reviewDesc)
              @RtvFldDesc("FLTYPE='WFPASSFAIL' and FLVALU='$(V_WPFAIL)'", "SYFLAG", "FLDESC", failDesc)

              @dtw_assign(attWfInstance, V_WHINST)      %while(@dtw_rlength(attWfInstance) != "15")        {@dtw_insert("0", attWfInstance, attWfInstance)%}
              @dtw_assign(wfInstanceDate, V_WHINDT)     %while(@dtw_rlength(wfInstanceDate) != "7")     {@dtw_insert("0", wfInstanceDate, wfInstanceDate)%}
              @dtw_assign(wfWorkItem, V_WHWITM)         %while(@dtw_rlength(wfWorkItem) != "5")         {@dtw_insert("0", wfWorkItem, wfWorkItem)%}
              @dtw_assign(wfWorkItemSequence, V_WHWISQ) %while(@dtw_rlength(wfWorkItemSequence) != "5") {@dtw_insert("0", wfWorkItemSequence, wfWorkItemSequence)%}

              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;wfWorkItem=@dtw_rurlescseq(V_WHWITM)&amp;wfWorkItemSequence=@dtw_rurlescseq(V_WHWISQ)&amp;wfParticipantId=@dtw_rurlescseq(V_WPPTID)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              @TimeStamp_CYMD(V_WPEXDT, V_WPEXDT) @Format_Date(V_WPEXDT, "H", F_WPEXDT)
              @TimeStamp_CYMD(V_WPTSTP, V_WPTSTP) @Format_Date(V_WPTSTP, "H", F_WPTSTP)
              @TimeStamp_CYMD(V_WPCMPL, V_WPCMPL) @Format_Date(V_WPCMPL, "H", F_WPCMPL)
              %INCLUDE "SetRowClass.icl"

              %if (V_WHINST != Check_WHINST || V_WHINDT != Check_WHINDT || V_WHWITM != Check_WHWITM || V_WHWISQ != Check_WHWISQ)
                  @dtw_assign(displayWorkItem, "Y")
                  @RtvFldDesc("WTINST=$(wfInstance) and WTINDT=$(wfInstanceDate) and WTWITM=$(V_WHWITM) and WTWISQ=$(V_WHWISQ) and WTTRID>0", "WFWITR", "Char(Count(*))", Cnt_Transition)
                  @RtvFldDesc("WCINST=$(wfInstance) and WCINDT=$(wfInstanceDate) and WCWITM=$(V_WHWITM) and WCWISQ=$(V_WHWISQ) ", "WFWICM", "Char(Count(*))", Cnt_Comment)
                  @RtvFldDesc("AHINST=$(wfInstance) and AHINDT=$(wfInstanceDate) and AHWITM=$(V_WHWITM) and AHWISQ=$(V_WHWISQ) ", "WFDTAH", "Char(Count(*))", Cnt_Data)
                  @RtvFldDesc("WEINST=$(wfInstance) and WEINDT=$(wfInstanceDate) and WEWITM=$(V_WHWITM) and WEWISQ=$(V_WHWISQ) ", "WFWIEN", "Char(Count(*))", Cnt_Notify)
                  @RtvFldDesc("WVINST=$(wfInstance) and WVINDT=$(wfInstanceDate) and WVWITM=$(V_WHWITM) and WVWISQ=$(V_WHWISQ) ", "WFWIVL", "Char(Count(*))", Cnt_Validate)
                  @dtw_assign(attachVarKey, "$(attWfInstance)$(wfInstanceDate)$(wfWorkItem)$(wfWorkItemSequence)")
                  @RtvFldDesc("ATFOLD='WORKFLOWWORKLIST' and ATVKEY='$(attachVarKey)'", "SYD2WA", "Char(Count(*))", Cnt_Attach)
                  @dtw_assign(Check_WHINST, V_WHINST)
                  @dtw_assign(Check_WHINDT, V_WHINDT)
                  @dtw_assign(Check_WHWITM, V_WHWITM)
                  @dtw_assign(Check_WHWISQ, V_WHWISQ)
                  @dtw_assign(Check_WPIPRT, "")
              %else
                  @dtw_assign(displayWorkItem, "")
                  @dtw_assign(Cnt_Transition, "0")
                  @dtw_assign(Cnt_Comment, "0")
                  @dtw_assign(Cnt_Data, "0")
                  @dtw_assign(Cnt_Notify, "0")
                  @dtw_assign(Cnt_Validate, "0")
                  @dtw_assign(Cnt_Attach, "0")
              %endif

              %if (V_WPIPRT != Check_WPIPRT)
                  @dtw_assign(displayParticipant, "Y")
                  @dtw_assign(Check_WPIPRT, V_WPIPRT)
              %else
                  @dtw_assign(displayParticipant, "")
              %endif


              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" || displayWFIcons=="Y")
                      <td class="opticon">
                          %if (Cnt_Transition > "0")
                              <a href="$(homeURL)$(cGIPath)WFHistoryTransition.d2w/REPORT$(maintainVar)" onclick="$(inquiryWinVar)">$(wfTransitionImage)</a>
                          %endif
                          %if (Cnt_Comment > "0")
                              <a href="$(homeURL)$(cGIPath)WFHistoryComment.d2w/REPORT$(maintainVar)" onclick="$(inquiryWinVar)">$(wfCommentImage)</a>
                          %endif
                          %if (Cnt_Data > "0")
                              <a href="$(homeURL)$(cGIPath)WFHistoryData.d2w/REPORT$(maintainVar)" onclick="$(inquiryWinVar)">$(wfDataImage)</a>
                          %endif
                          %if (Cnt_Notify > "0")
                              <a href="$(homeURL)$(cGIPath)WFHistoryNotification.d2w/REPORT$(maintainVar)" onclick="$(inquiryWinVar)">$(wfNotificationImage)</a>
                          %endif
                          %if (Cnt_Validate > "0")
                              <a href="$(homeURL)$(cGIPath)WFHistoryValidation.d2w/REPORT$(maintainVar)" onclick="$(inquiryWinVar)">$(wfValidationImage)</a>
                          %endif
                          %if (Cnt_Attach > "0")
                              @dtw_assign(attachForDesc, V_INDESC)
                              @dtw_assign(attachPrg1, "WFWIPT Where (WPINST,WPINDT,WPWITM,WPWISQ)=($(wfInstance),$(wfInstanceDate),$(wfWorkItem),$(wfWorkItemSequence))")
                              <a href="$(homeURL)$(phpPath)Attachment.php$(altVarBase)&amp;attachFolder=@dtw_rurlescseq(attachFolder)&amp;attachForDesc=@dtw_rurlescseq(attachForDesc)&amp;attachVarKey=@dtw_rurlescseq(attachVarKey)&amp;userProfile=@dtw_rurlescseq(userProfile)&amp;attachPrg1=@dtw_rurlescseq(attachPrg1)&amp;attachPrg2=@dtw_rurlescseq(attachPrg2)&amp;attachPrg3=@dtw_rurlescseq(attachPrg3)&amp;attachPrg4=@dtw_rurlescseq(attachPrg4)&amp;attachPrg5=@dtw_rurlescseq(attachPrg5)" onclick="$(selectionWinVar)">$(attachImageLrg)</a>
                          %endif
                      </td>
                  %endif
                  %if (displayWorkItem=="Y")
                      <td class="colnmbr">$(V_WHWITM)</td>                                      	
                      <td class="colalph" $(helpCursor)><span title="$(V_WHPONT)-$(V_WHSEQ)">$(V_PDDESC)</span></td>                                      	
                      <td class="colcode" $(helpCursor)><span title="$(modeDesc)">$(V_WHMODE)</span></td>
                      <td class="colalph">$(V_WHDESC)</td>
                  %else
                      <td class="colalph">&nbsp;</td>                                      	
                      <td class="colalph">&nbsp;</td>                                      	
                      <td class="colcode">&nbsp;</td>
                      <td class="colalph">&nbsp;</td>
                  %endif
                  %if (displayParticipant=="Y")
                      <td class="colalph" $(helpCursor)><span title="$(V_WPIPRT)">$(V_a_USDESC)</span></td>                                      	
                  %else
                      <td class="colnmbr">&nbsp;</td>                                      	
                  %endif
                  <td class="colalph" $(helpCursor)><span title="$(V_WPPART)">$(V_b_USDESC)</span></td>                                      	
                  <td class="colcode" $(helpCursor)><span title="$(reviewDesc)">$(V_WPRVWS)</span></td>
                  <td class="colcode" $(helpCursor)><span title="$(failDesc)">$(V_WPFAIL)</span></td>
                  <td class="colnmbr">$(V_WPDuration)</td>                                      	
                  <td class="colnmbr">$(V_WPPRTY)</td>                                      	
                  <td class="colnmbr">$(F_WPEXDT)</td>                                      	
                  <td class="colalph">$(F_WPTSTP)</td>                                      	
                  <td class="colalph">$(V_WPTimeStart)</td>                                      	
                  <td class="colalph">$(F_WPCMPL)</td>                                      	
                  <td class="colalph">$(V_WPTimeCompl)</td>                                      	
              </tr>
          %}
      </table>
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "WHWITM,WHWISQ,WPIPRT,WPPTID")
      @DTW_ASSIGN(orderByDisplay, "Work Item")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EMAIL) {
  %INCLUDE "setLibraryList.icl"
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)">
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "WorkItem")
      %if (orderBy == "WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderBy, "WHWITM DESC,WHWISQ DESC,WPIPRT DESC,WPPTID DESC")
          @DTW_ASSIGN(orderByDisplay, "Work Item (descending)")
      %else
          @DTW_ASSIGN(orderBy, "WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Work Item")
      %endif
  %elif (sequence == "DetailPoint")
      %if (orderBy == "PDDESCU,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderBy, "PDDESCU DESC,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Detail Point (descending), Work Item")
      %else
          @DTW_ASSIGN(orderBy, "PDDESCU,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Detail Point, Work Item")
      %endif
  %elif (sequence == "StartMode")
      %if (orderBy == "WHMODE,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderBy, "WHMODE DESC,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Start Mode (descending), Work Item")
      %else
          @DTW_ASSIGN(orderBy, "WHMODE,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Start Mode, Work Item")
      %endif
  %elif (sequence == "Reason")
      %if (orderBy == "WHDESCU,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderBy, "WHDESCU DESC,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Reason (descending), Work Item")
      %else
          @DTW_ASSIGN(orderBy, "WHDESCU,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Reason, Work Item")
      %endif
  %elif (sequence == "InitialParticipant")
      %if (orderBy == "a_USDESCU,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderBy, "a_USDESCU DESC,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Initial Participant (descending), Work Item")
      %else
          @DTW_ASSIGN(orderBy, "a_USDESCU,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Initial Participant, Work Item")
      %endif
  %elif (sequence == "Participant")
      %if (orderBy == "b_USDESCU,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderBy, "b_USDESCU DESC,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Participant (descending), Work Item")
      %else
          @DTW_ASSIGN(orderBy, "b_USDESCU,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Participant, Work Item")
      %endif
  %elif (sequence == "Review")
      %if (orderBy == "WPRVWS,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderBy, "WPRVWS DESC,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Review (descending), Work Item")
      %else
          @DTW_ASSIGN(orderBy, "WPRVWS,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Review, Work Item")
      %endif
  %elif (sequence == "Fail")
      %if (orderBy == "WPFAIL,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderBy, "WPFAIL DESC,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Pass/Fail (descending), Work Item")
      %else
          @DTW_ASSIGN(orderBy, "WPFAIL,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Pass/Fail, Work Item")
      %endif
  %elif (sequence == "Duration")
      %if (orderBy == "WPDuration,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderBy, "WPDuration DESC,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Days To Complete (descending), Work Item")
      %else
          @DTW_ASSIGN(orderBy, "WPDuration,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Days To Complete, Work Item")
      %endif
  %elif (sequence == "Priority")
      %if (orderBy == "WPPRTY,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderBy, "WPPRTY DESC,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Priority (descending), Work Item")
      %else
          @DTW_ASSIGN(orderBy, "WPPRTY,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Priority, Work Item")
      %endif
  %elif (sequence == "ExpireDate")
      %if (orderBy == "WPEXDT,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderBy, "WPEXDT DESC,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Expiration Date (descending), Work Item")
      %else
          @DTW_ASSIGN(orderBy, "WPEXDT,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Expiration Date, Work Item")
      %endif
  %elif (sequence == "DateStart")
      %if (orderBy == "WPTSTP,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderBy, "WPTSTP DESC,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Date Started (descending), Time Started (descending), Work Item")
      %else
          @DTW_ASSIGN(orderBy, "WPTSTP,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Date Started, Time Started, Work Item")
      %endif
  %elif (sequence == "TimeStart")
      %if (orderBy == "WPTimeStart,WPTSTP,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderBy, "WPTimeStart DESC,WPTSTP DESC,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Time Started (descending), Date Started (descending), Work Item")
      %else
          @DTW_ASSIGN(orderBy, "WPTimeStart,WPTSTP,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Time Started, Date Started, Work Item")
      %endif
  %elif (sequence == "DateCompl")
      %if (orderBy == "WPCMPL,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderBy, "WPCMPL DESC,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Date Completed (descending), Time Completed (descending), Work Item")
      %else
          @DTW_ASSIGN(orderBy, "WPCMPL,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Date Completed, Time Completed, Work Item")
      %endif
  %elif (sequence == "TimeCompl")
      %if (orderBy == "WPTimeCompl,WPCMPL,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderBy, "WPTimeCompl DESC,WPCMPL DESC,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Time Completed (descending), Date Completed (descending), Work Item")
      %else
          @DTW_ASSIGN(orderBy, "WPTimeCompl,WPCMPL,WHWITM,WHWISQ,WPIPRT,WPPTID")
          @DTW_ASSIGN(orderByDisplay, "Time Completed, Date Completed, Work Item")
      %endif
  %endif
	
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "timeedit.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchWorkItem, 5, 0) &&
                      editNum(document.Search.srchPriority, 2, 0) &&
                      editdate(document.Search.srchFromExpireDate) &&
                      editdate(document.Search.srchToExpireDate) &&
                      editdate(document.Search.srchFromDateStart) &&
                      editdate(document.Search.srchToDateStart) &&
                      editTimeHM(document.Search.srchFromTimeStart) &&
                      editTimeHM(document.Search.srchToTimeStart) &&
                      editdate(document.Search.srchFromDateCompl) &&
                      editdate(document.Search.srchToDateCompl) &&
                      editTimeHM(document.Search.srchFromTimeCompl) &&
                      editTimeHM(document.Search.srchToTimeCompl))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFHISTORYSRCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Work Item</td>
                              @dtw_assign(operNbr, "operWorkItem")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchWorkItem" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">Detail Point</td>
                              @dtw_assign(operNbr, "operDetailPoint")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDetailPoint" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Start Mode</td>
                              @dtw_assign(operNbr, "operMode")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchMode" size="1" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Reason</td>
                              @dtw_assign(operNbr, "operReason")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchReason" size="15" maxlength="5120"></td>
                          </tr>

                          <tr><td class="dsphdr">Initial Participant</td>
                              @dtw_assign(operNbr, "operInitialParticipant")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchInitialParticipant" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Participant</td>
                              @dtw_assign(operNbr, "operParticipant")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchParticipant" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Review</td>
                              @dtw_assign(operNbr, "operReview")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchReview" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Pass/Fail</td>
                              @dtw_assign(operNbr, "operFail")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchFail" size="1" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Priority</td>
                              @dtw_assign(operNbr, "operPriority")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchPriority" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Expiration Date</td>
                              @dtw_assign(operNbr, "operExpireDate")
                              <td>%INCLUDE "opersel_num2_short.icl"</td>
                              <td class="inputnmbr"><input name="srchFromExpireDate" type="text" size="6" maxlength="6">
                                  <a href="javascript:calWindow('srchFromExpireDate');">$(calendarImage)</a></td>
                              <td class="inputnmbr"><input name="srchToExpireDate" type="text" size="6" maxlength="6">
                                  <a href="javascript:calWindow('srchToExpireDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Date Started</td>
                              @dtw_assign(operNbr, "operDateStart")
                              <td>%INCLUDE "opersel_num2_short.icl"</td>
                              <td class="inputnmbr"><input name="srchFromDateStart" type="text" size="6" maxlength="6">
                                  <a href="javascript:calWindow('srchFromDateStart');">$(calendarImage)</a></td>
                              <td class="inputnmbr"><input name="srchToDateStart" type="text" size="6" maxlength="6">
                                  <a href="javascript:calWindow('srchToDateStart');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Time Started</td>
                              @dtw_assign(operNbr, "operTimeStart")
                              <td>%INCLUDE "opersel_num2_short.icl"</td>
                              <td class="inputnmbr"><input name="srchFromTimeStart" type="text" size="4" maxlength="4"></td>
                              <td class="inputnmbr"><input name="srchToTimeStart" type="text" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Date Completed</td>
                              @dtw_assign(operNbr, "operDateCompl")
                              <td>%INCLUDE "opersel_num2_short.icl"</td>
                              <td class="inputnmbr"><input name="srchFromDateCompl" type="text" size="6" maxlength="6">
                                  <a href="javascript:calWindow('srchFromDateCompl');">$(calendarImage)</a></td>
                              <td class="inputnmbr"><input name="srchToDateCompl" type="text" size="6" maxlength="6">
                                  <a href="javascript:calWindow('srchToDateCompl');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Time Completed</td>
                              @dtw_assign(operNbr, "operTimeCompl")
                              <td>%INCLUDE "opersel_num2_short.icl"</td>
                              <td class="inputnmbr"><input name="srchFromTimeCompl" type="text" size="4" maxlength="4"></td>
                              <td class="inputnmbr"><input name="srchToTimeCompl" type="text" size="4" maxlength="4"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchWorkItem.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("WHWITM",  "Work Item", $(srchWorkItem), "", operWorkItem, "N")
  @Build_WildCard ("PDDESCU",  "Detail Point", $(srchDetailPoint), "U", operDetailPoint, "A")
  @Build_WildCard ("WHMODE",  "Start Mode", $(srchMode), "U", operMode, "A")
  @Build_WildCard ("WHDESCU", "Reason", $(srchReason), "U", operReason, "A")
  @Build_WildCard ("a.USDESCU",  "Initial Participant", $(srchInitialParticipant), "U", operInitialParticipant, "A")
  @Build_WildCard ("b.USDESCU",  "Participant", $(srchParticipant), "U", operParticipant, "A")
  @Build_WildCard ("WPRVWS",  "Review", $(srchReview), "U", operReview, "A")
  @Build_WildCard ("WFAIL",  "Pass/Fail", $(srchFail), "U", operFail, "A")
  @Build_WildCard ("WPPRTY",  "Priority", $(srchPriority), "", operPriority, "N")
  @Range_WildCard ("DATE(WPEXDT)", "Expiration Date", $(srchFromExpireDate), $(srchToExpireDate), "", operExpireDate, "TSD")
  @Range_WildCard ("DATE(WPTSTP)", "Date Started", $(srchFromDateStart), $(srchToDateStart), "", operDateStart, "TSD")
  @Range_WildCard ("TIME(WPTSTP)", "Time Started", $(srchFromTimeStart), $(srchToTimeStart), "", operTimeStart, "TST")
  @Range_WildCard ("DATE(WPCMPL)", "Date Completed", $(srchFromDateCompl), $(srchToDateCompl), "", operDateCompl, "TSD")
  @Range_WildCard ("TIME(WPCMPL)", "Time Completed", $(srchFromTimeCompl), $(srchToTimeCompl), "", operTimeCompl, "TST")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}