%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Kit Options Inquiry"
  d2wName                 = "SelectOrderKitOption.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;lineNumber=@dtw_rurlescseq(lineNumber)&amp;orderNumber=@dtw_rurlescseq(orderNumber)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "1000"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "1000"
  prtMaxRows              = "1000"
  rowIndexNext            = "1"
  totalPages              = "0"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onLoad="window.focus()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select OEKTDT.*, OEORDT.* ", stmtSQL)
                      @dtw_concat(fileSQL, " OEKTDT inner join OEORDT on OKORD#=ODORD# and OKORL#=ODORL# ", fileSQL)
                      @dtw_concat(selectSQL, "OKORD#=$(orderNumber) and OKORL#=$(lineNumber) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Kit_Option_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Kit_Option_Query (IN CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
          %INCLUDE "PageTitle.icl"
          $(inquiryhrTagAttr)
          @dtw_assign(saveKit, "")
		
          %ROW{
              %if (saveKit == "")
                  <table $(contentTable)>
                      <tr>
                          <td class="colhdr">Order Number</td>
                          <td class="colhdr">Ln</td>
                          <td class="colhdr">Item Number</td>
                          <td class="colhdr">Description</td>
                          <td class="colhdr">Quantity</td>
                          <td class="colhdr">Price</td>
                          <td class="colhdr">Extended Price</td>
                      </tr>
                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          <td class="colnmbr">$(V_ODORD#)</td>		
                          <td class="colnmbr">$(V_ODORL#)</td>		
                          <td class="colalph">$(V_ODITEM)</td>		
                          <td class="colalph">$(V_ODIMDS)</td>		
                          @Format_Nbr(V_ODQORD, F_ODQORD, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                          <td class="colnmbr">$(F_ODQORD)</td>
                          @Format_Nbr(V_ODSLPR, F_ODSLPR, $(prcNbrDec), $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_ODSLPR)</td>
                          @Format_Nbr("@dtw_rmultiply(V_ODQORD, V_ODSLPR)", ExtendedPrice, "2", $(amtEditCode), "Y", "$", "")
                          <td class="colnmbr">$(ExtendedPrice)</td>
                      </tr>
                  </table>
                  <table $(contentTable)>
                      <tr>
                          <td class="colhdr">Component</td>
                          <td class="colhdr">Option</td>
                          <td class="colhdr">Description</td>
                          <td class="colhdr">Quantity</td>
                          <td class="colhdr">Extra Charge</td>
                      </tr>
              %endif

              %if (V_OKOITM != "")
                  @RtvFldDesc("IMITEM='$(V_OKOITM)'", "HDIMST", "IMIMDS", optionDesc)
              %endif

              %if (saveKit != V_OKCITM)
                  @RtvFldDesc("IMITEM='$(V_OKCITM)'", "HDIMST", "IMIMDS", compDesc)
                  %INCLUDE "SetRowClass.icl"
                  @dtw_assign(saveKit, V_OKCITM)
                  @dtw_assign(newKit, V_OKCITM)
                  %if (V_OKOITM != "")
                      <tr class="$(rowClass)">
                          <td class="colalph">$(newKit)</td>
                          <td class="colalph">&nbsp;</td>
                          <td class="colalph">$(compDesc)</td>
                          <td class="colnmbr">&nbsp;</td>
                          <td class="colnmbr">&nbsp;</td>
                      </tr>
                  %endif
              %else
                  @dtw_assign(newKit, "")
              %endif

              <tr class="$(rowClass)">
                  %if (V_OKOITM != "")
                      <td class="colalph">&nbsp;</td>
                  %else
                      <td class="colalph">$(newKit)</td>
                  %endif
                  <td class="colalph">$(V_OKOITM)</td>
                  %if (V_OKOITM != "")
                      <td class="colalph">$(optionDesc)</td>
                  %else
                      <td class="colalph">$(compDesc)</td>
                  %endif
                  @Format_Nbr(V_OKQORD, F_OKQORD, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  <td class="colnmbr">$(F_OKQORD)</td>
                  @Format_Nbr(V_OKXCHG, F_OKXCHG, $(prcNbrDec), $(amtEditCode), "", "$", "")
                  <td class="colnmbr">$(F_OKXCHG)</td>
              </tr>
          %}
      </table>
      $(inquiryhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}