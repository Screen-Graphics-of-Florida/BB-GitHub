%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Lot Distribution Reports"
  d2wName                 = "LotDistributionReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromOrderNumber, 8, 0) &&
                      editNum(document.Chg.toOrderNumber, 8, 0) &&
                      editNum(document.Chg.fromVendorNumber, 7, 0) &&
                      editNum(document.Chg.toVendorNumber, 7, 0) &&
                      editNum(document.Chg.fromPurchaseOrderNumber, 8, 0) &&
                      editNum(document.Chg.toPurchaseOrderNumber, 8, 0) &&
                      editFromToAll(document.Chg.fromLotNumber, document.Chg.toLotNumber, document.Chg.allLotNumber, "A") &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromOrderNumber, document.Chg.toOrderNumber, document.Chg.allOrderNumber, 8) &&
                      editFromToAll(document.Chg.fromVendorNumber, document.Chg.toVendorNumber, document.Chg.allVendorNumber, 7) &&
                      editFromToAll(document.Chg.fromVendorLotNumber, document.Chg.toVendorLotNumber, document.Chg.allVendorLotNumber, "A") &&
                      editFromToAll(document.Chg.fromPurchaseOrderNumber, document.Chg.toPurchaseOrderNumber, document.Chg.allPurchaseOrderNumber, 8))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "LOTDISTRIBUTIONREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromLotNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@ldr@", "lot")   @dtw_assign(Err_N1LDR,  fieldValue)
                                  @DecatErr_Field("@@vldr", "vendorLot") @dtw_assign(Err_N1VLDR,  fieldValue)
                                  @DecatErr_Field("@@flot", "fromLotNumber")        @dtw_assign(Err_N1FLT#,  fieldValue)
                                  @DecatErr_Field("@@tlot", "toLotNumber")        @dtw_assign(Err_N1TLT#,  fieldValue)
                                  @DecatErr_Field("@@alot", "allLotNumber")        @dtw_assign(Err_N1ALT#,  fieldValue)
                                  @DecatErr_Field("@@fitm", "fromItemNumber")        @dtw_assign(Err_N1FITM,  fieldValue)
                                  @DecatErr_Field("@@titm", "toItemNumber")        @dtw_assign(Err_N1TITM,  fieldValue)
                                  @DecatErr_Field("@@aitm", "allItemNumber")        @dtw_assign(Err_N1AITM,  fieldValue)
                                  @DecatErr_Field("@@ford", "fromOrderNumber")        @dtw_assign(Err_N1FORD,  fieldValue)
                                  @DecatErr_Field("@@tord", "toOrderNumber")        @dtw_assign(Err_N1TORD,  fieldValue)
                                  @DecatErr_Field("@@aord", "allOrderNumber")        @dtw_assign(Err_N1AORD,  fieldValue)
                                  @DecatErr_Field("@@fvnd", "fromVendorNumber")        @dtw_assign(Err_N1FVND,  fieldValue)
                                  @DecatErr_Field("@@tvnd", "toVendorNumber")        @dtw_assign(Err_N1TVND,  fieldValue)
                                  @DecatErr_Field("@@avnd", "allVendorNumber")        @dtw_assign(Err_N1AVND,  fieldValue)
                                  @DecatErr_Field("@@fvlt", "fromVendorLotNumber")        @dtw_assign(Err_N1FVLT,  fieldValue)
                                  @DecatErr_Field("@@tvlt", "toVendorLotNumber")        @dtw_assign(Err_N1TVLT,  fieldValue)
                                  @DecatErr_Field("@@avlt", "allVendorLotNumber")        @dtw_assign(Err_N1AVLT,  fieldValue)
                                  @DecatErr_Field("@@fpo@", "fromPurchaseOrderNumber")  @dtw_assign(Err_N1FPO#,  fieldValue)
                                  @DecatErr_Field("@@tpo@", "toPurchaseOrderNumber")   @dtw_assign(Err_N1TPO#,  fieldValue)
                                  @DecatErr_Field("@@apo@", "allPurchaseOrderNumber")  @dtw_assign(Err_N1APO#,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@ldr@")  @dtw_assign(V_N1LDR,  fieldValue)
                                  @Decat_Field("@@vldr")  @dtw_assign(V_N1VLDR,  fieldValue)
                                  @Decat_Field("@@flot")  @dtw_assign(V_N1FLT#,  fieldValue)
                                  @Decat_Field("@@tlot")  @dtw_assign(V_N1TLT#,  fieldValue)
                                  @Decat_Field("@@alot")  @dtw_assign(V_N1ALT#,  fieldValue)
                                  @Decat_Field("@@fitm")  @dtw_assign(V_N1FITM,  fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N1TITM,  fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N1AITM,  fieldValue)
                                  @Decat_Field("@@ford")  @dtw_assign(V_N1FORD,  fieldValue)
                                  @Decat_Field("@@tord")  @dtw_assign(V_N1TORD,  fieldValue)
                                  @Decat_Field("@@aord")  @dtw_assign(V_N1AORD,  fieldValue)
                                  @Decat_Field("@@fvnd")  @dtw_assign(V_N1FVND,  fieldValue)
                                  @Decat_Field("@@tvnd")  @dtw_assign(V_N1TVND,  fieldValue)
                                  @Decat_Field("@@avnd")  @dtw_assign(V_N1AVND,  fieldValue)
                                  @Decat_Field("@@fvlt")  @dtw_assign(V_N1FVLT,  fieldValue)
                                  @Decat_Field("@@tvlt")  @dtw_assign(V_N1TVLT,  fieldValue)
                                  @Decat_Field("@@avlt")  @dtw_assign(V_N1AVLT,  fieldValue)
                                  @Decat_Field("@@fpo@")  @dtw_assign(V_N1FPO#,  fieldValue)
                                  @Decat_Field("@@tpo@")  @dtw_assign(V_N1TPO#,  fieldValue)
                                  @Decat_Field("@@apo@")  @dtw_assign(V_N1APO#,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}

                                  %if (V_N1LDR == "1")
                                      @dtw_assign(checkedLot, "CHECKED")
                                  %else
                                      @dtw_assign(checkedLot, "")
                                  %endif
                                  %if (V_N1VLDR == "1")
                                      @dtw_assign(checkedVendorLot, "CHECKED")
                                  %else
                                      @dtw_assign(checkedVendorLot, "")
                                  %endif
                                  %if (V_N1ALT# == "ALL")
                                      @dtw_assign(checkedallLotNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallLotNumber, "")
                                  %endif
                                  %if (V_N1AITM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_N1AORD == "ALL")
                                      @dtw_assign(checkedallOrderNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallOrderNumber, "")
                                  %endif
                                  %if (V_N1AVND == "ALL")
                                      @dtw_assign(checkedallVendorNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallVendorNumber, "")
                                  %endif
                                  %if (V_N1AVLT == "ALL")
                                      @dtw_assign(checkedallVendorLotNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallVendorLotNumber, "")
                                  %endif
                                  %if (V_N1APO# == "ALL")
                                      @dtw_assign(checkedallPurchaseOrderNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPurchaseOrderNumber, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedLot, "CHECKED")
                                  @dtw_assign(checkedVendorLot, "CHECKED")
                                  @dtw_assign(checkedallLotNumber, "CHECKED")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallOrderNumber, "CHECKED")
                                  @dtw_assign(checkedallVendorNumber, "CHECKED")
                                  @dtw_assign(checkedallVendorLotNumber, "CHECKED")
                                  @dtw_assign(checkedallPurchaseOrderNumber, "CHECKED")
                              %endif

                              @SetTextOvr(Err_N1LDR)
                              <tr><td class="dsphdr"><span $(textOvr)>Select Options</span></td>
                                  <td class="inputnmbr"><input name="lot" type="checkbox" VALUE='1' $(checkedLot)>Lot Distribution Report</td>
                              </tr>
                              @DspErrMsg(Err_N1LDR)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="vendorLot" type="checkbox" VALUE='1' $(checkedVendorLot)>Vendor Lot Distribution Report</td>
                              </tr>

                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>
                              @SetTextOvr(Err_N1FLT#)
                              %if (textOvr == "") @SetTextOvr(Err_N1TLT#) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ALT#) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Lot Number</span></td>
                                  <td class="inputalph"><input name="fromLotNumber" value="$(V_N1FLT#)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(cGIPath)LotSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldLot=fromLotNumber&amp;fldItem=fItem&amp;fldWhs=fWhs" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fItem" type="hidden"><input name="fWhs" type="hidden"></td>
                                  <td class="inputalph"><input name="toLotNumber" value="$(V_N1TLT#)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(cGIPath)LotSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldLot=toLotNumber&amp;fldItem=tItem&amp;fldWhs=tWhs" onclick="$(searchWinVar)"> $(searchImage) </a><input name="tItem" type="hidden"><input name="tWhs" type="hidden"></td>
                                  <td class="inputalph"><input name="allLotNumber" value='ALL' $(checkedallLotNumber) type="checkbox" onClick="if (this.checked) this.form.fromLotNumber.value='', this.form.toLotNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FLT#)
                              @DspErrMsg(Err_N1TLT#)
                              @DspErrMsg(Err_N1ALT#)

                              @SetTextOvr(Err_N1FITM)
                              %if (textOvr == "") @SetTextOvr(Err_N1TITM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AITM) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N1FITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N1TITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FITM)
                              @DspErrMsg(Err_N1TITM)
                              @DspErrMsg(Err_N1AITM)

                              @SetTextOvr(Err_N1FORD)
                              %if (textOvr == "") @SetTextOvr(Err_N1TORD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AORD) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Order Number</span></td>
                                  <td class="inputalph"><input name="fromOrderNumber" value="$(V_N1FORD)" type="text" size="8" maxlength="8"></td>
                                  <td class="inputalph"><input name="toOrderNumber" value="$(V_N1TORD)" type="text" size="8" maxlength="8"></td>
                                  <td class="inputalph"><input name="allOrderNumber" value='ALL' $(checkedallOrderNumber) type="checkbox" onClick="if (this.checked) this.form.fromOrderNumber.value='', this.form.toOrderNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FORD)
                              @DspErrMsg(Err_N1TORD)
                              @DspErrMsg(Err_N1AORD)

                              @SetTextOvr(Err_N1FVND)
                              %if (textOvr == "") @SetTextOvr(Err_N1TVND) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AVND) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Vendor Number</span></td>
                                  <td class="inputnmbr"><input name="fromVendorNumber" value="$(V_N1FVND)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="vendorName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toVendorNumber" value="$(V_N1TVND)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="vendorName" type="hidden"></td>
                                  <td class="inputalph"><input name="allVendorNumber" value='ALL' $(checkedallVendorNumber) type="checkbox" onClick="if (this.checked) this.form.fromVendorNumber.value='', this.form.toVendorNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FVND)
                              @DspErrMsg(Err_N1TVND)
                              @DspErrMsg(Err_N1AVND)

                              @SetTextOvr(Err_N1FVLT)
                              %if (textOvr == "") @SetTextOvr(Err_N1TVLT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AVLT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Vendor Lot Number</span></td>
                                  <td class="inputalph"><input name="fromVendorLotNumber" value="$(V_N1FVLT)" type="text" size="15" maxlength="15"></td>
                                  <td class="inputalph"><input name="toVendorLotNumber" value="$(V_N1TVLT)" type="text" size="15" maxlength="15"></td>
                                  <td class="inputalph"><input name="allVendorLotNumber" value='ALL' $(checkedallVendorLotNumber) type="checkbox" onClick="if (this.checked) this.form.fromVendorLotNumber.value='', this.form.toVendorLotNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FVLT)
                              @DspErrMsg(Err_N1TVLT)
                              @DspErrMsg(Err_N1AVLT)

                              @SetTextOvr(Err_N1FPO#)
                              %if (textOvr == "") @SetTextOvr(Err_N1TPO#) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1APO#) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Purchase Order Number</span></td>
                                  <td class="inputalph"><input name="fromPurchaseOrderNumber" value="$(V_N1FPO#)" type="text" size="8" maxlength="8"></td>
                                  <td class="inputalph"><input name="toPurchaseOrderNumber" value="$(V_N1TPO#)" type="text" size="8" maxlength="8"></td>
                                  <td class="inputalph"><input name="allPurchaseOrderNumber" value='ALL' $(checkedallPurchaseOrderNumber) type="checkbox" onClick="if (this.checked) this.form.fromPurchaseOrderNumber.value='', this.form.toPurchaseOrderNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FPO#)
                              @DspErrMsg(Err_N1TPO#)
                              @DspErrMsg(Err_N1APO#)

                          </table>

                          @dtw_assign(envProgram, "HIVLTD")
                          @dtw_assign(envPrinter, "HIVLTDPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HIVLTS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(fromLotNumber)
  @dtw_mUPPERCASE(toLotNumber)
  @dtw_mUPPERCASE(allLotNumber)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(allOrderNumber)
  @dtw_mUPPERCASE(allVendorNumber)
  @dtw_mUPPERCASE(fromVendorLotNumber)
  @dtw_mUPPERCASE(toVendorLotNumber)
  @dtw_mUPPERCASE(allVendorLotNumber)
  @dtw_mUPPERCASE(allPurchaseOrderNumber)

  @dtw_assign(fromOrderNumber,@dtw_rstrip(fromOrderNumber))
  @dtw_assign(toOrderNumber,@dtw_rstrip(toOrderNumber))
  @dtw_assign(fromVendorNumber,@dtw_rstrip(fromVendorNumber))
  @dtw_assign(toVendorNumber,@dtw_rstrip(toVendorNumber))
  @dtw_assign(fromPurchaseOrderNumber,@dtw_rstrip(fromPurchaseOrderNumber))
  @dtw_assign(toPurchaseOrderNumber,@dtw_rstrip(toPurchaseOrderNumber))

  %if (lot != "1")
      @dtw_assign(lot, "0")
  %endif
  %if (vendorLot != "1")
      @dtw_assign(vendorLot, "0")
  %endif
  %if (allLotNumber != "ALL")
      @dtw_assign(allLotNumber, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allOrderNumber != "ALL")
      @dtw_assign(allOrderNumber, "")
  %endif
  %if (allVendorNumber != "ALL")
      @dtw_assign(allVendorNumber, "")
  %endif
  %if (allVendorLotNumber != "ALL")
      @dtw_assign(allVendorLotNumber, "")
  %endif
  %if (allPurchaseOrderNumber != "ALL")
      @dtw_assign(allPurchaseOrderNumber, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@ldr@", lot)
  @Concat_Field("@@vldr", vendorLot)
  @Concat_Field("@@flot", fromLotNumber)
  @Concat_Field("@@tlot", toLotNumber)
  @Concat_Field("@@alot", allLotNumber)
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@ford", fromOrderNumber)
  @Concat_Field("@@tord", toOrderNumber)
  @Concat_Field("@@aord", allOrderNumber)
  @Concat_Field("@@fvnd", fromVendorNumber)
  @Concat_Field("@@tvnd", toVendorNumber)
  @Concat_Field("@@avnd", allVendorNumber)
  @Concat_Field("@@fvlt", fromVendorLotNumber)
  @Concat_Field("@@tvlt", toVendorLotNumber)
  @Concat_Field("@@avlt", allVendorLotNumber)
  @Concat_Field("@@fpo@", fromPurchaseOrderNumber)
  @Concat_Field("@@tpo@", toPurchaseOrderNumber)
  @Concat_Field("@@apo@", allPurchaseOrderNumber)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}