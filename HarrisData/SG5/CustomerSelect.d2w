          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("ODITEM", "Item Number")
                  @Format_Column_Header("ODWH", "Whs")
                  @Format_Column_Header("ODIMDSU", "Item Description")
                  @Format_Column_Header("ODORD#", "Order Number")
                  @Format_Column_Header("ODOLN#", "Line")
                  @Format_Column_Header("ODBRL#", "Rel")
                  @Format_Column_Header("ODRQDT", "Required Date")
                  @Format_Column_Header("ODQORD", "Qty Ordered")
                  @Format_Column_Header("ODQOPK", "Qty On Pick")
                  @Format_Column_Header("ODQSTD", "Qty Shipped")
