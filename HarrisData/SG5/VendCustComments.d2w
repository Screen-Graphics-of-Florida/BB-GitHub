%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"

%Define {	
  page_title              = ""
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "999"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}
	
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onLoad="window.focus()" onBlur="window.close()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->

          %if (vendCustFlag == "C")
              @dtw_assign(page_title, "Customer Comment")
          %else
              @dtw_assign(page_title, "Vendor Comment")
          %endif
          %INCLUDE "PageTitle.icl"

          $(inquiryhrTagAttr)

          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select CXDOCT, CXHT, CXSEQ#, CXCMNT ", stmtSQL)
                      @dtw_concat(fileSQL, " HDCCMT ", fileSQL)
                      @dtw_concat(selectSQL, "CXVCF='$(vendCustFlag)' and CXNMBR=$(vendCustNumber) and CXDOCT='$(documentType)' and CXHT='$(commentType)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By CXSEQ# ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Customer_Query_Comment_Detail(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>

          $(inquiryhrTagAttr)
          %INCLUDE "Copyright.icl"

          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Customer_Query_Comment_Detail (IN  CHAR(64)    profileHandle,
				                       CHAR(2)     dataBaseID,
                                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              <tr><td class="colalph">No Comments Available</td></tr>
          %else
              @dtw_assign(previousDocType,"")
              @dtw_assign(previousCommentType,"")
          %endif

          %ROW{
              %if (V_CXDOCT == previousDocType && V_CXHT == previousCommentType )
                  <tr>
                      <td class="colalph">$(V_CXCMNT)</td>
                  </tr>
              %else
                  @dtw_assign(previousDocType, V_CXDOCT)
                  @dtw_assign(previousCommentType, V_CXHT)
                  @RtvFldDesc("DODOCT='$(V_CXDOCT)'", "HDDOCT", "DODESC", fieldDesc)
                  %if (V_CXHT == "H")
                      @dtw_concat(fieldDesc, "&nbsp; (Header)", fieldDesc)
                  %else
                      @dtw_concat(fieldDesc, "&nbsp; (Trailer)", fieldDesc)
                  %endif
                  <tr>
                      <td class="colhdr">$(fieldDesc)</td>
                  </tr>
                  <tr>
                      <td class="colalph">$(V_CXCMNT)</td>
                  </tr>
              %endif
          %}
      </table>
  %}
%}


%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}