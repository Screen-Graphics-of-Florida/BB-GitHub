%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title           = "Applicant Search"
  d2wName              = "ApplicantSearch.d2w"
  d2wVarBase           = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldDate=@dtw_rurlescseq(fldDate)&amp;fldSeq=@dtw_rurlescseq(fldSeq)&amp;fldDesc=@dtw_rurlescseq(fldDesc)&amp;fldComp=@dtw_rurlescseq(fldComp)"
  nextPrevVar          = "$(d2wVarBase)"
  wildDftVar           = "ENTRY$(d2wVarBase)"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  DTW_PAD_PGM_PARMS    = "YES"
  RPT_MAX_ROWS         = "10"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  rowIndexNext         = "1"
  totalPages           = "0"
  novcf                = ""
  docName              = ""
  fldDate              = ""
  fldSeq               = ""
  fldDesc              = ""
  fldComp              = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              function selectAppl(applDate, applSeq, desc,applComp){
                  window.opener.document.$(docName).$(fldDate).value = applDate;
                  window.opener.document.$(docName).$(fldSeq).value = applSeq;
                  window.opener.document.$(docName).$(fldDesc).value = desc;
                  window.opener.document.$(docName).$(fldComp).value = applComp;
                  window.opener.document.$(docName).$(fldDate).focus();
                  window.close();
              }
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editdate(document.Search.srchDate))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(uv_HRCompanyName, "APCOMP")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " PEAPPL ", fileSQL)
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, "APCOMP=$(applComp) and APAPDT=$(applDate) and APAPSQ=$(applSeq)", selectSQL)
                      %else
                          @dtw_concat(selectSQL, " APEMPL=0 ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Applicant_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) Applicant_Search (IN CHAR(64)    profileHandle,
     	                             CHAR(2)     dataBaseID,
                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Name</th>
                      <th class="colhdr">Application<br>Date</th>
                  </tr>
                  <tr>
                      <td class="inputalph">
                          <input type="text" name="srchName" size="30" maxlength="30">
                          <input type="hidden" name="operName" value="LIKE">
                      </td>
                       <td class="inputnmbr"><input name="srchDate" type="text" size="6" maxlength="6">
                          <input type="hidden" name="operDate" value="=">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchName.focus();
              </script>
          </form>
	
          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("APCOMP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Company" title="Sequence By Company"> Company</a></th>
                  @OrderBy_Sort("APAPDT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplDate" title="Sequence By Application Date, Sequence Number">Application<br>Date</a></th>
                  @OrderBy_Sort("APAPSQ", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplSeq" title="Sequence By Sequence Number, Application Date (descending)">Seq</a></th>
                  @OrderBy_Sort("APLNAMU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplLast" title="Sequence By Last Name, First Name">Name</a></th>
                  @OrderBy_Sort("APSKIL", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplSkill" title="Sequence By Skill, Last Name">Main Skill</a></th>
                  @OrderBy_Sort("APPHON", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplPhone" title="Sequence By Phone Number">Phone<br>Number</a></th>
                  @OrderBy_Sort("APLCTN", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplLoc" title="Sequence By Location Applied For">Location<br>Applied For</a></th>
                  @OrderBy_Sort("APJBCD", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplJob" title="Sequence By Job Code Applied For">Job Code<br>Applied For</a></th>
                  @OrderBy_Sort("APPSTN", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplPos" title="Sequence By Position Applied For">Position<br>Applied For</a></th>
                  @OrderBy_Sort("APSTTS", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplSts" title="Sequence By Status">Status</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %else
          <table $(contentTable)>
      %endif		

              %ROW{
                  %INCLUDE "SetRowClass.icl"

                  @Format_Quote(V_APLNAM, F_APLNAM)
                  @Format_Quote(V_APFNAM, F_APFNAM)
                  @Format_Quote(V_APMIDI, F_APMIDI)
                  @dtw_assign(applName, "")
                  @dtw_concat(applName, "$(F_APLNAM), $(F_APFNAM) $(F_APMIDI)", applName)

    	           %if (moreInfo != "Y")	
                      <tr class="$(rowClass)">
                          <td class="colnmbr">$(V_APCOMP)</td>
                          @dtw_assign(Ret_APAPDT, V_APAPDT)
                          @DateInputFromCYMD(Ret_APAPDT)
                          @Format_Date(V_APAPDT, "D", F_APAPDT)
                          <td class="colnmbr">$(F_APAPDT)</td>
                          <td class="colnmbr">$(V_APAPSQ)</td>
                          <td class="colalph"><a href="javascript:selectAppl('$(Ret_APAPDT)',$(V_APAPSQ),'$(applName)', $(V_APCOMP) )" title="Select Applicant">$(applName)</a></td>
                          <td class="colalph">$(V_APSKIL)</td>
                          %if (V_APPHON > "0")
                              @EditPhoneNumber(V_APPHON)
                          %endif
                          <td class="colcode">$(V_APPHON)</td>
                          <td class="colcode">$(V_APLCTN)</td>
                          <td class="colcode">$(V_APJBCD)</td>
                          <td class="colalph">$(V_APPSTN)</td>
                          <td class="colcode">$(V_APSTTS)</td>
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;applComp=@dtw_rurlescseq(V_APCOMP)&amp;applDate=@dtw_rurlescseq(V_APAPDT)&amp;applSeq=@dtw_rurlescseq(V_APAPSQ)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                      </tr>

                  %else
                      %{ More Information Page %}

                       @Format_Date(V_APAPDT, "D", F_APAPDT)
                          @dtw_assign(Ret_APAPDT, V_APAPDT)
                          @DateInputFromCYMD(Ret_APAPDT)
                      <tr><td><a href="javascript:selectAppl($(Ret_APAPDT),$(V_APAPSQ),'$(applName)', $(V_APCOMP) )" title="Select Applicant">$(selectImageLrg)</a></td></tr>

                      <tr><td class="dsphdr">Application Date</td>
                          <td class="dspdate">$(F_APAPDT)</td>
                      </tr>

                      <tr><td class="dsphdr">Sequence Number</td>
                          <td class="dspnmbr">$(V_APAPSQ)</td>
                      </tr>

                      %if(V_APSTTS != "")
                          <tr><td class="dsphdr">Status</td>
                              @RtvFldDesc("ODCOMP=$(V_APCOMP) and ODTYPE='A' and ODCODE='$(V_APSTTS)' ", "PECODE", "ODDESC", HrCodeDesc)
                              @Format_Code(V_APSTTS, F_APSTTS)
                              <td class="dspalph">$(HrCodeDesc)</td>
                              <td class="dspalph">$(F_APSTTS)</td>
                          </tr>
                      %endif

                      <tr><td class="dsphdr">Last Name</td>
                          <td class="dspalph">$(V_APLNAM)</td>
                      </tr>

                      <tr><td class="dsphdr">First Name</td>
                          <td class="dspalph">$(V_APFNAM)</td>
                      </tr>

                      <tr><td class="dsphdr">Middle Initial</td>
                          <td class="dspalph">$(V_APMIDI)</td>
                      </tr>

                      %if(V_APADR1 != "")
                          <tr><td class="dsphdr">Address Line 1</td>
                              <td class="dspalph">$(V_APADR1)</td>
                          </tr>
                      %endif

                      %if(V_APADR2 != "")
                          <tr><td class="dsphdr">Address Line 2</td>
                              <td class="dspalph">$(V_APADR2)</td>
                          </tr>
                      %endif

         	       %if (V_APCITY > "")
                          <tr><td class="dsphdr">City, State Zip</td>
                              <td class="dspalph">$(V_APCITY), $(V_APST) $(V_APZIP)</td>
                          </tr>
                      %endif

         	       %if (V_APPHON > "0")
                          @EditPhoneNumber(V_APPHON)
                          <tr><td class="dsphdr">Phone Number</td>
                              <td class="dspnmbr">$(V_APPHON)</td>
                          </tr>
                      %endif

         	       %if (V_APLCTN > "")
                          <tr><td class="dsphdr">Location Applied For</td>
                              @RtvFldDesc("ODCOMP=$(V_APCOMP) and ODTYPE='O' and ODCODE='$(V_APLCTN)' ", "PECODE", "ODDESC", HrCodeDesc)
                              @Format_Code(V_APLCTN, F_APLCTN)
                              <td class="dspalph">$(HrCodeDesc)</td>
                              <td class="dspalph">$(F_APLCTN)</td>
                          </tr>
                      %endif

         	       %if (V_APJBCD > "")
                          <tr><td class="dsphdr">Job Code Applied For</td>
                              @RtvFldDesc("ODCOMP=$(V_APCOMP) and ODTYPE='J' and ODCODE='$(V_APJBCD)' ", "PECODE", "ODDESC", HrCodeDesc)
                              @Format_Code(V_APJBCD, F_APJBCD)
                              <td class="dspalph">$(HrCodeDesc)</td>
                              <td class="dspalph">$(F_APJBCD)</td>
                          </tr>
                      %endif

         	       %if (V_APPSTN > "")
                          <tr><td class="dsphdr">Position Applied For</td>
                              <td class="dspalph">$(V_APPSTN)</td>
                          </tr>
                      %endif

         	       %if (V_APHIRE > "")
                          <tr><td class="dsphdr">Hire Source</td>
                              @RtvFldDesc("ODCOMP=$(V_APCOMP) and ODTYPE='W' and ODCODE='$(V_APHIRE)' ", "PECODE", "ODDESC", HrCodeDesc)
                              @Format_Code(V_APHIRE, F_APHIRE)
                              <td class="dspalph">$(HrCodeDesc)</td>
                              <td class="dspalph">$(F_APHIRE)</td>
                          </tr>
                      %endif

         	       %if (V_APMILT > "")
                          <tr><td class="dsphdr">Military Status</td>
                              @RtvFldDesc("ODCOMP=$(V_APCOMP) and ODTYPE='V' and ODCODE='$(V_APMILT)' ", "PECODE", "ODDESC", HrCodeDesc)
                              @Format_Code(V_APMILT, F_APMILT)
                              <td class="dspalph">$(HrCodeDesc)</td>
                              <td class="dspalph">$(F_APMILT)</td>
                          </tr>
                      %endif

         	       %if (V_APCFEL > "")
                          <tr><td class="dsphdr">Ever Convicted Of A Felony</td>
                              @RtvFldDesc("FLTYPE='BYN' and FLVALU='$(V_APCFEL)'", "SYFLAG", "FLDESC", syFlagDesc)
                              <td class="dspalph">$(syFlagDesc)</td>
                          </tr>
                      %endif

         	       %if (V_APUN18 > "")
                          <tr><td class="dsphdr">If Under 18, Proof Of Eligibility</td>
                              @RtvFldDesc("FLTYPE='BYN' and FLVALU='$(V_APUN18)'", "SYFLAG", "FLDESC", syFlagDesc)
                              <td class="dspalph">$(syFlagDesc)</td>
                          </tr>
                      %endif

         	       %if (V_APLEFE > "")
                          <tr><td class="dsphdr">Legaly Eligible For Employment In The U.S.</td>
                              @RtvFldDesc("FLTYPE='BYN' and FLVALU='$(V_APLEFE)'", "SYFLAG", "FLDESC", syFlagDesc)
                              <td class="dspalph">$(syFlagDesc)</td>
                          </tr>
                      %endif

         	       %if (V_APAONF > "")
                          <tr><td class="dsphdr">Application On File</td>
                              @RtvFldDesc("FLTYPE='BYN' and FLVALU='$(V_APAONF)'", "SYFLAG", "FLDESC", syFlagDesc)
                              <td class="dspalph">$(syFlagDesc)</td>
                          </tr>
                      %endif

                  %endif
              %}
          </table>
	   %if (moreInfo != "Y")	
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
	   %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "APLNAMU,APFNAMU")
      @DTW_ASSIGN(orderByDisplay, "Last Name, First Name")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(orderBy, "APCOMP")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY)
{
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Company")
      %if (orderBy == "APCOMP,APAPDT,APAPSQ")
          @DTW_ASSIGN(orderBy, "APCOMP DESC,APAPDT,APAPSQ")
          @DTW_ASSIGN(orderByDisplay, "Company (descending), Application Date, Sequence Number")
      %else
          @DTW_ASSIGN(orderBy, "APCOMP,APAPDT,APAPSQ")
          @DTW_ASSIGN(orderByDisplay, "Company, Application Date, Sequence Number")
      %endif
  %elif (sequence == "ApplDate")
      %if (orderBy == "APAPDT,APAPSQ")
          @DTW_ASSIGN(orderBy, "APAPDT DESC, APAPSQ")
          @DTW_ASSIGN(orderByDisplay, "Application Date (descending), Sequence Number")
      %else
          @DTW_ASSIGN(orderBy, "APAPDT,APAPSQ")
          @DTW_ASSIGN(orderByDisplay, "Application Date, Sequence Number")
      %endif
  %elif (sequence == "ApplSeq")
      %if (orderBy == "APAPSQ,APAPDT DESC")
          @DTW_ASSIGN(orderBy, "APAPSQ DESC,APAPDT DESC")
          @DTW_ASSIGN(orderByDisplay, "Sequence Number (descending), Application Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "APAPSQ,APAPDT DESC")
          @DTW_ASSIGN(orderByDisplay, "Sequence Number, Application Date (descending)")
      %endif
  %elif (sequence == "ApplLast")
      %if (orderBy == "APLNAMU,APFNAMU")
          @DTW_ASSIGN(orderBy, "APLNAMU DESC, APFNAMU")
          @DTW_ASSIGN(orderByDisplay, "Last Name (descending), First Name")
      %else
          @DTW_ASSIGN(orderBy, "APLNAMU,APFNAMU")
          @DTW_ASSIGN(orderByDisplay, "Last Name, First Name")
      %endif
  %elif (sequence == "ApplSkill")
      %if (orderBy == "APSKIL,APLNAMU")
          @DTW_ASSIGN(orderBy, "APSKIL DESC, APLNAMU")
          @DTW_ASSIGN(orderByDisplay, "Skill (descending), Last Name")
      %else
          @DTW_ASSIGN(orderBy, "APSKIL,APLNAMU")
          @DTW_ASSIGN(orderByDisplay, "Skill, Last Name")
      %endif
  %elif (sequence == "ApplPhone")
      %if (orderBy == "APPHON")
          @DTW_ASSIGN(orderBy, "APPHON DESC")
          @DTW_ASSIGN(orderByDisplay, "Phone Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "APPHON")
          @DTW_ASSIGN(orderByDisplay, "Phone Number")
      %endif
  %elif (sequence == "ApplJob")
      %if (orderBy == "APJBCD")
          @DTW_ASSIGN(orderBy, "APJBCD DESC")
          @DTW_ASSIGN(orderByDisplay, "Job Code Applied For (descending)")
      %else
          @DTW_ASSIGN(orderBy, "APJBCD")
          @DTW_ASSIGN(orderByDisplay, "Job Code Applied For")
      %endif
  %elif (sequence == "ApplPos")
      %if (orderBy == "APPSTN")
          @DTW_ASSIGN(orderBy, "APPSTN DESC")
          @DTW_ASSIGN(orderByDisplay, "Position Applied For (descending)")
      %else
          @DTW_ASSIGN(orderBy, "APPSTN")
          @DTW_ASSIGN(orderByDisplay, "Position Applied For")
      %endif
  %elif (sequence == "ApplLoc")
      %if (orderBy == "APLCTN")
          @DTW_ASSIGN(orderBy, "APLCTN DESC")
          @DTW_ASSIGN(orderByDisplay, "Location Applied For (descending)")
      %else
          @DTW_ASSIGN(orderBy, "APLCTN")
          @DTW_ASSIGN(orderByDisplay, "Location Applied For")
      %endif
  %elif (sequence == "ApplSts")
      %if (orderBy == "APSTTS")
          @DTW_ASSIGN(orderBy, "APSTTS DESC")
          @DTW_ASSIGN(orderByDisplay, "Status (descending)")
      %else
          @DTW_ASSIGN(orderBy, "APSTTS")
          @DTW_ASSIGN(orderByDisplay, "Status")
      %endif
  %elif (sequence == "EmplSeq")
      %if (orderBy == "APEMPL")
          @DTW_ASSIGN(orderBy, "APEMPL DESC")
          @DTW_ASSIGN(orderByDisplay, "Employee Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "APEMPL")
          @DTW_ASSIGN(orderByDisplay, "Employee Number")
      %endif
  %endif
		
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javaScript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchComp, 2, 0) &&
                      editdate(document.Search.srchDate) &&
                      editNum(document.Search.srchPhone, 10, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
           %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(contentTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"
                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Company</td>
                              @dtw_assign(operNbr, "operComp")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchComp" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Application Date</td>
                              @dtw_assign(operNbr, "operDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchDate" size="6 maxlength="6">
                              <a href="javascript:calWindow('srchDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Skill</td>
                              @dtw_assign(operNbr, "operSkill")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchSkill" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">City</td>
                              @dtw_assign(operNbr, "operCity")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCity" size="16" maxlength="16"></td>
                          </tr>

                          <tr><td class="dsphdr">State</td>
                              @dtw_assign(operNbr, "operState")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchState" size="2" maxlength="2"><a href="$(homeURL)$(phpPath)StateSearch.php$(altVarBase)&amp;docName=Search&amp;fldName=srchState&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stateDesc" value="$(fieldDesc)" type="text" size="35" disabled></td></tr>

                          <tr><td class="dsphdr">Zip Code</td>
                              @dtw_assign(operNbr, "operZip")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchZip" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Phone Number</td>
                              @dtw_assign(operNbr, "operPhone")
                              <td>&nbsp;</td>
                              <td class="inputnmbr"> <input type="text" name="srchPhone" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Location Applied For</td>
                              @dtw_assign(operNbr, "operLocation")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputnmbr"><input name="srchLoc" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Search&amp;fldType=O&amp;fldName=srchLoc&amp;fldDesc=locCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="locCodeDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Job Code Applied For</td>
                              @dtw_assign(operNbr, "operJobCode")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputnmbr"><input name="srchJob" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Search&amp;fldType=J&amp;fldName=srchJob&amp;fldDesc=jobCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="jobCodeDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Position Applied For</td>
                              @dtw_assign(operNbr, "operPos")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchPos" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Status</td>
                              @dtw_assign(operNbr, "operStatus")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchStts" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Search&amp;fldType=A&amp;fldName=srchStts&amp;fldDesc=stsCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="stsCodeDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Last Name</td>
                              @dtw_assign(operNbr, "operLast")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchLast" size="18" maxlength="18"></td>
                          </tr>

                          <tr><td class="dsphdr">First Name</td>
                              @dtw_assign(operNbr, "operFirst")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchFirst" size="18" maxlength="18"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDate.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("APCOMP", "Company", $(srchComp), "", operComp, "N")
  @Build_WildCard ("APLNAM", "Applicant Last Name", $(srchName), "U", operName, "A")
  @Build_WildCard ("APAPDT", "Application Date", $(srchDate), "", operDate, "D")
  @Build_WildCard ("upper(APSKIL)", "Skill", $(srchSkill), "U", operSkill, "A")
  @Build_WildCard ("upper(APCITY)", "City", $(srchCity), "U", operCity, "A")
  @Build_WildCard ("APST", "State", $(srchState), "U", operState, "A")
  @Build_WildCard ("APZIP", "Zip Code", $(srchZip), "U", operZip, "A")
  @Build_WildCard ("APPHON", "Phone Number", $(srchPhone), "", "", "P")
  @Build_WildCard ("APLCTN", "Location Applied For", $(srchLoc), "U", operLocation, "A")
  @Build_WildCard ("APJBCD", "Job Code Applied For", $(srchJob), "U", operJobCode, "A")
  @Build_WildCard ("upper(APPSTN)", "Position Applied For", $(srchPos), "U", operPos, "A")
  @Build_WildCard ("APSTTS", "Status", $(srchStts), "U", operStatus, "A")
  @Build_WildCard ("APFNAMU", "First Name", $(srchFirst), "U", operFirst, "A")
  @Build_WildCard ("APLNAMU", "Last Name", $(srchLast), "U", operLast, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
  %}