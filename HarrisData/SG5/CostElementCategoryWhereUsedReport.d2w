%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Cost Element Category Where Used Report"
  d2wName                 = "CostElementCategoryWhereUsedReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if  (editNum(document.Chg.fromPlantNumber, 3, 0) &&
                      editNum(document.Chg.toPlantNumber, 3, 0) &&
                      editFromToAll(document.Chg.fromPlantNumber, document.Chg.toPlantNumber, document.Chg.allPlantNumber, 3) &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromCostElementCategory, document.Chg.toCostElementCategory, document.Chg.allCostElementCategory, "A") &&
                      editFromToAll(document.Chg.fromDepartment, document.Chg.toDepartment, document.Chg.allDepartment, "A") &&
                      editFromToAll(document.Chg.fromWorkCenter, document.Chg.toWorkCenter, document.Chg.allWorkCenter, "A"))
                      return true;

              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "COSTELEMENTCATEGORYWHEREUSEDREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromPlantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb") @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@dtl@", "includeCostElementDetail")     @dtw_assign(Err_N1INCLDTL,  fieldValue)
                                  @DecatErr_Field("@@fplt", "fromPlantNumber")        @dtw_assign(Err_N1FPLNT,  fieldValue)
                                  @DecatErr_Field("@@tplt", "toPlantNumber")        @dtw_assign(Err_N1TPLNT,  fieldValue)
                                  @DecatErr_Field("@@aplt", "allPlantNumber")        @dtw_assign(Err_N1APLNT,  fieldValue)
                                  @DecatErr_Field("@@fitm", "fromItemNumber")        @dtw_assign(Err_N1FITEM,  fieldValue)
                                  @DecatErr_Field("@@titm", "toItemNumber")        @dtw_assign(Err_N1TITEM,  fieldValue)
                                  @DecatErr_Field("@@aitm", "allItemNumber")        @dtw_assign(Err_N1AITEM,  fieldValue)
                                  @DecatErr_Field("@@fcec", "fromCostElementCategory")     @dtw_assign(Err_N1FCECT,  fieldValue)
                                  @DecatErr_Field("@@tcec", "toCostElementCategory")        @dtw_assign(Err_N1TCECT,  fieldValue)
                                  @DecatErr_Field("@@acec", "allCostElementCategory")       @dtw_assign(Err_N1ACECT,  fieldValue)
                                  @DecatErr_Field("@@fdpt", "fromDepartment")        @dtw_assign(Err_N1FDEPT,  fieldValue)
                                  @DecatErr_Field("@@tdpt", "toDepartment")        @dtw_assign(Err_N1TDEPT,  fieldValue)
                                  @DecatErr_Field("@@adpt", "allDepartment")        @dtw_assign(Err_N1ADEPT,  fieldValue)
                                  @DecatErr_Field("@@fwc@", "fromWorkCenter")        @dtw_assign(Err_N1FWC,  fieldValue)
                                  @DecatErr_Field("@@twc@", "toWorkCenter")        @dtw_assign(Err_N1TWC,  fieldValue)
                                  @DecatErr_Field("@@awc@", "allWorkCenter")        @dtw_assign(Err_N1AWC,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@dtl@")  @dtw_assign(V_N1INCLDTL, fieldValue)
                                  @Decat_Field("@@fplt")  @dtw_assign(V_N1FPLNT,  fieldValue)
                                  @Decat_Field("@@tplt")  @dtw_assign(V_N1TPLNT,  fieldValue)
                                  @Decat_Field("@@aplt")  @dtw_assign(V_N1APLNT,  fieldValue)
                                  @Decat_Field("@@fitm")  @dtw_assign(V_N1FITEM,  fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N1TITEM,  fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N1AITEM,  fieldValue)
                                  @Decat_Field("@@fcec")  @dtw_assign(V_N1FCECT,  fieldValue)
                                  @Decat_Field("@@tcec")  @dtw_assign(V_N1TCECT,  fieldValue)
                                  @Decat_Field("@@acec")  @dtw_assign(V_N1ACECT,  fieldValue)
                                  @Decat_Field("@@fdpt")  @dtw_assign(V_N1FDEPT,  fieldValue)
                                  @Decat_Field("@@tdpt")  @dtw_assign(V_N1TDEPT,  fieldValue)
                                  @Decat_Field("@@adpt")  @dtw_assign(V_N1ADEPT,  fieldValue)
                                  @Decat_Field("@@fwc@")  @dtw_assign(V_N1FWC,  fieldValue)
                                  @Decat_Field("@@twc@")  @dtw_assign(V_N1TWC,  fieldValue)
                                  @Decat_Field("@@awc@")  @dtw_assign(V_N1AWC,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1INCLDTL == "02")
                                      @dtw_assign(includeCostElementDetailNo, "")
                                      @dtw_assign(includeCostElementDetailYes, "CHECKED")
                                  %else
                                      @dtw_assign(includeCostElementDetailNo, "CHECKED")
                                      @dtw_assign(includeCostElementDetail, "")
                                  %endif

                                  %if (V_N1APLNT == "ALL")
                                      @dtw_assign(checkedAllPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllPlantNumber, "")
                                  %endif
                                  %if (V_N1AITEM == "ALL")
                                      @dtw_assign(checkedAllItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllItemNumber, "")
                                  %endif
                                  %if (V_N1ACECT == "ALL")
                                      @dtw_assign(checkedAllCostElementCategory, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllCostElementCategory, "")
                                  %endif
                                  %if (V_N1ADEPT == "ALL")
                                      @dtw_assign(checkedAllDepartment, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllDepartment, "")
                                  %endif
                                  %if (V_N1AWC == "ALL")
                                      @dtw_assign(checkedAllWorkCenter, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllWorkCenter, "")
                                  %endif
                              %else
                                  @dtw_assign(includeCostElementDetailNo, "CHECKED")
                                  @dtw_assign(includeCostElementDetailYes, "")
                                  @RtvDftPlant(plantNumber, plantName)
                                  %if (plantNumber == "0")
                                      @dtw_assign(checkedAllPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(V_N1FPLNT, plantNumber)
                                      @dtw_assign(V_N1TPLNT, plantNumber)
                                      @dtw_assign(checkedAllPlantNumber, "")
                                  %endif
                                  @dtw_assign(checkedAllItemNumber, "CHECKED")
                                  @dtw_assign(checkedAllCostElementCategory, "CHECKED")
                                  @dtw_assign(checkedAllDepartment, "CHECKED")
                                  @dtw_assign(checkedAllWorkCenter, "CHECKED")
                              %endif

                              @SetTextOvr(Err_N1INCLDTL)
                              <tr><td  class="dsphdr"><span $(textOvr)>Include Cost Element Detail</span></td>
                                  <td class="inputnmbr"><input name="includeCostElementDetail" type="radio" VALUE='01' $(includeCostElementDetailNo)>No</td>
                              </tr>
                              @DspErrMsg(Err_N1INCLDTL)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="includeCostElementDetail" type="radio" VALUE='02' $(includeCostElementDetailYes)>Yes</td>
                              </tr>
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_N1FPLNT)
                              %if (textOvr == "") @SetTextOvr(Err_N1TPLNT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1APLNT) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                      <td class="inputnmbr"><input name="fromPlantNumber" value="$(V_N1FPLNT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromPlantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toPlantNumber" value="$(V_N1TPLNT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toPlantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName" type="hidden"></td>
                                  <td class="inputalph"><input name="allPlantNumber" value='ALL' $(checkedAllPlantNumber) type="checkbox" onClick="if (this.checked) this.form.fromPlantNumber.value='', this.form.toPlantNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FPLNT)
                              @DspErrMsg(Err_N1TPLNT)
                              @DspErrMsg(Err_N1APLNT)

                              @SetTextOvr(Err_N1FITEM)
                              %if (textOvr == "") @SetTextOvr(Err_N1TITEM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AITEM) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N1FITEM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N1TITEM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedAllItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FITEM)
                              @DspErrMsg(Err_N1TITEM)
                              @DspErrMsg(Err_N1AITEM)

                              @SetTextOvr(Err_N1FCECT)
                              %if (textOvr == "") @SetTextOvr(Err_N1TCECT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ACECT) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Cost Element Category </span></td>
                                  <td class="inputnmbr"><input name="fromCostElementCategory" value="$(V_N1FCECT)" type="text" size="7" maxlength="5"><a href="$(homeURL)$(cGIPath)CostElemCatSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;fldcat=fromCostElementCategory&amp;fldlongDesc=longDesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input name="longDesc" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toCostElementCategory" value="$(V_N1TCECT)" type="text" size="7" maxlength="5"><a href="$(homeURL)$(cGIPath)CostElemCatSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;fldcat=toCostElementCategory&amp;fldlongDesc=longDesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input name="longDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allCostElementCategory" value='ALL' $(checkedAllCostElementCategory) type="checkbox" onClick="if (this.checked) this.form.fromCostElementCategory.value='', this.form.toCostElementCategory.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FCECT)
                              @DspErrMsg(Err_N1TCECT)
                              @DspErrMsg(Err_N1ACECT)

                              @SetTextOvr(Err_N1FDEPT)
                              %if (textOvr == "") @SetTextOvr(Err_N1TDEPT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ADEPT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Department</span></td>
                                  <td class="inputalph"><input name="fromDepartment" value="$(V_N1FDEPT)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=fromDepartment&amp;fldWC=fromWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="toDepartment" value="$(V_N1TDEPT)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=toDepartment&amp;fldWC=toWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="allDepartment" value='ALL' $(checkedAllDepartment) type="checkbox" onClick="if (this.checked) this.form.fromDepartment.value='', this.form.toDepartment.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FDEPT)
                              @DspErrMsg(Err_N1TDEPT)
                              @DspErrMsg(Err_N1ADEPT)

                              @SetTextOvr(Err_N1FWC)
                              %if (textOvr == "") @SetTextOvr(Err_N1TWC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AWC) %endif
                              <tr><td class="dsphdr">Work Center </td>
                                  <td class="inputalph"><input name="fromWorkCenter" value="$(V_N1FWC)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=fromDepartment&amp;fldWC=fromWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="toWorkCenter" value="$(V_N1TWC)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=toDepartment&amp;fldWC=toWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="allWorkCenter" value='ALL' $(checkedAllWorkCenter) type="checkbox" onClick="if (this.checked) this.form.fromWorkCenter.value='', this.form.toWorkCenter.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FWC)
                              @DspErrMsg(Err_N1TWC)
                              @DspErrMsg(Err_N1AWC)

                          </table>

                          @dtw_assign(envProgram, "HSCECW")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSCECS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allPlantNumber)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(fromCostElementCategory)
  @dtw_mUPPERCASE(toCostElementCategory)
  @dtw_mUPPERCASE(allCostElementCategory)
  @dtw_mUPPERCASE(fromDepartment)
  @dtw_mUPPERCASE(toDepartment)
  @dtw_mUPPERCASE(allDepartment)
  @dtw_mUPPERCASE(fromWorkCenter)
  @dtw_mUPPERCASE(toWorkCenter)
  @dtw_mUPPERCASE(allWorkCenter)

  @dtw_assign(fromPlantNumber,@dtw_rstrip(fromPlantNumber))
  @dtw_assign(toPlantNumber,@dtw_rstrip(toPlantNumber))


  %if (allPlantNumber != "ALL")
      @dtw_assign(allPlantNumber, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allCostElementCategory != "ALL")
      @dtw_assign(allCostElementCategory, "")
  %endif
  %if (allDepartment != "ALL")
      @dtw_assign(allDepartment, "")
  %endif
  %if (allWorkCenter != "ALL")
      @dtw_assign(allWorkCenter, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@dtl@", includeCostElementDetail)
  @Concat_Field("@@fplt", fromPlantNumber)
  @Concat_Field("@@tplt", toPlantNumber)
  @Concat_Field("@@aplt", allPlantNumber)
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@fcec", fromCostElementCategory)
  @Concat_Field("@@tcec", toCostElementCategory)
  @Concat_Field("@@acec", allCostElementCategory)
  @Concat_Field("@@fdpt", fromDepartment)
  @Concat_Field("@@tdpt", toDepartment)
  @Concat_Field("@@adpt", allDepartment)
  @Concat_Field("@@fwc@", fromWorkCenter)
  @Concat_Field("@@twc@", toWorkCenter)
  @Concat_Field("@@awc@", allWorkCenter)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}