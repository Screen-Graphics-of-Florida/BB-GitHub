%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title 	        = "Employee Benefit"
  page_title2	        = "Dependent Benefit"
  d2wName              = "EmplBenefitSelect.d2w"
  attachFolder         = "EmployeeBenefit"
  d2wVarBase           = "$(genericVarBase)$(employeeVarBase)&amp;benefitCode=@dtw_rurlescseq(benefitCode)&amp;planCode=@dtw_rurlescseq(planCode)&amp;dependentNbr=@dtw_rurlescseq(dependentNbr)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(d2wName)"
  phpVarBase           = "$(altVarBase)$(employeeVarBase)&amp;benefitCode=@dtw_rurlescseq(benefitCode)&amp;planCode=@dtw_rurlescseq(planCode)&amp;dependentNbr=@dtw_rurlescseq(dependentNbr)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(d2wName)"
  programName          = "HPEECU"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  classification       = ""
  dspMaxRows           = "$(dspMaxRowsDft)"
  fsaMaint             = ""
  prtMaxRows           = "$(prtMaxRowsDft)"
  updateError          = ""
  applicationID        = "PE"
  attachVarKey         = ""
  attachForDesc        = ""
  quickLinksInUse      = "N"
  dataType             = "SSNO"
  modeD                = "D"
  modeI                = "I"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
  @dtw_replace(workURL, "@@dependentNbr", "@dtw_rurlescseq(dependentNbr)", "1", "a", workURL)
  @dtw_replace(workURL, "@@benefitCode", "@dtw_rurlescseq(benefitCode)", "1", "a", workURL)
  @dtw_replace(workURL, "@@planCode", "@dtw_rurlescseq(planCode)", "1", "a", workURL)
  @dtw_replace(workURL, "@@fromD2w", "@dtw_rurlescseq(fromD2w)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL_Display (INOUT stmtSQL) {
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
                  <table $(baseTable)>
                      <tr valign="top">
                          %if (formatToPrint == "")
                              @dtw_assign(pageID, "EMPLBENDISPLAY ")
                              <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                          %endif
                          <td class="content">
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                              @dtw_concat(fileSQL, " HREMCV inner join CBCOVR on ECCOMP=CVCOMP and ECFACL=CVFACL and ECCOVR=CVCOVR and ECPLAN=CVPLAN ", fileSQL)
                              @dtw_concat(fileSQL, "        inner join CBCODE on CVPLAN=CCCODE ", fileSQL)
                              @dtw_concat(selectSQL, " ECCOMP=$(prCompany) and ECFACL=$(prFacility) and ECEMPL=$(hrEmployee) and ECSPDP=$(dependentNbr) and ECCOVR='$(benefitCode)' and ECPLAN='$(planCode)' ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %INCLUDE "stmtSQLEnd.icl"
                              @Empl_Benefits_Display_Query(profileHandle, dataBaseID, stmtSQL)

                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select HREBBN.*, RRN(HREBBN) as BNRRN ", stmtSQL)
                              @dtw_concat(fileSQL, " HREBBN ", fileSQL)
                              @dtw_concat(selectSQL, " BNCOMP=$(prCompany) and BNFACL=$(prFacility) and BNEMPL=$(hrEmployee) and BNSPDP=$(dependentNbr) and BNCOVR='$(benefitCode)' and BNPLAN='$(planCode)' ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %INCLUDE "stmtSQLEnd.icl"
                              @Empl_Benefits_Ben(profileHandle, dataBaseID, stmtSQL)
                          </td>
                      </tr>
                  </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
    %endif
%}

%FUNCTION(DTW_SQL) Empl_Benefits_Display_Query(IN  CHAR(64)    profileHandle,
                                                   CHAR(2)     dataBaseID,
                                                   CHAR(32000) stmtSQL)

{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
      @RetDepNam(profileHandle, dataBaseID, dependentNbr, depName)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
              %if (dependentNbr == "0000000")
                  <tr><td><h1> Employee Benefit</h1></td>
              %else
                  <tr><td><h1> Dependent Benefit</h1></td>
              %endif
              @dtw_assign(dependentNbrFilled, "$(dependentNbr)")
              %while(@dtw_rlength(dependentNbrFilled) != "7") {@dtw_insert("0", dependentNbrFilled, dependentNbrFilled)%}

              %if (dependentNbr == "0000000")
                  @dtw_assign(attVar, "Employee_$(benefitCode)_$(planCode)")
              %else
                  @dtw_assign(attVar, "Dependent_$(dependentNbrFilled)_$(benefitCode)_$(planCode)")
              %endif
              %INCLUDE "emplAttachment.icl"
              %if (dependentNbr == "0000000")
                  @dtw_assign(attachForDesc, "$(F_EmpName) $(benefitCode) $(planCode)")
              %else
                  @dtw_assign(attachForDesc, "$(depName) $(benefitCode) $(planCode)")
              %endif
              @dtw_assign(attachPrg1, "HREMPL inner join HREMCV on EMCOMP=ECCOMP and EMFACL=ECFACL and EMEMPL=ECEMPL Where EMEMID=$(employeeID) and CVCOVR='$(benefitCode)' and CVPLAN = '$(planCode)'")

              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                      <td class="toolbar">
                      %INCLUDE "Attachment.icl"
                      %if ((backHome != "$(d2wName)/EMPLBENDISPLAY") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Return To Human Resource Administration">$(portalHome)</a>
                      %endif
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)EmplBenefitsAdd.d2w/ADD$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (sec_02 == "Y")
                          <a href="$(homeURL)$(phpPath)EmplBenefitsMaintain.php$(phpVarBase)&amp;tag=MAINTAIN&amp;maintenanceCode=C">$(changeImageLrg)</a>
                      %endif
                      %if (sec_03 == "Y")
                          @RtvFldDesc("CVCOMP=$(prCompany) AND CVFACL=$(prFacility) AND CVCOVR='$(benefitCode)' AND CVPLAN='$(planCode)'", "CBCOVR", "CVDESC", CVDESC)
                          @RtvFldDesc("CCCODE='$(planCode)'", "CBCODE", "CCDESC", CCDESC)
                          @Format_Confirm_Desc($(CVDESC), $(benefitCode), $(CCDESC), $(planCode), "", "", confirmDesc)
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(phpPath)EmplBenefitsMaintain.php$(phpVarBase)&amp;tag=Edit_Data&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                  </td>
              %endif
          </tr>
          %if (dependentNbr == "0000000")
              <tr><td><h2>$(F_EmpName)</h2></td></tr>
          %else
              <tr><td><h2> $(depName)</h2></td></tr>
          %endif
      </table>
      %INCLUDE "ConfMessageDisplay.icl"
      %ROW{
           @dtw_assign(V_ECDEDP, "@dtw_rformat(@dtw_rmultiply(V_ECDEDP, "100"),"","3")")
          <fieldset class="legendBody">
          <legend class="legendTitle"> Benefit </legend>
          <table $(contentTable)>
              <tr><td class="dsphdr">Benefit </td>
                  <td class="dspalph">$(V_CVDESC) </td></tr>

              <tr><td class="dsphdr">Plan </td>
                  <td class="dspnmbr">$(V_CCDESC)</td></tr>

              @Format_Date(V_ECELIG, "H", F_ECELIG)
              <tr><td class="dsphdr">Eligibility Date</td>
                  <td class="dspdate">$(F_ECELIG)</td></tr>

              @Format_Date(V_ECELEC, "H", F_ECELEC)
              <tr><td class="dsphdr">Enrollment Date</td>
                  <td class="dspdate">$(F_ECELEC)</td></tr>

              @Format_Date(V_ECDCE, "H", F_ECDCE)
              <tr><td class="dsphdr">Date Effective </td>
                  <td class="dspdate">$(F_ECDCE)</td></tr>

              %if(V_ECVEST != "0")
                  @Format_Date(V_ECVEST, "H", F_ECVEST)
                  <tr><td class="dsphdr">Vesting Date</td>
                      <td class="dspdate">$(F_ECVEST)</td></tr>
              %endif

              %if(V_ECAMT != "0")
                  <tr><td class="dsphdr">Amount </td>
                      <td class="dspnmbr">$(V_ECAMT)</td></tr>
              %endif

              %if(V_ECDEDA != ".00")
                 <tr><td class="dsphdr">Employee Deduction Amount</td>
                  @Format_Nbr($(V_ECDEDA), F_ECDEDA, "2", $(amtEditCode), "", "", "")
                  <td class="dspnmbr">$(F_ECDEDA)</td></tr>
              %endif

              %if(V_ECDEDP != "0.000")
                 <tr><td class="dsphdr">Employee Deduction Percent</td>
                     <td class="dspnmbr">$(V_ECDEDP)</td></tr>
              %endif

              %if (V_CVUNIT > "0")
                  <tr><td class="dsphdr">Number Of Units</td>
                      <td class="dspnmbr">$(V_ECUNIT)</td></tr>
              %endif

              @RtvColVal("ECCOMP=$(prCompany) and ECFACL=$(prFacility) and ECEMPL=$(hrEmployee) and ECSPDP=$(dependentNbr) and ECCOVR='$(benefitCode)' and ECPLAN='$(planCode)'", "HREMCV", "(ECPHSS)", "I", xsocsec) 
              @dtw_assign(V_ECPHSS, xsocsec)
             
              @Format_SSN(V_ECPHSS, F_ECPHSS)
              %if (V_ECPHSS > "0")
                  %while(@dtw_rlength(V_ECPHSS) != "9") {@dtw_insert("0", V_ECPHSS, V_ECPHSS)%}
              %endif
			  <tr><td class="dsphdr">Plan Holder SS# </td>
                  <td class="dspnmbr">$(F_ECPHSS)</td></tr>

              %if (V_ECPHC > "0")
                  @RtvFldDesc("FLTYPE='PLANHOLDER' and FLVALU='$(V_ECPHC)'", "SYFLAG", "FLDESC", syFlagDesc)
                  <tr><td class="dsphdr">Plan Holder Code </td>
                      <td class="dspalph">$(syFlagDesc)</td></tr>
              %endif

              %if (V_ECID > "")
                  <tr><td class="dsphdr">Identification Number</td>
                      <td class="dspnmbr">$(V_ECID)</td></tr>
              %endif

              @Format_Date(V_ECEDOC, "H", F_ECEDOC)
              <tr><td class="dsphdr">Electronic Document Distribution Authorization</td>
                  <td class="dspdate">$(F_ECEDOC)</td></tr>
          </table>
          </fieldset>

          %if(V_ECCERT != "0")
              <fieldset class="legendBody">
              <legend class="legendTitle"> Certificate Receipt </legend>
              <table $(contentTable)>
                  @Format_Date(V_ECCERT, "H", F_ECCERT)
                  <tr><td class="dsphdr">Date Received</td>
                      <td class="dspdate">$(F_ECCERT)</td></tr>

                  <tr><td class="dsphdr">Issuer</td>
                      <td class="dspnmbr">$(V_ECCISU)</td></tr>

                  %if (V_ECPHON > "0")
                      @EditPhoneNumber(V_ECPHON)
                  %endif
                  <tr><td class="dsphdr">Phone Number Of Issuer</td>
                      <td class="dspnmbr">$(V_ECPHON)</td></tr>

                  <tr><td class="dsphdr">Previous Months Of Coverage</td>
                      <td class="dspnmbr">$(V_ECMNTH)</td></tr>

                  @Format_Date(V_ECPREC, "H", F_ECPREC)
                  <tr><td class="dsphdr">Preexisting Condition Expiration Date</td>
                      <td class="dspdate">$(F_ECPREC)</td></tr>

              </table>
              </fieldset>
          %endif

          %if(V_ECDCT != "0")
              <fieldset class="legendBody">
              <legend class="legendTitle"> Benefit Termination </legend>
              <table $(contentTable)>
                  @Format_Date(V_ECDCT, "H", F_ECDCT)
                  <tr><td class="dsphdr">Coverage Termination Date </td>
                      <td class="dspdate">$(F_ECDCT)</td></tr>

                  @Format_Date(V_ECTRCR, "H", F_ECTRCR)
                  <tr><td class="dsphdr">Date Certificate Requested </td>
                      <td class="dspdate">$(F_ECTRCR)</td></tr>

                  @Format_Date(V_ECTRCI, "H", F_ECTRCI)
                  <tr><td class="dsphdr">Date Certificate Issued</td>
                      <td class="dspdate">$(F_ECTRCI)</td></tr>

                  @RtvYNDesc($(V_ECACKN), fieldDesc)
                  <tr><td class="dsphdr">Employee Receipt</td>
                      <td class="dspalph">$(fieldDesc)</td></tr>

                  @RtvYNDesc($(V_ECCARR), fieldDesc)
                  <tr><td class="dsphdr">Carrier Notified</td>
                      <td class="dspalph">$(fieldDesc)</td></tr>

                  <tr><td class="dsphdr">COBRA Premium Override</td>
                      @Format_Nbr($(V_ECPREM), F_ECPREM, "2", $(amtEditCode), "", "", "")
                      <td class="dspnmbr">$(F_ECPREM)</td></tr>
              </table>
              </legend>
              </fieldset>
          %endif
      %INCLUDE "AttachmentSQL.icl"
      %}
  %}
%}
%FUNCTION(DTW_SQL) Empl_Benefits_Ben(IN  CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)

{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(haveRows, "")

      %ROW{
          %if (haveRows == "")
              <fieldset class="legendBody">
              <legend class="legendTitle">Beneficiaries</legend>
                  <table $(contentTable)>
    	              <tr>
                          <th class="colhdr">Name</th>
                          <th class="colhdr">Soc Sec No</th>
                          <th class="colhdr">Percent</th>
                     </tr>
              @dtw_assign(haveRows,"Y")
          %endif
          %INCLUDE "SetRowClass.icl"
          @RtvColVal("RRN(HREBBN)=$(V_BNRRN)", "HREBBN", "(BNBSSN)", "I", xsocsec) 
          @dtw_assign(V_BNBSSN, xsocsec)
         
          @Format_SSN(V_BNBSSN, F_BNBSSN)

          <tr class="$(rowClass)">
              <td class="colalph">$(V_BNBNAM)</td>
              <td class="colalph">$(F_BNBSSN)</td>
              <td class="colnmbr">$(V_BNBPCT)</td>
          </tr>
      %}
      %if (haveRows == "Y")
          </table>
          </fieldset>
      %endif
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}
%INCLUDE "AttachmentSelect.icl"

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL_Display(stmtSQL)
  %endif
%}
