%INCLUDE "$(baseVar)"
%INCLUDE "GenericDirectCallVariables.icl"

%Define {
  page_title              = "Sign On"
  d2wName                 = "SignonEntry.d2w"
%}

%HTML(returnsignon) {
  %INCLUDE "$(signonPage)"
%}

%HTML(REPORT) {
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(welcomePageType)/WELCOME?baseVar=@dtw_rurlescseq(baseVar)&amp;newsLink=@dtw_rurlescseq(newsLink)&amp;profileName=@dtw_rurlescseq(profileName)">
%}

%HTML(SELECT) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("USUSER='$(userProfile)'", "SYUSER", "USROLE", activeRole)
  @dtw_SetCookie("role_cookie", "$(activeRole)", "path=/")
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Update SYHAND Set HNROLE='$(activeRole)' Where HNXHND='$(profileHandle)' @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(welcomePageType)/WELCOME?baseVar=@dtw_rurlescseq(baseVar)&amp;newsLink=@dtw_rurlescseq(newsLink)&amp;profileName=@dtw_rurlescseq(profileName)">
%}