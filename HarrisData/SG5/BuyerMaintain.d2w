%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Buyer Maintenance"
  d2wName                 = "BuyerMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;buyer=@dtw_rurlescseq(buyer)&amp;buyerDesc=@dtw_rurlescseq(buyerDesc)&amp;maintenanceCode=D"
  programName             = "HHDBUP"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
              if (document.Chg.buyer.value =="" ||
                  document.Chg.buyerDesc.value =="")
                     {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.buyer, 7, 0))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
              %INCLUDE "NumEdit.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "BUYERMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From HDBUYR Where BMBUYR = $(buyer)", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Buyer_Maintain(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Buyer_Maintain (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=103")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "buyer")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@buyr", "buyer")           @dtw_assign(Err_BMBUYR, fieldValue)
                          @DecatErr_Field("@@bna1", "buyerDesc")       @dtw_assign(Err_BMBNA1, fieldValue)
                          @DecatErr_Field("@@alph", "alphaSequence")   @dtw_assign(Err_BMALPH, fieldValue)
                      %endif

                      @Decat_Field("@@buyr")   @dtw_assign(V_BMBUYR, fieldValue)
                      @Decat_Field("@@bna1")   @dtw_assign(V_BMBNA1, fieldValue)
                      @Decat_Field("@@alph")   @dtw_assign(V_BMALPH, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "buyer")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_BMBUYR, "")
                      @dtw_assign(focusField, "buyer")
                  %else
                      @dtw_assign(focusField, "buyerDesc")
                  %endif

                  @SetTextOvr(Err_BMBUYR)
                  <tr><td class="dsphdr"><span $(textOvr)>Buyer</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="buyer" type="text" value="$(V_BMBUYR)" size="7" maxlength="7"> $(reqFieldChar) </td>
                      %else
                          <td class="inputnmbr"><input name="buyer" type="hidden" value="$(V_BMBUYR)" size="7" maxlength="7">$(V_BMBUYR)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_BMBUYR)

                  @dtw_assign(buyerDesc, V_BMBNA1)
                  @SetTextOvr(Err_BMBNA1)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="buyerDesc" type="text" value="$(V_BMBNA1)" size="26" maxlength="26"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_BMBNA1)
		
                  @SetTextOvr(Err_BMALPH)
                  <tr><td class="dsphdr"><span $(textOvr)>Alpha Sequence</span></td>
                      <td class="inputalph"><input type="text" name="alphaSequence" value="$(V_BMALPH)" size="4" maxlength="4"></td>
                  </tr>
                  @DspErrMsg(Err_BMALPH)
              %}
          </table>
	
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDBUP_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(alphaSequence)
  @dtw_assign(buyer,@dtw_rstrip(buyer))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@buyr", buyer)
  @Concat_Field("@@bna1", buyerDesc)
  @Concat_Field("@@alph", alphaSequence)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(buyerDesc), $(buyer), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@buyr", "buyer")
          @Format_ConfMsg_Desc("", $(buyerDesc), $(buyer), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=103&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;buyer=@dtw_rurlescseq(buyer)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
