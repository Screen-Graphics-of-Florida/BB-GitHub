%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Map Column Maintenance"
  d2wName                 = "MapColumnMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;mapKey=@dtw_rurlescseq(mapKey)&amp;interfaceTable=@dtw_rurlescseq(interfaceTable)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;passedInterfaceTable=@dtw_rurlescseq(passedInterfaceTable)&amp;updRecNbr=@dtw_rurlescseq(updRecNbr)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  editVariables           = ""
  interfaceLibrary        = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @RtvFldDesc("MEXHND='$(profileHandle)' and MEMPKY=$(mapKey) and MEMFIL='$(interfaceTable)' ", "SYMMCW", "char(count(*))", recCount)	
  %if (recCount <= "0")
      @RtvFileLib(interfaceTable, interfaceLibrary)

      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Insert Into SYMMCW (MEXHND,MEMPKY,MEMFIL,MEMFLD,MEDESC,MEDPOS,MEFLDT,MESTOR,MENAB,MEDLGC,MEPARM,MENOTE) ", stmtSQL)
      @dtw_concat(stmtSQL, " Select '$(profileHandle)', MDMPKY,MDMFIL,MDMFLD,MDDESC,MDDPOS,MDFLDT,MDSTOR,MDNAB,MDDLGC,MDPARM,MDNOTE ", stmtSQL)
      @dtw_concat(stmtSQL, " From SYMMCL ", stmtSQL)
      @dtw_concat(stmtSQL, " inner join QSYS2/SYSCOLUMNS on SYSTEM_TABLE_NAME='$(interfaceTable)' and SYSTEM_TABLE_SCHEMA='$(interfaceLibrary)' and SYSTEM_TABLE_NAME=MDMFIL and SYSTEM_COLUMN_NAME=MDMFLD ", stmtSQL)
      @dtw_concat(stmtSQL, " Where MDMPKY=$(mapKey) and MDMFIL='$(interfaceTable)' ", stmtSQL)
      @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)

      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Update SYMMCW Set ", stmtSQL)
      @dtw_concat(stmtSQL, " METTYP= ", stmtSQL)
      @dtw_concat(stmtSQL, "   (Select case when DATA_TYPE = 'NUMERIC' or DATA_TYPE='DECIMAL' THEN 'N' ", stmtSQL)
      @dtw_concat(stmtSQL, "                when DATA_TYPE = 'CHAR'                           THEN 'A' ", stmtSQL)
      @dtw_concat(stmtSQL, "                when DATA_TYPE = 'DATE'                           THEN 'L' ", stmtSQL)
      @dtw_concat(stmtSQL, "                when DATA_TYPE = 'TIMESTMP'                       THEN 'Z' ", stmtSQL)
      @dtw_concat(stmtSQL, "                ELSE ' ' END ", stmtSQL)
      @dtw_concat(stmtSQL, "    From QSYS2/SYSCOLUMNS Where SYSTEM_TABLE_NAME ='$(interfaceTable)' and SYSTEM_TABLE_SCHEMA = '$(interfaceLibrary)' and SYSTEM_TABLE_NAME =MEMFIL and SYSTEM_COLUMN_NAME=MEMFLD),", stmtSQL)
      @dtw_concat(stmtSQL, " METPOS= ", stmtSQL)
      @dtw_concat(stmtSQL, "   (Select ORDINAL_POSITION ", stmtSQL)
      @dtw_concat(stmtSQL, "    From QSYS2/SYSCOLUMNS Where SYSTEM_TABLE_NAME ='$(interfaceTable)' and SYSTEM_TABLE_SCHEMA = '$(interfaceLibrary)' and SYSTEM_TABLE_NAME =MEMFIL and SYSTEM_COLUMN_NAME=MEMFLD),", stmtSQL)
      @dtw_concat(stmtSQL, " MESIZE= ", stmtSQL)
      @dtw_concat(stmtSQL, "   (Select LENGTH ", stmtSQL)
      @dtw_concat(stmtSQL, "    From QSYS2/SYSCOLUMNS Where SYSTEM_TABLE_NAME ='$(interfaceTable)' and SYSTEM_TABLE_SCHEMA = '$(interfaceLibrary)' and SYSTEM_TABLE_NAME =MEMFIL and SYSTEM_COLUMN_NAME=MEMFLD),", stmtSQL)
      @dtw_concat(stmtSQL, " MEDECM= ", stmtSQL)
      @dtw_concat(stmtSQL, "   (Select coalesce(NUMERIC_SCALE,0) ", stmtSQL)
      @dtw_concat(stmtSQL, "    From QSYS2/SYSCOLUMNS Where SYSTEM_TABLE_NAME ='$(interfaceTable)' and SYSTEM_TABLE_SCHEMA = '$(interfaceLibrary)' and SYSTEM_TABLE_NAME =MEMFIL and SYSTEM_COLUMN_NAME=MEMFLD) ", stmtSQL)
      @dtw_concat(stmtSQL, " Where MEXHND='$(profileHandle)' and MEMPKY=$(mapKey) and MEMFIL='$(interfaceTable)' ", stmtSQL)
      @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)

      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Update SYMMCW Set ", stmtSQL)
      @dtw_concat(stmtSQL, " MEFLDT=METTYP ", stmtSQL)
      @dtw_concat(stmtSQL, " Where MEXHND='$(profileHandle)' and MEMPKY=$(mapKey) and MEMFIL='$(interfaceTable)' ", stmtSQL)
      @dtw_concat(stmtSQL, "   and (METTYP<>'N' or MEDECM<>0 or (MESIZE<>7 and MESIZE<>5)) ", stmtSQL)
      @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)
      
      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Insert Into SYMMCW (MEXHND,MEMPKY,MEMFIL,MEMFLD,MEDESC,MEDPOS,MEFLDT,MESTOR,MENAB,MEDLGC,MEPARM,MENOTE,METPOS,MESIZE,MEDECM,METTYP) ", stmtSQL)
      @dtw_concat(stmtSQL, " Select '$(profileHandle)', $(mapKey),'$(interfaceTable)', ", stmtSQL)
      @dtw_concat(stmtSQL, "        SYSTEM_COLUMN_NAME,COLUMN_TEXT,0, ", stmtSQL)
      @dtw_concat(stmtSQL, "        case when DATA_TYPE = 'NUMERIC' or DATA_TYPE='DECIMAL' THEN 'N' ", stmtSQL)
      @dtw_concat(stmtSQL, "             when DATA_TYPE = 'CHAR'                           THEN 'A' ", stmtSQL)
      @dtw_concat(stmtSQL, "             when DATA_TYPE = 'DATE'                           THEN 'L' ", stmtSQL)
      @dtw_concat(stmtSQL, "             when DATA_TYPE = 'TIMESTMP'                       THEN 'Z' ", stmtSQL)
      @dtw_concat(stmtSQL, "             ELSE ' ' END, ", stmtSQL)
      @dtw_concat(stmtSQL, "        ' ',' ',' ',' ',' ', ORDINAL_POSITION,LENGTH,coalesce(NUMERIC_SCALE,0), ", stmtSQL)
      @dtw_concat(stmtSQL, "        case when DATA_TYPE = 'NUMERIC' or DATA_TYPE='DECIMAL' THEN 'N' ", stmtSQL)
      @dtw_concat(stmtSQL, "             when DATA_TYPE = 'CHAR'                           THEN 'A' ", stmtSQL)
      @dtw_concat(stmtSQL, "             when DATA_TYPE = 'DATE'                           THEN 'L' ", stmtSQL)
      @dtw_concat(stmtSQL, "             when DATA_TYPE = 'TIMESTMP'                       THEN 'Z' ", stmtSQL)
      @dtw_concat(stmtSQL, "             ELSE ' ' END ", stmtSQL)
      @dtw_concat(stmtSQL, " From QSYS2/SYSCOLUMNS Where SYSTEM_TABLE_NAME ='$(interfaceTable)' and SYSTEM_TABLE_SCHEMA = '$(interfaceLibrary)' ", stmtSQL)
      @dtw_concat(stmtSQL, " and not exists (Select * from SYMMCW where MEXHND='$(profileHandle)' and MEMPKY=$(mapKey) and MEMFIL='$(interfaceTable)' and MEMFLD=SYSTEM_COLUMN_NAME) ", stmtSQL)
      @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)
  %endif

  @RtvFldDesc("MEXHND='$(profileHandle)' and MEMPKY=$(mapKey) and MEMFIL='$(interfaceTable)' ", "SYMMCW", "char(count(*))", recCount)	
  @dtw_assign(editVariables, "")
  @dtw_assign(ux, "1")
  %while(ux <= recCount){
      @dtw_assign(recNbr, ux)
      %while(@dtw_rlength(recNbr) != "4") {@dtw_insert("0", recNbr, recNbr)%}
      %if (editVariables != "")
          @dtw_concat(editVariables, "  &&", editVariables)
      %endif
      @dtw_concat(editVariables, " editNum(document.Chg.sq$(recNbr), 3, 1) ", editVariables)
      @dtw_add(ux, "1", ux)
  %}
  %INCLUDE "$(docType)"
  <html>
      <head>
 	   %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function confirmCancel()  { return confirm("Confirm cancel of update")}
              function confirmRefresh() { return confirm("Confirm refresh of columns")}
              function validate(chgForm) {
                  if ($(editVariables))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "MAPCOLUMNMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select SYMMCW.*,  ", stmtSQL)
                      @dtw_concat(stmtSQL, " Case WHEN MEDPOS > 0 THEN 'A' ELSE 'B' END as Section", stmtSQL)
                      @dtw_concat(stmtSQL, " From SYMMCW ", stmtSQL)
                      @dtw_concat(stmtSQL, " Where MEXHND='$(profileHandle)' and MEMPKY=$(mapKey) and MEMFIL='$(interfaceTable)' ", stmtSQL)
                      @dtw_concat(stmtSQL, " Order By Section,MEDPOS,METPOS,MEMFLD ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  <a href="javascript:document.Chg.updateOption.value=' '; check(document.Chg)">$(editNoUpdateSml)</a>
                  <a href="javascript:document.Chg.updateOption.value='U'; check(document.Chg)">$(acceptImageMed)</a>
                  <a onClick="return confirmCancel()"  href="javascript:history.back()">$(cancelImageMed)</a>
                  <a onClick="return confirmRefresh()" href="$(homeURL)$(cGIPath)$(d2wName)/REFRESH$(d2wVarBase)">$(selectResetImage)</a>
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>
      <table $(contentTable)>
          @RtvFldDesc("MHMPKY=$(mapKey)", "SYMMHD", "MHDESC", mapKeyDescription)
          @RtvFldDesc("MHMPKY=$(mapKey)", "SYMMHD", "MHWPGM", mapWFProgram)
          @Format_Header("Map Definition", $(mapKeyDescription), $(mapWFProgram))

          @RtvFldDesc("MFMPKY=$(mapKey) and MFMFIL='$(interfaceTable)'", "SYMMTB", "MFDESC", interfaceTableDescription)
          @RtvFldDesc("MFMPKY=$(mapKey) and MFMFIL='$(interfaceTable)'", "SYMMTB", "MFPRMR", V_MFPRMR)
          @Format_Header("Interface Table", $(interfaceTableDescription), $(interfaceTable))
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
		
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              <tr><td><input type="hidden" name="updateOption"></td></tr>
              <tr>
                  <td class="colhdr">Column</td>
                  <td class="colhdr">Display Position</td>
                  <td class="colhdr">Description</td>
                  <td class="colhdr">Column Type</td>
                  <td class="colhdr">Numeric Stored</td>
                  <td class="colhdr">Normal Balance</td>
                  <td class="colhdr">Default Logic</td>
                  %if (V_MFPRMR=="Y")
                      <td class="colhdr">Workflow Parameter</td>
                  %endif
                  <td class="colhdr">Note</td>
              </tr>
              %ROW {

                  @dtw_assign(recNbr, $(ROW_NUM))
                  %while(@dtw_rlength(recNbr) != "4") {@dtw_insert("0", recNbr, recNbr)%}

                  <tr>
                      <td class="inputalph"><input type="hidden" name="co$(recNbr)" value="$(V_MEMFLD)">$(V_MEMFLD)</td>
                      <td class="inputnmbr"><input type="text"   name="sq$(recNbr)" value="$(V_MEDPOS)" size="3" maxlength="5"></td>
                      <td class="inputalph"><input type="text"   name="ds$(recNbr)" value="$(V_MEDESC)" size="30" maxlength="50"></td>
                      %if (V_METTYP=="N" && V_MEDECM=="0" && (V_MESIZE=="7" || V_MESIZE=="5"))
                          <td class="inputalph"><input type="text"   name="ft$(recNbr)" value="$(V_MEFLDT)" size="1" maxlength="1"></td>
                      %else
                          <td class="inputalph"><input type="hidden" name="ft$(recNbr)" value="$(V_MEFLDT)">$(V_MEFLDT)</td>
                      %endif
                      %if (V_METTYP=="N")
                          <td class="inputalph" nowrap><input type="text"   name="ns$(recNbr)" value="$(V_MESTOR)" size="1" maxlength="1">
                                                <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=POSNEG&amp;flagSrchHdr=@dtw_rurlescseq("Numeric Stored")&amp;docName=Chg&amp;fldName=ns$(recNbr)&amp;fldDesc=ns$(recNbr)Desc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                <input type="hidden" name="ns$(recNbr)Desc"></td>
                          <td class="inputalph" nowrap><input type="text"   name="nb$(recNbr)" value="$(V_MENAB)" size="1" maxlength="1">
                                                <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=POSNEG&amp;flagSrchHdr=@dtw_rurlescseq("Normal Balance")&amp;docName=Chg&amp;fldName=nb$(recNbr)&amp;fldDesc=nb$(recNbr)Desc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                <input type="hidden" name="nb$(recNbr)Desc"></td>
                      %else
                          <td class="inputalph"><input type="hidden" name="ns$(recNbr)" value=""></td>
                          <td class="inputalph"><input type="hidden" name="nb$(recNbr)" value=""></td>
                      %endif
                      <td class="inputalph" nowrap><input type="text"   name="dl$(recNbr)" value="$(V_MEDLGC)" size="1" maxlength="1">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=BY&amp;flagSrchHdr=@dtw_rurlescseq("Default Logic")&amp;docName=Chg&amp;fldName=dl$(recNbr)&amp;fldDesc=dl$(recNbr)Desc" onclick="$(searchWinVar)">$(searchImage)</a>
                                            <input type="hidden" name="dl$(recNbr)Desc"></td>
                      %if (V_MFPRMR=="Y")
                          <td class="inputalph" nowrap><input type="text"   name="pm$(recNbr)" value="$(V_MEPARM)" size="4" maxlength="4">
                                                <a href="$(homeURL)$(cGIPath)WFParameterSearch.d2w/REPORT$(genericVarBase)&amp;docName=Chg&amp;fldName=pm$(recNbr)&amp;fldDesc=pm$(recNbr)Desc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                <input type="hidden" name="pm$(recNbr)Desc"></td>
                      %endif
                      <td class="inputalph"><input type="text"   name="nt$(recNbr)" value="$(V_MENOTE)" size="1000" maxlength="1000"></td>
                  </tr>
                  %if (V_MEMSG# != "")
                      @Ret_Error_Msg(profileHandle, dataBaseID, $(V_MEMSG#), errorMessage)
                      <tr>
                          <td class="error" colspan="9">Error: $(errorMessage)</td>		
                      </tr>
                  %endif
              %}
          </table>
      </form>
      <table $(contentTable)>
          <tr>
              <td class="toolbar">
                  <a href="javascript:document.Chg.updateOption.value=' '; check(document.Chg)">$(editNoUpdateSml)</a>
                  <a href="javascript:document.Chg.updateOption.value='U'; check(document.Chg)">$(acceptImageMed)</a>
                  <a onClick="return confirmCancel()"  href="javascript:history.back()">$(cancelImageMed)</a>
                  <a onClick="return confirmRefresh()" href="$(homeURL)$(cGIPath)$(d2wName)/REFRESH$(d2wVarBase)">$(selectResetImage)</a>
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSYMFM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(REFRESH) {
  %INCLUDE "setLibraryList.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Delete From SYMMCW Where MEXHND='$(profileHandle)' and MEMPKY=$(mapKey) and MEMFIL='$(interfaceTable)' ", stmtSQL)
  @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
  @SQL_Update(stmtSQL, status)

  @Set_SQL(stmtSQL)
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @RtvFldDesc("MEXHND='$(profileHandle)' and MEMPKY=$(mapKey) and MEMFIL='$(interfaceTable)' ", "SYMMCW", "char(count(*))", recCount)	
  @dtw_assign(ux, "1")
  %while(ux <= recCount){
      @dtw_assign(recNbr, ux)
      %while(@dtw_rlength(recNbr) != "4") {@dtw_insert("0", recNbr, recNbr)%}
      @dtw_assign(mfld, $(co$(recNbr)))
      @dtw_assign(dpos, $(sq$(recNbr)))   %if (dpos=="")  @dtw_assign(dpos, "0") %endif
      @dtw_assign(desc, $(ds$(recNbr)))
      @dtw_assign(fldt, $(ft$(recNbr)))   @dtw_mUPPERCASE(fldt)
      @dtw_assign(stor, $(ns$(recNbr)))   @dtw_mUPPERCASE(stor)
      @dtw_assign(nab , $(nb$(recNbr)))   @dtw_mUPPERCASE(nab)
      @dtw_assign(dlgc, $(dl$(recNbr)))   @dtw_mUPPERCASE(dlgc)
      @dtw_assign(parm, $(pm$(recNbr)))
      @dtw_assign(note, $(nt$(recNbr)))

      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Update SYMMCW Set MEDPOS=$(dpos), MEDESC='$(desc)', MEFLDT='$(fldt)', MESTOR='$(stor)', MENAB='$(nab)', MEDLGC='$(dlgc)', MEPARM='$(parm)', MENOTE='$(note)' ", stmtSQL)
      @dtw_concat(stmtSQL, " Where MEXHND='$(profileHandle)' and MEMPKY=$(mapKey) and MEMFIL='$(interfaceTable)' and MEMFLD='$(mfld)' ", stmtSQL)
      @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)

      @dtw_add(ux, "1", ux)
  %}

  @dtw_assign(maintenanceCode, updateOption)
  @dtw_assign(edtVar, "")
  @Concat_Field("@@mpky", mapKey)
  @Concat_Field("@@mfil", interfaceTable)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" && updateOption=="U")
      @RtvFldDesc("MFMPKY=$(mapKey) and MFMFIL='$(interfaceTable)'", "SYMMTB", "MFDESC", interfaceTableDescription)
      @Format_ConfMsg_Desc("C", $(interfaceTableDescription), "$(interfaceTable)", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
