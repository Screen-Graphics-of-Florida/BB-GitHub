%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Order Comments"
  d2wName                 = "OrderComments.d2w"
  d2wVarBase              = "$(genericVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  DTW_PAD_PGM_PARMS       = "YES"
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Open_History_Comments(profileHandle, dataBaseID, orderNumber, orderSequence, lineNumber, releaseNumber, orderDocType, type, commentTable)
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "headcmt.icl"
      </head>
  	
      <body $(bodyTagAttr) onLoad="window.focus()" onBlur="window.close()">
          %INCLUDE "$(cmtBanner)"
          <table $(contentTable)>
              @Format_Header("Order", $(orderNumber), "")
              @Format_Header("Line", $(lineNumber), "")
              @Format_Header("Release", $(releaseNumber), "")
              @RtvFldDesc("DODOCT='$(orderDocType)' and DOAPID='OE'", "HDDOCT", "DODESC", orderDocTypeDesc)
              @Format_Header("Document Type", $(orderDocTypeDesc), $(orderDocType))
          </table>
          $(hrTagAttr)

          <table $(contentTable)>
              @dtw_tb_rows(commentTable, maxRows)
              %if (maxRows > "0")
                  %INCLUDE "SetRowClass.icl"
                  @dtw_assign(x, "1")
                  %while(x <= maxRows){@dtw_tb_getv(commentTable, x, "1", cmt) @dtw_add(x, "1", x)
                      <tr class="$(rowClass)">
                          %if (cmt != "")
                              <td>&nbsp;</td><td class="colalph" colspan="4">$(cmt)</td>
                          %else
                              <td>&nbsp;</td><td class="colalph" colspan="4">&nbsp;</td>
                          %endif
                      </tr>
                  %}
              %endif
          </table>
          $(hrTagAttr)
          %INCLUDE "$(cmtTrailer)"
      </body>
  </html>
%}