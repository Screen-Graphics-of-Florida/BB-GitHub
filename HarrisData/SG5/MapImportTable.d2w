%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Import Table"
  d2wName                 = "MapImportTable.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;importKey=@dtw_rurlescseq(importKey)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HSYITM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  noMsg                   = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "MAPIMPORTTABLE")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select SYMITB.*,  ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(b.FLDESC,' ') as FixedFLDESC, upper(coalesce(b.FLDESC,' ')) as FixedFLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(c.FLDESC,' ') as DateFLDESC, upper(coalesce(c.FLDESC,' ')) as DateFLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(d.FLDESC,' ') as PeriodFLDESC, upper(coalesce(d.FLDESC,' ')) as PeriodFLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(e.FLDESC,' ') as TimeFLDESC, upper(coalesce(e.FLDESC,' ')) as TimeFLDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " SYMITB ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG b on b.FLTYPE='BY'      and b.FLVALU=FFFIXF ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG c on c.FLTYPE='DATEFMT' and c.FLVALU=FFDTFM ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG d on d.FLTYPE='PDFMT'   and d.FLVALU=FFPDFM ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG e on e.FLTYPE='TIMEFMT' and e.FLVALU=FFTMFM ", fileSQL)
                      @dtw_concat(selectSQL, " FFIMKY=$(importKey) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)MapImportTableMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      <table $(contentTable)>
          @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "FHDESC", V_FHDESC)
          @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "CHAR(FHMPKY)", V_FHMPKY)
          @Format_Header_URL("Import Definition", $(V_FHDESC), $(importKey), "$(homeURL)$(cGIPath)MapImportDefinitionSelect.d2w/REPORT$(d2wVarBase)")

          @RtvFldDesc("MHMPKY=$(V_FHMPKY)", "SYMMHD", "MHDESC", V_MHDESC)
          @RtvFldDesc("MHMPKY=$(V_FHMPKY)", "SYMMHD", "MHWPGM", V_MHWPGM)
          @Format_Header("Map Definition", $(V_MHDESC), $(V_MHWPGM))
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint == "")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">Import Table</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="15" maxlength="50">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchTable" size="10" maxlength="10">
                          <input type="hidden" name="operTable" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("FFDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description"  title="Sequence By Description, Import Table">Description</a></th>
              @OrderBy_Sort("FFIFIL", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Table"        title="Sequence By Import Table">Import Table</a></th>
              @OrderBy_Sort("FixedFLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FixedFormat"  title="Sequence By Fixed Format, Import Table">Fixed Format</a></th>
              @OrderBy_Sort("FFFDLM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Delimiter"    title="Sequence By Column Delimiter, Import Table">Column Delimiter</a></th>
              @OrderBy_Sort("FFRTPS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RecTypPos"    title="Sequence By Row Type Position/Placement, Import Table">Row Type Position/ Placement</a></th>
              @OrderBy_Sort("FFRTLN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RecTypLen"    title="Sequence By Row Type Length, Import Table">Row Type Length</a></th>
              @OrderBy_Sort("DateFLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DateFormat"   title="Sequence By Date Format, Import Table">Date Format</a></th>
              @OrderBy_Sort("PeriodFLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PeriodFormat" title="Sequence By Period Format, Import Table">Period Format</a></th>
              @OrderBy_Sort("TimeFLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TimeFormat"   title="Sequence By Time Format, Import Table">Time Format</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;importTable=@dtw_rurlescseq(V_FFIFIL)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;updRecNbr=@dtw_rurlescseq(START_ROW_NUM)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_FFDESC), "$(V_FFIFIL)", "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)MapImportTableMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)MapImportTableMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromImportTable=@dtw_rurlescseq(V_FFIFIL)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)MapImportTableMaintain.d2w/EDIT_DATA$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)MapImportTableSelect.d2w/REPORT$(d2wVarBase)&amp;passedImportTable=@dtw_rurlescseq(V_FFIFIL)" title="View Import Table">$(V_FFDESC)</a></td>
                  <td class="colalph">$(V_FFIFIL)</td>
                  <td class="colcode" $(helpCursor)><span title="$(V_FFFIXF)">$(V_FixedFLDESC)</span></td>
                  <td class="colcode">$(V_FFFDLM)</td>
                  <td class="colnmbr">$(V_FFRTPS)</td>
                  <td class="colnmbr">$(V_FFRTLN)</td>
                  <td class="colalph" $(helpCursor)><span title="$(V_FFDTFM)">$(V_DateFLDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_FFPDFM)">$(V_PeriodFLDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_FFTMFM)">$(V_TimeFLDESC)</span></td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select SYMITB.*,  ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(b.FLDESC,' ') as FixedFLDESC, upper(coalesce(b.FLDESC,' ')) as FixedFLDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(c.FLDESC,' ') as DateFLDESC, upper(coalesce(c.FLDESC,' ')) as DateFLDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(d.FLDESC,' ') as PeriodFLDESC, upper(coalesce(d.FLDESC,' ')) as PeriodFLDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(e.FLDESC,' ') as TimeFLDESC, upper(coalesce(e.FLDESC,' ')) as TimeFLDESCU ", stmtSQL)
  @dtw_concat(fileSQL, " SYMITB ", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG b on b.FLTYPE='BY'      and b.FLVALU=FFFIXF ", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG c on c.FLTYPE='DATEFMT' and c.FLVALU=FFDTFM ", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG d on d.FLTYPE='PDFMT'   and d.FLVALU=FFPDFM ", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG e on e.FLTYPE='TIMEFMT' and e.FLVALU=FFTMFM ", fileSQL)
  @dtw_concat(selectSQL, " FFIMKY=$(importKey) ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_XMLQuery (IN  CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("MapImportTableList")
          %ROW{
              @XMLIDTag("$(V_FFIMKY)-$(V_FFIFIL)", "MapImportTable ID")
                  @XMLTag(V_FFIMKY, "MapDefinition")
                  @XMLTag(V_FFIFIL, "ImportTable")
                  @XMLTag(V_FFDESC, "Description")
                  @XMLTag(V_FFFIXF, "FixedFormat")
                  @XMLTag(V_FFFDLM, "ColumnDelimiter")
                  @XMLTag(V_FFRTPS, "RowTypePositionPlacement")
                  @XMLTag(V_FFRTLN, "RowTypeLength")
                  @XMLTag(V_FFDTFM, "DateFormat")
                  @XMLTag(V_FFPDFM, "PeriodFormat")
                  @XMLTag(V_FFTMFM, "TimeFormat")
              @XMLEndTag("MapImportTable")
          %}
      @XMLEndTag("MapImportTableList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "FFDESCU,FFIFIL")
          @DTW_ASSIGN(orderByDisplay, "Description,  Import Table")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %if (updRecNbr > "0")
      @dtw_assign(START_ROW_NUM, updRecNbr)
      @dtw_assign(updRecNbr, "")
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Description")
      %if (orderBy == "FFDESCU,FFIFIL")
          @DTW_ASSIGN(orderBy, "FFDESCU DESC,FFIFIL")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Import Table")
      %else
          @DTW_ASSIGN(orderBy, "FFDESCU,FFIFIL")
          @DTW_ASSIGN(orderByDisplay, "Description, Import Table")
      %endif
  %elif (sequence == "Table")
      %if (orderBy == "FFIFIL")
          @DTW_ASSIGN(orderBy, "FFIFIL DESC")
          @DTW_ASSIGN(orderByDisplay, "Import Table (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FFIFIL")
          @DTW_ASSIGN(orderByDisplay, "Import Table")
      %endif
  %elif (sequence == "FixedFormat")
      %if (orderBy == "FixedFLDESCU,FFIFIL")
          @DTW_ASSIGN(orderBy, "FixedFLDESCU DESC,FFIFIL")
          @DTW_ASSIGN(orderByDisplay, "Fixed Format (descending), Import Table")
      %else
          @DTW_ASSIGN(orderBy, "FixedFLDESCU,FFIFIL")
          @DTW_ASSIGN(orderByDisplay, "Fixed Format, Import Table")
      %endif
  %elif (sequence == "Delimiter")
      %if (orderBy == "FFFDLM,FFIFIL")
          @DTW_ASSIGN(orderBy, "FFFDLM DESC,FFIFIL")
          @DTW_ASSIGN(orderByDisplay, "Column Delimiter (descending), Import Table")
      %else
          @DTW_ASSIGN(orderBy, "FFFDLM,FFIFIL")
          @DTW_ASSIGN(orderByDisplay, "Column Delimiter, Import Table")
      %endif
  %elif (sequence == "RecTypPos")
      %if (orderBy == "FFRTPS,FFIFIL")
          @DTW_ASSIGN(orderBy, "FFRTPS DESC,FFIFIL")
          @DTW_ASSIGN(orderByDisplay, "Row Type Position/Placement (descending), Import Table")
      %else
          @DTW_ASSIGN(orderBy, "FFRTPS,FFIFIL")
          @DTW_ASSIGN(orderByDisplay, "Row Type Position/Placement, Import Table")
      %endif
  %elif (sequence == "RecTypLen")
      %if (orderBy == "FFRTLN,FFIFIL")
          @DTW_ASSIGN(orderBy, "FFRTLN DESC,FFIFIL")
          @DTW_ASSIGN(orderByDisplay, "Row Type Length (descending), Import Table")
      %else
          @DTW_ASSIGN(orderBy, "FFRTLN,FFIFIL")
          @DTW_ASSIGN(orderByDisplay, "Row Type Length, Import Table")
      %endif
  %elif (sequence == "DateFormat")
      %if (orderBy == "DateFLDESCU,FFIFIL")
          @DTW_ASSIGN(orderBy, "DateFLDESCU DESC,FFIFIL")
          @DTW_ASSIGN(orderByDisplay, "Date Format (descending), Import Table")
      %else
          @DTW_ASSIGN(orderBy, "DateFLDESCU,FFIFIL")
          @DTW_ASSIGN(orderByDisplay, "Date Format, Import Table")
      %endif
  %elif (sequence == "PeriodFormat")
      %if (orderBy == "PeriodFLDESCU,FFIFIL")
          @DTW_ASSIGN(orderBy, "PeriodFLDESCU DESC,FFIFIL")
          @DTW_ASSIGN(orderByDisplay, "Period Format (descending), Import Table")
      %else
          @DTW_ASSIGN(orderBy, "PeriodFLDESCU,FFIFIL")
          @DTW_ASSIGN(orderByDisplay, "Period Format, Import Table")
      %endif
  %elif (sequence == "TimeFormat")
      %if (orderBy == "TimeFLDESCU,FFIFIL")
          @DTW_ASSIGN(orderBy, "TimeFLDESCU DESC,FFIFIL")
          @DTW_ASSIGN(orderByDisplay, "Time Format (descending), Import Table")
      %else
          @DTW_ASSIGN(orderBy, "TimeFLDESCU,FFIFIL")
          @DTW_ASSIGN(orderByDisplay, "Time Format, Import Table")
      %endif
  %endif
	
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchPlacement, 5, 0) &&
                      editNum(document.Search.srchRecTypeLength, 1, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "MAPIMPORTTABLESEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Import Table</td>
                              @dtw_assign(operNbr, "operTable")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchTable" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Fixed Format</td>
                              @dtw_assign(operNbr, "operFixedFormat")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchFixedFormat" size="10" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Column Delimiter</td>
                              @dtw_assign(operNbr, "operDelimiter")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDelimiter" size="1" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Date Format</td>
                              @dtw_assign(operNbr, "operDateFormat")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDateFormat" size="10" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Period Format</td>
                              @dtw_assign(operNbr, "operPeriodFormat")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchPeriodFormat" size="10" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Time Format</td>
                              @dtw_assign(operNbr, "operTimeFormat")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchTimeFormat" size="10" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Row Type Position/Placement</td>
                              @dtw_assign(operNbr, "operPlacement")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchPlacement" size="5" maxlength="5"></td>
                          </tr>	

                          <tr><td class="dsphdr">Row Type Length</td>
                              @dtw_assign(operNbr, "operRecTypeLength")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchRecTypeLength" size="1" maxlength="1"></td>
                          </tr>	

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDesc.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("FFDESCU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("FFIFIL", "Import Table", $(srchTable), "U", operTable, "A")
  @Build_WildCard ("Upper(coalesce(b.FLDESC,' '))", "Fixed Format", $(srchFixedFormat), "U", operFixedFormat, "A")
  @Build_WildCard ("Upper(FFFDLM)", "Column Delimiter", $(srchDelimiter), "U", operDelimiter, "A")
  @Build_WildCard ("Upper(coalesce(c.FLDESC,' '))", "Date Format", $(srchDateFormat), "U", operDateFormat, "A")
  @Build_WildCard ("Upper(coalesce(d.FLDESC,' '))", "Period Format", $(srchPeriodFormat), "U", operPeriodFormat, "A")
  @Build_WildCard ("Upper(coalesce(e.FLDESC,' '))", "Time Format", $(srchTimeFormat), "U", operTimeFormat, "A")
  @Build_WildCard ("FFRTPS",  "Row Type Position/Placement", $(srchPlacement), "", operPlacement, "N")
  @Build_WildCard ("FFRTLN",  "Row Type Length", $(srchRecTypeLength), "", operRecTypeLength, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}