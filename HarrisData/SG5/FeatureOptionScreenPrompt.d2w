%INCLUDE "$(baseVar)"
%INCLUDE "EdtVar.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title         = "Feature/Option Screen Prompt"
  d2wName            = "FeatureOptionScreenPrompt.d2w"
  d2wVarBase         = "$(genericVarBase)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;lineNumber=@dtw_rurlescseq(lineNumber)&amp;feature=@dtw_rurlescseq(feature)&amp;featureDesc=@dtw_rurlescseq(featureDesc)&amp;option=@dtw_rurlescseq(option)&amp;optionDesc=@dtw_rurlescseq(optionDesc)&amp;biLevel=@dtw_rurlescseq(biLevel)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  DATABASE           = "*LOCAL"
  DTW_DEFAULT_REPORT = "NO"
  DTW_HTML_TABLE     = "YES"
  DTW_PAD_PGM_PARMS  = "YES"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "headcmt.icl"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      @dtw_concat(stmtSQL, "Select * From HDOPWW Where SAOCTL=$(orderControlNumber) and SAFEAT='$(feature)' and SABLVL='$(biLevel)' and SAOPTN='$(option)'", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Option_Maintain(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Option_Maintain (IN CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  <a href="javascript:check(document.Chg)">$(selectAcceptImage)</a>
                  %INCLUDE "CloseWindow.icl"
              </td>
          </tr>
      </table>
      <table $(contentTable)>
          @Format_Header("Feature", $(featureDesc), $(feature))
          @Format_Header("Option", $(optionDesc), $(option))
      </table>
      $(hrTagAttr)

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)&amp;promptValue=@dtw_rurlescseq(V_SASCRV)">
          %ROW {
              <table $(contentTable)>
                  <tr><td class="dsphdr"><span $(textOvr)>$(V_SASCRP)</span></td>
                      <td class="inputalph"><input type="text" name="promptValue" value="$(V_SASCRV)" size="30" maxlength="30"></td>
                  </tr>
              </table>
          %}
      </form>
      $(hrTagAttr)
      <a href="javascript:check(document.Chg)">$(selectAcceptImage)</a>
      %INCLUDE "CloseWindow.icl"
  %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  %if (promptValue != "")
      @dtw_concat(stmtSQL, " Update HDOPWW Set SASCRV='$(promptValue)', SAER#=' '", stmtSQL)
      @dtw_concat(stmtSQL, " Where SAOCTL=$(orderControlNumber) and SAFEAT='$(feature)' and SABLVL='$(biLevel)' and SAOPTN='$(option)'  @@endsql", stmtSQL)
      @SQL_Update(stmtSQL, status)
  %endif

  <script TYPE="text/javascript">
      opener.location.href=opener.location.href;
      opener.focus();
      self.close();
  </script>
%}