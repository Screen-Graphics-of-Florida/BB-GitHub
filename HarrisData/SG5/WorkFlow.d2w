%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Workflow"
  d2wName                 = "WorkFlow.d2w"
  d2wVarBase              = "$(genericVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
  systemDate              = ""
  quickLinkByUser         = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WORKFLOW")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">

%{ QuickLink Table %} %INCLUDE "QuickLinkTable.icl"

%{ QuickLink User %}  %INCLUDE "QuickLinkByUser.icl"

%{ Heading %}
                      @dtw_assign(RPT_MAX_ROWS, "99")
                      @dtw_assign(dspMaxRows, "10")
                      @dtw_assign(wildCardSearch, "")  %{ No wildCardSearch %}
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " SYUSER ", fileSQL)
                      @dtw_concat(selectSQL, " USUSER='$(userProfile)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Select_Header(profileHandle, dataBaseID, stmtSQL)

                      @dtw_DATE("U", systemDate) @Date_MDY_ISO(@dtw_rReplace(systemDate,"/",""), systemDate)

%{ Quicklink Begin %} %INCLUDE "QuickLinkBegLoop.icl"

    %{ WorkList %}
                          %if (quicklinkRef == "worklist")
                              %INCLUDE "QuickLinkClear.icl"
                              @Retrieve_WebReg(userProfile, "", "WFWorkList.d2w", wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select WFWITM.*,WFWIPT.*,INDESC,INPROC,  ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(PDDESC,' ') as PDDESC,  ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(ATD2W,' ') as ATD2W  ", stmtSQL)
                              @dtw_concat(fileSQL, " WFWITM ", fileSQL)
                              @dtw_concat(fileSQL, " inner join WFWIPT on WPINST=WIINST and WPINDT=WIINDT and WPWITM=WIWITM and WPWISQ=WIWISQ ", fileSQL)
                              @dtw_concat(fileSQL, " inner join WFINST on ININST=WIINST and ININDT=WIINDT ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFPRDT on PDPROC=WIPROC and PDPONT=WIPONT and PDSEQ=WISEQ ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFPRAC on ATPROC=WIPROC and ATACTV=WIACTV ", fileSQL)
                              @dtw_concat(selectSQL, " WIMODE='M'  ", selectSQL)
                              @dtw_concat(selectSQL, " and WPPART='$(userProfile)' and (WPRVWS='Y' or WPRVWS=' ') ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %if (orderBy == "")
                                  @dtw_assign(orderBy, "WPEXDT,WPPRTY")
                                  @dtw_assign(orderByDisplay, "Expiration Date, Priority")
                              %endif
                              @dtw_concat(stmtSQL, " Order By $(orderBy)", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @WorkList_Query(profileHandle, dataBaseID, stmtSQL)

    %{ My Work Item %}
                          %elif (quicklinkRef == "myworkitem")
                              %INCLUDE "QuickLinkClear.icl"
                              @Retrieve_WebReg(userProfile, "", "WFMyWorkItem.d2w", wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select WFWITM.*,WFINST.*,WFWIPT.*,  ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(PDDESC,' ') as PDDESC,  ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(USDESC,WPPART) as USDESC  ", stmtSQL)
                              @dtw_concat(fileSQL, " WFWITM ", fileSQL)
                              @dtw_concat(fileSQL, " inner join WFINST on ININST=WIINST and ININDT=WIINDT ", fileSQL)
                              @dtw_concat(fileSQL, " inner join WFWIPT on WPINST=WIINST and WPINDT=WIINDT and WPWITM=WIWITM and WPWISQ=WIWISQ and WPPART<>INIUSR ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFPRDT on PDPROC=WIPROC and PDPONT=WIPONT and PDSEQ=WISEQ ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYUSER on USUSER=WPPART ", fileSQL)
                              @dtw_concat(selectSQL, " WIMODE='M' ", selectSQL)
                              @dtw_concat(selectSQL, " and INIUSR='$(userProfile)' ", selectSQL)
                              @dtw_concat(selectSQL, " and (WPRVWS='Y' or WPRVWS=' ') ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %if (orderBy == "")
                                  @dtw_assign(orderBy, "WPEXDT,WPPRTY")
                                  @dtw_assign(orderByDisplay, "Expiration Date, Priority")
                              %endif
                              @dtw_concat(stmtSQL, " Order By $(orderBy)", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @MyWorkItemList_Query(profileHandle, dataBaseID, stmtSQL)

    %{ Delegated Work Item %}
                          %elif (quicklinkRef == "delegatedworkitem")
                              %INCLUDE "QuickLinkClear.icl"
                              @Retrieve_WebReg(userProfile, "", "WFWorkItemDelegate.d2w", wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select WFWITM.*,WFWIPT.*,INDESC, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(PDDESC,' ') as PDDESC,  ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(USDESC,WPPART) as USDESC  ", stmtSQL)
                              @dtw_concat(fileSQL, " WFWITM ", fileSQL)
                              @dtw_concat(fileSQL, " inner join WFWIPT on WPINST=WIINST and WPINDT=WIINDT and WPWITM=WIWITM and WPWISQ=WIWISQ and WPPART<>WPIPRT ", fileSQL)
                              @dtw_concat(fileSQL, " inner join WFINST on ININST=WIINST and ININDT=WIINDT ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFPRDT on PDPROC=WIPROC and PDPONT=WIPONT and PDSEQ=WISEQ ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYUSER on USUSER=WPPART ", fileSQL)
                              @dtw_concat(selectSQL, " WIMODE='M'  ", selectSQL)
                              @dtw_concat(selectSQL, " and WPIPRT='$(userProfile)' and (WPRVWS='Y' or WPRVWS=' ') ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %if (orderBy == "")
                                  @dtw_assign(orderBy, "WPEXDT,WPPRTY,WPPART")
                                  @dtw_assign(orderByDisplay, "Expiration Date, Priority, Participant")
                              %endif
                              @dtw_concat(stmtSQL, " Order By $(orderBy)", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @DelegatedItem_Query(profileHandle, dataBaseID, stmtSQL)

    %{ Work Item History %}
                          %elif (quicklinkRef == "workitemhistory")
                              %INCLUDE "QuickLinkClear.icl"
                              @Retrieve_WebReg(userProfile, "", "WFHistory.d2w", wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select WFINST.*, ", stmtSQL)
                              @dtw_concat(stmtSQL, " Date(INTSTP) as INDateStart, Time(INTSTP) as INTimeStart, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(USDESC,' ') as USDESC, coalesce(USDESCU,' ') as USDESCU,  ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(PRDESC,' ') as PRDESC, coalesce(PRDESCU,' ') as PRDESCU ", stmtSQL)
                              @dtw_concat(fileSQL, " WFINST ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYUSER on USUSER=INIUSR ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFPRHD on PRPROC=INPROC ", fileSQL)
                              @dtw_concat(selectSQL, " INIUSR='$(userProfile)' ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %if (orderBy == "")
                                  @dtw_assign(orderBy, "ININST DESC")
                                  @dtw_assign(orderByDisplay, "Instance (descending)")
                              %endif
                              @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @WorkItem_History(profileHandle, dataBaseID, stmtSQL)

    %{ Work Item Error %}
                          %elif (quicklinkRef == "workitemerror")
                              %INCLUDE "QuickLinkClear.icl"
                              @Retrieve_WebReg(userProfile, "", "WFError.d2w", wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select WFWIVL.*,WFINST.*,   ", stmtSQL)
                              @dtw_concat(stmtSQL, " Date(INTSTP) as INDateStart, Time(INTSTP) as INTimeStart, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(USDESC,' ') as USDESC, coalesce(USDESCU,' ') as USDESCU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(PRDESC,' ') as PRDESC, coalesce(PRDESCU,' ') as PRDESCU ", stmtSQL)
                              @dtw_concat(fileSQL, " WFWIVL ", fileSQL)
                              @dtw_concat(fileSQL, " inner join WFINST on ININST=WVINST and ININDT=WVINDT ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYUSER on USUSER=INIUSR ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFPRHD on PRPROC=INPROC ", fileSQL)
                              @dtw_concat(selectSQL, " WVVTYP='T'", selectSQL)
                              @dtw_concat(selectSQL, " and INIUSR='$(userProfile)'", selectSQL)
                              @dtw_concat(selectSQL, " and WVRVWD<>'Y'", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %if (orderBy == "")
                                  @dtw_assign(orderBy, "ININST DESC")
                                  @dtw_assign(orderByDisplay, "Instance (descending)")
                              %endif
                              @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @WorkItem_Error(profileHandle, dataBaseID, stmtSQL)
                          %endif

%{ Quicklink End %}   %INCLUDE "QuickLinkEndLoop.icl"

                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          %INCLUDE "AlertMessageDisplay.icl"
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Select_Header (IN CHAR(64)    profileHandle,
                                     CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %ROW{
          <table $(contentTable)>
              @Format_Code(V_USUSER, F_USUSER)
              <tr><td><h2>$(V_USDESC) $(F_USUSER)</h2></td></tr>
          </table>

          $(hrTagAttr)

          %INCLUDE "QuickLinkDisplay.icl"
      %}
  %}
%}

%FUNCTION(dtw_sql) WorkList_Query (IN  CHAR(64) profileHandle,
                                       CHAR(2)   dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="worklist"></a>
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)WFWorkList.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              @RtvFldDesc("WIMODE='M' and WPPART='$(userProfile)' and (WPRVWS='Y' or WPRVWS=' ') ",                                 "WFWITM inner join WFWIPT on WPINST=WIINST and WPINDT=WIINDT and WPWITM=WIWITM and WPWISQ=WIWISQ", "CHAR(COUNT(*))", requestOwn)
              @RtvFldDesc("WIMODE='M' and WPPART='$(userProfile)' and (WPRVWS='Y' or WPRVWS=' ') and DATE(WPEXDT)<'$(systemDate)'", "WFWITM inner join WFWIPT on WPINST=WIINST and WPINDT=WIINDT and WPWITM=WIWITM and WPWISQ=WIWISQ", "CHAR(COUNT(*))", requestExpire)
              <tr><td class="dspalph"><a href="$(homeURL)$(cGIPath)WFWorkList.D2w/REPORT$(d2wVarBase)" title="View Work List">I have $(requestOwn) items in my Work List. </a>
                                      <a href="$(homeURL)$(cGIPath)WFWorkList.D2w/REPORT$(d2wVarBase)&amp;expireDate=@dtw_rurlescseq(systemDate)" title="View expired Work Items on Work List">$(requestExpire) are overdue. </a>
              </td></tr>

              <tr><th class="colhdr">Items in my Work List</th></tr>
          %endif

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;wfInstance=@dtw_rurlescseq(V_WIINST)&amp;wfInstanceDate=@dtw_rurlescseq(V_WIINDT)&amp;wfWorkItem=@dtw_rurlescseq(V_WIWITM)&amp;wfWorkItemSequence=@dtw_rurlescseq(V_WIWISQ)&amp;wfParticipantId=@dtw_rurlescseq(V_WPPTID)&amp;wfProcess=@dtw_rurlescseq(V_INPROC)&amp;wfPoint=@dtw_rurlescseq(V_WIPONT)&amp;wfSequence=@dtw_rurlescseq(V_WISEQ)")
              %INCLUDE "SetRowClass.icl"
              @Date_FromISO_ToCYMD(V_WPEXDT, V_WPEXDT) @Format_Date(V_WPEXDT, "D", F_WPEXDT)

              <tr class="$(rowClass)">
                  @dtw_assign(wfPath, "$(V_ATD2W)$(maintainVar)")
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)WFActiveWorkItemCheck.d2w/REPORT$(maintainVar)&amp;wfPath=@dtw_rurlescseq(wfPath)" title="View Work Item [$(V_ATD2W)]">$(V_INDESC)</a> with a priority of $(V_WPPRTY) expires on $(F_WPEXDT) ($(V_PDDESC)).  </td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) MyWorkItemList_Query (IN  CHAR(64) profileHandle,
                                             CHAR(2)   dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="myworkitem"></a>
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)WFMyWorkItem.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              @RtvFldDesc("WIMODE='M' and INIUSR='$(userProfile)' and (WPRVWS='Y' or WPRVWS=' ') ",                          "WFWITM inner join WFINST on ININST=WIINST and ININDT=WIINDT inner join WFWIPT on WPINST=WIINST and WPINDT=WIINDT and WPWITM=WIWITM and WPWISQ=WIWISQ and WPPART<>INIUSR ", "CHAR(COUNT(*))", requestInit)
              @RtvFldDesc("WIMODE='M' and INIUSR='$(userProfile)' and (WPRVWS='Y' or WPRVWS=' ') and DATE(WPEXDT)<'$(systemDate)' ", "WFWITM inner join WFINST on ININST=WIINST and ININDT=WIINDT inner join WFWIPT on WPINST=WIINST and WPINDT=WIINDT and WPWITM=WIWITM and WPWISQ=WIWISQ and WPPART<>INIUSR ", "CHAR(COUNT(*))", requestExpInit)
              <tr><td class="dspalph"><a href="$(homeURL)$(cGIPath)WFMyWorkItem.D2w/REPORT$(d2wVarBase)" title="View my Work Items">I have initiated $(requestInit) items that are currently on another Work List. </a>
                                      <a href="$(homeURL)$(cGIPath)WFMyWorkItem.D2w/REPORT$(d2wVarBase)&amp;expireDate=@dtw_rurlescseq(systemDate)" title="View my expired Work Items">$(requestExpInit) are overdue. </a></td>
              </tr>

              <tr><th class="colhdr">Items I initiated on another Work List.</th></tr>
          %endif

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;wfInstance=@dtw_rurlescseq(V_WIINST)&amp;wfInstanceDate=@dtw_rurlescseq(V_WIINDT)&amp;wfWorkItem=@dtw_rurlescseq(V_WIWITM)&amp;wfWorkItemSequence=@dtw_rurlescseq(V_WIWISQ)")
              %INCLUDE "SetRowClass.icl"
              @Date_FromISO_ToCYMD(V_WPEXDT, V_WPEXDT) @Format_Date(V_WPEXDT, "D", F_WPEXDT)

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)WFHistorySelect.d2w/REPORT$(maintainVar)&amp;fromD2w=@dtw_rurlescseq(d2wName)" title="View Work Item history">$(V_INDESC)</a> is on $(V_USDESC) Work List with a priority of $(V_WPPRTY). It expires on $(F_WPEXDT) ($(V_PDDESC)).  </td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) DelegatedItem_Query (IN  CHAR(64) profileHandle,
                                            CHAR(2)   dataBaseID,
                                            CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="delegatedworkitem"></a>
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)WFWorkItemDelegate.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              @RtvFldDesc("WIMODE='M' and WPIPRT='$(userProfile)' and (WPRVWS='Y' or WPRVWS=' ')",                           "WFWITM inner join WFWIPT on WPINST=WIINST and WPINDT=WIINDT and WPWITM=WIWITM and WPWISQ=WIWISQ and WPPART<>WPIPRT ", "CHAR(COUNT(*))", requestDelegate)
              @RtvFldDesc("WIMODE='M' and WPIPRT='$(userProfile)' and (WPRVWS='Y' or WPRVWS=' ') and DATE(WPEXDT)<'$(systemDate)' ", "WFWITM inner join WFWIPT on WPINST=WIINST and WPINDT=WIINDT and WPWITM=WIWITM and WPWISQ=WIWISQ and WPPART<>WPIPRT ", "CHAR(COUNT(*))", requestExpDelegate)
              <tr><td class="dspalph"><a href="$(homeURL)$(cGIPath)WFWorkItemDelegate.D2w/REPORT$(d2wVarBase)" title="View Work Items I delegated">I delegated $(requestDelegate) items that have not been addressed. </a>
                                      <a href="$(homeURL)$(cGIPath)WFWorkItemDelegate.D2w/REPORT$(d2wVarBase)&amp;expireDate=@dtw_rurlescseq(systemDate)" title="View expired Work Items I delegated">$(requestExpDelegate) are overdue. </a></td>
              </tr>

              <tr><th class="colhdr">Items I delegated to another Work List.</th></tr>
          %endif

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;wfInstance=@dtw_rurlescseq(V_WIINST)&amp;wfInstanceDate=@dtw_rurlescseq(V_WIINDT)&amp;wfWorkItem=@dtw_rurlescseq(V_WIWITM)&amp;wfWorkItemSequence=@dtw_rurlescseq(V_INDESC)")
              %INCLUDE "SetRowClass.icl"
              @Date_FromISO_ToCYMD(V_WPEXDT, V_WPEXDT) @Format_Date(V_WPEXDT, "D", F_WPEXDT)

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)WFHistorySelect.d2w/REPORT$(maintainVar)&amp;fromD2w=@dtw_rurlescseq(d2wName)" title="View Work Item history">$(V_INDESC)</a> is on $(V_USDESC) Work List with a priority of $(V_WPPRTY). It expires on $(F_WPEXDT) ($(V_PDDESC)).  </td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) WorkItem_History (IN CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="workitemhistory"></a>
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)WFHistory.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("ININST", "Instance")
                  @Format_Column_Header("INDESCU", "Description")
                  @Format_Column_Header("USDESCU", "Initial User")
                  @Format_Column_Header("INDateStart", "Date Started")
                  @Format_Column_Header("INTimeStart", "Time Started")
                  @Format_Column_Header("PRDESCU", "Process")
                  @Format_Column_Header("", "Status")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              %if (V_INSTAT=="S")
                  @dtw_assign(workItemStatus, "Waiting To Start")
              %else
                  @RtvFldDesc("WIINST=$(V_ININST) and WIINDT=$(V_ININDT)", "WFWITM", "CHAR(Count(*))", activeWorkItem)
                  %if (activeWorkItem>"0")
                      @dtw_assign(workItemStatus, "In Process")
                  %else
                      %if (V_INSTAT=="P")
                          @dtw_assign(workItemStatus, "Passed")
                      %else
                          @dtw_assign(workItemStatus, "Failed")
                      %endif
                  %endif
              %endif
              @DateFromISO(V_INDateStart, F_INDateStart)

              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_ININST)</td>                                      	
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)WFHistorySelect.d2w/REPORT$(d2wVarBase)&amp;wfInstance=@dtw_rurlescseq(V_ININST)&amp;wfInstanceDate=@dtw_rurlescseq(V_ININDT)&amp;fromD2w=@dtw_rurlescseq(d2wName)" title="View Work Item">$(V_INDESC)</a></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_INIUSR)">$(V_USDESC)</span></td>                                      	
                  <td class="colalph">$(F_INDateStart)</td>                                      	
                  <td class="colalph">$(V_INTimeStart)</td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_INPROC)">$(V_PRDESC)</span></td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_INSTAT)">$(workItemStatus)</span></td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) WorkItem_Error (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="workitemerror"></a>
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)WFError.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("ININST", "Instance")
                  @Format_Column_Header("INDESCU", "Description")
                  @Format_Column_Header("WVDESCU", "Error")
                  @Format_Column_Header("USDESCU", "Initial User")
                  @Format_Column_Header("INDateStart", "Date Started")
                  @Format_Column_Header("INTimeStart", "Time Started")
                  @Format_Column_Header("PRDESCU", "Process")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @DateFromISO(V_INDateStart, F_INDateStart)
              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_ININST)</td>                                      	
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)WFHistorySelect.d2w/REPORT$(d2wVarBase)&amp;wfInstance=@dtw_rurlescseq(V_ININST)&amp;wfInstanceDate=@dtw_rurlescseq(V_ININDT)&amp;fromD2w=@dtw_rurlescseq(d2wName)" title="View Work Item">$(V_INDESC)</a></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_WVVPGM)-$(V_WVVLID)">$(V_WVDESC)</span></td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_INIUSR)">$(V_USDESC)</span></td>                                      	
                  <td class="colalph">$(F_INDateStart)</td>                                      	
                  <td class="colalph">$(V_INTimeStart)</td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_INPROC)">$(V_PRDESC)</span></td>                                      	
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}