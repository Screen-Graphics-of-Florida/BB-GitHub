%INCLUDE "$(baseVar)"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Order Shipping - Kit Options In Error"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL)
{
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  <html>
      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
      @dtw_concat(fileSQL, " OEDTWK ", fileSQL)
      @dtw_concat(selectSQL, "O1OCTL=$(orderControlNumber) and O1KIT='K' and O1KTRL='$(reliefCode)' ", selectSQL)
      %INCLUDE "stmtSQLSelect.icl"
      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
      %INCLUDE "stmtSQLEnd.icl"
      %INCLUDE "stmtSQLTotalRows.icl"
      @Kit_Option_Error_Query(profileHandle, dataBaseID, stmtSQL)
  </html>
%}

%FUNCTION(dtw_sql) Kit_Option_Error_Query (IN CHAR(64)    profileHandle,
                                              CHAR(2)     dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count == "0")
          %if (reliefCode == "E")
              <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)ordershippingreview.d2w/ACCEPT$(d2wVarBase)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;turnaround=@dtw_rurlescseq(turnaround)">
          %elif (reliefCode == "D")
              <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)ordershippingentry.d2w/SHIP$(d2wVarBase)">
          %endif
      %endif

      %ROW{
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)ordershipkitoption.d2w/INPUT$(d2wVarBase)&amp;lineNumber=@dtw_rurlescseq(V_O1ORL#)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;turnaround=@dtw_rurlescseq(turnaround)&amp;reliefCode=@dtw_rurlescseq(reliefCode)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
      %}
  %}
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}