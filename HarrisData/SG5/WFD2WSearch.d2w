%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Workflow Script Search"
  d2wName                 = "WFD2WSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectWFD2W(wfD2W, wfD2WDescription){
                  window.opener.document.$(docName).$(fldName).value = wfD2W;
                  window.opener.document.$(docName).$(fldDesc).value = wfD2WDescription;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select WFD2WN.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(a.FLDESC,' ') as optpFLDESC, upper(coalesce(a.FLDESC,' ')) as optpFLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(b.FLDESC,' ') as optfFLDESC, upper(coalesce(b.FLDESC,' ')) as optfFLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(c.FLDESC,' ') as accpFLDESC, upper(coalesce(c.FLDESC,' ')) as accpFLDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " WFD2WN  ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG a on a.FLTYPE='BY' and a.FLVALU=D2OPTP ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG b on b.FLTYPE='BY' and b.FLVALU=D2OPTF ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG c on c.FLTYPE='WFD2WACCSS' and c.FLVALU=D2ACCP ", fileSQL)
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, " D2D2W='$(wfD2W)'", selectSQL)
                      %elif (wildCardSearch!="")
                          @dtw_concat(selectSQL, " D2D2W >' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"

      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Description</th>
                      <th class="colhdr">Script</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="15" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchWFD2W" size="20" maxlength="100">
                          <input type="hidden" name="operWFD2W" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
              @OrderBy_Sort("D2DESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description"  title="Sequence By Description, Script">Description</a></th>
              @OrderBy_Sort("D2D2W ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Script"       title="Sequence By Script">Script</a></th>
              @OrderBy_Sort("optpFLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=OptionalPass" title="Sequence By Allow Optional Transition For Pass, Script">Allow Optional Transition For Pass</a></th>
              @OrderBy_Sort("optfFLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=OptionalFail" title="Sequence By Allow Optional Transition For Fail, Script">Allow Optional Transition For Fail</a></th>
              @OrderBy_Sort("accpFLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Access"       title="Sequence By Participant Access For Pass, Script">Participant Access For Pass</a></th>
          </tr>

              %INCLUDE "NoRecordsFound.icl"
      %else
          <table $(contentTable)>
      %endif		

              %ROW{
                  @Format_Quote(V_D2D2W , F_D2D2W )
                  @Format_Quote(V_D2DESC, F_D2DESC)

                  %if (moreInfo != "Y")	
                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          <td class="colalph"><a href="javascript:selectWFD2W('$(F_D2D2W )','$(F_D2DESC)')" title="Select Script">$(V_D2DESC)</a></td>
                          <td class="colalph">$(V_D2D2W )</td>                                      	
                          <td class="colcode" $(helpCursor)><span title="$(V_D2OPTP)">$(V_optpFLDESC)</span></td>                                      	
                          <td class="colcode" $(helpCursor)><span title="$(V_D2OPTF)">$(V_optfFLDESC)</span></td>                                      	
                          <td class="colalph" $(helpCursor)><span title="$(V_D2ACCP)">$(V_accpFLDESC)</span></td>                                      	
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;wfD2W=@dtw_rurlescseq(V_D2D2W )&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                      </tr>

                  %else

                      <tr><td><a href="javascript:selectWFD2W('$(F_D2D2W )','$(F_D2DESC)')" title="Select Script">$(selectImageLrg)</a>
                          </td>
                      </tr>

                      <tr><td class="dsphdr">Script</td>
                          <td class="dspalph">$(V_D2D2W )</td></tr>

                      <tr><td class="dsphdr">Description</td>
                          <td class="dspalph">$(V_D2DESC)</td></tr>

                      @RtvFldDesc("FLTYPE='BY' and FLVALU='$(V_D2OPTP)'", "SYFLAG", "FLDESC", fieldDesc)
                      @Format_Code(V_D2OPTP, F_D2OPTP)
                      <tr><td class="dsphdr">Optional Transition Allowed For Pass</td>
                          <td class="dspalph">$(fieldDesc) $(F_D2OPTP)</td></tr>

                      @RtvFldDesc("FLTYPE='BY' and FLVALU='$(V_D2OPTF)'", "SYFLAG", "FLDESC", fieldDesc)
                      @Format_Code(V_D2OPTF, F_D2OPTF)
                      <tr><td class="dsphdr">Optional Transition Allowed For Fail</td>
                          <td class="dspalph">$(fieldDesc) $(F_D2OPTF)</td></tr>

                      @RtvFldDesc("FLTYPE='WFD2WACCSS' and FLVALU='$(V_D2ACCP)'", "SYFLAG", "FLDESC", fieldDesc)
                      @Format_Code(V_D2ACCP, F_D2ACCP)
                      <tr><td class="dsphdr">Participant Access For Pass</td>
                          <td class="dspalph">$(fieldDesc) $(F_D2ACCP)</td></tr>
                  %endif
              %}
          </table>
          %if (moreInfo != "Y")	
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
          %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "D2DESCU,D2D2W ")
      @DTW_ASSIGN(orderByDisplay, "Description, Script")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Description")
      %if (orderBy == "D2DESCU,D2D2W ")
          @DTW_ASSIGN(orderBy, "D2DESCU DESC,D2D2W ")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Script")
      %else
          @DTW_ASSIGN(orderBy, "D2DESCU,D2D2W ")
          @DTW_ASSIGN(orderByDisplay, "Description, Script")
      %endif
  %elif (sequence == "Script")
      %if (orderBy == "D2D2W ")
          @DTW_ASSIGN(orderBy, "D2D2W  DESC")
          @DTW_ASSIGN(orderByDisplay, "Script (descending)")
      %else
          @DTW_ASSIGN(orderBy, "D2D2W ")
          @DTW_ASSIGN(orderByDisplay, "Script")
      %endif
  %elif (sequence == "OptionalPass")
      %if (orderBy == "optpFLDESCU,D2D2W ")
          @DTW_ASSIGN(orderBy, "optpFLDESCU DESC,D2D2W ")
          @DTW_ASSIGN(orderByDisplay, "Allow Optional Transition For Pass (descending), Script")
      %else
          @DTW_ASSIGN(orderBy, "optpFLDESCU,D2D2W ")
          @DTW_ASSIGN(orderByDisplay, "Allow Optional Transition For Pass, Script")
      %endif
  %elif (sequence == "OptionalFail")
      %if (orderBy == "optfFLDESCU,D2D2W ")
          @DTW_ASSIGN(orderBy, "optfFLDESCU DESC,D2D2W ")
          @DTW_ASSIGN(orderByDisplay, "Allow Optional Transition For Fail (descending), Script")
      %else
          @DTW_ASSIGN(orderBy, "optfFLDESCU,D2D2W ")
          @DTW_ASSIGN(orderByDisplay, "Allow Optional Transition For Fail, Script")
      %endif
  %elif (sequence == "Access")
      %if (orderBy == "accpFLDESCU,D2D2W ")
          @DTW_ASSIGN(orderBy, "accpFLDESCU DESC,D2D2W ")
          @DTW_ASSIGN(orderByDisplay, "Participant Access For Pass (descending), Script")
      %else
          @DTW_ASSIGN(orderBy, "accpFLDESCU,D2D2W ")
          @DTW_ASSIGN(orderByDisplay, "Participant Access For Pass, Script")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "mediumSearch")
                  <td>
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Script</td>
                              @dtw_assign(operNbr, "operWFD2W")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchWFD2W" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Allow Optional Transition For Pass</td>
                              @dtw_assign(operNbr, "operOptPass")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchOptPass" size="10" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Allow Optional Transition For Fail</td>
                              @dtw_assign(operNbr, "operOptFail")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchOptFail" size="10" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Participant Access For Pass</td>
                              @dtw_assign(operNbr, "operAccessPass")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchAccessPass" size="10" maxlength="30"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDesc.focus();
                          </script>
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("D2DESCU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("D2D2W ",   "Script", $(srchWFD2W), "U", operWFD2W, "A")
  @Build_WildCard ("upper(coalesce(a.FLDESC,' '))",  "Allow Optional Transition For Pass", $(srchOptPass), "U", operOptPass, "A")
  @Build_WildCard ("upper(coalesce(b.FLDESC,' '))",  "Allow Optional Transition For Fail", $(srchOptFail), "U", operOptFail, "A")
  @Build_WildCard ("upper(coalesce(c.FLDESC,' '))",  "Participant Access For Pass", $(srchAccessPass), "U", operAccessPass, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
