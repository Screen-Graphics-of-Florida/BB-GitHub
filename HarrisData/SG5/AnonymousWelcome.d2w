%INCLUDE "$(baseVar)"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"

%Define {
  page_title              = "Sign On"
  d2wName                 = "AnonymousWelcome.d2w"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "999"
  menuTable               = %table
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@prfh", "$(profileHandle)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(portal, "")
                  @dtw_assign(pageID, "")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "$(AnonymousWelcomePage)"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WELCOME) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(REFRESH) {
  %INCLUDE "setLibraryList.icl"
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)AnonymousWelcome.d2w/WELCOME?baseVar=@dtw_rurlescseq(baseVar)&amp;eID=@dtw_rurlescseq(eID)&amp;newsLink=@dtw_rurlescseq(newsLink)&amp;profileName=@dtw_rurlescseq(profileName)&amp;demo=@dtw_rurlescseq(demo)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}