%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Documentation Reference Maintenance"
  d2wName                 = "DocReferenceMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;progName=@dtw_rurlescseq(progName)&amp;progNameDesc=@dtw_rurlescseq(progNameDesc)&amp;maintenanceCode=D"
  programName             = "HSYDOC_E"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  progTypeTable           = %table
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.progName.value =="" ||
                      document.Chg.progNameDesc.value =="")
                         {alert("$(reqFieldError)"); return false;}
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
	       %INCLUDE "numedit.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "DOCREFERENCEMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From SYDOCR ", stmtSQL)
                          @dtw_concat(stmtSQL, "Where DRPGNM='$(progName)' ", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "progName")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@pgnm", "progName")        @dtw_assign(Err_DRPGNM, fieldValue)
                          @DecatErr_Field("@@desc", "progNameDesc")    @dtw_assign(Err_DRDESC, fieldValue)
                          @DecatErr_Field("@@page", "pageName")        @dtw_assign(Err_DRPAGE, fieldValue)
                          @DecatErr_Field("@@book", "bookName")        @dtw_assign(Err_DRBOOK, fieldValue)
                          @DecatErr_Field("@@resv", "reserved")        @dtw_assign(Err_DRRESV, fieldValue)
                      %endif

                      @Decat_Field("@@pgnm")   @dtw_assign(V_DRPGNM, fieldValue)
                      @Decat_Field("@@desc")   @dtw_assign(V_DRDESC, fieldValue)
                      @Decat_Field("@@page")   @dtw_assign(V_DRPAGE, fieldValue)
                      @Decat_Field("@@book")   @dtw_assign(V_DRBOOK, fieldValue)
                      @Decat_Field("@@resv")   @dtw_assign(V_DRRESV, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "progName")
                      %endif
                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_DRPGNM, "")
                      @dtw_assign(focusField, "progName")
                  %else
                      @dtw_assign(focusField, "progNameDesc")
                  %endif

                  @SetTextOvr(Err_DRPGNM)
                  <tr><td class="dsphdr"><span $(textOvr)>Program Name</span></td>
                         %if (maintenanceCode == "A" || maintenanceCode == "Z")
                             <td class="inputalph"><input name="progName" type="text" value="$(V_DRPGNM)" size="50" maxlength="50"> $(reqFieldChar) </td>
                         %else
                             <td class="inputalph"><input name="progName" type="hidden" value="$(V_DRPGNM)" size="50" maxlength="50">$(V_DRPGNM)</td>
                         %endif
                  </tr>
                  @DspErrMsg(Err_DRPGNM)

                  @SetTextOvr(Err_DRDESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="progNameDesc" type="text" value="$(V_DRDESC)" size="50" maxlength="50"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_DRDESC)

                  @SetTextOvr(Err_DRPAGE)
                  <tr><td class="dsphdr"><span $(textOvr)>Page Name</span></td>
                      <td class="inputalph"><input name="pageName" type="text" value="$(V_DRPAGE)" size="50" maxlength="50"></td>
                  </tr>
                  @DspErrMsg(Err_DRPAGE)

                  @SetTextOvr(Err_DRBOOK)
                  <tr><td class="dsphdr"><span $(textOvr)>Book Name</span></td>
                      <td class="inputalph"><input name="bookName" type="text" value="$(V_DRBOOK)" size="50" maxlength="50"></td>
                  </tr>
                  @DspErrMsg(Err_DRBOOK)

                  @dtw_assign(checked, "")
                  %if (V_DRRESV == "Y")
                      @dtw_assign(checked, "CHECKED")
                  %endif
                  <tr><td class="dsphdr"><span $(textOvr)>Reserved Row On Update</span></td>
                      <td class="dspalph"><input type="checkbox" name="reserved"  value="Y"  $(checked)></td>
                  </tr>
              </table>
    			
              %}

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                              CHAR(2)     dataBaseID,
                                              CHAR(1)     maintenanceCode,
                                              CHAR(1)     errFound,
                                              CHAR(32000) edtVar,                             	
                                              CHAR(32000) errVar)
{%EXEC {HSYDOC_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@pgtp", progType)
  @Concat_Field("@@pgnm", progName)
  @Concat_Field("@@desc", progNameDesc)
  @Concat_Field("@@page", pageName)
  @Concat_Field("@@book", bookName)
  @Concat_Field("@@resv", reserved)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(progNameDesc), $(progName), "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)DocReference.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@pgnm", "progName")
      @Format_ConfMsg_Desc("", $(progNameDesc), $(progName), "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)DocReference.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;progType=@dtw_rurlescseq(progType)&amp;progName=@dtw_rurlescseq(progName)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
