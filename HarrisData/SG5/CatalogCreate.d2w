%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Catalog Create"
  d2wName                 = "CatalogCreate.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;catalog=@dtw_rurlescseq(catalog)&amp;catalogDesc=@dtw_rurlescseq(catalogDesc)&amp;catalogStatus=@dtw_rurlescseq(catalogStatus)"
  programName             = "HOECTN_W"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
       </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                   @dtw_assign(pageID, "CATALOGCREATE")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTopNS.icl"
                      %if (catalogStatus == "B")
                          <table $(contentTable)>
                              <tr><td><div class="error">Warning - Catalog Create Already In Process</div></td></tr>
                          </table>
                      %endif
                      $(hrTagAttr)
            			
                      <table $(contentTable)>
                          <tr><td class="dsphdr">Catalog Name</td>
                              <td class="dspalph">$(catalog)</td>
                          </tr>
                          <tr><td class="dsphdr">Description</td>
                              <td class="dspalph">$(catalogDesc)</td>
                          </tr>
                      </table>

                      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/REPORTSELECTION$(d2wVarBase)">
                          %INCLUDE "schedulesubmitquestion.icl"
                      </form>
                      %INCLUDE "SubmitScheduleBottomNS.icl"
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64) profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HOECTB_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/SELECTION$(d2wVarBase)">
  %endif
%}

%HTML(SELECTION) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL()
%}

%HTML (REPORTSELECTION) {	
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "catalogcreate")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTopNS.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;submitSchedule=@dtw_rurlescseq(submitSchedule)">
                          <table $(contentTable)>
                              %if (errFound != "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @DecatErr_Field("@@catn", "catalog")   @dtw_assign(Err_N1CATN,  fieldValue)
                                  %INCLUDE "scheduleJobErr.icl"    %{ Schedule Entries Errors %}

                                  @Decat_Field("@@catn")   @dtw_assign(V_N1CATN,  fieldValue)
                                  %INCLUDE "scheduleJobValue.icl"    %{ Schedule Entries Values %}
                              %endif

                              @SetTextOvr(Err_N1CATN)
                              <tr><td class="dsphdr"><span $(textOvr)>Catalog Name</span></td>
                                  <td class="dspalph">$(catalog)</td>
                              </tr>
                              @DspErrMsg(Err_N1CATN)

                              <tr><td class="dsphdr">Description</td>
                                  <td class="dspalph">$(catalogDesc)</td>
                              </tr>
                          </table>
                          @dtw_assign(envProgram, "COECTB")
                          @dtw_assign(envPrinter, "")
                          %INCLUDE "schedulejobNS.icl"
                          %INCLUDE "SubmitScheduleBottomNS.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(schJobName)
  @dtw_mUPPERCASE(schJobDescription)
  @dtw_mUPPERCASE(schJobQueue)
  @dtw_mUPPERCASE(schFrequency)
  @dtw_mUPPERCASE(schTime)
  @dtw_mUPPERCASE(schDate)
  @dtw_mUPPERCASE(schDays)

  @dtw_assign(edtVar, "")
  @Concat_Field("@@catn", catalog)
  %INCLUDE "scheduleJobConcatNS.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)
  %if (errFound == "")
      %INCLUDE "SubmitScheduleMessage.icl"
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=113&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORTSELECTION$(d2wVarBase)&amp;submitSchedule=@dtw_rurlescseq(submitSchedule)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}