%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Map Definition"
  d2wName                 = "MapDefinition.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HSYMHM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  noMsg                   = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "MAPDEFINITION")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " SYMMHD ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, " MHMPKY>0 ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)MapDefinitionMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint == "")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">Workflow Program</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="15" maxlength="50">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchWFProgram" size="10" maxlength="10">
                          <input type="hidden" name="operWFProgram" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("MHDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description"        title="Sequence By Description, Map Definition">Description</a></th>
              @OrderBy_Sort("MHWPGM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=WFProgram"          title="Sequence By Workflow Program, Map Definition">Workflow Program</a></th>
              @OrderBy_Sort("MHMPGM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MapProgram"         title="Sequence By Map Program, Map Definition">Map Program</a></th>
              @OrderBy_Sort("MHRPGM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ReportProgram"      title="Sequence By Interface Report Program, Map Definition">Interface Report Program</a></th>
              @OrderBy_Sort("MHCPGM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CleanUpProgram"     title="Sequence By Interface Clean Up Program, Map Definition">Interface Clean Up Program</a></th>
              @OrderBy_Sort("MHPPGM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ProcessProgram"     title="Sequence By Interface Process Program, Map Definition">Interface Process Program</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;mapKey=@dtw_rurlescseq(V_MHMPKY)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;updRecNbr=@dtw_rurlescseq(START_ROW_NUM)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_MHDESC), $(V_MHMPKY), "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)MapDefinitionMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)MapDefinitionMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromMapKey=@dtw_rurlescseq(V_MHMPKY)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)MapDefinitionMaintain.d2w/EDIT_DATA$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)MapDefinitionSelect.d2w/REPORT$(d2wVarBase)&amp;mapKey=@dtw_rurlescseq(V_MHMPKY)" title="View Map Definition">$(V_MHDESC)</a></td>
                  @RtvFldDesc("ACPGM='$(V_MHWPGM)' ", "WFAPCT", "Max(ACDESC)", fieldDesc)
                  <td class="colalph" $(helpCursor)><span title="$(fieldDesc)">$(V_MHWPGM)</span></td>                                      	
                  <td class="colalph">$(V_MHMPGM)</td>                                      	
                  <td class="colalph">$(V_MHRPGM)</td>                                      	
                  <td class="colalph">$(V_MHCPGM)</td>                                      	
                  <td class="colalph">$(V_MHPPGM)</td>                                      	
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select SYMMHD.*, ", stmtSQL)
  @dtw_concat(fileSQL, " SYMMHD ", fileSQL)
  %if (wildCardSearch!="")
      @dtw_concat(selectSQL, " MHMPKY>0 ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_XMLQuery (IN  CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("MapDefinitionList")
          %ROW{
              @XMLIDTag(V_MHMPKY, "MapDefinition ID")
                  @XMLTag(V_MHMPKY, "MapKey")
                  @XMLTag(V_MHDESC, "Description")
                  @XMLTag(V_MHWPGM, "WorkFlowProgram")
                  @XMLTag(V_MHMPGM, "MapProgram")
                  @XMLTag(V_MHRPGM, "InterfaceReportProgram")
                  @XMLTag(V_MHCPGM, "InterfaceCleanUpProgram")
                  @XMLTag(V_MHPPGM, "InterfaceProcessProgram")
              @XMLEndTag("MapDefinition")
          %}
      @XMLEndTag("MapDefinitionList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "MHDESCU,MHMPKY")
          @DTW_ASSIGN(orderByDisplay, "Description, Map Definition")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %if (updRecNbr > "0")
      @dtw_assign(START_ROW_NUM, updRecNbr)
      @dtw_assign(updRecNbr, "")
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Description")
      %if (orderBy == "MHDESCU,MHMPKY")
          @DTW_ASSIGN(orderBy, "MHDESCU DESC,MHMPKY")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Map Definition")
      %else
          @DTW_ASSIGN(orderBy, "MHDESCU,MHMPKY")
          @DTW_ASSIGN(orderByDisplay, "Description, Map Definition")
      %endif
  %elif (sequence == "WFProgram")
      %if (orderBy == "MHWPGM,MHDESCU")
          @DTW_ASSIGN(orderBy, "MHWPGM DESC,MHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Workflow Program (descending), Description")
      %else
          @DTW_ASSIGN(orderBy, "MHWPGM,MHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Workflow Program, Description")
      %endif
  %elif (sequence == "MapProgram")
      %if (orderBy == "MHMPGM,MHDESCU")
          @DTW_ASSIGN(orderBy, "MHMPGM DESC,MHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Map Program (descending), Description")
      %else
          @DTW_ASSIGN(orderBy, "MHMPGM,MHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Map Program, Description")
      %endif
  %elif (sequence == "ReportProgram")
      %if (orderBy == "MHRPGM,MHDESCU")
          @DTW_ASSIGN(orderBy, "MHRPGM DESC,MHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Interface Report Program (descending), Description")
      %else
          @DTW_ASSIGN(orderBy, "MHRPGM,MHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Interface Report Program, Description")
      %endif
  %elif (sequence == "CleanUpProgram")
      %if (orderBy == "MHCPGM,MHDESCU")
          @DTW_ASSIGN(orderBy, "MHCPGM DESC,MHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Interface Clean Up Program (descending), Description")
      %else
          @DTW_ASSIGN(orderBy, "MHCPGM,MHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Interface Clean Up Program, Description")
      %endif
  %elif (sequence == "ProcessProgram")
      %if (orderBy == "MHPPGM,MHDESCU")
          @DTW_ASSIGN(orderBy, "MHPPGM DESC,MHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Interface Process Program (descending), Description")
      %else
          @DTW_ASSIGN(orderBy, "MHPPGM,MHDESCU")
          @DTW_ASSIGN(orderByDisplay, "Interface Process Program, Description")
      %endif
  %endif
	
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "MAPDEFINITIONSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Workflow Program</td>
                              @dtw_assign(operNbr, "operWFProgram")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchWFProgram" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Map Program</td>
                              @dtw_assign(operNbr, "operMapProgram")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchMapProgram" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Interface Report Program</td>
                              @dtw_assign(operNbr, "operReportProgram")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchReportProgram" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Interface Clean Up Program</td>
                              @dtw_assign(operNbr, "operCleanUpProgram")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCleanUpProgram" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Interface Process Program</td>
                              @dtw_assign(operNbr, "operProcessProgram")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchProcessProgram" size="10" maxlength="10"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDesc.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("MHDESCU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("MHWPGM",  "Workflow Program", $(srchWFProgram), "U", operWFProgram, "A")
  @Build_WildCard ("MHMPGM",  "Map Program", $(srchMapProgram), "U", operMapProgram, "A")
  @Build_WildCard ("MHRPGM",  "Interface Report Program", $(srchReportProgram), "U", operReportProgram, "A")
  @Build_WildCard ("MHCPGM",  "Interface Clean Up Program", $(srchCleanUpProgram), "U", operCleanUpProgram, "A")
  @Build_WildCard ("MHPPGM",  "Interface Process Program", $(srchProcessProgram), "U", operProcessProgram, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}