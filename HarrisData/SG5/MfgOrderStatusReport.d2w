%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Manufacturing Order Status Report"
  d2wName                 = "MfgOrderStatusReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  forPlant                = ""
  sortSeqMax              = "9"
  sortPlantNumber         = "1"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromPlantNumber, 3, 0) &&
                      editNum(document.Chg.toPlantNumber, 3, 0) &&
                      editdate(document.Chg.fromStartDate) &&
                      editdate(document.Chg.toStartDate) &&
                      editdate(document.Chg.fromDueDate) &&
                      editdate(document.Chg.toDueDate) &&
                      editNum(document.Chg.fromBuyerAnalyst, 7, 0) &&
                      editNum(document.Chg.toBuyerAnalyst, 7, 0) &&
                      editFromToAll(document.Chg.fromPlantNumber, document.Chg.toPlantNumber, document.Chg.allPlantNumber, 3) &&
                      editFromToAll(document.Chg.fromOrderNumber, document.Chg.toOrderNumber, document.Chg.allOrderNumber, "A") &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromReferenceNumber, document.Chg.toReferenceNumber, document.Chg.allReferenceNumber, "A") &&
                      editFromToAll(document.Chg.fromStartDate, document.Chg.toStartDate, document.Chg.allStartDate, "D") &&
                      editFromToAll(document.Chg.fromDueDate, document.Chg.toDueDate, document.Chg.allDueDate, "D") &&
                      editFromToAll(document.Chg.fromBuyerAnalyst, document.Chg.toBuyerAnalyst, document.Chg.allBuyerAnalyst, 7) &&
                      editFromToAll(document.Chg.fromOrderType, document.Chg.toOrderType, document.Chg.allOrderType, "A") &&
                      editFromToAll(document.Chg.fromOrderStatus, document.Chg.toOrderStatus, document.Chg.allOrderStatus, "A")
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "MFGORDERSTATUSREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromPlantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@fplt", "fromPlantNumber")        @dtw_assign(Err_N1FPLT,  fieldValue)
                                  @DecatErr_Field("@@splt", "sortPlantNumber")        @dtw_assign(Err_N1SPLT,  fieldValue)
                                  @DecatErr_Field("@@sord", "sortOrderNumber")        @dtw_assign(Err_N1SORD,  fieldValue)
                                  @DecatErr_Field("@@sitm", "sortItemNumber")        @dtw_assign(Err_N1SITM,  fieldValue)
                                  @DecatErr_Field("@@sref", "sortReferenceNumber")        @dtw_assign(Err_N1SREF,  fieldValue)
                                  @DecatErr_Field("@@ssdt", "sortStartDate")        @dtw_assign(Err_N1SSDT,  fieldValue)
                                  @DecatErr_Field("@@sddt", "sortDueDate")        @dtw_assign(Err_N1SDDT,  fieldValue)
                                  @DecatErr_Field("@@sbac", "sortBuyerAnalyst")        @dtw_assign(Err_N1SBAC,  fieldValue)
                                  @DecatErr_Field("@@soty", "sortOrderType")        @dtw_assign(Err_N1SOTY,  fieldValue)
                                  @DecatErr_Field("@@sost", "sortOrderStatus")        @dtw_assign(Err_N1SOST,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}

                                  @Decat_Field("@@fplt")  @dtw_assign(V_N1FPLT,  fieldValue)
                                  @Decat_Field("@@tplt")  @dtw_assign(V_N1TPLT,  fieldValue)
                                  @Decat_Field("@@aplt")  @dtw_assign(V_N1APLT,  fieldValue)
                                  @Decat_Field("@@splt")  @dtw_assign(V_N1SPLT,  fieldValue)

                                  @Decat_Field("@@ford")  @dtw_assign(V_N1FORD,  fieldValue)
                                  @Decat_Field("@@tord")  @dtw_assign(V_N1TORD,  fieldValue)
                                  @Decat_Field("@@aord")  @dtw_assign(V_N1AORD,  fieldValue)
                                  @Decat_Field("@@sord")  @dtw_assign(V_N1SORD,  fieldValue)

                                  @Decat_Field("@@fitm")  @dtw_assign(V_N1FITM, fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N1TITM, fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N1AITM, fieldValue)
                                  @Decat_Field("@@sitm")  @dtw_assign(V_N1SITM, fieldValue)

                                  @Decat_Field("@@fref")  @dtw_assign(V_N1FREF,  fieldValue)
                                  @Decat_Field("@@tref")  @dtw_assign(V_N1TREF,  fieldValue)
                                  @Decat_Field("@@aref")  @dtw_assign(V_N1AREF,  fieldValue)
                                  @Decat_Field("@@sref")  @dtw_assign(V_N1SREF,  fieldValue)

                                  @Decat_Field("@@fsdt")  @dtw_assign(V_N1FSDT,  fieldValue)
                                  @Decat_Field("@@tsdt")  @dtw_assign(V_N1TSDT,  fieldValue)
                                  @Decat_Field("@@asdt")  @dtw_assign(V_N1ASDT,  fieldValue)
                                  @Decat_Field("@@ssdt")  @dtw_assign(V_N1SSDT,  fieldValue)

                                  @Decat_Field("@@fddt")  @dtw_assign(V_N1FDDT,  fieldValue)
                                  @Decat_Field("@@tddt")  @dtw_assign(V_N1TDDT,  fieldValue)
                                  @Decat_Field("@@addt")  @dtw_assign(V_N1ADDT,  fieldValue)
                                  @Decat_Field("@@sddt")  @dtw_assign(V_N1SDDT,  fieldValue)

                                  @Decat_Field("@@fbac")  @dtw_assign(V_N1FBAC,  fieldValue)
                                  @Decat_Field("@@tbac")  @dtw_assign(V_N1TBAC,  fieldValue)
                                  @Decat_Field("@@abac")  @dtw_assign(V_N1ABAC,  fieldValue)
                                  @Decat_Field("@@sbac")  @dtw_assign(V_N1SBAC,  fieldValue)

                                  @Decat_Field("@@foty")  @dtw_assign(V_N1FOTY, fieldValue)
                                  @Decat_Field("@@toty")  @dtw_assign(V_N1TOTY, fieldValue)
                                  @Decat_Field("@@aoty")  @dtw_assign(V_N1AOTY, fieldValue)
                                  @Decat_Field("@@soty")  @dtw_assign(V_N1SOTY, fieldValue)

                                  @Decat_Field("@@fost")  @dtw_assign(V_N1FOST, fieldValue)
                                  @Decat_Field("@@tost")  @dtw_assign(V_N1TOST, fieldValue)
                                  @Decat_Field("@@aost")  @dtw_assign(V_N1AOST, fieldValue)
                                  @Decat_Field("@@sost")  @dtw_assign(V_N1SOST, fieldValue)

                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries
 Values %}
                                  %if (V_N1APLT == "ALL")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPlantNumber, "")
                                  %endif
                                  %if (V_N1AORD == "ALL")
                                      @dtw_assign(checkedallOrderNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallOrderNumber, "")
                                  %endif
                                  %if (V_N1AITM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_N1AREF == "ALL")
                                      @dtw_assign(checkedallReferenceNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallReferenceNumber, "")
                                  %endif
                                  %if (V_N1ASDT == "ALL")
                                      @dtw_assign(checkedallStartDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallStartDate, "")
                                  %endif
                                  %if (V_N1ADDT == "ALL")
                                      @dtw_assign(checkedallDueDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallDueDate, "")
                                  %endif
                                  %if (V_N1ABAC == "ALL")
                                      @dtw_assign(checkedallBuyerAnalyst, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallBuyerAnalyst, "")
                                  %endif
                                  %if (V_N1AOTY == "ALL")
                                      @dtw_assign(checkedallOrderType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallOrderType, "")
                                  %endif
                                  %if (V_N1AOST == "ALL")
                                      @dtw_assign(checkedallOrderStatus, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallOrderStatus, "")
                                  %endif

                              %else
                                  @RtvDftPlant(plantNumber, plantName)
                                  %if (plantNumber == "0")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(V_N1FPLT, plantNumber)
                                      @dtw_assign(V_N1TPLT, plantNumber)
                                      @dtw_assign(checkedallPlantNumber, "")
                                      @dtw_assign(focusField, "fromOrderNumber")
                                  %endif
                                  @dtw_assign(checkedallOrderNumber, "CHECKED")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallReferenceNumber, "CHECKED")
                                  @dtw_assign(checkedallStartDate, "CHECKED")
                                  @dtw_assign(checkedallDueDate, "CHECKED")
                                  @dtw_assign(checkedallBuyerAnalyst, "CHECKED")
                                  @dtw_assign(checkedallOrderType, "CHECKED")
                                  @dtw_assign(checkedallOrderStatus, "CHECKED")
                              %endif

                          </table>

                          <table $(contentTable)>

                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                              </tr>

                              @SetTextOvr(Err_N1FPLT)
                              %if (textOvr == "") @SetTextOvr(Err_N1SPLT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                  <td class="inputnmbr"><input name="fromPlantNumber" value="$(V_N1FPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromPlantNumber&amp;fldDesc=fplantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fplantName"  type="hidden"></td>
                                  <td class="inputnmbr"><input name="toPlantNumber" value="$(V_N1TPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toPlantNumber&amp;fldDesc=tplantName" onclick="$(searchWinVar)">  $(searchImage) </a><input name="tplantName"  type="hidden"></td>
                                  <td class="inputalph"><input name="allPlantNumber" value='ALL' $(checkedallPlantNumber) type="checkbox" onClick="if (this.checked) this.form.fromPlantNumber.value='', this.form.toPlantNumber.value='';"></td>
                                  <td class="colcode"><input name="sortPlantNumber" type="hidden"  Value="$(sortPlantNumber)" size="1" maxlength="1">$(sortPlantNumber)</td>
                              </tr>
                              @DspErrMsg(Err_N1FPLT)
                              @DspErrMsg(Err_N1SPLT)

                              @SetTextOvr(Err_N1SORD)
                              <tr><td class="dsphdr"><span $(textOvr)>Order Number</span></td>
                                  <td class="inputalph"><input name="fromOrderNumber" value="$(V_N1FORD)" type="text" size="15" maxlength="9"><a href="$(homeURL)$(phpPath)MfgOrderSearch.php$(altVarBase)&amp;docName=Chg&amp;forPlant=$(forPlant)&amp;fldorder=fromOrderNumber" onclick="$(searchWinVar)">  $(searchImage) </a></td>
                                  <td class="inputalph"><input name="toOrderNumber" value="$(V_N1TORD)" type="text" size="15" maxlength="9"><a href="$(homeURL)$(phpPath)MfgOrderSearch.php$(altVarBase)&amp;docName=Chg&amp;forPlant=$(forPlant)&amp;fldorder=toOrderNumber" onclick="$(searchWinVar)">  $(searchImage) </a></td>
                                  <td class="inputalph"><input name="allOrderNumber" value='ALL' $(checkedallOrderNumber) type="checkbox" onClick="if (this.checked) this.form.fromOrderNumber.value='', this.form.toOrderNumber.value='';"></td>
                                  @Build_Sort_Select("sortOrderNumber", "$(V_N1SORD)")
                              </tr>
                              @DspErrMsg(Err_N1SORD)

                              @SetTextOvr(Err_N1SITM)
                              <tr><td class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N1FITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N1TITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                                  @Build_Sort_Select("sortItemNumber", "$(V_N1SITM)")
                              </tr>
                              @DspErrMsg(Err_N1SITM)

                              @SetTextOvr(Err_N1SREF)
                              <tr><td class="dsphdr"><span $(textOvr)>Reference Number</span></td>
                                  <td class="inputalph"><input name="fromReferenceNumber" value="$(V_N1FREF)" type="text" size="25" maxlength="20"></td>
                                  <td class="inputalph"><input name="toReferenceNumber" value="$(V_N1TREF)" type="text" size="25" maxlength="20"></td>
                                  <td class="inputalph"><input name="allReferenceNumber" value='ALL' $(checkedallReferenceNumber) type="checkbox" onClick="if (this.checked) this.form.fromReferenceNumber.value='', this.form.toReferenceNumber.value='';"></td>
                                  @Build_Sort_Select("sortReferenceNumber", "$(V_N1SREF)")
                              </tr>
                              @DspErrMsg(Err_N1SREF)

                              @SetTextOvr(Err_N1SSDT)
                              <tr><td class="dsphdr"><span $(textOvr)>Start Date</span></td>
                                  <td class="inputnmbr"><input name="fromStartDate" value="$(V_N1FSDT)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromStartDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toStartDate" value="$(V_N1TSDT)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toStartDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allStartDate" value='ALL' $(checkedallStartDate) type="checkbox" onClick="if (this.checked) this.form.fromStartDate.value='', this.form.toStartDate.value='';"></td>
                                  @Build_Sort_Select("sortStartDate", "$(V_N1SSDT)")
                              </tr>
                              @DspErrMsg(Err_N1SSDT)

                              @SetTextOvr(Err_N1SDDT)
                              <tr><td class="dsphdr"><span $(textOvr)>Due Date</span></td>
                                  <td class="inputnmbr"><input name="fromDueDate" value="$(V_N1FDDT)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromDueDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toDueDate" value="$(V_N1TDDT)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toDueDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allDueDate" value='ALL' $(checkedallDueDate) type="checkbox" onClick="if (this.checked) this.form.fromDueDate.value='', this.form.toDueDate.value='';"></td>
                                  @Build_Sort_Select("sortDueDate", "$(V_N1SDDT)")
                              </tr>
                              @DspErrMsg(Err_N1SDDT)

                              @SetTextOvr(Err_N1SBAC)
                              <tr><td class="dsphdr"><span $(textOvr)>Buyer/Analyst</span></td>
                                  <td class="inputnmbr"><input name="fromBuyerAnalyst" value="$(V_N1FBAC)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)BuyerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromBuyerAnalyst&amp;fldDesc=analystName&amp;buyerAnalyst=Analyst" onclick="$(searchWinVar)"> $(searchImage) </a><input name="analystName" type="hidden"><input name="Analyst" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toBuyerAnalyst" value="$(V_N1TBAC)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)BuyerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toBuyerAnalyst&amp;fldDesc=analystName&amp;buyerAnalyst=Analyst" onclick="$(searchWinVar)"> $(searchImage) </a><input name="analystName" type="hidden"><input name="Analyst" type="hidden"></td>
                                  <td class="inputalph"><input name="allBuyerAnalyst" value='ALL' $(checkedallBuyerAnalyst) type="checkbox" onClick="if (this.checked) this.form.fromBuyerAnalyst.value='', this.form.toBuyerAnalyst.value='';"></td>
                                  @Build_Sort_Select("sortBuyerAnalyst", "$(V_N1SBAC)")
                              </tr>
                              @DspErrMsg(Err_N1SBAC)

                              @SetTextOvr(Err_N1SOTY)
                              <tr><td class="dsphdr"><span $(textOvr)>Order Type</span></td>
                                  <td class="inputalph"><input name="fromOrderType" value="$(V_N1FOTY)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="toOrderType" value="$(V_N1TOTY)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="allOrderType" value='ALL' $(checkedallOrderType) type="checkbox" onClick="if (this.checked) this.form.fromOrderType.value='', this.form.toOrderType.value='';"></td>
                                  @Build_Sort_Select("sortOrderType", "$(V_N1SOTY)")
                              </tr>
                              @DspErrMsg(Err_N1SOTY)

                              @SetTextOvr(Err_N1SOST)
                              <tr><td class="dsphdr"><span $(textOvr)>Order Status</span></td>
                                  <td class="inputalph"><input name="fromOrderStatus" value="$(V_N1FOST)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="toOrderStatus" value="$(V_N1TOST)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="allOrderStatus" value='ALL' $(checkedallOrderStatus) type="checkbox" onClick="if (this.checked) this.form.fromOrderStatus.value='', this.form.toOrderStatus.value='';"></td>
                                  @Build_Sort_Select("sortOrderStatus", "$(V_N1SOST)")
                              </tr>
                              @DspErrMsg(Err_N1SOST)

                          </table>

                          @dtw_assign(envProgram, "HSI300")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSI903_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allPlantNumber)
  @dtw_mUPPERCASE(fromOrderNumber)
  @dtw_mUPPERCASE(toOrderNumber)
  @dtw_mUPPERCASE(allOrderNumber)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(fromReferenceNumber)
  @dtw_mUPPERCASE(toReferenceNumber)
  @dtw_mUPPERCASE(allReferenceNumber)
  @dtw_mUPPERCASE(allStartDate)
  @dtw_mUPPERCASE(allDueDate)
  @dtw_mUPPERCASE(allBuyerAnalyst)
  @dtw_mUPPERCASE(fromOrderType)
  @dtw_mUPPERCASE(toOrderType)
  @dtw_mUPPERCASE(allOrderType)
  @dtw_mUPPERCASE(fromOrderStatus)
  @dtw_mUPPERCASE(toOrderStatus)
  @dtw_mUPPERCASE(allOrderStatus)

  @dtw_assign(fromPlantNumber,@dtw_rstrip(fromPlantNumber))
  @dtw_assign(toPlantNumber,@dtw_rstrip(toPlantNumber))
  @dtw_assign(sortPlantNumber,@dtw_rstrip(sortPlantNumber))
  @dtw_assign(sortOrderNumber,@dtw_rstrip(sortOrderNumber))
  @dtw_assign(sortItemNumber,@dtw_rstrip(sortItemNumber))
  @dtw_assign(sortReferenceNumber,@dtw_rstrip(sortReferenceNumber))
  @dtw_assign(fromStartDate,@dtw_rstrip(fromStartDate))
  @dtw_assign(toStartDate,@dtw_rstrip(toStartDate))
  @dtw_assign(sortStartDate,@dtw_rstrip(sortStartDate))
  @dtw_assign(fromDueDate,@dtw_rstrip(fromDueDate))
  @dtw_assign(toDueDate,@dtw_rstrip(toDueDate))
  @dtw_assign(sortDueDate,@dtw_rstrip(sortDueDate))
  @dtw_assign(fromBuyerAnalyst,@dtw_rstrip(fromBuyerAnalyst))
  @dtw_assign(toBuyerAnalyst,@dtw_rstrip(toBuyerAnalyst))
  @dtw_assign(sortBuyerAnalyst,@dtw_rstrip(sortBuyerAnalyst))
  @dtw_assign(sortOrderType,@dtw_rstrip(sortOrderType))
  @dtw_assign(sortOrderStatus,@dtw_rstrip(sortOrderStatus))

  %if (allPlantNumber != "ALL")
      @dtw_assign(allPlantNumber, "")
  %endif
  %if (allOrderNumber != "ALL")
      @dtw_assign(allOrderNumber, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allReferenceNumber != "ALL")
      @dtw_assign(allReferenceNumber, "")
  %endif
  %if (allStartDate != "ALL")
      @dtw_assign(allStartDate, "")
  %endif
  %if (allDueDate != "ALL")
      @dtw_assign(allDueDate, "")
  %endif
  %if (allBuyerAnalyst != "ALL")
      @dtw_assign(allBuyerAnalyst, "")
  %endif
  %if (allOrderType != "ALL")
      @dtw_assign(allOrderType, "")
  %endif
  %if (allOrderStatus != "ALL")
      @dtw_assign(allOrderStatus, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@fplt", fromPlantNumber)
  @Concat_Field("@@tplt", toPlantNumber)
  @Concat_Field("@@aplt", allPlantNumber)
  @Concat_Field("@@splt", sortPlantNumber)
  @Concat_Field("@@ford", fromOrderNumber)
  @Concat_Field("@@tord", toOrderNumber)
  @Concat_Field("@@aord", allOrderNumber)
  @Concat_Field("@@sord", sortOrderNumber)
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@sitm", sortItemNumber)
  @Concat_Field("@@fref", fromReferenceNumber)
  @Concat_Field("@@tref", toReferenceNumber)
  @Concat_Field("@@aref", allReferenceNumber)
  @Concat_Field("@@sref", sortReferenceNumber)
  @Concat_Field("@@fsdt", fromStartDate)
  @Concat_Field("@@tsdt", toStartDate)
  @Concat_Field("@@asdt", allStartDate)
  @Concat_Field("@@ssdt", sortStartDate)
  @Concat_Field("@@fddt", fromDueDate)
  @Concat_Field("@@tddt", toDueDate)
  @Concat_Field("@@addt", allDueDate)
  @Concat_Field("@@sddt", sortDueDate)
  @Concat_Field("@@fbac", fromBuyerAnalyst)
  @Concat_Field("@@tbac", toBuyerAnalyst)
  @Concat_Field("@@abac", allBuyerAnalyst)
  @Concat_Field("@@sbac", sortBuyerAnalyst)
  @Concat_Field("@@foty", fromOrderType)
  @Concat_Field("@@toty", toOrderType)
  @Concat_Field("@@aoty", allOrderType)
  @Concat_Field("@@soty", sortOrderType)
  @Concat_Field("@@fost", fromOrderStatus)
  @Concat_Field("@@tost", toOrderStatus)
  @Concat_Field("@@aost", allOrderStatus)
  @Concat_Field("@@sost", sortOrderStatus)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}