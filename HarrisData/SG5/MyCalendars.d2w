%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "My Calendars"
  d2wName                 = "MyCalendars.d2w"
  d2wVarBase              = "$(genericVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
  reportSelType           = "C"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "MYCALENDARS")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " SYD2WR ", fileSQL)
                      @dtw_concat(selectSQL, "DRUSER='$(userProfile)' and DRTYPE='$(reportSelType)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @MyCalendars_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) MyCalendars_Query (IN CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count == "0" || sql_Record_Count == "")
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/New_Calendar$(d2wVarBase)&amp;maintenanceCode=R">
      %elif (sql_Record_Count > "1")
          %INCLUDE "PageTitleWithPrint.icl"
          %INCLUDE "ConfMessageDisplay.icl"

          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr>
                          <th class="colhdr">Description</th>
                      </tr>
                      <tr><td><input type="text" class="inputalph" name="srchDesc" size="20" maxlength="20">
                              <input type="hidden" name="operDesc" value="LIKE">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchDesc.focus();
                  </script>
              </form>

              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              <tr>
                  %if (formatToPrint != "Y")
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("DRDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description, Report"> Description</a></th>
              </tr>
      %endif

          %ROW{
              %if (sql_Record_Count == "1")
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;reportSelD2W=@dtw_rurlescseq(V_DRD2WN)&amp;reportSelUser=@dtw_rurlescseq(V_DRUSER)&amp;reportSelSeq=@dtw_rurlescseq(V_DRSEQN)&amp;reportSelDesc=@dtw_rurlescseq(V_DRDESC)")
                  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(maintainVar)&amp;maintenanceCode=R&amp;displayCalendar=Y">
              %else
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;reportSelD2W=@dtw_rurlescseq(V_DRD2WN)&amp;reportSelUser=@dtw_rurlescseq(V_DRUSER)&amp;reportSelSeq=@dtw_rurlescseq(V_DRSEQN)&amp;reportSelDesc=@dtw_rurlescseq(V_DRDESC)")
                  %INCLUDE "SetRowClass.icl"
                  @Format_Confirm_Desc($(V_DRDESC), "", "", "", "", "", confirmDesc)

                  <tr class="$(rowClass)">
                      %if (formatToPrint != "Y")
                          <td class="opticon">
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                              <a href="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(maintainVar)&amp;maintenanceCode=R" title="Click here change calendar selection">$(changeImageSml)</a>
                          </td>
                      %endif
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(maintainVar)&amp;maintenanceCode=R&amp;displayCalendar=Y" title="Click here display the calendar">$(V_DRDESC)</a></td>
                  </tr>
              %endif
          %}
      %if (sql_Record_Count > "1")
          </table>
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
          $(hrTagAttr)
          %INCLUDE "Copyright.icl"
      %endif
  %}
%}

%FUNCTION(dtw_directcall) Retrieve_Selection(INOUT CHAR(64)    profileHandle,
                                             INOUT CHAR(2)     dataBaseID,
                                             INOUT CHAR(1)     maintenanceCode,
                                             INOUT CHAR(1)     errFound,
                                             INOUT CHAR(32000) edtVar,                             	
                                             INOUT CHAR(32000) reportSelVar)
{%EXEC {HSYD2R_W.PGM %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(32000) edtVar)
  {%EXEC {HSYCLS_W.PGM %}
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @dtw_assign(edtVar, "")
  @Concat_Field("@@d2wn", reportSelD2W)
  @Concat_Field("@@user", reportSelUser)
  @Concat_Field("@@type", reportSelType)
  @Concat_Field("@@seqn", reportSelSeq)
  @Concat_Field("@@desc", reportSelDesc)
  @dtw_concat(edtVar, "}{", edtVar)

  @Retrieve_Selection(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, reportSelVar)

  %if (maintenanceCode == "D")
      @Set_SQL(stmtSQL)
  %elif (displayCalendar == "Y")
      @dtw_assign(edtVar, "")
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @Validate_Data(profileHandle, dataBaseID, edtVar)
      @Decat_Field("@@copn")   @dtw_assign(dspOpen, fieldValue)
      @Decat_Field("@@casn")   @dtw_assign(dspAssigned, fieldValue)
      @Decat_Field("@@ccmp")   @dtw_assign(dspCompleted, fieldValue)
      @Decat_Field("@@ctim")   @dtw_assign(dspTime, fieldValue)
      @dtw_assign(dspTimeSel, "N")
      @dtw_assign(dspAsgnSel, "N")
      @dtw_assign(dspOpenSel, "N")
      @dtw_assign(dspCompSel, "N")

      %if (dspTime == "CHECKED")
          @dtw_assign(dspTimeSel, "Y")
      %endif

      %if (dspAssigned == "CHECKED")
          @dtw_assign(dspAsgnSel, "Y")
      %endif

      %if (dspOpen == "CHECKED")
          @dtw_assign(dspOpenSel, "Y")
      %endif

      %if (dspCompleted == "CHECKED")
          @dtw_assign(dspCompSel, "Y")
      %endif

      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)EventCalendar.d2w/CALENDAR$(d2wVarBase)&amp;dspTime=@dtw_rurlescseq(dspTimeSel)&amp;dspComp=@dtw_rurlescseq(dspCompSel)&amp;dspOpen=@dtw_rurlescseq(dspOpenSel)&amp;dspAsgn=@dtw_rurlescseq(dspAsgnSel)&amp;reload=S">
  %else
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(reportSelD2W)/REPORT$(genericVarBase)&amp;errFound=Y&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif

%}

%HTML(New_Calendar) {
  %INCLUDE "setLibraryList.icl"

  @dtw_assign(edtVar, "")
  @Concat_Field("@@user", userProfile)
  @Concat_Field("@@cust", "")
  @Concat_Field("@@ccon", "")
  @Concat_Field("@@vend", "")
  @Concat_Field("@@scon", "")
  @Concat_Field("@@evnt", "")
  @Concat_Field("@@ccus", "Y")
  @Concat_Field("@@csup", "Y")
  @Concat_Field("@@copn", "Y")
  @Concat_Field("@@casn", "Y")
  @Concat_Field("@@ccmp", displayComp)
  @Concat_Field("@@ctim", displayTime)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, edtVar)

  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)EventCalendar.d2w/CALENDAR$(d2wVarBase)&amp;dspTime=@dtw_rurlescseq(dspTimeSel)&amp;dspComp=@dtw_rurlescseq(dspCompSel)&amp;dspOpen=@dtw_rurlescseq(dspOpenSel)&amp;dspAsgn=@dtw_rurlescseq(dspAsgnSel)&amp;reload=S">

%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "DRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Description")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Desc")
      %if (orderBy == "DRDESCU")
          @DTW_ASSIGN(orderBy, "DRDESCU DESC")
          @DTW_ASSIGN(orderByDisplay, "Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "DRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Description")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("DRDESCU", "Description", $(srchDesc), "U", operDesc, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}