%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StockLocMaintain.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Stock Location Maintenance"
  d2wName                 = "StockLocMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;warehouseName=@dtw_rurlescseq(warehouseName)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;stockRoom=@dtw_rurlescseq(stockRoom)&amp;aisle=@dtw_rurlescseq(aisle)&amp;location=@dtw_rurlescseq(location)&amp;maintenanceCode=D"
  programName             = "HHDSRU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.warehouseNumber.value =="" ||
                      document.Chg.stockRoom.value =="" &&
                      document.Chg.aisle.value =="" &&
                      document.Chg.location.value =="")
                         {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.warehouseNumber, 3, 0) &&
                      editNum(document.Chg.cubicCapacity, 5, 2) &&
                      editNum(document.Chg.weightLimit, 5, 2))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "STOCKLOCMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, " Select * From HDSTLC Where SLWHS = $(warehouseNumber) ", stmtSQL)
                          @dtw_concat(stmtSQL, " and SLSTKR = '$(stockRoom)' ", stmtSQL)
                          @dtw_concat(stmtSQL, " and SLAILE = '$(aisle)' ", stmtSQL)
                          @dtw_concat(stmtSQL, " and SLSLOC = '$(location)' ", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=288")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "warehouseNumber")
                      %else
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @dtw_assign(focusField, "")
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@whs@", "warehouseNumber")   @dtw_assign(Err_SLWHS,  fieldValue)
                          @DecatErr_Field("@@stkr", "stockRoom")   @dtw_assign(Err_SLSTKR, fieldValue)
                          @DecatErr_Field("@@aile", "aisle")   @dtw_assign(Err_SLAILE, fieldValue)
                          @DecatErr_Field("@@sloc", "location")   @dtw_assign(Err_SLSLOC, fieldValue)
                          @DecatErr_Field("@@palt", "palletSize")   @dtw_assign(Err_SLPALT, fieldValue)
                          @DecatErr_Field("@@rate", "priorityRating")   @dtw_assign(Err_SLRATE, fieldValue)
                          @DecatErr_Field("@@cube", "cubicCapacity")   @dtw_assign(Err_SLCUBE, fieldValue)
                          @DecatErr_Field("@@cuom", "cubicUM")   @dtw_assign(Err_SLCUOM, fieldValue)
                          @DecatErr_Field("@@wght", "weightLimit")   @dtw_assign(Err_SLWGHT, fieldValue)
                          @DecatErr_Field("@@wuom", "weightUM")   @dtw_assign(Err_SLWUOM, fieldValue)
                      %endif

                      @Decat_Field("@@whs@")   @dtw_assign(V_SLWHS,  fieldValue)
                      @Decat_Field("@@stkr")   @dtw_assign(V_SLSTKR, fieldValue)
                      @Decat_Field("@@aile")   @dtw_assign(V_SLAILE, fieldValue)
                      @Decat_Field("@@sloc")   @dtw_assign(V_SLSLOC, fieldValue)
                      @Decat_Field("@@palt")   @dtw_assign(V_SLPALT, fieldValue)
                      @Decat_Field("@@cube")   @dtw_assign(V_SLCUBE, fieldValue)
                      @Decat_Field("@@cuom")   @dtw_assign(V_SLCUOM, fieldValue)
                      @Decat_Field("@@wght")   @dtw_assign(V_SLWGHT, fieldValue)
                      @Decat_Field("@@wuom")   @dtw_assign(V_SLWUOM, fieldValue)
                      @Decat_Field("@@rate")   @dtw_assign(V_SLRATE, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(V_SLWHS,  $(warehouseNumber))
                          @dtw_assign(focusField, "stockRoom")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "stockRoom")
                      @dtw_assign(V_SLWHS,   $(warehouseNumber))
                      @dtw_assign(V_SLSTKR,  "")
                      @dtw_assign(V_SLAILE,  "")
                      @dtw_assign(V_SLSLOC,  "")
                  %else
                      @dtw_assign(focusField, "palletSize")
                  %endif

                  @Default_Zero(V_SLWHS)
                  @RtvFldDesc("WHWHS=$(V_SLWHS)", "HDWHSM", "WHWHNM", whsName)
                  @SetTextOvr(Err_SLWHS)
                  <tr><td class="dsphdr"><span $(textOvr)>Warehouse Number</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                           <td class="inputnmbr"><input name="warehouseNumber" type="text" value="$(V_SLWHS)" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=warehouseNumber&amp;fldDesc=whsName" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input name="whsName" type="text" value="$(whsName)" size="30" maxlength="30" disabled></td>
                      %else
                          <td class="inputnmbr"><input name="warehouseNumber" type="hidden" value="$(V_SLWHS)" size="3" maxlength="3">$(V_SLWHS) &nbsp; $(whsName)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_SLWHS)

                  @SetTextOvr(Err_SLSTKR)
                  <tr><td class="dsphdr"><span $(textOvr)>Stock Location</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="stockRoom" type="text" value="$(V_SLSTKR)" size="3" maxlength="3">
                                                      <input name="aisle" type="text" value="$(V_SLAILE)" size="4" maxlength="4">
                                                      <input name="location" type="text" value="$(V_SLSLOC)" size="8" maxlength="8"> $(reqFieldChar) </td>
                      %else
                          <td class="inputalph"><input name="stockRoom" type="hidden" value="$(V_SLSTKR)" size="3" maxlength="3">$(V_SLSTKR) -
                                                      <input name="aisle" type="hidden" value="$(V_SLAILE)" size="4" maxlength="4">$(V_SLAILE) -
                                                      <input name="location" type="hidden" value="$(V_SLSLOC)" size="8" maxlength="8">$(V_SLSLOC)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_SLSTKR)

                  @SetTextOvr(Err_SLPALT)
                  <tr><td class="dsphdr"><span $(textOvr)>Pallet Size</span></td>
                      <td class="inputalph"><input name="palletSize" type="text" value="$(V_SLPALT)" size="5" maxlength="5"></td>
                  </tr>
                  @DspErrMsg(Err_SLPALT)

                  @SetTextOvr(Err_SLRATE)
                  <tr><td class="dsphdr"><span $(textOvr)>Priority Rating</span></td>
                      @dtw_tb_rows(priorityTable, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(priorityTable, x, "1") != V_SLRATE) && (x < maxRows))
                            {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(priorityTable, "priorityRating", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_SLRATE)
	   		
                  @SetTextOvr(Err_SLCUBE)
                  <tr><td class="dsphdr"><span $(textOvr)>Cubic Capacity</span></td>
                      <td class="inputnmbr"><input type="text" name="cubicCapacity" value="$(V_SLCUBE)" size="9" maxlength="9"></td>
                  </tr>
                  @DspErrMsg(Err_SLCUBE)

                  @RtvFldDesc("UMUOM='$(V_SLCUOM)'", "HDUOM", "UMUMLD", fieldDesc)
                  @SetTextOvr(Err_SLCUOM)
                  <tr><td class="dsphdr"><span $(textOvr)>Cubic U/M</span></td>
                      <td class="inputnmbr"><input name="cubicUM" type="text" value="$(V_SLCUOM)" size="4" maxlength="2"><a href="$(homeURL)$(cGIPath)UnitOfMeasureSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=cubicUM&amp;fldDesc=cubicUMDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="cubicUMDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_SLCUOM)
	   		
                  @SetTextOvr(Err_SLWGHT)
                  <tr><td class="dsphdr"><span $(textOvr)>Weight Limit</span></td>
                      <td class="inputnmbr"><input type="text" name="weightLimit" value="$(V_SLWGHT)" size="9" maxlength="9"></td>
                  </tr>
                  @DspErrMsg(Err_SLWGHT)

                  @RtvFldDesc("UMUOM='$(V_SLWUOM)'", "HDUOM", "UMUMLD", fieldDesc)
                  @SetTextOvr(Err_SLWUOM)
                  <tr><td class="dsphdr"><span $(textOvr)>Weight U/M</span></td>
                      <td class="inputnmbr"><input name="weightUM" type="text" value="$(V_SLWUOM)" size="4" maxlength="2"><a href="$(homeURL)$(cGIPath)UnitOfMeasureSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=weightUM&amp;fldDesc=weightUMDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="weightUMDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_SLWUOM)
              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDSRU_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Priority_Rating_Query(profileHandle, dataBaseID, "PRIORITY  ", priorityTable)
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(stockRoom)
  @dtw_mUPPERCASE(aisle)
  @dtw_mUPPERCASE(location)
  @dtw_mUPPERCASE(palletSize)
  @dtw_mUPPERCASE(cubicUM)
  @dtw_mUPPERCASE(weightUM)
  @dtw_assign(warehouseNumber,@dtw_rstrip(warehouseNumber))
  @dtw_assign(cubicCapacity,@dtw_rstrip(cubicCapacity))
  @dtw_assign(weightLimit,@dtw_rstrip(weightLimit))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@whs@", warehouseNumber)
  @Concat_Field("@@stkr", stockRoom)
  @Concat_Field("@@aile", aisle)
  @Concat_Field("@@sloc", location)
  @Concat_Field("@@palt", palletSize)
  @Concat_Field("@@rate", priorityRating)
  @Concat_Field("@@cube", cubicCapacity)
  @Concat_Field("@@cuom", cubicUM)
  @Concat_Field("@@wght", weightLimit)
  @Concat_Field("@@wuom", weightUM)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      @RtvFldDesc("WHWHS=$(warehouseNumber)", "HDWHSM", "WHWHNM", warehouseName)
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, "$(stockRoom)-$(aisle)-$(location)", "", " in $(warehouseName)", "$(warehouseNumber)", "", "", confMessage)
      %else
          @DecatErr_Field("@@whs@", "stockRoom")
          %if (fieldValue=="") @DecatErr_Field("@@stkr", "stockRoom") %endif
          @Format_ConfMsg_Desc("", "$(stockRoom)-$(aisle)-$(location)", "", "in $(warehouseName)", "$(warehouseNumber)", "<br>$(fieldValue)", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=288&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;warehouseName=@dtw_rurlescseq(warehouseName)&amp;stockRoom=@dtw_rurlescseq(stockRoom)&amp;aisle=@dtw_rurlescseq(aisle)&amp;location=@dtw_rurlescseq(location)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
