%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Order Entry - User Defined Detail"
  d2wName                 = "OrderEntryDetail.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;lineNumber=@dtw_rurlescseq(lineNumber)&amp;releaseNumber=@dtw_rurlescseq(releaseNumber)&amp;errFound=@dtw_rurlescseq(errFound)&amp;addNonStock=@dtw_rurlescseq(addNonStock)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
  userDetailCount         = ""
  userDetailFields        = ""
  multShipToCustomer      = ""
  custType                = "B"
  O1OREC                  = ""
  tabID                   = "ITEMDETAIL"
  deleteAllowed           = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@customerName", "@dtw_rurlescseq(customerName)", "1", "a", workURL)
  @dtw_replace(workURL, "@@customerNumber", "@dtw_rurlescseq(customerNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@orderControlNumber", "@dtw_rurlescseq(orderControlNumber)", "1", "a", workURL)
%}

%MACRO_FUNCTION Remove_User_Field (IN CHAR(100) fieldSeq)
{
  @dtw_assign(z, "1")
  %while((@dtw_tb_rgetv(userDetailTable, z, "1") != "$(fieldSeq)") && (z < userDetailCount))
      {@dtw_add(z, "1", z)%}
  %if (@dtw_tb_rgetv(userDetailTable, z, "1") == "$(fieldSeq)")
       @dtw_tb_deleterow(userDetailTable, z, "1")
       @dtw_subtract(userDetailCount, "1", userDetailCount)
  %endif
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "OrderEntryProgOpt.icl"
          %INCLUDE "OrderEntryRetInfo.icl"
          @dtw_assign(multShipToCustomer, "0")
          %if (dropShip != "Y")
              @RtvFldDesc("CMCUST=$(H1BLTO) or CMBLTO=$(H1BLTO)", "HDCUST", "CHAR(COUNT(CMCUST))", multShipToCustomer)
          %endif

          %if (addNonStock == "Y")
              @dtw_assign(O1OREC, "N")
          %else
              @RtvFldDesc("O1OCTL=$(orderControlNumber) and O1ORL#=$(lineNumber) and O1BLN#=$(releaseNumber)", "OEDTWK", "O1OREC", O1OREC)
          %endif
          @User_Detail_Query(userProfile, H1ORTY, O1OREC, userDetailTable)
          @dtw_tb_rows(userDetailTable, userDetailCount)
          %if (oe_sec_07 != "Y")
              @Remove_User_Field("60")
          %endif
          %if (oe_sec_09 != "Y")
              @Remove_User_Field("90")
          %endif
          %if (oe_sec_08 != "Y" && O1OREC != "N" && addNonStock != "Y")
              @Remove_User_Field("100")
          %endif
          %if (oe_sec_10 != "Y")
              @Remove_User_Field("10")
          %endif
          %if (userDtlNumDesc1 == "")
              @Remove_User_Field("230")
          %endif
          %if (userDtlNumDesc2 == "")
              @Remove_User_Field("240")
          %endif
          %if (userDtlNumDesc3 == "")
              @Remove_User_Field("250")
          %endif
          %if (userDtlNumDesc4 == "")
              @Remove_User_Field("251")
          %endif
          %if (userDtlNumDesc5 == "")
              @Remove_User_Field("252")
          %endif
          %if (V_HDPORL == "00000" || allowPOGeneration != "Y")
              @Remove_User_Field("160")
          %endif

          @dtw_assign(recCnt, "1")
          @dtw_assign(userDetailFields, "")
          %while(recCnt <= userDetailCount) {
              @dtw_tb_getv(userDetailTable, recCnt, "1", V_UMFSEQ)
              %while(@dtw_rlength(V_UMFSEQ) != "3") {@dtw_insert("0", V_UMFSEQ, V_UMFSEQ)%}
              @dtw_concat(userDetailFields, "@@$(V_UMFSEQ)", userDetailFields)
              @dtw_add(recCnt, "1", recCnt)
          %}
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "OrderEntryConfirm.icl"
              function confirmClose() {return confirm("Confirm close of line");}
              function validate(chgForm) {
                  if (
                      %if (@dtw_rpos("@@020", userDetailFields) > "0")
                          document.Chg.itemNumber.value =="" ||
                      %endif
                      %if (@dtw_rpos("@@010", userDetailFields) > "0")
                          document.Chg.warehouse.value =="" ||
                      %endif
                      %if (@dtw_rpos("@@030", userDetailFields) > "0")
                          document.Chg.qtyOrdered.value =="" ||
                      %endif
                      %if (addNonStock == "Y" || O1OREC == "N")
                          document.Chg.itemDescription.value =="" ||
                          document.Chg.stockingUM.value =="" ||
                          document.Chg.pricingUM.value =="" ||
                          document.Chg.prodClass.value =="" ||
                      %endif
                      document.Chg.octl.value ==""
                     )
                     {alert("$(reqFieldError)"); return false;}
                  if (
                      editNum(document.Chg.octl, 8, 0)
                      %if (@dtw_rpos("@@010", userDetailFields) > "0")
                          && editNum(document.Chg.warehouse, 3, 0)
                      %endif
                      %if (@dtw_rpos("@@030", userDetailFields) > "0")
                          && editNum(document.Chg.qtyOrdered, 9, 4)
                      %endif
                      %if (@dtw_rpos("@@040", userDetailFields) > "0")
                          && editdate(document.Chg.reqDate)
                      %endif
                      %if (@dtw_rpos("@@060", userDetailFields) > "0")
                          && editNum(document.Chg.price, 8, 5)
                      %endif
                      %if (@dtw_rpos("@@070", userDetailFields) > "0")
                          && editNum(document.Chg.discountPercent, 3, 4)
                      %endif
                      %if (@dtw_rpos("@@090", userDetailFields) > "0")
                          && editNum(document.Chg.commissionPercent, 3, 4)
                      %endif
                      %if (@dtw_rpos("@@100", userDetailFields) > "0")
                          && editNum(document.Chg.unitCost, 8, 5)
                      %endif
                      %if (@dtw_rpos("@@230", userDetailFields) > "0")
                          && editNum(document.Chg.userNumeric1, 8, 5)
                      %endif
                      %if (@dtw_rpos("@@240", userDetailFields) > "0")
                          && editNum(document.Chg.userNumeric2, 8, 5)
                      %endif
                      %if (@dtw_rpos("@@250", userDetailFields) > "0")
                          && editNum(document.Chg.userNumeric3, 8, 5)
                      %endif
                      %if (@dtw_rpos("@@251", userDetailFields) > "0")
                          && editNum(document.Chg.userNumeric4, 8, 5)
                      %endif
                      %if (@dtw_rpos("@@252", userDetailFields) > "0")
                          && editNum(document.Chg.userNumeric5, 8, 5)
                      %endif
                     )
                     return true;
              }
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "NewWindowOpen.icl"
              %INCLUDE "SearchMenu.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "ORDERENTRYDETAIL")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (lineNumber == "000")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, " Select OEDTWK.*, coalesce(SPPART,O1IMDS) as O1IMDS ", stmtSQL)
                              @dtw_concat(stmtSQL, " From OEDTWK left join OESPWK on O1OCTL=SPOCTL and O1ORL#=SPORL# ", stmtSQL)
                              @dtw_concat(stmtSQL, " Where O1OCTL=$(orderControlNumber) and O1ORL#=$(lineNumber) and O1BLN#=$(releaseNumber)", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Order_Detail_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Order_Detail_Query (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "OrderEntryTabs.icl"

      %ROW {
          <div class="quickLinksTop">
              <a href="javascript:check(document.Chg)">$(acceptImageLrg)</a>
              %if (lineNumber > "000")
                  <a href="$(homeURL)$(cGIPath)$(d2wName)/DETAIL$(d2wVarBase)">$(selectResetImage)</a>
                  %if (V_O1QOPK == ".0000" && V_O1QSTC == ".0000" && V_O1QSTD != ".0000")
                      %if (V_O1MNCD != "X")
                          <a onClick="return confirmClose()" href="$(homeURL)$(cGIPath)$(d2wName)/STATUS$(d2wVarBase)&amp;status=X">$(lineCloseImage)</a>
                      %endif
                  %endif
              %endif
              %if (H1MNCD != "S")
                  <a href="$(homeURL)$(cGIPath)OrderEntryDetail.d2w/DETAIL$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;lineNumber=000&amp;releaseNumber=000" title="Add Line">$(addImageMed)</a>
                  %if (oe_sec_11 == "Y")
                      <a href="$(homeURL)$(cGIPath)OrderEntryDetail.d2w/DETAIL$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;lineNumber=000&amp;releaseNumber=000&amp;addNonStock=Y">$(nonStockImage)</a>
                  %endif
              %endif
              @dtw_assign(deleteAllowed, "")
              %if ((V_O1QOPK == ".0000" && V_O1QSTC == ".0000" && V_O1QSTD == ".0000") || H1MNCD == "A" || H1MNCD == "Z")
                  @dtw_assign(deleteAllowed, "Y")
                  %if (V_O1PO# > "0" && V_O1DSHP == "Y")
                      @dtw_assign(deleteAllowed, "")
                  %endif
              %endif
              %if (deleteAllowed == "Y")
                  <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)OrderEntryByItem.d2w/REMOVELINE$(d2wVarBase)">$(deleteImageMed)</a>
              %endif
          </div>
          %INCLUDE "RequiredField.icl"
          %INCLUDE "ErrorDisplay.icl"

          %if (errFound != "")
              @dtw_assign(focusField, "")
              @EdtVarErr(profileHandle, typeValue, edtVar)
              @ErrVarErr(profileHandle, typeError, errVar)
          %elif (lineNumber == "000")
              @dtw_assign(V_O1QORD, "1")
              @dtw_assign(V_O1RQDT, H1RQDT)
              @DateToCYMD(V_O1RQDT)
              @dtw_assign(V_O1WH, shipToWhs)
              %if (addNonStock == "Y")
                  @dtw_assign(V_O1BOAL, "N")
              %endif
          %endif

      <form class="formClass" METHOD=POST name="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(d2wVarBase)&amp;userDetailFields=@dtw_rurlescseq(userDetailFields)&amp;multShipToCustomer=@dtw_rurlescseq(multShipToCustomer)&amp;dropShip=@dtw_rurlescseq(dropShip)&amp;storeNbrReq=@dtw_rurlescseq(storeNbrReq)&amp;shipToWhs=@dtw_rurlescseq(shipToWhs)&amp;H1MNCD=@dtw_rurlescseq(H1MNCD)">
          <table $(contentTable)>
              <tr>
		   <td class="dsphdr">Line Number</td>
                  <td class="dspnmbr">
                      %if (lineNumber == "000")
                          @dtw_assign(addUpdDesc, "Add")
                          @dtw_assign(curLine, "999")
                      %else
                          @dtw_assign(addUpdDesc, "Update")
                          @dtw_assign(curLine, V_O1ORL#)
                      %endif
                      @RtvFldDesc("O1OCTL=$(orderControlNumber) and O1ORL#<$(curLine) and O1ORST='O' and O1BLN#=0 and O1MNCD<>'D' and O1MNCD<>'X'", "OEDTWK", "char(max(O1ORL#))", prevLine)
                      @RtvFldDesc("O1OCTL=$(orderControlNumber) and O1ORST='O' and O1BLN#=0 and O1MNCD<>'D' and O1MNCD<>'X'", "OEDTWK", "char(min(O1ORL#))", firstLine)
                      @RtvFldDesc("O1OCTL=$(orderControlNumber) and O1ORL#>$(curLine) and O1ORST='O' and O1BLN#=0 and O1MNCD<>'D' and O1MNCD<>'X'", "OEDTWK", "char(min(O1ORL#))", nextLine)
                      %if (lineNumber != "000")
                          @RtvFldDesc("O1OCTL=$(orderControlNumber) and O1ORST='O' and O1BLN#=0 and O1MNCD<>'D' and O1MNCD<>'X'", "OEDTWK", "char(max(O1ORL#))", lastLine)
                      %endif
                      %if (firstLine > "0" && firstLine != curLine && firstLine != prevLine)
                          @dtw_assign(previousImageBegTitle, "View First Line Number $(firstLine)")
                          <a href="$(homeURL)$(cGIPath)$(d2wName)/DETAIL$(d2wVarBase)&amp;prevNextLine=@dtw_rurlescseq(firstLine)">$(previousImageBegSml)</a>
                      %endif
                      %if (prevLine > "0")
                          @dtw_assign(previousImageTitle, "View Previous Line Number $(prevLine)")
                          <a href="$(homeURL)$(cGIPath)$(d2wName)/DETAIL$(d2wVarBase)&amp;prevNextLine=@dtw_rurlescseq(prevLine)">$(previousImageSml)</a>
                      %endif
                      %if (prevOrder > "0")
                          @dtw_assign(previousImageTitle, "View Previous Order Number $(prevOrder)")
                          <a href="$(homeURL)$(cGIPath)SelectOrder$(openHist).d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;salesmanNumber=@dtw_rurlescseq(salesmanNumber)&amp;salesmanName=@dtw_rurlescseq(salesmanName)&amp;orderNumber=@dtw_rurlescseq(prevOrder)&amp;orderSequence=@dtw_rurlescseq(prevNextSeq)&amp;noMenu=@dtw_rurlescseq(noMenu)">$(previousImageSml)</a>
                      %endif
                      %if (lineNumber == "000")
                          New Line
                      %else
                          $(V_O1ORL#)
                      %endif
                      %if (nextLine > "0")
                          @dtw_assign(nextImageTitle, "View Next Line Number $(nextLine)")
                          <a href="$(homeURL)$(cGIPath)$(d2wName)/DETAIL$(d2wVarBase)&amp;prevNextLine=@dtw_rurlescseq(nextLine)">$(nextImageSml)</a>
                      %endif
                      %if (lastLine > "0" && lastLine != curLine && nextLine != lastLine && lineNumber != "000")
                          @dtw_assign(nextImageEndTitle, "View Last Line Number $(lastLine)")
                          <a href="$(homeURL)$(cGIPath)$(d2wName)/DETAIL$(d2wVarBase)&amp;prevNextLine=@dtw_rurlescseq(lastLine)">$(nextImageEndSml)</a>
                      %endif
                      %if (confUpdate == "Y")
                          &nbsp; <span class="error">Confirm $(addUpdDesc) Of Line</span>
                      %endif
                  </td>
              </tr>

              @dtw_assign(recCnt, "1")
              %while(recCnt <= userDetailCount) {
                  @dtw_tb_getv(userDetailTable, recCnt, "1", V_UMFSEQ)
                  %while(@dtw_rlength(V_UMFSEQ) != "3") {@dtw_insert("0", V_UMFSEQ, V_UMFSEQ)%}

                      %if (V_UMFSEQ == "010")
                          %if (errFound != "")
                              @DecatErr_Field("@@wh@@", "warehouse")  @dtw_assign(Err_O1WH, fieldValue)
                              @Decat_Field("@@wh@@")                  @dtw_assign(V_O1WH, fieldValue)
                          %elif (focusField == "" && lineNumber == "000")
                              @dtw_assign(focusField, "warehouse")
                          %endif
                          @SetTextOvr(Err_O1WH)
                          <tr>
                              <td class="dsphdr"><span $(textOvr)>Warehouse Number</span></td>
                              @Default_Zero(V_O1WH)
                              @RtvFldDesc("WHWHS=$(V_O1WH)", "HDWHSM", "WHWHNM", warehouseName)
                              %if (lineNumber == "000")
                                  <td class="inputnmbr"><input name="warehouse" type="text" value="$(V_O1WH)" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=warehouse&amp;fldDesc=warehouseName" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input name="warehouseName" type="text" value="$(warehouseName)" size="35" disabled></td>
                              %else
                                  @Format_Code(V_O1WH, F_O1WH)
                                  <td class="dspalph">$(warehouseName) &nbsp; $(F_O1WH)</td>
                                  <td><input type="hidden" name="warehouse" value="$(V_O1WH)"></td>
                              %endif
                          </tr>
                          @DspErrMsg(Err_O1WH)

                      %elif (V_UMFSEQ == "020")
                          %if (errFound != "")
                              @DecatErr_Field("@@item", "itemNumber")  @dtw_assign(Err_O1ITEM, fieldValue)
                              @Decat_Field("@@item")                   @dtw_assign(V_O1ITEM, fieldValue)
                          %elif (focusField == "" && lineNumber == "000")
                              @dtw_assign(focusField, "itemNumber")
                          %endif
                          @SetTextOvr(Err_O1ITEM)
                          %if (V_O1ITEM != "" && V_O1OREC != "N")
                              @RtvFldDesc("IMITEM='$(V_O1ITEM)'", "HDIMST", "IMIMDS", itemDesc)
                          %endif
                          <tr>
     		               <td class="dsphdr"><span $(textOvr)>Item Number</span></td>
                              %if (lineNumber == "000")
                                  <td class="inputalph"><input type="text" name="itemNumber" value="$(V_O1ITEM)" size="15" maxlength="15"> $(reqFieldChar)
                                      %if (V_CIUVCT == "Y")
                                          <a href="$(homeURL)$(cGIPath)VendorCatalogSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=itemNumber&amp;fldDesc=itemDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="itemDesc" value="$(itemDesc)" size="35" disabled>
                                      %else
                                          <a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=itemNumber&amp;fldDesc=itemDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="itemDesc" value="$(itemDesc)" size="35" disabled>
                                      %endif
                                  </td>
                              %else
                                  @Format_Code(V_O1ITEM, F_O1ITEM)
                                  <td class="dspalph">$(V_O1IMDS) &nbsp; $(F_O1ITEM)</td>
                                  <td><input type="hidden" name="itemNumber" value="$(V_O1ITEM)" size="15" maxlength="15"></td>
                              %endif
                          </tr>
                          @DspErrMsg(Err_O1ITEM)

                      %elif (V_UMFSEQ == "030")
                          %if (errFound != "")
                              @DecatErr_Field("@@qord", "qtyOrdered")  @dtw_assign(Err_O1QORD, fieldValue)
                              @Decat_Field("@@qord")                   @dtw_assign(V_O1QORD, fieldValue)
                          %elif (focusField == "")
                              @dtw_assign(focusField, "qtyOrdered")
                          %endif
                          @SetTextOvr(Err_O1QORD)
                          <tr>
    		               <td class="dsphdr"><span $(textOvr)>Quantity Ordered</span></td>
                              %if ((V_O1PO# > "0" && V_O1DSHP == "Y") || (V_O1BOAL == "N" && V_O1QOPK > "0") || (H1MNCD == "S" && (V_O1BLKT == "Y" || V_O1BLN# > "0")))
                                  @Format_Nbr(V_O1QORD, F_O1QORD, "4", $(qtyEditCode), "Y", "", "")
                                  <td class="dspnmbr">
                                      $(F_O1QORD)
                                      <input type="hidden" name="qtyOrdered" value="$(V_O1QORD)">
                                  </td>
                              %else
                                  <td class="inputnmbr"><input type="text" name="qtyOrdered" value="$(V_O1QORD)" size="15" maxlength="15"> $(reqFieldChar)</td>
                              %endif
                          </tr>
                          @DspErrMsg(Err_O1QORD)

                      %elif (V_UMFSEQ == "040")
                          %if (errFound != "")
                              @DecatErr_Field("@@rqdt", "reqDate")  @dtw_assign(Err_O1RQDT, fieldValue)
                              @Decat_Field("@@rqdt")                @dtw_assign(V_O1RQDT, fieldValue)
                          %else
                              %if (focusField == "")
                                  @dtw_assign(focusField, "reqDate")
                              %endif
                              @DateInputFromCYMD(V_O1RQDT)
                          %endif
                          @SetTextOvr(Err_O1RQDT)
                          <tr>
                              <td class="dsphdr"><span $(textOvr)>Required Date</span></td>
                              <td class="inputnmbr"><input type="text" name="reqDate" value="$(V_O1RQDT)" size="6" maxlength="6">
                                  <a href="javascript:calWindow('reqDate');">$(calendarImage)</a>
                              </td>
                          </tr>
                          @DspErrMsg(Err_O1RQDT)

                      %elif (V_UMFSEQ == "050")
                          %if (errFound != "")
                              @DecatErr_Field("@@orec", "entryCode")  @dtw_assign(Err_O1OREC, fieldValue)
                              @Decat_Field("@@orec")                  @dtw_assign(V_O1OREC, fieldValue)
                          %elif (focusField == "")
                              @dtw_assign(focusField, "entryCode")
                          %endif
                          %if (oe_sec_11 == "N")
                              @dtw_assign(z, "1")
                              @dtw_tb_rows(entryCodeTable, rowCount)
                              %while(z <= rowCount) {
                                  %if (@dtw_tb_rgetv(entryCodeTable, z, "1") == "N")
                                      @dtw_tb_deleterow(entryCodeTable, z, "1")
                                      @dtw_subtract(rowCount, "1", rowCount)
                                  %else
                                      @dtw_add(z, "1", z)
                                  %endif
                              %}
                          %endif
                          @SetTextOvr(Err_O1OREC)
                          <tr>
    		               <td class="dsphdr"><span $(textOvr)>Entry Code</span></td>
                              %if (V_O1OREC == "N" || addNonStock == "Y")
    		                   <td class="dspalph">Non-Stock</td>
                                  <td><input type="hidden" name="entryCode" value="N"></td>
                              %elif ((V_O1PO# > "0" && V_O1DSHP == "Y") || lineNumber < "000" || H1MNCD == "S")
                                  @RtvFldDesc("FLTYPE='OEENTCODE' AND FLVALU='$(V_O1OREC)'", "SYFLAG", "FLDESC", fieldDesc)
    		                   <td class="dspalph">$(fieldDesc)</td>
                                  <td><input type="hidden" name="entryCode" value="$(V_O1OREC)" size="1" maxlength="1"></td>
                              %else
                                  %if (V_O1OREC == "")
                                      @dtw_assign(V_O1OREC, "S")
                                  %endif
                                  @dtw_tb_rows(entryCodeTable, maxRows)
                                  @dtw_assign(x, "1")
