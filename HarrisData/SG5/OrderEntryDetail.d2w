                      %elif (V_UMFSEQ == "250" && userDtlNumDesc3 > " ")
                          %if (errFound != "")
                              @DecatErr_Field("@@udn3", "userNumeric3")  @dtw_assign(Err_O1UDN3, fieldValue)
                              @Decat_Field("@@udn3")                     @dtw_assign(V_O1UDN3, fieldValue)
                          %elif (focusField == "")
                              @dtw_assign(focusField, "userNumeric3")
                          %endif
                          @SetTextOvr(Err_O1UDN3)
                          <tr>
        		       <td class="dsphdr"><span $(textOvr)>$(userDtlNumDesc3)</span></td>
                              <td class="inputnmbr"><input type="text" name="userNumeric3" value="$(V_O1UDN3)" size="22" maxlength="15"></td>
                          </tr>
                          @DspErrMsg(Err_O1UDN3)

                      %elif (V_UMFSEQ == "251" && userDtlNumDesc4 > " ")
                          %if (errFound != "")
                              @DecatErr_Field("@@udn4", "userNumeric4")  @dtw_assign(Err_O1UDN4, fieldValue)
                              @Decat_Field("@@udn4")                     @dtw_assign(V_O1UDN4, fieldValue)
                          %elif (focusField == "")
                              @dtw_assign(focusField, "userNumeric4")
                          %endif
                          @SetTextOvr(Err_O1UDN4)
                          <tr>
        		       <td class="dsphdr"><span $(textOvr)>$(userDtlNumDesc4)</span></td>
                              <td class="inputnmbr"><input type="text" name="userNumeric4" value="$(V_O1UDN4)" size="22" maxlength="15"></td>
                          </tr>
                          @DspErrMsg(Err_O1UDN4)

                      %elif (V_UMFSEQ == "252" && userDtlNumDesc5 > " ")
                          %if (errFound != "")
                              @DecatErr_Field("@@udn5", "userNumeric5")  @dtw_assign(Err_O1UDN5, fieldValue)
                              @Decat_Field("@@udn5")                     @dtw_assign(V_O1UDN5, fieldValue)
                          %elif (focusField == "")
                              @dtw_assign(focusField, "userNumeric5")
                          %endif
                          @SetTextOvr(Err_O1UDN5)
                          <tr>
        		       <td class="dsphdr"><span $(textOvr)>$(userDtlNumDesc5)</span></td>
                              <td class="inputnmbr"><input type="text" name="userNumeric5" value="$(V_O1UDN5)" size="22" maxlength="15"></td>
                          </tr>
                          @DspErrMsg(Err_O1UDN5)

                      %elif (V_UMFSEQ == "260")
                          %if (errFound != "")
                              @DecatErr_Field("@@pgrp", "prodGroup")  @dtw_assign(Err_O1PGRP, fieldValue)
                              @Decat_Field("@@pgrp")                  @dtw_assign(V_O1PGRP, fieldValue)
                          %elif (focusField == "")
                              @dtw_assign(focusField, "prodGroup")
                          %endif
                          @SetTextOvr(Err_O1PGRP)
                          <tr>
                              @RtvFldDesc("PGPGRP='$(V_O1PGRP)'", "HDPRGM", "PGDESC", fieldDesc)
        		       <td class="dsphdr"><span $(textOvr)>Product Group</span></td>
                              <td class="inputalph"><input name="prodGroup" type="text" value="$(V_O1PGRP)" size="7" maxlength="4"><a href="$(homeURL)$(cGIPath)productgroupsearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=prodGroup&amp;fldDesc=prodGroupDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="prodGroupDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                          </tr>
                          @DspErrMsg(Err_O1PGRP)

                      %elif (V_UMFSEQ == "270")
                          %if (errFound != "")
                              @DecatErr_Field("@@stor", "store")      @dtw_assign(Err_O1STOR, fieldValue)
                              @Decat_Field("@@stor")                  @dtw_assign(V_O1STOR, fieldValue)
                          %elif (focusField == "")
                              @dtw_assign(focusField, "store")
                          %endif

                          @RtvFldDesc("COSHTO=$(H1SHTO) and COSTOR='$(V_O1STOR)'", "HDCSTR", "CONAME", fieldDesc)
                          @SetTextOvr(Err_O1STOR)
                          <tr><td class="dsphdr"><span $(textOvr)>Store</span></td>
                              <td class="inputalph"><input name="store" type="text" value="$(V_O1STOR)" size="20" maxlength="20"><a href="$(homeURL)$(cGIPath)CustomerStoreSearch.d2w/REPORT$(d2wVarBase)&amp;docName=Chg&amp;fldName=store&amp;fldDesc=storeName" onclick="$(searchWinVar)"> $(storeReq) $(searchImage) </a><input name="storeName" type="text" value="$(fieldDesc)" size="35" disabled></td>
                          </tr>
                          @DspErrMsg(Err_O1STOR)
                      %endif
                  @dtw_add(recCnt, "1", recCnt)
              %}

              %if (V_O1BLKT == "N" && multShipToCustomer>"1" && dropShip != "Y")
                  %if (errFound != "")
                      @DecatErr_Field("@@shto", "shipToCustomer")  @dtw_assign(Err_O1SHTO, fieldValue)
                      @Decat_Field("@@shto")                       @dtw_assign(V_O1SHTO, fieldValue)
                  %elif (focusField == "")
                      @dtw_assign(focusField, "shipToCustomer")
                  %endif
                  @SetTextOvr(Err_O1SHTO)
                  @RtvFldDesc("CMCUST=$(V_O1SHTO)", "HDCUST", "CMCNA1", fieldDesc)
                  <tr><td class="dsphdr"><span $(textOvr)>Ship-To</span></td>
                      <td class="inputnmbr"><input name="shipToCustomer" type="text" value="$(V_O1SHTO)" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;forCustomer=@dtw_rurlescseq(H1BLTO)&amp;docName=Chg&amp;fldName=shipToCustomer&amp;fldDesc=shipToName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="shipToName" value="$(fieldDesc)" size="35" type="text" disabled></td>
                  </tr>
                  @DspErrMsg(Err_O1SHTO)

                  %if (errFound != "")
                      @DecatErr_Field("@@svsv", "shipVia")  @dtw_assign(Err_O1SVSV, fieldValue)
                      @Decat_Field("@@svsv")                @dtw_assign(V_O1SVSV, fieldValue)
                  %elif (focusField == "")
                      @dtw_assign(focusField, "shipVia")
                  %endif
                  @SetTextOvr(Err_O1SVSV)
                  @RtvFldDesc("SVSVSV='$(V_O1SVSV)'", "HDSHPV", "SVSVDS", fieldDesc)
                  <tr><td class="dsphdr"><span $(textOvr)>Ship Via</span></td>
                      <td class="inputalph"><input name="shipVia" type="text" value="$(V_O1SVSV)" size="7" maxlength="2"><a href="$(homeURL)$(phpPath)ShipViaSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=shipVia&amp;fldDesc=shipViaDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="shipViaDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_O1SVSV)
              %endif
              	
              %if (V_HDMPRL > "0" && (lineNumber == "000" || V_O1MNCD == "A"))
                  %if (V_O1ABDM == "Y")
                      @dtw_assign(abnormalChecked, "CHECKED")
                  %else
                      @dtw_assign(abnormalChecked, "")
                  %endif
                  <tr><td class="dsphdr"><span $(textOvr)>Abnormal Demand</span></td>
                      <td class="inputalph"><input name="abnormalDemand" type="checkbox" $(abnormalChecked) VALUE='Y'></td>
                  </tr>
              %endif

              <tr><td class="inputalph"><input type="hidden" name="octl" value="$(orderControlNumber)"></td></tr>
          %}
          </table>
          %if (focusField != "")
              <script type="text/javascript">
                  document.Chg.$(focusField).focus();
              </script>
          %endif
      </form>
      @dtw_assign(errFound, "")
      <a href="javascript:check(document.Chg)">$(acceptImageLrg)</a>
      %if (lineNumber > "000")
          <a href="$(homeURL)$(cGIPath)$(d2wName)/DETAIL$(d2wVarBase)">$(selectResetImage)</a>
      %endif
      %if (H1MNCD != "S")
          <a href="$(homeURL)$(cGIPath)OrderEntryDetail.d2w/DETAIL$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;lineNumber=000&amp;releaseNumber=000" title="Add Line">$(addImageMed)</a>
          %if (oe_sec_11 == "Y")
              <a href="$(homeURL)$(cGIPath)OrderEntryDetail.d2w/DETAIL$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;lineNumber=000&amp;releaseNumber=000&amp;addNonStock=Y">$(nonStockImage)</a>
          %endif
      %endif
      %if (deleteAllowed == "Y")
          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)OrderEntryByItem.d2w/REMOVELINE$(d2wVarBase)">$(deleteImageMed)</a>
      %endif
      %INCLUDE "EndTabs.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
      @dtw_GetCookie("work_cookie", haveKit)
      @dtw_SetCookie("work_cookie", "", "path=/")
      %if (haveKit == "K")
          <meta http-equiv="refresh" content="0; URL=javascript:NewWindow('$(homeURL)$(cGIPath)OrderEntryKitOptionError.d2w/DISPLAY$(d2wVarBase)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;reliefCode=D&amp;addToOrder=C&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))','orderEntry_win','$(orderEntryWinPctH)','$(orderEntryWinPctW)','$(orderEntryWinSB)','$(orderEntryWinRZ)','$(orderEntryWinTB)','$(orderEntryWinMB)','$(orderEntryWinST)');">
      %elif (haveKit == "Q")
          <meta http-equiv="refresh" content="0; URL=javascript:NewWindow('$(homeURL)$(cGIPath)OrderEntryKitOptionError.d2w/DISPLAY$(d2wVarBase)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;reliefCode=E&amp;addToOrder=C&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))','orderEntry_win','$(orderEntryWinPctH)','$(orderEntryWinPctW)','$(orderEntryWinSB)','$(orderEntryWinRZ)','$(orderEntryWinTB)','$(orderEntryWinMB)','$(orderEntryWinST)');">
      %elif (haveKit == "F")
          <meta http-equiv="refresh" content="0; URL=javascript:NewWindow('$(homeURL)$(cGIPath)OrderEntryFeatureOptionError.d2w/DISPLAY$(d2wVarBase)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;reliefCode=D&amp;addToOrder=C&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))','orderEntry_win','$(orderEntryWinPctH)','$(orderEntryWinPctW)','$(orderEntryWinSB)','$(orderEntryWinRZ)','$(orderEntryWinTB)','$(orderEntryWinMB)','$(orderEntryWinST)');">
      %elif (haveKit == "B")
          <meta http-equiv="refresh" content="0; URL=javascript:NewWindow('$(homeURL)$(cGIPath)OrderEntryBlanketLine.d2w/DISPLAY$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))','orderEntry_win','$(orderEntryWinPctH)','$(orderEntryWinPctW)','$(orderEntryWinSB)','$(orderEntryWinRZ)','$(orderEntryWinTB)','$(orderEntryWinMB)','$(orderEntryWinST)');">
      %endif
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     qtyChg,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HOEUDD_W.PGM %}
%}

%HTML(DETAIL) {
  %INCLUDE "setLibraryList.icl"
  %if (prevNextLine > "0")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;lineNumber=@dtw_rurlescseq(prevNextLine)&amp;releaseNumber=000">
  %else
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)">
  %endif
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @EntryCode_Query(profileHandle, dataBaseID, "OEENTCODE ", entryCodeTable)
  @Set_SQL(stmtSQL)
%}

%HTML(UPDATE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(itemNumber)
  @dtw_mUPPERCASE(stockingUM)
  @dtw_mUPPERCASE(pricingUM)
  @dtw_mUPPERCASE(prodClass)
  @dtw_mUPPERCASE(prodGroup)
  @dtw_mUPPERCASE(allowBackorders)
  @dtw_mUPPERCASE(taxable)
  %if (generatePO == "") @dtw_assign(generatePO, "N") %endif
  @dtw_mUPPERCASE(generatePO)
  @dtw_mUPPERCASE(shipVia)
  @dtw_mUPPERCASE(store)
  @dtw_mUPPERCASE(userAlpha1)
  @dtw_mUPPERCASE(userAlpha2)
  @dtw_mUPPERCASE(userAlpha3)
  @dtw_mUPPERCASE(userAlpha4)
  @dtw_mUPPERCASE(userAlpha5)
  @dtw_mUPPERCASE(userAlpha6)
  @dtw_mUPPERCASE(userAlpha7)
  @dtw_mUPPERCASE(userAlpha8)
  @dtw_mUPPERCASE(userAlpha9)
  @dtw_mUPPERCASE(userAlpha0)

  @dtw_assign(qtyOrdered,@dtw_rstrip(qtyOrdered))
  @dtw_assign(reqDate,@dtw_rstrip(reqDate))
  @dtw_assign(price,@dtw_rstrip(price))
  @dtw_assign(shipToCustomer,@dtw_rstrip(shipToCustomer))
  @dtw_assign(discountPercent,@dtw_rstrip(discountPercent))
  @dtw_assign(commissionPercent,@dtw_rstrip(commissionPercent))
  @dtw_assign(unitCost,@dtw_rstrip(unitCost))
  @dtw_assign(userNumeric1,@dtw_rstrip(userNumeric1))
  @dtw_assign(userNumeric2,@dtw_rstrip(userNumeric2))
  @dtw_assign(userNumeric3,@dtw_rstrip(userNumeric3))
  @dtw_assign(userNumeric4,@dtw_rstrip(userNumeric4))
  @dtw_assign(userNumeric5,@dtw_rstrip(userNumeric5))

  %if (entryCode == "N")
      @dtw_assign(stockingUM, pricingUM)
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@octl", orderControlNumber)
  @Concat_Field("@@orl#", lineNumber)
  @Concat_Field("@@bln#", releaseNumber)
  @Concat_Field("@@strq", storeNbrReq)
  %if (@dtw_rpos("@@040", userDetailFields) > "0")
      @Concat_Field("@@rqdt", reqDate)
  %endif
  %if (@dtw_rpos("@@090", userDetailFields) > "0")
      @Concat_Field("@@cmpc", commissionPercent)
  %endif
  %if (@dtw_rpos("@@070", userDetailFields) > "0")
      @Concat_Field("@@lnds", discountPercent)
  %endif
  %if (@dtw_rpos("@@050", userDetailFields) > "0")
      @Concat_Field("@@orec", entryCode)
  %endif
  %if (@dtw_rpos("@@020", userDetailFields) > "0")
      @Concat_Field("@@item", itemNumber)
  %endif
  %if (@dtw_rpos("@@080", userDetailFields) > "0")
      @Concat_Field("@@imds", itemDescription)
  %endif
  %if (@dtw_rpos("@@130", userDetailFields) > "0")
      @Concat_Field("@@pcls", prodClass)
  %endif
  %if (@dtw_rpos("@@260", userDetailFields) > "0")
      @Concat_Field("@@pgrp", prodGroup)
  %endif
  %if (@dtw_rpos("@@270", userDetailFields) > "0")
      @Concat_Field("@@stor", store)
  %endif
  %if (@dtw_rpos("@@030", userDetailFields) > "0")
      @Concat_Field("@@qord", qtyOrdered)
  %endif
  %if (@dtw_rpos("@@140", userDetailFields) > "0")
      %if (allowBackorders == "")
          @dtw_assign(allowBackorders, " ")
      %endif
      @Concat_Field("@@boal", allowBackorders)
  %endif
  %if (@dtw_rpos("@@010", userDetailFields) > "0")
      @Concat_Field("@@wh@@", warehouse)
  %elif (lineNumber == "000" && shipToWhs > "0")
      @Concat_Field("@@wh@@", shipToWhs)
  %endif
  %if (@dtw_rpos("@@180", userDetailFields) > "0")
      @Concat_Field("@@orcs", custItemNumber)
  %endif
  %if (@dtw_rpos("@@120", userDetailFields) > "0")
      @Concat_Field("@@prum", pricingUM)
  %endif
  %if (@dtw_rpos("@@150", userDetailFields) > "0")
      @Concat_Field("@@taxc", taxable)
  %endif
  %if (@dtw_rpos("@@060", userDetailFields) > "0")
      @Concat_Field("@@slpr", price)
  %endif
  %if (@dtw_rpos("@@100", userDetailFields) > "0")
      @Concat_Field("@@cost", unitCost)
  %endif
  %if (@dtw_rpos("@@110", userDetailFields) > "0")
      @Concat_Field("@@stum", stockingUM)
  %endif
  %if (@dtw_rpos("@@160", userDetailFields) > "0")
      @Concat_Field("@@gnpo", generatePO)
  %endif
  %if (multShipToCustomer>"1" && dropShip != "Y")
      @Concat_Field("@@shto", shipToCustomer)
      @Concat_Field("@@svsv", shipVia)
  %endif
  %if (@dtw_rpos("@@200", userDetailFields) > "0")
      @Concat_Field("@@uda1", userAlpha1)
  %endif
  %if (@dtw_rpos("@@210", userDetailFields) > "0")
      @Concat_Field("@@uda2", userAlpha2)
  %endif
  %if (@dtw_rpos("@@220", userDetailFields) > "0")
      @Concat_Field("@@uda3", userAlpha3)
  %endif
  %if (@dtw_rpos("@@221", userDetailFields) > "0")
      @Concat_Field("@@uda4", userAlpha4)
  %endif
  %if (@dtw_rpos("@@222", userDetailFields) > "0")
      @Concat_Field("@@uda5", userAlpha5)
  %endif
  %if (@dtw_rpos("@@223", userDetailFields) > "0")
      @Concat_Field("@@uda6", userAlpha6)
  %endif
  %if (@dtw_rpos("@@224", userDetailFields) > "0")
      @Concat_Field("@@uda7", userAlpha7)
  %endif
  %if (@dtw_rpos("@@225", userDetailFields) > "0")
      @Concat_Field("@@uda8", userAlpha8)
  %endif
  %if (@dtw_rpos("@@226", userDetailFields) > "0")
      @Concat_Field("@@uda9", userAlpha9)
  %endif
  %if (@dtw_rpos("@@227", userDetailFields) > "0")
      @Concat_Field("@@uda0", userAlpha0)
  %endif
  %if (@dtw_rpos("@@230", userDetailFields) > "0")
      @Concat_Field("@@udn1", userNumeric1)
  %endif
  %if (@dtw_rpos("@@240", userDetailFields) > "0")
      @Concat_Field("@@udn2", userNumeric2)
  %endif
  %if (@dtw_rpos("@@250", userDetailFields) > "0")
      @Concat_Field("@@udn3", userNumeric3)
  %endif
  %if (@dtw_rpos("@@251", userDetailFields) > "0")
      @Concat_Field("@@udn4", userNumeric4)
  %endif
  %if (@dtw_rpos("@@252", userDetailFields) > "0")
      @Concat_Field("@@udn5", userNumeric5)
  %endif
  %if (V_HDMPRL > "0")
      @Concat_Field("@@abdm", abnormalDemand)
  %endif
  @Concat_Field("@@clln", closeLine)
  %if (entryCode != "N")
      @Concat_Field("@@vcat", V_CIUVCT)
  %endif
  @Concat_Field("@@pcfc", productCfgFormat)
  @Concat_Field("@@ucat", productCfgOptionDesc)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, qtyChg, errFound, edtVar, errVar)
  		
  %if (errFound == "")
      @Decat_Field("@@mfgr") @dtw_assign(mfgReview, fieldValue)
      @Decat_Field("@@hkit") @dtw_assign(haveKit,   fieldValue)
      %if (haveKit == "" && qtyChg != "")
          @dtw_assign(haveKit, qtyChg)
      %endif
      @dtw_SetCookie("work_cookie", "$(haveKit)", "path=/")
      @DTW_ASSIGN(updateTotal, "Y")
      @Update_Misc_Charges (profileHandle, dataBaseID, orderControlNumber, freightCharge, specialCharge, updateTotal)
      %if (maintCode == "S")
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)ordershippingreview.d2w/DISPLAY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)">
      %else
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)&amp;confUpdate=Y">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}

%HTML(STATUS) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Update OEDTWK Set O1MNCD='$(status)' ", stmtSQL)
  @dtw_concat(stmtSQL, " Where O1OCTL=$(orderControlNumber) and O1ORL#=$(lineNumber) @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)
  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)OrderEntryByItem.d2w/ENTRY$(d2wVarBase)">
%}
