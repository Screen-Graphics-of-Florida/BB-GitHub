%INCLUDE "$(baseVar)"
%INCLUDE "EdtVar.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Copy Line"
  d2wName                 = "OrderEntryCopyLine.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;lineNumber=@dtw_rurlescseq(lineNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;itemDescription=@dtw_rurlescseq(itemDescription)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  <html>
      <head>
          %INCLUDE "headcmt.icl"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.copies.value =="")
                     {alert("$(reqFieldError)"); return false;}
                  testfield = document.Chg.copies.value;
                  var negPos=testfield.indexOf('-');
                  if (negPos>=0) {alert ("Negative is not allowed.  Please try again."); return false;}
                  var min = parseInt(document.Chg.copies.value, 3);
                  if (min < 1) {alert("Copies cannot be zero"); return false;}
                  return true;
              }
         </script>
      </head>
      <body $(bodyTagAttr)>
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  <td class="toolbar">
                      <a href="javascript:check(document.Chg)">$(selectAcceptImage)</a>
                      %INCLUDE "CloseWindow.icl"
                  </td>
              </tr>
          </table>
          <table $(contentTable)>
              @RtvFldDesc("WHWHS=$(warehouseNumber)", "HDWHSM", "WHWHNM", warehouseName)
              @Format_Header("Item", $(itemDescription), $(itemNumber))
              @Format_Header("Warehouse", $(warehouseName), $(warehouseNumber))
          </table>
          $(hrTagAttr)
          %INCLUDE "RequiredField.icl"
              <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)">
                  <table $(contentTable)>
                      <tr><td class="dsphdr">Copies</td>
                          <td class="inputnmbr"><input type="text" name="copies" value="1" size="3" maxlength="3"> $(reqFieldChar)</td>
                      </tr>
                  </table>
              </form>
          $(hrTagAttr)
          <a href="javascript:check(document.Chg)">$(selectAcceptImage)</a>
          %INCLUDE "CloseWindow.icl"
      </body>
  </html>
%}

%FUNCTION(DTW_directcall) Validate_Data (INOUT CHAR(32000)  edtVar)

{%EXEC {HOEOEC_L.PGM %}
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(toOrderType)

  @dtw_assign(edtVar, "")
  @Concat_Field("@@octl", orderControlNumber)
  @Concat_Field("@@line", lineNumber)
  @Concat_Field("@@copy", copies)
  @Concat_Field("@@usmp", V_CIUSMP)

  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(edtVar)
  @DTW_ASSIGN(updateTotal, "Y")
  @Update_Misc_Charges (profileHandle, dataBaseID, orderControlNumber, freightCharge, specialCharge, updateTotal)

  <script TYPE="text/javascript">
      opener.location.href=opener.location.href;
      window.close()
  </script>
%}
