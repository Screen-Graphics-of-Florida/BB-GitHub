%INCLUDE "$(baseVar)"
%INCLUDE "ARControl$(dataBaseID).icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Accounts Receivable Status"
  d2wName                 = "AccountReceivableSelect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
  quickLinkByUser         = "Y"
  allCustomers            = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          @dtw_assign(title, page_title)
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                       @dtw_assign(pageID, "ACCOUNTRECEIVESELECT")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
%{ QuickLink Table %}   %INCLUDE "QuickLinkTable.icl"
	
%{ QuickLink By User %} %INCLUDE "QuickLinkByUser.icl"

%{ Heading %}
                      @dtw_assign(RPT_MAX_ROWS, "99")
                      @dtw_assign(dspMaxRows, "10")
                      %INCLUDE "AddRecordSQL.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      @AR_Select_Header(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Begin %}     %INCLUDE "QuickLinkBegLoop.icl"

%{ Demographics %}
                          %if (quicklinkRef == "demographics")
                              %INCLUDE "QuickLinkClear.icl"
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                              @dtw_concat(fileSQL, " ARCTRL ", fileSQL)
                              @dtw_concat(selectSQL, "RRN(ARCTRL)=1 ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %INCLUDE "stmtSQLEnd.icl"
                              @AR_Select_Demographics(profileHandle, dataBaseID, stmtSQL)

%{ New Customer Defaults %}
                          %elif (quicklinkRef == "newcustomerdefault")
                              %INCLUDE "QuickLinkClear.icl"
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                              @dtw_concat(fileSQL, " ARCTRL ", fileSQL)
                              @dtw_concat(selectSQL, "RRN(ARCTRL)=1 ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %INCLUDE "stmtSQLEnd.icl"
                              @AR_Select_NewCustomerDefault(profileHandle, dataBaseID, stmtSQL)

%{ User Defined Fields %}
                          %elif (quicklinkRef == "userdefined")
                              %INCLUDE "QuickLinkClear.icl"
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                              @dtw_concat(fileSQL, " ARCTRL ", fileSQL)
                              @dtw_concat(selectSQL, "RRN(ARCTRL)=1 ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %INCLUDE "stmtSQLEnd.icl"
                              @AR_Select_UserDefined(profileHandle, dataBaseID, stmtSQL)

%{ Open Invoices %}
                          %elif (quicklinkRef == "openinvoice")
                              %INCLUDE "QuickLinkClear.icl"
                              %INCLUDE "stmtSQLClear.icl"
                              %if (V_HDMCRL>"0")
                                  @dtw_concat(distinctSQL, "IVLOC||IVARAC||IVARSB||IVCURT", distinctSQL)
                                  @dtw_concat(stmtSQL, " Select IVLOC, IVARAC, IVARSB, IVCURT, ", stmtSQL)
                              %else
                                  @dtw_concat(distinctSQL, "IVLOC||IVARAC||IVARSB", distinctSQL)
                                  @dtw_concat(stmtSQL, " Select IVLOC, IVARAC, IVARSB,  ", stmtSQL)
                              %endif
                              @dtw_concat(stmtSQL, " SUM(IVIVAM-IVNPOS) as IVIVAM, ", stmtSQL)
                              @dtw_concat(stmtSQL, " SUM(IVDAMT-IVONPO) as IVDBAL, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(max(LOCO#),' ') as LOCO#, coalesce(max(LOFAC#),' ') as LOFAC#, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(max(LOLNA1),CHAR(IVLOC)) as LOLNA1, coalesce(upper(max(LOLNA1)),CHAR(IVLOC)) as LOLNA1U, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(max(CFCFNM),' ') as CFCFNM, coalesce(max(CFCFNMU),' ') as CFCFNMU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(max(CHCHDS),' ') as CHCHDS, coalesce(max(CHCHDSU),' ') as CHCHDSU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(max(CYDESC),' ') as CYDESC, coalesce(upper(max(CYDESC)),' ') as CYDESCU, ", stmtSQL)
                              %if (V_HDMCRL>"0")
                                  @dtw_concat(stmtSQL, " coalesce((Select Count(*) from HDINVC b Where b.IVLOC=a.IVLOC and b.IVARAC=a.IVARAC and b.IVARSB=b.IVARSB and b.IVCURT=a.IVCURT and b.IVIVAM-b.IVNPOS<>0 and b.IVIVCD<>'U') ,0) as INV_COUNT ", stmtSQL)
                              %else
                                  @dtw_concat(stmtSQL, " coalesce((Select Count(*) from HDINVC b Where b.IVLOC=a.IVLOC and b.IVARAC=a.IVARAC and b.IVARSB=b.IVARSB and b.IVIVAM-b.IVNPOS<>0 and b.IVIVCD<>'U') ,0) as INV_COUNT ", stmtSQL)
                              %endif
                              @dtw_concat(fileSQL, " HDINVC a ", fileSQL)
                              @dtw_concat(fileSQL, " left join HDLCTN on LOLOC#=IVLOC ", fileSQL)
                              @dtw_concat(fileSQL, " left join HDCFAC on CFCO#=LOCO# and CFFAC#=LOFAC# ", fileSQL)
                              @dtw_concat(fileSQL, " left join HDCHRT on CHACCT=IVARAC and CHSUB=IVARSB ", fileSQL)
                              @dtw_concat(fileSQL, " left join HDCTYP on CYTYPE=IVCURT ", fileSQL)
                              @dtw_concat(selectSQL, " IVIVAM-IVNPOS<>0 ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %if (V_HDMCRL>"0")
                                  @dtw_concat(stmtSQL, " Group By IVLOC, IVARAC, IVARSB, IVCURT ", stmtSQL)
                                  @dtw_concat(stmtSQL, " Order By LOLNA1, IVLOC, IVARAC, IVARSB, IVCURT ", stmtSQL)
                              %else
                                  @dtw_concat(stmtSQL, " Group By IVLOC, IVARAC, IVARSB ", stmtSQL)
                                  @dtw_concat(stmtSQL, " Order By LOLNA1, IVLOC, IVARAC, IVARSB ", stmtSQL)
                              %endif
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @AR_Select_OpenInvoice(profileHandle, dataBaseID, stmtSQL)

%{ Cash Payment %}
                          %elif (quicklinkRef == "cashapplication")
                              %INCLUDE "QuickLinkClear.icl"
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(distinctSQL, "CHAR(YPBANK)||CHAR(YPBDAT)||CHAR(YPBCH) ", distinctSQL)
                              @dtw_concat(stmtSQL, " Select YPBANK, YPBDAT, YPBCH, SUM(YPAMT) as YPAMT ", stmtSQL)
                              @dtw_concat(stmtSQL, "       ,SUM(YPCAMT) as YPCAMT ", stmtSQL)
                              @dtw_concat(stmtSQL, "       ,count(*) as PMT_COUNT ", stmtSQL)
                              @dtw_concat(stmtSQL, " ,Max(BKBKNM) as BKBKNM, upper(Max(BKBKNM)) as BKBKNMU,Max(BKBACC) as BKBACC, Max(BKCO) as BKCO, Max(BKFAC) as BKFAC, Max(BKACCT) as BKACCT, Max(BKSUB) as BKSUB, Max(BKCURT) as BKCURT,  ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(max(CHCHDS),' ') as CHCHDS, coalesce(max(CHCHDSU),' ') as CHCHDSU, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(max(CYDESC),' ') as CYDESC, coalesce(upper(max(CYDESC)),' ') as CYDESCU ", stmtSQL)
                              @dtw_concat(fileSQL, " ARYPTD ", fileSQL)
                              @dtw_concat(fileSQL, " inner join HDBANK on BKBANK=YPBANK ", fileSQL)
                              @dtw_concat(fileSQL, " Left Join ARPYCD on PYPYCD=YPPYCD ", fileSQL)
                              @dtw_concat(fileSQL, " left join HDCHRT on CHACCT=BKACCT and CHSUB=BKSUB ", fileSQL)
                              @dtw_concat(fileSQL, " left join HDCTYP on CYTYPE=BKCURT ", fileSQL)
                              @dtw_concat(selectSQL, " YPAMT<>0 ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              @dtw_concat(stmtSQL, " Group By YPBANK, YPBDAT, YPBCH ", stmtSQL)
                              @dtw_concat(stmtSQL, " Order By YPBDAT DESC, YPBCH, BKBKNM, YPBANK ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @AR_Select_CashApplication(profileHandle, dataBaseID, stmtSQL)

%{ Aging %}
                          %elif (quicklinkRef == "aging")
                              @LoadARAging(profileHandle, allCustomers)
                              %INCLUDE "QuickLinkClear.icl"
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(distinctSQL, "AIBCKT ", distinctSQL)
                              @dtw_concat(stmtSQL, " Select AIBCKT, sum(AIIVAM) as IVAMT, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce((Select Count(*) from ARAIWK b Where b.AIXHND='$(profileHandle)' and b.AIBCKT=a.AIBCKT and b.AIIVCD<>'U') ,0) as INV_COUNT ", stmtSQL)
                              @dtw_concat(fileSQL, " ARAIWK a ", fileSQL)
                              @dtw_concat(selectSQL, "AIXHND='$(profileHandle)'", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              @dtw_concat(stmtSQL, " Group By AIBCKT ", stmtSQL)
                              @dtw_concat(stmtSQL, " Order By AIBCKT ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @AR_Select_Aging(profileHandle, dataBaseID, stmtSQL)
%{ Unposted Sub Ledger %}
                          %elif (quicklinkRef == "unpostedsubledger")
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Delete From  GLUSFDWK ", stmtSQL)
                              @dtw_concat(stmtSQL, " Where WFXHND='$(profileHandle)'  ", stmtSQL)
                              @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
                              @SQL_Update(stmtSQL, status)

                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Insert Into GLUSFDWK (WFXHND,            WFFILE,  WFJRNL,WFPER#,WFDATE,WFTTYP,WFFCUR,WFDESC,               WFUAMT,    WFDESCU) ", stmtSQL)
                              @dtw_concat(stmtSQL, " Select                '$(profileHandle)','HDARTR',JRJRNL,JRPER#,JRDATE,JRTTYP,JRFCUR,'Accounts Receivable',SUM(JRAMT),Upper('Accounts Receivable')  ", stmtSQL)
                              @dtw_concat(stmtSQL, " From HDARTR   ", stmtSQL)
                              @dtw_concat(stmtSQL, " Where JRAMT>0  ", stmtSQL)
                              @dtw_concat(stmtSQL, " GROUP BY JRJRNL,JRPER#,JRDATE,JRTTYP,JRFCUR ", stmtSQL)
                              @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
                              @SQL_Update(stmtSQL, status)

                              %INCLUDE "QuickLinkClear.icl"
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select GLUSFDWK.*, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(FLDESC,' ') as transFLDESC, upper(coalesce(FLDESC,' ')) as transFLDESCU ", stmtSQL)
                              @dtw_concat(fileSQL, " GLUSFDWK ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYFLAG on FLTYPE='GLTRANTYP' and FLVALU=WFTTYP ", fileSQL)
                              @dtw_concat(selectSQL, "WFXHND='$(profileHandle)' ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              @dtw_concat(stmtSQL, " Order By WFDESC,WFFILE,WFPER# ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @AR_Select_UnpostedSubLedger(profileHandle, dataBaseID, stmtSQL)
                          %endif

%{ Quicklink End %}       %INCLUDE "QuickLinkEndLoop.icl"

                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) AR_Select_Header (IN  CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                      <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                  %endif
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>
      <table $(contentTable)>
          %ROW{
          %}
      </table>

      $(hrTagAttr)
      %INCLUDE "QuickLinkDisplay.icl"
  %}
%}

%FUNCTION(dtw_sql) AR_Select_Demographics (IN  CHAR(64)    profileHandle,
                                               CHAR(2)     dataBaseID,
                                               CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      <a name="demographics"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      %ROW{
          <table $(contentTable)>
              @PeriodFromCYP(V_CRDPER)
              <tr><td class="dsphdr">A/R Distribution Period</td>
                  <td class="dspnmbr">$(V_CRDPER)</td>
              </tr>

              @Format_Acct("$(V_CRARAC)", "$(V_CRARSB)", "", F_AcctSub)
              @Format_Code(F_AcctSub, F_AcctSub)
              @RtvFldDesc("CHACCT=$(V_CRARAC) and CHSUB=$(V_CRARSB) ", "HDCHRT", "CHCHDS", fieldDesc)
              <tr><td class="dsphdr">A/R Account</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_AcctSub)</td>
              </tr>

              @Format_Acct("$(V_CRTXAC)", "$(V_CRTXSB)", "", F_AcctSub)
              @Format_Code(F_AcctSub, F_AcctSub)
              @RtvFldDesc("CHACCT=$(V_CRTXAC) and CHSUB=$(V_CRTXSB) ", "HDCHRT", "CHCHDS", fieldDesc)
              <tr><td class="dsphdr">Sales Tax Account</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_AcctSub)</td>
              </tr>

              @Format_Acct("$(V_CRFRAC)", "$(V_CRFRSB)", "", F_AcctSub)
              @Format_Code(F_AcctSub, F_AcctSub)
              @RtvFldDesc("CHACCT=$(V_CRFRAC) and CHSUB=$(V_CRFRSB) ", "HDCHRT", "CHCHDS", fieldDesc)
              <tr><td class="dsphdr">Freight Account</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_AcctSub)</td>
              </tr>

              @Format_Acct("$(V_CRSCAC)", "$(V_CRSCSB)", "", F_AcctSub)
              @Format_Code(F_AcctSub, F_AcctSub)
              @RtvFldDesc("CHACCT=$(V_CRSCAC) and CHSUB=$(V_CRSCSB) ", "HDCHRT", "CHCHDS", fieldDesc)
              <tr><td class="dsphdr">Special Charges Account</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_AcctSub)</td>
              </tr>

              @RtvFldDesc("FLTYPE='INTRCO' and FLVALU='$(V_CRINTR)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_CRINTR, F_CRINTR)
              <tr><td class="dsphdr">Generate Inter-Company Transactions</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRINTR)</td>
              </tr>

              @RtvYNDesc($(V_CRARGL), fieldDesc)
              @Format_Code(V_CRARGL, F_CRARGL)
              <tr><td class="dsphdr">Feed A/R To G/L</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRARGL)</td>
              </tr>

              @RtvFldDesc("FLTYPE='DORS' and FLVALU='$(V_CRFEDS)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_CRFEDS, F_CRFEDS)
              <tr><td class="dsphdr">G/L Distribution Feed</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRFEDS)</td>
              </tr>

              @RtvFldDesc("FLTYPE='DORS' and FLVALU='$(V_CRFPDS)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_CRFPDS, F_CRFPDS)
              <tr><td class="dsphdr">G/L Payment Feed</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRFPDS)</td>
              </tr>

              @RtvYNDesc($(V_CRAUTO), fieldDesc)
              @Format_Code(V_CRAUTO, F_CRAUTO)
              <tr><td class="dsphdr">Restore A/R Feed If Errors Exist</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRAUTO)</td>
              </tr>

              <tr><td class="dsphdr">Miscellaneous Cash Customer</td>
                  <td class="dspalph">$(V_CRMSCC)</td>
              </tr>

              <tr><td class="dsphdr">Miscellaneous Cash Invoice Number</td>
                  <td class="dspnmbr">$(V_CRMSCI)</td>
              </tr>

              @RtvFldDesc("FLTYPE='AGEARCRDT' and FLVALU='$(V_CRCIAO)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_CRCIAO, F_CRCIAO)
              <tr><td class="dsphdr">Age Credit Invoices Based On</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRCIAO)</td>
              </tr>

              @RtvFldDesc("FLTYPE='AGEDATE' and FLVALU='$(V_CRBAON)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_CRBAON, F_CRBAON)
              <tr><td class="dsphdr">Base Aging On Code</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRBAON)</td>
              </tr>

              @RtvYNDesc($(V_CRBBAL), fieldDesc)
              @Format_Code(V_CRBBAL, F_CRBBAL)
              <tr><td class="dsphdr">Deposit Balancing Required</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRBBAL)</td>
              </tr>

              @RtvYNDesc($(V_CRABCH), fieldDesc)
              @Format_Code(V_CRABCH, F_CRABCH)
              <tr><td class="dsphdr">Auto Assign A/R Payment Batch</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRABCH)</td>
              </tr>

              <tr><td class="dsphdr">Last A/R Payment Batch Used</td>
                  <td class="dspnmbr">$(V_CRPBCH)</td>
              </tr>

              <tr><td class="dsphdr">Order Entry Batch</td>
                  <td class="dspnmbr">$(V_CROEBH)</td>
              </tr>

              <tr><td class="dsphdr">NSF Batch</td>
                  <td class="dspnmbr">$(V_CRNSBH)</td>
              </tr>

              <tr><td class="dsphdr">Invoice Entry Batch</td>
                  <td class="dspnmbr">$(V_CRIEBH)</td>
              </tr>

              @RtvFldDesc("PYPYCD='$(V_CRDPYC)'", "ARPYCD", "PYPYDS", fieldDesc)
              @Format_Code(V_CRDPYC, F_CRDPYC)
              <tr><td class="dsphdr">Deduction Payment Code</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRDPYC)</td>
              </tr>

              @RtvFldDesc("TMCTRM='$(V_CRDTRM)'", "HDTRMS", "TMCTDS", fieldDesc)
              @Format_Code(V_CRDTRM, F_CRDTRM)
              <tr><td class="dsphdr">Deduction Terms Code</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRDTRM)</td>
              </tr>

              @RtvFldDesc("PYPYCD='$(V_CRNPYC)'", "ARPYCD", "PYPYDS", fieldDesc)
              @Format_Code(V_CRNPYC, F_CRNPYC)
              <tr><td class="dsphdr">NSF Payment Code</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRNPYC)</td>
              </tr>

              @RtvFldDesc("CSSTCD='$(V_CRNCOL)'", "ARCSTM", "CSDESC", fieldDesc)
              @Format_Code(V_CRNCOL, F_CRNCOL)
              <tr><td class="dsphdr">NSF Collection Status</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRNCOL)</td>
              </tr>

              <tr><td class="dsphdr">Last Collection ID</td>
                  <td class="dspalph">$(V_CRCTRL)</td>
              </tr>

              %if (V_HDMCRL > "0")
                  @RtvYNDesc($(V_CRPRMC), fieldDesc)
                  @Format_Code(V_CRPRMC, F_CRPRMC)
                  <tr><td class="dsphdr">Process Multi-Currency</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_CRPRMC)</td>
                  </tr>

                  @RtvFldDesc("RYTYPE='$(V_CRMCRT)'", "HDRTYP", "RYDESC", fieldDesc)
                  @Format_Code(V_CRMCRT, F_CRMCRT)
                  <tr><td class="dsphdr">A/R Currency Rate Type</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_CRMCRT)</td>
                  </tr>
              %endif

              @RtvYNDesc($(V_CRPARF), fieldDesc)
              @Format_Code(V_CRPARF, F_CRPARF)
              <tr><td class="dsphdr">Process A/R Factoring</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRPARF)</td>
              </tr>

              @RtvFldDesc("BKBANK=$(V_CRFBNK)", "HDBANK", "BKBKNM", fieldDesc)
              @Format_Code(V_CRFBNK, F_CRFBNK)
              <tr><td class="dsphdr">Factor Bank Number</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRFBNK)</td>
              </tr>

              @RtvFldDesc("PYPYCD='$(V_CRPYCD)'", "ARPYCD", "PYPYDS", fieldDesc)
              @Format_Code(V_CRPYCD, F_CRPYCD)
              <tr><td class="dsphdr">Factoring Payment Code</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRPYCD)</td>
              </tr>

              @Format_Acct("$(V_CRFARA)", "$(V_CRFARS)", "", F_AcctSub)
              @Format_Code(F_AcctSub, F_AcctSub)
              @RtvFldDesc("CHACCT=$(V_CRFARA) and CHSUB=$(V_CRFARS) ", "HDCHRT", "CHCHDS", fieldDesc)
              <tr><td class="dsphdr">Factoring A/R Account</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_AcctSub)</td>
              </tr>

              @Format_Acct("$(V_CRFLIA)", "$(V_CRFLIS)", "", F_AcctSub)
              @Format_Code(F_AcctSub, F_AcctSub)
              @RtvFldDesc("CHACCT=$(V_CRFLIA) and CHSUB=$(V_CRFLIS) ", "HDCHRT", "CHCHDS", fieldDesc)
              <tr><td class="dsphdr">Factoring Liability Account</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_AcctSub)</td>
              </tr>

          </table>

          <table $(contentTable)>
              <tr><td class="dsphdr">Aging:</td>
                  <td class="colhdr">One</td>
                  <td class="colhdr">Two</td>
                  <td class="colhdr">Three</td>
                  <td class="colhdr">Four</td>
              </tr>

              <tr><td class="dsphdr">Number Of Days</td>
                  <td class="colnmbr">$(V_CRAGE1)</td>
                  <td class="colnmbr">$(V_CRAGE2)</td>
                  <td class="colnmbr">$(V_CRAGE3)</td>
                  <td class="colnmbr">$(V_CRAGE4)</td>
              </tr>
          </table>
      %}
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) AR_Select_NewCustomerDefault (IN  CHAR(64)    profileHandle,
                                                     CHAR(2)     dataBaseID,
                                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="newcustomerdefault"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %ROW{
              @RtvFldDesc("FLTYPE='BY' and FLVALU='$(V_CRAACN)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_CRAACN, F_CRAACN)
              <tr><td class="dsphdr">Auto Assign Customer Number</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRAACN)</td>
              </tr>

              <tr><td class="dsphdr">Last Customer Number Used</td>
                  <td class="dspalph">$(V_CRLCNU)</td>
              </tr>

              <tr><td class="dsphdr">Credit Limit</td>
                  <td class="dspalph">$(V_CRCCRL)</td>
              </tr>

              @RtvFldDesc("TMCTRM='$(V_CRCTRM)'", "HDTRMS", "TMCTDS", fieldDesc)
              @Format_Code(V_CRCTRM, F_CRCTRM)
              <tr><td class="dsphdr">Terms Code</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRCTRM)</td>
              </tr>

              @RtvYNDesc($(V_CRCSCC), fieldDesc)
              @Format_Code(V_CRCSCC, F_CRCSCC)
              <tr><td class="dsphdr">Service Charge</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRCSCC)</td>
              </tr>

              @RtvYNDesc($(V_CRCSTC), fieldDesc)
              @Format_Code(V_CRCSTC, F_CRCSTC)
              <tr><td class="dsphdr">Statement</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRCSTC)</td>
              </tr>

              @RtvFldDesc("WHWHS=$(V_CRWHS)", "HDWHSM", "WHWHNM", fieldDesc)
              @Format_Code(V_CRWHS, F_CRWHS)
              <tr><td class="dsphdr">Warehouse Number</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRWHS)</td>
              </tr>

              @RtvFldDesc("SMSLSM=$(V_CRSLSM)", "HDSLSM", "SMSNA1", fieldDesc)
              @Format_Code(V_CRSLSM, F_CRSLSM)
              <tr><td class="dsphdr">Salesman</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRSLSM)</td>
              </tr>

              @RtvFldDesc("LOLOC#=$(V_CRLOC)", "HDLCTN", "LOLNA1", fieldDesc)
              @Format_Code(V_CRLOC, F_CRLOC)
              <tr><td class="dsphdr">Location</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRLOC)</td>
              </tr>

              @RtvFldDesc("RGCRGN='$(V_CRCRGN)'", "HDCRGN", "RGCRDS", fieldDesc)
              @Format_Code(V_CRCRGN, F_CRCRGN)
              <tr><td class="dsphdr">Region</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRCRGN)</td>
              </tr>

              @RtvFldDesc("CNCTCD='$(V_CRCTRY)'", "HDCTRY", "CNCDES", fieldDesc)
              @Format_Code(V_CRCTRY, F_CRCTRY)
              <tr><td class="dsphdr">Country</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRCTRY)</td>
              </tr>

              @RtvFldDesc("CCCCLS='$(V_CRCCLS)'", "HDCCLS", "CCCCDS", fieldDesc)
              @Format_Code(V_CRCCLS, F_CRCCLS)
              <tr><td class="dsphdr">Class Code</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRCCLS)</td>
              </tr>

              @RtvFldDesc("SVSVSV='$(V_CRSVIA)'", "HDSHPV", "SVSVDS", fieldDesc)
              @Format_Code(V_CRSVIA, F_CRSVIA)
              <tr><td class="dsphdr">Ship Via</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_CRSVIA)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

