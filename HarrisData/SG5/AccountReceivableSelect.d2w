%FUNCTION(dtw_sql) AR_Select_OpenInvoice (IN  CHAR(64)    profileHandle,
                                              CHAR(2)     dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      <a name="openinvoice"></a>
      %if (backHome == "")
          @dtw_assign(backHome, "$(d2wName)/REPORT")
      %endif
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)LocationAROpenInvoice.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("", "Location")
                  @Format_Column_Header("", "Company/Facility")
                  @Format_Column_Header("", "Account")
                  @Format_Column_Header("", "Open Amount")
                  %if (V_HDMCRL > "0")
                      @Format_Column_Header("", "Currency")
                      @Format_Column_Header("", "Domestic Amount")
                  %endif
                  @Format_Column_Header("", "Number Of Invoices")
              </tr>
          %endif

          %ROW{
              @Format_CoFac("$(V_LOCO#)", "$(V_LOFAC#)", "", F_CoFac)
              @Format_Acct("$(V_IVARAC)", "$(V_IVARSB)", "", F_AcctSub)
              @Format_Nbr($(V_IVIVAM), F_IVIVAM, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr($(V_IVDBAL), F_IVDBAL, "2", $(amtEditCode), "Y", "", "")

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)LocationSelect.d2w/REPORT$(genericVarBase)&amp;locationNumber=@dtw_rurlescseq(V_IVLOC)&amp;locationName=@dtw_rurlescseq(V_LOLNA1)" title="View Location [$(V_IVLOC)]">$(V_LOLNA1)</a></td>
                  <td class="colalph" $(helpCursor)><span title="$(F_CoFac)">$(V_CFCFNM)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(F_AcctSub)">$(V_CHCHDS)</span></td>
                  %if (V_HDMCRL > "0")
                      <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=177&amp;fKey1=IVLOC&amp;fVal1=@dtw_rurlescseq(V_IVLOC)&amp;fKey2=IVARAC&amp;fVal2=@dtw_rurlescseq(V_IVARAC)&amp;fKey3=IVARSB&amp;fVal3=@dtw_rurlescseq(V_IVARSB)&amp;fKey4=IVCURT&amp;fVal4=@dtw_rurlescseq(V_IVCURT)&amp;fKey5=IVOPEN&amp;fVal5=Y&amp;fDsc5=null&amp;fRel=Y" title="View Customer Invoices">$(F_IVIVAM)</a></td>
                      <td class="colalph" $(helpCursor)><span title="$(V_IVCURT)">$(V_CYDESC)</span></td>
                      <td class="colnmbr">$(F_IVDBAL)</td>
                  %else
                      <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=177&amp;fKey1=IVLOC&amp;fVal1=@dtw_rurlescseq(V_IVLOC)&amp;fKey2=IVARAC&amp;fVal2=@dtw_rurlescseq(V_IVARAC)&amp;fKey3=IVARSB&amp;fVal3=@dtw_rurlescseq(V_IVARSB)&amp;fKey4=IVOPEN&amp;fVal4=Y&amp;fDsc5=null&amp;fRel=Y" title="View Customer Invoices">$(F_IVIVAM)</a></td>
                  %endif
                  <td class="colnmbr">$(V_INV_COUNT)</td>
              </tr>
          %}

          @RtvFldDesc(" IVIVAM-IVNPOS<>0  ", "HDINVC", "CHAR(SUM(IVIVAM-IVNPOS))", V_IVIVAM)
          @Format_Nbr($(V_IVIVAM), F_IVIVAM, "2", $(amtEditCode), "Y", "", "")
          %INCLUDE "SetRowClass.icl"
          <tr class="$(rowClass)">
              <td class="colalph">Total Open</td>
              <td class="colalph">&nbsp;</td>
              <td class="colalph">&nbsp;</td>
              <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=177&amp;fKey1=IVOPEN&amp;fVal1=Y&amp;fDsc1=null" title="View Customer Invoices">$(F_IVIVAM)</a></td>
              <td class="colalph">&nbsp;</td>
              %if (V_HDMCRL > "0")
                   <td class="colalph">&nbsp;</td>
              %endif
          </tr>
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) AR_Select_CashApplication (IN  CHAR(64)    profileHandle,
                                                  CHAR(2)     dataBaseID,
                                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      <a name="cashapplication"></a>
      %if (backHome == "")
          @dtw_assign(backHome, "$(d2wName)/REPORT")
      %endif
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)BankARCashApplication.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("", "Bank")
                  @Format_Column_Header("", "Batch")
                  @Format_Column_Header("", "Date")
                  @Format_Column_Header("", "Amount")
                  @Format_Column_Header("", "Cash Account")
                  %if (V_HDMCRL > "0")
                      @Format_Column_Header("", "Currency")
                      @Format_Column_Header("", "Domestic Amount Paid")
                  %endif
                  @Format_Column_Header("", "Number Of Payments")
              </tr>
          %endif

          %ROW{
              @Format_Acct("$(V_BKACCT)", "$(V_BKSUB)", "", F_AcctSub)
              @Format_Nbr($(V_YPAMT), F_YPAMT, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr($(V_YPCAMT), F_YPCAMT, "2", $(amtEditCode), "Y", "", "")
              @Format_Date(V_YPBDAT, "D", F_YPBDAT)

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph" $(helpCursor)><span title="$(V_YPBANK)">$(V_BKBKNM)</span></td>
                  <td class="colnmbr"><a href="$(homeURL)$(phpPath)ApplCashBatchSelect.php$(altVarBase)&amp;fromBatchNumber=@dtw_rurlescseq(V_YPBCH)&amp;fromBatchDate=@dtw_rurlescseq(V_YPBDAT)&amp;fromBatchBank=@dtw_rurlescseq(V_YPBANK)" title="View Batch">$(V_YPBCH)</a></td>
                  <td class="colnmbr">$(F_YPBDAT)</td>
                  <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=176&amp;fKey1=YPBCH&amp;fVal1=@dtw_rurlescseq(V_YPBCH)&amp;fKey2=YPBDAT&amp;fVal2=@dtw_rurlescseq(V_YPBDAT)&amp;fKey3=YPBANK&amp;fVal3=@dtw_rurlescseq(V_YPBANK)" title="View Payment History">$(F_YPAMT)</a></td>
                  <td class="colalph" $(helpCursor)><span title="$(F_AcctSub)">$(V_CHCHDS)</span></td>
                  %if (V_HDMCRL > "0")
                      <td class="colalph" $(helpCursor)><span title="$(V_BKCURT)">$(V_CYDESC)</span></td>
                      <td class="colnmbr">$(F_YPCAMT)</td>
                  %endif
                  <td class="colnmbr">$(V_PMT_COUNT)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) AR_Select_Aging (IN  CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="aging"></a>
      %if (backHome == "")
          @dtw_assign(backHome, "$(d2wName)/REPORT")
      %endif
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      @dtw_assign(oneTime, "")
      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %endif
          %ROW{
              %if (sql_Record_Count > "0")
                  %if (oneTime == "")
                      <tr>
                          <th class="colhdr">Aging Days</th>
                          <th class="colhdr">Amount Due</th>
                          <th class="colhdr">Number Of Invoices</th>
                      </tr>

                      @dtw_assign(oneTime, "Y")
                      @dtw_assign(T_IVAMT, "0")
                      @dtw_assign(T_INV_COUNT, "0")
                  %endif
              %endif

              %if (V_AIBCKT == "1")
                  @dtw_assign(agingDesc, "Current")
              %elif (V_AIBCKT == "2")
                  @dtw_assign(agingDesc, "1 - $(V_CRAGE1)")
              %elif (V_AIBCKT == "3")
                  @dtw_assign(agingDesc, "@dtw_radd(V_CRAGE1, "1") - $(V_CRAGE2)")
              %elif (V_AIBCKT == "4")
                  @dtw_assign(agingDesc, "@dtw_radd(V_CRAGE2, "1") - $(V_CRAGE3)")
              %elif (V_AIBCKT == "5")
                  @dtw_assign(agingDesc, "@dtw_radd(V_CRAGE3, "1") - $(V_CRAGE4)")
              %elif (V_AIBCKT == "6")
                  @dtw_assign(agingDesc, "@dtw_radd(V_CRAGE4, "1") - over")
              %elif (V_AIBCKT == "7")
                  @dtw_assign(agingDesc, "Credits")
              %endif

              @dtw_add(T_IVAMT, V_IVAMT, "15", T_IVAMT)
              @dtw_add(T_INV_COUNT, V_INV_COUNT, "15", T_INV_COUNT)
              @Format_Nbr($(V_IVAMT), F_IVAMT, "2", $(amtEditCode), "", "", "")

              %INCLUDE "SetRowClass.icl"

              <tr class="$(rowClass)">
                  <td class="colcode">$(agingDesc)</td>
                  <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=177&amp;fKey1=AIBCKT&amp;fVal1=@dtw_rurlescseq(V_AIBCKT)&amp;fDsc1=@dtw_rurlescseq(agingDesc)&amp;fKey2=IVOPEN&amp;fVal2=Y&amp;fDsc2=null" title="View Customer Invoices">$(F_IVAMT)</a></td>
                  <td class="colnmbr">$(V_INV_COUNT)</td>
              </tr>
          %}

          @Format_Nbr(T_IVAMT, F_IVAMT, "2", $(amtEditCode), "", "", "")
          %INCLUDE "SetRowClass.icl"
          <tr>
              <td class="coltotal">Total</td>
              <td class="coltotal">$(F_IVAMT)</td>
              <td class="coltotal">$(T_INV_COUNT)</td>
          </tr>
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) AR_Select_UnpostedSubLedger (IN  CHAR(64)    profileHandle,
                                                    CHAR(2)     dataBaseID,
                                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="unpostedsubledger"></a>
      %if (backHome == "")
          @dtw_assign(backHome, "$(d2wName)/REPORT")
      %endif
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)GLUnpostSubLedger.d2w/REPORT$(d2wVarBase)&amp;SubLedger=AR")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("WFFILE", "Sub-Ledger")
                  @Format_Column_Header("WFPER#", "Period")
                  @Format_Column_Header("WFJRNL", "Journal")
                  @Format_Column_Header("WFDATE", "Transaction Date")
                  @Format_Column_Header("WFTTYP", "Transaction Type")
                  @Format_Column_Header("WFDESC", "Description")
                  @Format_Column_Header("WFUAMT", "Amount")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @dtw_assign(F_WFPER#, V_WFPER#)
              @PeriodFromCYP(F_WFPER#)
              @Format_Date(V_WFDATE, "D", F_WFDATE)
              @Format_Nbr($(V_WFUAMT), F_WFUAMT, "2", $(amtEditCode), "Y", "", "")

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)GLHDARTRJrnl.d2w/ENTRY$(genericVarBase)&amp;glJournal=@dtw_rurlescseq(V_WFJRNL)&amp;glPer=@dtw_rurlescseq(V_WFPER#)&amp;glDate=@dtw_rurlescseq(V_WFDATE)&amp;glTransType=@dtw_rurlescseq(V_WFTTYP)&amp;glFrCur=@dtw_rurlescseq(V_WFFCUR)" title="View Unposted $(V_WFDESC)">$(V_WFFILE)</a></td>
                  <td class="colnmbr">$(F_WFPER#)</td>
                  <td class="colalph">$(V_WFJRNL)</td>
                  <td class="colnmbr">$(F_WFDATE)</td>
                  <td class="colalph" $(helpCursor)><span title="$(V_WFTTYP)">$(V_transFLDESC)</span></td>
                  <td class="colalph">$(V_WFDESC)</td>
                  <td class="colnmbr">$(F_WFUAMT)</td>
              </tr>
	   %}
      </table>
      </fieldset>
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"

  @Set_SQL(stmtSQL)
%}