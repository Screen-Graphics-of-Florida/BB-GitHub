%INCLUDE "$(baseVar)"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Sales Inquiry Selection Update"
  d2wName                 = "SalesInqUpdate.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;selectSequence=@dtw_rurlescseq(selectSequence)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  selectData              = ""	
  selectName              = "SALESINQ"
%}

%FUNCTION(dtw_directcall) Update_User_Selection(INOUT CHAR(64) profileHandle,
                                                INOUT CHAR(2)  dataBaseID,
                                                INOUT CHAR(1)  maintCode,
                                                INOUT CHAR(10) userProfile,
                                                INOUT CHAR(10) selectName,
                                                INOUT DEC(5,0) selectSequence,
                                                INOUT CHAR(50) selectDesc,
                                                INOUT CHAR(10) selectTotals,
                                                INOUT CHAR(500) selectGroupBy,
                                                INOUT CHAR(3000) selectCriteria)
{%EXEC {HSYUSL_W.PGM %}
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(maintCode, "R")
  @Update_User_Selection(profileHandle, dataBaseID, maintCode, userProfile, selectName, selectSequence, selectDesc, selectTotals, selectGroupBy, selectCriteria)
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.selectDesc.value =="")
                         {alert("Please enter a description"); return false;}
                      return true;
              }
	       %INCLUDE "numedit.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onLoad="window.focus()" onKeyPress="checkEnterChg()">
          <table $(contentTable)>
              <tr><td><h1>$(page_title)</h1></td>
                  <td class="toolbar">
                      <a href="javascript:check(document.Chg)">$(selectAcceptImage)</a>
                  </td>
              </tr>
          </table>

          $(hrTagAttr)

          <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(d2wVarBase)">
              <table $(contentTable)>
                  <tr><td class="dsphdr">Description</td>
                      <td class="inputalph"><input name="selectDesc" value="$(selectDesc)" type="text" size="50" maxlength="50"></td>
                  </tr>
              </table>
          </form>
          $(hrTagAttr)
      </body>
  </html>
%}

%HTML(UPDATE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(maintCode, "U")
  @Update_User_Selection(profileHandle, dataBaseID, maintCode, userProfile, selectName, selectSequence, selectDesc, selectTotals, selectGroupBy, selectCriteria)
  <script TYPE="text/javascript">
      window.close()
  </script>
%}