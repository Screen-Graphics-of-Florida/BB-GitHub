%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Cancel Picking Tickets"
  d2wName                 = "CancelPickingTicketsSelect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;orderBy=@dtw_rurlescseq(orderBy)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  stmtSQL                 = ""
  haveRec                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CANCELPICKINGTICKETS")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select a.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(b.CMCNA1,' ') as CMCNA1, coalesce(b.CMCNA1U,' ') as CMCNA1U ", stmtSQL)
                      @dtw_concat(fileSQL, " OECPTW ", fileSQL)
                      @dtw_concat(fileSQL, " left join OEORHP a on a.IHTURN=CPTURN ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDCUST b on IHSHTO=b.CMCUST ", fileSQL)
                      @dtw_concat(selectSQL, " CPXHND='$(profileHandle)'", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Cancel_Picking_Tickets_Select(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Cancel_Picking_Tickets_Select (IN CHAR(64)    profileHandle,
                                                     CHAR(2)     dataBaseID,
                                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  <a href="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)">$(selectAcceptImage)</a>
                  <a href="javascript:history.back()">$(cancelImageLrg)</a>
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>

      $(hrTagAttr)

      <table $(contentTable)>
          <tr>
              @OrderBy_Sort("IHTURN", sortVar)
              <td class="colhdr$(sortVar)">Turnaround<br>Number</td>
              @OrderBy_Sort("IHORD#", sortVar)
              <td class="colhdr$(sortVar)">Order<br>Number</td>
              @OrderBy_Sort("IHSHTO", sortVar)
              <td class="colhdr$(sortVar)">Ship-To<br>Number</td>
              @OrderBy_Sort("CMCNA1U", sortVar)
              <td class="colhdr$(sortVar)">Name</td>
              @OrderBy_Sort("IHRQDT", sortVar)
              <td class="colhdr$(sortVar)">Required<br>Date</td>
              @OrderBy_Sort("IHGEND", sortVar)
              <td class="colhdr$(sortVar)">Generation<br>Date</td>
              @OrderBy_Sort("IHSVSV", sortVar)
              <td class="colhdr$(sortVar)">Ship<br>Via</td>
              @OrderBy_Sort("IHORTY", sortVar)
              <td class="colhdr$(sortVar)">Order<br>Type</td>
              @OrderBy_Sort("IHUSER", sortVar)
              <td class="colhdr$(sortVar)">User</td>
          </tr>
		
          %ROW{

              %INCLUDE "SetRowClass.icl"
              %if (V_PWSEL == "S")
                  @dtw_assign(selected, "CHECKED")
              %else
                  @dtw_assign(selected, "")
              %endif

              @Format_Date(V_IHRQDT, "D", F_IHRQDT)
              @Format_Date(V_IHGEND, "D", F_IHGEND)
              @RtvFldDesc("SVSVSV='$(V_IHSVSV)'", "HDSHPV", "SVSVDS", shipViaDesc)
              @RtvFldDesc("(OTOTCD='$(V_IHORTY)' and OTAPID='OE')", "HDOTYP", "OTDESC", orderTypeDesc)
              @RtvFldDesc("USUSER='$(V_IHUSER)'", "SYUSER", "USDESC", userName)

              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_IHTURN)</td>
                  <td class="colnmbr">$(V_IHORD#)</td>
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)CustomerInquiry.d2w/DISPLAY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(V_IHSHTO)" onclick="$(inquiryWinVar)" title="Customer Quickview">$(V_IHSHTO)</a></td>
                  <td class="colalph">$(V_CMCNA1)</td>
                  <td class="coldate">$(F_IHRQDT)</td>
                  <td class="coldate">$(F_IHGEND)</td>
                  <td class="colalph" $(helpCursor)><span title="$(shipViaDesc)">$(V_IHSVSV)</span></td>
                  <td class="colcode" $(helpCursor)><span title="$(orderTypeDesc)">$(V_IHORTY)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_IHUSER)">$(userName)</span></td>
              </tr>
          %}
      </table>
      $(hrTagAttr)
      <a href="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)">$(selectAcceptImage)</a>
      <a href="javascript:history.back()">$(cancelImageLrg)</a>
      @dtw_assign(medIcon, "Y")
      %INCLUDE "HelpPage.icl"
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data (INOUT CHAR(64)    profileHandle,
                                               CHAR(2)     dataBaseID,
                                               CHAR(1)     updCode,
                                               CHAR(1)     errFound,
                                               CHAR(32000) edtVar,                             	
                                               CHAR(32000) errVar)
{%EXEC {HOECPS_W.PGM %}
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"

  @dtw_assign(updCode, "U")
  @dtw_assign(edtVar, "")
  @dtw_concat(edtVar, "}{", edtVar)

  @dtw_assign(confMessage, "Selected Picking Tickets have been cancelled")
  @Validate_Data(profileHandle, dataBaseID, updCode, errFound, edtVar, errVar)
  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)CancelPickingTickets.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}
