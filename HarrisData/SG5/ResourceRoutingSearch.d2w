%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Resource Routing Search"
  d2wName                 = "ResourceRoutingSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
  advanceSearch           = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectResource(item, desc){
                  window.opener.document.$(docName).$(fldName).value = item;
                  window.opener.document.$(docName).$(fldDesc).value = desc;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (moreInfo == "Y")
                          @dtw_concat(stmtSQL, " Select MSMFRM.*, IMIMDS ", stmtSQL)
                      %else
                          @dtw_concat(stmtSQL, " Select RRPN, IMIMDS, IMIMDSU ", stmtSQL)
                      %endif
                      @dtw_concat(fileSQL, " MSMFRM, HDIMST ", fileSQL)
                      @dtw_concat(selectSQL, " RRPN=IMITEM", selectSQL)
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, " and RRPLT=$(plantNumber) and RRPN='$(itemNumber)'", selectSQL)
                      %else
                          @dtw_concat(selectSQL, " and RRPLT=$(plantNumber)", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      %if (moreInfo != "Y")
                          @dtw_concat(stmtSQL, " Group By RRPN,IMIMDS,IMIMDSU", stmtSQL)
                          @dtw_concat(distinctSQL, "RRPN concat IMIMDS concat IMIMDSU", distinctSQL)
                      %endif
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @ResourceRouting_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) ResourceRouting_Search (IN  CHAR(64)    profileHandle,
				                CHAR(2)     dataBaseID,
                                               CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr"> Item Number</th>
                      <th class="colhdr"> Description</th>
                  </tr>
                  <tr>
                      <td class="inputalph">
                          <input type="text" name="srchItem" size="15" maxlength="15">
                          <input type="hidden" name="operItem" value="LIKE">
                      </td>
                      <td class="inputalph">
                          <input type="text" name="srchDesc" size="30" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchItem.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("RRPN", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=itemNumber" title="Sequence By Item Number"> Item Number</a></th>
                  @OrderBy_Sort("IMIMDSU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=description" title="Sequence By Description, Item Number"> Description</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %else
          <table $(contentTable)>
              @Format_Quote(itemDesc, F_IMIMDS)
              <tr><td>
                      <a href="javascript:selectResource('$(itemNumber)', '$(itemDesc)')">$(selectImageLrg)</a>
                  </td>
              </tr>
              <tr><td class="dsphdr">Item Number</td>
                  <td class="dspalph">$(itemNumber)</td>
                  <td class="dspalph">$(F_IMIMDS)</td>
              </tr>
          </table>

          $(inquiryhrTagAttr)
          <table $(contentTable)>
          @dtw_assign(dspHeader, "Y")
      %endif		

          %ROW{
              %INCLUDE "SetRowClass.icl"

              %if (moreInfo != "Y")	
                  @Format_Quote(V_IMIMDS, F_IMIMDS)
                  <tr class="$(rowClass)">
                      <td class="colalph">$(V_RRPN)</td>
                      <td class="colalph"><a href="javascript:selectResource('$(V_RRPN)', '$(F_IMIMDS)')" title="Select Item">$(V_IMIMDS)</a></td>
                      <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(V_RRPN)&amp;itemDesc=@dtw_rurlescseq(V_IMIMDS)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                  </tr>

              %else
                  %if (dspHeader == "Y")
                      @dtw_assign(dspHeader, "")
                      <tr>
                          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                          <th class="colhdr">Rtg<br>Seq</th>
                          <th class="colhdr">Dept</th>
                          <th class="colhdr">W/C</th>
                          <th class="colhdr">Measured<br>Hours</th>
                          <th class="colhdr">Ref<br>Code</th>
                          <th class="colhdr">Crew<br>Size</th>
                          <th class="colhdr">Setup<br>Hours</th>
                      </tr>
                  %endif

                  @Format_Nbr($(V_RRMHRS), F_RRMHRS, "4", $(hrsEditCode), "", "", "")
                  @Format_Nbr($(V_RRMPON), F_RRMPON, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_RRSUHR), F_RRSUHR, "2", $(amtEditCode), "", "", "")
                  <tr class="$(rowClass)">
                      <td class="colnmbr">$(V_RRSEQN)</td>
                      <td class="colalph">$(V_RRDEPT)</td>
                      <td class="colalph">$(V_RRWC)</td>
                      <td class="colnmbr">$(F_RRMHRS)</td>
                      <td class="colalph">$(V_RRMHRC)</td>
                      <td class="colnmbr">$(F_RRMPON)</td>
                      <td class="colnmbr">$(F_RRSUHR)</td>
                  </tr>

              %endif
          %}
      </table>
      %if (moreInfo != "Y")	
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
      %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "RRPN")
      @DTW_ASSIGN(orderByDisplay, "Item Number")
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "itemNumber")
      %if (orderBy == "RRPN")
          @DTW_ASSIGN(orderBy, "RRPN DESC")
          @DTW_ASSIGN(orderByDisplay, "Item Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "RRPN")
          @DTW_ASSIGN(orderByDisplay, "Item Number")
      %endif
  %elif (sequence == "description")
      %if (orderBy == "IMIMDSU,RRPN")
          @DTW_ASSIGN(orderBy, "IMIMDSU DESC,RRPN")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Item Number")
      %else
          @DTW_ASSIGN(orderBy, "IMIMDSU,RRPN")
          @DTW_ASSIGN(orderByDisplay, "Description, Item Number")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("RRPN", "Item Number", $(srchItem), "U", operItem, "A")
  @Build_WildCard ("IMIMDSU", "Item Description", $(srchDesc), "U", operDesc, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}