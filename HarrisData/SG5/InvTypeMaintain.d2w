%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Inventory Type Maintenance"
  d2wName                 = "InvTypeMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;invType=@dtw_rurlescseq(invType)&amp;invTypeDesc=@dtw_rurlescseq(invTypeDesc)&amp;maintenanceCode=D"
  programName             = "HHDITM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.invType.value =="" ||
                      document.Chg.invTypeDesc.value =="")
                     {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.accountNumber, 4, 0) &&
                      editNum(document.Chg.subaccountNumber, 4, 0))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "INVTYPEMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From HDITYP Where ITITC = '$(invType)'", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=109")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "invType")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@itc@", "invType")          @dtw_assign(Err_ITITC,  fieldValue)
                          @DecatErr_Field("@@desc", "invTypeDesc")      @dtw_assign(Err_ITDESC, fieldValue)
                          @DecatErr_Field("@@iasm", "accountNumber")    @dtw_assign(Err_ITIASM, fieldValue)
                          @DecatErr_Field("@@iass", "subaccountNumber") @dtw_assign(Err_ITIASS, fieldValue)
                          @DecatErr_Field("@@alph", "alphaSequence")    @dtw_assign(Err_ITALPH, fieldValue)
                      %endif

                      @Decat_Field("@@itc@")   @dtw_assign(V_ITITC,  fieldValue)
                      @Decat_Field("@@desc")   @dtw_assign(V_ITDESC, fieldValue)
                      @Decat_Field("@@iasm")   @dtw_assign(V_ITIASM, fieldValue)
                      @Decat_Field("@@iass")   @dtw_assign(V_ITIASS, fieldValue)
                      @Decat_Field("@@alph")   @dtw_assign(V_ITALPH, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "invType")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_ITITC,  "")
                      @dtw_assign(focusField, "invType")
                  %else
                      @dtw_assign(focusField, "invTypeDesc")
                  %endif

                  @SetTextOvr(Err_ITITC)
                  <tr><td class="dsphdr"><span $(textOvr)>Inventory Type</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="invType" type="text" value="$(V_ITITC)" size="4" maxlength="4"> $(reqFieldChar) </td>
                      %else
                          <td class="inputalph"><input name="invType" type="hidden" value="$(V_ITITC)" size="4" maxlength="4">$(V_ITITC)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_ITITC)

                  @SetTextOvr(Err_ITDESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="invTypeDesc" type="text" value="$(V_ITDESC)" size="20" maxlength="20"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_ITDESC)
	   		
                  @Default_Zero(V_ITIASM)
                  @Default_Zero(V_ITIASS)
                  @RtvFldDesc("CHACCT=$(V_ITIASM) and CHSUB=$(V_ITIASS) ", "HDCHRT", "CHCHDS", acctDesc)
                  @SetTextOvr(Err_ITIASM)
                  <tr><td class="dsphdr"><span $(textOvr)>Inventory Asset Account</span></td>
                      <td class="inputnmbr"><input name="accountNumber" value="$(V_ITIASM)" type="text" size="4" maxlength="4"> - <input name="subaccountNumber" value="$(V_ITIASS)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=accountNumber&amp;subFld=subaccountNumber&amp;descFld=assetAcctDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="assetAcctDesc" value="$(acctDesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_ITIASM)
	      		
                  @SetTextOvr(Err_ITALPH)
                  <tr><td class="dsphdr"><span $(textOvr)>Alpha Sequence</span></td>
                      <td class="inputalph"><input type="text" name="alphaSequence" value="$(V_ITALPH)" size="4" maxlength="4"></td>
                  </tr>
                  @DspErrMsg(Err_ITALPH)
              %}
          </table>
	
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDITM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(invType)
  @dtw_mUPPERCASE(alphaSequence)
  @dtw_assign(accountNumber,@dtw_rstrip(accountNumber))
  @dtw_assign(subaccountNumber,@dtw_rstrip(subaccountNumber))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@itc@", invType)
  @Concat_Field("@@desc", invTypeDesc)
  @Concat_Field("@@iasm", accountNumber)
  @Concat_Field("@@iass", subaccountNumber)
  @Concat_Field("@@alph", alphaSequence)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(invTypeDesc), $(invType), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@itc@", "invType")
          @Format_ConfMsg_Desc("", $(invTypeDesc), $(invType), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=109&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;invType=@dtw_rurlescseq(invType)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}