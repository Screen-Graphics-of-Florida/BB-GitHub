%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Work Flow D2W"
  d2wName                 = "WFD2W.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HWFD2M"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  noMsg                   = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "WFD2W")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select WFD2WN.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(a.FLDESC,' ') as optpFLDESC, upper(ifnull(a.FLDESC,' ')) as optpFLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(b.FLDESC,' ') as optfFLDESC, upper(ifnull(b.FLDESC,' ')) as optfFLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(c.FLDESC,' ') as accpFLDESC, upper(ifnull(c.FLDESC,' ')) as accpFLDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " WFD2WN  ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG a on a.FLTYPE='BY' and a.FLVALU=D2OPTP ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG b on b.FLTYPE='BY' and b.FLVALU=D2OPTF ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG c on c.FLTYPE='WFD2WACCSS' and c.FLVALU=D2ACCP ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, " D2D2W >' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (backHome != "$(d2wName)/report" && backHome != "")
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)WFD2WMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint == "")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">D2W</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="15" maxlength="50">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchWFD2W" size="20" maxlength="100">
                          <input type="hidden" name="operWFD2W" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("D2DESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Description, D2W">Description</a></th>
              @OrderBy_Sort("D2D2W ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=D2W"         title="Sequence By D2W">D2W</a></th>
              @OrderBy_Sort("optpFLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=OptionalPass" title="Sequence By Allow Optional Transition For Pass, D2W">Allow Optional Transition For Pass</a></th>
              @OrderBy_Sort("optfFLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=OptionalFail" title="Sequence By Allow Optional Transition For Fail, D2W">Allow Optional Transition For Fail</a></th>
              @OrderBy_Sort("accpFLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Access"      title="Sequence By Participant Access For Pass, D2W">Participant Access For Pass</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;wfD2W=@dtw_rurlescseq(V_D2D2W )&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;updRecNbr=@dtw_rurlescseq(START_ROW_NUM)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_D2DESC), $(V_D2D2W ), "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)WFD2WMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_04 == "Y")
                              <a href="$(homeURL)$(cGIPath)WFD2WMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromWFD2W=@dtw_rurlescseq(V_D2D2W )&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)WFD2WMaintain.d2w/EDIT_DATA$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_D2DESC)</td>
                  <td class="colalph">$(V_D2D2W )</td>                                      	
                  <td class="colcode" $(helpCursor)><span title="$(V_D2OPTP)">$(V_optpFLDESC)</span></td>                                      	
                  <td class="colcode" $(helpCursor)><span title="$(V_D2OPTF)">$(V_optfFLDESC)</span></td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_D2ACCP)">$(V_accpFLDESC)</span></td>                                      	
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select WFD2WN.*, ", stmtSQL)
  @dtw_concat(stmtSQL, " ifnull(a.FLDESC,' ') as optpFLDESC, upper(ifnull(a.FLDESC,' ')) as optpFLDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " ifnull(b.FLDESC,' ') as optfFLDESC, upper(ifnull(b.FLDESC,' ')) as optfFLDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " ifnull(c.FLDESC,' ') as accpFLDESC, upper(ifnull(c.FLDESC,' ')) as accpFLDESCU ", stmtSQL)
  @dtw_concat(fileSQL, " WFD2WN  ", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG a on a.FLTYPE='BY' and a.FLVALU=D2OPTP ", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG b on b.FLTYPE='BY' and b.FLVALU=D2OPTF ", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG c on c.FLTYPE='WFD2WACCSS' and c.FLVALU=D2ACCP ", fileSQL)
  %if (wildCardSearch!="")
      @dtw_concat(selectSQL, " D2D2W >' ' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_XMLQuery (IN  CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("WFD2WList")
          %ROW{
              @XMLIDTag(V_D2D2W , "WFD2W ID")
                  @XMLTag(V_D2D2W , "wfD2W")
                  @XMLTag(V_D2DESC, "Description")
                  @XMLTag(V_D2OPTP, "AllowOptionalTransitionForPass")
                  @XMLTag(V_D2OPTF, "AllowOptionalTransitionForFail")
                  @XMLTag(V_D2ACCP, "ParticipantAccessForPass")
              @XMLEndTag("WFD2W")
          %}
      @XMLEndTag("WFD2WList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "D2DESCU,D2D2W ")
          @DTW_ASSIGN(orderByDisplay, "Description, D2W")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %if (updRecNbr > "0")
      @dtw_assign(START_ROW_NUM, updRecNbr)
      @dtw_assign(updRecNbr, "")
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Description")
      %if (orderBy == "D2DESCU,D2D2W ")
          @DTW_ASSIGN(orderBy, "D2DESCU DESC,D2D2W ")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), D2W")
      %else
          @DTW_ASSIGN(orderBy, "D2DESCU,D2D2W ")
          @DTW_ASSIGN(orderByDisplay, "Description, D2W")
      %endif
  %elseif (sequence == "D2W")
      %if (orderBy == "D2D2W ")
          @DTW_ASSIGN(orderBy, "D2D2W  DESC")
          @DTW_ASSIGN(orderByDisplay, "D2W (descending)")
      %else
          @DTW_ASSIGN(orderBy, "D2D2W ")
          @DTW_ASSIGN(orderByDisplay, "D2W")
      %endif
  %elseif (sequence == "OptionalPass")
      %if (orderBy == "optpFLDESCU,D2D2W ")
          @DTW_ASSIGN(orderBy, "optpFLDESCU DESC,D2D2W ")
          @DTW_ASSIGN(orderByDisplay, "Allow Optional Transition For Pass (descending), D2W")
      %else
          @DTW_ASSIGN(orderBy, "optpFLDESCU,D2D2W ")
          @DTW_ASSIGN(orderByDisplay, "Allow Optional Transition For Pass, D2W")
      %endif
  %elseif (sequence == "OptionalFail")
      %if (orderBy == "optfFLDESCU,D2D2W ")
          @DTW_ASSIGN(orderBy, "optfFLDESCU DESC,D2D2W ")
          @DTW_ASSIGN(orderByDisplay, "Allow Optional Transition For Fail (descending), D2W")
      %else
          @DTW_ASSIGN(orderBy, "optfFLDESCU,D2D2W ")
          @DTW_ASSIGN(orderByDisplay, "Allow Optional Transition For Fail, D2W")
      %endif
  %elseif (sequence == "Access")
      %if (orderBy == "accpFLDESCU,D2D2W ")
          @DTW_ASSIGN(orderBy, "accpFLDESCU DESC,D2D2W ")
          @DTW_ASSIGN(orderByDisplay, "Participant Access For Pass (descending), D2W")
      %else
          @DTW_ASSIGN(orderBy, "accpFLDESCU,D2D2W ")
          @DTW_ASSIGN(orderByDisplay, "Participant Access For Pass, D2W")
      %endif
  %endif
	
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFD2WSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">D2W</td>
                              @dtw_assign(operNbr, "operWFD2W")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchWFD2W" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Allow Optional Transition For Pass</td>
                              @dtw_assign(operNbr, "operOptPass")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchOptPass" size="10" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Allow Optional Transition For Fail</td>
                              @dtw_assign(operNbr, "operOptFail")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchOptFail" size="10" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Participant Access For Pass</td>
                              @dtw_assign(operNbr, "operAccessPass")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchAccessPass" size="10" maxlength="30"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDesc.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("D2DESCU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("D2D2W ",   "D2W", $(srchWFD2W), "U", operWFD2W, "A")
  @Build_WildCard ("upper(ifnull(a.FLDESC,' '))",  "Allow Optional Transition For Pass", $(srchOptPass), "U", operOptPass, "A")
  @Build_WildCard ("upper(ifnull(b.FLDESC,' '))",  "Allow Optional Transition For Fail", $(srchOptFail), "U", operOptFail, "A")
  @Build_WildCard ("upper(ifnull(c.FLDESC,' '))",  "Participant Access For Pass", $(srchAccessPass), "U", operAccessPass, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
