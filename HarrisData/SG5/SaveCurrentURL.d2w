%INCLUDE "$(baseVar)"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "VarBase.icl"

%Define {	
  d2wName                 = "SaveCurrentURL.d2w"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  DTW_HTML_TABLE          = "NO"
%}

%HTML(SAVE) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Delete From SYEERR Where ERXHND='$(profileHandle)' @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Insert Into SYEERR (ERXHND,ERTYPE,EREERR,ERTSTP) ", stmtSQL)
  @dtw_concat(stmtSQL, " Values('$(profileHandle)','U','$(currentURL)',Current_Timestamp) @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)
%}