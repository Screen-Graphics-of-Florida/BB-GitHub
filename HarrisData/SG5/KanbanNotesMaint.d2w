%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NoteComment.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Kanban Notes Maintenance"
  d2wName                 = "KanbanNotesMaint.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(fromPlant)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;plantName=@dtw_rurlescseq(plantName)&amp;itemDescription=@dtw_rurlescseq(itemDescription)&amp;documentType=@dtw_rurlescseq(documentType)&amp;docDescr=@dtw_rurlescseq(docDescr)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@plantNumber", "@dtw_rurlescseq(plantNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@itemNumber", "@dtw_rurlescseq(itemNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@documentType", "@dtw_rurlescseq(documentType)", "1", "a", workURL)
%}

%MACRO_FUNCTION Display_Comments () {	
  <html>
      <head>
          %INCLUDE "headcmt.icl"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "$(cmtBanner)"
          <!-- End Of Banner Code -->
          <table $(contentTable) width="100%">
              <tr valign="top">
                  <td>
                      @dtw_assign(comments, "")
                      @dtw_assign(comment, "")
                      %if (cmtSelection != "C")
                          @Get_Kanban_Comments(profileHandle, dataBaseID, plantNumber, itemNumber, documentType, comment)
                      %endif

                      <table $(contentTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1> $(page_title)</h1></td>
                              <td>
                                  <a href="$(homeURL)$(cGIPath)NoteSearch.d2w/REPORT$(d2wVarBase)&amp;docName=Chg&amp;fldComment=comments&amp;noteFile=HDKBCM" onclick="$(searchWinVar)"> $(searchDesc)</a>
                                  <a href="$(homeURL)$(cGIPath)SpecSearch.d2w/REPORT$(genericVarBase)&amp;docName=Chg&amp;fldComment=comments" onclick="$(searchWinVar)"> $(searchSpecLrg)</a>
                                  %INCLUDE "CloseWindow.icl"
                              </td>
                          </tr>
                      </table>

                      <table $(contentTable)>
                          @Format_Header("Plant", $(plantName), $(plantNumber))
                          @Format_Header("Item", $(itemDescription), $(itemNumber))
                          @Format_Header("Document", $(docDescr), $(documentType))
                      </table>

                       @dtw_assign(focusField, "comments")
                      <table $(contentTable)>
                          <form class="formClass" METHOD=POST NAME="Chg"  ACTION="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)">
                              <tr>
                                  <td>
                                      %if ("$(comment)" != "")
                                          <textarea name="comments" ROWS=20 COLS=60 WRAP="hard">$(comment)</textarea>
                                      %else
                                          <textarea name="comments" ROWS=20 COLS=60 WRAP="hard"></textarea>
                                      %endif
                                  </td>
                              </tr>
                      </table>
            	       <table $(contentTable)>
                          <tr>
                              <td valign="top">
                                  <a href="javascript:check(document.Chg)">$(commentAcceptImage)</a>
                                  <a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)" onclick="$(commentWinVar)">$(commentResetImage)</a>
                                  <a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;cmtSelection=C">$(commentClearImage)</a>
                              </td>
                          </tr>
                      </table>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(cmtTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(DTW_directcall) Update_Comments (INOUT CHAR(64)     profileHandle,
                                                 CHAR(2)      dataBaseID,
                                                 DEC(3,0)     plantNumber,
                                                 CHAR (15)    itemNumber,
                                                 CHAR(3)      documentType,
                                                 char(32000)  comments)

{%EXEC {HSIKBN_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Display_Comments ()
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  @Update_Comments(profileHandle, dataBaseID, plantNumber, itemNumber, documentType, comments)

  @dtw_assign(confMessage, "Confirm Update Of Document $(documentType) - $(docDescr)")
  <script TYPE="text/javascript">
      opener.location.href=opener.location.href;
      opener.focus();
      window.close();
  </script>
%}