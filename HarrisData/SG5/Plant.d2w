%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Plant"
  d2wName                 = "Plant.d2w"
  d2wVarBase              = "$(genericVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HHDPLU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchPlant, 3, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "PLANT")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      @dtw_assign(uv_PlantName, "PLPLNT")
                      @dtw_assign(uv_CompanyName, "PLCO#")
                      @dtw_assign(uv_FacilityName, "PLFAC#")
                      @dtw_assign(uv_ScheduleName, "PLSCHD")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select PLPLNT, PLNAME, PLCO#, PLFAC#, PLADR1, PLCITY, PLST, PLZIP, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(PLNAME) as PLNAMEU, " , stmtSQL)
                      @dtw_concat(stmtSQL, " upper(PLADR1) as PLADR1U, " , stmtSQL)
                      @dtw_concat(stmtSQL, " upper(PLCITY) as PLCITYU " , stmtSQL)
                      @dtw_concat(fileSQL, " HDPLNT ", fileSQL)
                      %if (wildCardSearch!="" || uv_Sql != "")
                          @dtw_concat(selectSQL, "PLPLNT>0 ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Plant_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Plant_Query (IN CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count != "1")
          <table $(contentTable)>
              <colgroup>
                 <col width="80%">
                 <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                      <td class="toolbar">
                          %if (sec_01 == "Y")
                              <a href="$(homeURL)$(cGIPath)plantmaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"

          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Name</th>
                          <th class="colhdr">Plant</th>
                      </tr>
                      <tr>
                          <td><input type="text" class="inputalph" name="srchName" size="26" maxlength="26">
                              <input type="hidden" name="operName" value="LIKE">
                          </td>
                          <td><input type="text" class="inputnmbr" name="srchPlant" size="3" maxlength="3">
                              <input type="hidden" name="operPlant" value="=">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchName.focus();
                  </script>
              </form>

              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              <tr>
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("PLPLNT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=number" title="Sequence By Plant"> Plant</a></th>
                  @OrderBy_Sort("PLNAMEU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=name" title="Sequence By Name, Plant"> Name</a></th>
                  @OrderBy_Sort("PLCO#", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=coFac" title="Sequence By Company/Facility, Name, Plant"> Co/Fac</a></th>
                  @OrderBy_Sort("PLADR1U", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=address" title="Sequence By Address, Name, Plant"> Address</a></th>
                  @OrderBy_Sort("PLCITYU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=city" title="Sequence By City, Name, Plant"> City</a></th>
                  @OrderBy_Sort("PLST", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=state" title="Sequence By State, Name, Plant"> State</a></th>
                  @OrderBy_Sort("PLZIP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=zipCode" title="Sequence By Zip, Name, Plant"> Zip</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %endif

              %ROW{
                  %if (sql_Record_Count == "1")
                      @Save_WebReg(webRegCurFile, profileHandle, d2wName, "", orderBy, orderByDisplay, "")
                      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(V_PLPLNT)&amp;plantName=@dtw_rurlescseq(V_PLNAME)">
                  %else
                      @dtw_assign(maintainVar, "$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(V_PLPLNT)&amp;plantName=@dtw_rurlescseq(V_PLNAME)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
                      %INCLUDE "SetRowClass.icl"
                      @Format_Confirm_Desc($(V_PLNAME), $(V_PLPLNT), "", "", "", "", confirmDesc)

                      <tr class="$(rowClass)">
                          %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                              <td class="opticon">
                                  %if (sec_02 == "Y" || sec_03 == "Y")
                                      <a href="$(homeURL)$(cGIPath)plantmaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                                  %endif
                                  %if (sec_04 == "Y")
                                      <a href="$(homeURL)$(cGIPath)plantmaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                                  %endif
                                  %if (sec_03 == "Y")
                                      <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)plantmaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                                  %endif
                              </td>
                          %endif
                          <td class="colnmbr">$(V_PLPLNT)</td>
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(maintainVar)" title="View Plant">$(V_PLNAME)</a></td>
                          @Format_CoFac("$(V_PLCO#)", "$(V_PLFAC#)", "", F_CoFac)
                          <td class="colnmbr">$(F_CoFac)</td>
                          <td class="colalph">$(V_PLADR1)</td>
                          <td class="colalph">$(V_PLCITY)</td>
                          <td class="colcode">$(V_PLST)</td>
                          <td class="colalph">$(V_PLZIP)</td>
                      </tr>
                  %endif
              %}
          </table>
          %if (sql_Record_Count != "1")
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  @dtw_assign(uv_PlantName, "PLPLNT")
  %INCLUDE "userview.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select PLPLNT, PLNAME, PLCO#, PLFAC#, PLADR1, PLCITY, PLST, PLZIP, ", stmtSQL)
  @dtw_concat(stmtSQL, " upper(PLNAME) as PLNAMEU, " , stmtSQL)
  @dtw_concat(stmtSQL, " upper(PLADR1) as PLADR1U, " , stmtSQL)
  @dtw_concat(stmtSQL, " upper(PLCITY) as PLCITYU " , stmtSQL)
  @dtw_concat(fileSQL, " HDPLNT ", fileSQL)
  %if (wildCardSearch!="" || uv_Sql != "")
      @dtw_concat(selectSQL, "PLPLNT>0 ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @Plant_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) Plant_XMLQuery (IN  CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("PlantList")
          %ROW{
              @XMLIDTag(V_PLPLNT, "Plant ID")
                  @XMLTag(V_PLPLNT, "Plant")
                  @XMLTag(V_PLNAME, "Name")
                  @XMLTag(V_PLCO#, "Company")
                  @XMLTag(V_PLFAC#, "Facility")
                  @XMLTag(V_PLADR1, "Address")
                  @XMLTag(V_PLCITY, "City")
                  @XMLTag(V_PLST, "State")
                  @XMLTag(V_PLZIP, "Zip")
              @XMLEndTag("Plant")
          %}
      @XMLEndTag("PlantList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "PLNAMEU,PLPLNT")
          @DTW_ASSIGN(orderByDisplay, "Name, Plant")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "number")
      %if (orderBy == "PLPLNT")
          @DTW_ASSIGN(orderBy, "PLPLNT DESC")
          @DTW_ASSIGN(orderByDisplay, "Plant (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PLPLNT")
          @DTW_ASSIGN(orderByDisplay, "Plant")
      %endif
  %elseif (sequence == "name")
      %if (orderBy == "PLNAMEU,PLPLNT")
          @DTW_ASSIGN(orderBy, "PLNAMEU DESC,PLPLNT")
          @DTW_ASSIGN(orderByDisplay, "Name (descending), Plant")
      %else
          @DTW_ASSIGN(orderBy, "PLNAMEU,PLPLNT")
          @DTW_ASSIGN(orderByDisplay, "Name, Plant")
      %endif
  %elseif (sequence == "coFac")
      %if (orderBy == "PLCO#,PLFAC#,PLNAMEU,PLPLNT")
          @DTW_ASSIGN(orderBy, "PLCO# DESC,PLFAC# DESC,PLNAMEU,PLPLNT")
          @DTW_ASSIGN(orderByDisplay, "Company/Facility (descending), Name, Plant")
      %else
          @DTW_ASSIGN(orderBy, "PLCO#,PLFAC#,PLNAMEU,PLPLNT")
          @DTW_ASSIGN(orderByDisplay, "Company/Facility, Name, Plant")
      %endif
  %elseif (sequence == "address")
      %if (orderBy == "PLADR1U,PLNAMEU,PLPLNT")
          @DTW_ASSIGN(orderBy, "PLADR1U DESC,PLNAMEU,PLPLNT")
          @DTW_ASSIGN(orderByDisplay, "Address (descending), Name, Plant")
      %else
          @DTW_ASSIGN(orderBy, "PLADR1U,PLNAMEU,PLPLNT")
          @DTW_ASSIGN(orderByDisplay, "Address, Name, Plant")
      %endif
  %elseif (sequence == "city")
      %if (orderBy == "PLCITYU,PLNAMEU,PLPLNT")
          @DTW_ASSIGN(orderBy, "PLCITYU DESC,PLNAMEU,PLPLNT")
          @DTW_ASSIGN(orderByDisplay, "City (descending), Name, Plant")
      %else
          @DTW_ASSIGN(orderBy, "PLCITYU,PLNAMEU,PLPLNT")
          @DTW_ASSIGN(orderByDisplay, "City, Name, Plant")
      %endif
  %elseif (sequence == "state")
      %if (orderBy == "PLST,PLNAMEU,PLPLNT")
          @DTW_ASSIGN(orderBy, "PLST DESC,PLNAMEU,PLPLNT")
          @DTW_ASSIGN(orderByDisplay, "State (descending), Name, Plant")
      %else
          @DTW_ASSIGN(orderBy, "PLST,PLNAMEU,PLPLNT")
          @DTW_ASSIGN(orderByDisplay, "State, Name, Plant")
      %endif
  %elseif (sequence == "zipCode")
      @DTW_ASSIGN(orderBy, "PLZIP,PLNAMEU,PLPLNT")
      %if (orderBy == "PLZIP,PLNAMEU,PLPLNT")
          @DTW_ASSIGN(orderBy, "PLZIP DESC,PLNAMEU,PLPLNT")
          @DTW_ASSIGN(orderByDisplay, "Zip (descending), Name, Plant")
      %else
          @DTW_ASSIGN(orderBy, "PLZIP,PLNAMEU,PLPLNT")
          @DTW_ASSIGN(orderByDisplay, "Zip, Name, Plant")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchCo, 2, 0) &&
                      editNum(document.Search.srchFac, 4, 0) &&
                      editNum(document.Search.srchSchedule, 3, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PLANTSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Plant Number</td>
                              @dtw_assign(operNbr, "operPlant")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchPlant" size="5" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Plant Name</td>
                              @dtw_assign(operNbr, "operName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchName" size="26" maxlength="26"></td>
                          </tr>

                          <tr><td class="dsphdr">Company</td>
                              @dtw_assign(operNbr, "operCo")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchCo" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Facility</td>
                              @dtw_assign(operNbr, "operFac")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchFac" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Address</td>
                              <td>&nbsp;</td>
                              <td class="inputalph"> <input type="text" name="srchAddress" size="26" maxlength="26"></td>
                          </tr>

                          <tr><td class="dsphdr">State</td>
                              @dtw_assign(operNbr, "operState")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchState" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Zip</td>
                              @dtw_assign(operNbr, "operZip")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchZip" size="14" maxlength="14"></td>
                          </tr>

                          <tr><td class="dsphdr">Country</td>
                              @dtw_assign(operNbr, "operCountry")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCountry" size="3" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Schedule</td>
                              @dtw_assign(operNbr, "operSchedule")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchSchedule" size="3" maxlength="3"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchPlant.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("PLPLNT", "Plant Number", $(srchPlant), "", operPlant, "N")
  @Build_WildCard ("upper(PLNAME)", "Plant Name", $(srchName), "U", operName, "A")
  @Build_WildCard ("PLCO#", "Company", $(srchCo), "", operCo, "N")
  @Build_WildCard ("PLFAC#", "Facility", $(srchFac), "", operFac, "N")

  @dtw_assign(srchAddress,@dtw_rstrip(srchAddress))
  %if (srchAddress != "")
      @Build_WildCard ("PLADR1", "Address", $(srchAddress), "U", "LIKE", "V")
      @dtw_mUPPERCASE(srchAddress)
      @dtw_replace(srchAddress, "?", "_", "1", "a", srchAddress)
      @dtw_replace(srchAddress, "*", "%", "1", "a", srchAddress)
      @dtw_concat(wildCardTemp, " (trim(upper(PLADR1)) LIKE '$(srchAddress)'", wildCardTemp)
      @dtw_concat(wildCardTemp, " OR   trim(upper(PLADR2)) LIKE '$(srchAddress)'", wildCardTemp)
      @dtw_concat(wildCardTemp, " OR   trim(upper(PLCITY)) LIKE '$(srchAddress)')", wildCardTemp)
  %endif
		
  @Build_WildCard ("PLST", "State", $(srchState), "U", operState, "A")
  @Build_WildCard ("PLZIP", "Zip", $(srchZip), "U", operZip, "A")
  @Build_WildCard ("PLCTRY", "Country", $(srchCountry), "U", operCountry, "A")
  @Build_WildCard ("PLSCHD", "Schedule", $(srchSchedule), "", operSchedule, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
