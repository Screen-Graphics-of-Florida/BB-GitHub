%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Employee Property Maintenance"
  d2wName                 = "EmplPropertyMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)$(employeeVarBase)&amp;sequenceNumber=@dtw_rurlescseq(sequenceNumber)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;delD2w=@dtw_rurlescseq(delD2w)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;propertyType=@dtw_rurlescseq(propertyType)&amp;propertyDesc=@dtw_rurlescseq(propertyDesc)&amp;maintenanceCode=D"
  programName             = "HPEPRO"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  hrCodeType              = "N"
  updateError             = " "
  applicationID           = "PE"
  propertyType            = " "
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
  @dtw_replace(workURL, "@@sequenceNumber", "@dtw_rurlescseq(sequenceNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@fromD2w", "@dtw_rurlescseq(fromD2w)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	      %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                      if (document.Chg.propertyType.value =="" ||
                          document.Chg.issueDate.value =="" ||
                          document.Chg.renewalDate.value =="" ||
                          document.Chg.propertyDesc.value =="")
                         {alert("$(reqFieldError)"); return false;}
                      if (editdate(document.Chg.issueDate) &&
                          editdate(document.Chg.renewalDate))
                      return true;
                  }
              function confirmDelete() {return confirm("$(delRecordConf)")}
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->

              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "PROPMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                          @dtw_concat(stmtSQL, "SELECT * FROM PEPROP WHERE PRCOMP = $(hrCompany) AND PREMPL = $(hrEmployee) AND PRSEQ = $(sequenceNumber)", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
  %}

%FUNCTION(dtw_sql) Maintain_Query (IN  CHAR(64)    profileHandle,
				        CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      <table $(contentTable)>
	   <colgroup>
	       <col width="80%">
	       <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  <form class="formClass" METHOD=POST NAME="EmployeeCopyTo" ACTION="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;maintenanceCode=Z">
                      <input name="prCompanyCopyTo" type="hidden" size="2"><input name="prFacilityCopyTo" type="hidden" size="4"><input name="prEmployeeCopyTo" type="hidden" size="5"><input name="hrCompanyCopyTo" type="hidden" size="2"><input name="hrEmployeeCopyTo" type="hidden" size="9">
                  </form>
                  %if (sec_01=="Y" && sec_04=="Y" && maintenanceCode != "A")
               
                  %endif
                  %INCLUDE "MaintainTopNoTable.icl"
              </td>
          </tr>
          %if (prCompanyCopyTo>"0")
              @dtw_assign(prCompany, prCompanyCopyTo)
              @dtw_assign(prFacility, prFacilityCopyTo)
              @dtw_assign(prEmployee, prEmployeeCopyTo)
              @dtw_assign(hrCompany, hrCompanyCopyTo)
              @dtw_assign(hrEmployee, hrEmployeeCopyTo)
          %endif
          @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
          <tr><td><h2>$(F_EmpName)</h2></td></tr>
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "propertyType")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)

                          @DecatErr_Field("@@typr", "propertyType")  @dtw_assign(Err_PRTYPR, fieldValue)
                          @DecatErr_Field("@@desc", "propertyDesc")  @dtw_assign(Err_PRDESC, fieldValue)
                          @DecatErr_Field("@@issu", "issueDate")     @dtw_assign(Err_PRISSU, fieldValue)
                          @DecatErr_Field("@@renw", "renewalDate")   @dtw_assign(Err_PRRENW, fieldValue)
                          @DecatErr_Field("@@tstp", "timeStamp")     @dtw_assign(Err_TSTP, fieldValue)
                      %endif
                      @Decat_Field("@@typr")   @dtw_assign(V_PRTYPR, fieldValue)
                      @Decat_Field("@@desc")   @dtw_assign(V_PRDESC, fieldValue)
                      @Decat_Field("@@issu")   @dtw_assign(V_PRISSU, fieldValue)
                      @Decat_Field("@@renw")   @dtw_assign(V_PRRENW, fieldValue)
                      @Decat_Field("@@tstp")   @dtw_assign(V_PRTSTP, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(V_PRCOMP,   "00")
                          @dtw_assign(V_PRFACL,  "0000")
                          @dtw_assign(V_PREMPL, "000000000")
                          @dtw_assign(V_PRSEQ, "00")
                          @dtw_assign(V_PRISSU, "0")
                          @dtw_assign(V_PRRENW, "0")
                          @dtw_assign(focusField, "propertyType")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      %if (prCompanyCopyTo<="0")
                          @dtw_assign(V_PRTYPR, "")
                      %endif
                      @dtw_assign(focusField, "propertyType")
                      @DateInputFromCYMD(V_PRISSU)
                      @DateInputFromCYMD(V_PRRENW)
                  %else
                      @dtw_assign(focusField, "propertyDesc")
                      @DateInputFromCYMD(V_PRISSU)
                      @DateInputFromCYMD(V_PRRENW)
                  %endif

                  @RtvFldDesc("ODCOMP=$(V_PRCOMP) and ODTYPE='$(hrCodeType)' and ODCODE='$(V_PRTYPR)' ", "PECODE", "CHAR(ODDESC)", codeDesc)
              	  @SetTextOvr(Err_TSTP)
                  <tr><td class="dsphdr"><span $(textOvr)>.</span></td>
                  	  <td><input name="timeStamp" type="hidden" value="$(V_PRTSTP)"></td> 
                  </tr>
                  @DspErrMsg(Err_TSTP)
                  
                  @SetTextOvr(Err_PRTYPR)
                  <tr><td class="dsphdr"><span $(textOvr)>Property Type</span></td>
                      <td class="inputalph"><input name="propertyType" type="text" value="$(V_PRTYPR)" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Chg&amp;fldComp=@dtw_rurlescseq(hrCompany)&amp;fldType=N&amp;fldName=propertyType&amp;fldDesc=PropertyCodeDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="PropertyCodeDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                  </tr>
                  @DspErrMsg(Err_PRTYPR)

                  @SetTextOvr(Err_PRDESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Property Description</span></td>
                      <td class="inputalph"><input name="propertyDesc" type="text" value="$(V_PRDESC)" size="30" maxlength="30"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_PRDESC)

                  @SetTextOvr(Err_PRISSU)
	           <tr><td class="dsphdr"><span $(textOvr)>Issue Date</span></td>
                      <td class="inputnmbr"><input type="text" name="issueDate" value="$(V_PRISSU)" size="6" maxlength="6"> 		
                          <a href="javascript:calWindow('issueDate');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_PRISSU)

                  @SetTextOvr(Err_PRRENW)
                  <tr><td class="dsphdr"><span $(textOvr)>Renewal Date</span></td>
                      <td class="inputnmbr"><input name="renewalDate" type="text" value="$(V_PRRENW)" size="6" maxlength="6">
                          <a href="javascript:calWindow('renewalDate');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_PRRENW)
              %}
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                                 INOUT CHAR(2)     dataBaseID,
                                                 INOUT CHAR(1)     maintenanceCode,
                                                 INOUT CHAR(1)     errFound,
                                                 INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar,
                                        INOUT DEC(4,0)    seqWork)
  {%EXEC {HPEPRO_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @hrCode_Query(profileHandle, dataBaseID, hrCompany, hrCodeType, hrCodeTable)	
	   @dtw_tb_insertrow(hrCodeTable, "0", "1")
          @dtw_tb_setv(hrCodeTable, "", "1", "2")
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(issueDate,@dtw_rstrip(issueDate))
  @dtw_assign(renewalDate,@dtw_rstrip(renewalDate))

  @dtw_assign(updateError, " ")

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  %if (maintenanceCode == "A")
      @dtw_assign(sequenceNumber, "0")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@comp", hrCompany)
  @Concat_Field("@@facl", prFacility)
  @Concat_Field("@@empl", hrEmployee)
  @Concat_Field("@@seq@", sequenceNumber)
  @Concat_Field("@@typr", propertyType)
  @Concat_Field("@@desc", propertyDesc)
  @Concat_Field("@@issu", issueDate)
  @Concat_Field("@@renw", renewalDate)
  @Concat_Field("@@tstp", timeStamp)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar, seqWork)

  @RtvFldDesc("ODCOMP=$(hrCompany) and ODTYPE='N' and ODCODE='$(propertyType)' ", "PECODE", "ODDESC", HrCodeDesc)
  @DecatErr_Field("@@typr", "propertyType")  @dtw_assign(Err_PRTYPR, fieldValue)
  
  %if (errFound == "")
      @dtw_assign(sequenceNumber, seqWork)
      @Format_ConfMsg_Desc(maintenanceCode, "Description ", $(propertyDesc), $(HrCodeDesc), $(propertyType), "", "", confMessage)
      %if (maintenanceCode == "D")
          %if ((fromD2w != "") && (fromD2w != "EmplPropertySelect.d2w"))
              <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %else
              <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)employeeProperty.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
          %endif
      %elif (fromD2w != "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;propertyType=@dtw_rurlescseq(propertyType)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)employeeProperty.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@typr", "propertyType")
      @Format_ConfMsg_Desc(maintenanceCode, "Description ", $(propertyDesc), $(HrCodeDesc), $(propertyType), "<br>$(fieldValue)", "", confMessage)
      %if (fromD2w != "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)employeeProperty.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %elif ((maintenanceCode == "C" || maintenanceCode == "D") && errFound != "" && fieldValue != "")
      @DecatErr_Field("@@typr", "propertyType")
      @Format_ConfMsg_Desc("E", "Description" , $(propertyDesc), $(HrCodeDesc), $(propertyType), "<br>$(fieldValue)", "", confMessage)
      %if (fromD2w != "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)employeeProperty.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;propertyType=@dtw_rurlescseq(propertyType)&amp;errFound=@dtw_rurlescseq(errFound)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}