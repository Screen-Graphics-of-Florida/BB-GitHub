%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Price Override Report"
  d2wName                 = "PriceOverrideReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromLocation, 3, 0) &&
                      editNum(document.Chg.toLocation, 3, 0) &&
                      editdate(document.Chg.fromRequiredDate) &&
                      editdate(document.Chg.toRequiredDate) &&
                      editFromToAll(document.Chg.fromLocation, document.Chg.toLocation, document.Chg.allLocation, 3) &&
                      editFromToAll(document.Chg.fromRequiredDate, document.Chg.toRequiredDate, document.Chg.allRequiredDate, "D"))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PRICEOVERRIDEREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromLocation")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)

                                  @DecatErr_Field("@@floc", "fromLocation")     @dtw_assign(Err_FLOC#,  fieldValue)
                                  @DecatErr_Field("@@tloc", "toLocation")       @dtw_assign(Err_TLOC#,  fieldValue)
                                  @DecatErr_Field("@@aloc", "allLocation")      @dtw_assign(Err_ALOC#,  fieldValue)
                                  @DecatErr_Field("@@fdat", "fromRequiredDate")     @dtw_assign(Err_FDATE,  fieldValue)
                                  @DecatErr_Field("@@tdat", "toRequiredDate")       @dtw_assign(Err_TDATE,  fieldValue)
                                  @DecatErr_Field("@@adat", "allRequiredDate")      @dtw_assign(Err_ADATE,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}

                                  @Decat_Field("@@floc")   @dtw_assign(V_FLOC#,  fieldValue)
                                  @Decat_Field("@@tloc")   @dtw_assign(V_TLOC#,  fieldValue)
                                  @Decat_Field("@@aloc")   @dtw_assign(V_ALOC#,  fieldValue)
                                  @Decat_Field("@@fdat")   @dtw_assign(V_FDATE,  fieldValue)
                                  @Decat_Field("@@tdat")   @dtw_assign(V_TDATE,  fieldValue)
                                  @Decat_Field("@@adat")   @dtw_assign(V_ADATE,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}

                                  %if (V_ALOC# == "ALL")
                                      @dtw_assign(checkedallLocation, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallLocation, "")
                                  %endif
                                  %if (V_ADATE == "ALL")
                                      @dtw_assign(checkedallRequiredDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallRequiredDate, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedallLocation, "CHECKED")
                                  @dtw_assign(checkedallRequiredDate, "CHECKED")
                              %endif
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_FLOC#)
                              %if (textOvr == "") @SetTextOvr(Err_TLOC#) %endif
                              %if (textOvr == "") @SetTextOvr(Err_ALOC#) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Location Number</span></td>
                                  <td class="inputnmbr"><input name="fromLocation" value="$(V_FLOC#)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)LocationSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromLocation&amp;fldDesc=flocDesc" onclick="$(searchWinVar)">$(searchImage) </a> <input name="flocDesc" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toLocation" value="$(V_TLOC#)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)LocationSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toLocation&amp;fldDesc=tlocDesc" onclick="$(searchWinVar)">$(searchImage) </a> <input name="tlocDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allLocation" value='ALL' $(checkedallLocation) type="checkbox" onClick="if (this.checked) this.form.fromLocation.value='', this.form.toLocation.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_FLOC#)
                              @DspErrMsg(Err_TLOC#)
                              @DspErrMsg(Err_ALOC#)

                              @SetTextOvr(Err_FDATE)
                              %if (textOvr == "") @SetTextOvr(Err_TDATE) %endif
                              %if (textOvr == "") @SetTextOvr(Err_ADATE) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Required Date</span></td>
                                  <td class="inputnmbr"><input name="fromRequiredDate" value="$(V_FDATE)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromRequiredDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toRequiredDate" value="$(V_TDATE)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toRequiredDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allRequiredDate" value='ALL' $(checkedallRequiredDate) type="checkbox" onClick="if (this.checked) this.form.fromRequiredDate.value='', this.form.toRequiredDate.value='';"></td>
                              </tr>  			
                              @DspErrMsg(Err_FDATE)
                              @DspErrMsg(Err_TDATE)
                              @DspErrMsg(Err_ADATE)
                          </table>

                          @dtw_assign(envProgram, "HOEPOR")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HOESPO_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allLocation)
  @dtw_mUPPERCASE(allRequiredDate)

  @dtw_assign(fromLocation,@dtw_rstrip(fromLocation))
  @dtw_assign(toLocation,@dtw_rstrip(toLocation))
  @dtw_assign(fromRequiredDate,@dtw_rstrip(fromRequiredDate))
  @dtw_assign(toRequiredDate,@dtw_rstrip(toRequiredDate))

  %if (allLocation != "ALL")
      @dtw_assign(allLocation, "")
  %endif

  %if (allRequiredDate != "ALL")
      @dtw_assign(allRequiredDate, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@floc", fromLocation)
  @Concat_Field("@@tloc", toLocation)
  @Concat_Field("@@aloc", allLocation)
  @Concat_Field("@@fdat", fromRequiredDate)
  @Concat_Field("@@tdat", toRequiredDate)
  @Concat_Field("@@adat", allRequiredDate)
  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}