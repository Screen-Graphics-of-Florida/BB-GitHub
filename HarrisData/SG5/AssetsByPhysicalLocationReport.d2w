%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Assets By Physical Location Report"
  d2wName                 = "AssetsByPhysicalLocationReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "4"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if ((document.Chg.schedule.value =="") || (document.Chg.schedule.value =="0"))
                     {alert("$(reqFieldError)");
                      document.Chg.schedule.focus();
                      document.Chg.schedule.select();
                      return false;}

                  if (document.Chg.allAssetAccount.checked == true &&
                     (document.Chg.fromAccount.value > "" ))
                     {alert("From and to values are not valid with all selection");
                     document.Chg.fromAccount.focus();
                     document.Chg.fromAccount.select();
                     return false;}

                  if (document.Chg.allAssetAccount.checked == true &&
                     (document.Chg.fromSubaccount.value > "" ))
                     {alert("From and to values are not valid with all selection");
                     document.Chg.fromSubaccount.focus();
                     document.Chg.fromSubaccount.select();
                     return false;}

                  if (document.Chg.allAssetAccount.checked == true &&
                     (document.Chg.toAccount.value > "" ))
                     {alert("From and to values are not valid with all selection");
                     document.Chg.toAccount.focus();
                     document.Chg.toAccount.select();
                     return false;}

                  if (document.Chg.allAssetAccount.checked == true &&
                     (document.Chg.toSubaccount.value > "" ))
                     {alert("From and to values are not valid with all selection");
                     document.Chg.toSubaccount.focus();
                     document.Chg.toSubaccount.select();
                     return false;}

                  if (document.Chg.allAssetAccount.checked == false &&
                     (document.Chg.fromAccount.value == "" && document.Chg.toAccount.value == "" && document.Chg.fromSubaccount.value == "" && document.Chg.toSubaccount.value == ""))
                     {alert("From to and all selections are all blank");
                     document.Chg.fromAccount.focus();
                     document.Chg.fromAccount.select();
                     return false;}

                  if (editNum(document.Chg.schedule, 2, 0) &&
                      editNum(document.Chg.fromSite, 3, 0) &&
                      editNum(document.Chg.toSite, 3, 0) &&
                      editNum(document.Chg.fromAssetNumber, 12, 0) &&
                      editNum(document.Chg.toAssetNumber, 12, 0) &&
                      editNum(document.Chg.fromAccount, 4, 0) &&
                      editNum(document.Chg.toAccount, 4, 0) &&
                      editNum(document.Chg.fromSubaccount, 4, 0) &&
                      editNum(document.Chg.toSubaccount, 4, 0) &&
                      editNum(document.Chg.fromPhysicalLocation, 3, 0) &&
                      editNum(document.Chg.toPhysicalLocation, 3, 0) &&
                      editFromToAll(document.Chg.fromSite, document.Chg.toSite, document.Chg.allSite, 3) &&
                      editFromToAll(document.Chg.fromAssetNumber, document.Chg.toAssetNumber, document.Chg.allAssetNumber, 12) &&
                      editFromToAll(document.Chg.fromPhysicalLocation, document.Chg.toPhysicalLocation, document.Chg.allPhysicalLocation, 3)
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ASSETSBYPHYSICALLOCATIONREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
                      %INCLUDE "RequiredField.icl"
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "schedule")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@schd", "schedule") @dtw_assign(Err_SCHED,  fieldValue)
                                  @DecatErr_Field("@@ssit", "sortSite")        @dtw_assign(Err_N1SSIT,  fieldValue)
                                  @DecatErr_Field("@@sast", "sortAssetNumber")        @dtw_assign(Err_N1SAST,  fieldValue)
                                  @DecatErr_Field("@@fact", "fromAssetAccount")        @dtw_assign(Err_N1FACT,  fieldValue)
                                  @DecatErr_Field("@@sact", "sortAssetAccount")        @dtw_assign(Err_N1SACT,  fieldValue)
                                  @DecatErr_Field("@@sloc", "sortPhysicalLocation")        @dtw_assign(Err_N1SLOC,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@schd")  @dtw_assign(V_SCHED,  fieldValue)
                                  @Decat_Field("@@fsit")  @dtw_assign(V_N1FSIT,  fieldValue)
                                  @Decat_Field("@@tsit")  @dtw_assign(V_N1TSIT,  fieldValue)
                                  @Decat_Field("@@asit")  @dtw_assign(V_N1ASIT,  fieldValue)
                                  @Decat_Field("@@ssit")  @dtw_assign(V_N1SSIT,  fieldValue)
                                  @Decat_Field("@@psit")  @dtw_assign(V_N1PSIT,  fieldValue)
                                  @Decat_Field("@@fast")  @dtw_assign(V_N1FAST,  fieldValue)
                                  @Decat_Field("@@tast")  @dtw_assign(V_N1TAST,  fieldValue)
                                  @Decat_Field("@@aast")  @dtw_assign(V_N1AAST,  fieldValue)
                                  @Decat_Field("@@sast")  @dtw_assign(V_N1SAST,  fieldValue)
                                  @Decat_Field("@@past")  @dtw_assign(V_N1PAST,  fieldValue)
                                  @Decat_Field("@@fact")  @dtw_assign(V_N1FACT,  fieldValue)
                                  @Decat_Field("@@fsub")  @dtw_assign(V_N1FSUB,  fieldValue)
                                  @Decat_Field("@@tact")  @dtw_assign(V_N1TACT,  fieldValue)
                                  @Decat_Field("@@tsub")  @dtw_assign(V_N1TSUB,  fieldValue)
                                  @Decat_Field("@@aact")  @dtw_assign(V_N1AACT,  fieldValue)
                                  @Decat_Field("@@sact")  @dtw_assign(V_N1SACT,  fieldValue)
                                  @Decat_Field("@@pact")  @dtw_assign(V_N1PACT,  fieldValue)
                                  @Decat_Field("@@floc")  @dtw_assign(V_N1FLOC,  fieldValue)
                                  @Decat_Field("@@tloc")  @dtw_assign(V_N1TLOC,  fieldValue)
                                  @Decat_Field("@@aloc")  @dtw_assign(V_N1ALOC,  fieldValue)
                                  @Decat_Field("@@sloc")  @dtw_assign(V_N1SLOC,  fieldValue)
                                  @Decat_Field("@@ploc")  @dtw_assign(V_N1PLOC,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1ASIT == "ALL")
                                      @dtw_assign(checkedAllSite, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllSite, "")
                                  %endif
                                  %if (V_N1AAST == "ALL")
                                      @dtw_assign(checkedAllAssetNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllAssetNumber, "")
                                  %endif
                                  %if (V_N1AACT == "ALL")
                                      @dtw_assign(checkedAllAssetAccount, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllAssetAccount, "")
                                  %endif
                                  %if (V_N1ALOC == "ALL")
                                      @dtw_assign(checkedAllPhysicalLocation, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllPhysicalLocation, "")
                                  %endif

                                  %if (V_N1PSIT == "Y")
                                      @dtw_assign(checkedSiteTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedSiteTotals, "")
                                  %endif
                                  %if (V_N1PAST == "Y")
                                      @dtw_assign(checkedAssetNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAssetNumberTotals, "")
                                  %endif
                                  %if (V_N1PACT == "Y")
                                      @dtw_assign(checkedAssetAccountTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAssetAccountTotals, "")
                                  %endif
                                  %if (V_N1PLOC == "Y")
                                      @dtw_assign(checkedPhysicalLocationTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedPhysicalLocationTotals, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedAllSite, "CHECKED")
                                  @dtw_assign(checkedAllAssetNumber, "CHECKED")
                                  @dtw_assign(checkedAllAssetAccount, "CHECKED")
                                  @dtw_assign(checkedAllPhysicalLocation, "CHECKED")
                              %endif

                              @Default_Zero(V_SCHED)
                              @RtvFldDesc("SMSCHD=$(V_SCHED)", "FASCHD", "SMDESC", V_N1SCDD)
                              @SetTextOvr(Err_SCHED)
                              <tr><td align=right class="dsphdr"><span $(textOvr)>Schedule</td>
                                  <td class="inputnmbr"><input type="text" name="schedule" value="$(V_SCHED)" size="2" maxlength="2">$(reqFieldChar)
                                                        <a href="$(homeURL)$(cGIPath)AssetScheduleSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=schedule&amp;fldDesc=scheduleDescription" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="text" disabled name="scheduleDescription" value="$(V_N1SCDD)" size="30"></td>
                              </tr>
                              @DspErrMsg(Err_SCHED)
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                                  <td class="colhdr">Print<br>Totals</td>
                              </tr>

                              @SetTextOvr(Err_N1FSIT)
                              <tr><td class="dsphdr"><span $(textOvr)>Site</td>
                                  <td class="inputnmbr"><input type="text" name="fromSite" value="$(V_N1FSIT)" size="12" maxlength="3">
                                                        <a href="$(homeURL)$(cGIPath)FASiteSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromSite&amp;fldDesc=frDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="hidden" name="frDesc"></td>
                                  <td class="inputnmbr"><input type="text" name="toSite" value="$(V_N1TSIT)" size="12" maxlength="3">
                                                        <a href="$(homeURL)$(cGIPath)FASiteSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toSite&amp;fldDesc=toDesc" onclick="$(searchWinVar)">$(searchImage) </a>
                                                        <input type="hidden" name="toDesc"></td>
                                  <td class="inputalph"><input type="checkbox" name="allSite" value='ALL' $(checkedAllSite) onClick="if (this.checked) this.form.fromSite.value='', this.form.toSite.value='';"></td>
                                  @Build_Sort_Select("sortSite", "$(V_N1SSIT)")
                                  <td align=center ><input type="checkbox" name="totalSite" $(checkedSiteTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1SSIT)

                              @SetTextOvr(Err_N1FAST)
                              <tr><td class="dsphdr"><span $(textOvr)>Asset Number </span></td>
                                  <td class="inputnmbr"><input type="text" name="fromAssetNumber" value="$(V_N1FAST)" size="12" maxlength="12"></td>
                                  <td class="inputnmbr"><input type="text" name="toAssetNumber" value="$(V_N1TAST)" size="12" maxlength="12"></td>
                                  <td class="inputalph"><input type="checkbox" name="allAssetNumber" value='ALL' $(checkedAllAssetNumber) onClick="if (this.checked) this.form.fromAssetNumber.value='', this.form.toAssetNumber.value='';"></td>
                                  @Build_Sort_Select("sortAssetNumber", "$(V_N1SAST)")
                                  <td align=center ><input type="checkbox" name="totalAssetNumber" $(checkedAssetNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1SAST)

                              @SetTextOvr(Err_N1FACT)
                              %if (textOvr == "") @SetTextOvr(Err_N1SACT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Asset Account</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromAccount" value="$(V_N1FACT)" size="4" maxlength="4"> - <input type="text" name="fromSubaccount" value="$(V_N1FSUB)" size="4" maxlength="4">
                                                        <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=fromAccount&amp;subFld=fromSubaccount&amp;descFld=accDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                                                        <input type="hidden" name="accDesc"></td>
                                  <td class="inputnmbr"><input type="text" name="toAccount" value="$(V_N1TACT)" size="4" maxlength="4"> - <input type="text" name="toSubaccount" value="$(V_N1TSUB)" size="4" maxlength="4">
                                                        <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=toAccount&amp;subFld=toSubaccount&amp;descFld=accDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                                                        <input type="hidden" name="accDesc"></td>
                                  <td class="inputalph"><input type="checkbox" name="allAssetAccount" value='ALL' $(checkedAllAssetAccount) onClick="if (this.checked) this.form.fromAccount.value='', this.form.fromSubaccount.value='', this.form.toAccount.value='', this.form.toSubaccount.value='';"></td>
                                  @Build_Sort_Select("sortAssetAccount", "$(V_N1SACT)")
                                  <td align=center ><input type="checkbox" name="totalAssetAccount" $(checkedAssetAccountTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1FACT)
                              @DspErrMsg(Err_N1SACT)

                              @SetTextOvr(Err_N1FLOC)
                              <tr><td class="dsphdr"><span $(textOvr)>Physical Location</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromPhysicalLocation" value="$(V_N1FLOC)" size="12" maxlength="3"></td>
                                  <td class="inputnmbr"><input type="text" name="toPhysicalLocation" value="$(V_N1TLOC)" size="12" maxlength="3"></td>
                                  <td class="inputalph"><input type="checkbox" name="allPhysicalLocation" value='ALL' $(checkedAllPhysicalLocation) onClick="if (this.checked) this.form.fromPhysicalLocation.value='', this.form.toPhysicalLocation.value='';"></td>
                                  @Build_Sort_Select("sortPhysicalLocation", "$(V_N1SLOC)")
                                  <td align=center ><input type="checkbox" name="totalPhysicalLocation" $(checkedPhysicalLocationTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1SLOC)

                          </table>

                          @dtw_assign(envProgram, "HFALAR")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HFALAS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allSite)
  @dtw_mUPPERCASE(allAssetNumber)
  @dtw_mUPPERCASE(allAssetAccount)
  @dtw_mUPPERCASE(allPhysicalLocation)

  @dtw_assign(schedule,@dtw_rstrip(schedule))
  @dtw_assign(fromSite,@dtw_rstrip(fromSite))
  @dtw_assign(toSite,@dtw_rstrip(toSite))
  @dtw_assign(sortSite,@dtw_rstrip(sortSite))
  @dtw_assign(fromAssetNumber,@dtw_rstrip(fromAssetNumber))
  @dtw_assign(toAssetNumber,@dtw_rstrip(toAssetNumber))
  @dtw_assign(sortAssetNumber,@dtw_rstrip(sortAssetNumber))
  @dtw_assign(fromAccount,@dtw_rstrip(fromAccount))
  @dtw_assign(fromSubaccount,@dtw_rstrip(fromSubaccount))
  @dtw_assign(toAccount,@dtw_rstrip(toAccount))
  @dtw_assign(toSubaccount,@dtw_rstrip(toSubaccount))
  @dtw_assign(sortAssetAccount,@dtw_rstrip(sortAssetAccount))
  @dtw_assign(fromPhysicalLocation,@dtw_rstrip(fromPhysicalLocation))
  @dtw_assign(toPhysicalLocation,@dtw_rstrip(toPhysicalLocation))
  @dtw_assign(sortPhysicalLocation,@dtw_rstrip(sortPhysicalLocation))

  %if (allSite != "ALL")
      @dtw_assign(allSite, "")
  %endif
  %if (allAssetNumber != "ALL")
      @dtw_assign(allAssetNumber, "")
  %endif
  %if (allAssetAccount != "ALL")
      @dtw_assign(allAssetAccount, "")
  %endif
  %if (allPhysicalLocation != "ALL")
      @dtw_assign(allPhysicalLocation, "")
  %endif

  %if (totalSite != "Y")
      @dtw_assign(totalSite, "N")
  %endif
  %if (totalAssetNumber != "Y")
      @dtw_assign(totalAssetNumber, "N")
  %endif
  %if (totalAssetAccount != "Y")
      @dtw_assign(totalAssetAccount, "N")
  %endif
  %if (totalPhysicalLocation != "Y")
      @dtw_assign(totalPhysicalLocation, "N")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@schd", schedule)
  @Concat_Field("@@fsit", fromSite)
  @Concat_Field("@@tsit", toSite)
  @Concat_Field("@@asit", allSite)
  @Concat_Field("@@ssit", sortSite)
  @Concat_Field("@@psit", totalSite)
  @Concat_Field("@@fast", fromAssetNumber)
  @Concat_Field("@@tast", toAssetNumber)
  @Concat_Field("@@aast", allAssetNumber)
  @Concat_Field("@@sast", sortAssetNumber)
  @Concat_Field("@@past", totalAssetNumber)
  @Concat_Field("@@fact", fromAccount)
  @Concat_Field("@@fsub", fromSubaccount)
  @Concat_Field("@@tact", toAccount)
  @Concat_Field("@@tsub", toSubaccount)
  @Concat_Field("@@aact", allAssetAccount)
  @Concat_Field("@@sact", sortAssetAccount)
  @Concat_Field("@@pact", totalAssetAccount)
  @Concat_Field("@@floc", fromPhysicalLocation)
  @Concat_Field("@@tloc", toPhysicalLocation)
  @Concat_Field("@@aloc", allPhysicalLocation)
  @Concat_Field("@@sloc", sortPhysicalLocation)
  @Concat_Field("@@ploc", totalPhysicalLocation)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}