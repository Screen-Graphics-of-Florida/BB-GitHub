%INCLUDE "$(baseVar)"
%INCLUDE "ARControl$(dataBaseID).icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Sales Inquiry Selection"
  d2wName                 = "SalesInqSelect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;allUsers=@dtw_rurlescseq(allUsers)"
  programName             = "HSYUSL_W"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  selectName              = "SALESINQ"
  selectUser              = ""
  fromField               = ""
  toField                 = ""
  seqField                = ""
  S1                      = ""
  S2                      = ""
  S3                      = ""
  S4                      = ""
  S5                      = ""
  S6                      = ""
  S7                      = ""
  S8                      = ""
  S9                      = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%INCLUDE "opersel_rtvfield.icl"
%INCLUDE "opersel_bldfield.icl"

%MACRO_FUNCTION Set_SQL () {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              function confirmReset() {return confirm("Confirm Reset Of Form")}
              function confirmClear() {return confirm("Confirm Clear Of Form")}
              function resetForm() {document.Chg.reset();}
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
	          %INCLUDE "numedit.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.groupItemNbr, 2, 0) &&
                      editNum(document.Chg.groupItemDesc, 2, 0) &&
                      editNum(document.Chg.fromBillToNbr, 7, 0) &&
                      editNum(document.Chg.toBillToNbr, 7, 0) &&
                      editNum(document.Chg.groupBillToNbr, 2, 0) &&
                      editNum(document.Chg.fromShipToNbr, 7, 0) &&
                      editNum(document.Chg.toShipToNbr, 7, 0) &&
                      editNum(document.Chg.groupShipToNbr, 2, 0) &&
                      editNum(document.Chg.groupShipToName, 2, 0) &&
                      editNum(document.Chg.groupAddress1, 2, 0) &&
                      editNum(document.Chg.groupAddress2, 2, 0) &&
                      editNum(document.Chg.groupAddress3, 2, 0) &&
                      editNum(document.Chg.groupCity, 2, 0) &&
                      editNum(document.Chg.groupState, 2, 0) &&
                      editNum(document.Chg.groupZip, 2, 0) &&
                  %{    editdate(document.Chg.fromInvDate) && %}
                  %{    editdate(document.Chg.toInvDate) && %}
                      editNum(document.Chg.groupInvDate, 2, 0) &&
                      editNum(document.Chg.groupProdClass, 2, 0) &&
                      editNum(document.Chg.groupProdGroup, 2, 0) &&
                      editNum(document.Chg.groupInvType, 2, 0) &&
                  %{    editdate(document.Chg.fromShipDate) && %}
                  %{    editdate(document.Chg.toShipDate) && %}
                      editNum(document.Chg.groupShipDate, 2, 0) &&
                      editNum(document.Chg.fromSellPrice, 8, 5) &&
                      editNum(document.Chg.toSellPrice, 8, 5) &&
                      editNum(document.Chg.groupSellPrice, 2, 0) &&
                      editNum(document.Chg.fromQtySold, 9, 4) &&
                      editNum(document.Chg.toQtySold, 9, 4) &&
                      editNum(document.Chg.groupQtySold, 2, 0) &&
                      editNum(document.Chg.fromSalesman, 3, 0) &&
                      editNum(document.Chg.toSalesman, 3, 0) &&
                      editNum(document.Chg.groupSalesman, 2, 0) &&
                      editNum(document.Chg.groupCustClass, 2, 0) &&
                      editNum(document.Chg.groupRegion, 2, 0) &&
                      editNum(document.Chg.fromLoc, 3, 0) &&
                      editNum(document.Chg.toLoc, 3, 0) &&
                      editNum(document.Chg.groupLoc, 2, 0) &&
                      editNum(document.Chg.fromWhs, 3, 0) &&
                      editNum(document.Chg.toWhs, 3, 0) &&
                      editNum(document.Chg.groupWhs, 2, 0) &&
                      editNum(document.Chg.groupShipViaCode, 2, 0) &&
                      editNum(document.Chg.groupShipViaDesc, 2, 0) &&
                      editNum(document.Chg.groupOrderType, 2, 0)
                      %if (V_CRSCR1 != "")
                          && editNum(document.Chg.groupCustUDA1, 2, 0)
                      %endif
                      %if (V_CRSCR2 != "")
                          && editNum(document.Chg.groupCustUDA2, 2, 0)
                      %endif
                      %if (V_CRSCR3 != "")
                          && editNum(document.Chg.groupCustUDA3, 2, 0)
                      %endif
                      %if (V_CRSCR4 != "")
                          && editNum(document.Chg.groupCustUDA4, 2, 0)
                      %endif
                      %if (V_CRSCR5 != "")
                          && editNum(document.Chg.groupCustUDA5, 2, 0)
                      %endif
                      %if (V_CIIAS1 != "")
                          && editNum(document.Chg.groupItemUDA1, 2, 0)
                      %endif
                      %if (V_CIIAS2 != "")
                          && editNum(document.Chg.groupItemUDA2, 2, 0)
                      %endif
                      %if (V_CIIAS3 != "")
                          && editNum(document.Chg.groupItemUDA3, 2, 0)
                      %endif
                      %if (V_CIIAS4 != "")
                          && editNum(document.Chg.groupItemUDA4, 2, 0)
                      %endif
                      %if (V_CIIAS5 != "")
                          && editNum(document.Chg.groupItemUDA5, 2, 0)
                      %endif
                      %if (V_CIINS1 != "")
                          && editNum(document.Chg.groupItemUDN1, 2, 0)
                      %endif
                      %if (V_CIINS2 != "")
                          && editNum(document.Chg.groupItemUDN2, 2, 0)
                      %endif
                      %if (V_CIINS3 != "")
                          && editNum(document.Chg.groupItemUDN3, 2, 0)
                      %endif
                      %if (V_CIINS4 != "")
                          && editNum(document.Chg.groupItemUDN4, 2, 0)
                      %endif
                      %if (V_CIINS5 != "")
                          && editNum(document.Chg.groupItemUDN5, 2, 0)
                      %endif
                      )
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "SALESINQSELECT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      <table $(contentTable)>
            	       <colgroup>
            	           <col width="80%">
            	           <col width="15%">
                          <tr><td><h1>$(page_title)</h1></td>
                              <td>&nbsp;</td>
                              <td class="toolbar">
                                  <a href="$(homeURL)$(cGIPath)salesinq.d2w/REPORT$(d2wVarBase)" title="Return To Sales Inquiry">$(previousImage)</a>
                                  <a href="javascript:check(document.Chg)">$(selectAcceptImage)</a>
                                  <a onClick="return confirmReset() && resetForm()">$(selectResetImage)</a>
                                  <a onClick="return confirmClear()" href="$(homeURL)$(cGIPath)$(d2wName)/SELECT$(d2wVarBase)&amp;selectUser=@dtw_rurlescseq(selectUser)">$(selectClearImage)</a>
                                  @dtw_assign(medIcon, "Y")
                                  %INCLUDE "HelpPage.icl"
                              </td>
                          </tr>
                      </table>

                      $(hrTagAttr)
            	
                      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/PROCESS$(d2wVarBase)&amp;selectSequence=@dtw_rurlescseq(selectSequence)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
                          <table $(contentTable)>
                              <colgroup>
                                  <col width="160*">
                              </colgroup>
                              <tr><td class="dsphdr">Description</td>
                                  <td class="inputalph"><input name="selectDesc" type="text" value="$(selectDesc)" size="50" maxlength="50"></td>
                              </tr>

                              @dtw_assign(checkedByQty, "")
                              @dtw_assign(checkedByAmt, "")
                              @dtw_assign(checkedByCnt, "")
                              %if (@dtw_rsubstr(selectTotals, "1", "1") == "Y")
                                  @dtw_assign(checkedByQty, "CHECKED")
                              %endif
                              %if (@dtw_rsubstr(selectTotals, "2", "1") == "Y")
                                  @dtw_assign(checkedByAmt, "CHECKED")
                              %endif
                              %if (@dtw_rsubstr(selectTotals, "3", "1") == "Y")
                                  @dtw_assign(checkedByCnt, "CHECKED")
                              %endif
                              <tr><td class="dsphdr">Display Totals By </td>
                                  <td class="dspcode"><input name="totalByQty" type="checkbox" $(checkedByQty) VALUE='Y'>Quantity
                                                      <input name="totalByAmt" type="checkbox" $(checkedByAmt) VALUE='Y'>Amount
                                                      <input name="totalByCnt" type="checkbox" $(checkedByCnt) VALUE='Y'>Count
                                  </td>
                              </tr>
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">Operand</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">Group<br>By</td>
                              </tr>

                              @Retrieve_Field("DHITEM")
                              @dtw_assign(operNbr, "operItemNbr")
                              <tr><td class="dsphdr">Item Number</td>
                                  <td>%INCLUDE "opersel_alph.icl"</td>
                                  <td class="inputalph"><input name="fromItemNbr" type="text" value="$(fromField)" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNbr&amp;fldDesc=fromItemDescH" onclick="$(searchWinVar)"> $(searchImage) &nbsp; </a><input name="fromItemDescH" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNbr" type="text" value="$(toField)" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNbr&amp;fldDesc=toItemDescH" onclick="$(searchWinVar)"> $(searchImage) &nbsp; </a><input name="toItemDescH" type="hidden"></td>
                                  <td class="inputnmbr"><input type="text" name="groupItemNbr" value="$(seqField)" size="2" maxlength="2"></td>
                              </tr>

                              @Retrieve_Field("DHIMDS")
                              @dtw_assign(operNbr, "operItemDesc")
                              <tr><td class="dsphdr">Item Description</td>
                                  <td>%INCLUDE "opersel_alph.icl"</td>
                                  <td class="inputalph"><input name="fromItemDesc" type="text" value="$(fromField)" size="15" maxlength="30"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNbrH&amp;fldDesc=fromItemDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fromItemNbrH" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemDesc" type="text" value="$(toField)" size="15" maxlength="30"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNbrH&amp;fldDesc=toItemDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toItemNbrH" type="hidden"></td>
                                  <td class="inputnmbr"><input type="text" name="groupItemDesc" value="$(seqField)" size="2" maxlength="2"></td>
                              </tr>

                              @Retrieve_Field("DHBLTO")
                              @dtw_assign(operNbr, "operBillToNbr")
                              <tr><td class="dsphdr">Bill-To Number</td>
                                  <td>%INCLUDE "opersel_num.icl"</td>
                                  <td class="inputnmbr"><input name="fromBillToNbr" type="text" value="$(fromField)" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromBillToNbr&amp;fldDesc=fromBillToNbrNameH" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fromBillToNbrNameH" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toBillToNbr" type="text" value="$(toField)" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toBillToNbr&amp;fldDesc=toBillToNbrNameH" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toBillToNbrNameH" type="hidden"></td>
                                  <td class="inputnmbr"><input type="text" name="groupBillToNbr" value="$(seqField)" size="2" maxlength="2"></td>
                              </tr>

                              @Retrieve_Field("DHSHTO")
                              @dtw_assign(operNbr, "operShipToNbr")
                              <tr><td class="dsphdr">Ship-To Number</td>
                                  <td>%INCLUDE "opersel_num.icl"</td>
                                  <td class="inputnmbr"><input name="fromShipToNbr" type="text" value="$(fromField)" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromShipToNbr&amp;fldDesc=fromShipToNbrNameH" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fromShipToNbrNameH" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toShipToNbr" type="text" value="$(toField)" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toShipToNbr&amp;fldDesc=toShipToNbrNameH" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toShipToNbrNameH" type="hidden"></td>
                                  <td class="inputnmbr"><input type="text" name="groupShipToNbr" value="$(seqField)" size="2" maxlength="2"></td>
                              </tr>

                              @Retrieve_Field("CMCNA1U")
                              @dtw_assign(operNbr, "operShipToName")
                              <tr><td class="dsphdr">Ship-To Name</td>
                                  <td>%INCLUDE "opersel_alph.icl"</td>
                                  <td class="inputalph"><input name="fromShipToName" type="text" value="$(fromField)" size="15" maxlength="26"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromShipToNbrH&amp;fldDesc=fromShipToName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fromShipToNbrH" type="hidden"></td>
                                  <td class="inputalph"><input name="toShipToName" type="text" value="$(toField)" size="15" maxlength="26"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toShipToNbrH&amp;fldDesc=toShipToName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toShipToNbrH" type="hidden"></td>
                                  <td class="inputnmbr"><input type="text" name="groupShipToName" value="$(seqField)" size="2" maxlength="2"></td>
                              </tr>

                              @Retrieve_Field("CMCNA2U")
                              @dtw_assign(operNbr, "operAddress1")
                              <tr><td class="dsphdr">Address 1</td>
                                  <td>%INCLUDE "opersel_alph.icl"</td>
                                  <td class="inputalph"><input name="fromAddress1" type="text" value="$(fromField)" size="15" maxlength="26"></td>
                                  <td class="inputalph"><input name="toAddress1" type="text" value="$(toField)" size="15" maxlength="26"></td>
                                  <td class="inputnmbr"><input type="text" name="groupAddress1" value="$(seqField)" size="2" maxlength="2"></td>
                              </tr>

                              @Retrieve_Field("CMCNA3U")
                              @dtw_assign(operNbr, "operAddress2")
                              <tr><td class="dsphdr">Address 2</td>
                                  <td>%INCLUDE "opersel_alph.icl"</td>
                                  <td class="inputalph"><input name="fromAddress2" type="text" value="$(fromField)" size="15" maxlength="26"></td>
                                  <td class="inputalph"><input name="toAddress2" type="text" value="$(toField)" size="15" maxlength="26"></td>
                                  <td class="inputnmbr"><input type="text" name="groupAddress2" value="$(seqField)" size="2" maxlength="2"></td>
                              </tr>

                              @Retrieve_Field("CMCNA4U")
                              @dtw_assign(operNbr, "operAddress3")
                              <tr><td class="dsphdr">Address 3</td>
                                  <td>%INCLUDE "opersel_alph.icl"</td>
                                  <td class="inputalph"><input name="fromAddress3" type="text" value="$(fromField)" size="15" maxlength="19"></td>
                                  <td class="inputalph"><input name="toAddress3" type="text" value="$(toField)" size="15" maxlength="19"></td>
                                  <td class="inputnmbr"><input type="text" name="groupAddress3" value="$(seqField)" size="2" maxlength="2"></td>
                              </tr>

                              @Retrieve_Field("CMCCTY")
                              @dtw_assign(operNbr, "operCity")
                              <tr><td class="dsphdr">City</td>
                                  <td>%INCLUDE "opersel_alph.icl"</td>
                                  <td class="inputalph"><input name="fromCity" type="text" value="$(fromField)" size="15" maxlength="26"></td>
                                  <td class="inputalph"><input name="toCity" type="text" value="$(toField)" size="15" maxlength="26"></td>
                                  <td class="inputnmbr"><input type="text" name="groupCity" value="$(seqField)" size="2" maxlength="2"></td>
                              </tr>

                              @Retrieve_Field("CMST")
                              @dtw_assign(operNbr, "operState")
                              <tr><td class="dsphdr">State</td>
                                  <td>%INCLUDE "opersel_alph.icl"</td>
                                  <td class="inputalph"><input name="fromState" type="text" value="$(fromField)" size="2" maxlength="2"><a href="$(homeURL)$(phpPath)StateSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromState&amp;fldDesc=fromStateDescH" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fromStateDescH" type="hidden"></td>
                                  <td class="inputalph"><input name="toState" type="text" value="$(toField)" size="2" maxlength="2"><a href="$(homeURL)$(phpPath)StateSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toState&amp;fldDesc=toStateDescH" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toStateDescH" type="hidden"></td>
                                  <td class="inputnmbr"><input type="text" name="groupState" value="$(seqField)" size="2" maxlength="2"></td>
                              </tr>

                              @Retrieve_Field("CMZIP")
                              @dtw_assign(operNbr, "operZip")
                              <tr><td class="dsphdr">Zip Code</td>
                                  <td>%INCLUDE "opersel_alph.icl"</td>
                                  <td class="inputalph"><input name="fromZip" type="text" value="$(fromField)" size="15" maxlength="13"></td>
                                  <td class="inputalph"><input name="toZip" type="text" value="$(toField)" size="15" maxlength="13"></td>
                                  <td class="inputnmbr"><input type="text" name="groupZip" value="$(seqField)" size="2" maxlength="2"></td>
                              </tr>

                              @Retrieve_Field("DHDTLI")
                              @dtw_assign(operNbr, "operInvDate")
                              <tr><td class="dsphdr">Invoice Date</td>
                                  <td>%INCLUDE "opersel_num.icl"</td>
                                  <td class="inputnmbr"><input name="fromInvDate" type="text" value="$(fromField)" size="15" maxlength="30">
                                      <a href="javascript:calWindow('fromInvDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toInvDate" type="text" value="$(toField)" size="15" maxlength="30">
                                      <a href="javascript:calWindow('toInvDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input type="text" name="groupInvDate" value="$(seqField)" size="2" maxlength="2"></td>
                              </tr>

                              @Retrieve_Field("@@LIYR")
                              <tr><td class="dsphdr">Invoice Year</td>
                                  <td class="inputalph"><input name="operInvYear" type="hidden" value=""></td>
                                  <td class="inputalph"><input name="fromInvYear" type="hidden" value=""></td>
                                  <td class="inputalph"><input name="toInvYear" type="hidden" value=""></td>
                                  <td class="inputnmbr"><input type="text" name="groupInvYear" value="$(seqField)" size="2" maxlength="2"></td>
                              </tr>

                              @Retrieve_Field("@@LIQT")
                              <tr><td class="dsphdr">Invoice Quarter</td>
                                  <td class="inputalph"><input name="operInvQtr" type="hidden" value=""></td>
                                  <td class="inputalph"><input name="fromInvQtr" type="hidden" value=""></td>
                                  <td class="inputalph"><input name="toInvQtr" type="hidden" value=""></td>
                                  <td class="inputnmbr"><input type="text" name="groupInvQtr" value="$(seqField)" size="2" maxlength="2"></td>
                              </tr>

                              @Retrieve_Field("@@LIMO")
                              <tr><td class="dsphdr">Invoice Month</td>
                                  <td class="inputalph"><input name="operInvMnth" type="hidden" value=""></td>
                                  <td class="inputalph"><input name="fromInvMnth" type="hidden" value=""></td>
                                  <td class="inputalph"><input name="toInvMnth" type="hidden" value=""></td>
                                  <td class="inputnmbr"><input type="text" name="groupInvMnth" value="$(seqField)" size="2" maxlength="2"></td>
                              </tr>

                              @Retrieve_Field("@@LIWK")
                              <tr><td class="dsphdr">Invoice Week</td>
                                  <td class="inputalph"><input name="operInvWeek" type="hidden" value=""></td>
                                  <td class="inputalph"><input name="fromInvWeek" type="hidden" value=""></td>
                                  <td class="inputalph"><input name="toInvWeek" type="hidden" value=""></td>
                                  <td class="inputnmbr"><input type="text" name="groupInvWeek" value="$(seqField)" size="2" maxlength="2"></td>
                              </tr>

                              @Retrieve_Field("DHPCLS")
                              @dtw_assign(operNbr, "operProdClass")
                              <tr><td class="dsphdr">Product Class</td>
                                  <td>%INCLUDE "opersel_alph.icl"</td>
                                  <td class="inputalph"><input name="fromProdClass" type="text" value="$(fromField)" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)prodclasssearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromProdClass&amp;fldDesc=fromProdClassDescH" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fromProdClassDescH" type="hidden"></td>
                                  <td class="inputalph"><input name="toProdClass" type="text" value="$(toField)" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)prodclasssearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toProdClass&amp;fldDesc=toProdClassDescH" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toProdClassDescH" type="hidden"></td>
                                  <td class="inputnmbr"><input type="text" name="groupProdClass" value="$(seqField)" size="2" maxlength="2"></td>
                              </tr>

                              @Retrieve_Field("DHPGRP")
                              @dtw_assign(operNbr, "operProdGroup")
                              <tr><td class="dsphdr">Product Group</td>
                                  <td>%INCLUDE "opersel_alph.icl"</td>
                                  <td class="inputalph"><input name="fromProdGroup" type="text" value="$(fromField)" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)productgroupsearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromProdGroup&amp;fldDesc=fromProdGroupDescH" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fromProdGroupDescH" type="hidden"></td>
                                  <td class="inputalph"><input name="toProdGroup" type="text" value="$(toField)" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)productgroupsearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toProdGroup&amp;fldDesc=toProdGroupDescH" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toProdGroupDescH" type="hidden"></td>
                                  <td class="inputnmbr"><input type="text" name="groupProdGroup" value="$(seqField)" size="2" maxlength="2"></td>
                              </tr>

                              @Retrieve_Field("IMITC")
                              @dtw_assign(operNbr, "operInvType")
                              <tr><td class="dsphdr">Inventory Type</td>
                                  <td>%INCLUDE "opersel_alph.icl"</td>
