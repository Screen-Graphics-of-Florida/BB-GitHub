                                      <a onClick="return confirmReset() && resetForm()">$(selectResetImage)</a>
                                      <a onClick="return confirmClear()" href="$(homeURL)$(cGIPath)$(d2wName)/SELECT$(d2wVarBase)&amp;selectUser=@dtw_rurlescseq(selectUser)">$(selectClearImage)</a>
                                      @dtw_assign(medIcon, "Y")
                                      %INCLUDE "HelpPage.icl"
                                  </td>
                              </tr>
                          </table>

                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Update_User_Selection(INOUT CHAR(64) profileHandle,
                                                INOUT CHAR(2)  dataBaseID,
                                                INOUT CHAR(1)  maintCode,
                                                INOUT CHAR(10) userProfile,
                                                INOUT CHAR(10) selectName,
                                                INOUT DEC(5,0) selectSequence,
                                                INOUT CHAR(50) selectDesc,
                                                INOUT CHAR(10) selectTotals,
                                                INOUT CHAR(500) selectGroupBy,
                                                INOUT CHAR(3000) selectCriteria)
{%EXEC {HSYUSL_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if ((sec_02 == "N" && maintenanceCode != "A") || (sec_01 == "N" && maintenanceCode == "A"))
      %INCLUDE "ProgSecurityError.icl"
  %else
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/SELECT$(d2wVarBase)&amp;selectDesc=@dtw_rurlescseq(selectDesc)&amp;selectUser=@dtw_rurlescseq(selectUser)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}

%HTML(SELECT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(selectGroupBy, "")
  @dtw_assign(selectCriteria, "")
  %if (selectDesc != "")
      @dtw_assign(maintCode, "S")
      @Update_User_Selection(profileHandle, dataBaseID, maintCode, selectUser, selectName, selectSequence, selectDesc, selectTotals, selectGroupBy, selectCriteria)
  %endif
  @Set_SQL()
%}

%HTML(RETRIEVE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(selectGroupBy, "")
  @dtw_assign(selectCriteria, "")
  @dtw_assign(maintCode, "R")
  @Update_User_Selection(profileHandle, dataBaseID, maintCode, selectUser, selectName, selectSequence, selectDesc, selectTotals, selectGroupBy, selectCriteria)
  @Set_SQL()
%}

%HTML(PROCESS) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(fromItemNbr)
  @dtw_mUPPERCASE(toItemNbr)
  @dtw_mUPPERCASE(fromBillToName)
  @dtw_mUPPERCASE(toBillToName)
  @dtw_mUPPERCASE(fromShipToName)
  @dtw_mUPPERCASE(toShipToName)
  @dtw_mUPPERCASE(fromAddress1)
  @dtw_mUPPERCASE(toAddress1)
  @dtw_mUPPERCASE(fromAddress2)
  @dtw_mUPPERCASE(toAddress2)
  @dtw_mUPPERCASE(fromAddress3)
  @dtw_mUPPERCASE(toAddress3)
  @dtw_mUPPERCASE(fromCity)
  @dtw_mUPPERCASE(toCity)
  @dtw_mUPPERCASE(fromState)
  @dtw_mUPPERCASE(toState)
  @dtw_mUPPERCASE(fromZip)
  @dtw_mUPPERCASE(toZip)
  @dtw_mUPPERCASE(fromProdClass)
  @dtw_mUPPERCASE(toProdClass)
  @dtw_mUPPERCASE(fromProdGroup)
  @dtw_mUPPERCASE(toProdGroup)
  @dtw_mUPPERCASE(fromInvType)
  @dtw_mUPPERCASE(toInvType)
  @dtw_mUPPERCASE(fromCustClass)
  @dtw_mUPPERCASE(toCustClass)
  @dtw_mUPPERCASE(fromRegion)
  @dtw_mUPPERCASE(toRegion)
  @dtw_mUPPERCASE(fromShipViaCode)
  @dtw_mUPPERCASE(toShipViaCode)
  @dtw_mUPPERCASE(fromOrderType)
  @dtw_mUPPERCASE(toOrderType)
  @dtw_mUPPERCASE(fromCustUDA1)
  @dtw_mUPPERCASE(toCustUDA1)
  @dtw_mUPPERCASE(fromCustUDA2)
  @dtw_mUPPERCASE(toCustUDA2)
  @dtw_mUPPERCASE(fromCustUDA3)
  @dtw_mUPPERCASE(toCustUDA3)
  @dtw_mUPPERCASE(fromCustUDA4)
  @dtw_mUPPERCASE(toCustUDA4)
  @dtw_mUPPERCASE(fromCustUDA5)
  @dtw_mUPPERCASE(toCustUDA5)
  @dtw_mUPPERCASE(fromItemUDA1)
  @dtw_mUPPERCASE(toItemUDA1)
  @dtw_mUPPERCASE(fromItemUDA2)
  @dtw_mUPPERCASE(toItemUDA2)
  @dtw_mUPPERCASE(fromItemUDA3)
  @dtw_mUPPERCASE(toItemUDA3)
  @dtw_mUPPERCASE(fromItemUDA4)
  @dtw_mUPPERCASE(toItemUDA4)
  @dtw_mUPPERCASE(fromItemUDA5)
  @dtw_mUPPERCASE(toItemUDA5)

  @dtw_assign(groupItemNbr,@dtw_rstrip(groupItemNbr))
  @dtw_assign(groupItemDesc,@dtw_rstrip(groupItemDesc))
  @dtw_assign(groupBillToNbr,@dtw_rstrip(groupBillToNbr))
  @dtw_assign(groupShipToNbr,@dtw_rstrip(groupShipToNbr))
  @dtw_assign(groupShipToName,@dtw_rstrip(groupShipToName))
  @dtw_assign(groupAddress1,@dtw_rstrip(groupAddress1))
  @dtw_assign(groupAddress2,@dtw_rstrip(groupAddress2))
  @dtw_assign(groupAddress3,@dtw_rstrip(groupAddress3))
  @dtw_assign(groupCity,@dtw_rstrip(groupCity))
  @dtw_assign(groupState,@dtw_rstrip(groupState))
  @dtw_assign(groupZip,@dtw_rstrip(groupZip))
  @dtw_assign(groupInvDate,@dtw_rstrip(groupInvDate))
  @dtw_assign(groupInvYear,@dtw_rstrip(groupInvYear))
  @dtw_assign(groupProdClass,@dtw_rstrip(groupProdClass))
  @dtw_assign(groupProdGroup,@dtw_rstrip(groupProdGroup))
  @dtw_assign(groupInvType,@dtw_rstrip(groupInvType))
  @dtw_assign(groupShipDate,@dtw_rstrip(groupShipDate))
  @dtw_assign(groupSellPrice,@dtw_rstrip(groupSellPrice))
  @dtw_assign(groupQtySold,@dtw_rstrip(groupQtySold))
  @dtw_assign(groupCustClass,@dtw_rstrip(groupCustClass))
  @dtw_assign(groupRegion,@dtw_rstrip(groupRegion))
  @dtw_assign(groupLoc,@dtw_rstrip(groupLoc))
  @dtw_assign(groupSalesman,@dtw_rstrip(groupSalesman))
  @dtw_assign(groupWhs,@dtw_rstrip(groupWhs))
  @dtw_assign(groupShipViaCode,@dtw_rstrip(groupShipViaCode))
  @dtw_assign(groupShipViaDesc,@dtw_rstrip(groupShipViaDesc))
  @dtw_assign(groupOrderType,@dtw_rstrip(groupOrderType))
  @dtw_assign(groupCustUDA1,@dtw_rstrip(groupCustUDA1))
  @dtw_assign(groupCustUDA2,@dtw_rstrip(groupCustUDA2))
  @dtw_assign(groupCustUDA3,@dtw_rstrip(groupCustUDA3))
  @dtw_assign(groupCustUDA4,@dtw_rstrip(groupCustUDA4))
  @dtw_assign(groupCustUDA5,@dtw_rstrip(groupCustUDA5))
  @dtw_assign(groupItemUDA1,@dtw_rstrip(groupItemUDA1))
  @dtw_assign(groupItemUDA2,@dtw_rstrip(groupItemUDA2))
  @dtw_assign(groupItemUDA3,@dtw_rstrip(groupItemUDA3))
  @dtw_assign(groupItemUDA4,@dtw_rstrip(groupItemUDA4))
  @dtw_assign(groupItemUDA5,@dtw_rstrip(groupItemUDA5))
  @dtw_assign(groupItemUDN1,@dtw_rstrip(groupItemUDN1))
  @dtw_assign(groupItemUDN2,@dtw_rstrip(groupItemUDN2))
  @dtw_assign(groupItemUDN3,@dtw_rstrip(groupItemUDN3))
  @dtw_assign(groupItemUDN4,@dtw_rstrip(groupItemUDN4))
  @dtw_assign(groupItemUDN5,@dtw_rstrip(groupItemUDN5))

  @dtw_assign(maintCode, "A")
  %if (totalByQty!="Y")
      @dtw_assign(totalByQty, "N")
  %endif
  %if (totalByAmt!="Y")
      @dtw_assign(totalByAmt, "N")
  %endif
  %if (totalByCnt!="Y")
      @dtw_assign(totalByCnt, "N")
  %endif
  @dtw_concat("$(totalByQty)", "$(totalByAmt)", selectTotals)
  @dtw_concat(selectTotals, "$(totalByCnt)", selectTotals)
  @dtw_assign(selectGroupBy, "")
  @dtw_assign(x, "1")
  %while(x  <= "500"){@dtw_concat(selectGroupBy, " ", selectGroupBy) @dtw_add(x, "1", x)%}
  @dtw_assign(selectCriteria, "")
  @Build_Select("DHITEM ", operItemNbr, fromItemNbr, toItemNbr, groupItemNbr)
  @Build_Select("DHIMDS ", operItemDesc, fromItemDesc, toItemDesc, groupItemDesc)
  @Build_Select("DHBLTO ", operBillToNbr, fromBillToNbr, toBillToNbr, groupBillToNbr)
  @Build_Select("DHSHTO ", operShipToNbr, fromShipToNbr, toShipToNbr, groupShipToNbr)
  @Build_Select("CMCNA1U", operShipToName, fromShipToName, toShipToName, groupShipToName)
  @Build_Select("CMCNA2U", operAddress1, fromAddress1, toAddress1, groupAddress1)
  @Build_Select("CMCNA3U", operAddress2, fromAddress2, toAddress2, groupAddress2)
  @Build_Select("CMCNA4U", operAddress3, fromAddress3, toAddress3, groupAddress3)
  @Build_Select("CMCCTYU", operCity, fromCity, toCity, groupCity)
  @Build_Select("CMST   ", operState, fromState, toState, groupState)
  @Build_Select("CMZIP  ", operZip, fromZip, toZip, groupZip)
  @Build_Select("DHDTLI ", operInvDate, fromInvDate, toInvDate, groupInvDate)
  @Build_Select("@@LIYR ", operInvYear, fromInvYear, toInvYear, groupInvYear)
  @Build_Select("@@LIQT ", operInvQtr, fromInvQtr, toInvQtr, groupInvQtr)
  @Build_Select("@@LIMO ", operInvMnth, fromInvMnth, toInvMnth, groupInvMnth)
  @Build_Select("@@LIWK ", operInvWeek, fromInvWeek, toInvWeek, groupInvWeek)
  @Build_Select("DHPCLS ", operProdClass, fromProdClass, toProdClass, groupProdClass)
  @Build_Select("DHPGRP ", operProdGroup, fromProdGroup, toProdGroup, groupProdGroup)
  @Build_Select("IMITC  ", operInvType, fromInvType, toInvType, groupInvType)
  @Build_Select("HHDOTS ", operShipDate, fromShipDate, toShipDate, groupShipDate)
  @Build_Select("@@SDYR ", operShipYear, fromShipYear, toShipYear, groupShipYear)
  @Build_Select("@@SDQT ", operShipQtr, fromShipQtr, toShipQtr, groupShipQtr)
  @Build_Select("@@SDMO ", operShipMnth, fromShipMnth, toShipMnth, groupShipMnth)
  @Build_Select("@@SDWK ", operShipWeek, fromShipWeek, toShipWeek, groupShipWeek)
  @Build_Select("DHSLPR ", operSellPrice, fromSellPrice, toSellPrice, groupSellPrice)
  @Build_Select("DHQSTC ", operQtySold, fromQtySold, toQtySold, groupQtySold)
  @Build_Select("HHSLSM ", operSalesman, fromSalesman, toSalesman, groupSalesman)
  @Build_Select("CMCCLS ", operCustClass, fromCustClass, toCustClass, groupCustClass)
  @Build_Select("CMCRGN ", operRegion, fromRegion, toRegion, groupRegion)
  @Build_Select("DHLOC# ", operLoc, fromLoc, toLoc, groupLoc)
  @Build_Select("DHWH   ", operWhs, fromWhs, toWhs, groupWhs)
  @Build_Select("DHSVSV ", operShipViaCode, fromShipViaCode, toShipViaCode, groupShipViaCode)
  @Build_Select("DHSVDS ", operShipViaDesc, fromShipViaDesc, toShipViaDesc, groupShipViaDesc)
  @Build_Select("HHORTY ", operOrderType, fromOrderType, toOrderType, groupOrderType)
  @Build_Select("CMUDF1 ", operCustUDA1, fromCustUDA1, toCustUDA1, groupCustUDA1)
  @Build_Select("CMUDF2 ", operCustUDA2, fromCustUDA2, toCustUDA2, groupCustUDA2)
  @Build_Select("CMUDF3 ", operCustUDA3, fromCustUDA3, toCustUDA3, groupCustUDA3)
  @Build_Select("CMUDF4 ", operCustUDA4, fromCustUDA4, toCustUDA4, groupCustUDA4)
  @Build_Select("CMUDF5 ", operCustUDA5, fromCustUDA5, toCustUDA5, groupCustUDA5)
  @Build_Select("IMUDA1 ", operItemUDA1, fromItemUDA1, toItemUDA1, groupItemUDA1)
  @Build_Select("IMUDA2 ", operItemUDA2, fromItemUDA2, toItemUDA2, groupItemUDA2)
  @Build_Select("IMUDA3 ", operItemUDA3, fromItemUDA3, toItemUDA3, groupItemUDA3)
  @Build_Select("IMUDA4 ", operItemUDA4, fromItemUDA4, toItemUDA4, groupItemUDA4)
  @Build_Select("IMUDA5 ", operItemUDA5, fromItemUDA5, toItemUDA5, groupItemUDA5)
  @Build_Select("IMUDN1 ", operItemUDN1, fromItemUDN1, toItemUDN1, groupItemUDN1)
  @Build_Select("IMUDN2 ", operItemUDN2, fromItemUDN2, toItemUDN2, groupItemUDN2)
  @Build_Select("IMUDN3 ", operItemUDN3, fromItemUDN3, toItemUDN3, groupItemUDN3)
  @Build_Select("IMUDN4 ", operItemUDN4, fromItemUDN4, toItemUDN4, groupItemUDN4)
  @Build_Select("IMUDN5 ", operItemUDN5, fromItemUDN5, toItemUDN5, groupItemUDN5)

  @dtw_concat(selectCriteria, "@@END", selectCriteria)
  @Update_User_Selection(profileHandle, dataBaseID, maintCode, userProfile, selectName, selectSequence, selectDesc, selectTotals, selectGroupBy, selectCriteria)
  %if (selectGroupBy != "")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)SalesInqGroupBy.d2w/PROCESS$(d2wVarBase)&amp;downloadProfileHandle=@dtw_rurlescseq(profileHandle)&amp;selectSequence=@dtw_rurlescseq(selectSequence)&amp;grpFldLvl=1&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %else
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)SalesInqDisplay.d2w/PROCESS$(d2wVarBase)&amp;downloadProfileHandle=@dtw_rurlescseq(profileHandle)&amp;selectSequence=@dtw_rurlescseq(selectSequence)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}