%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "QuickLink.icl"

%Define {
  page_title              = "Condition"
  d2wName                 = "WFConditionSelect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfCondition=@dtw_rurlescseq(wfCondition)"
  programName             = "HWFCNM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
  V_CMDESC                = ""	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_assign(backHome, "$(d2wName)/REPORT")
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          @RtvFldDesc("CMCOND=$(wfCondition)", "WFCNDM", "CMDESC", V_CMDESC)
          @Format_Code(wfCondition, F_wfCondition)
          @dtw_assign(title, "$(V_CMDESC) $(F_wfCondition)")
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "WFCONDITIONSELECT")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif

                  <td class="content">
%{ quicklinkSeqTable %}
                      @dtw_assign(RPT_MAX_ROWS, "99")
                      @dtw_assign(dspMaxRows, "99")
                      @QuicklinkSequence(profileHandle, dataBaseID, d2wName, quicklinkSeqTable)
                      @dtw_tb_rows(quicklinkSeqTable,quicklinkCount)
                      %if (quicklinkCount == "0" || quicklinkCount == "")
                          @dtw_assign(quicklinkCount, "0")
                      %endif
%{ Heading %}
                      @dtw_assign(RPT_MAX_ROWS, "99")
                      @dtw_assign(dspMaxRows, "10")
                      @dtw_assign(wildCardSearch, "")  %{ No wildCardSearch %}
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " WFCNDM ", fileSQL)
                      @dtw_concat(selectSQL, " CMCOND=$(wfCondition) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Condition_Select_Header(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Display Loop %}
                      @dtw_assign(x, "1")
                      %while(x <= quicklinkCount) {
                          @dtw_tb_getv(quicklinkSeqTable, x, "1", quicklinkRef)
                          @dtw_lowercase(quicklinkRef,quicklinkRef)
                          @dtw_tb_getv(quicklinkSeqTable, x, "2", quicklinkTitle)
                          @dtw_tb_getv(quicklinkSeqTable, x, "3", quicklinkMaxRows)
                          %if (quicklinkMaxRows == "0" || quicklinkMaxRows == "" )
                              @dtw_assign(quicklinkMaxRows, dspMaxRowsDft)
                          %endif
                          @dtw_assign(RPT_MAX_ROWS, quicklinkMaxRows)
                          @dtw_assign(dspMaxRows, quicklinkMaxRows)

    %{ Expression %}
                          %if (quicklinkRef == "expression")
                              %INCLUDE "QuickLinkClear.icl"
                              @Retrieve_WebReg(userProfile, "", "WFExpression.d2w", wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, " Select WFCNDE.*, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(a.FLDESC,' ') as anorFLDESC, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(b.FLDESC,' ') as ptypFLDESC, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(c.FLDESC,' ') as vtypFLDESC, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(d.PMPRMD,CEPFLD) as parmPMPRMD, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(e.PMPRMD,CEVFLD) as valuPMPRMD, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(VIDESC,' ') as VIDESC ", stmtSQL)
                              @dtw_concat(fileSQL, " WFCNDE ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYFLAG a on a.FLTYPE='WFCNDCONT' and a.FLVALU=CEANOR ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYFLAG b on b.FLTYPE='WFCNDPTYP' and b.FLVALU=CEPTYP ", fileSQL)
                              @dtw_concat(fileSQL, " left join SYFLAG c on c.FLTYPE='WFCNDVTYP' and c.FLVALU=CEVTYP and CEVLID=0", fileSQL)
                              @dtw_concat(fileSQL, " left join WFPARM d on d.PMPARM=CEPFLD ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFPARM e on e.PMPARM=CEVFLD ", fileSQL)
                              @dtw_concat(fileSQL, " left join WFVLID on VIVPGM=CEVPGM and VIVLID=CEVLID ", fileSQL)
                              @dtw_concat(selectSQL, " CECOND=$(wfCondition) ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %if (orderBy == "")
                                  @dtw_assign(orderBy, "CECOND,CETSSQ")
                                  @dtw_assign(orderByDisplay, "Test Sequence")
                              %endif
                              @dtw_concat(stmtSQL, " Order By $(orderBy)", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @Condition_Select_Expression(profileHandle, dataBaseID, stmtSQL)
                          %endif

                          @dtw_add(x, "1", x)
                      %}
%{ Quicklink Display Loop END %}

                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Condition_Select_Header (IN CHAR(64)    profileHandle,
                                               CHAR(2)     dataBaseID,
                                               CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>

              %if (formatToPrint != "Y")
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;fromD2w=")
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)WFConditionMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (sec_01=="Y" && sec_04=="Y")
                          <a href="$(homeURL)$(cGIPath)WFConditionMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromCondition=@dtw_rurlescseq(wfCondition)&amp;maintenanceCode=Z">$(copyImageLrg)</a>
                      %endif
                      %if (sec_02 == "Y" || sec_03 == "Y")
                          <a href="$(homeURL)$(cGIPath)WFConditionMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageLrg)</a>
                      %endif
                      %if (sec_03 == "Y")
                          @Format_Confirm_Desc($(V_CMDESC), $(wfCondition), "", "", "", "", confirmDesc)
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)WFConditionMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %ROW{
          <table $(contentTable)>
              <tr><td class="dsphdr">Condition</td>
                  @Format_Code(V_CMCOND, F_CMCOND)
                  <td class="dspalph">$(V_CMDESC) $(F_CMCOND)</td>
              </tr>
          </table>

          $(hrTagAttr)

          %INCLUDE "QuickLinkDisplay.icl"
      %}
  %}
%}

%FUNCTION(dtw_sql) Condition_Select_Expression (IN CHAR(64)    profileHandle,
                                                   CHAR(2)     dataBaseID,
                                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="expression"></a>
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)WFExpression.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("CECONDE", "Expression")
                  @Format_Column_Header("CETSSQ", "Test Sequence")
                  @Format_Column_Header("anorFLDESC", "And/<br>Or")
                  @Format_Column_Header("VIDESC", "Section")
                  @Format_Column_Header("ptypFLDESC", "Type")
                  @Format_Column_Header("CEPEXT", "External Table")
                  @Format_Column_Header("CEPWHR", "Where")
                  @Format_Column_Header("parmPMPRMD", "Column")
                  @Format_Column_Header("CEOPER", "Operand")
                  @Format_Column_Header("CEVAL1", "Value One")
                  @Format_Column_Header("CEVAL2", "Value Two")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph">$(V_CECONDE)</td>
                  <td class="colnmbr">$(V_CETSSQ)</td>
                  <td class="colcode" $(helpCursor)><span title="$(V_CEANOR)">$(V_anorFLDESC)</span></td>
                  %if (V_CEVLID>"0")
                      <td class="colalph" colspan="8" $(helpCursor)><span title="$(V_CEVPGM)-$(V_CEVLID)">Validation: $(V_VIDESC)</span></td>
                  %else
                      <td class="colalph">Parameter:</td>
                      <td class="colalph" $(helpCursor)><span title="$(V_CEPTYP)">$(V_ptypFLDESC)</span></td>
                      <td class="colalph">$(V_CEPEXT)</td>
                      <td class="colalph">$(V_CEPWHR)</td>
                      <td class="colalph" $(helpCursor)><span title="$(V_CEPFLD)">$(V_parmPMPRMD)</span></td>
                      <td class="colalph">$(V_CEOPER)</td>
                      <td class="colalph">&nbsp;</td>
                      <td class="colalph">&nbsp;</td>
                  %endif
              </tr>
              %if (V_CEVLID<="0")
                  <tr class="$(rowClass)">
                      <td class="colalph">&nbsp;</td>
                      <td class="colalph">&nbsp;</td>
                      <td class="colalph">&nbsp;</td>
                      <td class="colalph">Value:</td>
                      <td class="colalph" $(helpCursor)><span title="$(V_CEVTYP)">$(V_vtypFLDESC)</span></td>
                      <td class="colalph">$(V_CEVEXT)</td>
                      <td class="colalph">$(V_CEVWHR)</td>
                      <td class="colalph" $(helpCursor)><span title="$(V_CEVFLD)">$(V_valuPMPRMD)</span></td>
                      <td class="colalph">&nbsp;</td>
                      <td class="colalph">$(V_CEVAL1)</td>
                      <td class="colalph">$(V_CEVAL2)</td>
                  </tr>
              %endif
          %}
      </table>
      </fieldset>
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}