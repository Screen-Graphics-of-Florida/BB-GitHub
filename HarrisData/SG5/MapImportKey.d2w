%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Import Key"
  d2wName                 = "MapImportKey.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;importKey=@dtw_rurlescseq(importKey)&amp;passedImportTable=@dtw_rurlescseq(passedImportTable)&amp;passedRecordType=@dtw_rurlescseq(passedRecordType)&amp;limitRecordType=@dtw_rurlescseq(limitRecordType)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HSYIKM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  noMsg                   = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "MAPIMPORTKEY")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (formatToPrint == "Y")
                         @dtw_concat(stmtSQL, " Select SYMIKY.*,  ", stmtSQL)
                      %else
                         @dtw_concat(stmtSQL, " Select Distinct FKIMKY, FKIFIL, FKRTYP, FKMFIL, FKPFIL,  ", stmtSQL)
                         @dtw_assign(distinctSQL, "FKIMKY, FKIFIL, FKRTYP, FKMFIL, FKPFIL")
                      %endif
                      @dtw_concat(stmtSQL, " coalesce(FFDESC,' ') as FFDESC, coalesce(FFDESCU,' ') as FFDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(FRDESC,' ') as FRDESC, coalesce(FRDESCU,' ') as FRDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(a.MFDESC,' ') as MFDESC, coalesce(a.MFDESCU,' ') as MFDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(b.MFDESC,' ') as parentMFDESC, coalesce(b.MFDESCU,' ') as parentMFDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " SYMIKY ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYMIHD on FHIMKY=FKIMKY ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYMITB on FFIMKY=FKIMKY and FFIFIL=FKIFIL ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYMIRT on FRIMKY=FKIMKY and FRIFIL=FKIFIL and FRRTYP=FKRTYP ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYMMTB a on a.MFMPKY=FHMPKY and a.MFMFIL=FKMFIL ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYMMTB b on b.MFMPKY=FHMPKY and b.MFMFIL=FKPFIL ", fileSQL)
                      @dtw_concat(selectSQL, " FKIMKY=$(importKey) ", selectSQL)
                      %if (passedImportTable != "")
                          @dtw_concat(selectSQL, " and FKIFIL='$(passedImportTable)' ", selectSQL)
                      %endif
                      %if (limitRecordType == "Y")
                          @dtw_concat(selectSQL, " and FKRTYP='$(passedRecordType)' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %if (formatToPrint == "Y")
                          @dtw_concat(stmtSQL, ", FKIFIL,FKRTYP,FKMFIL,FKPFIL,FKKYSQ ", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("FFIMKY=$(importKey)", "SYMITB", "CHAR(COUNT(*))", importTableCount)
      %if (passedImportTable == "")
          %if (importTableCount == "1")
              @RtvFldDesc("FFIMKY=$(importKey)", "SYMITB", "MAX(FFIFIL)", passedImportTable)
          %endif
      %endif

      %if (limitRecordType == "")
          %if (passedImportTable == "")
              @RtvFldDesc("FFIMKY=$(importKey) and FFRTPS>0 ", "SYMITB", "char(Count(*))", recordTypeTables)
              @RtvFldDesc("FRIMKY=$(importKey)", "SYMIRT", "CHAR(COUNT(*))", recordTypeCount)
          %else
              @RtvFldDesc("FFIMKY=$(importKey) and FFIFIL='$(passedImportTable)' and FFRTPS>0 ", "SYMITB", "char(Count(*))", recordTypeTables)
              @RtvFldDesc("FRIMKY=$(importKey) and FRIFIL='$(passedImportTable)' ", "SYMIRT", "CHAR(COUNT(*))", recordTypeCount)
          %endif
          %if (recordTypeTables == importTableCount && recordTypeCount=="1")
              @dtw_assign(limitRecordType, "Y")
              %if (passedImportTable == "")
                  @RtvFldDesc("FRIMKY=$(importKey)", "SYMIRT", "MAX(FRRTYP)", passedRecordType)
              %else
                  @RtvFldDesc("FRIMKY=$(importKey) and FRIFIL='$(passedImportTable)'", "SYMIRT", "MAX(FRRTYP)", passedRecordType)
              %endif
          %endif
      %endif

      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)MapImportKeyMaintain.d2w/REFRESH$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      <table $(contentTable)>
          @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "FHDESC", V_FHDESC)
          @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "CHAR(FHMPKY)", V_FHMPKY)
          @Format_Header_URL("Import Definition", $(V_FHDESC), $(importKey), "$(homeURL)$(cGIPath)MapImportDefinitionSelect.d2w/REPORT$(d2wVarBase)")

          @RtvFldDesc("MHMPKY=$(V_FHMPKY)", "SYMMHD", "MHDESC", V_MHDESC)
          @RtvFldDesc("MHMPKY=$(V_FHMPKY)", "SYMMHD", "MHWPGM", V_MHWPGM)
          @Format_Header("Map Definition", $(V_MHDESC), $(V_MHWPGM))

          %if (passedImportTable != "")
              @RtvFldDesc("FFIMKY=$(importKey) and FFIFIL='$(passedImportTable)'", "SYMITB", "FFDESC", V_FFDESC)
              @Format_Header_URL("Import Table", $(V_FFDESC), $(passedImportTable), "$(homeURL)$(cGIPath)MapImportTableSelect.d2w/REPORT$(d2wVarBase)&amp;importTable=@dtw_rurlescseq(passedImportTable)")
          %endif

          %if (limitRecordType == "Y")
              @RtvFldDesc("FRIMKY=$(importKey) and FRIFIL='$(passedImportTable)' and FRRTYP='$(passedRecordType)'", "SYMIRT", "FRDESC", V_FRDESC)
              @Format_Header_URL("Row Type", $(V_FRDESC), $(passedRecordType), "$(homeURL)$(cGIPath)MapImportRecordTypeSelect.d2w/REPORT$(d2wVarBase)")
          %endif
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint == "")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Interface Table</th>
                      <th class="colhdr">Parent Interface Table</th>
                      %if (passedImportTable == "")
                          <th class="colhdr">Import Table</th>
                      %endif
                      %if (limitRecordType == "" && recordTypeCount>"0")
                          <th class="colhdr">Row Type</th>
                      %endif
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchInterfaceTable" size="15" maxlength="50">
                          <input type="hidden" name="operInterfaceTable" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchParentTable" size="15" maxlength="50">
                          <input type="hidden" name="operParentTable" value="LIKE">
                      </td>
                      %if (passedImportTable == "")
                          <td><input type="text" class="inputalph" name="srchImportTable" size="15" maxlength="50">
                              <input type="hidden" name="operImportTable" value="LIKE">
                          </td>
                      %endif
                      %if (limitRecordType == "" && recordTypeCount>"0")
                          <td><input type="text" class="inputalph" name="srchRecType" size="15" maxlength="50">
                              <input type="hidden" name="operRecType" value="LIKE">
                          </td>
                      %endif
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchInterfaceTable.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              %if (passedImportTable == "")
                  @OrderBy_Sort("FFDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ImportTable"  title="Sequence By Import Table, Row Type">Import Table</a></th>
              %endif
              %if (limitRecordType == "" && recordTypeCount>"0")
                  @OrderBy_Sort("FRDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RowType"      title="Sequence By Row Type">Row Type</a></th>
              %endif
              @OrderBy_Sort("MFDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=InterfaceTable"   title="Sequence By Interface Table">Interface Table</a></th>
              @OrderBy_Sort("parentMFDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ParentTable"      title="Sequence By Parent Interface Table, Row Type">Parent Interface Table</a></th>
              %if (formatToPrint == "Y")
                  <th class="colhdr">Key Sequence</th>
                  <th class="colhdr">Key Position/ Placement</th>
                  <th class="colhdr">Key Length</th>
              %endif
          </tr>

          %INCLUDE "NoRecordsFound.icl"
          @dtw_assign(test_FKIFIL, "")
          @dtw_assign(test_FKRTYP, "")
          @dtw_assign(test_FKMFIL, "")
          @dtw_assign(test_FKPFIL, "")

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;importTable=@dtw_rurlescseq(V_FKIFIL)&amp;importRecordType=@dtw_rurlescseq(V_FKRTYP)&amp;interfaceTable=@dtw_rurlescseq(V_FKMFIL)&amp;parentInterfaceTable=@dtw_rurlescseq(V_FKPFIL)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;updRecNbr=@dtw_rurlescseq(START_ROW_NUM)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_FFDESC), "$(V_FKIFIL)-$(V_FKRTYP)-$(V_FKMFIL)-$(V_FKPFIL)", "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)MapImportKeyMaintain.d2w/REFRESH$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)MapImportKeyMaintain.d2w/REFRESH$(maintainVar)&amp;fromImportTable=@dtw_rurlescseq(V_FKIFIL)&amp;fromImportRecordType=@dtw_rurlescseq(V_FKRTYP)&amp;fromImportInterfaceTable=@dtw_rurlescseq(V_FKMFIL)&amp;fromImportParentTable=@dtw_rurlescseq(V_FKPFIL)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)MapImportKeyMaintain.d2w/EDIT_DATA$(maintainVar)&amp;maintenanceCode=D&amp;updateOption=U">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  %if (test_FKIFIL!=V_FKIFIL || test_FKRTYP!=V_FKRTYP || test_FRDESC!=V_FRDESC || test_FKMFIL!=V_FKMFIL || test_FKPFIL!=V_FKPFIL)
                      @dtw_assign(test_FKIFIL, V_FKIFIL)
                      @dtw_assign(test_FKRTYP, V_FKRTYP)
                      @dtw_assign(test_FKMFIL, V_FKMFIL)
                      @dtw_assign(test_FKPFIL, V_FKPFIL)
                      %if (passedImportTable == "")
                          <td class="colalph" $(helpCursor)><span title="$(V_FKIFIL)">$(V_FFDESC)</span></td>
                      %endif
                      %if (limitRecordType == "" && recordTypeCount>"0")
                          <td class="colalph" $(helpCursor)><span title="$(V_FKRTYP)">$(V_FRDESC)</span></td>
                      %endif
                      <td class="colalph" $(helpCursor)><span title="$(V_FKMFIL)">$(V_MFDESC)</span></td>
                      <td class="colalph" $(helpCursor)><span title="$(V_FKPFIL)">$(V_parentMFDESC)</span></td>
                  %else
                      %if (passedImportTable == "")
                          <td class="colalph">&nbsp;</td>
                      %endif
                      %if (limitRecordType == "" && recordTypeCount>"0")
                          <td class="colnmbr">&nbsp;</td>                                      	
                      %endif
                      <td class="colnmbr">&nbsp;</td>                                      	
                      <td class="colalph">&nbsp;</td>
                  %endif
                  %if (formatToPrint == "Y")
                      <td class="colalph">$(V_FKKYSQ)</td>                                      	
                      <td class="colnmbr">$(V_FKKYPS)</td>                                      	
                      <td class="colnmbr">$(V_FKKYLN)</td>                                      	
                  %endif
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select SYMIKY.*,  ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(FFDESC,' ') as FFDESC, coalesce(FFDESCU,' ') as FFDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(FRDESC,' ') as FRDESC, coalesce(FRDESCU,' ') as FRDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(a.MFDESC,' ') as MFDESC, coalesce(a.MFDESCU,' ') as MFDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(b.MFDESC,' ') as parentMFDESC, coalesce(b.MFDESCU,' ') as parentMFDESCU ", stmtSQL)
  @dtw_concat(fileSQL, " SYMIKY ", fileSQL)
  @dtw_concat(fileSQL, " left join SYMIHD on FHIMKY=FKIMKY ", fileSQL)
  @dtw_concat(fileSQL, " left join SYMITB on FFIMKY=FKIMKY and FFIFIL=FKIFIL ", fileSQL)
  @dtw_concat(fileSQL, " left join SYMIRT on FRIMKY=FKIMKY and FRIFIL=FKIFIL and FRRTYP=FKRTYP ", fileSQL)
  @dtw_concat(fileSQL, " left join SYMMTB a on a.MFMPKY=FHMPKY and a.MFMFIL=FKMFIL ", fileSQL)
  @dtw_concat(fileSQL, " left join SYMMTB b on b.MFMPKY=FHMPKY and b.MFMFIL=FKPFIL ", fileSQL)
  @dtw_concat(selectSQL, " FKIMKY=$(importKey) ", selectSQL)
  %if (passedImportTable != "")
      @dtw_concat(selectSQL, " and FKIFIL='$(passedImportTable)' ", selectSQL)
  %endif
  %if (limitRecordType == "Y")
      @dtw_concat(selectSQL, " and FKRTYP='$(passedRecordType)' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_XMLQuery (IN  CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("MapImportKeyList")
          %ROW{
              @XMLIDTag("$(V_FKIMKY)-$(V_FKIFIL)-$(V_FKRTYP)-$(V_FKMFIL)-$(V_FKPFIL)-$(V_FKKYSQ)", "MapImportKey ID")
                  @XMLTag(V_FKIMKY, "MapDefinition")
                  @XMLTag(V_FKIFIL, "ImportTable")
                  @XMLTag(V_FKRTYP, "RowType")
                  @XMLTag(V_FKMFIL, "InterfaceTable")
                  @XMLTag(V_FKPFIL, "ParentInterfaceTable")
                  @XMLTag(V_FKKYSQ, "KeySequence")
                  @XMLTag(V_FKKYPS, "KeyPositionPlacement")
                  @XMLTag(V_FKKYLN, "KeyLength")
              @XMLEndTag("MapImportKey")
          %}
      @XMLEndTag("MapImportKeyList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "FFDESCU,FRDESCU,FFDESCU")
          @DTW_ASSIGN(orderByDisplay, "Import Table, Row Type")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %if (updRecNbr > "0")
      @dtw_assign(START_ROW_NUM, updRecNbr)
      @dtw_assign(updRecNbr, "")
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "ImportTable")
      %if (orderBy == "FFDESCU,FRDESCU,FFDESCU")
          @DTW_ASSIGN(orderBy, "FFDESCU DESC,FRDESCU,FFDESCU")
          @DTW_ASSIGN(orderByDisplay, "Import Table (descending), Row Type")
      %else
          @DTW_ASSIGN(orderBy, "FFDESCU,FRDESCU,FFDESCU")
          @DTW_ASSIGN(orderByDisplay, "Import Table, Row Type")
      %endif
  %elif (sequence == "RowType")
      %if (orderBy == "FRDESCU,FFDESCU")
          @DTW_ASSIGN(orderBy, "FRDESCU DESC,FFDESCU")
          @DTW_ASSIGN(orderByDisplay, "Row Type (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FRDESCU,FFDESCU")
          @DTW_ASSIGN(orderByDisplay, "Row Type")
      %endif
  %elif (sequence == "InterfaceTable")
      %if (orderBy == "MFDESCU,FFDESCU,FRDESCU")
          @DTW_ASSIGN(orderBy, "MFDESCU DESC,FFDESCU,FRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Interface Table (descending)")
      %else
          @DTW_ASSIGN(orderBy, "MFDESCU,FFDESCU,FRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Interface Table")
      %endif
  %elif (sequence == "ParentTable")
      %if (orderBy == "parentMFDESCU,FFDESCU,FRDESCU")
          @DTW_ASSIGN(orderBy, "parentMFDESCU DESC,FFDESCU,FRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Parent Interface Table (descending)")
      %else
          @DTW_ASSIGN(orderBy, "parentMFDESCU,FFDESCU,FRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Parent Interface Table")
      %endif
  %endif
	
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "MAPIMPORTKEYSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          %if (limitRecordType == "")
                              %if (passedImportTable == "")
                                  @RtvFldDesc("FRIMKY=$(importKey)", "SYMIRT", "CHAR(COUNT(*))", recordTypeCount)
                              %else
                                  @RtvFldDesc("FRIMKY=$(importKey) and FRIFIL='$(passedImportTable)' ", "SYMIRT", "CHAR(COUNT(*))", recordTypeCount)
                              %endif
                          %endif

                          %if (passedImportTable == "")
                              @dtw_assign(focusField, "srchImportTable")
                          %elif (limitRecordType == "" && recordTypeCount>"0")
                              @dtw_assign(focusField, "srchRecType")
                          %else
                              @dtw_assign(focusField, "srchInterfaceTable")
                          %endif

                          %if (passedImportTable == "")
                              <tr><td class="dsphdr">Import Table</td>
                                  @dtw_assign(operNbr, "operImportTable")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchImportTable" size="15" maxlength="50"></td>
                              </tr>
                          %endif

                          %if (limitRecordType == "" && recordTypeCount>"0")
                              <tr><td class="dsphdr">Row Type</td>
                                  @dtw_assign(operNbr, "operRecType")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchRecType" size="15" maxlength="50"></td>
                              </tr>
                          %endif

                          <tr><td class="dsphdr">Interface Table</td>
                              @dtw_assign(operNbr, "operInterfaceTable")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchInterfaceTable" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Parent Interface Table</td>
                              @dtw_assign(operNbr, "operParentTable")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchParentTable" size="15" maxlength="50"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.$(focusField).focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("FFDESCU", "Import Table", $(srchImportTable), "U", operImportTable, "A")
  @Build_WildCard ("FRDESCU", "Row Type", $(srchRecType), "U", operRecType, "A")
  @Build_WildCard ("a.MFDESCU", "Interface Table", $(srchInterfaceTable), "U", operInterfaceTable, "A")
  @Build_WildCard ("b.MFDESCU", "Parent Interface Table", $(srchParentTable), "U", operParentTable, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}