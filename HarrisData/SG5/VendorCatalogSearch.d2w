%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Item Search"
  d2wName                 = "VendorCatalogSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  novcf                   = ""
  imageExists             = ""
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectItem(item, desc){
                  window.opener.document.$(docName).$(fldName).value = item;
                  window.opener.document.$(docName).$(fldDesc).value = desc;
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select coalesce(nullif(VCVNIT,' '),nullif(VCITEM,' '), VCPITM) as VCVNIT, VCITEM, VCPITM, VCIMDS, VCIMDSU, VCSYNM, VCPCLS, ", stmtSQL)
                      @dtw_concat(stmtSQL, "        VCUOMS, VCHAZM, VCUPCT, VCUPC,  VCCATN,  VCITC,  VCIMWG, ", stmtSQL)
                      @dtw_concat(stmtSQL, "        VCUOMW, VCCSZS, VCCUUM, VCQUAL, ", stmtSQL)
                      @dtw_concat(stmtSQL, " Case When VCITEM=' ' or VCVENI='Y' or VCNSTK='Y' Then 'Y' Else ' ' End as VCAT ", stmtSQL)
                      @dtw_concat(fileSQL, " HDVCAT ", fileSQL)
                      @dtw_concat(selectSQL, " VCPCLS>' ' and VCUOMS>' ' ", selectSQL)
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, " and VCPITM='$(itemNumber)' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @RtvFldDesc("$(selectSQL)", "$(fileSQL)", "char(count(*))", sq1_Record_Count)
                      @dtw_assign(stmtSQL_sv, stmtSQL)

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select IMITEM as VCVNIT, IMITEM as VCITEM, IMITEM as VCPITM, ", stmtSQL)
                      %if (V_CIUSMP == "Y")
                          @dtw_concat(stmtSQL, "  coalesce(SMPART,IMIMDS) as VCIMDS, coalesce(SMPART,IMIMDSU) as VCIMDSU, ", stmtSQL)
                      %else
                          @dtw_concat(stmtSQL, "  IMIMDS as VCIMDS, IMIMDSU as VCIMDSU, ", stmtSQL)
                      %endif
                      @dtw_concat(stmtSQL, " coalesce(SYSYNM,'') as VCSYNM, IMPCLS as VCPCLS, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(IMUOMS,'') as VCUOMS, IMHAZM as VCHAZM, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(IMUPCT,'') as VCUPCT, IMUPC  as VCUPC, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(IMCATN,'') as VCCATN, IMITC  as VCITC, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(IMIMWG,0 ) as VCIMWG, IMUOMW as VCUOMW, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(IMCSZS,0 ) as VCCSZS, IMCUUM as VCCUUM, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(IMQUAL,'') as VCQUAL, ' ' as VCAT ", stmtSQL)
                      @dtw_concat(fileSQL, " HDIMST left  join HDSITM on IMITEM=SYITEM", fileSQL)
                      %if (V_CIUSMP == "Y")
                          @dtw_concat(fileSQL, "    left  join HDSPRT on IMITEM=SMCITM", fileSQL)
                      %endif
                      @dtw_concat(fileSQL, "        left exception join HDVCAT on IMITEM=VCITEM", fileSQL)
                      @dtw_concat(selectSQL, "IMIMAC=' ' ", selectSQL)
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, " and IMITEM='$(itemNumber)' ", selectSQL)
                      %endif
                      @dtw_assign(wildCardSearch_sv, wildCardSearch)
                      @dtw_replace(wildCardSearch, "VCVNIT", "IMITEM", wildCardSearch)
                      %if (V_CIUSMP == "Y")
                          @dtw_replace(wildCardSearch, "VCIMDSU", "coalesce(SMPART,IMIMDSU)", wildCardSearch)
                      %else
                          @dtw_replace(wildCardSearch, "VCIMDSU", "IMIMDSU", wildCardSearch)
                      %endif
                      @dtw_replace(wildCardSearch, "VCSYNM", "SYSYNM", wildCardSearch)
                      @dtw_replace(wildCardSearch, "VCPCLS", "IMPCLS", wildCardSearch)
                      %INCLUDE "stmtSQLSelect.icl"
                      @RtvFldDesc("$(selectSQL)", "$(fileSQL)", "char(count(*))", sq2_Record_Count)
                      @dtw_assign(wildCardSearch, wildCardSearch_sv)
                      @dtw_add(sq1_Record_Count, sq2_Record_Count, sql_Record_Count)

                      @dtw_assign(stmtSQL, "$(stmtSQL_sv) UNION $(stmtSQL)")
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %if (sql_Record_Count == "0")
                          @dtw_assign(stmtSQL, "Select FLTYPE From SYFLAG Where FLTYPE='NoRecFnd'")
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Vendor_Catalog_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Vendor_Catalog_Search (IN CHAR(64)    profileHandle,
				              CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"

      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Item Number</th>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">Synonynm</th>
                      <th class="colhdr">Product<br>Class</th>
                  </tr>
                  <tr><td class="inputalph">
                          <input type="text" name="srchItem" size="10" maxlength="15">
                          <input type="hidden" name="operItem" value="LIKE">
                      </td>
                      <td class="inputalph">
                          <input type="text" name="srchDesc" size="10" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td class="inputalph">
                          <input type="text" name="srchSyn" size="4" maxlength="15">
                          <input type="hidden" name="operSyn" value="LIKE">
                      </td>
                      <td class="inputalph">
                          <input type="text" name="srchProdClass" size="4" maxlength="4">
                          <input type="hidden" name="operProdClass" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchItem.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("VCVNIT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=vendItem" title="Sequence By Item Number">Item Number</a></th>
                  @OrderBy_Sort("VCIMDSU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=desc" title="Sequence By Description, Item Number">Description</a></th>
                  @OrderBy_Sort("VCSYNM", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=synonym" title="Sequence By Synonym">Synonym</a></th>
                  @OrderBy_Sort("VCPCLS", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=prodClass" title="Sequence By Product Class, Item Number">Product<br>Class</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
          %else
              <table $(contentTable)>
	          %endif		

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Quote(V_VCPITM, F_VCPITM)
              @Format_Quote(V_VCIMDS, F_VCIMDS)

              %if (moreInfo != "Y")	
              %if (V_VCAT == "Y")
                  @dtw_assign(itemClass, "colvcat")
              %else
                  @dtw_assign(itemClass, "colalph")
              %endif
                  @dtw_assign(itemImage, "$(V_VCPITM)$(itemImageExt)")
                  @dtwf_exists(itemImage, imageExists)
                  <tr class="$(rowClass)">
                      <td class="$(itemClass)">$(V_VCVNIT)</td>
                      <td class="$(itemClass)"><a href="javascript:selectItem('$(F_VCPITM)','$(F_VCIMDS)')" title="Select Vendor Item">$(V_VCIMDS)</a></td>
                      <td class="$(itemClass)">$(V_VCSYNM)</td>
                      <td class="$(itemClass)">$(V_VCPCLS)</td>
                      <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(V_VCPITM)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                  </tr>

              %else

                  <tr><td><a href="javascript:selectItem('$(F_VCPITM)','$(F_VCIMDS)')" title="Select Item">$(selectImageLrg)</a></td></tr>

                  <tr><td class="dsphdr">Item Number</td>
                      <td class="dspalph">$(V_VCPITM)</td>
                  </tr>
	   		
                  <tr><td class="dsphdr">Item Description</td>
                      <td class="dspalph">$(V_VCIMDS)</td>
                  </tr>
	   		
                  @RtvFldDesc("PCPCLS='$(V_VCPCLS)'", "HDPCLS", "PCPCDS", fieldDesc)
                  <tr><td class="dsphdr">Product Class</td>
                      <td class="dspalph">$(fieldDesc)</td></tr>

                  @RtvFldDesc("UMUOM='$(V_VCUOMS)'", "HDUOM", "UMUMLD", fieldDesc)
                  <tr><td class="dsphdr">Stocking Unit Of Measure</td>
                      <td class="dspalph">$(fieldDesc)</td></tr>

                  @RtvYNDesc($(V_VCHAZM), fieldDesc)
                  <tr><td class="dsphdr">Hazardous Material</td>
                      <td class="dspalph">$(fieldDesc)</td></tr>

                  %if (V_VCUPC>"0")		
                      @RtvFldDesc("FLTYPE='UPCBAR' and FLVALU='$(V_VCUPCT)'", "SYFLAG", "FLDESC", fieldDesc)
                      <tr><td class="dsphdr">U.P.C. Bar Code Type</td>
                          <td class="dspalph">$(fieldDesc)</td></tr>

                      <tr><td class="dsphdr">U.P.C Number</td>
                          <td class="dspnmbr">$(V_VCUPC)</td></tr>
                  %endif

                  %if (V_VCCATN!="")		
                      <tr><td class="dsphdr">Catalog Number</td>
                          <td class="dspalph">$(V_VCCATN)</td></tr>
                  %endif

                  %if (V_VCITC!="")		
                      @RtvFldDesc("ITITC='$(V_VCITC)'", "HDITYP", "ITDESC", fieldDesc)
                      <tr><td class="dsphdr">Inventory Type</td>
                          <td class="dspalph">$(fieldDesc)</td></tr>
                  %endif

                  %if (V_VCIMWG!=".000")		
                      <tr><td class="dsphdr">Weight</td>
                          <td class="dspnmbr">$(V_VCIMWG)</td></tr>
                  %endif

                  %if (V_VCUOMW!="")		
                      @RtvFldDesc("UMUOM='$(V_VCUOMW)'", "HDUOM", "UMUMLD", fieldDesc)
                      <tr><td class="dsphdr">Weight Unit Of Measure</td>
                          <td class="dspalph">$(fieldDesc)</td></tr>
                  %endif

                  %if (V_VCCSZS!=".0000")		
                      <tr><td class="dsphdr">Cubic Size</td>
                          <td class="dspnmbr">$(V_VCCSZS)</td></tr>
                  %endif

                  %if (V_VCCUUM!="")		
                      @RtvFldDesc("UMUOM='$(V_VCCUUM)'", "HDUOM", "UMUMLD", fieldDesc)
                      <tr><td class="dsphdr">Cubic Unit Of Measure</td>
                          <td class="dspalph">$(fieldDesc)</td></tr>
                  %endif

                  %if (V_VCQUAL!="")		
                      @RtvFldDesc("FLTYPE='QUALCONTRL' and FLVALU='$(V_VCQUAL)'", "SYFLAG", "FLDESC", fieldDesc)
                      <tr><td class="dsphdr">Quality Control Item</td>
                          <td class="dspalph">$(fieldDesc)</td></tr>
                  %endif
              %endif
          %}
      </table>
      %if (moreInfo != "Y")	
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
      %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "VCIMDSU,VCPITM")
      @DTW_ASSIGN(orderByDisplay, "Description, Item Number")
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "vendItem")
      %if (orderBy == "VCVNIT")
          @DTW_ASSIGN(orderBy, "VCVNIT DESC")
          @DTW_ASSIGN(orderByDisplay, "Item Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "VCVNIT")
          @DTW_ASSIGN(orderByDisplay, "Item Number")
      %endif
  %elif (sequence == "desc")
      %if (orderBy == "VCIMDSU,VCVNIT")
          @DTW_ASSIGN(orderBy, "VCIMDSU DESC,VCVNIT")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Item Number")
      %else
          @DTW_ASSIGN(orderBy, "VCIMDSU,VCVNIT")
          @DTW_ASSIGN(orderByDisplay, "Description, Item Number")
      %endif
  %elif (sequence == "synonym")
      %if (orderBy == "VCSYNM")
          @DTW_ASSIGN(orderBy, "VCSYNM DESC")
          @DTW_ASSIGN(orderByDisplay, "Synonym (descending)")
      %else
          @DTW_ASSIGN(orderBy, "VCSYNM")
          @DTW_ASSIGN(orderByDisplay, "Synonym")
      %endif
  %elif (sequence == "prodClass")
      %if (orderBy == "VCPCLS,VCVNIT")
          @DTW_ASSIGN(orderBy, "VCPCLS DESC,VCVNIT")
          @DTW_ASSIGN(orderByDisplay, "Product Class (descending), Item Number")
      %else
          @DTW_ASSIGN(orderBy, "VCPCLS,VCVNIT")
          @DTW_ASSIGN(orderByDisplay, "Product Class, Item Number")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ITEMSEARCH")
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                              <tr><td class="dsphdr">Item Number</td>
                                  @dtw_assign(operNbr, "operItem")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input name="srchItem" type="text" size="15" maxlength="15">$(V_VCPITM)</td>
                              </tr>
            			
                              <tr><td class="dsphdr">Item Description</td>
                                  @dtw_assign(operNbr, "operDesc")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input name="srchDesc" type="text" size="30" maxlength="30"></td>
                              </tr>
            			
                              <tr><td class="dsphdr">Product Class</td>
                                  @dtw_assign(operNbr, "operProdClass")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input name="srchProdClass" type="text" size="4" maxlength="4"><a href="$(homeURL)$(cGIPath)prodclasssearch.d2w/ENTRY$(genericVarBase)&amp;docName=Search&amp;fldName=srchProdClass&amp;fldDesc=productClassDescH" onclick="$(searchWinVar)"> $(searchImage) </a><input name="productClassDescH" type="text" disabled></td>
                              </tr>

                              %if (V_HDPDRL > "0")
                                  <tr><td class="dsphdr">Part Type</td>
                                      @dtw_assign(operNbr, "operPartType")
                                      <td>%INCLUDE "opersel_alph_short.icl"</td>
                                      <td class="inputalph"><input name="srchPartType" type="text" size="1" maxlength="1"></td>
                                  </tr>
                              %endif

                              <tr><td class="dsphdr">Catalog Number</td>
                                  @dtw_assign(operNbr, "operCatalog")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchCatalog" size="15" maxlength="15"></td>
                              </tr>

                              <tr><td class="dsphdr">U.P.C. Number</td>
                                  @dtw_assign(operNbr, "operUPC")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchUPC" size="14" maxlength="14"></td>
                              </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchItem.focus();
                          </script>
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("coalesce(nullif(VCVNIT,' '),nullif(VCITEM,' '), VCPITM)", "Item Number", $(srchItem), "U", operItem, "A")
  @Build_WildCard ("VCIMDSU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("VCSYNM", "Synonynm", $(srchSyn), "U", operSyn, "A")
  @Build_WildCard ("VCPCLS", "Product Class", $(srchProdClass), "U", operProdClass, "A")
  @Build_WildCard ("VCCATN", "Catalog Number", $(srchCatalog), "U", operCatalog, "A")
  @Build_WildCard ("VCUPC", "U.P.C. Number", $(srchUPC), "", operUPC, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}