%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Product Configuration"
  d2wName                 = "CostSimulatorFeatureOption2.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(fromPlant)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "1000"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "1000"
  prtMaxRows              = "1000"
  rowIndexNext            = "1"
  totalPages              = "0"
  errFound                = ""
  imageExists             = ""
  sellPrice               = "0"
  mandatory               = ""
  allowMultiple           = ""
  variableQty             = ""
  linkVariable            = ""
  popUpWin                = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              var optionWin;
              function confirmNoUpdate() {
                  return confirm("Confirm No Update Of Featured Item")
              }              
              %INCLUDE "numedit.icl"
              %INCLUDE "NewWindowOpen.icl"
              function submitForm(action) {document.Chg.action = action; return true;}
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "CSFEATOPTIONS")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      <table $(contentTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1>$(page_title)</h1></td>
                              %if (formatToPrint == "")
                                  <td class="toolbar">
                                      <a href="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)&amp;maintenanceCode=U">$(acceptImageLrg)</a>
                                      <a href="$(homeURL)$(cGIPath)$(d2wName)/NOUPDATE$(d2wVarBase)">$(cancelImageLrg)</a>
                                      <a href="$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)&amp;formatToPrint=Y" target=_blank>$(formatPrintMed)</a>
                                      @dtw_assign(medIcon, "Y")
                                      %INCLUDE "HelpPage.icl"
                                  </td>
                              %endif
                          </tr>
                      </table>

                      <table $(contentTable)>
                          @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
                          @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
                          @RtvFldDesc("WKXHND='$(profileHandle)'", "WRKSIM", "coalesce(WKCUST,0)", customerNumber)
                          @RtvFldDesc("WKXHND='$(profileHandle)'", "WRKSIM", "coalesce(WKQTY,0)", orderQuantity)
                          @RtvFldDesc("WKXHND='$(profileHandle)'", "WRKSIM", "coalesce(WKSELL,0)", sellPrice)
                          @Format_Header("Plant", $(plantName), $(plantNumber))
                          %if (customerNumber != "0")
                              @RtvFldDesc("CMCUST=$(customerNumber)", "HDCUST", "CMCNA1", customerName)
                              @Format_Header("Customer Number", "$(customerName)", $(customerNumber))
                          %endif
                      </table>
                      
                      $(hrTagAttr)

                      <table $(contentTable)>
                          <tr>
                              <td class="colhdr">Item Number</td>
                              <td class="colhdr">Description</td>
                              <td class="colhdr">Quantity</td>
                              <td class="colhdr">Total Price</td>
                              <td class="colhdr">Extended Price</td>
                          </tr>
                          %INCLUDE "SetRowClass.icl"
                          <tr class="$(rowClass)">
                              <td class="colalph">$(itemNumber)</td>		
                              <td class="colalph">$(itemDescription)</td>		
                              @Format_Nbr(orderQuantity, F_qtyOrdered, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                              <td class="colnmbr">$(F_qtyOrdered)</td>
                              @Format_Nbr(sellPrice, F_price, $(prcNbrDec), $(amtEditCode), "Y", "", "")
                              <td class="colnmbr">$(F_price)</td>
                              @Format_Nbr("@dtw_rmultiply(orderQuantity, sellPrice)", ExtendedPrice, "2", $(amtEditCode), "Y", "$", "")
                              <td class="colnmbr">$(ExtendedPrice)</td>
                          </tr>
                      </table>&nbsp;

                      %if (formatToPrint == "")
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select e.SADESC as SAFDSC, e.SAMAND as SAFMAN, e.SAMULT as SAFMUL, e.SAVARQ as SAFVAR, e.SAER# as SAFER#, a.* ", stmtSQL)
                          @dtw_concat(fileSQL, " HDFOPW a join HDFOPW e on a.SAXHND=e.SAXHND and a.SAFEAT=e.SAFEAT and ' '=e.SAOPTN and ' '=e.SABLVL and 'Y'<>e.SASELC ", fileSQL)
                          @dtw_concat(selectSQL, " a.SAXHND='$(profileHandle)' and e.SAMAND='Y' and a.SASELC<>'Y' ", selectSQL)
                          @dtw_concat(selectSQL, " and ( ", selectSQL)
                          @dtw_concat(selectSQL, " (a.SAOPTN=' ' and a.SABLVL=' ' and not exists (Select b.SAOPTN from HDFOPW b where b.SAXHND='$(profileHandle)' and b.SAFEAT=a.SAFEAT and b.SAOPTN<>' ' and b.SAMNCD='S')) ", selectSQL)
                          @dtw_concat(selectSQL, " or ", selectSQL)
                          @dtw_concat(selectSQL, " (a.SAOPTN<>' ' and a.SAMNCD='S') ", selectSQL)
                          @dtw_concat(selectSQL, " ) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By Upper(SAFDSC) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Required_Feature_Query(profileHandle, dataBaseID, stmtSQL)

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_assign(distinctSQL, "SAIGRP,IGDESC")
                          @dtw_concat(stmtSQL, " Select SAIGRP, IGDESC ", stmtSQL)
                          @dtw_concat(fileSQL, " HDFOPW inner join HDIGPH on 'G'=IGTYPE and SAIGRP=IGIGRP and $(plantNumber)=IGPLT ", fileSQL)
                          @dtw_concat(selectSQL, "SAXHND='$(profileHandle)' and SAFEAT>' ' and SAOPTN=' ' and SABLVL=' ' and SASELC<>'Y' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Group by SAIGRP,IGDESC ", stmtSQL)
                          @dtw_concat(stmtSQL, " Order By Upper(IGDESC) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @Feature_Group_Query(profileHandle, dataBaseID, stmtSQL)
                      %endif

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select e.SADESC as SAFDSC, e.SAMAND as SAFMAN, e.SAMULT as SAFMUL, e.SAVARQ as SAFVAR, a.* ", stmtSQL)
                      @dtw_concat(fileSQL, " HDFOPW  a join HDFOPW e on a.SAXHND=e.SAXHND and a.SAFEAT=e.SAFEAT and ' '=e.SAOPTN and ' '=e.SABLVL and 'Y'<>e.SASELC ", fileSQL)
                      @dtw_concat(selectSQL, "a.SAXHND='$(profileHandle)' and a.SAOPTN<>' ' and a.SAMNCD='S' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By Upper(SAFDSC) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      %if (formatToPrint == "Y")
                          @Feature_Item_Print(profileHandle, dataBaseID, stmtSQL)
                      %else
                          @Feature_Item_Query(profileHandle, dataBaseID, stmtSQL)
                      %endif

                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Required_Feature_Query (IN CHAR(64)    profileHandle,
                                              CHAR(2)     dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <fieldset class="legendBodyFO"><legend class="legendTitleFO">Required Feature</legend>
          <table $(contentTable)>
              <tr>
                  <td class="colhdr">$(optionHeading)</td>
                  <td class="colhdr">Feature</td>
                  <td class="colhdr">Option</td>
                  <td class="colhdr">Price</td>
                  <td class="colhdr">Extra<br>Charge</td>
                  <td class="colhdr">Extended Price</td>
                  <td class="colhdr">Quantity</td>
              </tr>
              %if (sql_Record_Count == "0")
                  <tr>
                      <td class="confMsg" colspan="10">No Required Features Found</td>
                  </tr>                	
              %endif

              %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;feature=@dtw_rurlescseq(V_SAFEAT)&amp;featureDesc=@dtw_rurlescseq(V_SAFDSC)&amp;option=@dtw_rurlescseq(V_SAOPTN)&amp;optionDesc=@dtw_rurlescseq(V_SADESC)")
                  @Format_Confirm_Desc($(V_SAFDSC), $(V_SADESC), "", "", "", "", confirmDesc)
                  <tr>
                      <td class="opticon">
                          %if (V_SAMNCD == "S")
                              <a href="$(homeURL)$(cGIPath)CostFeatureOptionPriceOverride.d2w/MAINTAIN$(maintainVar)&amp;biLevel=@dtw_rurlescseq(V_SABLVL)" onclick="$(smallPromptWinVar)">$(changeImageSml)</a>
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                      @dtw_assign(fromD2w, "$(d2wName)/DISPLAY")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)CostSimulatorOptionSearch.d2w/LOAD$(d2wVarBase)&amp;feature=@dtw_rurlescseq(V_SAFEAT)&amp;featureDesc=@dtw_rurlescseq(V_SAFDSC)&amp;maintenanceCode=L&amp;fromD2w=@dtw_rurlescseq(fromD2w)" onclick="$(searchWinVar)" title="Search">$(V_SAFDSC)</a></td>
                      %if (V_SAMNCD != "S" && V_SAFER# != "")
                          @Ret_Error_Msg(profileHandle, dataBaseID, $(V_SAFER#), errorMessage)
                          <td class="error" colspan="4">$(errorMessage)</td>
                      %endif
                      %if (V_SAMNCD == "S")
                          <td class="colalph"><span title="Item $(V_SAOPTN)">$(V_SADESC)</span></td>
                          %if (V_SALPOV == "Y")
                              @Format_Nbr(V_SASLPR, F_SASLPR, $(prcNbrDec), "3", "Y", "", "")
                              <td class="oepriceover" $(helpCursor)><span title="Price has been overridden">$(F_SASLPR)</span></td>
                          %else
                              @Format_Nbr(V_SASLPR, F_SASLPR, $(prcNbrDec), "4", "Y", "", "")
                              <td class="colnmbr">$(F_SASLPR)</td>
                          %endif
                          @Format_Nbr(V_SAXCHG, F_SAXCHG, $(prcNbrDec), "4", "Y", "", "")
                          <td class="colnmbr">$(F_SAXCHG)</td>
                          %if (V_SAPCPP == ".0000")
                              @dtw_assign(V_SAPCPP, "1")
                          %endif
                          @dtw_assign(extPrice, @dtw_radd(@dtw_rdivide(@dtw_rmultiply(V_SAOQTY, V_SASLPR), V_SAPCPP), V_SAXCHG))
                          @Format_Nbr(extPrice, ExtendedPrice, $(prcNbrDec), $(amtEditCode), "Y", "", "")
                          <td class="colnmbr">$(ExtendedPrice)</td>
                          @Format_Nbr(V_SAOQTY, F_SAOQTY, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                          %if (V_SAFVAR == "Y")
                               @dtw_assign(columnId, "$(V_SAFEAT)$(V_SAOPTN)")
                               <td class="colnmbr"><a href="$(homeURL)$(cGIPath)MfgOptionQuantity.d2w/MAINTAIN$(maintainVar)&amp;fromOrdQty=@dtw_rurlescseq(F_SAOQTY)&amp;columnId=@dtw_rurlescseq(columnId)" onclick="$(smallPromptWinVar)" title="Change Quantity"><span id="req$(columnId)">$(F_SAOQTY)</span></a></td>
                          %else
                              <td class="colnmbr">$(F_SAOQTY)</td>
                          %endif
                          @Check_Item_Comments(profileHandle, dataBaseID, V_SAOPTN, "", customerNumber, "WEB", headerTrailer, itemComments)
                          @dtw_assign(itemImage, "$(V_SAOPTN)$(itemImageExt)")
                          @dtwf_exists(itemImage, imageExists)
                          <td class="colicon">
                              @dtw_assign(commentVar, "$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(V_SAOPTN)&amp;itemDesc=@dtw_rurlescseq(V_SADESC)&amp;vendCustNumber=@dtw_rurlescseq(customerNumber)&amp;vendCustFlag=C")
                              %if (itemComments == "Y")
                                  <a href="$(homeURL)$(cGIPath)ItemComments.d2w/REPORT$(commentVar)" onclick="$(commentWinVar)">$(commentExistImage)</a>
                              %elif (itemComments != "")
                                  <a href="$(homeURL)$(cGIPath)VendCustItemComments.d2w/REPORT$(commentVar)" onclick="$(commentWinVar)">$(commentExistImage)</a>
                              %endif
                              %if (imageExists == "Y")
                                  <a href="$(homeURL)$(cGIPath)ImageDisplay.d2w/DISPLAY$(genericVarBase)&amp;imageDisplayPath=$(homeURL)$(itemImage)&amp;imageDesc=@dtw_rurlescseq(V_SADESC)" onclick="$(itemImageWinVar)">$(foundImage)</a>
                              %endif
                          </td>
                      %endif
                  </tr>
              %}

          </table>
      </fieldset>&nbsp;
  %}
%}

%FUNCTION(dtw_sql) Feature_Group_Query (IN CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <fieldset class="legendBodyFO"><legend class="legendTitleFO">Feature Group</legend>
          <table $(contentTable)>
              %if (sql_Record_Count == "0")
                  <tr>
                      <td class="confMsg" colspan="10">No Feature Groups Found</td>
                  </tr>                	
              %endif

              %ROW{
                  <tr>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)CostSimulatorFeatureGroup.d2w/REPORT$(d2wVarBase)&amp;featureGroup=@dtw_rurlescseq(V_SAIGRP)&amp;featureGroupDesc=@dtw_rurlescseq(V_IGDESC)">$(V_IGDESC)</a></td>
                  </tr>
              %}

          </table>
      </fieldset>&nbsp;
  %}
%}

%FUNCTION(dtw_sql) Feature_Item_Query (IN  CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <fieldset class="legendBodyFO"><legend class="legendTitleFO">Selected Options</legend>
          <table $(contentTable)>
              <tr>
                  <td class="colhdr">$(optionHeading)</td>
                  <td class="colhdr">Feature</td>
                  <td class="colhdr">Option</td>
                  <td class="colhdr">Price</td>
                  <td class="colhdr">Extra<br>Charge</td>
                  <td class="colhdr">Extended Price</td>
                  <td class="colhdr">Quantity</td>
              </tr>
              %if (sql_Record_Count == "0")
                  <tr>
                      <td class="confMsg" colspan="10">No Selected Options Found</td>
                  </tr>                	
              %endif
              @dtw_assign(optionTotal, "0")
		
              %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;feature=@dtw_rurlescseq(V_SAFEAT)&amp;featureDesc=@dtw_rurlescseq(V_SAFDSC)&amp;option=@dtw_rurlescseq(V_SAOPTN)&amp;optionDesc=@dtw_rurlescseq(V_SADESC)")
                  @Format_Confirm_Desc($(V_SAFDSC), $(V_SADESC), "", "", "", "", confirmDesc)
                  @Check_Item_Comments(profileHandle, dataBaseID, V_SAOPTN, "", customerNumber, "WEB", headerTrailer, itemComments)
                  @dtw_assign(itemImage, "$(V_SAOPTN)$(itemImageExt)")
                  @dtwf_exists(itemImage, imageExists)
                  <tr>
                      <td class="opticon">
                          <a href="$(homeURL)$(cGIPath)CostFeatureOptionPriceOverride.d2w/MAINTAIN$(maintainVar)&amp;biLevel=@dtw_rurlescseq(V_SABLVL)" onclick="$(smallPromptWinVar)">$(changeImageSml)</a>
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                      </td>
                      @dtw_assign(fromD2w, "$(d2wName)/DISPLAY")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)CostSimulatorOptionSearch.d2w/LOAD$(d2wVarBase)&amp;feature=@dtw_rurlescseq(V_SAFEAT)&amp;featureDesc=@dtw_rurlescseq(V_SAFDSC)&amp;maintenanceCode=L&amp;fromD2w=@dtw_rurlescseq(fromD2w)" onclick="$(searchWinVar)" title="Search">$(V_SAFDSC)</a></td>
                      <td class="colalph"><span title="Item $(V_SAOPTN)">$(V_SADESC)</span></td>
                      %if (V_SALPOV == "Y")
                          @Format_Nbr(V_SASLPR, F_SASLPR, $(prcNbrDec), "3", "Y", "", "")
                          <td class="oepriceover" $(helpCursor)><span title="Price has been overridden">$(F_SASLPR)</span></td>
                      %else
                          @Format_Nbr(V_SASLPR, F_SASLPR, $(prcNbrDec), "4", "Y", "", "")
                          <td class="colnmbr">$(F_SASLPR)</td>
                      %endif
                      @Format_Nbr(V_SAXCHG, F_SAXCHG, $(prcNbrDec), "4", "Y", "", "")
                      <td class="colnmbr">$(F_SAXCHG)</td>
                      %if (V_SAPCPP == ".0000")
                          @dtw_assign(V_SAPCPP, "1")
                      %endif
                      @dtw_assign(extPrice, @dtw_radd(@dtw_rdivide(@dtw_rmultiply(V_SAOQTY, V_SASLPR), V_SAPCPP), V_SAXCHG))
                      @dtw_add(optionTotal, @dtw_radd(@dtw_rdivide(@dtw_rmultiply(V_SAOQTY, V_SASLPR), V_SAPCPP), V_SAXCHG), "15", optionTotal)
                      @Format_Nbr(extPrice, ExtendedPrice, $(prcNbrDec), $(amtEditCode), "Y", "", "")
                      <td class="colnmbr">$(ExtendedPrice)</td>
                      @Format_Nbr(V_SAOQTY, F_SAOQTY, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                      %if (V_SAFVAR == "Y")
                          @dtw_assign(columnId, "$(V_SAFEAT)$(V_SAOPTN)")
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)MfgOptionQuantity.d2w/MAINTAIN$(maintainVar)&amp;fromOrdQty=@dtw_rurlescseq(F_SAOQTY)&amp;columnId=@dtw_rurlescseq(columnId)" onclick="$(smallPromptWinVar)" title="Change Quantity"><span id="sel$(columnId)">$(F_SAOQTY)</span></a></td>
                      %else
                          <td class="colnmbr">$(F_SAOQTY)</td>
                      %endif
                      <td class="colicon">
                          @dtw_assign(commentVar, "$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(V_SAOPTN)&amp;itemDesc=@dtw_rurlescseq(V_SADESC)&amp;vendCustNumber=@dtw_rurlescseq(customerNumber)&amp;vendCustFlag=C")
                          %if (itemComments == "Y")
                              <a href="$(homeURL)$(cGIPath)ItemComments.d2w/REPORT$(commentVar)" onclick="$(commentWinVar)">$(commentExistImage)</a>
                          %elif (itemComments != "")
                              <a href="$(homeURL)$(cGIPath)VendCustItemComments.d2w/REPORT$(commentVar)" onclick="$(commentWinVar)">$(commentExistImage)</a>
                          %endif
                          %if (imageExists == "Y")
                              <a href="$(homeURL)$(cGIPath)ImageDisplay.d2w/DISPLAY$(genericVarBase)&amp;imageDisplayPath=$(homeURL)$(itemImage)&amp;imageDesc=@dtw_rurlescseq(V_SADESC)" onclick="$(itemImageWinVar)">$(foundImage)</a>
                          %endif
                      </td>
                  </tr>
              %}
              @Format_Nbr(optionTotal, F_optionTotal, $(prcNbrDec), $(amtEditCode), "Y", "", "")
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colnmbr" colspan="5">Option Total</td>
                  <td class="coltotal">$(F_optionTotal)</td>
              </tr>
              @dtw_subtract(sellPrice, optionTotal, itemPrice)
              @Format_Nbr(itemPrice, F_itemPrice, $(prcNbrDec), $(amtEditCode), "Y", "", "")
              <tr class="$(rowClass)">
                  <td class="colnmbr" colspan="5">Base Item Price</td>
                  <td class="colnmbr">$(F_itemPrice)</td>
              </tr>
              @Format_Nbr(sellPrice, F_price, $(prcNbrDec), $(amtEditCode), "Y", "", "")
              <tr class="$(rowClass)">
                  <td class="colnmbr" colspan="5">Total Price</td>
                  <td class="coltotal">$(F_price)</td>
              </tr>
          </table>
      </fieldset>
  <a href="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)&amp;maintenanceCode=U">$(acceptImageLrg)</a>
  <a href="$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)&amp;formatToPrint=Y" target=_blank>$(formatPrintMed)</a>
  @dtw_assign(medIcon, "Y")
  %INCLUDE "HelpPage.icl"
  $(hrTagAttr)
  %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_sql) Feature_Item_Print (IN  CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <tr>
              <td class="colhdr">Feature</td>
              <td class="colhdr">Option</td>
              <td class="colhdr">Description</td>
              <td class="colhdr">Quantity</td>
              <td class="colhdr">Price</td>
              <td class="colhdr">Extra Charge</td>
              <td class="colhdr">Extended Price</td>
          </tr>
          @dtw_assign(saveFeature, "")
          @dtw_assign(optionTotal, "0")
		
          %ROW{
              %if (saveFeature != V_SAFEAT)
                  %INCLUDE "SetRowClass.icl"
                  @dtw_assign(saveFeature, V_SAFEAT)
                  @dtw_assign(newFeature, V_SAFEAT)
              %else
                  @dtw_assign(newFeature, "")
              %endif
              %if (V_SAPCPP == ".0000")
                  @dtw_assign(V_SAPCPP, "1")
              %endif
              @dtw_assign(extPrice, @dtw_radd(@dtw_rdivide(@dtw_rmultiply(V_SAOQTY, V_SASLPR), V_SAPCPP), V_SAXCHG))
              @dtw_add(optionTotal, @dtw_radd(@dtw_rdivide(@dtw_rmultiply(V_SAOQTY, V_SASLPR), V_SAPCPP), V_SAXCHG), "15", optionTotal)
              @Format_Nbr(extPrice, ExtendedPrice, $(prcNbrDec), $(amtEditCode), "Y", "", "")
              <tr class="$(rowClass)">
                  <td class="colalph">$(newFeature)</td>
                  <td class="colalph">$(V_SAOPTN)</td>
                  <td class="colalph">$(V_SADESC)</td>
                  @Format_Nbr(V_SAOQTY, F_SAOQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  <td class="colnmbr">$(F_SAOQTY)</td>
                  @Format_Nbr(V_SASLPR, F_SASLPR, $(prcNbrDec), "4", "", "", "")
                  <td class="colnmbr">$(F_SASLPR)</td>
                  @Format_Nbr(V_SAXCHG, F_SAXCHG, $(prcNbrDec), "4", "", "", "")
                  <td class="colnmbr">$(F_SAXCHG)</td>
                  <td class="colnmbr">$(ExtendedPrice)</td>
              </tr>
          %}
          @Format_Nbr(optionTotal, F_optionTotal, $(prcNbrDec), $(amtEditCode), "Y", "", "")
          %INCLUDE "SetRowClass.icl"
          <tr class="$(rowClass)">
              <td class="colnmbr" colspan="6">Option Total</td>
              <td class="coltotal">$(F_optionTotal)</td>
          </tr>
          @dtw_subtract(sellPrice, optionTotal, itemPrice)
          @Format_Nbr(itemPrice, F_itemPrice, $(prcNbrDec), $(amtEditCode), "Y", "", "")
          <tr class="$(rowClass)">
              <td class="colnmbr" colspan="6">Base Item Price</td>
              <td class="colnmbr">$(F_itemPrice)</td>
          </tr>
          @Format_Nbr(sellPrice, F_price, $(prcNbrDec), $(amtEditCode), "Y", "", "")
          <tr class="$(rowClass)">
              <td class="colnmbr" colspan="6">Total Price</td>
              <td class="coltotal">$(F_price)</td>
          </tr>
      </table>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}


%FUNCTION(dtw_directcall) Update_Feature_Option (INOUT CHAR(64)    profileHandle,
                                                 INOUT CHAR(32000) edtVar,
                                                 INOUT CHAR(32000) errVar,
                                                 INOUT CHAR(1)     errFound)
{%EXEC {HSCFO2_W.PGM %}
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@item", itemNumber)
  @Concat_Field("@@mncd", maintenanceCode)
  @Concat_Field("@@ucat", productCfgOptionDesc)
  %if (maintenanceCode != "U")
      @Concat_Field("@@feat", feature)
      @Concat_Field("@@optn", option)
  %endif

  @dtw_concat(edtVar, "}{", edtVar)
  @Update_Feature_Option(profileHandle, edtVar, errVar, errFound)

  %if (errFound == "Y" || maintenanceCode != "U")
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)">
  %else
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)CostSimulatorDisplay.d2w/REPORT$(d2wVarBase)">
  %endif
%}

%HTML(NOUPDATE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@item", itemNumber)
  @Concat_Field("@@mncd", "E")
  @dtw_concat(edtVar, "}{", edtVar)

  @Update_Feature_Option(profileHandle, edtVar, errVar, errFound)

  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)CostSimulatorDisplay.d2w/REPORT$(d2wVarBase)">
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("SAPLT=$(plantNumber) and SAFPRT='$(itemNumber)'", "HDOPWD", "char(count(*))", dftCount)
  %if (dftCount > "0")

      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Delete From HDFOPW Where SAXHND='$(profileHandle)' @@endsql", stmtSQL)
      @SQL_Update(stmtSQL, status)

      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Insert Into HDFOPW (SAXHND,SARSEQ,SAFPRT,SAFEAT,SABLVL,SABLDS,SAMNCD,SAOPTN,SADESC,SAMAND,SAMULT,SAXCHG, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     SAIMQT,SAVARQ,SAFQTY,SAOQTY,SASLPR,SAPCPP,SALPOV,SASLFT,SAER#,SASELC,SAVCAT, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     SAIAVO,SARBLV,SAROPT,SAIGRP,SANAME) ", stmtSQL)
      @dtw_concat(stmtSQL, " Select '$(profileHandle)',SARSEQ,'$(itemNumber)',SAFEAT,SABLVL,SABLDS,SAMNCD,SAOPTN,SADESC,SAMAND,SAMULT,SAXCHG, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     SAIMQT,SAVARQ,SAFQTY,SAOQTY,SASLPR,SAPCPP,SALPOV,SASLFT,SAER#,SASELC,SAVCAT, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     SAIAVO,SARBLV,SAROPT,SAIGRP,SANAME ", stmtSQL)
      @dtw_concat(stmtSQL, " From HDOPWD Where SAPLT=$(plantNumber) and SAFPRT='$(itemNumber)' @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)
      
      @dtw_assign(edtVar, "")
      @Concat_Field("@@plt@", plantNumber)
      @Concat_Field("@@item", itemNumber)
      @dtw_assign(maintenanceCode, "P")
      @Concat_Field("@@mncd", maintenanceCode)
      @Concat_Field("@@ucat", productCfgOptionDesc)
      @dtw_concat(edtVar, "}{", edtVar)

      @Update_Feature_Option(profileHandle, edtVar, errVar, errFound)
  %else
      @dtw_assign(edtVar, "")
      @Concat_Field("@@plt@", plantNumber)
      @Concat_Field("@@item", itemNumber)
      @Concat_Field("@@mncd", "L")
      @Concat_Field("@@ucat", productCfgOptionDesc)
      @dtw_concat(edtVar, "}{", edtVar)

      @Update_Feature_Option(profileHandle, edtVar, errVar, errFound)
  %endif
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)&amp;updateRowNum=@dtw_rurlescseq(updateRowNum)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(PRICE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@item", itemNumber)
  @Concat_Field("@@mncd", maintenanceCode)
  @Concat_Field("@@ucat", productCfgOptionDesc)
  @Concat_Field("@@feat", feature)
  @Concat_Field("@@optn", option)
  @dtw_concat(edtVar, "}{", edtVar)

  @Update_Feature_Option(profileHandle, edtVar, errVar, errFound)
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)&amp;updateRowNum=@dtw_rurlescseq(updateRowNum)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  %if (updateRowNum > "0")
      @dtw_assign(START_ROW_NUM,  "$(updateRowNum)")
  %endif
  @Set_SQL(stmtSQL)
%}