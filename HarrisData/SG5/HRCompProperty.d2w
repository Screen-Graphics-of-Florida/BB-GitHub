%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title 	        = "Employee Property"
  d2wName              = "HRCompProperty.d2w"
  d2wVarBase           = "$(genericVarBase)&amp;hrCompany=@dtw_rurlescseq(hrCompany)&amp;inclActive=@dtw_rurlescseq(inclActive)&amp;inclTerminated=@dtw_rurlescseq(inclTerminated)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(d2wName)"
  nextPrevVar          = "$(d2wVarBase)"
  wildDftVar           = "REPORT$(d2wVarBase)"
  programName          = "HPEPRO"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  facilityZero         = "0000"
  inclActive           = ""
  inclTerminated       = ""
  rowIndexNext		= "1"
  totalPages		= "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@hrCompany", "@dtw_rurlescseq(hrCompany)", "1", "a", workURL)
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
  @dtw_replace(workURL, "@@fromD2w", "@dtw_rurlescseq(fromD2w)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchEmployee, 9, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                       @dtw_assign(pageID, "HRCOMPPROP")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "UserViewEmpl.icl"
                      %INCLUDE "UserView.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select PRCOMP, PREMPL, PRSEQ, PRTYPR, PRDESC, PRISSU, ODDESC, PRRENW, ", stmtSQL)
                      @dtw_concat(stmtSQL, " EMCOMP, EMFACL, EMEMPL, EMPECP, EMPEMP, EMLNAM, EMLNAMU, EMMIDI, EMFNAM, ", stmtSQL)
                      @dtw_concat(stmtSQL, " EMFNAMU, EMRNAM, EMFNAMU, EMLNAMU, EMTRCD, EMDEPT, EMLOC, EMJOB, EMTYPE,", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(PRDESC) as PRDESCU,", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(ODDESC) as ODDESCU", stmtSQL)
                      @dtw_concat(fileSQL, " PEPROP inner join HREMPL on PRCOMP=EMPECP and PREMPL=EMPEMP ", fileSQL)
                      @dtw_concat(fileSQL, "        inner join PECODE on PRCOMP=ODCOMP and PRTYPR=ODCODE and ODTYPE='N' ", fileSQL)
                      @dtw_concat(selectSQL, " PRCOMP=$(hrCompany)", selectSQL)
                      %INCLUDE "activeTerminatedEmplSQL.icl"
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @EmplProp_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) EmplProp_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count != "1")
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/report") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>

              @RetHrCompNam(profileHandle, dataBaseID, hrCompany, facilityZero, coFacName)
              <tr><td><h2>$(coFacName)</h2></td></tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"
          $(hrTagAttr)

          %if (formatToPrint != "Y")
	       <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Last<br>Name</th>
                          <th class="colhdr">Property<br>Description</th>
                          <th class="colhdr">Employee<br>Number</th>
                      </tr>
                      <tr><td class="inputalph"><input type="text" name="srchLast" size="18" maxlength="18">
                              <input type="hidden" name="operLast" value="LIKE">
                          </td>
                          <td class="inputalph"><input type="text" name="srchPropDesc" size="20" maxlength="20">
                              <input type="hidden" name="operPropDesc" value="LIKE">
                          </td>
                          <td class="inputalph"><input type="text" name="srchEmployee" size="9" maxlength="9">
                              <input type="hidden" name="operEmployee" value="=">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchLast.focus();
                  </script>
              </form>

              %INCLUDE "ActiveTerminatedChecked.icl"
              @dtw_assign(viewCheckBox, "HR")
              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              <tr>
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("PREMPL", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Employee" title="Sequence By Employee Number, Property Description">Employee<br>Number</a></th>
                  @OrderBy_Sort("EMLNAMU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=LastName" title="Sequence By Employee Last Name, Property Description">Name</a></th>
                  @OrderBy_Sort("PRTYPR", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Property" title="Sequence By Property Type, Property Description">Property<br>Type</a></th>
                  @OrderBy_Sort("ODDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TypeDesc" title="Sequence By Type Description, Property Description">Type<br>Description</a></th>
                  @OrderBy_Sort("PRDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PropDesc" title="Sequence By Property Description, Type Description">Property Description</a></th>
                  @OrderBy_Sort("PRISSU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Issue" title="Sequence By Issue Date, Property Description">Issue<br> Date</a></th>
                  @OrderBy_Sort("PRRENW", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Renewal" title="Sequence By Renewal Date, Property Description">Renewal<br>Date</a></th>
              </tr>
          %INCLUDE "NoRecordsFound.icl"
      %endif
	       %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;prCompany=@dtw_rurlescseq(V_EMCOMP)&amp;prFacility=@dtw_rurlescseq(V_EMFACL)&amp;prEmployee=@dtw_rurlescseq(V_EMEMPL)&amp;hrEmployee=@dtw_rurlescseq(V_EMPEMP)&amp;sequenceNumber=@dtw_rurlescseq(V_PRSEQ)&amp;propertyType=@dtw_rurlescseq(V_PRTYPR)&amp;propertyTypeDesc=@dtw_rurlescseq(V_ODDESC)&amp;propertyDesc=@dtw_rurlescseq(V_PRDESC)")
                  %if (sql_Record_Count == "1")
                      @Save_WebReg(webRegCurFile, profileHandle, d2wName, "", orderBy, orderByDisplay, "")
                      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)EmplPropertySelect.d2w/REPORT$(maintainVar)">
                  %else
                      @Format_Date(V_PRISSU, "D", F_PRISSU)
                      @Format_Date(V_PRRENW, "D", F_PRRENW)
                      @Format_Confirm_Desc($(V_PRDESC), "", $(V_ODDESC), $(V_PRTYPR), "", "", confirmDesc)

                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                              <td class="opticon">
                                  %if (sec_02 == "Y" || sec_03 == "Y")
                                      <a href="$(homeURL)$(cGIPath)EmplPropertyMaintain.d2w/REPORT$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                                  %endif
                                  %if (sec_01=="Y" && sec_04=="Y")
                                      <a href="$(homeURL)$(cGIPath)EmplPropertyMaintain.d2w/REPORT$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                                  %endif
                                  %if (sec_03 == "Y")
                                      <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)EmplPropertyMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                                  %endif
                              </td>
                          %endif
                          @Format_EmplName(V_EMFNAM, V_EMLNAM, V_EMMIDI, V_EMRNAM, V_EMTRCD, "D", F_EmpName)
                          <td class="colnmbr">$(V_PREMPL)</td>
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)EmployeeProperty.d2w/REPORT$(maintainVar)" title="View All Property For This Employee">$(F_EmpName)</a></td>
                          <td class="colcode"><a href="$(homeURL)$(cGIPath)EmplPropertySelect.d2w/REPORT$(maintainVar)" title="View Property Row">$(V_PRTYPR)</a></td>
                          <td class="colalph">$(V_ODDESC)</td>
                          <td class="colalph">$(V_PRDESC)</td>
                          <td class="coldate">$(F_PRISSU)</td>
                          <td class="coldate">$(F_PRRENW)</td>
                      </tr>
                  %endif
	       %}
	   </table>
          %if (sql_Record_Count != "1")
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "UserViewEmpl.icl"
  %INCLUDE "UserView.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select PRCOMP, PREMPL, PRSEQ, PRTYPR, PRDESC, PRISSU, ODDESC, PRRENW, ", stmtSQL)
  @dtw_concat(stmtSQL, " EMCOMP, EMFACL, EMEMPL, EMPECP, EMPEMP, EMLNAM, EMLNAMU, EMMIDI, EMFNAM, ", stmtSQL)
  @dtw_concat(stmtSQL, " EMFNAMU, EMRNAM, EMFNAMU, EMLNAMU, EMTRCD, EMDEPT, EMLOC, EMJOB, EMTYPE,", stmtSQL)
  @dtw_concat(stmtSQL, " upper(PRDESC) as PRDESCU,", stmtSQL)
  @dtw_concat(stmtSQL, " upper(ODDESC) as ODDESCU", stmtSQL)
  @dtw_concat(fileSQL, " PEPROP inner join HREMPL on PRCOMP=EMPECP and PREMPL=EMPEMP ", fileSQL)
  @dtw_concat(fileSQL, "        inner join PECODE on PRCOMP=ODCOMP and PRTYPR=ODCODE and ODTYPE='N' ", fileSQL)
  @dtw_concat(selectSQL, " PRCOMP=$(hrCompany)", selectSQL)
  %INCLUDE "activeTerminatedEmplSQL.icl"
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @EmplProp_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) EmplProp_XMLQuery (IN CHAR(64)    profileHandle,
			                  CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("CompanyPropertyList")
          %ROW{
               @DateFromCYMD(V_PRISSU)
               @DateFromCYMD(V_PRRENW)
               @EditPhoneNumber(V_EMPHON)

		    @XMLIDTag(@DTW_rCONCAT(V_PRCOMP, @DTW_rCONCAT("/", @DTW_rCONCAT(V_PREMPL, @DTW_rCONCAT("/", V_PRSEQ)))), "Property ID")
                   @XMLTag(V_PRCOMP, "CompanyNumber")
                   @XMLTag(V_PREMPL, "EmployeeNumber")
                   @XMLBeginTag("PersonName")
                       @XMLTag(V_EMRNAM, "FormattedName")
                       @XMLTag(V_EMFNAM, "GivenName")
                       @XMLTag(V_EMMIDI, "MiddleName")
                       @XMLTag(V_EMLNAM, "FamilyName")
                   @XMLEndTag("PersonName")
                   @XMLTag(V_PRTYPR, "PropertyType")
                   @XMLTag(V_ODDESC, "TypeDescription")
                   @XMLTag(V_PRDESC, "PropertyDescription")
                   @XMLTag(V_PRISSU, "IssueDate")
                   @XMLTag(V_PRRENW, "RenewalDate")
               @XMLEndTag("Property")
          %}
      @XMLEndTag("CompanyPropertyList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "PRTYPR,PRDESC")
              @DTW_ASSIGN(orderByDisplay, "Property Type, Property Description")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %elif (chgActive == "Y" && inclActive == "Y")
              @dtw_assign(inclActive, "")
          %elif (chgActive == "Y")
              @dtw_assign(inclActive, "Y")
          %elif (chgTerminated == "Y" && inclTerminated == "Y")
              @dtw_assign(inclTerminated, "")
          %elif (chgTerminated == "Y")
              @dtw_assign(inclTerminated, "Y")
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      %if (inclActive == "" && inclTerminated == "" && chgActive != "Y" && chgTerminated != "Y")
          @dtw_assign(inclActive, activeEmpl)
          @dtw_assign(inclTerminated, terminatedEmpl)
      %endif
      %INCLUDE "SearchReturn.icl"
  %endif
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Property")
      %if (orderBy == "PRTYPR,PRDESCU")
          @DTW_ASSIGN(orderBy, "PRTYPR DESC,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Property Type (descending), Property Description")
      %else
          @DTW_ASSIGN(orderBy, "PRTYPR,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Property Type, Property Description")
      %endif
  %elif (sequence == "TypeDesc")
      %if (orderBy == "ODDESCU,PRDESCU")
          @DTW_ASSIGN(orderBy, "ODDESCU DESC,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Type Description (descending), Property Description")
      %else
          @DTW_ASSIGN(orderBy, "ODDESCU,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Type Description, Property Description")
      %endif
  %elif (sequence == "PropDesc")
      %if (orderBy == "PRDESCU,ODDESCU")
          @DTW_ASSIGN(orderBy, "PRDESCU DESC,ODDESCU")
          @DTW_ASSIGN(orderByDisplay, "Property Description (descending), Type Description")
      %else
          @DTW_ASSIGN(orderBy, "PRDESCU,ODDESCU")
          @DTW_ASSIGN(orderByDisplay, "Property Description, Type Description")
      %endif
  %elif (sequence == "Issue")
      %if (orderBy == "PRISSU,PRDESCU")
          @DTW_ASSIGN(orderBy, "PRISSU DESC,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Issue Date (descending), Property Description")
      %else
          @DTW_ASSIGN(orderBy, "PRISSU,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Issue Date, Property Description")
      %endif
  %elif (sequence == "Renewal")
      %if (orderBy == "PRRENW,PRDESCU")
          @DTW_ASSIGN(orderBy, "PRRENW DESC,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Renewal Date (descending), Property Description")
      %else
          @DTW_ASSIGN(orderBy, "PRRENW,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Renewal Date, Property Description")
      %endif
  %elif (sequence == "Employee")
      %if (orderBy == "PREMPL,PRDESCU")
          @DTW_ASSIGN(orderBy, "PREMPL DESC,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Employee Number (descending), Property Description")
      %else
          @DTW_ASSIGN(orderBy, "PREMPL,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Employee Number, Property Description")
      %endif
  %elif (sequence == "LastName")
      %if (orderBy == "EMLNAMU,EMFNAMU,PRDESCU")
          @DTW_ASSIGN(orderBy, "EMLNAMU DESC,EMFNAMU,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Last Name (descending), First Name, Property Description")
      %else
          @DTW_ASSIGN(orderBy, "EMLNAMU,EMFNAMU,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Last Name, First Name, Property Description")
      %endif
  %endif
	
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              @dtw_assign(formName, "Search")
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editdate(document.Search.srchIssue) &&
                      editdate(document.Search.srchFromRenewal) &&
                      editdate(document.Search.srchToRenewal) &&
                      editNum(document.Search.srchEmployee, 9, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->

          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "COMPPROPSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      @RetHrCompNam(profileHandle, dataBaseID, hrCompany, facilityZero, coFacName)
                      <h2>$(coFacName)</h2>

                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><th class="dsphdr"> <br>Property</th></tr>

                          <tr><td class="dsphdr"><br>Property Type</td>
                              @dtw_assign(operNbr, "operType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchType" type="text" size="5" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Search&amp;fldComp=@dtw_rurlescseq(hrCompany)&amp;fldType=N&amp;fldName=srchType&amp;fldDesc=typeCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="typeCodeDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Property Type Description</td>
                              @dtw_assign(operNbr, "operTypeDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchTypeDesc" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Property Description</td>
                              @dtw_assign(operNbr, "operPropDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchPropDesc" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Issue Date</td>
                              @dtw_assign(operNbr, "operIssue")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchIssue" size="6" maxlength="6"> 		
                                  <a href="javascript:calWindow('srchIssue');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">From Renewal Date</td>
                              @dtw_assign(operNbr, "operFromRenewal")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchFromRenewal" size="6" maxlength="6"> 		
                                  <a href="javascript:calWindow('srchFromRenewal');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">To Renewal Date</td>
                              @dtw_assign(operNbr, "operToRenewal")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchToRenewal" size="6" maxlength="6"> 		
                                  <a href="javascript:calWindow('srchToRenewal');">$(calendarImage)</a></td>
                          </tr>

                          <tr><th class="dsphdr"> <br>Employee</th></tr>

                          <tr><td class="dsphdr"><br>Number</td>
                              @dtw_assign(operNbr, "operEmployee")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchEmployee" size="9" maxlength="9"></td>
                          </tr>

                          <tr><td class="dsphdr">First Name</td>
                              @dtw_assign(operNbr, "operFirst")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchFirst" size="18" maxlength="18"></td>
                          </tr>

                          <tr><td class="dsphdr">Last Name</td>
                              @dtw_assign(operNbr, "operLast")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchLast" size="18" maxlength="18"></td>
                          </tr>

                          <tr><td class="dsphdr">Location</td>
                              @dtw_assign(operNbr, "operLoc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchLoc" type="text" size="5" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Search&amp;fldComp=@dtw_rurlescseq(hrCompany)&amp;fldType=O&amp;fldName=srchLoc&amp;fldDesc=locCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="locCodeDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Department</td>
                              @dtw_assign(operNbr, "operDept")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchDept" type="text" size="5" maxlength="5"> <a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Search&amp;fldName=srchDept&amp;fldDesc=deptDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="deptDesc" value="$(deptDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Job Code</td>
                              @dtw_assign(operNbr, "operJob")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchJob" type="text" size="5" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Search&amp;fldComp=@dtw_rurlescseq(hrCompany)&amp;fldType=J&amp;fldName=srchJob&amp;fldDesc=jobCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="jobCodeDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchTypeDesc.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("PRTYPR", "Property Type", $(srchType), "U", operType, "A")
  @Build_WildCard ("upper(PRDESC)", "Property Type Description", $(srchPropDesc), "U", operPropDesc, "A")
  @Build_WildCard ("upper(ODDESC)", "Type Description", $(srchTypeDesc), "U", operTypeDesc, "A")
  @Build_WildCard ("PRISSU", "Issue Date", $(srchIssue), "", operIssue, "D")
  @Build_WildCard ("PRRENW", "From Renewal Date", $(srchFromRenewal), "", operFromRenewal, "D")
  @Build_WildCard ("PRRENW", "To Renewal Date", $(srchToRenewal), "", operToRenewal, "D")
  @Build_WildCard ("EHRSP", "Gross Pay", $(srchGross), "", operGross, "N")
  @Build_WildCard ("EHNETP", "Net Pay", $(srchNet), "", operNet, "N")
  @Build_WildCard ("EHPPDT", "Pay Period End Date", $(srchPayPer), "", operPayPer, "D")
  @Build_WildCard ("PREMPL", "Employee Number", $(srchEmployee), "", operEmployee, "N")
  @Build_WildCard ("EMFNAMU", "First Name", $(srchFirst), "U", operFirst, "A")
  @Build_WildCard ("EMLNAMU", "Last Name", $(srchLast), "U", operLast, "A")
  @Build_WildCard ("EMLOC", "Location", $(srchLoc), "U", operLoc, "A")
  @Build_WildCard ("EMDEPT", "Department", $(srchDept), "U", operDept, "A")
  @Build_WildCard ("EMJOB", "Job Code", $(srchJob), "U", operJob, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}