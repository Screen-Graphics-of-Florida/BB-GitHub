%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Activity"
  d2wName                 = "WFActivity.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfProcess=@dtw_rurlescseq(wfProcess)&amp;passedWfPoint=@dtw_rurlescseq(passedWfPoint)&amp;passedWfSequence=@dtw_rurlescseq(passedWfSequence)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HWFACM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  noMsg                   = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "WFACTIVITY")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select WFPRAC.*,  ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(FLDESC,' ') as FLDESC, upper(coalesce(FLDESC,' ')) as FLDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " WFPRAC ", fileSQL)
                      %if (passedWfPoint != "")
                          @dtw_concat(fileSQL, " inner join WFPRDT on PDPPRC=ATPROC and PDPACT=ATACTV and PDPROC='$(wfProcess)' and PDPONT=$(passedWfPoint) and PDSEQ=$(passedWfSequence) ", fileSQL)
                      %endif
                      @dtw_concat(fileSQL, " left join SYFLAG on FLTYPE='WFMODE' and FLVALU=ATMODE ", fileSQL)
                      @dtw_concat(selectSQL, " ATPROC='$(wfProcess)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)WFActivityMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      <table $(contentTable)>
          @RtvFldDesc("PRPROC='$(wfProcess)'", "WFPRHD", "PRDESC", V_PRDESC)
          @Format_Header_URL("Process", $(V_PRDESC), $(wfProcess), "$(homeURL)$(cGIPath)WFProcessSelect.d2w/REPORT$(d2wVarBase)")

          %if (passedWfPoint != "")
              @RtvFldDesc("PDPROC='$(wfProcess)' and PDPONT=$(passedWfPoint) and PDSEQ=$(passedWfSequence)", "WFPRDT", "PDDESC", V_PDDESC)
              @Format_Header_URL("Detail Point", $(V_PDDESC), "$(passedWfPoint)-$(passedWfSequence)", "$(homeURL)$(cGIPath)WFDetailSelect.d2w/REPORT$(d2wVarBase)")
          %endif
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint == "")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">Activity</th>
                      <th class="colhdr">Start Mode</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="15" maxlength="50">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchActivity" size="15" maxlength="30">
                          <input type="hidden" name="operActivity" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchMode" size="15" maxlength="30">
                          <input type="hidden" name="operMode" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("ATDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description"    title="Sequence By Description, Activity">Description</a></th>
              @OrderBy_Sort("ATACTV", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Activity"  title="Sequence By Activity">Activity</a></th>
              @OrderBy_Sort("FLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=StartMode" title="Sequence By Start Mode, Activity">Start Mode</a></th>
              @OrderBy_Sort("ATPGM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Program"    title="Sequence By Activity Program, Activity">Activity Program</a></th>
              @OrderBy_Sort("ATD2W", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=D2wPage"    title="Sequence By Script To Process, Activity">Script To Process</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;wfActivity=@dtw_rurlescseq(V_ATACTV)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;updRecNbr=@dtw_rurlescseq(START_ROW_NUM)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_ATDESC), $(V_ATACTV), "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)WFActivityMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)WFActivityMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromActivity=@dtw_rurlescseq(V_ATACTV)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)WFActivityMaintain.d2w/EDIT_DATA$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_ATDESC)</td>
                  <td class="colalph">$(V_ATACTV)</td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_ATMODE)">$(V_FLDESC)</span></td>
                  <td class="colalph">$(V_ATPGM)</td>
                  <td class="colalph">$(V_ATD2W)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select WFPRAC.*,  ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(FLDESC,' ') as FLDESC, upper(coalesce(FLDESC,' ')) as FLDESCU ", stmtSQL)
  @dtw_concat(fileSQL, " WFPRAC ", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG on FLTYPE='WFMODE' and FLVALU=ATMODE ", fileSQL)
  @dtw_concat(selectSQL, " ATPROC='$(wfProcess)' ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_XMLQuery (IN  CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("WFActivityList")
          %ROW{
              @XMLIDTag("$(V_ATPROC)-$(V_ATACTV)", "Activity ID")
                  @XMLTag(V_ATPROC, "Process")
                  @XMLTag(V_ATACTV, "Activity")
                  @XMLTag(V_ATDESC, "Description")
                  @XMLTag(V_ATMODE, "StartMode")
                  @XMLTag(V_ATPRTY, "Priority")
                  @XMLTag(V_ATPGM, "Program")
                  @XMLTag(V_ATD2W, "Script")
              @XMLEndTag("Activity")
          %}
      @XMLEndTag("WFActivityList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "ATDESCU,ATACTV")
          @DTW_ASSIGN(orderByDisplay, "Description, Activity")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %if (updRecNbr > "0")
      @dtw_assign(START_ROW_NUM, updRecNbr)
      @dtw_assign(updRecNbr, "")
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Description")
      %if (orderBy == "ATDESCU,ATACTV")
          @DTW_ASSIGN(orderBy, "ATDESCU DESC,ATACTV")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Activity")
      %else
          @DTW_ASSIGN(orderBy, "ATDESCU,ATACTV")
          @DTW_ASSIGN(orderByDisplay, "Description, Activity")
      %endif
  %elif (sequence == "Activity")
      %if (orderBy == "ATACTV")
          @DTW_ASSIGN(orderBy, "ATACTV DESC")
          @DTW_ASSIGN(orderByDisplay, "Activity (descending)")
      %else
          @DTW_ASSIGN(orderBy, "ATACTV")
          @DTW_ASSIGN(orderByDisplay, "Activity")
      %endif
  %elif (sequence == "StartMode")
      %if (orderBy == "FLDESCU,ATACTV")
          @DTW_ASSIGN(orderBy, "FLDESCU DESC,ATACTV")
          @DTW_ASSIGN(orderByDisplay, "Start Mode (descending), Activity")
      %else
          @DTW_ASSIGN(orderBy, "FLDESCU,ATACTV")
          @DTW_ASSIGN(orderByDisplay, "Start Mode, Activity")
      %endif
 %elif (sequence == "Program")
      %if (orderBy == "ATPGM,ATACTV")
          @DTW_ASSIGN(orderBy, "ATPGM DESC,ATACTV")
          @DTW_ASSIGN(orderByDisplay, "Activity Program (descending), Activity")
      %else
          @DTW_ASSIGN(orderBy, "ATPGM,ATACTV")
          @DTW_ASSIGN(orderByDisplay, "Activity Program, Activity")
      %endif
 %elif (sequence == "D2wPage")
      %if (orderBy == "ATD2W,ATACTV")
          @DTW_ASSIGN(orderBy, "ATD2W DESC,ATACTV")
          @DTW_ASSIGN(orderByDisplay, "Script To Process (descending), Activity")
      %else
          @DTW_ASSIGN(orderBy, "ATD2W,ATACTV")
          @DTW_ASSIGN(orderByDisplay, "Script To Process, Activity")
      %endif
  %endif
	
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchPriority, 2, 0) &&
                      editNum(document.Search.srchParticipantRequired, 2, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFACTIVITYSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Activity</td>
                              @dtw_assign(operNbr, "operActivity")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchActivity" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Start Mode</td>
                              @dtw_assign(operNbr, "operMode")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchMode" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Priority</td>
                              @dtw_assign(operNbr, "operPriority")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchPriority" size="2" maxlength="2"></td>
            	       </tr>	

                          <tr><td class="dsphdr">Script To Process</td>
                              @dtw_assign(operNbr, "operD2W")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchD2W" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Activity Program</td>
                              @dtw_assign(operNbr, "operPgm")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchPgm" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Exit Point Before</td>
                              @dtw_assign(operNbr, "operExitPt1")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchExitPt1" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">Exit Point After</td>
                              @dtw_assign(operNbr, "operExitPt2")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchExitPt2" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">All Participants Required</td>
                              @dtw_assign(operNbr, "operAllParticipant")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchAllParticipant" size="1" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Number Of Participants Required</td>
                              @dtw_assign(operNbr, "operParticipantRequired")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchParticipantRequired" size="2" maxlength="2"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDesc.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("ATDESCU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("ATACTV",  "Activity", $(srchActivity), "U", operActivity, "A")
  @Build_WildCard ("upper(FLDESC)", "Start Mode", $(srchMode), "U", operMode, "A")
  @Build_WildCard ("ATPRTY",  "Priority", $(srchPriority), "", operPriority, "N")
  @Build_WildCard ("ATD2W",  "Script To Process", $(srchD2W), "U", operD2W, "A")
  @Build_WildCard ("ATPGM",   "Activity Program", $(srchPgm), "U", operPgm, "A")
  @Build_WildCard ("ATEX1U",  "Exit Point Before", $(srchExitPt1), "U", operExitPt1, "A")
  @Build_WildCard ("ATEX2U",  "Exit Point After", $(srchExitPt2), "U", operExitPt2, "A")
  @Build_WildCard ("ATPRTA",  "All Participants Required", $(srchAllParticipant), "U", operAllParticipant, "A")
  @Build_WildCard ("ATPRTR",  "Number Of Participants Required", $(srchParticipantRequired), "", operParticipantRequired, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}