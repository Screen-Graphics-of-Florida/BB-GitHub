%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Sales Analysis Report"
  d2wName                 = "SalesAnalysisReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "08"
  sortSalesmanNumber      = "1"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromLocationNumber, 3, 0) &&
                      editNum(document.Chg.toLocationNumber, 3, 0) &&
                      editNum(document.Chg.fromSalesmanNumber, 3, 0) &&
                      editNum(document.Chg.toSalesmanNumber, 3, 0) &&
                      editNum(document.Chg.fromShipToNumber, 7, 0) &&
                      editNum(document.Chg.toShipToNumber, 7, 0) &&
                      editNum(document.Chg.fromBillToNumber, 7, 0) &&
                      editNum(document.Chg.toBillToNumber, 7, 0) &&
                      editNum(document.Chg.fromInvoiceNumber, 7, 0) &&
                      editNum(document.Chg.toInvoiceNumber, 7, 0) &&
                      editNum(document.Chg.fromWarehouseNumber, 3, 0) &&
                      editNum(document.Chg.toWarehouseNumber, 3, 0) &&
                      editdate(document.Chg.fromInvoiceDate) &&
                      editdate(document.Chg.toInvoiceDate) &&
                      editFromToAll(document.Chg.fromLocationNumber, document.Chg.toLocationNumber, document.Chg.allLocationNumber, 3) &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromProductClass, document.Chg.toProductClass, document.Chg.allProductClass, "A") &&
                      editFromToAll(document.Chg.fromSalesmanNumber, document.Chg.toSalesmanNumber, document.Chg.allSalesmanNumber, 3) &&
                      editFromToAll(document.Chg.fromShipToNumber, document.Chg.toShipToNumber, document.Chg.allShipToNumber, 7) &&
                      editFromToAll(document.Chg.fromBillToNumber, document.Chg.toBillToNumber, document.Chg.allBillToNumber, 7) &&
                      editFromToAll(document.Chg.fromInvoiceNumber, document.Chg.toInvoiceNumber, document.Chg.allInvoiceNumber, 7) &&
                      editFromToAll(document.Chg.fromWarehouseNumber, document.Chg.toWarehouseNumber, document.Chg.allWarehouseNumber, 3) &&
                      editFromToAll(document.Chg.fromInvoiceDate, document.Chg.toInvoiceDate, document.Chg.allInvoiceDate, "D"))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "SALESANALYSISREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromLocationNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@floc", "fromLocationNumber")          @dtw_assign(Err_N1FLOC,  fieldValue)
                                  @DecatErr_Field("@@tloc", "toLocationNumber")          @dtw_assign(Err_N1TLOC,  fieldValue)
                                  @DecatErr_Field("@@aloc", "allLocationNumber")          @dtw_assign(Err_N1ALOC,  fieldValue)
                                  @DecatErr_Field("@@sloc", "sortLocationNumber")          @dtw_assign(Err_N1SLOC,  fieldValue)
                                  @DecatErr_Field("@@ploc", "totalLocationNumber")          @dtw_assign(Err_N1PLOC,  fieldValue)
                                  @DecatErr_Field("@@fitm", "fromItemNumber")          @dtw_assign(Err_N1FITM,  fieldValue)
                                  @DecatErr_Field("@@titm", "toItemNumber")          @dtw_assign(Err_N1TITM,  fieldValue)
                                  @DecatErr_Field("@@aitm", "allItemNumber")          @dtw_assign(Err_N1AITM,  fieldValue)
                                  @DecatErr_Field("@@sitm", "sortItemNumber")          @dtw_assign(Err_N1SITM,  fieldValue)
                                  @DecatErr_Field("@@pitm", "totalItemNumber")          @dtw_assign(Err_N1PITM,  fieldValue)
                                  @DecatErr_Field("@@fcls", "fromProductClass")          @dtw_assign(Err_N1FCLS,  fieldValue)
                                  @DecatErr_Field("@@tcls", "toProductClass")          @dtw_assign(Err_N1TCLS,  fieldValue)
                                  @DecatErr_Field("@@acls", "allProductClass")          @dtw_assign(Err_N1ACLS,  fieldValue)
                                  @DecatErr_Field("@@scls", "sortProductClass")          @dtw_assign(Err_N1SCLS,  fieldValue)
                                  @DecatErr_Field("@@pcls", "totalProductClass")          @dtw_assign(Err_N1PCLS,  fieldValue)
                                  @DecatErr_Field("@@fsls", "fromSalesmanNumber")       @dtw_assign(Err_N1FSLS,  fieldValue)
                                  @DecatErr_Field("@@tsls", "toSalesmanNumber")       @dtw_assign(Err_N1TSLS,  fieldValue)
                                  @DecatErr_Field("@@asls", "allSalesmanNumber")       @dtw_assign(Err_N1ASLS,  fieldValue)
                                  @DecatErr_Field("@@ssls", "sortSalesmanNumber")       @dtw_assign(Err_N1SSLS,  fieldValue)
                                  @DecatErr_Field("@@psls", "totalSalesmanNumber")       @dtw_assign(Err_N1PSLS,  fieldValue)
                                  @DecatErr_Field("@@fcus", "fromShipToNumber")       @dtw_assign(Err_N1FCUS,  fieldValue)
                                  @DecatErr_Field("@@tcus", "toShipToNumber")       @dtw_assign(Err_N1TCUS,  fieldValue)
                                  @DecatErr_Field("@@acus", "allShipToNumber")       @dtw_assign(Err_N1ACUS,  fieldValue)
                                  @DecatErr_Field("@@scus", "sortShipToNumber")       @dtw_assign(Err_N1SCUS,  fieldValue)
                                  @DecatErr_Field("@@pcus", "totalShipToNumber")       @dtw_assign(Err_N1PCUS,  fieldValue)
                                  @DecatErr_Field("@@fbtc", "fromBillToNumber")       @dtw_assign(Err_N1FBTC,  fieldValue)
                                  @DecatErr_Field("@@tbtc", "toBillToNumber")       @dtw_assign(Err_N1TBTC,  fieldValue)
                                  @DecatErr_Field("@@abtc", "allBillToNumber")       @dtw_assign(Err_N1ABTC,  fieldValue)
                                  @DecatErr_Field("@@sbtc", "sortBillToNumber")       @dtw_assign(Err_N1SBTC,  fieldValue)
                                  @DecatErr_Field("@@pbtc", "totalBillToNumber")       @dtw_assign(Err_N1PBTC,  fieldValue)
                                  @DecatErr_Field("@@finv", "fromInvoiceNumber")       @dtw_assign(Err_N1FINV,  fieldValue)
                                  @DecatErr_Field("@@tinv", "toInvoiceNumber")       @dtw_assign(Err_N1TINV,  fieldValue)
                                  @DecatErr_Field("@@ainv", "allInvoiceNumber")       @dtw_assign(Err_N1AINV,  fieldValue)
                                  @DecatErr_Field("@@sinv", "sortInvoiceNumber")       @dtw_assign(Err_N1SINV,  fieldValue)
                                  @DecatErr_Field("@@pinv", "totalInvoiceNumber")       @dtw_assign(Err_N1PINV,  fieldValue)
                                  @DecatErr_Field("@@fwhs", "fromWarehouseNumber")       @dtw_assign(Err_N1FWHS,  fieldValue)
                                  @DecatErr_Field("@@twhs", "toWarehouseNumber")       @dtw_assign(Err_N1TWHS,  fieldValue)
                                  @DecatErr_Field("@@awhs", "allWarehouseNumber")       @dtw_assign(Err_N1AWHS,  fieldValue)
                                  @DecatErr_Field("@@swhs", "sortWarehouseNumber")       @dtw_assign(Err_N1SWHS,  fieldValue)
                                  @DecatErr_Field("@@pwhs", "totalWarehouseNumber")       @dtw_assign(Err_N1PWHS,  fieldValue)
                                  @DecatErr_Field("@@fdte", "fromInvoiceDate")       @dtw_assign(Err_N1FDTE,  fieldValue)
                                  @DecatErr_Field("@@tdte", "toInvoiceDate")       @dtw_assign(Err_N1TDTE,  fieldValue)
                                  @DecatErr_Field("@@adte", "allInvoiceDate")       @dtw_assign(Err_N1ADTE,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}

                                  @Decat_Field("@@floc")  @dtw_assign(V_N1FLOC,  fieldValue)
                                  @Decat_Field("@@tloc")  @dtw_assign(V_N1TLOC,  fieldValue)
                                  @Decat_Field("@@aloc")  @dtw_assign(V_N1ALOC,  fieldValue)
                                  @Decat_Field("@@sloc")  @dtw_assign(V_N1SLOC,  fieldValue)
                                  @Decat_Field("@@ploc")  @dtw_assign(V_N1PLOC,  fieldValue)
                                  @Decat_Field("@@fitm")  @dtw_assign(V_N1FITM,  fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N1TITM,  fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N1AITM,  fieldValue)
                                  @Decat_Field("@@sitm")  @dtw_assign(V_N1SITM,  fieldValue)
                                  @Decat_Field("@@pitm")  @dtw_assign(V_N1PITM,  fieldValue)
                                  @Decat_Field("@@fcls")  @dtw_assign(V_N1FCLS,  fieldValue)
                                  @Decat_Field("@@tcls")  @dtw_assign(V_N1TCLS,  fieldValue)
                                  @Decat_Field("@@acls")  @dtw_assign(V_N1ACLS,  fieldValue)
                                  @Decat_Field("@@scls")  @dtw_assign(V_N1SCLS,  fieldValue)
                                  @Decat_Field("@@pcls")  @dtw_assign(V_N1PCLS,  fieldValue)
                                  @Decat_Field("@@fsls")  @dtw_assign(V_N1FSLS,  fieldValue)
                                  @Decat_Field("@@tsls")  @dtw_assign(V_N1TSLS,  fieldValue)
                                  @Decat_Field("@@asls")  @dtw_assign(V_N1ASLS,  fieldValue)
                                  @Decat_Field("@@ssls")  @dtw_assign(V_N1SSLS,  fieldValue)
                                  @Decat_Field("@@psls")  @dtw_assign(V_N1PSLS,  fieldValue)
                                  @Decat_Field("@@fcus")  @dtw_assign(V_N1FCUS,  fieldValue)
                                  @Decat_Field("@@tcus")  @dtw_assign(V_N1TCUS,  fieldValue)
                                  @Decat_Field("@@acus")  @dtw_assign(V_N1ACUS,  fieldValue)
                                  @Decat_Field("@@scus")  @dtw_assign(V_N1SCUS,  fieldValue)
                                  @Decat_Field("@@pcus")  @dtw_assign(V_N1PCUS,  fieldValue)
                                  @Decat_Field("@@fbtc")  @dtw_assign(V_N1FBTC,  fieldValue)
                                  @Decat_Field("@@tbtc")  @dtw_assign(V_N1TBTC,  fieldValue)
                                  @Decat_Field("@@abtc")  @dtw_assign(V_N1ABTC,  fieldValue)
                                  @Decat_Field("@@sbtc")  @dtw_assign(V_N1SBTC,  fieldValue)
                                  @Decat_Field("@@pbtc")  @dtw_assign(V_N1PBTC,  fieldValue)
                                  @Decat_Field("@@finv")  @dtw_assign(V_N1FINV,  fieldValue)
                                  @Decat_Field("@@tinv")  @dtw_assign(V_N1TINV,  fieldValue)
                                  @Decat_Field("@@ainv")  @dtw_assign(V_N1AINV,  fieldValue)
                                  @Decat_Field("@@sinv")  @dtw_assign(V_N1SINV,  fieldValue)
                                  @Decat_Field("@@pinv")  @dtw_assign(V_N1PINV,  fieldValue)
                                  @Decat_Field("@@fwhs")  @dtw_assign(V_N1FWHS,  fieldValue)
                                  @Decat_Field("@@twhs")  @dtw_assign(V_N1TWHS,  fieldValue)
                                  @Decat_Field("@@awhs")  @dtw_assign(V_N1AWHS,  fieldValue)
                                  @Decat_Field("@@swhs")  @dtw_assign(V_N1SWHS,  fieldValue)
                                  @Decat_Field("@@pwhs")  @dtw_assign(V_N1PWHS,  fieldValue)
                                  @Decat_Field("@@fdte")  @dtw_assign(V_N1FDTE,  fieldValue)
                                  @Decat_Field("@@tdte")  @dtw_assign(V_N1TDTE,  fieldValue)
                                  @Decat_Field("@@adte")  @dtw_assign(V_N1ADTE,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}

                                  %if (V_N1ALOC == "ALL")
                                      @dtw_assign(checkedallLocationNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallLocationNumber, "")
                                  %endif

                                  %if (V_N1AITM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif

                                  %if (V_N1ACLS == "ALL")
                                      @dtw_assign(checkedallProductClass, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallProductClass, "")
                                  %endif

                                  %if (V_N1ASLS == "ALL")
                                      @dtw_assign(checkedallSalesmanNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallSalesmanNumber, "")
                                  %endif

                                  %if (V_N1ACUS == "ALL")
                                      @dtw_assign(checkedallShipToNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallShipToNumber, "")
                                  %endif

                                  %if (V_N1ABTC == "ALL")
                                      @dtw_assign(checkedallBillToNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallBillToNumber, "")
                                  %endif

                                  %if (V_N1AINV == "ALL")
                                      @dtw_assign(checkedallInvoiceNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallInvoiceNumber, "")
                                  %endif

                                  %if (V_N1AWHS == "ALL")
                                      @dtw_assign(checkedallWarehouseNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallWarehouseNumber, "")
                                  %endif

                                  %if (V_N1ADTE == "ALL")
                                      @dtw_assign(checkedallInvoiceDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallInvoiceDate, "")
                                  %endif

                              %else
                                  @dtw_assign(checkedallLocationNumber, "CHECKED")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallProductClass, "CHECKED")
                                  @dtw_assign(checkedallSalesmanNumber, "CHECKED")
                                  @dtw_assign(checkedallShipToNumber, "CHECKED")
                                  @dtw_assign(checkedallBillToNumber, "CHECKED")
                                  @dtw_assign(checkedallInvoiceNumber, "CHECKED")
                                  @dtw_assign(checkedallWarehouseNumber, "CHECKED")
                                  @dtw_assign(checkedallInvoiceDate, "CHECKED")
                                  @dtw_assign(V_N1PLOC, "N")
                                  @dtw_assign(V_N1PITM, "N")
                                  @dtw_assign(V_N1PCLS, "N")
                                  @dtw_assign(V_N1PSLS, "N")
                                  @dtw_assign(V_N1PCUS, "N")
                                  @dtw_assign(V_N1PBTC, "N")
                                  @dtw_assign(V_N1PINV, "N")
                                  @dtw_assign(V_N1PWHS, "N")
                              %endif
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                                  <td class="colhdr">Summary/<br>Totals</td>
                              </tr>

                              @SetTextOvr(Err_N1FLOC)
                              %if (textOvr == "") @SetTextOvr(Err_N1TLOC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ALOC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SLOC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PLOC) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Location Number</span></td>
                                  <td class="inputnmbr"><input name="fromLocationNumber" value="$(V_N1FLOC)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)LocationSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromLocationNumber&amp;fldDesc=flocDesc" onclick="$(searchWinVar)">$(searchImage) </a> <input name="flocDesc" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toLocationNumber" value="$(V_N1TLOC)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)LocationSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toLocationNumber&amp;fldDesc=tlocDesc" onclick="$(searchWinVar)">$(searchImage) </a> <input name="tlocDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allLocationNumber" value='ALL' $(checkedallLocationNumber) type="checkbox" onClick="if (this.checked) this.form.fromLocationNumber.value='', this.form.toLocationNumber.value='';"></td>
                                  @Build_Sort_Select("sortLocationNumber", "$(V_N1SLOC)")
                                  @dtw_tb_rows(summarytotalTable, maxRows)
                                     @dtw_assign(x, "1")
                                  %while((@dtw_tb_rgetv(summarytotalTable, x, "1") != V_N1PLOC) && (x < maxRows))
                                    {@dtw_add(x, "1", x)%}
                                    <td>@dtw_tb_select(summarytotalTable, "totalLocationNumber", "2", "1", "N", "", x, "1")</td>
                              </tr>
                              @DspErrMsg(Err_N1FLOC)
                              @DspErrMsg(Err_N1TLOC)
                              @DspErrMsg(Err_N1ALOC)
                              @DspErrMsg(Err_N1SLOC)
                              @DspErrMsg(Err_N1PLOC)

                              @SetTextOvr(Err_N1FITM)
                              %if (textOvr == "") @SetTextOvr(Err_N1TITM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AITM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SITM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PITM) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputnmbr"><input name="fromItemNumber" value="$(V_N1FITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toItemNumber" value="$(V_N1TITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=titemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="titemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                                  @Build_Sort_Select("sortItemNumber", "$(V_N1SITM)")
                                  @dtw_tb_rows(summarytotalTable, maxRows)
                                     @dtw_assign(x, "1")
                                  %while((@dtw_tb_rgetv(summarytotalTable, x, "1") != V_N1PITM) && (x < maxRows))
                                    {@dtw_add(x, "1", x)%}
                                    <td>@dtw_tb_select(summarytotalTable, "totalItemNumber", "2", "1", "N", "", x, "1")</td>
                              </tr>
                              @DspErrMsg(Err_N1FITM)
                              @DspErrMsg(Err_N1TITM)
                              @DspErrMsg(Err_N1AITM)
                              @DspErrMsg(Err_N1SITM)
                              @DspErrMsg(Err_N1PITM)

                              @SetTextOvr(Err_N1FCLS)
                              %if (textOvr == "") @SetTextOvr(Err_N1TCLS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ACLS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SCLS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PCLS) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Product Class</span></td>
                                  <td class="inputalph"><input name="fromProductClass" value="$(V_N1FCLS)" type="text" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)prodclasssearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromProductClass&amp;fldDesc=fromProdClassDescH" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fromProdClassDescH" type="hidden"></td>
                                  <td class="inputalph"><input name="toProductClass" value="$(V_N1TCLS)" type="text" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)prodclasssearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toProductClass&amp;fldDesc=toProdClassDescH" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toProdClassDescH" type="hidden"></td>
                                  <td class="inputalph"><input name="allProductClass" value='ALL' $(checkedallProductClass) type="checkbox" onClick="if (this.checked) this.form.fromProductClass.value='', this.form.toProductClass.value='';"></td>
                                  @Build_Sort_Select("sortProductClass", "$(V_N1SCLS)")
                                  @dtw_tb_rows(summarytotalTable, maxRows)
                                     @dtw_assign(x, "1")
                                  %while((@dtw_tb_rgetv(summarytotalTable, x, "1") != V_N1PCLS) && (x < maxRows))
                                    {@dtw_add(x, "1", x)%}
                                    <td>@dtw_tb_select(summarytotalTable, "totalProductClass", "2", "1", "N", "", x, "1")</td>
                              </tr>
                              @DspErrMsg(Err_N1FCLS)
                              @DspErrMsg(Err_N1TCLS)
                              @DspErrMsg(Err_N1ACLS)
                              @DspErrMsg(Err_N1SCLS)
                              @DspErrMsg(Err_N1PCLS)

                              @SetTextOvr(Err_N1FSLS)
                              %if (textOvr == "") @SetTextOvr(Err_N1TSLS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ASLS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SSLS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PSLS) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Salesman Number</span></td>
                                  <td class="inputnmbr"><input name="fromSalesmanNumber" value="$(V_N1FSLS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)SalesmanSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromSalesmanNumber&amp;fldDesc=fsalesmanName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fsalesmanName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toSalesmanNumber" value="$(V_N1TSLS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)SalesmanSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toSalesmanNumber&amp;fldDesc=tsalesmanName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="tsalesmanName" type="hidden"></td>
                                  <td class="inputalph"><input name="allSalesmanNumber" value='ALL' $(checkedallSalesmanNumber) type="checkbox" onClick="if (this.checked) this.form.fromSalesmanNumber.value='', this.form.toSalesmanNumber.value='';"></td>
                                  @Build_Sort_Select("sortSalesmanNumber", "$(V_N1SSLS)")
                                  @dtw_tb_rows(summarytotalTable, maxRows)
                                     @dtw_assign(x, "1")
                                  %while((@dtw_tb_rgetv(summarytotalTable, x, "1") != V_N1PSLS) && (x < maxRows))
                                    {@dtw_add(x, "1", x)%}
                                    <td>@dtw_tb_select(summarytotalTable, "totalSalesmanNumber", "2", "1", "N", "", x, "1")</td>
                              </tr>
                              @DspErrMsg(Err_N1FSLS)
                              @DspErrMsg(Err_N1TSLS)
                              @DspErrMsg(Err_N1ASLS)
                              @DspErrMsg(Err_N1SSLS)
                              @DspErrMsg(Err_N1PSLS)

                              @SetTextOvr(Err_N1FCUS)
                              %if (textOvr == "") @SetTextOvr(Err_N1TCUS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ACUS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SCUS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PCUS) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Ship-To Customer</span></td>
                                  <td class="inputnmbr"><input name="fromShipToNumber" value="$(V_N1FCUS)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromShipToNumber&amp;fldDesc=fcusName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="fcusName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toShipToNumber" value="$(V_N1TCUS)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toShipToNumber&amp;fldDesc=tcusName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="tcusName" type="hidden"></td>
                                  <td class="inputalph"><input name="allShipToNumber" value='ALL' $(checkedallShipToNumber) type="checkbox" onClick="if (this.checked) this.form.fromShipToNumber.value='', this.form.toShipToNumber.value='';"></td>
                                  @Build_Sort_Select("sortShipToNumber", "$(V_N1SCUS)")
                                  @dtw_tb_rows(summarytotalTable, maxRows)
                                     @dtw_assign(x, "1")
                                  %while((@dtw_tb_rgetv(summarytotalTable, x, "1") != V_N1PCUS) && (x < maxRows))
                                    {@dtw_add(x, "1", x)%}
                                    <td>@dtw_tb_select(summarytotalTable, "totalShipToNumber", "2", "1", "N", "", x, "1")</td>
                              </tr>
                              @DspErrMsg(Err_N1FCUS)
                              @DspErrMsg(Err_N1TCUS)
                              @DspErrMsg(Err_N1ACUS)
                              @DspErrMsg(Err_N1SCUS)
                              @DspErrMsg(Err_N1PCUS)

                              @SetTextOvr(Err_N1FBTC)
                              %if (textOvr == "") @SetTextOvr(Err_N1TBTC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ABTC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SBTC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PBTC) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Bill-To Customer</span></td>
                                  <td class="inputnmbr"><input name="fromBillToNumber" value="$(V_N1FBTC)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromBillToNumber&amp;fldDesc=fbilltoName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="fbilltoName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toBillToNumber" value="$(V_N1TBTC)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toBillToNumber&amp;fldDesc=tbilltoName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="tbilltoName" type="hidden"></td>
                                  <td class="inputalph"><input name="allBillToNumber" value='ALL' $(checkedallBillToNumber) type="checkbox" onClick="if (this.checked) this.form.fromBillToNumber.value='', this.form.toBillToNumber.value='';"></td>
                                  @Build_Sort_Select("sortBillToNumber", "$(V_N1SBTC)")
                                  @dtw_tb_rows(summarytotalTable, maxRows)
                                     @dtw_assign(x, "1")
                                  %while((@dtw_tb_rgetv(summarytotalTable, x, "1") != V_N1PBTC) && (x < maxRows))
                                    {@dtw_add(x, "1", x)%}
                                    <td>@dtw_tb_select(summarytotalTable, "totalBillToNumber", "2", "1", "N", "", x, "1")</td>
                              </tr>
                              @DspErrMsg(Err_N1FBTC)
                              @DspErrMsg(Err_N1TBTC)
                              @DspErrMsg(Err_N1ABTC)
                              @DspErrMsg(Err_N1SBTC)
                              @DspErrMsg(Err_N1PBTC)

                              @SetTextOvr(Err_N1FINV)
                              %if (textOvr == "") @SetTextOvr(Err_N1TINV) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AINV) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SINV) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PINV) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Invoice Number</span></td>
                                  <td class="inputnmbr"><input name="fromInvoiceNumber" value="$(V_N1FINV)" type="text" size="7" maxlength="7"></td>
                                  <td class="inputnmbr"><input name="toInvoiceNumber" value="$(V_N1TINV)" type="text" size="7" maxlength="7"></td>
                                  <td class="inputalph"><input name="allInvoiceNumber" value='ALL' $(checkedallInvoiceNumber) type="checkbox" onClick="if (this.checked) this.form.fromInvoiceNumber.value='', this.form.toInvoiceNumber.value='';"></td>
                                  @Build_Sort_Select("sortInvoiceNumber", "$(V_N1SINV)")
                                  @dtw_tb_rows(summarytotalTable, maxRows)
                                     @dtw_assign(x, "1")
                                  %while((@dtw_tb_rgetv(summarytotalTable, x, "1") != V_N1PINV) && (x < maxRows))
                                    {@dtw_add(x, "1", x)%}
                                    <td>@dtw_tb_select(summarytotalTable, "totalInvoiceNumber", "2", "1", "N", "", x, "1")</td>
                              </tr>
                              @DspErrMsg(Err_N1FINV)
                              @DspErrMsg(Err_N1TINV)
                              @DspErrMsg(Err_N1AINV)
                              @DspErrMsg(Err_N1SINV)
                              @DspErrMsg(Err_N1PINV)

                              @SetTextOvr(Err_N1FWHS)
                              %if (textOvr == "") @SetTextOvr(Err_N1TWHS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AWHS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SWHS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PWHS) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Warehouse</span></td>
                                  <td class="inputnmbr"><input name="fromWarehouseNumber" value="$(V_N1FWHS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromWarehouseNumber&amp;fldDesc=fwarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fwarehouseName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toWarehouseNumber" value="$(V_N1TWHS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toWarehouseNumber&amp;fldDesc=twarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="twarehouseName" type="hidden"></td>
                                  <td class="inputalph"><input name="allWarehouseNumber" value='ALL' $(checkedallWarehouseNumber) type="checkbox" onClick="if (this.checked) this.form.fromWarehouseNumber.value='', this.form.toWarehouseNumber.value='';"></td>
                                  @Build_Sort_Select("sortWarehouseNumber", "$(V_N1SWHS)")
                                  @dtw_tb_rows(summarytotalTable, maxRows)
                                     @dtw_assign(x, "1")
                                  %while((@dtw_tb_rgetv(summarytotalTable, x, "1") != V_N1PWHS) && (x < maxRows))
                                    {@dtw_add(x, "1", x)%}
                                    <td>@dtw_tb_select(summarytotalTable, "totalWarehouseNumber", "2", "1", "N", "", x, "1")</td>
                              </tr>
                              @DspErrMsg(Err_N1FWHS)
                              @DspErrMsg(Err_N1TWHS)
                              @DspErrMsg(Err_N1AWHS)
                              @DspErrMsg(Err_N1SWHS)
                              @DspErrMsg(Err_N1PWHS)

                              @SetTextOvr(Err_N1FDTE)
                              %if (textOvr == "") @SetTextOvr(Err_N1TDTE) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ADTE) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Invoice Date</span></td>
                                  <td class="inputnmbr"><input name="fromInvoiceDate" value="$(V_N1FDTE)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromInvoiceDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toInvoiceDate" value="$(V_N1TDTE)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toInvoiceDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allInvoiceDate" value='ALL' $(checkedallInvoiceDate) type="checkbox" onClick="if (this.checked) this.form.fromInvoiceDate.value='', this.form.toInvoiceDate.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FDTE)
                              @DspErrMsg(Err_N1TDTE)
                              @DspErrMsg(Err_N1ADTE)
                          </table>

                          @dtw_assign(envProgram, "HOESAR")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HOESSA_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @SummaryTotal_Query(profileHandle, dataBaseID, "SUMMARYTTL", summarytotalTable)
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allLocationNumber)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(fromProductClass)
  @dtw_mUPPERCASE(toProductClass)
  @dtw_mUPPERCASE(allProductClass)
  @dtw_mUPPERCASE(allSalesmanNumber)
  @dtw_mUPPERCASE(allShipToNumber)
  @dtw_mUPPERCASE(allBillToNumber)
  @dtw_mUPPERCASE(allInvoiceNumber)
  @dtw_mUPPERCASE(allWarehouseNumber)
  @dtw_mUPPERCASE(allInvoiceDate)

  @dtw_assign(fromLocationNumber,@dtw_rstrip(fromLocationNumber))
  @dtw_assign(toLocationNumber,@dtw_rstrip(toLocationNumber))
  @dtw_assign(sortLocationNumber,@dtw_rstrip(sortLocationNumber))
  @dtw_assign(sortItemNumber,@dtw_rstrip(sortItemNumber))
  @dtw_assign(fromSalesmanNumber,@dtw_rstrip(fromSalesmanNumber))
  @dtw_assign(toSalesmanNumber,@dtw_rstrip(toSalesmanNumber))
  @dtw_assign(sortSalesmanNumber,@dtw_rstrip(sortSalesmanNumber))
  @dtw_assign(fromShipToNumber,@dtw_rstrip(fromShipToNumber))
  @dtw_assign(toShipToNumber,@dtw_rstrip(toShipToNumber))
  @dtw_assign(sortShipToNumber,@dtw_rstrip(sortShipToNumber))
  @dtw_assign(fromBillToNumber,@dtw_rstrip(fromBillToNumber))
  @dtw_assign(toBillToNumber,@dtw_rstrip(toBillToNumber))
  @dtw_assign(sortBillToNumber,@dtw_rstrip(sortBillToNumber))
  @dtw_assign(fromInvoiceNumber,@dtw_rstrip(fromInvoiceNumber))
  @dtw_assign(toInvoiceNumber,@dtw_rstrip(toInvoiceNumber))
  @dtw_assign(sortInvoiceNumber,@dtw_rstrip(sortInvoiceNumber))
  @dtw_assign(fromWarehouseNumber,@dtw_rstrip(fromWarehouseNumber))
  @dtw_assign(toWarehouseNumber,@dtw_rstrip(toWarehouseNumber))
  @dtw_assign(sortWarehouseNumber,@dtw_rstrip(sortWarehouseNumber))
  @dtw_assign(fromInvoiceDate,@dtw_rstrip(fromInvoiceDate))
  @dtw_assign(toInvoiceDate,@dtw_rstrip(toInvoiceDate))

  %if (allLocationNumber != "ALL")
      @dtw_assign(allLocationNumber, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allProductClass != "ALL")
      @dtw_assign(allProductClass, "")
  %endif
  %if (allSalesmanNumber != "ALL")
      @dtw_assign(allSalesmanNumber, "")
  %endif
  %if (allShipToNumber != "ALL")
      @dtw_assign(allShipToNumber, "")
  %endif
  %if (allBillToNumber != "ALL")
      @dtw_assign(allBillToNumber, "")
  %endif
  %if (allInvoiceNumber != "ALL")
      @dtw_assign(allInvoiceNumber, "")
  %endif
  %if (allWarehouseNumber != "ALL")
      @dtw_assign(allWarehouseNumber, "")
  %endif


  @dtw_assign(edtVar, "")
  @Concat_Field("@@floc", fromLocationNumber)
  @Concat_Field("@@tloc", toLocationNumber)
  @Concat_Field("@@aloc", allLocationNumber)
  @Concat_Field("@@sloc", sortLocationNumber)
  @Concat_Field("@@ploc", totalLocationNumber)
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@sitm", sortItemNumber)
  @Concat_Field("@@pitm", totalItemNumber)
  @Concat_Field("@@fcls", fromProductClass)
  @Concat_Field("@@tcls", toProductClass)
  @Concat_Field("@@acls", allProductClass)
  @Concat_Field("@@scls", sortProductClass)
  @Concat_Field("@@pcls", totalProductClass)
  @Concat_Field("@@fsls", fromSalesmanNumber)
  @Concat_Field("@@tsls", toSalesmanNumber)
  @Concat_Field("@@asls", allSalesmanNumber)
  @Concat_Field("@@ssls", sortSalesmanNumber)
  @Concat_Field("@@psls", totalSalesmanNumber)
  @Concat_Field("@@fcus", fromShipToNumber)
  @Concat_Field("@@tcus", toShipToNumber)
  @Concat_Field("@@acus", allShipToNumber)
  @Concat_Field("@@scus", sortShipToNumber)
  @Concat_Field("@@pcus", totalShipToNumber)
  @Concat_Field("@@fbtc", fromBillToNumber)
  @Concat_Field("@@tbtc", toBillToNumber)
  @Concat_Field("@@abtc", allBillToNumber)
  @Concat_Field("@@sbtc", sortBillToNumber)
  @Concat_Field("@@pbtc", totalBillToNumber)
  @Concat_Field("@@finv", fromInvoiceNumber)
  @Concat_Field("@@tinv", toInvoiceNumber)
  @Concat_Field("@@ainv", allInvoiceNumber)
  @Concat_Field("@@sinv", sortInvoiceNumber)
  @Concat_Field("@@pinv", totalInvoiceNumber)
  @Concat_Field("@@fwhs", fromWarehouseNumber)
  @Concat_Field("@@twhs", toWarehouseNumber)
  @Concat_Field("@@awhs", allWarehouseNumber)
  @Concat_Field("@@swhs", sortWarehouseNumber)
  @Concat_Field("@@pwhs", totalWarehouseNumber)
  @Concat_Field("@@fdte", fromInvoiceDate)
  @Concat_Field("@@tdte", toInvoiceDate)
  @Concat_Field("@@adte", allInvoiceDate)
  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  @dtw_assign(totalLocationNumber, "")
  %INCLUDE "SubmitScheduleUpdate.icl"
%}