%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title 	        = "COBRA Codes"
  d2wName              = "CobraCodes.d2w"
  d2wVarBase           = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar          = "$(d2wVarBase)"
  wildDftVar           = "REPORT$(d2wVarBase)"
  programName          = "HPECCU"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  DTW_PRINT_HEADER     = "NO"
  RPT_MAX_ROWS 	= "10"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext		= "1"
  totalPages		= "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "COBRACODES")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select CCTYPE, CCCODE, CCDESC, CCQWNP, CCQENP, CCQELP, CCQFPP, CCQCNP,", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(CCDESC) as CCDESCU", stmtSQL)
                      @dtw_concat(fileSQL, " CBCODE ", fileSQL)
                      %if (wildCardSearch!="" || uv_Sql!="")
                          @dtw_concat(selectSQL, "CCTYPE<>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @CobraCodes_Inquiry(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) CobraCodes_Inquiry (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count != "1")
          <table $(contentTable)>
	       <colgroup>
	           <col width="80%">
	           <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/report") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"
	
          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr"> Description</th></tr>
                      <tr><td><input type="text" class="inputalph" name="srchDesc" size="20" maxlength="20">
                              <input type="hidden" name="operDesc" value="LIKE">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchDesc.focus();
                  </script>
              </form>

              %INCLUDE "WildCardPage.icl"
          %endif
	   		
          <table $(contentTable)>
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("CCTYPE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CodeType" title="Sequence By Type, Description">Type</a></th>
                  <th class="colhdr">Type<br>Description</th>
                  @OrderBy_Sort("CCCODE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CobraCode" title="Sequence By Code, Type"> Code</a></th>
                  @OrderBy_Sort("CCDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence Description, Type, Code"> Description</a></th>
              </tr>
          %INCLUDE "NoRecordsFound.icl"
      %endif

              %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;codeType=@dtw_rurlescseq(V_CCTYPE)&amp;cobraCode=@dtw_rurlescseq(V_CCCODE)")
                  %if (sql_Record_Count == "1")
                      @Save_WebReg(webRegCurFile, profileHandle, d2wName, "", orderBy, orderByDisplay, "")
                      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)CobraCodeSelect.d2w/REPORT$(maintainVar)">
                  %else
                      %INCLUDE "SetRowClass.icl"
                      %if (V_CCTYPE == "P")
                          @dtw_assign(typeDescription, "Plan Code")
                      %elif (V_CCTYPE == "T")
                          @dtw_assign(typeDescription, "Termination")
                      %elif (V_CCTYPE == "Q")
                          @dtw_assign(typeDescription, "Qualifying Event Code")
                      %endif
                      @dtw_assign(codeDescription, "$(V_CCDESC)")
                      %if (V_CCTYPE == "P")
                          @dtw_assign(typeDescription, "Plan Code")
                      %elif (V_CCTYPE == "T")
                          @dtw_assign(typeDescription, "Termination Code")
                      %elif (V_CCTYPE == "Q")
                          @dtw_assign(typeDescription, "Qualifying Event Code")
                          %if (V_CCCODE == "TE")
                              @dtw_assign(codeDescription, "Termination Of Employment")
                          %elif (V_CCCODE == "DE")
                              @dtw_assign(codeDescription, "Death Of An Employee")
                          %elif (V_CCCODE == "DL")
                              @dtw_assign(codeDescription, "Divorce Or Legal Separation")
                          %elif (V_CCCODE == "DP")
                              @dtw_assign(codeDescription, "Dependent No Longer Qualified")
                          %elif (V_CCCODE == "MC")
                              @dtw_assign(codeDescription, "Employee Entitled To Medicare")
                          %elif (V_CCCODE == "RE")
                              @dtw_assign(codeDescription, "Reduction In Work Hours")
                          %elif (V_CCCODE == "SL")
                              @dtw_assign(codeDescription, "Substantial Loss Of Coverage")
                          %elif (V_CCCODE == "TE")
                              @dtw_assign(codeDescription, "Termination Of Employment")
                          %endif
                      %endif
                      <tr class="$(rowClass)">
                          %if (V_CCTYPE == previousType)
                              <td>&nbsp;</td>
                              <td>&nbsp;</td>
                          %else
                              @dtw_assign(previousType, "$(V_CCTYPE)")
                              <td class="colcode">$(V_CCTYPE)</td>
                              <td class="colalph">$(typeDescription)</td>
                          %endif
                          <td class="colalph">$(V_CCCODE)</td>
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)CobraCodeSelect.d2w/REPORT$(maintainVar)" title="View COBRA Code Row">$(codeDescription)</a></td>
                      </tr>
                  %endif
              %}
          </table>
          %if (sql_Record_Count != "1")
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "Select CCTYPE, CCCODE, CCDESC, CCQWNP, CCQENP, CCQELP, CCQFPP, CCQCNP,", stmtSQL)
  @dtw_concat(stmtSQL, " upper(CCDESC) as CCDESCU", stmtSQL)
  @dtw_concat(fileSQL, " CBCODE ", fileSQL)
  %if (wildCardSearch!="" || uv_Sql!="")
      @dtw_concat(selectSQL, "CCTYPE<>' ' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @CobraCode_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) CobraCode_XMLQuery (IN CHAR(64)    profileHandle,
			                   CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
       @XMLBeginTag("CobraCodeList")
           %ROW{
               @dtw_assign(codeDescription, "$(V_CCDESC)")
               %if (V_CCTYPE == "P")
                   @dtw_assign(typeDescription, "Plan Code")
               %elif (V_CCTYPE == "T")
                   @dtw_assign(typeDescription, "Termination Code")
               %elif (V_CCTYPE == "Q")
                   @dtw_assign(typeDescription, "Qualifying Event Code")
                   %if (V_CCCODE == "TE")
                       @dtw_assign(codeDescription, "Termination Of Employment")
                   %elif (V_CCCODE == "DE")
                       @dtw_assign(codeDescription, "Death Of An Employee")
                   %elif (V_CCCODE == "DL")
                       @dtw_assign(codeDescription, "Divorce Or Legal Separation")
                   %elif (V_CCCODE == "DP")
                       @dtw_assign(codeDescription, "Dependent No Longer Qualified")
                   %elif (V_CCCODE == "MC")
                       @dtw_assign(codeDescription, "Employee Entitled To Medicare")
                   %elif (V_CCCODE == "RE")
                       @dtw_assign(codeDescription, "Reduction In Work Hours")
                   %elif (V_CCCODE == "SL")
                       @dtw_assign(codeDescription, "Substantial Loss Of Coverage")
                   %elif (V_CCCODE == "TE")
                       @dtw_assign(codeDescription, "Termination Of Employment")
                   %endif
               %endif

               @XMLIDTag(V_CCCODE, "CobraCode ID")
                   @XMLTag(V_CCTYPE, "CodeType")
                   @XMLTag(typeDescription, "TypeDescription")
                   @XMLTag(V_CCCODE, "CobraCode")
                   @XMLTag(codeDescription, "CodeDescription")
                   @XMLTag(V_CCQENP, "EmployerNotificationPeriodDays")
                   @XMLTag(V_CCQWNP, "EmployeeNotificationPeriodDays")
                   @XMLTag(V_CCQELP, "ElectionPeriodDays")
                   @XMLTag(V_CCQFPP, "FirstpaymentPeriodDays")
                   @XMLTag(V_CCQCNP, "ContinuationPeriodMonths")
               @XMLEndTag("CobraCode")
           %}
       @XMLEndTag("CobraCodeList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "CCTYPE,CCDESCU")
              @DTW_ASSIGN(orderByDisplay, "Type, Description")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      %INCLUDE "SearchReturn.icl"
  %endif
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "CodeType")
      %if (orderBy == "CCTYPE,CCDESCU")
          @DTW_ASSIGN(orderBy, "CCTYPE DESC,CCDESCU")
          @DTW_ASSIGN(orderByDisplay, "Type (descending), Description")
      %else
          @DTW_ASSIGN(orderBy, "CCTYPE,CCDESCU")
          @DTW_ASSIGN(orderByDisplay, "Type, Description")
      %endif
  %elif (sequence == "CobraCode")
      %if (orderBy == "CCCODE,CCTYPE")
          @DTW_ASSIGN(orderBy, "CCCODE DESC,CCTYPE")
          @DTW_ASSIGN(orderByDisplay, "Code (descending), Type")
      %else
          @DTW_ASSIGN(orderBy, "CCCODE,CCTYPE")
          @DTW_ASSIGN(orderByDisplay, "Code, Type")
      %endif
  %elif (sequence == "Description")
      %if (orderBy == "CCDESCU,CCTYPE,CCCODE")
          @DTW_ASSIGN(orderBy, "CCDESCU DESC,CCTYPE,CCCODE")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Type, Code")
      %else
          @DTW_ASSIGN(orderBy, "CCDESCU,CCTYPE,CCCODE")
          @DTW_ASSIGN(orderByDisplay, "Description, Type, Code")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CBCODESEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Code Type</td>
                              @dtw_assign(operNbr, "operType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchType" size="3" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=COBRACODE&amp;flagSrchHdr=@dtw_rurlescseq("COBRA Code Type")&amp;docName=Search&amp;fldName=srchType&amp;fldDesc=srchTypeDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="srchTypeDesc" value="$(fieldDesc)" type="text" size="20" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Code</td>
                              @dtw_assign(operNbr, "operCode")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCode" size="3" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="20" maxlength="20"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchType.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("CCTYPE", "Code Type", $(srchType), "U", operType, "A")
  @Build_WildCard ("CCCODE", "Code", $(srchCode), "U", operCode, "A")
  @Build_WildCard ("upper(CCDESC)", "Description", $(srchDesc), "U", operDesc, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}