%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Participant Maintenance"
  d2wName                 = "WFParticipantMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfProcess=@dtw_rurlescseq(wfProcess)&amp;passedWfPoint=@dtw_rurlescseq(passedWfPoint)&amp;passedWfSequence=@dtw_rurlescseq(passedWfSequence)&amp;passedWfParticipant=@dtw_rurlescseq(passedWfParticipant)&amp;fromPoint=@dtw_rurlescseq(fromPoint)&amp;fromSequence=@dtw_rurlescseq(fromSequence)&amp;fromParticipantId=@dtw_rurlescseq(fromParticipantId)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;updRecNbr=@dtw_rurlescseq(updRecNbr)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;wfPoint=@dtw_rurlescseq(wfPoint)&amp;wfSequence=@dtw_rurlescseq(wfSequence)&amp;wfParticipantId=@dtw_rurlescseq(wfParticipantId)&amp;maintenanceCode=D"
  programName             = "HWFPTM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function confirmDelete() {return confirm("$(delRecordConf)")}
              function validate(chgForm) {
                  if (document.Chg.wfPoint.value =="" ||
                      document.Chg.wfSequence.value =="" ||
                      document.Chg.wfParticipant.value =="")
                         {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.wfPoint, 4, 3) &&
                      editNum(document.Chg.wfSequence, 4, 3)
                      )
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFPARTICIPANTMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " WFPRPT ", fileSQL)
                          @dtw_concat(selectSQL, " PAPROC='$(wfProcess)' and PAPONT=$(wfPoint) and PASEQ=$(wfSequence) and PAPAID=$(wfParticipantId) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          @RtvFldDesc("PRPROC='$(wfProcess)'", "WFPRHD", "PRDESC", wfProcessDescription)
          @Format_Header("", $(wfProcessDescription), $(wfProcess))
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          %ROW {
              %if (errFound != "" || maintenanceCode == "A")
                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(edtVar, "")
                      @dtw_assign(focusField, "wfPoint")
                  %else
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@pont", "wfPoint")                @dtw_assign(Err_PAPONT, fieldValue)
                      @DecatErr_Field("@@seq@", "wfSequence")             @dtw_assign(Err_PASEQ, fieldValue)
                      @DecatErr_Field("@@part", "wfParticipant")          @dtw_assign(Err_PAPART, fieldValue)
                  %endif

                  @Decat_Field("@@pont")   @dtw_assign(V_PAPONT, fieldValue)
                  @Decat_Field("@@seq@")   @dtw_assign(V_PASEQ, fieldValue)
                  @Decat_Field("@@paid")   @dtw_assign(V_PAPAID, fieldValue)
                  @Decat_Field("@@part")   @dtw_assign(V_PAPART, fieldValue)

                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(focusField, "wfPoint")
                      @dtw_assign(V_PAPONT, "0")
                      @dtw_assign(V_PASEQ, "0")
                      @dtw_assign(V_PAPAID, "0")
                  %endif

                  @dtw_assign(errFound, "")

              %elif (maintenanceCode == "Z")
                  @dtw_assign(focusField, "wfPoint")
                  @dtw_assign(V_PAPAID, "0")
              %else
                  @dtw_assign(focusField, "wfParticipant")
              %endif

              <table $(contentTable)>
                  <tr><td><input name="wfParticipantId" type="hidden" value="$(V_PAPAID)"></td></tr>

                  @Default_Zero(V_PAPONT)
                  @Default_Zero(V_PASEQ)
                  @SetTextOvr(Err_PAPONT)
                  @RtvFldDesc("PDPROC='$(wfProcess)' and PDPONT=$(V_PAPONT) and PDSEQ=$(V_PASEQ) ", "WFPRDT", "PDDESC", fieldDesc)
                  <tr><td class="dsphdr"><span $(textOvr)>Detail Point</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="wfPoint" type="text" value="$(V_PAPONT)" size="8" maxlength="8">
                                                             <input name="wfSequence" type="text" value="$(V_PASEQ)" size="8" maxlength="8">
                                                                    <a href="$(homeURL)$(cGIPath)WFDetailSearch.d2w/REPORT$(genericVarBase)&amp;docName=Chg&amp;specificWFProcess=@dtw_rurlescseq(wfProcess)&amp;fldPoint=wfPoint&amp;fldSequence=wfSequence&amp;fldDesc=wfSequenceDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage)</a>
                                                             <input name="wfSequenceDesc" value="$(fieldDesc)" type="text" size="30" disabled></td>
                      %else
                          <td class="inputnmbr"><input name="wfPoint" type="hidden" value="$(V_PAPONT)">$(V_PAPONT) - <input name="wfSequence" type="hidden" value="$(V_PASEQ)">$(V_PASEQ)
                                                             $(fieldDesc)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_PAPONT)

                  @SetTextOvr(Err_PAPART)
                  @RtvFldDesc("USUSER='$(V_PAPART)' ", "SYUSER", "USDESC", fieldDesc)
                  <tr><td class="dsphdr"><span $(textOvr)>Participant</span></td>
                      <td class="inputalph"><input name="wfParticipant" type="text" value="$(V_PAPART)" size="10" maxlength="10"> $(reqFieldChar)
                                                         @dtw_assign(searchTitle, "User")
                                                         <a href="$(homeURL)$(phpPath)UserSearch.php$(altVarBase)&amp;docName=Chg&amp;userFld=wfParticipant&amp;descFld=wfParticipantName" onclick="$(searchWinVar)"> $(searchImage) </a>
                                                         @dtw_assign(searchTitle, "Common User")
                                                         <a href="$(homeURL)$(cGIPath)CommonUserSearch.d2w/REPORT$(genericVarBase)&amp;docName=Chg&amp;fldName=wfParticipant&amp;fldDesc=wfParticipantName" onclick="$(searchWinVar)"> $(searchImage) </a>
                                                         @dtw_assign(searchTitle, "")
                                                         <input disabled name="wfParticipantName" value="$(fieldDesc)" type="text" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_PAPART)
              </table>
          %}

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HWFPTM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  %if (maintenanceCode == "D" && wfParticipant == "")
      @RtvFldDesc("PAPROC='$(wfProcess)' and PAPONT=$(wfPoint) and PASEQ=$(wfSequence) and PAPAID=$(wfParticipantId)", "WFPRPT", "PAPART", wfParticipant)
  %endif
  @RtvFldDesc("PDPROC='$(wfProcess)' and PDPONT=$(wfPoint) and PDSEQ=$(wfSequence) ", "WFPRDT", "PDDESC", V_PDDESC)
  @RtvFldDesc("USUSER='$(wfParticipant)'", "SYUSER", "USDESC", V_USDESC)

  @dtw_mUPPERCASE(wfProcess)
  @dtw_mUPPERCASE(wfParticipant)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@frm1", fromPoint)
  @Concat_Field("@@frm2", fromSequence)
  @Concat_Field("@@frm3", fromParticipantId)
  @Concat_Field("@@proc", wfProcess)
  @Concat_Field("@@pont", wfPoint)
  @Concat_Field("@@seq@", wfSequence)
  @Concat_Field("@@paid", wfParticipantId)
  @Concat_Field("@@part", wfParticipant)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, "$(V_PDDESC)-$(V_USDESC)", "$(wfPoint)-$(wfSequence)-$(wfParticipant)", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage))&amp;wfParticipant=@dtw_rurlescseq(passedWfParticipant)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@pont", "wfPoint")
      @Format_ConfMsg_Desc("", "$(V_PDDESC)-$(V_USDESC)", "$(wfPoint)-$(wfSequence)-$(wfParticipant)", "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)&amp;wfParticipant=@dtw_rurlescseq(passedWfParticipant)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;wfPoint=@dtw_rurlescseq(wfPoint)&amp;wfSequence=@dtw_rurlescseq(wfSequence)&amp;wfParticipantId=@dtw_rurlescseq(wfParticipantId)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
