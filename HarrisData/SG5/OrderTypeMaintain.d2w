%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Order Type Maintenance"
  d2wName                 = "OrderTypeMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromAPID=@dtw_rurlescseq(fromAPID)&amp;fromOrderType=@dtw_rurlescseq(fromOrderType)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;orderType=@dtw_rurlescseq(orderType)&amp;orderApplication=@dtw_rurlescseq(orderApplication)&amp;description=@dtw_rurlescseq(description)&amp;maintenanceCode=D"
  programName             = "HHDOTU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.orderType.value =="" ||
                      document.Chg.description.value =="")
                     {alert("$(reqFieldError)"); return false;}
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ORDERTYPEMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From HDOTYP Where OTOTCD='$(orderType)' and OTAPID='$(orderApplication)'", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %ROW {
          @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
          %if (backURL == "")
              @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=156")
          %endif
          @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
          %INCLUDE "MaintainTop.icl"
          $(hrTagAttr)
          %INCLUDE "RequiredField.icl"
          %INCLUDE "ErrorDisplay.icl"

          <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">

              %if (errFound != "" || maintenanceCode == "A")
                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(edtVar, "")
                      @dtw_assign(focusField, "orderType")
                  %else
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@apid", "orderApplication")  @dtw_assign(Err_OTAPID, fieldValue)
                      @DecatErr_Field("@@otcd", "orderType")         @dtw_assign(Err_OTOTCD, fieldValue)
                      @DecatErr_Field("@@desc", "description")       @dtw_assign(Err_OTDESC, fieldValue)
                      @DecatErr_Field("@@aatx", "allowAccTax")       @dtw_assign(Err_OTAATX, fieldValue)
                      @DecatErr_Field("@@apog", "allowPoGen")        @dtw_assign(Err_OTAPOG, fieldValue)

                      @DecatErr_Field("@@sdt1", "hdrDateScr2")       @dtw_assign(Err_OTSDT1, fieldValue)
                      @DecatErr_Field("@@sdt2", "hdrDateScr3")       @dtw_assign(Err_OTSDT2, fieldValue)
                      @DecatErr_Field("@@sdt3", "hdrDateScr4")       @dtw_assign(Err_OTSDT3, fieldValue)
                      @DecatErr_Field("@@rd11", "hdrDateHdg21")      @dtw_assign(Err_OTRD11, fieldValue)
                      @DecatErr_Field("@@rd12", "hdrDateHdg22")      @dtw_assign(Err_OTRD12, fieldValue)
                      @DecatErr_Field("@@rd21", "hdrDateHdg31")      @dtw_assign(Err_OTRD21, fieldValue)
                      @DecatErr_Field("@@rd22", "hdrDateHdg32")      @dtw_assign(Err_OTRD22, fieldValue)
                      @DecatErr_Field("@@rd31", "hdrDateHdg41")      @dtw_assign(Err_OTRD31, fieldValue)
                      @DecatErr_Field("@@rd32", "hdrDateHdg42")      @dtw_assign(Err_OTRD32, fieldValue)

                      @DecatErr_Field("@@scr1", "hdrAlphScr1")       @dtw_assign(Err_OTSCR1, fieldValue)
                      @DecatErr_Field("@@scr2", "hdrAlphScr2")       @dtw_assign(Err_OTSCR2, fieldValue)
                      @DecatErr_Field("@@scr3", "hdrAlphScr3")       @dtw_assign(Err_OTSCR3, fieldValue)
                      @DecatErr_Field("@@scr4", "hdrAlphScr4")       @dtw_assign(Err_OTSCR4, fieldValue)
                      @DecatErr_Field("@@scr5", "hdrAlphScr5")       @dtw_assign(Err_OTSCR5, fieldValue)
                      @DecatErr_Field("@@rp11", "hdrAlphHdg11")      @dtw_assign(Err_OTRP11, fieldValue)
                      @DecatErr_Field("@@rp12", "hdrAlphHdg12")      @dtw_assign(Err_OTRP12, fieldValue)
                      @DecatErr_Field("@@rp21", "hdrAlphHdg21")      @dtw_assign(Err_OTRP21, fieldValue)
                      @DecatErr_Field("@@rp22", "hdrAlphHdg22")      @dtw_assign(Err_OTRP22, fieldValue)
                      @DecatErr_Field("@@rp31", "hdrAlphHdg31")      @dtw_assign(Err_OTRP31, fieldValue)
                      @DecatErr_Field("@@rp32", "hdrAlphHdg32")      @dtw_assign(Err_OTRP32, fieldValue)
                      @DecatErr_Field("@@rp41", "hdrAlphHdg41")      @dtw_assign(Err_OTRP41, fieldValue)
                      @DecatErr_Field("@@rp42", "hdrAlphHdg42")      @dtw_assign(Err_OTRP42, fieldValue)
                      @DecatErr_Field("@@rp51", "hdrAlphHdg51")      @dtw_assign(Err_OTRP51, fieldValue)
                      @DecatErr_Field("@@rp52", "hdrAlphHdg52")      @dtw_assign(Err_OTRP52, fieldValue)

                      @DecatErr_Field("@@asc1", "dtlAlphScr1")       @dtw_assign(Err_OTASC1, fieldValue)
                      @DecatErr_Field("@@asc2", "dtlAlphScr2")       @dtw_assign(Err_OTASC2, fieldValue)
                      @DecatErr_Field("@@asc3", "dtlAlphScr3")       @dtw_assign(Err_OTASC3, fieldValue)
                      @DecatErr_Field("@@ar11", "dtlAlphHdg11")      @dtw_assign(Err_OTAR11, fieldValue)
                      @DecatErr_Field("@@ar12", "dtlAlphHdg12")      @dtw_assign(Err_OTAR12, fieldValue)
                      @DecatErr_Field("@@ar21", "dtlAlphHdg21")      @dtw_assign(Err_OTAR21, fieldValue)
                      @DecatErr_Field("@@ar22", "dtlAlphHdg22")      @dtw_assign(Err_OTAR22, fieldValue)
                      @DecatErr_Field("@@ar31", "dtlAlphHdg31")      @dtw_assign(Err_OTAR31, fieldValue)
                      @DecatErr_Field("@@ar32", "dtlAlphHdg32")      @dtw_assign(Err_OTAR32, fieldValue)

                      @DecatErr_Field("@@nsc1", "dtlNumScr1")        @dtw_assign(Err_OTNSC1, fieldValue)
                      @DecatErr_Field("@@nsc2", "dtlNumScr2")        @dtw_assign(Err_OTNSC2, fieldValue)
                      @DecatErr_Field("@@nsc3", "dtlNumScr3")        @dtw_assign(Err_OTNSC3, fieldValue)
                      @DecatErr_Field("@@nr11", "dtlNumHdg11")       @dtw_assign(Err_OTNR11, fieldValue)
                      @DecatErr_Field("@@nr12", "dtlNumHdg12")       @dtw_assign(Err_OTNR12, fieldValue)
                      @DecatErr_Field("@@nr21", "dtlNumHdg21")       @dtw_assign(Err_OTNR21, fieldValue)
                      @DecatErr_Field("@@nr22", "dtlNumHdg22")       @dtw_assign(Err_OTNR22, fieldValue)
                      @DecatErr_Field("@@nr31", "dtlNumHdg31")       @dtw_assign(Err_OTNR31, fieldValue)
                      @DecatErr_Field("@@nr32", "dtlNumHdg32")       @dtw_assign(Err_OTNR32, fieldValue)
                  %endif

                  @Decat_Field("@@apid")  @dtw_assign(V_OTAPID, fieldValue)
                  @Decat_Field("@@otcd")  @dtw_assign(V_OTOTCD, fieldValue)
                  @Decat_Field("@@desc")  @dtw_assign(V_OTDESC, fieldValue)
                  @Decat_Field("@@aatx")  @dtw_assign(V_OTAATX, fieldValue)
                  @Decat_Field("@@apog")  @dtw_assign(V_OTAPOG, fieldValue)
                  @Decat_Field("@@sdt1")  @dtw_assign(V_OTSDT1, fieldValue)
                  @Decat_Field("@@sdt2")  @dtw_assign(V_OTSDT2, fieldValue)
                  @Decat_Field("@@sdt3")  @dtw_assign(V_OTSDT3, fieldValue)
                  @Decat_Field("@@rd11")  @dtw_assign(V_OTRD11, fieldValue)
                  @Decat_Field("@@rd12")  @dtw_assign(V_OTRD12, fieldValue)
                  @Decat_Field("@@rd21")  @dtw_assign(V_OTRD21, fieldValue)
                  @Decat_Field("@@rd22")  @dtw_assign(V_OTRD22, fieldValue)
                  @Decat_Field("@@rd31")  @dtw_assign(V_OTRD31, fieldValue)
                  @Decat_Field("@@rd32")  @dtw_assign(V_OTRD32, fieldValue)

                  @Decat_Field("@@hnd1")  @dtw_assign(V_OTHND1, fieldValue)
                  @Decat_Field("@@hnd2")  @dtw_assign(V_OTHND2, fieldValue)
                  @Decat_Field("@@hnd3")  @dtw_assign(V_OTHND3, fieldValue)
                  @Decat_Field("@@hnd4")  @dtw_assign(V_OTHND4, fieldValue)
                  @Decat_Field("@@hnd5")  @dtw_assign(V_OTHND5, fieldValue)

                  @Decat_Field("@@scr1")  @dtw_assign(V_OTSCR1, fieldValue)
                  @Decat_Field("@@scr2")  @dtw_assign(V_OTSCR2, fieldValue)
                  @Decat_Field("@@scr3")  @dtw_assign(V_OTSCR3, fieldValue)
                  @Decat_Field("@@scr4")  @dtw_assign(V_OTSCR4, fieldValue)
                  @Decat_Field("@@scr5")  @dtw_assign(V_OTSCR5, fieldValue)
                  @Decat_Field("@@scr6")  @dtw_assign(V_OTSCR6, fieldValue)
                  @Decat_Field("@@scr7")  @dtw_assign(V_OTSCR7, fieldValue)
                  @Decat_Field("@@scr8")  @dtw_assign(V_OTSCR8, fieldValue)
                  @Decat_Field("@@scr9")  @dtw_assign(V_OTSCR9, fieldValue)
                  @Decat_Field("@@scr0")  @dtw_assign(V_OTSCR0, fieldValue)
                  @Decat_Field("@@rp11")  @dtw_assign(V_OTRP11, fieldValue)
                  @Decat_Field("@@rp12")  @dtw_assign(V_OTRP12, fieldValue)
                  @Decat_Field("@@rp21")  @dtw_assign(V_OTRP21, fieldValue)
                  @Decat_Field("@@rp22")  @dtw_assign(V_OTRP22, fieldValue)
                  @Decat_Field("@@rp31")  @dtw_assign(V_OTRP31, fieldValue)
                  @Decat_Field("@@rp32")  @dtw_assign(V_OTRP32, fieldValue)
                  @Decat_Field("@@rp41")  @dtw_assign(V_OTRP41, fieldValue)
                  @Decat_Field("@@rp42")  @dtw_assign(V_OTRP42, fieldValue)
                  @Decat_Field("@@rp51")  @dtw_assign(V_OTRP51, fieldValue)
                  @Decat_Field("@@rp52")  @dtw_assign(V_OTRP52, fieldValue)

                  @Decat_Field("@@asc1")  @dtw_assign(V_OTASC1, fieldValue)
                  @Decat_Field("@@asc2")  @dtw_assign(V_OTASC2, fieldValue)
                  @Decat_Field("@@asc3")  @dtw_assign(V_OTASC3, fieldValue)
                  @Decat_Field("@@asc4")  @dtw_assign(V_OTASC4, fieldValue)
                  @Decat_Field("@@asc5")  @dtw_assign(V_OTASC5, fieldValue)
                  @Decat_Field("@@asc6")  @dtw_assign(V_OTASC6, fieldValue)
                  @Decat_Field("@@asc7")  @dtw_assign(V_OTASC7, fieldValue)
                  @Decat_Field("@@asc8")  @dtw_assign(V_OTASC8, fieldValue)
                  @Decat_Field("@@asc9")  @dtw_assign(V_OTASC9, fieldValue)
                  @Decat_Field("@@asc0")  @dtw_assign(V_OTASC0, fieldValue)
                  @Decat_Field("@@ar11")  @dtw_assign(V_OTAR11, fieldValue)
                  @Decat_Field("@@ar12")  @dtw_assign(V_OTAR12, fieldValue)
                  @Decat_Field("@@ar21")  @dtw_assign(V_OTAR21, fieldValue)
                  @Decat_Field("@@ar22")  @dtw_assign(V_OTAR22, fieldValue)
                  @Decat_Field("@@ar31")  @dtw_assign(V_OTAR31, fieldValue)
                  @Decat_Field("@@ar32")  @dtw_assign(V_OTAR32, fieldValue)

                  @Decat_Field("@@nsc1")  @dtw_assign(V_OTNSC1, fieldValue)
                  @Decat_Field("@@nsc2")  @dtw_assign(V_OTNSC2, fieldValue)
                  @Decat_Field("@@nsc3")  @dtw_assign(V_OTNSC3, fieldValue)
                  @Decat_Field("@@nsc4")  @dtw_assign(V_OTNSC4, fieldValue)
                  @Decat_Field("@@nsc5")  @dtw_assign(V_OTNSC5, fieldValue)
                  @Decat_Field("@@nr11")  @dtw_assign(V_OTNR11, fieldValue)
                  @Decat_Field("@@nr12")  @dtw_assign(V_OTNR12, fieldValue)
                  @Decat_Field("@@nr21")  @dtw_assign(V_OTNR21, fieldValue)
                  @Decat_Field("@@nr22")  @dtw_assign(V_OTNR22, fieldValue)
                  @Decat_Field("@@nr31")  @dtw_assign(V_OTNR31, fieldValue)
                  @Decat_Field("@@nr32")  @dtw_assign(V_OTNR32, fieldValue)

                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(V_OTAATX, "N")
                  %endif

                  @dtw_assign(errFound, "")

              %elif (maintenanceCode == "Z")
                  @dtw_assign(focusField, "orderType")
                  @dtw_assign(V_OTOTCD, "")
              %else
                  @dtw_assign(focusField, "description")
              %endif

              <table $(contentTable)>
                  @RtvFldDesc("AIAPID='$(orderApplication)'", "SYAPID", "AIAPDS", apidDesc)
	           <tr><td class="dsphdr"><span $(textOvr)>Application ID</span></td>
                      <td class="inputalph"><input name="orderApplication" type="hidden" value="$(orderApplication)">$(apidDesc)</td>
                  </tr>

                  @SetTextOvr(Err_OTOTCD)
	           <tr><td class="dsphdr"><span $(textOvr)>Order Type</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="orderType" type="text" value="$(V_OTOTCD)" size="5" maxlength="1">$(reqFieldChar)</td>
                      %else
                          <td class="inputalph"><input name="orderType" type="hidden" value="$(V_OTOTCD)">$(V_OTOTCD)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_OTOTCD)

                  @SetTextOvr(Err_OTDESC)
    	           <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="description" type="text" value="$(V_OTDESC)" size="35" maxlength="23">$(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_OTDESC)

                  %if (orderApplication=="OE")
                      @SetTextOvr(Err_OTAATX)
                      <tr><td class="dsphdr"><span $(textOvr)>Allow Access To Tax Amounts</span></td>
                          @dtw_tb_rows(yn01Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_OTAATX) && (x < maxRows)) {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(yn01Table, "allowAccTax", "2", "1", "N", "", x, "1")</td>
                      </tr>
                      @DspErrMsg(Err_OTAATX)

                      @SetTextOvr(Err_OTAPOG)
                      <tr><td class="dsphdr"><span $(textOvr)>Allow P/O Generation</span></td>
                          @dtw_tb_rows(yn02Table, maxRows)
                          @dtw_assign(x, "1")
                          %while((@dtw_tb_rgetv(yn02Table, x, "1") != V_OTAPOG) && (x < maxRows)) {@dtw_add(x, "1", x)%}
                          <td>@dtw_tb_select(yn02Table, "allowPoGen", "2", "1", "N", "", x, "1")</td>
                      </tr>
                      @DspErrMsg(Err_OTAPOG)
                  %endif
              </table>

              <fieldset class="legendBody">
                  <legend class="legendTitle">User-Defined Header</legend>
                  <table $(contentTable)>
                      <tr><td>&nbsp;</td>
                          <td class="colhdr">Description</td>
                          <td class="colhdr" colspan="2">Report Heading</td>
                      </tr>
    	         		
                      @SetTextOvr(Err_OTSDT1)
                      <tr><td class="dsphdr"><span $(textOvr)>Date 2</span></td>
                          <td class="inputalph"><input type="text" name="hdrDateScr2" value="$(V_OTSDT1)" size="35" maxlength="23"></td>
                          <td class="inputalph"><input type="text" name="hdrDateHdg21" value="$(V_OTRD11)" size="15" maxlength="8"></td>
                          <td class="inputalph"><input type="text" name="hdrDateHdg22" value="$(V_OTRD12)" size="15" maxlength="8"></td>
                      </tr>
                      @DspErrMsg(Err_OTSDT1)
    	         		
                      @SetTextOvr(Err_OTSDT2)
                      <tr><td class="dsphdr"><span $(textOvr)>Date 3</span></td>
                          <td class="inputalph"><input type="text" name="hdrDateScr3" value="$(V_OTSDT2)" size="35" maxlength="23"></td>
                          <td class="inputalph"><input type="text" name="hdrDateHdg31" value="$(V_OTRD21)" size="15" maxlength="8"></td>
                          <td class="inputalph"><input type="text" name="hdrDateHdg32" value="$(V_OTRD22)" size="15" maxlength="8"></td>
                      </tr>
                      @DspErrMsg(Err_OTSDT2)
    	         		
                      @SetTextOvr(Err_OTSDT3)
                      <tr><td class="dsphdr"><span $(textOvr)>Date 4</span></td>
                          <td class="inputalph"><input type="text" name="hdrDateScr4" value="$(V_OTSDT3)" size="35" maxlength="23"></td>
                          <td class="inputalph"><input type="text" name="hdrDateHdg41" value="$(V_OTRD31)" size="15" maxlength="8"></td>
                          <td class="inputalph"><input type="text" name="hdrDateHdg42" value="$(V_OTRD32)" size="15" maxlength="8"></td>
                      </tr>
                      @DspErrMsg(Err_OTSDT3)
    	         		
                      @SetTextOvr(Err_OTSCR1)
                      <tr><td class="dsphdr"><span $(textOvr)>Alpha 1</span></td>
                          <td class="inputalph"><input type="text" name="hdrAlphScr1" value="$(V_OTSCR1)" size="35" maxlength="23"></td>
                          <td class="inputalph"><input type="text" name="hdrAlphHdg11" value="$(V_OTRP11)" size="15" maxlength="8"></td>
                          <td class="inputalph"><input type="text" name="hdrAlphHdg12" value="$(V_OTRP12)" size="15" maxlength="8"></td>
                      </tr>
                      @DspErrMsg(Err_OTSCR1)
    	         		
                      @SetTextOvr(Err_OTSCR2)
                      <tr><td class="dsphdr"><span $(textOvr)>Alpha 2</span></td>
                          <td class="inputalph"><input type="text" name="hdrAlphScr2" value="$(V_OTSCR2)" size="35" maxlength="23"></td>
                          <td class="inputalph"><input type="text" name="hdrAlphHdg21" value="$(V_OTRP21)" size="15" maxlength="8"></td>
                          <td class="inputalph"><input type="text" name="hdrAlphHdg22" value="$(V_OTRP22)" size="15" maxlength="8"></td>
                      </tr>
                      @DspErrMsg(Err_OTSCR2)
    	         		
                      @SetTextOvr(Err_OTSCR3)
                      <tr><td class="dsphdr"><span $(textOvr)>Alpha 3</span></td>
                          <td class="inputalph"><input type="text" name="hdrAlphScr3" value="$(V_OTSCR3)" size="35" maxlength="23"></td>
                          <td class="inputalph"><input type="text" name="hdrAlphHdg31" value="$(V_OTRP31)" size="15" maxlength="8"></td>
                          <td class="inputalph"><input type="text" name="hdrAlphHdg32" value="$(V_OTRP32)" size="15" maxlength="8"></td>
                      </tr>
                      @DspErrMsg(Err_OTSCR3)
    	         		
                      @SetTextOvr(Err_OTSCR4)
                      <tr><td class="dsphdr"><span $(textOvr)>Alpha 4</span></td>
                          <td class="inputalph"><input type="text" name="hdrAlphScr4" value="$(V_OTSCR4)" size="35" maxlength="23"></td>
                          <td class="inputalph"><input type="text" name="hdrAlphHdg41" value="$(V_OTRP41)" size="15" maxlength="8"></td>
                          <td class="inputalph"><input type="text" name="hdrAlphHdg42" value="$(V_OTRP42)" size="15" maxlength="8"></td>
                      </tr>
                      @DspErrMsg(Err_OTSCR4)
    	         		
                      @SetTextOvr(Err_OTSCR5)
                      <tr><td class="dsphdr"><span $(textOvr)>Alpha 5</span></td>
                          <td class="inputalph"><input type="text" name="hdrAlphScr5" value="$(V_OTSCR5)" size="35" maxlength="23"></td>
                          <td class="inputalph"><input type="text" name="hdrAlphHdg51" value="$(V_OTRP51)" size="15" maxlength="8"></td>
                          <td class="inputalph"><input type="text" name="hdrAlphHdg52" value="$(V_OTRP52)" size="15" maxlength="8"></td>
                      </tr>
                      @DspErrMsg(Err_OTSCR5)
    	         		
                      @SetTextOvr(Err_OTSCR6)
                      <tr><td class="dsphdr"><span $(textOvr)>Alpha 6</span></td>
                          <td class="inputalph"><input type="text" name="hdrAlphScr6" value="$(V_OTSCR6)" size="35" maxlength="23"></td>
                      </tr>
                      @DspErrMsg(Err_OTSCR6)
    	         		
                      @SetTextOvr(Err_OTSCR7)
                      <tr><td class="dsphdr"><span $(textOvr)>Alpha 7</span></td>
                          <td class="inputalph"><input type="text" name="hdrAlphScr7" value="$(V_OTSCR7)" size="35" maxlength="23"></td>
                      </tr>
                      @DspErrMsg(Err_OTSCR7)
    	         		
                      @SetTextOvr(Err_OTSCR8)
                      <tr><td class="dsphdr"><span $(textOvr)>Alpha 8</span></td>
                          <td class="inputalph"><input type="text" name="hdrAlphScr8" value="$(V_OTSCR8)" size="35" maxlength="23"></td>
                      </tr>
                      @DspErrMsg(Err_OTSCR8)
    	         		
                      @SetTextOvr(Err_OTSCR9)
                      <tr><td class="dsphdr"><span $(textOvr)>Alpha 9</span></td>
                          <td class="inputalph"><input type="text" name="hdrAlphScr9" value="$(V_OTSCR9)" size="35" maxlength="23"></td>
                      </tr>
                      @DspErrMsg(Err_OTSCR9)
    	         		
                      @SetTextOvr(Err_OTSCR0)
                      <tr><td class="dsphdr"><span $(textOvr)>Alpha 10</span></td>
                          <td class="inputalph"><input type="text" name="hdrAlphScr0" value="$(V_OTSCR0)" size="35" maxlength="23"></td>
                      </tr>
                      @DspErrMsg(Err_OTSCR0)
    	         		
                      @SetTextOvr(Err_OTHND1)
                      <tr><td class="dsphdr"><span $(textOvr)>Numeric 1</span></td>
                          <td class="inputalph"><input type="text" name="hdrNumScr1" value="$(V_OTHND1)" size="35" maxlength="23"></td>
                      </tr>
                      @DspErrMsg(Err_OTHND1)
    	         		
                      @SetTextOvr(Err_OTHND2)
                      <tr><td class="dsphdr"><span $(textOvr)>Numeric 2</span></td>
                          <td class="inputalph"><input type="text" name="hdrNumScr2" value="$(V_OTHND2)" size="35" maxlength="23"></td>
                      </tr>
                      @DspErrMsg(Err_OTHND2)
    	         		
                      @SetTextOvr(Err_OTHND3)
                      <tr><td class="dsphdr"><span $(textOvr)>Numeric 3</span></td>
                          <td class="inputalph"><input type="text" name="hdrNumScr3" value="$(V_OTHND3)" size="35" maxlength="23"></td>
                      </tr>
                      @DspErrMsg(Err_OTHND3)
    	         		
                      @SetTextOvr(Err_OTHND4)
                      <tr><td class="dsphdr"><span $(textOvr)>Numeric 4</span></td>
                          <td class="inputalph"><input type="text" name="hdrNumScr4" value="$(V_OTHND4)" size="35" maxlength="23"></td>
                      </tr>
                      @DspErrMsg(Err_OTHND4)
    	         		
                      @SetTextOvr(Err_OTHND5)
                      <tr><td class="dsphdr"><span $(textOvr)>Numeric 5</span></td>
                          <td class="inputalph"><input type="text" name="hdrNumScr5" value="$(V_OTHND5)" size="35" maxlength="23"></td>
                      </tr>
                      @DspErrMsg(Err_OTHND5)
                  </table>       			
              </fieldset>

              %if (orderApplication=="OE")
                  <fieldset class="legendBody">
                      <legend class="legendTitle">User-Defined Detail</legend>
                      <table $(contentTable)>
                          <tr><td>&nbsp;</td>
                              <td class="colhdr">Description</td>
                              <td class="colhdr" colspan="2">Report Heading</td>
                          </tr>
        	         		
                          @SetTextOvr(Err_OTASC1)
                          <tr><td class="dsphdr"><span $(textOvr)>Alpha 1</span></td>
                              <td class="inputalph"><input type="text" name="dtlAlphScr1" value="$(V_OTASC1)" size="35" maxlength="23"></td>
                              <td class="inputalph"><input type="text" name="dtlAlphHdg11" value="$(V_OTAR11)" size="15" maxlength="8"></td>
                              <td class="inputalph"><input type="text" name="dtlAlphHdg12" value="$(V_OTAR12)" size="15" maxlength="8"></td>
                          </tr>
                          @DspErrMsg(Err_OTASC1)
        	         		
                          @SetTextOvr(Err_OTASC2)
                          <tr><td class="dsphdr"><span $(textOvr)>Alpha 2</span></td>
                              <td class="inputalph"><input type="text" name="dtlAlphScr2" value="$(V_OTASC2)" size="35" maxlength="23"></td>
                              <td class="inputalph"><input type="text" name="dtlAlphHdg21" value="$(V_OTAR21)" size="15" maxlength="8"></td>
                              <td class="inputalph"><input type="text" name="dtlAlphHdg22" value="$(V_OTAR22)" size="15" maxlength="8"></td>
                          </tr>
                          @DspErrMsg(Err_OTASC2)
        	         		
                          @SetTextOvr(Err_OTASC3)
                          <tr><td class="dsphdr"><span $(textOvr)>Alpha 3</span></td>
                              <td class="inputalph"><input type="text" name="dtlAlphScr3" value="$(V_OTASC3)" size="35" maxlength="23"></td>
                              <td class="inputalph"><input type="text" name="dtlAlphHdg31" value="$(V_OTAR31)" size="15" maxlength="8"></td>
                              <td class="inputalph"><input type="text" name="dtlAlphHdg32" value="$(V_OTAR32)" size="15" maxlength="8"></td>
                          </tr>
                          @DspErrMsg(Err_OTASC3)
        	         		
                          @SetTextOvr(Err_OTASC4)
                          <tr><td class="dsphdr"><span $(textOvr)>Alpha 4</span></td>
                              <td class="inputalph"><input type="text" name="dtlAlphScr4" value="$(V_OTASC4)" size="35" maxlength="23"></td>
                          </tr>
                          @DspErrMsg(Err_OTASC4)
        	         		
                          @SetTextOvr(Err_OTASC5)
                          <tr><td class="dsphdr"><span $(textOvr)>Alpha 5</span></td>
                              <td class="inputalph"><input type="text" name="dtlAlphScr5" value="$(V_OTASC5)" size="35" maxlength="23"></td>
                          </tr>
                          @DspErrMsg(Err_OTASC5)
        	         		
                          @SetTextOvr(Err_OTASC6)
                          <tr><td class="dsphdr"><span $(textOvr)>Alpha 6</span></td>
                              <td class="inputalph"><input type="text" name="dtlAlphScr6" value="$(V_OTASC6)" size="35" maxlength="23"></td>
                          </tr>
                          @DspErrMsg(Err_OTASC6)
        	         		
                          @SetTextOvr(Err_OTASC7)
                          <tr><td class="dsphdr"><span $(textOvr)>Alpha 7</span></td>
                              <td class="inputalph"><input type="text" name="dtlAlphScr7" value="$(V_OTASC7)" size="35" maxlength="23"></td>
                          </tr>
                          @DspErrMsg(Err_OTASC7)
        	         		
                          @SetTextOvr(Err_OTASC8)
                          <tr><td class="dsphdr"><span $(textOvr)>Alpha 8</span></td>
                              <td class="inputalph"><input type="text" name="dtlAlphScr8" value="$(V_OTASC8)" size="35" maxlength="23"></td>
                          </tr>
                          @DspErrMsg(Err_OTASC8)
        	         		
                          @SetTextOvr(Err_OTASC9)
                          <tr><td class="dsphdr"><span $(textOvr)>Alpha 9</span></td>
                              <td class="inputalph"><input type="text" name="dtlAlphScr9" value="$(V_OTASC9)" size="35" maxlength="23"></td>
                          </tr>
                          @DspErrMsg(Err_OTASC9)
        	         		
                          @SetTextOvr(Err_OTASC0)
                          <tr><td class="dsphdr"><span $(textOvr)>Alpha 10</span></td>
                              <td class="inputalph"><input type="text" name="dtlAlphScr0" value="$(V_OTASC0)" size="35" maxlength="23"></td>
                          </tr>
                          @DspErrMsg(Err_OTASC0)
        	         		
                          @SetTextOvr(Err_OTNSC1)
                          <tr><td class="dsphdr"><span $(textOvr)>Numeric 1</span></td>
                              <td class="inputalph"><input type="text" name="dtlNumScr1" value="$(V_OTNSC1)" size="35" maxlength="23"></td>
                              <td class="inputalph"><input type="text" name="dtlNumHdg11" value="$(V_OTNR11)" size="15" maxlength="8"></td>
                              <td class="inputalph"><input type="text" name="dtlNumHdg12" value="$(V_OTNR12)" size="15" maxlength="8"></td>
                          </tr>
                          @DspErrMsg(Err_OTNSC1)
        	         		
                          @SetTextOvr(Err_OTNSC2)
                          <tr><td class="dsphdr"><span $(textOvr)>Numeric 2</span></td>
                              <td class="inputalph"><input type="text" name="dtlNumScr2" value="$(V_OTNSC2)" size="35" maxlength="23"></td>
                              <td class="inputalph"><input type="text" name="dtlNumHdg21" value="$(V_OTNR21)" size="15" maxlength="8"></td>
                              <td class="inputalph"><input type="text" name="dtlNumHdg22" value="$(V_OTNR22)" size="15" maxlength="8"></td>
                          </tr>
                          @DspErrMsg(Err_OTNSC2)
        	         		
                          @SetTextOvr(Err_OTNSC3)
                          <tr><td class="dsphdr"><span $(textOvr)>Numeric 3</span></td>
                              <td class="inputalph"><input type="text" name="dtlNumScr3" value="$(V_OTNSC3)" size="35" maxlength="23"></td>
                              <td class="inputalph"><input type="text" name="dtlNumHdg31" value="$(V_OTNR31)" size="15" maxlength="8"></td>
                              <td class="inputalph"><input type="text" name="dtlNumHdg32" value="$(V_OTNR32)" size="15" maxlength="8"></td>
                          </tr>
                          @DspErrMsg(Err_OTNSC3)
        	         		
                          @SetTextOvr(Err_OTNSC4)
                          <tr><td class="dsphdr"><span $(textOvr)>Numeric 4</span></td>
                              <td class="inputalph"><input type="text" name="dtlNumScr4" value="$(V_OTNSC4)" size="35" maxlength="23"></td>
                          </tr>
                          @DspErrMsg(Err_OTNSC4)
        	         		
                          @SetTextOvr(Err_OTNSC5)
                          <tr><td class="dsphdr"><span $(textOvr)>Numeric 5</span></td>
                              <td class="inputalph"><input type="text" name="dtlNumScr5" value="$(V_OTNSC5)" size="35" maxlength="23"></td>
                          </tr>
                          @DspErrMsg(Err_OTNSC5)
                      </table>       			
                  </fieldset>
              %endif
          %}

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDOTU_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %if (orderApplication=="OE")
          @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
          @yn02_Table_Query(profileHandle, dataBaseID, "BY        ", yn02Table)
      %endif
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(ADD) {
  @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
  %if (backURL == "")
      @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=156")
  %endif
  %INCLUDE "setLibraryList.icl"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ORDERTYPEMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      <table $(contentTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1>Add Order Type</h1></td>
                              <td class="toolbar">
                                  <a href="javascript:history.back()">$(cancelImageMed)</a>
                                  @dtw_assign(medIcon, "Y")
                                  %INCLUDE "HelpPage.icl"
                              </td>
                          </tr>
                      </table>

                      $(hrTagAttr)
                      <form class="formClass" METHOD=POST name=Add ACTION="$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
                          <table $(contentTable)>
                              @RtvFldDesc("AIAPID='OE'", "SYAPID", "AIAPDS", oeDesc)
                              @RtvFldDesc("AIAPID='PO'", "SYAPID", "AIAPDS", poDesc)
                              <tr><td class="dsphdr">Application ID</td>
                                  <td class="inputcode"><input onClick="javascript:document.Add.submit()" name="orderApplication" type="radio" VALUE='OE'> $(oeDesc) &nbsp; <input onClick="javascript:document.Add.submit()" name="orderApplication" type="radio" VALUE='PO'> $(poDesc) </td>
                              </tr>
                          </table>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(orderApplication)
  @dtw_mUPPERCASE(orderType)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@fapl", fromAPID)
  @Concat_Field("@@fotc", fromOrderType)
  @Concat_Field("@@apid", orderApplication)
  @Concat_Field("@@otcd", orderType)
  @Concat_Field("@@desc", description)
  %if (orderApplication=="OE")
      @Concat_Field("@@aatx", allowAccTax)
      @Concat_Field("@@apog", allowPoGen)
  %endif
  @Concat_Field("@@sdt1", hdrDateScr2)
  @Concat_Field("@@rd11", hdrDateHdg21)
  @Concat_Field("@@rd12", hdrDateHdg22)
  @Concat_Field("@@sdt2", hdrDateScr3)
  @Concat_Field("@@rd21", hdrDateHdg31)
  @Concat_Field("@@rd22", hdrDateHdg32)
  @Concat_Field("@@sdt3", hdrDateScr4)
  @Concat_Field("@@rd31", hdrDateHdg41)
  @Concat_Field("@@rd32", hdrDateHdg42)

  @Concat_Field("@@scr1", hdrAlphScr1)
  @Concat_Field("@@rp11", hdrAlphHdg11)
  @Concat_Field("@@rp12", hdrAlphHdg12)
  @Concat_Field("@@scr2", hdrAlphScr2)
  @Concat_Field("@@rp21", hdrAlphHdg21)
  @Concat_Field("@@rp22", hdrAlphHdg22)
  @Concat_Field("@@scr3", hdrAlphScr3)
  @Concat_Field("@@rp31", hdrAlphHdg31)
  @Concat_Field("@@rp32", hdrAlphHdg32)
  @Concat_Field("@@scr4", hdrAlphScr4)
  @Concat_Field("@@rp41", hdrAlphHdg41)
  @Concat_Field("@@rp42", hdrAlphHdg42)
  @Concat_Field("@@scr5", hdrAlphScr5)
  @Concat_Field("@@rp51", hdrAlphHdg51)
  @Concat_Field("@@rp52", hdrAlphHdg52)
  @Concat_Field("@@scr6", hdrAlphScr6)
  @Concat_Field("@@scr7", hdrAlphScr7)
  @Concat_Field("@@scr8", hdrAlphScr8)
  @Concat_Field("@@scr9", hdrAlphScr9)
  @Concat_Field("@@scr0", hdrAlphScr0)
  @Concat_Field("@@hnd1", hdrNumScr1)
  @Concat_Field("@@hnd2", hdrNumScr2)
  @Concat_Field("@@hnd3", hdrNumScr3)
  @Concat_Field("@@hnd4", hdrNumScr4)
  @Concat_Field("@@hnd5", hdrNumScr5)

  %if (orderApplication=="OE")
      @Concat_Field("@@asc1", dtlAlphScr1)
      @Concat_Field("@@ar11", dtlAlphHdg11)
      @Concat_Field("@@ar12", dtlAlphHdg12)
      @Concat_Field("@@asc2", dtlAlphScr2)
      @Concat_Field("@@ar21", dtlAlphHdg21)
      @Concat_Field("@@ar22", dtlAlphHdg22)
      @Concat_Field("@@asc3", dtlAlphScr3)
      @Concat_Field("@@ar31", dtlAlphHdg31)
      @Concat_Field("@@ar32", dtlAlphHdg32)
      @Concat_Field("@@asc4", dtlAlphScr4)
      @Concat_Field("@@asc5", dtlAlphScr5)
      @Concat_Field("@@asc6", dtlAlphScr6)
      @Concat_Field("@@asc7", dtlAlphScr7)
      @Concat_Field("@@asc8", dtlAlphScr8)
      @Concat_Field("@@asc9", dtlAlphScr9)
      @Concat_Field("@@asc0", dtlAlphScr0)

      @Concat_Field("@@nsc1", dtlNumScr1)
      @Concat_Field("@@nr11", dtlNumHdg11)
      @Concat_Field("@@nr12", dtlNumHdg12)
      @Concat_Field("@@nsc2", dtlNumScr2)
      @Concat_Field("@@nr21", dtlNumHdg21)
      @Concat_Field("@@nr22", dtlNumHdg22)
      @Concat_Field("@@nsc3", dtlNumScr3)
      @Concat_Field("@@nr31", dtlNumHdg31)
      @Concat_Field("@@nr32", dtlNumHdg32)
      @Concat_Field("@@nsc4", dtlNumScr4)
      @Concat_Field("@@nsc5", dtlNumScr5)
  %endif

  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          %if (orderApplication != "")
              @RtvFldDesc("AIAPID='$(orderApplication)'", "SYAPID", "AIAPDS", apidDesc)
              @Format_ConfMsg_Desc(maintenanceCode, $(description), $(orderType), "For $(apidDesc)", "$(orderApplication)", "", "", confMessage)
          %else
              @Format_ConfMsg_Desc(maintenanceCode, $(description), $(orderType), "", "", "", "", confMessage)
          %endif
      %else
          @DecatErr_Field("@@otcd", "orderType")
          @Format_ConfMsg_Desc("", $(description), $(orderType), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=156&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;orderType=@dtw_rurlescseq(orderType)&amp;orderApplication=@dtw_rurlescseq(orderApplication)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}