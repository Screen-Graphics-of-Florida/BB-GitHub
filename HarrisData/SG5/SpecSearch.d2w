%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Specification Search"
  d2wName                 = "SpecSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldComment=@dtw_rurlescseq(fldComment)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
  docName                 = ""
  fldComment              = ""
  specification           = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectSpecification(specification){
                  window.opener.document.$(docName).$(fldComment).value += specification;
                  window.opener.document.$(docName).$(fldComment).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select SHSPEC, SHDESC, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(SHDESC) as SHDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " HDSPCH ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, " SHSPEC<>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Spec_Search_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
     </body>
  </html>
%}

%FUNCTION(dtw_sql) Spec_Search_Query (IN CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(displayCloseIcon, "Y")
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)

      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr"> Specification </th>
                  <th class="colhdr"> Description </th>
              </tr>
              <tr><td align=center><input type="text" class="inputalph" name="srchSpec" size="15" maxlength="15">
                      <input type="hidden" name="operSpec" value="LIKE">
                  </td>
                  <td><input type="text" class="inputalph" name="srchDesc" size="30" maxlength="30">
                      <input type="hidden" name="operDesc" value="LIKE">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
          <script TYPE="text/javascript">
              document.Search.srchSpec.focus();
          </script>
      </form>

      %INCLUDE "WildCardPage.icl"

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              @OrderBy_Sort("SHSPEC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=document" title="Sequence By Specification"> Specification</a></th>
              @OrderBy_Sort("SHDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=description" title="Sequence By Description, Specification"> Description</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Get_Specifications(profileHandle, dataBaseID, V_SHSPEC, comment)
              @DTW_CHARTOHEX(comment, cmtHex)
              @DTW_POS("0D", cmtHex, dPos)
              @dtw_assign(beg, "1")
              @dtw_assign(inc, "0")
              %while(dPos > "0") {
                  @DTW_SUBTRACT(dPos, "1", end)
                  @DTW_DIVREM(end, "2", result)
                  %if (result == "0")
                      @DTW_divide(end, "2", str)
                      @DTW_add(str, inc, str)
                      @DTW_INSERT("\r", comment, str, comment)
                      @DTW_add(inc, "2", inc)
                  %endif
                  @DTW_ADD(dPos, "2", beg)
                  @DTW_POS("0D", cmtHex, beg, dPos)
              %}
              @Format_Quote(comment, F_comment)
              <tr class="$(rowClass)">
                  <td class="colalph"><a href="javascript:selectSpecification('$(F_comment)')" title="Select Specifications">$(V_SHSPEC)</a></td>
                  <td class="colalph">$(V_SHDESC)</td>
                  <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/VIEW$(d2wVarBase)&amp;fromSpecification=@dtw_rurlescseq(V_SHSPEC)&amp;fromSpecDesc=@dtw_rurlescseq(V_SHDESC)" title="View Specifications">$(moreInfoImage)</a></td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Display_Specifications () {	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectSpecification(specification){
                  window.opener.document.$(docName).$(fldComment).value += specification;
                  window.opener.document.$(docName).$(fldComment).focus();
                  window.close();
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(contentTable)>
              <tr valign="top">
                  <td>
                      @Get_Specifications(profileHandle, dataBaseID, fromSpecification, comment)
                      @Format_Quote(comment, F_comment)
                      @DTW_CHARTOHEX(F_comment, cmtHex)
                      @DTW_POS("0D", cmtHex, dPos)
                      @dtw_assign(beg, "1")
                      @dtw_assign(inc, "0")
                      %while(dPos > "0") {
                          @DTW_SUBTRACT(dPos, "1", end)
                          @DTW_DIVREM(end, "2", result)
                          %if (result == "0")
                              @DTW_divide(end, "2", str)
                              @DTW_add(str, inc, str)
                              @DTW_INSERT("\r", F_comment, str, F_comment)
                              @DTW_add(inc, "2", inc)
                          %endif
                          @DTW_ADD(dPos, "2", beg)
                          @DTW_POS("0D", cmtHex, beg, dPos)
                      %}
                      <table $(contentTable)>
                          <tr><td><h1>$(page_title)</h1></td>
                              <td class="toolbar">
                                  <a href="javascript:selectSpecification('$(F_comment)')" title="Select Specifications">$(copyImageLrg)</a>
                                  %INCLUDE "CloseWindow.icl"
                              </td>
                          </tr>
                      </table>

                      <table $(contentTable)>
                          <tr align="center"><td><h2>$(fromSpecDesc)</h2></td></tr>
                          <tr><td><textarea ROWS=20 COLS=60 WRAP="hard">$(comment)</textarea></td></tr>
                      </table>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(DTW_directcall) Get_Specifications (INOUT CHAR(64)    profileHandle,
				   		     CHAR(2)     dataBaseID,
    				                     CHAR(15)    fromSpecification,
    				                     char(32000) comment)

{%EXEC {HHDSPC_P.PGM %}
%}

%HTML(VIEW) {
  %INCLUDE "setLibraryList.icl"
  @Display_Specifications ()
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "SHDESCU,SHSPEC")
      @DTW_ASSIGN(orderByDisplay, "Description, Specification")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "document")
      %if (orderBy == "SHSPEC")
          @DTW_ASSIGN(orderBy, "SHSPEC DESC")
          @DTW_ASSIGN(orderByDisplay, "Specification (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SHSPEC")
          @DTW_ASSIGN(orderByDisplay, "Specification")
      %endif
  %elif (sequence == "description")
      %if (orderBy == "SHDESCU,SHSPEC")
          @DTW_ASSIGN(orderBy, "SHDESCU DESC,SHSPEC")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Specification")
      %else
          @DTW_ASSIGN(orderBy, "SHDESCU,SHSPEC")
          @DTW_ASSIGN(orderByDisplay, "Description, Specification")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("SHSPEC", "Specification", $(srchSpec), "U", operSpec, "A")
  @Build_WildCard ("upper(SHDESC)", "Description", $(srchDesc), "U", operDesc, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}