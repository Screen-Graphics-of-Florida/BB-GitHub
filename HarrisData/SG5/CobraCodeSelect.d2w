%INCLUDE "$(baseVar)"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title 	       = "COBRA Code"
  d2wName             = "CobraCodeSelect.d2w"
  d2wVarBase          = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;codeType=@dtw_rurlescseq(codeType)&amp;cobraCode=@dtw_rurlescseq(cobraCode)"
  programName         = "HPECCU"
  DATABASE            = "*LOCAL"
  DTW_DEFAULT_REPORT  = "NO"
  RPT_MAX_ROWS        = "99"
  ROW_NUM             = "0"
  START_ROW_NUM       = "1"
  rowIndexNext	       = "1"
  totalPages	       = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@codeType", "@dtw_rurlescseq(codeType)", "1", "a", workURL)
  @dtw_replace(workURL, "@@cobraCode", "@dtw_rurlescseq(cobraCode)", "1", "a", workURL)
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "CBCODESELECT")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          @dtw_concat(stmtSQL, "Select *  From CBCODE", stmtSQL)
                          @dtw_concat(stmtSQL, " WHERE CCTYPE='$(codeType)' and CCCODE='$(cobraCode)'", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @CobraCode_Inquiry(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) CobraCode_Inquiry (IN CHAR(64)    profileHandle,
				          CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td>&nbsp;</td>
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/report") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %ROW {
          <table $(contentTable)>
              @dtw_assign(codeDescription, "$(V_CCDESC)")
              %if (V_CCTYPE == "Q")
                  @dtw_assign(typeDescription, "Qualifying Event Code")
                  %if (V_CCTYPE == "TE")
                      @dtw_assign(typeDescription, "Termination Of Empoyment")
                  %elif (V_CCCODE == "DE")
                      @dtw_assign(codeDescription, "Death Of An Employee")
                  %elif (V_CCCODE == "DL")
                      @dtw_assign(codeDescription, "Divorce Or Legal Separation")
                  %elif (V_CCCODE == "DP")
                      @dtw_assign(codeDescription, "Dependent No Longer Qualified")
                  %elif (V_CCCODE == "MC")
                      @dtw_assign(codeDescription, "Employee Entitled To Medicare")
                  %elif (V_CCCODE == "RE")
                      @dtw_assign(codeDescription, "Reduction In Work Hours")
                  %elif (V_CCCODE == "SL")
                      @dtw_assign(codeDescription, "Substantial Loss Of Coverage")
                  %elif (V_CCCODE == "TE")
                      @dtw_assign(codeDescription, "Termination Of Employment")
                  %endif
              %endif
              <tr><td class="dsphdr">Code Type</td>
                  <td class="dspalph">$(V_CCTYPE)</td></tr>
              @RtvFldDesc("FLTYPE='COBRACODE' and FLVALU='$(V_CCTYPE)'", "SYFLAG", "FLDESC", syFlagDesc)
              <tr><td class="dsphdr">Type Description</td>
                  <td class="dspalph">$(syFlagDesc)</td></tr>
              <tr><td class="dsphdr">Code</td>
                  <td class="dspalph">$(V_CCCODE)</td></tr>
              <tr><td class="dsphdr">Description</td>
                  <td class="dspalph">$(codeDescription)</td></tr>
              %if (V_CCTYPE == "Q")
                  <tr><td class="dsphdr">Employer Notification Period</td>
                      <td class="dspalph">$(V_CCQENP) Days</td></tr>
                  <tr><td class="dsphdr">Employee Notification Period</td>
                      <td class="dspalph">$(V_CCQWNP) Days</td></tr>
                  <tr><td class="dsphdr">Employee Election Period</td>
                      <td class="dspalph">$(V_CCQELP) Days</td></tr>
                  <tr><td class="dsphdr">Continuation Period</td>
                      <td class="dspalph">$(V_CCQCNP) Months</td></tr>
                  <tr><td class="dsphdr">First Payment Period</td>
                      <td class="dspalph">$(V_CCQFPP) Days</td></tr>
              %endif
          </table>
      %}	
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}