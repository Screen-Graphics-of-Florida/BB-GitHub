%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Component Material Shortage"
  d2wName                 = "ComponentMaterialShortage.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;mfgOrder=@dtw_rurlescseq(mfgOrder)&amp;parentItem=@dtw_rurlescseq(parentItem)&amp;parentItemDesc=@dtw_rurlescseq(parentItemDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HSI???"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "Menu.js"
                  %INCLUDE "NumEdit.icl"
                  %INCLUDE "CheckEnterSearch.icl"
                  function validate(searchForm) {
                      if (editNum(document.Search.srchSeq, 3, 0))
                          return true;
                  }
                  %INCLUDE "NoFormValidate.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "COMPONENTMATERIALSHORTAGE")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select CSCPN,CSCIMD,CSSEQN,CSPTYP,CSUOMS,CSRQDT,CSRQTY,CSQTYI,(CSOHQT + CSOHRC + CSOHFS) as onHand,CSAVQT,CSSHRT ", stmtSQL)
                          @dtw_concat(fileSQL, " SICMSW", fileSQL)
                          @dtw_concat(selectSQL, " CSXHND='$(profileHandle)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy)", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @ComponentShortage_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) ComponentShortage_Query (IN CHAR(64)    profileHandle,
				                CHAR(2)     dataBaseID,
                                               CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      <table $(contentTable)>
          @Format_Header_URL("Plant", $(plantName), $(plantNumber), "$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;plantName=@dtw_rurlescseq(plantName)")
          @Format_Header_URL("Mfg Order", $(mfgOrder), "", "")
          @Format_Header_URL("Parent Item", $(parentItemDesc), $(parentItem), "$(homeURL)$(cGIPath)ItemPlantSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(parentItem)&amp;plantNumber=@dtw_rurlescseq(plantNumber)")
      </table>
      %INCLUDE "ConfMessageDisplay.icl"
	
      $(hrTagAttr)	

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Component<br>Item</th>
                      <th class="colhdr">Rtg<br>Seq</th>
                      <th class="colhdr">Component Description</th>
                  </tr>

                  <tr>
                      <td><input type="text" class="inputalph" name="srchComponent" size="15" maxlength="15">
                          <input type="hidden" name="operComponent" value="LIKE">
                      </td>
                      <td><input type="text" class="inputnmbr" name="srchSeq" size="5" maxlength="3">
                          <input type="hidden" name="operSeq" value="=">
                      </td>
                      <td><input type="text" class="inputalph" name="srchCompDesc" size="15" maxlength="30">
                          <input type="hidden" name="operCompDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchComponent.focus();
              </script>
          </form>
	
          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("CSCPN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CPN" title="Sequence By Component Item"> Component<br>Item</a></th>	
              @OrderBy_Sort("CSSEQN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SEQN" title="Sequence By Routing Sequence"> Rtg<br>Seq</a></th>
              @OrderBy_Sort("CSCIMD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CIMD" title="Sequence By Component Description"> Component Description</th>
              @OrderBy_Sort("CSPTYP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PTYP" title="Sequence By Part Type"> Part<br>Type</th>
              @OrderBy_Sort("CSUOMS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=UOMS" title="Sequence By Stocking Unit Of Measure"> St<br>UM</th>
              @OrderBy_Sort("CSRQDT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RQDT" title="Sequence By Required Date">Due Date</a></th>
              @OrderBy_Sort("CSRQTY", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RQTY" title="Sequence By Required Quantity">Required<br>Quantity</a></th>
              @OrderBy_Sort("CSQTYI", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=QTYI" title="Sequence By Issued Quantity">Issued<br>Quantity</a></th>
              @OrderBy_Sort("onHand", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=OHQT" title="Sequence By On Hand Quantity">On Hand<br>Quantity</th>
              @OrderBy_Sort("CSAVQT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=AVQT" title="Sequence By Available Quantity">Available<br>Quantity</a></th>
              @OrderBy_Sort("CSSHRT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SHRT" title="Sequence By Short Quantity">Short<br>Quantity</a></th>
          </tr>		
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc("Component Item", $(V_CSCPN), "", "", "", "", confirmDesc)
              @dtw_replace(confirmDesc, "'", "\'", "1", "a", confirmDesc)
              @dtw_assign(maintainVar, "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(V_CSCPN)")
	       <tr class="$(rowClass)">
                  @RtvFldDesc("(FLTYPE='PARTTYPE' and FLVALU='$(V_CSPTYP)')", "SYFLAG", "FLDESC", ptypDesc)
                  @RtvFldDesc("(UMUOM='$(V_CSUOMS)')", "HDUOM", "UMUMLD", uomsDesc)
                  @Format_Date(V_CSRQDT, "D", F_CSRQDT)
                  @Format_Nbr($(V_CSRQTY), F_CSRQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @Format_Nbr($(V_CSQTYI), F_CSQTYI, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @Format_Nbr($(V_onHand), F_onHand, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @Format_Nbr($(V_CSAVQT), F_CSAVQT, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @Format_Nbr($(V_CSSHRT), F_CSSHRT, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  %if (V_CSPTYP == "M")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)MfgOrderMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=A" title="Create Mfg Order">$(V_CSCPN)</a></td>
                  %else
                      <td class="colalph">$(V_CSCPN)</td>
                  %endif
                  <td class="colnmbr"> $(V_CSSEQN)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemPlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(V_CSCPN)" title="View Item/Plant">$(V_CSCIMD)</a></td>
                  <td class="colcode" $(helpCursor)><span title="$(ptypDesc)">$(V_CSPTYP)</span></td>
                  <td class="colcode" $(helpCursor)><span title="$(uomsDesc)">$(V_CSUOMS)</span></td>
                  <td class="colnmbr">$(F_CSRQDT)</td>
                  <td class="colnmbr">$(F_CSRQTY)</td>
                  <td class="colnmbr">$(F_CSQTYI)</td>
                  <td class="colnmbr">$(F_onHand)</td>
                  <td class="colnmbr">$(F_CSAVQT)</td>
                  <td class="colnmbr">$(F_CSSHRT)</td>
	       </tr>
	   %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Create_Work_File (IN    CHAR(64)    profileHandle,
                                                  CHAR(32000) edtVar)
{%EXEC {HSICMS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@pitm", parentItem)
  @Concat_Field("@@pimd", parentItemDesc)
  @Concat_Field("@@ord@", mfgOrder)
  @dtw_concat(edtVar, "}{", edtVar)

  @Create_Work_File (profileHandle, edtVar)

  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "CSCPN,CSSEQN")
          @DTW_ASSIGN(orderByDisplay, "Component Item, Routing Sequence")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "CPN")
      %if (orderBy == "CSCPN,CSSEQN")
          @DTW_ASSIGN(orderBy, "CSCPN DESC,CSSEQN")
          @DTW_ASSIGN(orderByDisplay, "Component Item (descending), Routing Sequence")
      %else
          @DTW_ASSIGN(orderBy, "CSCPN,CSSEQN")
          @DTW_ASSIGN(orderByDisplay, "Component Item, Routing Sequence")
      %endif
  %elif (sequence == "SEQN")
      %if (orderBy == "CSSEQN,CSCPN")
          @DTW_ASSIGN(orderBy, "CSSEQN DESC,CSCPN")
          @DTW_ASSIGN(orderByDisplay, "Routing Sequence (descending), Component Item")
      %else
          @DTW_ASSIGN(orderBy, "CSSEQN,CSCPN")
          @DTW_ASSIGN(orderByDisplay, "Routing Sequence, Component Item")
      %endif
  %elif (sequence == "CIMD")
      %if (orderBy == "CSCIMD,CSCPN")
          @DTW_ASSIGN(orderBy, "CSCIMD DESC,CSCPN")
          @DTW_ASSIGN(orderByDisplay, "Component Description (descending), Component Item")
      %else
          @DTW_ASSIGN(orderBy, "CSCIMD,CSCPN")
          @DTW_ASSIGN(orderByDisplay, "Component Description, Component Item")
      %endif
  %elif (sequence == "PTYP")
      %if (orderBy == "CSPTYP,CSCPN")
          @DTW_ASSIGN(orderBy, "CSPTYP DESC,CSCPN")
          @DTW_ASSIGN(orderByDisplay, "Part Type (descending), Component Item")
      %else
          @DTW_ASSIGN(orderBy, "CSPTYP,CSCPN")
          @DTW_ASSIGN(orderByDisplay, "Part Type, Component Item")
      %endif
  %elif (sequence == "UOMS")
      %if (orderBy == "CSUOMS,CSCPN")
          @DTW_ASSIGN(orderBy, "CSUOMS DESC,CSCPN")
          @DTW_ASSIGN(orderByDisplay, "Stocking Unit Of Measure (descending), Component Item")
      %else
          @DTW_ASSIGN(orderBy, "CSUOMS,CSCPN")
          @DTW_ASSIGN(orderByDisplay, "Stocking Unit Of Measure, Component Item")
      %endif
  %elif (sequence == "RQDT")
      %if (orderBy == "CSRQDT,CSCPN")
          @DTW_ASSIGN(orderBy, "CSRQDT DESC,CSCPN")
          @DTW_ASSIGN(orderByDisplay, "Required Date (descending), Component Item")
      %else
          @DTW_ASSIGN(orderBy, "CSRQDT,CSCPN")
          @DTW_ASSIGN(orderByDisplay, "Required Date, Component Item")
      %endif
  %elif (sequence == "RQTY")
      %if (orderBy == "CSRQTY,CSCPN")
          @DTW_ASSIGN(orderBy, "CSRQTY DESC,CSCPN")
          @DTW_ASSIGN(orderByDisplay, "Required Quantity (descending), Component Item")
      %else
          @DTW_ASSIGN(orderBy, "CSRQTY,CSCPN")
          @DTW_ASSIGN(orderByDisplay, "Required Quantity, Component Item")
      %endif
  %elif (sequence == "QTYI")
      %if (orderBy == "CSQTYI,CSCPN")
          @DTW_ASSIGN(orderBy, "CSQTYI DESC,CSCPN")
          @DTW_ASSIGN(orderByDisplay, "Issued Quantity (descending), Component Item")
      %else
          @DTW_ASSIGN(orderBy, "CSQTYI,CSCPN")
          @DTW_ASSIGN(orderByDisplay, "Issued Quantity, Component Item")
      %endif
  %elif (sequence == "OHQT")
      %if (orderBy == "OnHand,CSCPN")
          @DTW_ASSIGN(orderBy, "OnHand DESC,CSCPN")
          @DTW_ASSIGN(orderByDisplay, "On Hand Quantity (descending), Component Item")
      %else
          @DTW_ASSIGN(orderBy, "OnHand,CSCPN")
          @DTW_ASSIGN(orderByDisplay, "On Hand Quantity, Component Item")
      %endif
  %elif (sequence == "AVQT")
      %if (orderBy == "CSAVQT,CSCPN")
          @DTW_ASSIGN(orderBy, "CSAVQT DESC,CSCPN")
          @DTW_ASSIGN(orderByDisplay, "Available Quantity (descending), Component Item")
      %else
          @DTW_ASSIGN(orderBy, "CSAVQT,CSCPN")
          @DTW_ASSIGN(orderByDisplay, "Available Quantity, Component Item")
      %endif
  %elif (sequence == "SHRT")
      %if (orderBy == "CSSHRT,CSCPN")
          @DTW_ASSIGN(orderBy, "CSSHRT DESC,CSCPN")
          @DTW_ASSIGN(orderByDisplay, "Short Quantity (descending), Component Item")
      %else
          @DTW_ASSIGN(orderBy, "CSSHRT,CSCPN")
          @DTW_ASSIGN(orderByDisplay, "Short Quantity, Component Item")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("CSCPN", "Component Item", $(srchComponent), "U", operComponent, "A")
  @Build_WildCard ("upper(CSCIMD)", "Component Description", $(srchCompDesc), "U", operCompDesc, "A")
		
  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}