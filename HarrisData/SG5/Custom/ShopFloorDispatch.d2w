%INCLUDE "$(baseVar)"
%INCLUDE "EdtVar.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "ETControl$(dataBaseID).icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Shop Floor Dispatch"
  d2wName                 = "ShopFloorDispatch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;touchScreen=Y"
  altVarBaseT             = "$(altVarBase)&amp;touchScreen=Y"
  currentURL              = "$(d2wName)/REPORT$(d2wVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HSI214"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "50"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "50"
  rowIndexNext            = "1"
  totalPages              = "0"
  sec_01                  = ""
  sec_02                  = ""
  sec_03                  = ""
  sec_04                  = ""
  sec_05                  = ""
  sec_06                  = ""
  sec_07                  = ""
  sec_08                  = ""
  sec_09                  = ""
  sec_10                  = ""
  sec_11                  = ""
  sec_12                  = ""
  sec_13                  = ""
  sec_14                  = ""
  sec_15                  = ""
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  @dtw_assign(timeOutM, "0")
  %if (sfdTimeOut > "0")
      @dtw_multiply(sfdTimeOut, "1000", timeOutM)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
              %INCLUDE "AJAXRequestFunction.icl"
              %INCLUDE "KeyboardFunctionsTS.icl"
              %INCLUDE "ShowHideSelCriteria.icl"

              function selUpdate(plt,ord,seq,row) {
                 var selFld="selRec"+row;
                 var url = "$(homeURL)$(cGIPath)ShopFloorDispatchSelUpdate.d2w/UPDATE?baseVar=@dtw_rurlescseq(baseVar)&eID=@dtw_rurlescseq(eID)";
                     url += "&plantNumber=" + escape(plt);
                     url += "&mfgOrder=" + escape(ord);
                     url += "&seqNumber=" + escape(seq);
                 var sel='';
                     if (document.getElementById(selFld).checked) {sel='Y';}
                     url += "&selFlag=" + escape(sel);
	          var ajaxRequest = new ajaxObject(url,selUpdateResponse);
	              ajaxRequest.update();
              }

              function selUpdateResponse(responseText, responseStatus) {
                 if (responseStatus==200) {
                 } else  { alert(responseStatus + " -- Error Processing Request");}
              }

              function saveCurrURL() {
                  var url = "$(homeURL)$(cGIPath)SaveCurrentURL.d2w/SAVE?baseVar=@dtw_rurlescseq(baseVar)&eID=@dtw_rurlescseq(eID)&currentURL=@dtw_rurlescseq(currentURL)";
	              var saveRequest = new getXMLHTTPRequest();
                  saveRequest.open("GET", url, false);
                  saveRequest.send(null);
              }

              setInterval("window.location.replace('$(homeURL)$(cGIPath)$(d2wName)/BUILD?baseVar=@dtw_rurlescseq(baseVar)&eID=@dtw_rurlescseq(eID)&START_ROW_NUM=$(START_ROW_NUM)');",600000);

              %if (timeOutM > "0")
                  setTimeout("window.location.assign('$(homeURL)$(cGIPath)EmployeeSignOn.d2w/REPORT?baseVar=@dtw_rurlescseq(baseVar)&portal=@dtw_rurlescseq(portal)&eID=@dtw_rurlescseq(eID)&touchScreen=Y');",$(timeOutM));
              %endif

          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">

%{ Shop Floor Dispatch Heading %}
                      @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                      @dtw_assign(START_ROW_NUM, "1")
                      @dtw_assign(stmtSQL, "")
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(stmtSQL, " From SIDCTW Where WDXHND='$(profileHandle)' ", stmtSQL)
                      @dtw_concat(stmtSQL, " Fetch First 1 Row Only With NC  @@endsql", stmtSQL)
                      @Dispatch_Header(profileHandle, dataBaseID, stmtSQL)

%{ Shop Floor Dispatch Detail %}
                      @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " SIDOPW ", fileSQL)
                      @dtw_concat(selectSQL, "WOXHND='$(profileHandle)' ", selectSQL)
%{EXT-BEG: 2008-10-06 Add selection criteria to limit displayed records to work orders that have reported work complete (WOQTYC - Quantity Completed) %}
%{  this line failed due to the simple comma after the last field (LPFVQT)
  @dtw_concat(fileSQL, " left outer join (Select LPPLT, LPORD, LPSEQN, LPQTYC, LPFVQT, From HDMLPM) LP ", fileSQL)
  The line below is the same line, except I've taken out the extra comma so it works
%}


		      @dtw_concat(fileSQL, " left outer join (Select LPPLT, LPORD, LPSEQN, LPREAS, LPQTYC, LPFVQT, LPOPRC From HDMLPM) LP ", fileSQL)

                      @dtw_concat(fileSQL, " on (WOPLT = LPPLT and WOMORD = LPORD and LPSEQN = ", fileSQL)
                      @dtw_concat(fileSQL, " (Select max(LPSEQN) From HDMLPM Where LPREAS <> 'D' and (LPPLT = WOPLT and LPORD = WOMORD and LPSEQN < WOSEQN ))) ", fileSQL)
                      @dtw_concat(selectSQL, " and (LPQTYC > 0 or LPSEQN is null or LPFVQT > 0 or LPOPRC = 'Y')  ", selectSQL)
%{EXT-END %}

                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Dispatch_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
                  <td>
                      <ul class="toolbarTS">
                          <li class="optionTS"><a href="$(homeURL)$(cGIPath)EmployeeSignOn.d2w/REPORT$(d2wVarBase)">&nbsp;<br>Exit</a></li>
                          %if (sec_02 == "Y")
                              <li class="optionTS"><a onClick="saveCurrURL();"   href="$(homeURL)$(cGIPath)LaborEntry.d2w/BUILD$(d2wVarBase)">&nbsp;<br>Labor Entry</a></li>
                          %endif
                          %if (sec_07 == "Y")
                              <li class="optionTS"><a href="$(homeURL)$(cGIPath)$(d2wName)/Shift_OnOff$(d2wVarBase)">&nbsp;<br>Shift On/Off</a></li>
                          %endif
                          %if (sec_08 == "Y")
                              <li class="optionTS"><a href="$(homeURL)$(cGIPath)LaborEntryIndirect.d2w/BUILD$(d2wVarBase)">&nbsp;<br>Indirect</a></li>
                          %endif
                          %if (sec_12 == "Y" && V_TALTFM != "")
                              <li class="optionTS"><a href="$(homeURL)$(cGIPath)LaborEntryLunch.d2w/BUILD$(d2wVarBase)">&nbsp;<br>Lunch</a></li>
                          %endif                          
                          %if (sec_09 == "Y")
                              <li class="optionTS"><a href="$(homeURL)$(cGIPath)DataCollection.d2w/REPORT$(d2wVarBase)">&nbsp;<br>Data Collection</a></li>
                          %endif
                          %if (sec_14 == "Y")
                              <li class="optionTS"><a href="$(homeURL)$(phpPath)LaborEntryOverride.php$(altVarBaseT)&amp;tag=BUILD">&nbsp;<br>Override Labor Entry</a></li>
                          %endif
                          <li class="optionTS"><a href="$(homeURL)$(cGIPath)$(d2wName)/BUILD$(d2wVarBase)">&nbsp;<br>Refresh</a></li>
                      </ul>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Dispatch_Header (IN CHAR(64)    profileHandle,
				                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <tr><td><h1> $(page_title)</h1></td></tr>
      </table>

      %ROW{
          <table $(contentTable)>
              @Format_Header("Plant", $(V_WDPNAM), $(V_WDPLT))
              %if (V_WDGRP == "0")
                  @Format_Header("Employee", $(V_WDENAM), "")
              %else
                  @Format_Header("Group", $(V_WDGDSC), "")
              %endif
              @dtw_assign(F_WDDEPT, $(V_WDDEPT))
              @dtw_concat(F_WDDEPT, " / ", F_WDDEPT)
              @dtw_concat(F_WDDEPT, $(V_WDWC), F_WDDEPT)
              @Format_Code(F_WDDEPT, F_WDDEPT)
              <tr><td class="hdrtitl">Department/Work Center:</td>
                  <td class="hdrdata">$(V_WDWDSC) &nbsp; $(F_WDDEPT)</td>
                  %if (sec_03 == "Y")
                  	 <td><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBaseT)&amp;forPlant=$(V_WDPLT)&amp;docName=Chg&amp;flddept=deptNumber&amp;fldWC=workCenter&amp;fldDesc=wcDesc&amp;dispatch=Y" onclick="$(searchWinVar)">&nbsp; $(searchDesc)</a></td>
                  %endif
              </tr>
          </table>
          <form class="formClass" method="post" name="Chg" action="$(homeURL)$(cGIPath)$(d2wName)/Change_WC$(d2wVarBase)">
              <input type="hidden" name="deptNumber">
              <input type="hidden" name="workCenter">
              <input type="hidden" name="wcDesc">
          </form>
      %}

      %INCLUDE "ConfMessageDisplay.icl"
      $(hrTagAttr)
  %}
%}


%FUNCTION(dtw_sql) Dispatch_Query (IN CHAR(64)    profileHandle,
				                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      <form class="formClass" method="post" name="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr">Item Number</th>
                  <th class="colhdr">Order Number</th>
                  <td>&nbsp;</td>
              </tr>
              <tr><td class="inputalph">
                      <input class="input" id="srchItem" onfocus="kbActive(this, 'keyboard');" name="srchItem" type="text" size="15" maxlength="15">
                      <input type="hidden" name="operItem" value="LIKE">
                  </td>
                  <td class="inputalph">
                      <input class="input" id="srchOrder" onfocus="kbActive(this, 'keyboard');" name="srchOrder" type="text" size="15" maxlength="9">
                      <input type="hidden" name="operOrder" value="LIKE">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  <td><input type="hidden" id="submitSearch"></td>
              </tr>
          </table>
      </form>
	
      @dtw_assign(pageSelectList, "N")
      @dtw_assign(wildCardDefault, "N")
      @dtw_assign(advanceSearch, "N")
      %INCLUDE "WildCardPage.icl"

      <form class="formClass" method="post" name="Select" action="">
          <table $(contentTable)>
              <tr>
              	  <th>&nbsp;</th>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("WOITEM", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ITEM" title="Sequence By Item Number">Item Number</a></th>
                  @OrderBy_Sort("WOCPNS", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CPNS" title="Sequence By Component Shortage">Sh</a></th>
                  @OrderBy_Sort("WOSCHS", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SCHS" title="Sequence By Schedule Sequence">Sch<br>Seq</a></th>
                  @OrderBy_Sort("WOMORD", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ORD" title="Sequence By Order Number">Order</a></th>
                  @OrderBy_Sort("WOSEQN", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SEQN" title="Sequence By Routing Sequence">Rtg<br>Seq</a></th>
                  @OrderBy_Sort("WOCSDT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CSDT" title="Sequence By Start Date">Start<br>Date</a></th>
                  @OrderBy_Sort("WOCDDT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CDDT" title="Sequence By Due Date">Due<br>Date</a></th>
                  @OrderBy_Sort("WOQTYR", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=QTYR" title="Sequence By Quantity Remaining">Quantity</a></th>
                  @OrderBy_Sort("WOHRSR", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=HRSR" title="Sequence By Hours Remaining">Hours </a></th>
                  <th class="colhdr">Sel</th>
              </tr>		
              %INCLUDE "NoRecordsFound.icl"

              %ROW{

                  %if (V_WOOACT == "Y")
                     @dtw_assign(selClass, "selRow")
                  %else
                     %INCLUDE "SetRowClass.icl"
                     @dtw_assign(selClass, rowClass)
                  %endif
                  @Format_Date(V_WOCSDT, "D", F_WOCSDT)
                  @Format_Date(V_WOCDDT, "D", F_WOCDDT)
                  @Format_Nbr($(V_WOQTYR), F_WOQTYR, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @Format_Nbr($(V_WOHRSR), F_WOHRSR, $(hrsNbrDec), $(hrsEditCode), "", "", "")
                  %if (V_WOOSEL == "Y")
                      @dtw_assign(orderChecked, "CHECKED")
                  %else
                      @dtw_assign(orderChecked, "")
                  %endif
                  <tr class="$(selClass)">
                      %if (V_WONTCD != "")
                          <td class="opticon"><a href="$(homeURL)$(cGIPath)LaborInProcessNotesInquiry.d2w/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(V_WOPLT)&amp;mfgOrder=@dtw_rurlescseq(V_WOMORD)&amp;sequenceNumber=@dtw_rurlescseq(V_WOSEQN)&amp;documentType=RTG" onclick="$(commentWinVar)">$(commentExistImage)</a></td>
                      %else
                          <td>&nbsp;</td>
                      %endif
                      <td class="colalph" onclick="showSel('selData$(ROW_NUM)');">$(V_WOITEM)</td>
                      <td class="colcode" onclick="showSel('selData$(ROW_NUM)');">$(V_WOCPNS)</td>
                      <td class="colnmbr" onclick="showSel('selData$(ROW_NUM)');">$(V_WOSCHS)</td>
                      <td class="colalph" onclick="showSel('selData$(ROW_NUM)');">$(V_WOMORD)</td>
                      <td class="colnmbr" onclick="showSel('selData$(ROW_NUM)');">$(V_WOSEQN)</td>
                      <td class="colnmbr" onclick="showSel('selData$(ROW_NUM)');">$(F_WOCSDT)</td>
                      <td class="colnmbr" onclick="showSel('selData$(ROW_NUM)');">$(F_WOCDDT)</td>
                      <td class="colnmbr" onclick="showSel('selData$(ROW_NUM)');">$(F_WOQTYR)</td>
                      <td class="colnmbr">$(F_WOHRSR)</td>
                      %if (V_WORPTL != "N")
                          <td align="center"><input id="selRec$(ROW_NUM)" name="selRec$(ROW_NUM)" class="bigcheck" type="checkbox" $(orderChecked) onClick="selUpdate('$(V_WOPLT)','$(V_WOMORD)','$(V_WOSEQN)',$(ROW_NUM));"/></td>
                      %endif
                  </tr>
                  <tr>
                      <td>
                          @dtw_assign(moreInfo, "")
                          @Build_More_Info("Item Number", V_WOITEM, "", moreInfo)
                          @Build_More_Info("Description", V_WOIMDS, "", moreInfo)
                          @Build_More_Info("Shortage", V_WOCPNS, "", moreInfo)
                          @Build_More_Info("Order Number", V_WOMORD, "", moreInfo)
                          @Build_More_Info("Sequence", V_WOSEQN, "", moreInfo)
                          @Build_More_Info("Start Date", F_WOCSDT, "", moreInfo)
                          @Build_More_Info("Due Date", F_WOCDDT, "", moreInfo)
                          @Build_More_Info("Quantity", F_WOQTYR, "", moreInfo)
                          @Build_More_Info("Hours", F_WOHRSR, "", moreInfo)
                          %if (V_WOORD# != "0")
                              @Build_More_Info("Sales Order", V_WOORD#, "", moreInfo)
                          %endif
                          %if (V_WOSLTO != "0")
                              @Format_Code($(V_WOSLTO), F_WOSLTO)
                              @RtvFldDesc("CMCUST=$(V_WOSLTO) ", "HDCUST", "CMCNA1", V_CMCNA1)
                              @Build_More_Info("Customer", V_CMCNA1, F_WOSLTO, moreInfo)
                          %endif
                          %if (V_WOMGTP != ".0")
                              @Build_More_Info("Priority", V_WOMGTP, "", moreInfo)
                          %endif
                          %if (V_WONXWC != "")
                              @Build_More_Info("Next W/C", V_WONXWC, "", moreInfo)
                          %endif
                          %if (V_WOLSWC != "")
                              @Build_More_Info("Last W/C", V_WOLSWC, "", moreInfo)
                          %endif
                          %if (V_WOEMGR != "0")
                              @Build_More_Info("Employee/Group", V_WOEMGR, "", moreInfo)
                          %endif
                          <div id="selData$(ROW_NUM)" class="moreInfoPos">
                              <table $(quickSearchTable)>
                                  <tr>
                                      <td>&nbsp;</td>
                                      <td>&nbsp;</td>
                                      <td rowspan="20">
                                          <ul class="toolbarTS">
                                              <li class="optionTS2"><a href="javascript:void+0" onClick="hideSel('selData$(ROW_NUM)')">&nbsp;<br>Exit</a></li>
                                              %if (sec_04 == "Y" && V_WOISSC != "N")
                                                  <li class="optionTS2"><a onClick="saveCurrURL();"  href="$(homeURL)$(cGIPath)ComponentMaterialRequisition.d2w/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(V_WOPLT)&amp;mfgOrder=@dtw_rurlescseq(V_WOMORD)&amp;parentItem=@dtw_rurlescseq(V_WOITEM)">Component<br>Material<br>Requisition</a></li>
                                              %endif
                                              %if (sec_05 == "Y" && V_WOORDR != "N")
                                                  <li class="optionTS2"><a onClick="saveCurrURL();"  href="$(homeURL)$(cGIPath)MfgOrderReceipt.d2w/REPORT$(d2wVarBase)&amp;turnaroundNumber=@dtw_rurlescseq(V_WOORTN)">Finished<br>Goods<br>Receipt</a></li>
                                              %endif
                                              %if (sec_06 == "Y")
                                                  <li class="optionTS2"><a onClick="saveCurrURL();"  href="$(homeURL)$(cGIPath)MfgOrderFinalTag.d2w/REPORT$(d2wVarBase)&amp;turnaroundNumber=@dtw_rurlescseq(V_WOFTTN)">&nbsp;<br>Final Tag</a></li>
                                              %endif
                                          </ul>
                                      </td>
                                      <td rowspan="20">
                                          <ul class="toolbarTS">
                                              %if (sec_01 == "Y")
                                                  <li class="optionTS2"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq($(V_WOPLT))&amp;mfgOrder=@dtw_rurlescseq($(V_WOMORD))&amp;sequenceNumber=@dtw_rurlescseq(V_WOSEQN)&amp;operComp=Y&amp;START_ROW_NUM=@dtw_rurlescseq(START_ROW_NUM)">&nbsp;<br>Operation Complete</a></li>
                                              %endif
                                              %if (sec_10 == "Y")
                                                  <li class="optionTS2"><a href="$(homeURL)$(cGIPath)SelectMfgOrder.d2w/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq($(V_WOPLT))&amp;mfgOrder=@dtw_rurlescseq($(V_WOMORD))" onclick="$(inquiryWinVar)">&nbsp;<br>Order Inquiry</a></li>
                                              %endif
                                              %if (sec_11 == "Y")
                                                  <li class="optionTS2"><a href="$(homeURL)$(cGIPath)ProductStructureIndentedStockStatusInquiry.d2w/DISPLAY$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq($(V_WOPLT))&amp;itemNumber=@dtw_rurlescseq($(V_WOITEM))&amp;quantityRequired=@dtw_rurlescseq($(V_WOQTYR))" onclick="$(inquiryWinVar)">&nbsp;<br>Stock Status</a></li>
                                              %endif
                                              %if (V_WONTCD != "")
                                                  <li class="optionTS2"><a href="$(homeURL)$(cGIPath)LaborInProcessNotesInquiry.d2w/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(V_WOPLT)&amp;mfgOrder=@dtw_rurlescseq(V_WOMORD)&amp;sequenceNumber=@dtw_rurlescseq(V_WOSEQN)&amp;documentType=RTG" onclick="$(commentWinVar)">&nbsp;<br>Routing Notes</a></li>
                                              %endif
                                              %if (sec_13 == "Y")
                                                  @dtw_assign(attachPlantKey, V_WOPLT)
                                                  %while(@dtw_rlength(attachPlantKey) != "3") {@dtw_insert("0", attachPlantKey, attachPlantKey) %}
                                                  @dtw_assign(attachItemPlantKey, "$(attachPlantKey)$(V_WOITEM)")
                                                  @RtvFldDesc("ATFOLD<>' ' and (ATFOLD='ITEM' and ATVKEY='$(V_WOITEM)' or ATFOLD='ITEMPLANT' and ATVKEY='$(attachItemPlantKey)') and (ATUSER='$(userProfile)' or ATPRIV=' ' or '$(admin)' ='Y')", "SYD2WA", "char(coalesce(count(*),0))", attachments)
                                                  %if (attachments > "0")
                                                      <li class="optionTS2"><a href="$(homeURL)$(phpPath)ItemPlantAttachment.php$(altVarBaseT)&amp;plantNumber=@dtw_rurlescseq($(V_WOPLT))&amp;itemNumber=@dtw_rurlescseq($(V_WOITEM))" onclick="$(inquiryWinVar)">&nbsp;<br>Attachments</a></li>
                                                  %endif
                                              %endif
                                          </ul>
                                      </td>
                                  </tr>
                                  $(moreInfo)
                              </table>
                          </div>
                      </td>
                  </tr>
	       %}
          </table>
      </form>

      %INCLUDE "KeyboardTS.icl"

      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSI214_W.PGM %}
%}

%HTML(Change_WC) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(deptNumber)
  @dtw_mUPPERCASE(workCenter)

  @dtw_assign(edtVar, "")
  @Concat_Field("@@subr", "SrChgWC")
  @Concat_Field("@@dept", deptNumber)
  @Concat_Field("@@wc@@", workCenter)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, errFound, edtVar, errVar)
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
%}

%HTML(Shift_OnOff) {
  %INCLUDE "setLibraryList.icl"

  @dtw_assign(edtVar, "")
  @Concat_Field("@@subr", "SrShift")
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, errFound, edtVar, errVar)

  %if (errFound == "")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;START_ROW_NUM=@dtw_rurlescseq(START_ROW_NUM)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %elif (errFound == "C")
      @DecatErr_Field("@@cmsg", "confMessage")
      @dtw_assign(confMessage, fieldValue)
      @dtw_assign(errFound, "")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;START_ROW_NUM=@dtw_rurlescseq(START_ROW_NUM)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;START_ROW_NUM=@dtw_rurlescseq(START_ROW_NUM)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}

%HTML(BUILD) {
  %INCLUDE "setLibraryList.icl"

  @dtw_assign(edtVar, "")
  @Concat_Field("@@subr", "SrFillWk")
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, errFound, edtVar, errVar)
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;START_ROW_NUM=$(START_ROW_NUM)&amp;confMessage=@dtw_rurlescseq(confMessage)">
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "WOSCHS,WOCSDT,WOMORD,WOSEQN")
      @DTW_ASSIGN(orderByDisplay, "Schedule Sequence, Current Start Date")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)

  %if (operComp == "Y")
      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Update HDMLPM Set LPOPRC='Y', LPTSUS='$(userProfile)', LPTSWS='BROWSER', LPTSTP=current_timestamp ", stmtSQL)
      @dtw_concat(stmtSQL, " Where LPPLT=$(plantNumber) and LPORD='$(mfgOrder)' and LPSEQN=$(sequenceNumber) @@endsql", stmtSQL)
      @SQL_Update(stmtSQL, status)

      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Delete From SIDOPW ", stmtSQL)
      @dtw_concat(stmtSQL, " Where WOPLT=$(plantNumber) and WOMORD='$(mfgOrder)' and WOSEQN=$(sequenceNumber) and WOXHND='$(profileHandle)' @@endsql", stmtSQL)
      @SQL_Update(stmtSQL, status)
  %endif

  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "ITEM")
      %if (orderBy == "WOITEM,WOCSDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderBy, "WOITEM DESC,WOCSDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Item Number (descending), Start Date, Order")
      %else
          @DTW_ASSIGN(orderBy, "WOITEM,WOCSDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Item Number, Start Date, Order")
      %endif
  %elif (sequence == "CPNS")
      %if (orderBy == "WOCPNS,WOCSDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderBy, "WOCPNS DESC,WOCSDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Shortage (descending), Start Date, Order")
      %else
          @DTW_ASSIGN(orderBy, "WOCPNS,WOCSDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Shortage, Start Date, Order")
      %endif
  %elif (sequence == "SCHS")
      %if (orderBy == "WOSCHS,WOCSDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderBy, "WOSCHS DESC,WOCSDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Schedule (descending), Start Date, Order")
      %else
          @DTW_ASSIGN(orderBy, "WOSCHS,WOCSDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Schedule, Start Date, Order")
      %endif
  %elif (sequence == "ORD")
      %if (orderBy == "WOMORD,WOSEQN")
          @DTW_ASSIGN(orderBy, "WOMORD DESC,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Order (descending), Sequence")
      %else
          @DTW_ASSIGN(orderBy, "WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Order, Sequence")
      %endif
  %elif (sequence == "SEQN")
      %if (orderBy == "WOSEQN,WOMORD")
          @DTW_ASSIGN(orderBy, "WOSEQN DESC,WOMORD")
          @DTW_ASSIGN(orderByDisplay, "Sequence (descending), Order")
      %else
          @DTW_ASSIGN(orderBy, "WOSEQN,WOMORD")
          @DTW_ASSIGN(orderByDisplay, "Sequence, Order")
      %endif
  %elif (sequence == "CSDT")
      %if (orderBy == "WOCSDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderBy, "WOCSDT DESC,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Start Date (descending), Order, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "WOCSDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Start Date, Order, Sequence")
      %endif
  %elif (sequence == "CDDT")
      %if (orderBy == "WOCDDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderBy, "WOCDDT DESC,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Due Date (descending), Order, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "WOCDDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Due Date, Order, Sequence")
      %endif
  %elif (sequence == "QTYR")
      %if (orderBy == "WOQTYR,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderBy, "WOQTYR DESC,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Quantity (descending), Order, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "WOQTYR,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Quantity, Order, Sequence")
      %endif
  %elif (sequence == "HRSR")
      %if (orderBy == "WOHRSR,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderBy, "WOHRSR DESC,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Hours (descending), Order, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "WOHRSR,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Hours, Order, Sequence")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("WOITEM", "Item Number", $(srchItem), "U", operItem, "A")
  @Build_WildCard ("WOMORD", "Order Number", $(srchOrder), "U", operOrder, "A")
		
  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}

