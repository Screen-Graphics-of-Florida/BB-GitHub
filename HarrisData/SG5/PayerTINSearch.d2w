%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Payer TIN Search"
  d2wName                 = "PayerTINSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectPayerTIN(payerTIN, payerTINName){
                  window.opener.document.$(docName).$(fldName).value = payerTIN;
                  window.opener.document.$(docName).$(fldDesc).value = payerTINName;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select APPTIN.*,  ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(TNPNAM) as TNPNAMU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(TNPADR) as TNPADRU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(TNCITY) as TNCITYU ", stmtSQL)
                      @dtw_concat(fileSQL, " APPTIN ", fileSQL)
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, " TNTIN#='$(payerTIN)'", selectSQL)
                      %elif (wildCardSearch!="")
                          @dtw_concat(selectSQL, " TNTIN#<>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Process_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Process_Search (IN  CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Name</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchName" size="40" maxlength="40">
                          <input type="hidden" name="operName" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchName.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("TNPNAMU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Name" title="Sequence By Name"> Name</a></th>
                  @OrderBy_Sort("TNPADRU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Address" title="Sequence By Address"> Address</a></th>
                  @OrderBy_Sort("TNCITYU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=City" title="Sequence By City, Name"> City</a></th>
                  @OrderBy_Sort("TNST", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=State" title="Sequence By State, Name"> State</a></th>
                  @OrderBy_Sort("TNZIP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Zip" title="Sequence By Zip, Name"> Zip</a></th>
                  @OrderBy_Sort("TNPHON", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Phone" title="Sequence By Phone"> Phone Number</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %else
          <table $(contentTable)>
      %endif		

              %ROW{
                  @EditPhoneNumber(V_TNPHON)
                  @Format_Quote(V_TNTIN#, F_TNTIN#)
                  @Format_Quote(V_TNPNAM, F_TNPNAM)

                  %if (moreInfo != "Y")	
                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          <td class="colalph"><a href="javascript:selectPayerTIN('$(F_TNTIN#)','$(F_TNPNAM)')" title="Select Payer TIN">$(V_TNPNAM)</a></td>
                          <td class="colalph"> $(V_TNPADR)</td>
                          <td class="colalph"> $(V_TNCITY)</td>
                          <td class="colcode"> $(V_TNST)</td>
                          <td class="colnmbr"> $(V_TNZIP)</td>
                          <td class="colnmbr"> $(V_TNPHON)</td>
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;payerTIN=@dtw_rurlescseq(V_TNTIN#)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                      </tr>

                  %else

                      <tr><td><a href="javascript:selectPayerTIN('$(F_TNTIN#)','$(F_TNPNAM)')" title="Select Payer TIN">$(selectImageLrg)</a>
                      </td></tr>

                      <tr><td class="dsphdr">Payer TIN</td>
                          <td class="dspalph">$(V_TNTIN#)</td>
                      </tr>

                      <tr><td class="dsphdr">Payer Name 1</td>
                          <td class="dspalph">$(V_TNPNAM)</td></tr>

                      <tr><td class="dsphdr">Payer Name 2</td>
                          <td class="dspalph">$(V_TNPNA2)</td></tr>

                      <tr><td class="dsphdr">Address</td>
                          <td class="dspalph">$(V_TNPADR)</td></tr>	

                      <tr><td class="dsphdr">City</td>
                          <td class="dspalph">$(V_TNCITY)</td></tr>

                      @RtvFldDesc("STID='$(V_TNST)'", "HDSTID", "STDESC", fieldDesc)
                      <tr><td class="dsphdr">State</td>
                          <td class="dspalph">$(fieldDesc)</td></tr>

                      <tr><td class="dsphdr">Zip</td>
                          <td class="dspalph">$(V_TNZIP)</td></tr>

                      <tr><td class="dsphdr">Phone Number</td>
                          <td class="dspnmbr">$(V_TNPHON)-$(V_TNPHEX)</td></tr>

                      @RtvFldDesc("CNCTCD='$(V_CMCTRY)'", "HDCTRY", "CNCDES", fieldDesc)
                      <tr><td class="dsphdr">Country</td>
                          <td class="dspalph">$(fieldDesc)</td></tr>

                      <tr><td class="dsphdr">Contact Name</td>
                          <td class="dspalph">$(V_TNCTNM)</td></tr>

                      <tr><td class="dsphdr">IRS Name Control</td>
                          <td class="dspalph">$(V_TNIRSN)</td></tr>

                      <tr><td class="dsphdr">Combined Fed/State Filer</td>
                          <td class="dspalph">$(V_TNCFSF)</td></tr>

                      <tr><td class="dsphdr">Foreign Entity</td>
                          <td class="dspalph">$(V_TNFORC)</td></tr>

                      <tr><td class="dsphdr">Last Filing Indicator</td>
                          <td class="dspalph">$(V_TNLFIN)</td></tr>

                      <tr><td class="dsphdr">Last Year 1099 Filed</td>
                          <td class="dspalph">$(V_TNLYRF)</td></tr>

                      <tr><td class="dsphdr">Create Summary 1099</td>
                          <td class="dspalph">$(V_TNCSUM)</td></tr>

                      <tr><td class="dsphdr">Transfer Agent</td>
                          <td class="dspalph">$(V_TNTRNA)</td></tr>

                      <tr><td class="dsphdr">Date Extension Filed</td>
                          <td class="dspalph">$(V_TNEXTD)</td></tr>

                      <tr><td class="dsphdr">Extension Status</td>
                          <td class="dspalph">$(V_TNEXTS)</td></tr>

                      <tr><td class="dsphdr">Second Payer Name</td>
                          <td class="dspalph">$(V_TNSPNM)</td></tr>

                      <tr><td class="dsphdr">Second Payer Address</td>
                          <td class="dspalph">$(V_TNSPAD)</td></tr>

                      <tr><td class="dsphdr">Second Payer City</td>
                          <td class="dspalph">$(V_TNSPCT)</td></tr>

                      <tr><td class="dsphdr">Second Payer State</td>
                          <td class="dspalph">$(V_TNSPST)</td></tr>

                      <tr><td class="dsphdr">Second Payer Zip Code</td>
                          <td class="dspalph">$(V_TNSPZP)</td></tr>

                      <tr><td class="dsphdr">Second Payer Phone Number</td>
                          <td class="dspalph">$(V_TNSPHN)-$(V_TNSPEX)</td></tr>

                      <tr><td class="dsphdr">Second Payer Contact Name</td>
                          <td class="dspalph">$(V_TNSCTN)</td></tr>
                  %endif
              %}
          </table>
          %if (moreInfo != "Y")	
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
          %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "TNPNAMU")
      @DTW_ASSIGN(orderByDisplay, "Name")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(orderBy, "TNTIN#")
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Name")
      %if (orderBy == "TNPNAMU")
          @DTW_ASSIGN(orderBy, "TNPNAMU DESC")
          @DTW_ASSIGN(orderByDisplay, "Name (descending)")
      %else
          @DTW_ASSIGN(orderBy, "TNPNAMU")
          @DTW_ASSIGN(orderByDisplay, "Name")
      %endif
  %elif (sequence == "Address")
      %if (orderBy == "TNPADRU,TNPNAMU")
          @DTW_ASSIGN(orderBy, "TNPADRU DESC,TNPNAMU")
          @DTW_ASSIGN(orderByDisplay, "Address (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "TNPADRU,TNPNAMU")
          @DTW_ASSIGN(orderByDisplay, "Address, Name")
      %endif
  %elif (sequence == "City")
      %if (orderBy == "TNCITYU,TNPNAMU")
          @DTW_ASSIGN(orderBy, "TNCITYU DESC,TNPNAMU")
          @DTW_ASSIGN(orderByDisplay, "City (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "TNCITYU,TNPNAMU")
          @DTW_ASSIGN(orderByDisplay, "City, Name")
      %endif
  %elif (sequence == "State")
      %if (orderBy == "TNST,TNPNAMU")
          @DTW_ASSIGN(orderBy, "TNST DESC,TNPNAMU")
          @DTW_ASSIGN(orderByDisplay, "State (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "TNST,TNPNAMU")
          @DTW_ASSIGN(orderByDisplay, "State, Name")
      %endif
  %elif (sequence == "Zip")
      %if (orderBy == "TNZIP,TNPNAMU")
          @DTW_ASSIGN(orderBy, "TNZIP DESC,TNPNAMU")
          @DTW_ASSIGN(orderByDisplay, "Zip (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "TNZIP,TNPNAMU")
          @DTW_ASSIGN(orderByDisplay, "Zip, Name")
      %endif
  %elif (sequence == "Phone")
      @DTW_ASSIGN(orderBy, "TNPHON")
      %if (orderBy == "TNPHON")
          @DTW_ASSIGN(orderBy, "TNPHON DESC")
          @DTW_ASSIGN(orderByDisplay, "Phone Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "TNPHON")
          @DTW_ASSIGN(orderByDisplay, "Phone Number")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchPhone, 11, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "payerTINSearch")
                  <td>
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Payer Name</td>
                              @dtw_assign(operNbr, "operName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchName" size="40" maxlength="40"></td>
                          </tr>

                          <tr><td class="dsphdr">Address</td>
                              @dtw_assign(operNbr, "operAddr")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchAddress" size="26" maxlength="26"></td>	
                          </tr>

                          <tr><td class="dsphdr">State</td>
                              @dtw_assign(operNbr, "operState")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchState" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Zip</td>
                              @dtw_assign(operNbr, "operZip")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchZip" size="14" maxlength="14"></td>
                          </tr>

                          <tr><td class="dsphdr">Phone Number</td>
                              <td>&nbsp;</td>
                              <td class="inputnmbr"> <input type="text" name="srchPhone" size="11" maxlength="11"></td>
                          </tr>

                          <tr><td class="dsphdr">Country</td>
                              @dtw_assign(operNbr, "operCountry")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCountry" size="3" maxlength="3"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchName.focus();
                          </script>
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("upper(TNPNAM)", "Payer Name", $(srchName), "U", operName, "A")

  @dtw_assign(srchAddress,@dtw_rstrip(srchAddress))
  %if (srchAddress != "")
      @Build_WildCard ("TNPADRU", "Address", $(srchAddress), "U", "LIKE", "V")
      @dtw_mUPPERCASE(srchAddress)
      @dtw_replace(srchAddress, "?", "_", "1", "a", srchAddress)
      @dtw_replace(srchAddress, "*", "%", "1", "a", srchAddress)
      @dtw_concat(wildCardTemp, " (trim(upper(TNPADR)) LIKE '$(srchAddress)'", wildCardTemp)
      @dtw_concat(wildCardTemp, " OR   trim(upper(TNCITY)) LIKE '$(srchAddress)')", wildCardTemp)
  %endif
		
  @Build_WildCard ("TNST", "State", $(srchState), "U", operState, "A")
  @Build_WildCard ("TNZIP", "Zip", $(srchZip), "", operZip, "A")
  @Build_WildCard ("TNPHON", "Phone Number", $(srchPhone), "", "", "P")
  @Build_WildCard ("TNCTRY", "Country", $(srchCountry), "U", operCountry, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
