%}

%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Order Point Report"
  d2wName                 = "OrderPointReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  forPlant                = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromPlantNumber, 3, 0) &&
                      editNum(document.Chg.toPlantNumber, 3, 0) &&
                      editNum(document.Chg.fromBuyerAnalystCode, 7, 0) &&
                      editNum(document.Chg.toBuyerAnalystCode, 7, 0) &&
                      editFromToAll(document.Chg.fromPlantNumber, document.Chg.toPlantNumber, document.Chg.allPlantNumber, 3) &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromPartType, document.Chg.toPartType, document.Chg.allPartType, "A") &&
                      editFromToAll(document.Chg.fromInventoryType, document.Chg.toInventoryType, document.Chg.allInventoryType, "A") &&
                      editFromToAll(document.Chg.fromOrderPolicyCode, document.Chg.toOrderPolicyCode, document.Chg.allOrderPolicyCode, "A") &&
                      editFromToAll(document.Chg.fromBuyerAnalystCode, document.Chg.toBuyerAnalystCode, document.Chg.allBuyerAnalystCode, 7)
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ORDERPOINTREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromPlantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@fplt", "fromPlantNumber")        @dtw_assign(Err_TRPLT1,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@rump")  @dtw_assign(V_TRUMP,  fieldValue)
								  @Decat_Field("@@selv")  @dtw_assign(V_OUTFMT, fieldValue)

                                  @Decat_Field("@@fplt")  @dtw_assign(V_TRPLT1,  fieldValue)
                                  @Decat_Field("@@tplt")  @dtw_assign(V_TRPLT2,  fieldValue)
                                  @Decat_Field("@@aplt")  @dtw_assign(V_PLTALL,  fieldValue)

                                  @Decat_Field("@@fitm")  @dtw_assign(V_TRITM1, fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_TRITM2, fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_ITMALL, fieldValue)

                                  @Decat_Field("@@fpyt")  @dtw_assign(V_TRPYT1,  fieldValue)
                                  @Decat_Field("@@tpyt")  @dtw_assign(V_TRPYT2,  fieldValue)
                                  @Decat_Field("@@apyt")  @dtw_assign(V_PTYALL,  fieldValue)

                                  @Decat_Field("@@fitc")  @dtw_assign(V_TRITC1,  fieldValue)
                                  @Decat_Field("@@titc")  @dtw_assign(V_TRITC2,  fieldValue)
                                  @Decat_Field("@@aitc")  @dtw_assign(V_ITCALL,  fieldValue)

                                  @Decat_Field("@@fopc")  @dtw_assign(V_TROPC1,  fieldValue)
                                  @Decat_Field("@@topc")  @dtw_assign(V_TROPC2,  fieldValue)
                                  @Decat_Field("@@aopc")  @dtw_assign(V_OPCALL,  fieldValue)

                                  @Decat_Field("@@fbuy")  @dtw_assign(V_TRBUY1,  fieldValue)
                                  @Decat_Field("@@tbuy")  @dtw_assign(V_TRBUY2,  fieldValue)
                                  @Decat_Field("@@abuy")  @dtw_assign(V_BUYALL,  fieldValue)

                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_TRUMP == "02")
                                      @dtw_assign(purchasing, "")
                                      @dtw_assign(stocking, "CHECKED")
                                  %else
                                      @dtw_assign(purchasing, "CHECKED")
                                      @dtw_assign(stocking, "")
                                  %endif
								  %if (V_OUTFMT == "02")
                                      @dtw_assign(seqReport, "")
                                      @dtw_assign(seqCSV, "CHECKED")
                                  %else
                                      @dtw_assign(seqReport, "CHECKED")
                                      @dtw_assign(seqCSV, "")
                                  %endif
                                  %if (V_PLTALL == "ALL")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPlantNumber, "")
                                  %endif
                                  %if (V_ITMALL == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_PTYALL == "ALL")
                                      @dtw_assign(checkedallPartType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPartType, "")
                                  %endif
                                  %if (V_ITCALL == "ALL")
                                      @dtw_assign(checkedallInventoryType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallInventoryType, "")
                                  %endif
                                  %if (V_OPCALL == "ALL")
                                      @dtw_assign(checkedallOrderPolicyCode, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallOrderPolicyCode, "")
                                  %endif
                                  %if (V_BUYALL == "ALL")
                                      @dtw_assign(checkedallBuyerAnalystCode, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallBuyerAnalystCode, "")
                                  %endif

                              %else
                                  @dtw_assign(purchasing, "CHECKED")
                                  @dtw_assign(stocking, "")
								  @dtw_assign(seqReport, "CHECKED")
                                  @dtw_assign(seqCSV, "")
                                  @RtvDftPlant(plantNumber, plantName)
                                  %if (plantNumber == "0")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(V_TRPLT1, plantNumber)
                                      @dtw_assign(V_TRPLT2, plantNumber)
                                      @dtw_assign(checkedallPlantNumber, "")
                                      @dtw_assign(focusField, "fromItemNumber")
                                  %endif
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallPartType, "CHECKED")
                                  @dtw_assign(checkedallInventoryType, "CHECKED")
                                  @dtw_assign(checkedallOrderPolicyCode, "CHECKED")
                                  @dtw_assign(checkedallBuyerAnalystCode, "CHECKED")
                              %endif

                            <tr><td class="dsphdr"><span $(textOvr)>Report Unit Of Measure</span></td>
                              <td class="inputnmbr"><input name="reportUnitOfMeasure" type="radio" VALUE='01' $(purchasing)>Purchasing</td>
							</tr>  
							<tr><td>&nbsp;</td>
                              <td class="inputnmbr"><input name="reportUnitOfMeasure" type="radio" VALUE='02' $(stocking)>Stocking</td>
                            </tr>
							
							<tr><td>&nbsp;</td></tr>
							<tr><td class="dsphdr"><span $(textOvr)>Output Format</span></td>
                                <td class="inputnmbr"><input name="outFormat" type="radio" VALUE='01' $(seqReport)>Report</td>
                            </tr>
							
                            <tr><td>&nbsp;</td>  							
                                <td class="inputnmbr"><input name="outFormat" type="radio" VALUE='02' $(seqCSV)>CSV File</td>
                                <td>&nbsp;</td>
                            </tr>
							<tr><td>&nbsp;</td></tr>

                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_TRPLT1)
                              <tr><td  class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                  <td class="inputnmbr"><input name="fromPlantNumber" value="$(V_TRPLT1)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromPlantNumber&amp;fldDesc=fplantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fplantName"  type="hidden"></td>
                                  <td class="inputnmbr"><input name="toPlantNumber" value="$(V_TRPLT2)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toPlantNumber&amp;fldDesc=tplantName" onclick="$(searchWinVar)">  $(searchImage) </a><input name="tplantName"  type="hidden"></td>
                                  <td class="inputalph"><input name="allPlantNumber" value='ALL' $(checkedallPlantNumber) type="checkbox" onClick="if (this.checked) this.form.fromPlantNumber.value='', this.form.toPlantNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_TRPLT1)

                              <tr><td  class="dsphdr">Item Number</td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_TRITM1)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_TRITM2)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                              </tr>

                              <tr><td  class="dsphdr"><span $(textOvr)>Part Type</span></td>
                                  <td class="inputalph"><input name="fromPartType" value="$(V_TRPYT1)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="toPartType" value="$(V_TRPYT2)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="allPartType" value='ALL' $(checkedallPartType) type="checkbox" onClick="if (this.checked) this.form.fromPartType.value='', this.form.toPartType.value='';"></td>
                              </tr>

                              <tr><td  class="dsphdr"><span $(textOvr)>Inventory Type</span></td>
                                  <td class="inputalph"><input name="fromInventoryType" value="$(V_TRITC1)" type="text" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)invtypesearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromInventoryType&amp;fldDesc=finventoryTypeDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="finventoryTypeDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="toInventoryType" value="$(V_TRITC2)" type="text" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)invtypesearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toInventoryType&amp;fldDesc=tinventoryTypeDesc" onclick="$(searchWinVar)">$(searchImage) </a><input name="tinventoryTypeDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="allInventoryType" value='ALL' $(checkedallInventoryType) type="checkbox" onClick="if (this.checked) this.form.fromInventoryType.value='', this.form.toInventoryType.value='';"></td>
                              </tr>

                              <tr><td  class="dsphdr">Order Policy Code</td>
                                  <td class="inputalph"><input name="fromOrderPolicyCode" value="$(V_TROPC1)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="toOrderPolicyCode" value="$(V_TROPC2)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="allOrderPolicyCode" value='ALL' $(checkedallOrderPolicyCode) type="checkbox" onClick="if (this.checked) this.form.fromOrderPolicyCode.value='', this.form.toOrderPolicyCode.value='';"></td>
                              </tr>

                              <tr><td  class="dsphdr">Buyer/Analyst Code</td>
                                  <td class="inputnmbr"><input name="fromBuyerAnalystCode" value="$(V_TRBUY1)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)BuyerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromBuyerAnalystCode&amp;fldDesc=analystName&amp;buyerAnalyst=Analyst" onclick="$(searchWinVar)"> $(searchImage) </a><input name="analystName" type="hidden"><input name="Analyst" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toBuyerAnalystCode" value="$(V_TRBUY2)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)BuyerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toBuyerAnalystCode&amp;fldDesc=analystName&amp;buyerAnalyst=Analyst" onclick="$(searchWinVar)"> $(searchImage) </a><input name="analystName" type="hidden"><input name="Analyst" type="hidden"></td>
                                  <td class="inputalph"><input name="allBuyerAnalystCode" value='ALL' $(checkedallBuyerAnalystCode) type="checkbox" onClick="if (this.checked) this.form.fromBuyerAnalystCode.value='', this.form.toBuyerAnalystCode.value='';"></td>
                              </tr>
                          </table>

                          %if (outFormat == "02")
                            @dtw_assign(envProgram, "HSI311CSV")
						  %else
                            @dtw_assign(envProgram, "HSI311")
						  %endif 	
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSI910_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allPlantNumber)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(fromPartType)
  @dtw_mUPPERCASE(toPartType)
  @dtw_mUPPERCASE(allPartType)
  @dtw_mUPPERCASE(fromInventoryType)
  @dtw_mUPPERCASE(toInventoryType)
  @dtw_mUPPERCASE(allInventoryType)
  @dtw_mUPPERCASE(fromOrderPolicyCode)
  @dtw_mUPPERCASE(toOrderPolicyCode)
  @dtw_mUPPERCASE(allOrderPolicyCode)
  @dtw_mUPPERCASE(allBuyerAnalystCode)

  @dtw_assign(fromPlantNumber,@dtw_rstrip(fromPlantNumber))
  @dtw_assign(toPlantNumber,@dtw_rstrip(toPlantNumber))
  @dtw_assign(fromBuyerAnalystCode,@dtw_rstrip(fromBuyerAnalystCode))
  @dtw_assign(toBuyerAnalystCode,@dtw_rstrip(toBuyerAnalystCode))

  %if (allPlantNumber != "ALL")
      @dtw_assign(allPlantNumber, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allPartType != "ALL")
      @dtw_assign(allPartType, "")
  %endif
  %if (allInventoryType != "ALL")
      @dtw_assign(allInventoryType, "")
  %endif
  %if (allOrderPolicyCode != "ALL")
      @dtw_assign(allOrderPolicyCode, "")
  %endif
  %if (allBuyerAnalystCode != "ALL")
      @dtw_assign(allBuyerAnalystCode, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@rump", reportUnitOfMeasure)
  @Concat_Field("@@selv", outFormat)
  @Concat_Field("@@fplt", fromPlantNumber)
  @Concat_Field("@@tplt", toPlantNumber)
  @Concat_Field("@@aplt", allPlantNumber)
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@fpyt", fromPartType)
  @Concat_Field("@@tpyt", toPartType)
  @Concat_Field("@@apyt", allPartType)
  @Concat_Field("@@fitc", fromInventoryType)
  @Concat_Field("@@titc", toInventoryType)
  @Concat_Field("@@aitc", allInventoryType)
  @Concat_Field("@@fopc", fromOrderPolicyCode)
  @Concat_Field("@@topc", toOrderPolicyCode)
  @Concat_Field("@@aopc", allOrderPolicyCode)
  @Concat_Field("@@fbuy", fromBuyerAnalystCode)
  @Concat_Field("@@tbuy", toBuyerAnalystCode)
  @Concat_Field("@@abuy", allBuyerAnalystCode)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}