%INCLUDE "$(baseVar)"
%INCLUDE "BrowserType.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Assign Purchase Order"
  d2wName                 = "KanbanAssignPO.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(fromPlant)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;plantName=@dtw_rurlescseq(plantName)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;itemDescription=@dtw_rurlescseq(itemDescription)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;lineNumber=@dtw_rurlescseq(lineNumber)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@plantNumber", "@dtw_rurlescseq(plantNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@itemNumber", "@dtw_rurlescseq(itemNumber)", "1", "a", workURL)
%}

%MACRO_FUNCTION Enter_Quantity () {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "headcmt.icl"
          <script TYPE="text/javascript">
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "NoFormValidate.icl"
                  function validate(chgForm) {
                      if (editNum(document.Chg.purchaseOrder, 8, 0) &&
                          editNum(document.Chg.orderLineNumber, 3, 0))
                          return true;
                  }
          </script>
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          @dtw_assign(displayCloseIcon, "Y")
          %INCLUDE "$(cmtBanner)"
          <!-- End Of Banner Code -->
          <table $(contentTable)>
              <tr valign="top">
                  <td>
                      @dtw_assign(medIcon, "Y")
                      %INCLUDE "PageTitle.icl"

                      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
                      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)

                      <table $(contentTable)>
                          @Format_Header("Plant", $(plantName), $(plantNumber))
                          @Format_Header("Item", $(itemDescription), $(itemNumber))
                      </table>
                      $(hrTagAttr)
                      %INCLUDE "ErrorDisplay.icl"

                      <form class="formClass" METHOD=POST NAME="Chg"  ACTION="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)">
                          <table $(contentTable)>

                              %if (errFound != "")
                                  @dtw_assign(focusField, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @DecatErr_Field("@@ord#", "orderNumber")      @dtw_assign(Err_orderNumber, fieldValue)
                                  @DecatErr_Field("@@orl#", "lineNumber")       @dtw_assign(Err_lineNumber, fieldValue)
                                  @Decat_Field("@@ord#")                        @dtw_assign(purchaseOrder, fieldValue)
                                  @Decat_Field("@@orl#")                        @dtw_assign(orderLineNumber, fieldValue)
                                  @dtw_assign(errFound, "")
                              %endif
                              @dtw_assign(focusField, "purchaseOrder")

                              @SetTextOvr(Err_orderNumber)
                              <tr>
                                  <td class="dsphdr">Purchase Order/Line Number</td>
                                  <td class="inputnmbr"><input name="purchaseOrder" type="text" value="$(orderNumber)" size="8" maxlength="8"> / <input name="orderLineNumber" type="text" value="$(lineNumber)" size="3" maxlength="3"></td>
                              </tr>
                              @DspErrMsg(Err_orderNumber)
                          </table>
                	   <table $(contentTable)>
                              <tr>
                                  <td valign="top">
                                      <a href="javascript:check(document.Chg)">$(commentAcceptImage)</a>
                                      <a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)">$(commentResetImage)</a>
                                      %INCLUDE "CloseWindow.icl"
                                  </td>
                              </tr>
                          </table>
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(cmtTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(10)    progCall,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)

{%EXEC {HSIKBM_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Enter_Quantity ()
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"

  @dtw_assign(maintenanceCode, "C")
  @dtw_assign(progCall, "ChgPO")
  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@item", itemNumber)
  @Concat_Field("@@ord#", purchaseOrder)
  @Concat_Field("@@orl#", orderLineNumber)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, progCall, edtVar, errVar)

  %if (errFound == "")
      @dtw_assign(confMessage, "Confirm Change Of Assigned Purchase Order Number")
      @BrowserType(browserCode)
      %if (browserCode == "IE")
          <script TYPE="text/javascript">
              opener.location.href='$(homeURL)$(cGIPath)Kanban.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(fromPlant)&amp;confMessage=@dtw_rurlescseq(confMessage)';
              window.close();
          </script>
      %else
          <meta http-equiv="refresh" content="0; URL=javascript:opener.document.location='$(homeURL)$(cGIPath)Kanban.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(fromPlant)&amp;confMessage=@dtw_rurlescseq(confMessage)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))';self.close();">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}