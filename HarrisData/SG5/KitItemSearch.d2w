%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Kit Item Search"
  d2wName                 = "KitItemSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
  advanceSearch           = "N"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectItem(item, desc){
                  window.opener.document.$(docName).$(fldName).value = item;
                  window.opener.document.$(docName).$(fldDesc).value = desc;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select KTKTIT,KTKTDS,KTKTRL,KTKTPR,KTKTCS,KTORDP,KTINVC, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(KTKTDS) as KTKTDSU ", stmtSQL)
                      @dtw_concat(fileSQL, " HDKIT ", fileSQL)
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, "KTKTIT='$(itemNumber)'", selectSQL)
                      %elif (wildCardSearch!="")
                          @dtw_concat(selectSQL, " KTKTIT<>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @KitItem_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) KitItem_Search (IN  CHAR(64)    profileHandle,
				                    CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"

      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr"> Kit <br> Item</th>
                      <th class="colhdr"> Description</th>
                  </tr>
                  <tr><td class="inputalph">
                          <input type="text" name="srchItem" size="15" maxlength="15">
                          <input type="hidden" name="operItem" value="LIKE">
                      </td>
                      <td class="inputalph">
                          <input type="text" name="srchDesc" size="30" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchItem.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("KTKTIT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=item" title="Sequence By Kit Item"> Kit Item</a></th>
                  @OrderBy_Sort("KTKTDSU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=description" title="Sequence By Description"> Description</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %else
              <table $(contentTable)>
	     %endif		

          %ROW{
              %INCLUDE "SetRowClass.icl"
               @Format_Quote(V_KTKTDS, F_KTKTDS)

              %if (moreInfo != "Y")	
                  <tr class="$(rowClass)">
                      <td class="colalph"> $(V_KTKTIT)</td>
                      <td class="colalph"><a href="javascript:selectItem('$(V_KTKTIT)','$(F_KTKTDS)')" title="Select Kit Item">$(V_KTKTDS)</a></td>
                      <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(V_KTKTIT)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                  </tr>

              %else
                  <tr><td><a href="javascript:selectItem('$(V_KTKTIT)','$(F_KTKTDS)')" title="Select Kit Item">$(selectImageLrg)</a>
                      </td>
                  </tr>

                  <tr><td class="dsphdr">Kit Item</td>
                      <td class="dspalph">$(V_KTKTIT)</td>
                  </tr>
	   		
                  <tr><td class="dsphdr">Description</td>
                      <td class="dspalph">$(V_KTKTDS)</td>
                  </tr>

                  <tr><td class="dsphdr">Relieve By Kit/Component/Options</td>
                      <td class="dspalph">$(V_KTKTRL)</td></tr>
	   		
                  <tr><td class="dsphdr">Price By Kit/Component/Options</td>
                      <td class="dspalph">$(V_KTKTPR)</td></tr>

                  <tr><td class="dsphdr">Cost By Kit/Component/Options</td>
                      <td class="dspalph">$(V_KTKTCS)</td></tr>

                  <tr><td class="dsphdr">Document Print Code</td>
                      <td class="dspalph">$(V_KTINVC)</td></tr>

                  <tr><td class="dsphdr">Orders In Process</td>
                      <td class="dspalph">$(V_KTORDP)</td></tr>

              %endif
          %}
      </table>
      %if (moreInfo != "Y")	
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
      %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "KTKTDSU,KTKTIT")
      @DTW_ASSIGN(orderByDisplay, "Description, Kit Item")
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "item")
      %if (orderBy == "KTKTIT")
          @DTW_ASSIGN(orderBy, "KTKTIT DESC")
          @DTW_ASSIGN(orderByDisplay, "Kit Item (descending)")
      %else
          @DTW_ASSIGN(orderBy, "KTKTIT")
          @DTW_ASSIGN(orderByDisplay, "Kit Number")
      %endif
  %elif (sequence == "description")
      %if (orderBy == "KTKTDSU")
          @DTW_ASSIGN(orderBy, "KTKTDSU DESC")
          @DTW_ASSIGN(orderByDisplay, "Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "KTKTDSU")
          @DTW_ASSIGN(orderByDisplay, "Description")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		

  @Build_WildCard ("KTKTIT", "Kit Item", $(srchItem), "U", operItem, "A")
  @Build_WildCard ("upper(KTKTDS)", "Kit Item Description", $(srchDesc), "U", operDesc, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}