%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Manual Order Allocation Report"
  d2wName                 = "ManualOrderAllocationReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "5"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromWarehouseNumber, 3, 0) &&
                      editNum(document.Chg.toWarehouseNumber, 3, 0) &&
                      editNum(document.Chg.fromOrderNumber, 8, 0) &&
                      editNum(document.Chg.toOrderNumber, 8, 0) &&
                      editdate(document.Chg.fromRequiredDate) &&
                      editdate(document.Chg.toRequiredDate) &&
                      editNum(document.Chg.fromShipToCustomer, 7, 0) &&
                      editNum(document.Chg.toShipToCustomer, 7, 0) &&
                      editFromToAll(document.Chg.fromWarehouseNumber, document.Chg.toWarehouseNumber, document.Chg.allWarehouseNumber, 3) &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromOrderNumber, document.Chg.toOrderNumber, document.Chg.allOrderNumber, 8) &&
                      editFromToAll(document.Chg.fromRequiredDate, document.Chg.toRequiredDate, document.Chg.allRequiredDate, "D") &&
                      editFromToAll(document.Chg.fromShipToCustomer, document.Chg.toShipToCustomer, document.Chg.allShipToCustomer, 7))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "MANUALORDERALLOCATIONREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromWarehouseNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@fwhs", "fromWarehouseNumber")        @dtw_assign(Err_N1FWHS,  fieldValue)
                                  @DecatErr_Field("@@twhs", "toWarehouseNumber")        @dtw_assign(Err_N1TWHS,  fieldValue)
                                  @DecatErr_Field("@@awhs", "allWarehouseNumber")        @dtw_assign(Err_N1AWHS,  fieldValue)
                                  @DecatErr_Field("@@swhs", "sortWarehouseNumber")        @dtw_assign(Err_N1SWHS,  fieldValue)
                                  @DecatErr_Field("@@fitm", "fromItemNumber")        @dtw_assign(Err_N1FITM,  fieldValue)
                                  @DecatErr_Field("@@titm", "toItemNumber")        @dtw_assign(Err_N1TITM,  fieldValue)
                                  @DecatErr_Field("@@aitm", "allItemNumber")        @dtw_assign(Err_N1AITM,  fieldValue)
                                  @DecatErr_Field("@@sitm", "sortItemNumber")        @dtw_assign(Err_N1SITM,  fieldValue)
                                  @DecatErr_Field("@@ford", "fromOrderNumber")        @dtw_assign(Err_N1FORD,  fieldValue)
                                  @DecatErr_Field("@@tord", "toOrderNumber")        @dtw_assign(Err_N1TORD,  fieldValue)
                                  @DecatErr_Field("@@aord", "allOrderNumber")        @dtw_assign(Err_N1AORD,  fieldValue)
                                  @DecatErr_Field("@@sord", "sortOrderNumber")        @dtw_assign(Err_N1SORD,  fieldValue)
                                  @DecatErr_Field("@@frqd", "fromRequiredDate")        @dtw_assign(Err_N1FRQD,  fieldValue)
                                  @DecatErr_Field("@@trqd", "toRequiredDate")        @dtw_assign(Err_N1TRQD,  fieldValue)
                                  @DecatErr_Field("@@arqd", "allRequiredDate")        @dtw_assign(Err_N1ARQD,  fieldValue)
                                  @DecatErr_Field("@@srqd", "sortRequiredDate")        @dtw_assign(Err_N1SRQD,  fieldValue)
                                  @DecatErr_Field("@@fsht", "fromShipToCustomer")          @dtw_assign(Err_N1FSHT,  fieldValue)
                                  @DecatErr_Field("@@tsht", "toShipToCustomer")          @dtw_assign(Err_N1TSHT,  fieldValue)
                                  @DecatErr_Field("@@asht", "allShipToCustomer")          @dtw_assign(Err_N1ASHT,  fieldValue)
                                  @DecatErr_Field("@@ssht", "sortShipToCustomer")          @dtw_assign(Err_N1SSHT,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@fwhs")  @dtw_assign(V_N1FWHS,  fieldValue)
                                  @Decat_Field("@@twhs")  @dtw_assign(V_N1TWHS,  fieldValue)
                                  @Decat_Field("@@awhs")  @dtw_assign(V_N1AWHS,  fieldValue)
                                  @Decat_Field("@@swhs")  @dtw_assign(V_N1SWHS,  fieldValue)
                                  @Decat_Field("@@fitm")  @dtw_assign(V_N1FITM,  fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N1TITM,  fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N1AITM,  fieldValue)
                                  @Decat_Field("@@sitm")  @dtw_assign(V_N1SITM,  fieldValue)
                                  @Decat_Field("@@ford")  @dtw_assign(V_N1FORD,  fieldValue)
                                  @Decat_Field("@@tord")  @dtw_assign(V_N1TORD,  fieldValue)
                                  @Decat_Field("@@aord")  @dtw_assign(V_N1AORD,  fieldValue)
                                  @Decat_Field("@@sord")  @dtw_assign(V_N1SORD,  fieldValue)
                                  @Decat_Field("@@frqd")  @dtw_assign(V_N1FRQD,  fieldValue)
                                  @Decat_Field("@@trqd")  @dtw_assign(V_N1TRQD,  fieldValue)
                                  @Decat_Field("@@arqd")  @dtw_assign(V_N1ARQD,  fieldValue)
                                  @Decat_Field("@@srqd")  @dtw_assign(V_N1SRQD,  fieldValue)
                                  @Decat_Field("@@fsht")  @dtw_assign(V_N1FSHT,  fieldValue)
                                  @Decat_Field("@@tsht")  @dtw_assign(V_N1TSHT,  fieldValue)
                                  @Decat_Field("@@asht")  @dtw_assign(V_N1ASHT,  fieldValue)
                                  @Decat_Field("@@ssht")  @dtw_assign(V_N1SSHT,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}

                                  %if (V_N1AWHS == "ALL")
                                      @dtw_assign(checkedallWarehouseNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallWarehouseNumber, "")
                                  %endif
                                  %if (V_N1AITM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_N1AORD == "ALL")
                                      @dtw_assign(checkedallOrderNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallOrderNumber, "")
                                  %endif
                                  %if (V_N1ARQD == "ALL")
                                      @dtw_assign(checkedallRequiredDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallRequiredDate, "")
                                  %endif
                                  %if (V_N1ASHT == "ALL")
                                      @dtw_assign(checkedallShipToCustomer, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallShipToCustomer, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedallWarehouseNumber, "CHECKED")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallOrderNumber, "CHECKED")
                                  @dtw_assign(checkedallRequiredDate, "CHECKED")
                                  @dtw_assign(checkedallShipToCustomer, "CHECKED")
                              %endif

                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                              </tr>

                              @SetTextOvr(Err_N1FWHS)
                              %if (textOvr == "") @SetTextOvr(Err_N1TWHS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AWHS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SWHS) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Warehouse Number</span></td>
                                  <td class="inputnmbr"><input name="fromWarehouseNumber" value="$(V_N1FWHS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromWarehouseNumber&amp;fldDesc=fwarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fwarehouseName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toWarehouseNumber" value="$(V_N1TWHS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toWarehouseNumber&amp;fldDesc=twarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="twarehouseName" type="hidden"></td>
                                  <td class="inputalph"><input name="allWarehouseNumber" value='ALL' $(checkedallWarehouseNumber) type="checkbox" onClick="if (this.checked) this.form.fromWarehouseNumber.value='', this.form.toWarehouseNumber.value='';"></td>
                                  @Build_Sort_Select("sortWarehouseNumber", "$(V_N1SWHS)")
                              </tr>
                              @DspErrMsg(Err_N1FWHS)
                              @DspErrMsg(Err_N1TWHS)
                              @DspErrMsg(Err_N1AWHS)
                              @DspErrMsg(Err_N1SWHS)

                              @SetTextOvr(Err_N1FITM)
                              %if (textOvr == "") @SetTextOvr(Err_N1TITM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AITM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SITM) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N1FITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N1TITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                                  @Build_Sort_Select("sortItemNumber", "$(V_N1SITM)")
                              </tr>
                              @DspErrMsg(Err_N1FITM)
                              @DspErrMsg(Err_N1TITM)
                              @DspErrMsg(Err_N1AITM)
                              @DspErrMsg(Err_N1SITM)

                              @SetTextOvr(Err_N1FORD)
                              %if (textOvr == "") @SetTextOvr(Err_N1TORD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1AORD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SORD) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Order Number</span></td>
                                  <td class="inputnmbr"><input name="fromOrderNumber" value="$(V_N1FORD)" type="text" size="8" maxlength="8"></td>
                                  <td class="inputnmbr"><input name="toOrderNumber" value="$(V_N1TORD)" type="text" size="8" maxlength="8"></td>
                                  <td class="inputalph"><input name="allOrderNumber" value='ALL' $(checkedallOrderNumber) type="checkbox" onClick="if (this.checked) this.form.fromOrderNumber.value='', this.form.toOrderNumber.value='';"></td>
                                  @Build_Sort_Select("sortOrderNumber", "$(V_N1SORD)")
                              </tr>
                              @DspErrMsg(Err_N1FORD)
                              @DspErrMsg(Err_N1TORD)
                              @DspErrMsg(Err_N1AORD)
                              @DspErrMsg(Err_N1SORD)

                              @SetTextOvr(Err_N1FRQD)
                              %if (textOvr == "") @SetTextOvr(Err_N1TRQD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ARQD) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SRQD) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Required Date</span></td>
                                  <td class="inputnmbr"><input name="fromRequiredDate" value="$(V_N1FRQD)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromRequiredDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toRequiredDate" value="$(V_N1TRQD)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toRequiredDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allRequiredDate" value='ALL' $(checkedallRequiredDate) type="checkbox" onClick="if (this.checked) this.form.fromRequiredDate.value='', this.form.toRequiredDate.value='';"></td>
                                  @Build_Sort_Select("sortRequiredDate", "$(V_N1SRQD)")
                              </tr>
                              @DspErrMsg(Err_N1FRQD)
                              @DspErrMsg(Err_N1TRQD)
                              @DspErrMsg(Err_N1ARQD)
                              @DspErrMsg(Err_N1SRQD)

                              @SetTextOvr(Err_N1FSHT)
                              %if (textOvr == "") @SetTextOvr(Err_N1TSHT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ASHT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1SSHT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Ship-To Customer</span></td>
                                  <td class="inputnmbr"><input name="fromShipToCustomer" value="$(V_N1FSHT)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromShipToCustomer&amp;fldDesc=fcusName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="fcusName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toShipToCustomer" value="$(V_N1TSHT)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toShipToCustomer&amp;fldDesc=tcusName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="tcusName" type="hidden"></td>
                                  <td class="inputalph"><input name="allShipToCustomer" value='ALL' $(checkedallShipToCustomer) type="checkbox" onClick="if (this.checked) this.form.fromShipToCustomer.value='', this.form.toShipToCustomer.value='';"></td>
                                  @Build_Sort_Select("sortShipToCustomer", "$(V_N1SSHT)")
                              </tr>
                              @DspErrMsg(Err_N1FSHT)
                              @DspErrMsg(Err_N1TSHT)
                              @DspErrMsg(Err_N1ASHT)
                              @DspErrMsg(Err_N1SSHT)

                          </table>

                          @dtw_assign(envProgram, "HOEMOR")
                          @dtw_assign(envPrinter, "HOEMORPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HOEMOS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allWarehouseNumber)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(allOrderNumber)
  @dtw_mUPPERCASE(allRequiredDate)
  @dtw_mUPPERCASE(allShipToCustomer)

  @dtw_assign(fromWarehouseNumber,@dtw_rstrip(fromWarehouseNumber))
  @dtw_assign(toWarehouseNumber,@dtw_rstrip(toWarehouseNumber))
  @dtw_assign(sortWarehouseNumber,@dtw_rstrip(sortWarehouseNumber))
  @dtw_assign(sortItemNumber,@dtw_rstrip(sortItemNumber))
  @dtw_assign(fromOrderNumber,@dtw_rstrip(fromOrderNumber))
  @dtw_assign(toOrderNumber,@dtw_rstrip(toOrderNumber))
  @dtw_assign(sortOrderNumber,@dtw_rstrip(sortOrderNumber))
  @dtw_assign(fromRequiredDate,@dtw_rstrip(fromRequiredDate))
  @dtw_assign(toRequiredDate,@dtw_rstrip(toRequiredDate))
  @dtw_assign(sortRequiredDate,@dtw_rstrip(sortRequiredDate))
  @dtw_assign(fromShipToCustomer,@dtw_rstrip(fromShipToCustomer))
  @dtw_assign(toShipToCustomer,@dtw_rstrip(toShipToCustomer))
  @dtw_assign(sortShipToCustomer,@dtw_rstrip(sortShipToCustomer))


  %if (allWarehouseNumber != "ALL")
      @dtw_assign(allWarehouseNumber, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allOrderNumber != "ALL")
      @dtw_assign(allOrderNumber, "")
  %endif
  %if (allRequiredDate != "ALL")
      @dtw_assign(allRequiredDate, "")
  %endif
  %if (allShipToCustomer != "ALL")
      @dtw_assign(allShipToCustomer, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@fwhs", fromWarehouseNumber)
  @Concat_Field("@@twhs", toWarehouseNumber)
  @Concat_Field("@@awhs", allWarehouseNumber)
  @Concat_Field("@@swhs", sortWarehouseNumber)
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@sitm", sortItemNumber)
  @Concat_Field("@@ford", fromOrderNumber)
  @Concat_Field("@@tord", toOrderNumber)
  @Concat_Field("@@aord", allOrderNumber)
  @Concat_Field("@@sord", sortOrderNumber)
  @Concat_Field("@@frqd", fromRequiredDate)
  @Concat_Field("@@trqd", toRequiredDate)
  @Concat_Field("@@arqd", allRequiredDate)
  @Concat_Field("@@srqd", sortRequiredDate)
  @Concat_Field("@@fsht", fromShipToCustomer)
  @Concat_Field("@@tsht", toShipToCustomer)
  @Concat_Field("@@asht", allShipToCustomer)
  @Concat_Field("@@ssht", sortShipToCustomer)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}