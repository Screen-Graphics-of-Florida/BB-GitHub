          @DTW_ASSIGN(oth_orderBy, "TJTTYP,TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(oth_orderByDisplay, "Type, Date, Journal, Sequence")
      %endif
  %elseif (sequence == "Reference")
      %if (oth_orderBy == "TDREF,TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(oth_orderBy, "TDREF DESC,TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(oth_orderByDisplay, "Reference (descending), Date, Journal, Sequence")
      %else
          @DTW_ASSIGN(oth_orderBy, "TDREF,TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(oth_orderByDisplay, "Reference, Date, Journal, Sequence")
      %endif
  %elseif (sequence == "Period")
      %if (oth_orderBy == "TDPER#,TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(oth_orderBy, "TDPER# DESC,TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(oth_orderByDisplay, "Period (descending), Date, Journal, Sequence")
      %else
          @DTW_ASSIGN(oth_orderBy, "TDPER#,TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(oth_orderByDisplay, "Period, Date, Journal, Sequence")
      %endif
  %elseif (sequence == "Description")
      %if (oth_orderBy == "TDDESC,TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(oth_orderBy, "TDDESC DESC,TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(oth_orderByDisplay, "Description (descending), Date, Journal, Sequence")
      %else
          @DTW_ASSIGN(oth_orderBy, "TDDESC,TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(oth_orderByDisplay, "Description, Date, Journal, Sequence")
      %endif
  %elseif (sequence == "Date")
      %if (oth_orderBy == "TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(oth_orderBy, "TDTDTE DESC,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(oth_orderByDisplay, "Date (descending), Journal, Sequence")
      %else
          @DTW_ASSIGN(oth_orderBy, "TDTDTE,TDJRNL,TDJSEQ,TDREC")
          @DTW_ASSIGN(oth_orderByDisplay, "Date, Journal, Sequence")
      %endif
  %endif

  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, "GLDDSubOTH", oth_orderBy, oth_orderByDisplay)
  @Set_SQL(stmtSQL)
%}