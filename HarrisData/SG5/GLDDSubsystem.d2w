%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Drill Down Subsystem Entries"
  d2wName                 = "GLDDSubsystem.d2w"
  d2wVarBase              = "$(genericVarBase)$(glDDVarBase)&amp;accountNumber=@dtw_rurlescseq(accountNumber)&amp;subAccount=@dtw_rurlescseq(subAccount)&amp;coNumber=@dtw_rurlescseq(coNumber)&amp;facNumber=@dtw_rurlescseq(facNumber)&amp;accountAmount=@dtw_rurlescseq(accountAmount)&amp;fromPer=@dtw_rurlescseq(fromPer)&amp;toPer=@dtw_rurlescseq(toPer)&amp;columnValue=@dtw_rurlescseq(columnValue)&amp;ap_orderBy=@dtw_rurlescseq(ap_orderBy)&amp;ar_orderBy=@dtw_rurlescseq(ar_orderBy)&amp;fa_orderBy=@dtw_rurlescseq(fa_orderBy)&amp;iv_orderBy=@dtw_rurlescseq(iv_orderBy)&amp;gl_orderBy=@dtw_rurlescseq(gl_orderBy)&amp;oth_orderBy=@dtw_rurlescseq(oth_orderBy)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
  view_ap                 = ""
  view_ar                 = ""
  view_fa                 = ""
  view_iv                 = ""
  view_po                 = ""
  view_gl                 = ""
  view_ot                 = ""
  V_DDUNPS                = ""
  uv_Sql_ap               = ""
  uv_Sql_ar               = ""
  uv_Sql_fa               = ""
  uv_Sql_iv               = ""
  uv_Sql_po               = ""
  uv_Sql_gl               = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @RtvFldDesc("DDGRSN='$(ddReport)'", "GLDDRP", "DDUNPS", V_DDUNPS)
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <link rel=stylesheet type="text/css" href="$(homeURL)$(homePath)$(GLDDStyleSheet)">
          <script TYPE="text/javascript">
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      %{Accounts Payable User View %}
                          @dtw_assign(uv_CompanyName, "TDCO")
                          @dtw_assign(uv_FacilityName, "TDFAC")
                          @dtw_assign(uv_AccountName, "TDACCT")
                          @dtw_assign(uv_SubaccountName, "TDSUB")
                          @dtw_assign(uv_VendorName, "APVEND")
                          @dtw_assign(uv_VendorTypeName, "VMVTYP")
                          %INCLUDE "UserView.icl"
                          @dtw_assign(uv_Sql_ap, uv_Sql)

                          @dtw_assign(ap_fileSQL, "GLTRDT,APGLDD ")
                          @dtw_assign(ap_fileSQL, "$(ap_fileSQL) left join HDVEND on APVEND=VMVEND")
                          @dtw_assign(ap_fileSQL, "$(ap_fileSQL) left join SYFLAG a on a.FLTYPE='APFEED' and a.FLVALU=APRPTS")
                          @dtw_assign(ap_fileSQL, "$(ap_fileSQL) left join SYFLAG b on b.FLTYPE='APCHECKCD' and b.FLVALU=APCKCD")
                          @dtw_assign(ap_selectSQL, "TDCO=$(coNumber) and TDFAC=$(facNumber) and TDACCT=$(accountNumber) and TDSUB=$(subAccount)")
                          @dtw_assign(ap_selectSQL, "$(ap_selectSQL) and TDPER# between $(fromPer) and $(toPer) ")
                          @dtw_assign(ap_selectSQL, "$(ap_selectSQL) and TDDDSQ>0 and TDDDPG=' ' and TDAPID='AP' ")
                          @dtw_assign(ap_selectSQL, "$(ap_selectSQL) and TDPER#=APPER# and TDDDSQ=APDDSQ and TDDDFL=APDDFL ")
                          %if (uv_Sql_ap != "")
                              @dtw_assign(ap_selectSQL, "$(ap_selectSQL) and ($(uv_Sql_ap))")
                          %endif
                          @RtvFldDesc("$(ap_selectSQL)", "$(ap_fileSQL)", "CHAR(Count(*))", view_ap)

                      %{Accounts Receivable User View %}
                          @dtw_assign(uv_CompanyName, "TDCO")
                          @dtw_assign(uv_FacilityName, "TDFAC")
                          @dtw_assign(uv_AccountName, "TDACCT")
                          @dtw_assign(uv_SubaccountName, "TDSUB")
                          @dtw_assign(uv_CustomerName, "ARBLTO")
                          @dtw_assign(uv_CustomerClassName, "CMCCLS")
                          @dtw_assign(uv_RegionName, "CMCRGN")
                          @dtw_assign(uv_BillingLocationName, "CMLOC#")
                          @dtw_assign(uv_SalesmanName, "CMSLSM")
                          @dtw_assign(uv_WarehouseName, "CMWH#")
                          %INCLUDE "UserView.icl"
                          @dtw_assign(uv_Sql_ar, uv_Sql)

                          @dtw_assign(ar_fileSQL, "GLTRDT,ARGLDD")
                          @dtw_assign(ar_fileSQL, "$(ar_fileSQL) left join HDCUST on ARBLTO=CMCUST")
                          @dtw_assign(ar_fileSQL, "$(ar_fileSQL) left join ARPYCD on PYPYCD=ARARPC")
                          @dtw_assign(ar_fileSQL, "$(ar_fileSQL) left join SYFLAG on FLTYPE='ARFEED' and FLVALU=ARRPTS")
                          @dtw_assign(ar_fileSQL, "$(ar_fileSQL) left join HDLCTN on LOLOC#=ARLOC#")
                          @dtw_assign(ar_selectSQL, "TDCO=$(coNumber) and TDFAC=$(facNumber) and TDACCT=$(accountNumber) and TDSUB=$(subAccount)")
                          @dtw_assign(ar_selectSQL, "$(ar_selectSQL) and TDPER# between $(fromPer) and $(toPer) ")
                          @dtw_assign(ar_selectSQL, "$(ar_selectSQL) and TDDDSQ>0 and TDDDPG=' ' and TDAPID='AR' ")
                          @dtw_assign(ar_selectSQL, "$(ar_selectSQL) and TDPER#=ARPER# and TDDDSQ=ARDDSQ and TDDDFL=ARDDFL ")
                          %if (uv_Sql_ar != "")
                              @dtw_assign(ar_selectSQL, "$(ar_selectSQL) and ($(uv_Sql_ar))")
                          %endif
                          @RtvFldDesc("$(ar_selectSQL)", "$(ar_fileSQL)", "CHAR(Count(*))", view_ar)

                      %{Fixed Assets User View  %}
                          @dtw_assign(uv_CompanyName, "TDCO")
                          @dtw_assign(uv_FacilityName, "TDFAC")
                          @dtw_assign(uv_AccountName, "TDACCT")
                          @dtw_assign(uv_SubaccountName, "TDSUB")
                          @dtw_assign(uv_SiteName, "GFSITE")
                          @dtw_assign(uv_PropertyTypeName, "GFPROP")
                          @dtw_assign(uv_FamilyCodeName, "GFFMCD")
                          %INCLUDE "UserView.icl"
                          @dtw_assign(uv_Sql_fa, uv_Sql)

                          @dtw_assign(fa_fileSQL, "GLTRDT,FAGLDD")
                          @dtw_assign(fa_fileSQL, "$(fa_fileSQL) left join SYFLAG on FLTYPE='FAFEED' and FLVALU=GFRPTS")
                          @dtw_assign(fa_selectSQL, "  TDCO=$(coNumber) and TDFAC=$(facNumber) and TDACCT=$(accountNumber) and TDSUB=$(subAccount) ")
                          @dtw_assign(fa_selectSQL, "$(fa_selectSQL) and TDPER# between $(fromPer) and $(toPer) ")
                          @dtw_assign(fa_selectSQL, "$(fa_selectSQL) and TDDDSQ>0 and TDDDPG=' ' and TDAPID='FA' ")
                          @dtw_assign(fa_selectSQL, "$(fa_selectSQL) and TDPER#=GFPER# and TDDDSQ=GFDDSQ and TDDDFL=GFDDFL ")
                          %if (uv_Sql_fa != "")
                              @dtw_assign(fa_selectSQL, "$(fa_selectSQL) and ($(uv_Sql_fa))")
                          %endif
                          @RtvFldDesc("$(fa_selectSQL)", "$(fa_fileSQL)", "CHAR(Count(*))", view_fa)

                      %{Inventory User View %}
                          @dtw_assign(uv_CompanyName, "TDCO")
                          @dtw_assign(uv_FacilityName, "TDFAC")
                          @dtw_assign(uv_AccountName, "TDACCT")
                          @dtw_assign(uv_SubaccountName, "TDSUB")
                          %INCLUDE "UserView.icl"
                          @dtw_assign(uv_Sql_iv, uv_Sql)

                          @dtw_assign(iv_fileSQL, "GLTRDT,IVGLDD")
                          @dtw_assign(iv_fileSQL, "$(iv_fileSQL) left join HDIMST on IVITEM=IMITEM")
                          @dtw_assign(iv_fileSQL, "$(iv_fileSQL) left join HDTTYP on TTTYPE=IVIVTT")
                          @dtw_assign(iv_fileSQL, "$(iv_fileSQL) left join HDWHSM on WHWHS =IVWHS")
                          @dtw_assign(iv_fileSQL, "$(iv_fileSQL) left join HDPLNT on PLPLNT=IVPLT")
                          @dtw_assign(iv_fileSQL, "$(iv_fileSQL) left join HDPCLS on PCPCLS=IVPCLS")
                          @dtw_assign(iv_fileSQL, "$(iv_fileSQL) left join HDITYP on ITITC =IVITC")
                          @dtw_assign(iv_selectSQL, "TDCO=$(coNumber) and TDFAC=$(facNumber) and TDACCT=$(accountNumber) and TDSUB=$(subAccount)")
                          @dtw_assign(iv_selectSQL, "$(iv_selectSQL) and TDPER# between $(fromPer) and $(toPer) ")
                          @dtw_assign(iv_selectSQL, "$(iv_selectSQL) and TDDDSQ>0 and TDDDPG=' ' and TDAPID='IV' ")
                          @dtw_assign(iv_selectSQL, "$(iv_selectSQL) and TDPER#=IVPER# and TDDDSQ=IVDDSQ and TDDDFL=IVDDFL ")
                          %if (uv_Sql_iv != "")
                              @dtw_assign(iv_selectSQL, "$(iv_selectSQL) and ($(uv_Sql_iv))")
                          %endif
                          @RtvFldDesc("$(iv_selectSQL)", "$(iv_fileSQL)", "CHAR(Count(*))", view_iv)

                      %{Purchasing User View %}
                          @dtw_assign(uv_CompanyName, "TDCO")
                          @dtw_assign(uv_FacilityName, "TDFAC")
                          @dtw_assign(uv_AccountName, "TDACCT")
                          @dtw_assign(uv_SubaccountName, "TDSUB")
                          %INCLUDE "UserView.icl"
                          @dtw_assign(uv_Sql_po, uv_Sql)

                          @dtw_assign(po_fileSQL, "GLTRDT,POGLDD")
                          @dtw_assign(po_fileSQL, "$(po_fileSQL) left join HDTTYP on TTTYPE=POIVTT")
                          @dtw_assign(po_fileSQL, "$(po_fileSQL) left join HDWHSM on WHWHS =POWHS")
                          @dtw_assign(po_fileSQL, "$(po_fileSQL) left join HDPLNT on PLPLNT=POPLT")
                          @dtw_assign(po_fileSQL, "$(po_fileSQL) left join HDPCLS on PCPCLS=POPCLS")
                          @dtw_assign(po_fileSQL, "$(po_fileSQL) left join HDITYP on ITITC =POITC")
                          @dtw_assign(po_selectSQL, "TDCO=$(coNumber) and TDFAC=$(facNumber) and TDACCT=$(accountNumber) and TDSUB=$(subAccount)")
                          @dtw_assign(po_selectSQL, "$(po_selectSQL) and TDPER# between $(fromPer) and $(toPer) ")
                          @dtw_assign(po_selectSQL, "$(po_selectSQL) and TDDDSQ>0 and TDDDPG=' ' and TDAPID='PO' ")
                          @dtw_assign(po_selectSQL, "$(po_selectSQL) and POPER#=TDPER# and PODDSQ=TDDDSQ and PODDFL=TDDDFL ")
                          %if (uv_Sql_po != "")
                              @dtw_assign(po_selectSQL, "$(po_selectSQL) and ($(uv_Sql_po))")
                          %endif
                          @RtvFldDesc("$(po_selectSQL)", "$(po_fileSQL)", "CHAR(Count(*))", view_po)

                      %{General Ledger User View %}
                          @dtw_assign(uv_CompanyName, "TDCO")
                          @dtw_assign(uv_FacilityName, "TDFAC")
                          @dtw_assign(uv_AccountName, "TDACCT")
                          @dtw_assign(uv_SubaccountName, "TDSUB")
                          %INCLUDE "UserView.icl"
                          @dtw_assign(uv_Sql_gl, uv_Sql)

                          @dtw_assign(gl_fileSQL, "GLTRDT,GLTRJL")
                          @dtw_assign(gl_fileSQL, "$(gl_fileSQL) left join SYFLAG on FLTYPE='GLTRANTYP' and FLVALU=TJTTYP")
                          @dtw_assign(gl_selectSQL, "TDCO=$(coNumber) and TDFAC=$(facNumber) and TDACCT=$(accountNumber) and TDSUB=$(subAccount) ")
                          @dtw_assign(gl_selectSQL, "$(gl_selectSQL) and TDPER# between $(fromPer) and $(toPer) ")
                          @dtw_assign(gl_selectSQL, "$(gl_selectSQL) and TDDDSQ=0   ")
                          @dtw_assign(gl_selectSQL, "$(gl_selectSQL) and TDJRNL=TJJRNL and TDPER#=TJPER# and TDTDTE=TJTDTE and TDJSEQ=TJJSEQ")

                          %if (V_DDUNPS == "N")
                              @dtw_assign(gl_selectSQL, " $(gl_selectSQL) and TJSTAT='P'")
                          %endif

                          @RtvFldDesc("DDGRSN='$(ddReport)'", "GLDDRP", "DDEOYA", V_DDEOYA)
                          %if (V_DDEOYA == "N")
                              @dtw_assign(gl_selectSQL, " $(gl_selectSQL) and TJTTYP<>'YE'")
                          %endif

                          %if (uv_Sql_gl != "")
                              @dtw_assign(gl_selectSQL, " $(gl_selectSQL) and ($(uv_Sql_gl))")
                          %endif
                          @RtvFldDesc("$(gl_selectSQL)", "$(gl_fileSQL)", "CHAR(Count(*))", view_gl)

                      %{Other %}
                          @dtw_assign(ot_fileSQL, "GLTRDT,GLTRJL")
                          @dtw_assign(ot_selectSQL, "TDCO=$(coNumber) and TDFAC=$(facNumber) and TDACCT=$(accountNumber) and TDSUB=$(subAccount)")
                          @dtw_assign(ot_selectSQL, "$(ot_selectSQL) and TDPER# between $(fromPer) and $(toPer) ")
                          @dtw_assign(ot_selectSQL, "$(ot_selectSQL) and TDDDSQ>0 and TDDDPG='Y'  ")
                          @dtw_assign(ot_selectSQL, "$(ot_selectSQL) and TDJRNL=TJJRNL and TDPER#=TJPER# and TDTDTE=TJTDTE and TDJSEQ=TJJSEQ")
                          %if (uv_Sql_gl != "")
                              @dtw_assign(ot_selectSQL, "$(ot_selectSQL) and ($(uv_Sql_gl))")
                          %endif
                          @RtvFldDesc("$(ot_selectSQL)", "$(ot_fileSQL)", "CHAR(Count(*))", view_ot)

                      %{Header %}
                          @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                          @dtw_assign(SAVE_MAX_ROWS, RPT_MAX_ROWS)
                          @dtw_assign(START_ROW_NUM, "1")
                          @dtw_assign(RPT_MAX_ROWS, "9999")
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_assign(appendUserView, "N")
                          @dtw_assign(appendWildCard, "N")
                          @dtw_assign(stmtSQL, "SELECT * ")
                          @dtw_assign(fileSQL, "GLDDHD ")
                          @dtw_assign(selectSQL, " DHGRSN='$(ddReport)' and DHCO=$(ddCompany) and DHFAC=$(ddFacility) ")
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_assign(stmtSQL, "$(stmtSQL) order by DHGRSN  ")
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @RptHdg_Query(profileHandle, dataBaseID, stmtSQL)
                          @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                          @dtw_assign(RPT_MAX_ROWS, SAVE_MAX_ROWS)

                      %{Accounts Payable     %}
                      %if (view_ap>"0")
                          @Retrieve_WebReg(webRegCurFile, profileHandle, "GLDDSubAP", wildCardSearch, ap_orderBy, ap_orderByDisplay, wildCardDisplay)
                          @dtw_assign(START_ROW_NUM, "1")
                          @dtw_assign(RPT_MAX_ROWS, "9999")
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_assign(appendUserView, "N")
                          @dtw_assign(appendWildCard, "N")
                          @dtw_assign(stmtSQL, "SELECT APDDSQ,APDDFL,APRPTS,APJRNL,APAMT,APBANK,APVOU#,APLINE,APVEND,APCHK#,APCHKD,APCKCD,APINV#,APINVD,APMEMO,APPO#,APDSTD, ")
                          @dtw_assign(stmtSQL, "$(stmtSQL) VMVNA1,VMVNA1U, ")
                          @dtw_assign(stmtSQL, "$(stmtSQL) a.FLDESC as srcFLDESC, ")
                          @dtw_assign(stmtSQL, "$(stmtSQL) b.FLDESC as pmtFLDESC ")
                          @dtw_assign(fileSQL, ap_fileSQL)
                          @dtw_assign(selectSQL, ap_selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_assign(stmtSQL, "$(stmtSQL) ORDER BY $(ap_orderBy) ")
                          %INCLUDE "stmtSQLEnd.icl"
                          @AccountsPayable_Query(profileHandle, dataBaseID, stmtSQL)
                      %endif

                      %{Accounts Receivable     %}
                      %if (view_ar>"0")
                          @Retrieve_WebReg(webRegCurFile, profileHandle, "GLDDSubAR", wildCardSearch, ar_orderBy, ar_orderByDisplay, wildCardDisplay)
                          @dtw_assign(START_ROW_NUM, "1")
                          @dtw_assign(RPT_MAX_ROWS, "9999")
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_assign(appendUserView, "N")
                          @dtw_assign(appendWildCard, "N")
                          @dtw_assign(stmtSQL, "SELECT ARDDSQ,ARDDFL,ARRPTS,ARJRNL,ARARPC,ARACHK,ARDTPD,ARBANK,ARAIV#,ARIVDT,ARBLTO,ARCUST,ARAMT,ARLOC#,ARORD#,ARORDT,ARISEQ,ARPSEQ, ")
                          @dtw_assign(stmtSQL, "$(stmtSQL) CMCNA1,CMCNA1U, FLDESC, PYPYDS, LOLNA1 ")
                          @dtw_assign(fileSQL, ar_fileSQL)
                          @dtw_assign(selectSQL, ar_selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_assign(stmtSQL, "$(stmtSQL) ORDER BY $(ar_orderBy) ")
                          %INCLUDE "stmtSQLEnd.icl"
                          @AccountsReceivable_Query(profileHandle, dataBaseID, stmtSQL)
                      %endif

                      %{Fixed Assets     %}
                      %if (view_fa>"0")
                          @Retrieve_WebReg(webRegCurFile, profileHandle, "GLDDSubFA", wildCardSearch, fa_orderBy, fa_orderByDisplay, wildCardDisplay)
                          @dtw_assign(START_ROW_NUM, "1")
                          @dtw_assign(RPT_MAX_ROWS, "9999")
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_assign(appendUserView, "N")
                          @dtw_assign(appendWildCard, "N")
                          @dtw_assign(stmtSQL, "SELECT GFPER#,GFDDSQ,GFRPTS,GFJRNL,GFAMT,GFSITE,GFASST,GFSCHD,GFDESC,GFPROP,GFFPCD,GFRTPD,GFRTDT,GFRRES,GFTRFG,GFTFPD,GFTSIT,GFTAST,GFBDDT,GFLFYY,GFLFMM,GFDPCD, ")
                          @dtw_assign(stmtSQL, "$(stmtSQL) FLDESC ")
                          @dtw_assign(fileSQL, fa_fileSQL)
                          @dtw_assign(selectSQL, fa_selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_assign(stmtSQL, "$(stmtSQL) ORDER BY $(fa_orderBy) ")
                          %INCLUDE "stmtSQLEnd.icl"
                          @FixedAssets_Query(profileHandle, dataBaseID, stmtSQL)
                      %endif

                      %{Inventory        %}
                      %if (view_iv>"0")
                          @Retrieve_WebReg(webRegCurFile, profileHandle, "GLDDSubIV", wildCardSearch, iv_orderBy, iv_orderByDisplay, wildCardDisplay)
                          @dtw_assign(START_ROW_NUM, "1")
                          @dtw_assign(RPT_MAX_ROWS, "9999")
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_assign(appendUserView, "N")
                          @dtw_assign(appendWildCard, "N")
                          @dtw_assign(stmtSQL, "SELECT IVAMT,IVQTY,IVDSEQ,IVOSEQ,IVIVTT,IVTRDT,IVWHS,IVPCLS,IVITC,IVITEM,IVPLT,IVMORD, ")
                          @dtw_assign(stmtSQL, "$(stmtSQL) IMIMDS,TTDESC,WHWHNM,PLNAME,PCPCDS,ITDESC ")
                          @dtw_assign(fileSQL, iv_fileSQL)
                          @dtw_assign(selectSQL, iv_selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_assign(stmtSQL, "$(stmtSQL) ORDER BY $(iv_orderBy) ")
                          %INCLUDE "stmtSQLEnd.icl"
                          @Inventory_Query(profileHandle, dataBaseID, stmtSQL)
                      %endif

                      %{Purchasing     %}
                      %if (view_po>"0")
                          @Retrieve_WebReg(webRegCurFile, profileHandle, "GLDDSubPO", wildCardSearch, po_orderBy, po_orderByDisplay, wildCardDisplay)
                          @dtw_assign(START_ROW_NUM, "1")
                          @dtw_assign(RPT_MAX_ROWS, "9999")
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_assign(appendUserView, "N")
                          @dtw_assign(appendWildCard, "N")
                          @dtw_assign(stmtSQL, " SELECT POAMT,POQTY,POIVTT,POTRDT,POWHS,POPLT,POVEND,POPO,POSEQ,POPCLS,POITC,POPOEC,POITEM,POIMDS, ")
                          @dtw_assign(stmtSQL, " $(stmtSQL) TTDESC,WHWHNM,PLNAME,PCPCDS,ITDESC ")
                          @dtw_assign(fileSQL, po_fileSQL)
                          @dtw_assign(selectSQL, po_selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                          @Purchasing_Query(profileHandle, dataBaseID, stmtSQL)
                      %endif

                      %{General Ledger %}
                      %if (view_gl>"0")
                          @Retrieve_WebReg(webRegCurFile, profileHandle, "GLDDSubGL", wildCardSearch, gl_orderBy, gl_orderByDisplay, wildCardDisplay)
                          @dtw_assign(START_ROW_NUM, "1")
                          @dtw_assign(RPT_MAX_ROWS, "9999")
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_assign(appendUserView, "N")
                          @dtw_assign(appendWildCard, "N")
                          @dtw_assign(stmtSQL, "SELECT TDJRNL,TDPER#,TDTDTE,TDJSEQ,TDREC,TDREF,TDAMT,TDDESC,TDSEQ#,TDAPID, ")
                          @dtw_assign(stmtSQL, "$(stmtSQL) TJTTYP, FLDESC ")
                          @dtw_assign(fileSQL, gl_fileSQL)
                          @dtw_assign(selectSQL, gl_selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_assign(stmtSQL, " $(stmtSQL) ORDER BY $(gl_orderBy) ")
                          %INCLUDE "stmtSQLEnd.icl"
                          @GeneralLedger_Query(profileHandle, dataBaseID, stmtSQL)
                      %endif

                      %{Other %}
                      %if (view_ot>"0")
                          @Retrieve_WebReg(webRegCurFile, profileHandle, "GLDDSubOTH", wildCardSearch, oth_orderBy, oth_orderByDisplay, wildCardDisplay)
                          @dtw_assign(START_ROW_NUM, "1")
                          @dtw_assign(RPT_MAX_ROWS, "9999")
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_assign(appendUserView, "N")
                          @dtw_assign(appendWildCard, "N")
                          @dtw_assign(stmtSQL, "SELECT TDJRNL,TDPER#,TDTDTE,TDJSEQ,TDREC,TDREF,TDAMT,TDDESC,TDSEQ#,TDAPID ")
                          @dtw_assign(fileSQL, ot_fileSQL)
                          @dtw_assign(selectSQL, ot_selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_assign(stmtSQL, "$(stmtSQL) ORDER BY $(oth_orderBy) ")
                          %INCLUDE "stmtSQLEnd.icl"
                          @Other_Query(profileHandle, dataBaseID, stmtSQL)
                      %endif

                      $(inquiryhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) RptHdg_Query (IN  CHAR(64) profileHandle,
                                     CHAR(2)   dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count == "0")
          @DTW_EXIT()
      %endif

      <a NAME="top"></a>

      %ROW{
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if (ddReport!="")
                              <a href="$(homeURL)$(cGIPath)GLDDReport.d2w/REPORT$(genericVarBase)$(glDDVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))" title="Return To Drill Down Report">$(portalHome)</a>
                          %endif
                          <a href="$(homeURL)$(cGIPath)$(d2wName)/ENTRY$(d2wVarBase)&amp;formatToPrint=Y" target=_blank>$(formatPrintDesc)</a>
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>

              <tr><td><h2>$(V_DHUSRN)</h2></td> </tr>

              %if (V_DHGRH1 != "")
                  <tr><td><h2>$(V_DHGRH1)</h2></td></tr>
              %endif

              %if (V_DHGRH2 != "")
                  <tr><td><h2>$(V_DHGRH2)</h2></td></tr>
              %endif

              %if (V_DHGRH3 != "")
                  <tr><td><h2>$(V_DHGRH3)</h2></td></tr>
              %endif

              <tr><td><h2>$(V_DHGRHP)</h2></td></tr>

              %if (uv_Sql_ap != "" || uv_Sql_ar != "" || uv_Sql_fa != "" || uv_Sql_iv != "" || uv_Sql_po != "" || uv_Sql_gl != "")
                 <tr><td><h3> You may not be authorized to view some transactions </h3></td></tr>
              %endif

          </table>
      %}

      $(inquiryhrTagAttr)

      %if (formatToPrint != "Y")
          <table $(contentTable)>
              %if (view_ap>"0")
                  <tr><td><a href="#accountspayable">Accounts Payable</a></td></tr>
              %endif
              %if (view_ar>"0")
                  <tr><td><a href="#accountsreceivable">Accounts Receivable</a></td></tr>
              %endif
              %if (view_fa>"0")
                  <tr><td><a href="#fixedassets">Fixed Assets</a></td></tr>
              %endif
              %if (view_iv>"0")
                  <tr><td><a href="#inventory">Inventory</a></td></tr>
              %endif
              %if (view_gl>"0")
                  <tr><td><a href="#generalledger">General Ledger</a></td></tr>
              %endif
              %if (view_po>"0")
                  <tr><td><a href="#purchasing">Purchasing</a></td></tr>
              %endif
              %if (view_ot>"0")
                  <tr><td><a href="#other">Other</a></td></tr>
              %endif
              <tr><td>&nbsp;</td></tr>
          </table>
      %endif

      <table $(contentTable)>
          <tr><th class="colhdr"> Co/Fac</th>
              <th class="colhdr"> Name</th>
              <th class="colhdr"> Account</th>
              <th class="colhdr"> Account Name</th>
              <th class="colhdr"> Type</th>
              <th class="colhdr"> Usage</th>
              %if (V_HDMCRL > "0")
                  <th class="colhdr"> Cur</th>
              %endif
              <th class="colhdr"> Amount</th>
              %if (columnValue=="")
                  <th class="colhdr"> Opening<br>Balance</th>
              %endif
          </tr>

          @Retrieve_AcctJrnl_Data(profileHandle,
                                 dataBaseID,
                                 coNumber,
                                 facNumber,
                                 accountNumber,
                                 subAccount,
                                 fromPer,
                                 toPer,
                                 V_DDUNPS,
                                 acctName,
                                 coFacName,
                                 balanceIncome,
                                 currencyUnit,
                                 currencyType,
                                 beginBal)

          @Format_CoFac("$(coNumber)", "$(facNumber)", "", F_CoFac)
          @Format_Acct("$(accountNumber)", "$(subAccount)", "", F_AcctSub)

          %INCLUDE "SetRowClass.icl"

          <tr class="$(rowClass)">
              <td class="colnmbr">$(F_CoFac)</td>
              <td class="colalph">$(coFacName)</td>
              <td class="colnmbr">$(F_AcctSub)</td>
              <td class="colalph">$(acctName)</td>
              <td class="colalph">$(balanceIncome)</td>
              <td class="colalph">$(currencyUnit) </td>
              %if (V_HDMCRL > "0")
                  <td class="colalph">$(currencyType) </td>
              %endif
              <td class="colnmbr">$(accountAmount)</td>
              %if (columnValue=="")
                  @Format_Nbr($(beginBal), F_beginBal, "2", $(amtEditCode), "Y", "", "")
                  <td class="colnmbr">$(F_beginBal)</td>
              %endif
          </tr>
      </table>
  %}
%}

%FUNCTION(dtw_sql) AccountsPayable_Query (IN  CHAR(64) profileHandle,
                                              CHAR(2)   dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (formatToPrint != "Y")
          <table $(contentTable)>
              <tr><td><a href="#top">$(topOfFormImage)</a></td></tr>
          </table>
      %endif

      <a name="accountspayable"></a>
      <fieldset class="legendBody">
          <legend class="legendTitle">Accounts Payable</legend>
          	
          <table $(contentTable)>
              @dtw_assign(headOnce, "")

              %ROW{
                  %if (headOnce == "")
                      @dtw_assign(headOnce, "Y")
                      <tr>
                          @dtw_assign(ap_orderByVar, "$(d2wVarBase)$(searchVarBase)")
                          @Named_OrderBy_Sort("APAMT", "$(ap_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AP_ORDERBY$(ap_orderByVar)&amp;sequence=Amount" title="Sequence By Amount"> Amount</a></th>
                          @Named_OrderBy_Sort("APRPTS", "$(ap_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AP_ORDERBY$(ap_orderByVar)&amp;sequence=Source" title="Sequence By Source"> Source</a></th>
                          @Named_OrderBy_Sort("APINV#", "$(ap_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AP_ORDERBY$(ap_orderByVar)&amp;sequence=Invoice" title="Sequence By Invoice"> Invoice</a></th>
                          @Named_OrderBy_Sort("APINVD", "$(ap_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AP_ORDERBY$(ap_orderByVar)&amp;sequence=InvDate" title="Sequence By Invoice Date"> Invoice<br>Date</a></th>
                          @Named_OrderBy_Sort("VMVNA1U", "$(ap_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AP_ORDERBY$(ap_orderByVar)&amp;sequence=VendorName" title="Sequence By Vendor Name"> Vendor<br>Name</a></th>
                          @Named_OrderBy_Sort("APDSTD", "$(ap_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AP_ORDERBY$(ap_orderByVar)&amp;sequence=DistPd" title="Sequence By Distribution Period"> Dist<br>Period</a></th>
                          @Named_OrderBy_Sort("APPO#", "$(ap_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AP_ORDERBY$(ap_orderByVar)&amp;sequence=PONumber" title="Sequence By Purchase Order"> Purchase<br>Order</a></th>
                          @Named_OrderBy_Sort("APMEMO", "$(ap_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AP_ORDERBY$(ap_orderByVar)&amp;sequence=Memo" title="Sequence By Memo"> Memo</a></th>
                          @Named_OrderBy_Sort("APVOU#", "$(ap_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AP_ORDERBY$(ap_orderByVar)&amp;sequence=Voucher" title="Sequence By Voucher"> Voucher</a></th>
                          @Named_OrderBy_Sort("APBANK", "$(ap_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AP_ORDERBY$(ap_orderByVar)&amp;sequence=Bank" title="Sequence By Bank"> Bank</a></th>
                          @Named_OrderBy_Sort("APCHK#", "$(ap_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AP_ORDERBY$(ap_orderByVar)&amp;sequence=CheckNumber" title="Sequence By Check"> Check</a></th>
                          @Named_OrderBy_Sort("APCHKD", "$(ap_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AP_ORDERBY$(ap_orderByVar)&amp;sequence=CheckDate" title="Sequence By Check Date"> Check<br>Date</a></th>
                          @Named_OrderBy_Sort("APCKCD", "$(ap_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AP_ORDERBY$(ap_orderByVar)&amp;sequence=CheckCode" title="Sequence By Check Code"> Check<br>Code</a></th>
                     </tr>
                  %endif

                  %INCLUDE "SetRowClass.icl"

                  @dtw_assign(invoiceDate, V_APINVD)
                  @dtw_assign(checkDate, V_APCHKD)
                  @PeriodFromCYP(V_APDSTD)
                  @Format_Nbr($(V_APAMT), F_APAMT, "2", $(amtEditCode), "Y", "", "")
                  @Format_Date(V_APINVD, "D", F_APINVD)
                  @Format_Date(V_APCHKD, "D", F_APCHKD)

                  <tr class="$(rowClass)">
                      %if (V_APDDSQ != "0" && V_APDDFL == "APDIST")
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)GLDDApDist.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_APVEND)&amp;bankNumber=@dtw_rurlescseq(V_APBANK)&amp;voucherNumber=@dtw_rurlescseq(V_APVOU#)&amp;lineNumber=@dtw_rurlescseq(V_APLINE)&amp;checkNumber=@dtw_rurlescseq(V_APCHK#)&amp;checkDate=@dtw_rurlescseq(checkDate)&amp;checkCode=@dtw_rurlescseq(V_APCKCD)&amp;glDDSeq=@dtw_rurlescseq(V_APDDSQ)" title="View A/P Invoice Detail - Distribution">$(F_APAMT)</a></td>
                      %elseif (V_APDDSQ != "0" && V_APDDFL == "APPAID")
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)GLDDApPymt.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_APVEND)&amp;bankNumber=@dtw_rurlescseq(V_APBANK)&amp;voucherNumber=@dtw_rurlescseq(V_APVOU#)&amp;lineNumber=@dtw_rurlescseq(V_APLINE)&amp;checkNumber=@dtw_rurlescseq(V_APCHK#)&amp;checkDate=@dtw_rurlescseq(checkDate)&amp;checkCode=@dtw_rurlescseq(V_APCKCD)&amp;glDDSeq=@dtw_rurlescseq(V_APDDSQ)" title="View A/P Invoice Detail - Payments">$(F_APAMT)</a></td>
                      %else
                          <td class="colnmbr">$(F_APAMT)</td>
                      %endif
                      <td class="colcode" $(helpCursor)><span title="$(V_srcFLDESC)">$(V_APRPTS)</span></td>
                      <td class="colalph">$(V_APINV#)</td>
                      <td class="coldate">$(F_APINVD)</td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)VendorInquiry.d2w/DISPLAY$(genericVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_APVEND)" onclick="$(inquiryWinVar)" title="Vendor Quickview">$(V_VMVNA1)</a></td>
                      <td class="colnmbr">$(V_APDSTD)</td>
                      @RtvFldDesc("(PHVEND=$(V_APVEND) or PHRTOV=$(V_APVEND)) and PHPO=$(V_APPO#)", "POPOHH", "Char(Count(*))", recordsHave)
                      %if (recordsHave>"0")
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)VendorOrderHistory.d2w/REPORT$(genericVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_APVEND)&amp;vendorName=@dtw_rurlescseq(V_VMVNA1)&amp;purchaseOrderNumber=@dtw_rurlescseq(V_APPO#)&amp;orderBy=PHPO&amp;noMenu=Y" onclick="$(drillDownWinVar)" title="View Vendor Order History">$(V_APPO#)</a></td>
                      %else
                          <td class="colnmbr">&nbsp;</td>
                      %endif
                      <td class="colalph">$(V_APMEMO)</td>
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)APInvoice.d2w/ENTRY$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;vendorNumber=@dtw_rurlescseq(V_APVEND)&amp;voucherNumber=@dtw_rurlescseq(V_APVOU#)&amp;ddReport=@dtw_rurlescseq(ddReport)&amp;glJrnl=@dtw_rurlescseq(V_APJRNL)&amp;glDDSeq=@dtw_rurlescseq(V_APDDSQ)&amp;ddDescr=@dtw_rurlescseq(ddDescr)&amp;ddCompany=@dtw_rurlescseq(ddCompany)&amp;ddFacility=@dtw_rurlescseq(ddFacility)&amp;noMenu=Y" title="View A/P Invoice">$(V_APVOU#)</a></td>
                      %if (V_APBANK != "0")
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)BankInquiry.d2w/DISPLAY$(genericVarBase)&amp;bankNumber=@dtw_rurlescseq(V_APBANK)" onclick="$(inquiryWinVar)" title="Bank Quickview">$(V_APBANK)</a></td>
                      %else
                          <td class="colnmbr">&nbsp;</td>
                      %endif
                      %if (V_APCHK# != "0")
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)APCheckInquiry.d2w/ENTRY$(genericVarBase)&amp;checkNumber=@dtw_rurlescseq(V_APCHK#)&amp;checkDate=@dtw_rurlescseq(checkDate)&amp;bankNumber=@dtw_rurlescseq(V_APBANK)" onclick="$(drillDownWinVar)" title="A/P Check Quickview">$(V_APCHK#)</a></td>
                      %else
                          <td class="colnmbr">&nbsp;</td>
                      %endif
                      <td class="coldate">$(F_APCHKD)</td>
                      <td class="colcode" $(helpCursor)><span title="$(V_pmtFLDESC)">$(V_APCKCD)</span></td>
                  </tr>
              %}
          </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) AccountsReceivable_Query (IN  CHAR(64) profileHandle,
                                                 CHAR(2)   dataBaseID,
                                                 CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (formatToPrint != "Y")
          <table $(contentTable)>
              <tr><td><a href="#top">$(topOfFormImage)</a></td></tr>
          </table>
      %endif

      <a name="accountsreceivable"></a>
      <fieldset class="legendBody">
          <legend class="legendTitle">Accounts Receivable</legend>
          	
          <table $(contentTable)>
              @DTW_ASSIGN(hdrOnce, "")
              %ROW{
                  %if (hdrOnce == "")
                      @DTW_ASSIGN(hdrOnce, "Y")
                      <tr>
                          @dtw_assign(ar_orderByVar, "$(d2wVarBase)$(searchVarBase)")
                          @Named_OrderBy_Sort("ARAMT", "$(ar_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AR_ORDERBY$(ar_orderByVar)&amp;sequence=Amount" title="Sequence By Amount"> Amount</a></th>
                          @Named_OrderBy_Sort("ARRPTS", "$(ar_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AR_ORDERBY$(ar_orderByVar)&amp;sequence=Source" title="Sequence By Source"> Source</a></th>
                          @Named_OrderBy_Sort("ARAIV#", "$(ar_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AR_ORDERBY$(ar_orderByVar)&amp;sequence=Invoice" title="Sequence By Invoice Number"> Invoice<br>Number</a></th>
                          @Named_OrderBy_Sort("ARIVDT", "$(ar_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AR_ORDERBY$(ar_orderByVar)&amp;sequence=InvDate" title="Sequence By Invoice Date"> Invoice<br>Date</a></th>
                          @Named_OrderBy_Sort("ARLOC#", "$(ar_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AR_ORDERBY$(ar_orderByVar)&amp;sequence=Location" title="Sequence By Location"> Loc</a></th>
                          @Named_OrderBy_Sort("ARBLTO", "$(ar_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AR_ORDERBY$(ar_orderByVar)&amp;sequence=Customer" title="Sequence By Customer"> Customer</a></th>
                          @Named_OrderBy_Sort("CMCNA1U", "$(ar_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AR_ORDERBY$(ar_orderByVar)&amp;sequence=CustomerName" title="Sequence By Customer Name"> Customer<br>Name</a></th>
                          @Named_OrderBy_Sort("ARORD#", "$(ar_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AR_ORDERBY$(ar_orderByVar)&amp;sequence=OrderNumber" title="Sequence By Order Number"> Order<br>Number</a></th>
                          @Named_OrderBy_Sort("ARORDT", "$(ar_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AR_ORDERBY$(ar_orderByVar)&amp;sequence=OrderDate" title="Sequence By Order Date"> Order<br>Date</a></th>
                          @Named_OrderBy_Sort("ARARPC", "$(ar_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AR_ORDERBY$(ar_orderByVar)&amp;sequence=PmtCode" title="Sequence By Payment Code"> Payment<br>Code</a></th>
                          @Named_OrderBy_Sort("ARDTPD", "$(ar_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AR_ORDERBY$(ar_orderByVar)&amp;sequence=DatePaid" title="Sequence By Date Paid"> Date Paid</a></th>
                          @Named_OrderBy_Sort("ARBANK", "$(ar_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AR_ORDERBY$(ar_orderByVar)&amp;sequence=Bank" title="Sequence By Bank"> Bank</a></th>
                          @Named_OrderBy_Sort("ARACHK", "$(ar_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/AR_ORDERBY$(ar_orderByVar)&amp;sequence=CheckNumber" title="Sequence By Check Number"> Check<br>Number</a></th>
                     </tr>
                  %endif

                  %INCLUDE "SetRowClass.icl"

                  @Check_Invoice(profileHandle, dataBaseID, V_ARAIV#, V_ARBLTO, invoiceFound)

                  @dtw_assign(invoiceDate, V_ARIVDT)
                  @dtw_assign(datePaid, V_ARDTPD)
                  @Format_Nbr($(V_ARAMT), F_ARAMT, "2", $(amtEditCode), "Y", "", "")
                  @Format_Date(V_ARIVDT, "D", F_ARIVDT)
                  @Format_Date(V_ARORDT, "D", F_ARORDT)
                  @Format_Date(V_ARDTPD, "D", F_ARDTPD)

                  <tr class="$(rowClass)">
                      %if (V_ARDDSQ != "0" && V_ARDDFL=="HDARDS")
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)GLDDArDist.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;glJrnl=@dtw_rurlescseq(V_ARJRNL)&amp;customerNumber=@dtw_rurlescseq(V_ARBLTO)&amp;locationNumber=@dtw_rurlescseq(V_ARLOC#)&amp;glDDSeq=@dtw_rurlescseq(V_ARDDSQ)&amp;glDDFile=@dtw_rurlescseq(V_ARDDFL)&amp;invoiceSequence=@dtw_rurlescseq(V_ARISEQ)&amp;paymentSequence=@dtw_rurlescseq(V_ARPSEQ)" title="View Invoice Detail - Distribution">$(F_ARAMT)</a></td>
                      %elseif (V_ARDDSQ != "0" && V_ARDDFL=="HDINVC")
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)GLDDArDist.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;glJrnl=@dtw_rurlescseq(V_ARJRNL)&amp;customerNumber=@dtw_rurlescseq(V_ARBLTO)&amp;locationNumber=@dtw_rurlescseq(V_ARLOC#)&amp;glDDSeq=@dtw_rurlescseq(V_ARDDSQ)&amp;glDDFile=@dtw_rurlescseq(V_ARDDFL)&amp;invoiceSequence=@dtw_rurlescseq(V_ARISEQ)&amp;paymentSequence=@dtw_rurlescseq(V_ARPSEQ)" title="View Invoice Detail - Revaluation">$(F_ARAMT)</a></td>
                      %elseif (V_ARDDSQ != "0" && V_ARDDFL == "ARYPTD")
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)GLDDArPymt.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;glJrnl=@dtw_rurlescseq(V_ARJRNL)&amp;customerNumber=@dtw_rurlescseq(V_ARBLTO)&amp;locationNumber=@dtw_rurlescseq(V_ARLOC#)&amp;glDDSeq=@dtw_rurlescseq(V_ARDDSQ)&amp;invoiceSequence=@dtw_rurlescseq(V_ARISEQ)&amp;paymentSequence=@dtw_rurlescseq(V_ARPSEQ)" title="View Invoice Detail - Payment">$(F_ARAMT)</a></td>
                      %else
                          <td class="colnmbr">$(F_ARAMT)</td>
                      %endif
                      <td class="colcode" $(helpCursor)><span title="$(V_FLDESC)">$(V_ARRPTS)</span></td>
                      %if (invoiceFound == "Y")
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)SelectInvoice.d2w/DISPLAY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(V_ARBLTO)&amp;invoiceNumber=@dtw_rurlescseq(V_ARAIV#)&amp;invoiceDate=@dtw_rurlescseq(invoiceDate)&amp;formatToPrint=Y" onclick="$(invoiceWinVar)" title="Invoice Quickview">$(V_ARAIV#)</a></td>
                      %else
                          <td class="colnmbr">$(V_ARAIV#)</td>
                      %endif
                      <td class="coldate"><a href="$(homeURL)$(cGIPath)ARInvoiceInquiry.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;customerNumber=@dtw_rurlescseq(V_ARBLTO)&amp;invoiceSequence=@dtw_rurlescseq(V_ARISEQ)&amp;glJrnl=@dtw_rurlescseq(V_ARJRNL)&amp;glDDSeq=@dtw_rurlescseq(V_ARDDSQ)&amp;noMenu=Y" title="View A/R Invoice">$(F_ARIVDT)</a></td>
                      <td class="colnmbr" $(helpCursor)><span title="$(V_LOLNA1)">$(V_ARLOC#)</span.</td>
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)CustomerInquiry.d2w/DISPLAY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(V_ARBLTO)&amp;shipToCustomer=@dtw_rurlescseq(V_ARCUST)" onclick="$(inquiryWinVar)" title="Customer Quickview">$(V_ARBLTO)</a></td>
                      <td class="colalph">$(V_CMCNA1)</td>
                      @RtvFldDesc("(HHBLTO=$(V_ARBLTO) or HHSHTO=$(V_ARBLTO)) and HHLIV#=$(V_ARAIV#)", "OEORHH", "Char(Count(*))", recordsHave)
                      %if (recordsHave>"0")
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)CustomerOrderHistory.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(V_ARBLTO)&amp;arInvoiceNumber=@dtw_rurlescseq(V_ARAIV#)&amp;noMenu=Y" onclick="$(drillDownWinVar)" title="View Customer Order History">$(V_ARORD#)</a></td>
                      %else
                          <td class="colnmbr">$(V_ARORD#)</td>
                      %endif
                      <td class="coldate">$(F_ARORDT)</td>

                      <td class="colcode" $(helpCursor)><span title="$(V_PYPYDS)">$(V_ARARPC)</span></td>
                      <td class="coldate">$(F_ARDTPD)</td>
                      %if (V_ARBANK != "0")
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)BankInquiry.d2w/DISPLAY$(genericVarBase)&amp;bankNumber=@dtw_rurlescseq(V_ARBANK)" onclick="$(inquiryWinVar)" title="Bank Quickview">$(V_ARBANK)</a></td>
                      %else
                          <td class="colnmbr">&nbsp;</td>
                      %endif
                      %if (V_ARACHK != "" && V_ARBANK>"0")
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)ARCheckInquiry.d2w/ENTRY$(genericVarBase)&amp;checkNumber=@dtw_rurlescseq(V_ARACHK)&amp;datePaid=@dtw_rurlescseq(datePaid)&amp;bankNumber=@dtw_rurlescseq(V_ARBANK)" onclick="$(drillDownWinVar)" title="A/R Check Quickview">$(V_ARACHK)</a></td>
                      %else
                          <td class="colalph">$(V_ARACHK)</td>
                      %endif
                  </tr>
              %}
          </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) FixedAssets_Query (IN  CHAR(64) profileHandle,
                                          CHAR(2)   dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (formatToPrint != "Y")
          <table $(contentTable)>
              <tr><td><a href="#top">$(topOfFormImage)</a></td></tr>
          </table>
      %endif

      <a name="fixedassets"></a>
      <fieldset class="legendBody">
          <legend class="legendTitle">Fixed Assets</legend>
          	
          <table $(contentTable)>
              @dtw_assign(headOnce, "")

              %ROW{
                  %if (headOnce == "")
                      @dtw_assign(headOnce, "Y")
                      <tr>
                          @dtw_assign(fa_orderByVar, "$(d2wVarBase)$(searchVarBase)")
                          @Named_OrderBy_Sort("GFAMT", "$(fa_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/FA_ORDERBY$(fa_orderByVar)&amp;sequence=Amount" title="Sequence By Amount, Asset, Site"> Amount</a></th>
                          @Named_OrderBy_Sort("GFRPTS", "$(fa_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/FA_ORDERBY$(fa_orderByVar)&amp;sequence=TransType" title="Sequence By Transaction Type, Asset, Site"> Trans<br>Type</a></th>
                          @Named_OrderBy_Sort("GFASST", "$(fa_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/FA_ORDERBY$(fa_orderByVar)&amp;sequence=Asset" title="Sequence By Asset, Site"> Asset</a></th>
                          @Named_OrderBy_Sort("GFDESC", "$(fa_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/FA_ORDERBY$(fa_orderByVar)&amp;sequence=AssetDescr" title="Sequence By Asset Description, Asset, Site"> Asset<br>Description</a></th>
                          @Named_OrderBy_Sort("GFPROP", "$(fa_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/FA_ORDERBY$(fa_orderByVar)&amp;sequence=PropType" title="Sequence By Property Type, Asset, Site"> Property<br>Type</a></th>
                          @Named_OrderBy_Sort("GFBDDT", "$(fa_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/FA_ORDERBY$(fa_orderByVar)&amp;sequence=BeginDeprDate" title="Sequence By Begin Depr Date, Asset, Site">Begin<br>Depr<br>Date</a></th>
                          @Named_OrderBy_Sort("GFLFYY", "$(fa_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/FA_ORDERBY$(fa_orderByVar)&amp;sequence=Life" title="Sequence By Life, Asset, Site">Life</a></th>
                          @Named_OrderBy_Sort("GFDPCD", "$(fa_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/FA_ORDERBY$(fa_orderByVar)&amp;sequence=DeprMeth" title="Sequence By Depreciation Method, Asset, Site"> Depr<br>Meth</a></th>
                          @Named_OrderBy_Sort("GFPER#", "$(fa_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/FA_ORDERBY$(fa_orderByVar)&amp;sequence=DeprPeriod" title="Sequence By Depreciation Period, Asset, Site">Depr<br>Period</a></th>
                          @Named_OrderBy_Sort("GFSITE", "$(fa_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/FA_ORDERBY$(fa_orderByVar)&amp;sequence=SiteName" title="Sequence By Site, Asset "> Site</a></th>
                          @Named_OrderBy_Sort("GFSCHD", "$(fa_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/FA_ORDERBY$(fa_orderByVar)&amp;sequence=Schedule" title="Sequence By Schedule, Asset, Site">Sched</a></th>
                          @Named_OrderBy_Sort("GFFPCD", "$(fa_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/FA_ORDERBY$(fa_orderByVar)&amp;sequence=RetireCode" title="Sequence By Retirement Code, Asset, Site"> Retire<br>Code</a></th>
                          @Named_OrderBy_Sort("GFRTDT", "$(fa_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/FA_ORDERBY$(fa_orderByVar)&amp;sequence=RetireDate" title="Sequence By Retirement Date, Asset, Site"> Retirement<br>Date</a></th>
                          @Named_OrderBy_Sort("GFRRES", "$(fa_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/FA_ORDERBY$(fa_orderByVar)&amp;sequence=RetireReason" title="Sequence By Retirement Reason, Asset, Site"> Retirement<br>Reason</a></th>
                          @Named_OrderBy_Sort("GFFPCD", "$(fa_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/FA_ORDERBY$(fa_orderByVar)&amp;sequence=TrfCode" title="Sequence By Transfer Code, Asset, Site"> Transfer<br>Code</a></th>
                          @Named_OrderBy_Sort("GFRTDT", "$(fa_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/FA_ORDERBY$(fa_orderByVar)&amp;sequence=TrfDate" title="Sequence By Transfer Date, Asset, Site"> Transfer<br>Date</a></th>
                          @Named_OrderBy_Sort("GFTSIT", "$(fa_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/FA_ORDERBY$(fa_orderByVar)&amp;sequence=TrfToAsset" title="Sequence By Transfer To Asset"> Transfer To<br>Asset</a></th>
                          @Named_OrderBy_Sort("GFTFPD", "$(fa_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/FA_ORDERBY$(fa_orderByVar)&amp;sequence=TrfPeriod" title="Sequence By Transfer Period, Asset, Site"> Transfer<br>Period</a></th>
                          @Named_OrderBy_Sort("GFTSIT", "$(fa_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/FA_ORDERBY$(fa_orderByVar)&amp;sequence=TrfFrAsset" title="Sequence By Transfer From Asset"> Transfer From<br>Asset</a></th>
                     </tr>
                  %endif

                  %INCLUDE "SetRowClass.icl"

                  @dtw_assign(SV_GFPER#, V_GFPER#)
                  @PeriodFromCYP(V_GFRTPD)
                  @PeriodFromCYP(V_GFTFPD)
                  @PeriodFromCYP(V_GFPER#)
                  @Format_Nbr($(V_GFAMT), F_GFAMT, "2", $(amtEditCode), "Y", "", "")
                  @Format_Date(V_GFRTDT, "D", F_GFRTDT)
                  @Format_Date(V_GFBDDT, "D", F_GFBDDT)

                  <tr class="$(rowClass)">
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)GLDDFAAssetDetail.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;siteNumber=@dtw_rurlescseq(V_GFSITE)&amp;assetNumber=@dtw_rurlescseq(V_GFASST)&amp;scheduleNumber=@dtw_rurlescseq(V_GFSCHD)&amp;ddRptRef=@dtw_rurlescseq(V_GFRPTS)&amp;deprPeriod=@dtw_rurlescseq(SV_GFPER#)&amp;glJrnl=@dtw_rurlescseq(V_GFJRNL)&amp;glDDSeq=@dtw_rurlescseq(V_GFDDSQ)" title="View Asset Drill Down History For Transaction">$(F_GFAMT)</a></td>
                      <td class="colcode" $(helpCursor)><span title="$(V_FLDESC)">$(V_GFRPTS)</span></td>
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)GLDDFAAssetDetail.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;siteNumber=@dtw_rurlescseq(V_GFSITE)&amp;assetNumber=@dtw_rurlescseq(V_GFASST)&amp;scheduleNumber=@dtw_rurlescseq(V_GFSCHD)&amp;glJrnl=@dtw_rurlescseq(V_GFJRNL)&amp;glDDSeq=@dtw_rurlescseq(V_GFDDSQ)" title="View Asset Drill Down History">$(V_GFASST)</a></td>
                      @RtvFldDesc("AMSITE=$(V_GFSITE) and AMASST=$(V_GFASST)", "FAMSTR", "Char(Count(*))", recordsHave)
                      %if (recordsHave>"0")
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)FAAssetSelect.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;siteNumber=@dtw_rurlescseq(V_GFSITE)&amp;assetNumber=@dtw_rurlescseq(V_GFASST)&amp;scheduleNumber=@dtw_rurlescseq(V_GFSCHD)&amp;glJrnl=@dtw_rurlescseq(V_GFJRNL)&amp;glDDSeq=@dtw_rurlescseq(V_GFDDSQ)" title="View Asset">$(V_GFDESC)</a></td>
                      %else
                          <td class="colalph">$(V_GFDESC)</td>
                      %endif
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)FAPropertyInquiry.d2w/DISPLAY$(genericVarBase)&amp;propertyType=@dtw_rurlescseq(V_GFPROP)" onclick="$(inquiryWinVar)" title="Property Type Quickview">$(V_GFPROP)</a></td>
                      <td class="coldate">$(F_GFBDDT)</td>
                      <td class="colnmbr">$(V_GFLFYY)/$(V_GFLFMM)</td>
                      <td class="colcode"><a href="$(homeURL)$(cGIPath)FADeprMethodInquiry.d2w/DISPLAY$(genericVarBase)&amp;deprMethod=@dtw_rurlescseq(V_GFDPCD)" onclick="$(inquiryWinVar)" title="Depreciation Method Quickview">$(V_GFDPCD)</a></td>
                      <td class="colnmbr">$(V_GFPER#)</td>
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)FASiteInquiry.d2w/DISPLAY$(genericVarBase)&amp;siteNumber=@dtw_rurlescseq(V_GFSITE)" onclick="$(inquiryWinVar)" title="Site Quickview">$(V_GFSITE)</a></td>
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)FAScheduleInquiry.d2w/DISPLAY$(genericVarBase)&amp;scheduleNumber=@dtw_rurlescseq(V_GFSCHD)" onclick="$(inquiryWinVar)" title="Schedule Quickview">$(V_GFSCHD)</a></td>
                      %if (V_GFRPTS=="RET")
                          <td class="colcode">$(V_GFFPCD)</td>
                          <td class="coldate">$(F_GFRTDT)</td>
                          <td class="colalph">$(V_GFRRES)</td>
                      %else
                          <td class="colalph">&nbsp;</td>
                          <td class="colalph">&nbsp;</td>
                          <td class="colalph">&nbsp;</td>
                      %endif
                      %if (V_GFRPTS == "TRF" && V_GFTRFG == "F")
                          <td class="colcode">$(V_GFFPCD)</td>
                          <td class="coldate">$(F_GFRTDT)</td>
                          <td class="colnmbr">$(V_GFTSIT)-$(V_GFTAST)</td>
                      %else
                          <td class="colalph">&nbsp;</td>
                          <td class="colalph">&nbsp;</td>
                          <td class="colalph">&nbsp;</td>
                      %endif
                      %if (V_GFRPTS == "TRF")
                          <td class="colnmbr">$(V_GFTFPD)</td>
                      %else
                          <td class="colalph">&nbsp;</td>
                      %endif
                      %if (V_GFRPTS == "TRF" && V_GFTRFG == "T")
                          <td class="colnmbr">$(V_GFTSIT)-$(V_GFTAST)</td>
                      %else
                          <td class="colalph">&nbsp;</td>
                      %endif
                  </tr>
              %}
          </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Inventory_Query (IN CHAR(64) profileHandle,
                                       CHAR(2)   dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (formatToPrint != "Y")
          <table $(contentTable)>
              <tr><td><a href="#top">$(topOfFormImage)</a></td></tr>
          </table>
      %endif

      <a name="inventory"></a>
      <fieldset class="legendBody">
          <legend class="legendTitle">Inventory</legend>
          	
          <table $(contentTable)>
              @DTW_ASSIGN(hdrOnce, "")
              %ROW{

                  %if (hdrOnce == "")
                      @DTW_ASSIGN(hdrOnce, "Y")
                      <tr>
                          @dtw_assign(iv_orderByVar, "$(d2wVarBase)$(searchVarBase)")
                          @Named_OrderBy_Sort("IVAMT", "$(iv_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/IV_ORDERBY$(iv_orderByVar)&amp;sequence=Amount" title="Sequence By Amount"> Amount</a></th>
                          @Named_OrderBy_Sort("IVTRDT", "$(iv_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/IV_ORDERBY$(iv_orderByVar)&amp;sequence=TransDate" title="Sequence By Transaction Date"> Trans<br>Date</a></th>
                          @Named_OrderBy_Sort("IVIVTT", "$(iv_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/IV_ORDERBY$(iv_orderByVar)&amp;sequence=TransType" title="Sequence By Transaction Type"> Trans<br>Type</a></th>
                          @Named_OrderBy_Sort("IVITEM", "$(iv_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/IV_ORDERBY$(iv_orderByVar)&amp;sequence=Item" title="Sequence By Item Number"> Item Number</a></th>
                          @Named_OrderBy_Sort("IMIMDS", "$(iv_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/IV_ORDERBY$(iv_orderByVar)&amp;sequence=ItemDesc" title="Sequence By Description"> Description</a></th>
                          @Named_OrderBy_Sort("IVWHS", "$(iv_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/IV_ORDERBY$(iv_orderByVar)&amp;sequence=Warehouse" title="Sequence By Warehouse"> Whs</a></th>
                          @Named_OrderBy_Sort("IVPLT", "$(iv_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/IV_ORDERBY$(iv_orderByVar)&amp;sequence=Plant" title="Sequence By Plant"> Plant</a></th>
                          @Named_OrderBy_Sort("IVMORD", "$(iv_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/IV_ORDERBY$(iv_orderByVar)&amp;sequence=MfgOrder" title="Sequence By Mfg Order"> Mfg Order</a></th>
                          @Named_OrderBy_Sort("IVQTY", "$(iv_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/IV_ORDERBY$(iv_orderByVar)&amp;sequence=Quantity" title="Sequence By Quantity"> Quantity</a></th>
                          @Named_OrderBy_Sort("IVPCLS", "$(iv_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/IV_ORDERBY$(iv_orderByVar)&amp;sequence=ProdClass" title="Sequence By Product Class"> Prod<br>Class</a></th>
                          @Named_OrderBy_Sort("IVITC", "$(iv_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/IV_ORDERBY$(iv_orderByVar)&amp;sequence=InvType" title="Sequence By Inventory Type"> Inv<br>Type</a></th>
                     </tr>
                  %endif

                  %INCLUDE "SetRowClass.icl"

                  @Format_Nbr($(V_IVAMT), F_IVAMT, "2", $(amtEditCode), "Y", "", "")
                  @Format_Nbr($(V_IVQTY), F_IVQTY, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                  @Format_Date(V_IVTRDT, "D", F_IVTRDT)

                  <tr class="$(rowClass)">
                      %if (V_IVOSEQ != "0")
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)GLDDIvOrigTrans.d2w/ENTRY$(d2wVarBase)&amp;origTransSequence=@dtw_rurlescseq($(V_IVOSEQ))" title="View Transaction">$(F_IVAMT)</a></td>
                      %else
                          <td class="colnmbr">$(F_IVAMT)</td>
                      %endif
                      <td class="coldate">$(F_IVTRDT)</td>
                      <td class="colalph" $(helpCursor)><span title="$(V_TTDESC)">$(V_IVIVTT)</span></td>
                      %if (V_IMIMDS != "")
                          <td class="colalph">$(V_IVITEM)</td>
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemInquiry.d2w/DISPLAY$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq($(V_IVITEM))" onclick="$(inquiryWinVar)" title="Item Quickview">$(V_IMIMDS)</a></td>
                      %else
                          <td class="colalph">$(V_IVITEM)</td>
                          <td class="colalph">&nbsp;</td>
                      %endif
                      <td class="colnmbr" $(helpCursor)><span title="$(V_WHWHNM)">$(V_IVWHS)</span></td>
                      <td class="colnmbr" $(helpCursor)><span title="$(V_PLNAME)">$(V_IVPLT)</span></td>
                      %if (V_IVMORD != "")
                          @RtvFldDesc("OHPLT=$(V_IVPLT) and OHORD='$(V_IVMORD)'", "HDMOHM", "CHAR(COUNT(OHORD))", mfgOrderCnt)
                      %else
                          @dtw_assign(mfgOrderCnt, "0")
                      %endif
                      %if (mfgOrderCnt > "0")
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)SelectMfgOrder.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq($(V_IVPLT))&amp;mfgOrder=@dtw_rurlescseq($(V_IVMORD))" onclick="$(inquiryWinVar)" title="View Mfg Order">$(V_IVMORD)</a></td>
                      %else
                          <td class="colalph">$(V_IVMORD)</td>
                      %endif
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)TransactionHistoryInquiry.d2w/DISPLAY$(genericVarBase)&amp;origTransSequence=@dtw_rurlescseq($(V_IVOSEQ))&amp;transSequence=@dtw_rurlescseq($(V_IVDSEQ))" onclick="$(inquiryWinVar)" title="Transaction Quickview">$(F_IVQTY)</a></td>
                      <td class="colalph" $(helpCursor)><span title="$(V_PCPCDS)">$(V_IVPCLS)</span></td>
                      <td class="colalph" $(helpCursor)><span title="$(V_ITDESC)">$(V_IVITC)</span></td>
                  </tr>
              %}
          </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Purchasing_Query (IN CHAR(64) profileHandle,
                                        CHAR(2)   dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (formatToPrint != "Y")
          <table $(contentTable)>
              <tr><td><a href="#top">$(topOfFormImage)</a></td></tr>
          </table>
      %endif

      <a name="purchasing"></a>
      <fieldset class="legendBody">
          <legend class="legendTitle">Purchasing</legend>
          	
          <table $(contentTable)>
              @DTW_ASSIGN(hdrOnce, "")
              %ROW{

                  %if (hdrOnce == "")
                      @DTW_ASSIGN(hdrOnce, "Y")
                      <tr>
                          @dtw_assign(po_orderByVar, "$(d2wVarBase)$(searchVarBase)")
                          @Named_OrderBy_Sort("POAMT", "$(po_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/PO_ORDERBY$(po_orderByVar)&amp;sequence=Amount" title="Sequence By Amount"> Amount</a></th>
                          @Named_OrderBy_Sort("POTRDT", "$(po_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/PO_ORDERBY$(po_orderByVar)&amp;sequence=TransDate" title="Sequence By Transaction Date"> Trans<br>Date</a></th>
                          @Named_OrderBy_Sort("POIVTT", "$(po_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/PO_ORDERBY$(po_orderByVar)&amp;sequence=TransType" title="Sequence By Transaction Type"> Trans<br>Type</a></th>
                          @Named_OrderBy_Sort("POITEM", "$(po_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/PO_ORDERBY$(po_orderByVar)&amp;sequence=Item" title="Sequence By Item Number"> Item Number</a></th>
                          @Named_OrderBy_Sort("POIMDS", "$(po_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/PO_ORDERBY$(po_orderByVar)&amp;sequence=ItemDesc" title="Sequence By Description"> Description</a></th>
                          @Named_OrderBy_Sort("POWHS", "$(po_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/PO_ORDERBY$(po_orderByVar)&amp;sequence=Warehouse" title="Sequence By Warehouse"> Whs</a></th>
                          @Named_OrderBy_Sort("POPLT", "$(po_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/PO_ORDERBY$(po_orderByVar)&amp;sequence=Plant" title="Sequence By Plant"> Plant</a></th>
                          @Named_OrderBy_Sort("POPO", "$(po_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/PO_ORDERBY$(po_orderByVar)&amp;sequence=PurchaseOrder" title="Sequence By Purchase Order"> Purchase<br>Order</a></th>
                          @Named_OrderBy_Sort("POQTY", "$(po_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/PO_ORDERBY$(po_orderByVar)&amp;sequence=Quantity" title="Sequence By Quantity"> Quantity</a></th>
                          @Named_OrderBy_Sort("POPCLS", "$(po_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/PO_ORDERBY$(po_orderByVar)&amp;sequence=ProdClass" title="Sequence By Product Class"> Prod<br>Class</a></th>
                          @Named_OrderBy_Sort("POITC", "$(po_orderBy)", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/PO_ORDERBY$(po_orderByVar)&amp;sequence=InvType" title="Sequence By Inventory Type"> Inv<br>Type</a></th>
                     </tr>
                  %endif

                  %INCLUDE "SetRowClass.icl"

                  @Format_Nbr($(V_POAMT), F_POAMT, "2", $(amtEditCode), "Y", "", "")
                  @Format_Nbr($(V_POQTY), F_POQTY, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                  @Format_Date(V_POTRDT, "D", F_POTRDT)

                  <tr class="$(rowClass)">
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)GLDDPoReceiptDetail.d2w/ENTRY$(d2wVarBase)&amp;poNumber=@dtw_rurlescseq($(V_POPO))&amp;receiptSeq=@dtw_rurlescseq($(V_POSEQ))" title="View P/O Receipt Detail">$(F_POAMT)</a></td>
                      <td class="coldate">$(F_POTRDT)</td>
                      <td class="colalph" $(helpCursor)><span title="$(V_TTDESC)">$(V_POIVTT)</span></td>
                      %if (V_POPOEC != "N")
                          <td class="colalph">$(V_POITEM)</td>
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemInquiry.d2w/DISPLAY$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq($(V_POITEM))" onclick="$(inquiryWinVar)" title="Item Quickview">$(V_POIMDS)</a></td>
                      %else
                          <td class="colalph">$(V_POITEM)</td>
                          <td class="colalph">&nbsp;</td>
                      %endif
                      <td class="colnmbr" $(helpCursor)><span title="$(V_WHWHNM)">$(V_POWHS)</span></td>
                      <td class="colnmbr" $(helpCursor)><span title="$(V_PLNAME)">$(V_POPLT)</span></td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)SelectPurchaseOrderHistory.d2w/REPORT$(genericVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_POVEND)&amp;purchaseOrderNumber=@dtw_rurlescseq(V_POPO)&amp;orderSequence=@dtw_rurlescseq(V_POSEQ)&amp;noMenu=Y" onclick="$(inquiryWinVar)" title="View Purchase Order">$(V_POPO)</a></td>
                      <td class="colnmbr">$(F_POQTY)</a></td>
                      <td class="colalph" $(helpCursor)><span title="$(V_PCPCDS)">$(V_POPCLS)</span></td>
                      <td class="colalph" $(helpCursor)><span title="$(V_ITDESC)">$(V_POITC)</span></td>
                  </tr>
              %}
          </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) GeneralLedger_Query (IN  CHAR(64) profileHandle,
                                            CHAR(2)   dataBaseID,
                                            CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (formatToPrint != "Y")
          <table $(contentTable)>
              <tr><td><a href="#top">$(topOfFormImage)</a></td></tr>
          </table>
      %endif

      <a name="generalledger"></a>
      <fieldset class="legendBody">
          <legend class="legendTitle">General Ledger</legend>
          	
          <table $(contentTable)>
              @dtw_assign(gl_orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @Named_OrderBy_Sort("TDAMT", "$(gl_orderBy)", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/GL_ORDERBY$(gl_orderByVar)&amp;sequence=Amount" title="Sequence By Amount, Date, Journal, Sequence"> Amount</a></th>
                  @Named_OrderBy_Sort("TDJRNL", "$(gl_orderBy)", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/GL_ORDERBY$(gl_orderByVar)&amp;sequence=Journal" title="Sequence By Journal, Date, Sequence"> Journal</a></th>
                  @Named_OrderBy_Sort("TJTTYP", "$(gl_orderBy)", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/GL_ORDERBY$(gl_orderByVar)&amp;sequence=Type" title="Sequence By Transaction Type, Date, Journal, Sequence"> Type</a></th>
                  @Named_OrderBy_Sort("TDREF", "$(gl_orderBy)", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/GL_ORDERBY$(gl_orderByVar)&amp;sequence=Reference" title="Sequence By Reference, Date, Journal, Sequence"> Reference</a></th>
                  @Named_OrderBy_Sort("TDPER#", "$(gl_orderBy)", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/GL_ORDERBY$(gl_orderByVar)&amp;sequence=Period" title="Sequence By Period, Date, Journal, Sequence"> Period</a></th>
                  @Named_OrderBy_Sort("TDDESC", "$(gl_orderBy)", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/GL_ORDERBY$(gl_orderByVar)&amp;sequence=Description" title="Sequence By Description, Date, Journal, Sequence"> Description</a></th>
                  @Named_OrderBy_Sort("TDTDTE", "$(gl_orderBy)", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/GL_ORDERBY$(gl_orderByVar)&amp;sequence=Date" title="Sequence By Date, Journal, Sequence"> Date</a></th>
              </tr>

              %ROW{
                  %INCLUDE "SetRowClass.icl"

                  @dtw_assign(glDate, V_TDTDTE)
                  @dtw_assign(glPer, V_TDPER#)

                  @PeriodFromCYP(V_TDPER#)
                  @Format_Nbr($(V_TDAMT), F_TDAMT, "2", $(amtEditCode), "Y", "", "")
                  @Format_Date(V_TDTDTE, "D", F_TDTDTE)

                  <tr class="$(rowClass)">
                      <td class="colnmbr">$(F_TDAMT)</td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)GLDDGLJrnl.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;glJrnl=@dtw_rurlescseq(V_TDJRNL)&amp;glPer=@dtw_rurlescseq(glPer)&amp;glDate=@dtw_rurlescseq(glDate)&amp;glJrnlSeq=@dtw_rurlescseq(V_TDJSEQ)" title="View General Ledger Journal">$(V_TDJRNL)</a></td>
                      <td class="colalph" $(helpCursor)><span title="$(V_FLDESC)">$(V_TJTTYP)</span></td>
                      <td class="colalph">$(V_TDREF)</td>
                      <td class="colnmbr">$(V_TDPER#)</td>
                      <td class="colalph">$(V_TDDESC)</td>
                      <td class="coldate">$(F_TDTDTE)</td>
                      %if (V_TDSEQ# != "0")
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)GLDDAcctJrnlComment.d2w/ENTRY$(genericVarBase)&amp;glJrnl=@dtw_rurlescseq(V_TDJRNL)&amp;glPer=@dtw_rurlescseq(glPer)&amp;glDate=@dtw_rurlescseq(glDate)&amp;glJrnlSeq=@dtw_rurlescseq(V_TDJSEQ)&amp;glJrnlRec=@dtw_rurlescseq(V_TDREC)&amp;glLdSeq=@dtw_rurlescseq(V_TDSEQ#)" onclick="$(commentWinVar)">$(commentView)</a></td>
                      %endif
                  </tr>
              %}
          </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Other_Query (IN  CHAR(64) profileHandle,
                                    CHAR(2)   dataBaseID,
                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (formatToPrint != "Y")
          <table $(contentTable)>
              <tr><td><a href="#top">$(topOfFormImage)</a></td></tr>
          </table>
      %endif

      <a name="other"></a>
      <fieldset class="legendBody">
          <legend class="legendTitle">Other</legend>
          	
          <table $(contentTable)>
              @dtw_assign(oth_orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @Named_OrderBy_Sort("TDAMT", "oth_orderBy", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/OTH_ORDERBY$(oth_orderByVar)&amp;sequence=Amount" title="Sequence By Amount, Date, Journal, Sequence"> Amount</a></th>
                  @Named_OrderBy_Sort("TDJRNL", "oth_orderBy", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/OTH_ORDERBY$(oth_orderByVar)&amp;sequence=Journal" title="Sequence By Journal, Date, Sequence"> Journal</a></th>
                  @Named_OrderBy_Sort("TJTTYP", "oth_orderBy", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/OTH_ORDERBY$(oth_orderByVar)&amp;sequence=Type" title="Sequence By Transaction Type, Date, Journal, Sequence"> Type</a></th>
                  @Named_OrderBy_Sort("TDREF", "oth_orderBy", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/OTH_ORDERBY$(oth_orderByVar)&amp;sequence=Reference" title="Sequence By Reference, Date, Journal, Sequence"> Reference</a></th>
                  @Named_OrderBy_Sort("TDPER#", "oth_orderBy", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/OTH_ORDERBY$(oth_orderByVar)&amp;sequence=Period" title="Sequence By Period, Date, Journal, Sequence"> Period</a></th>
                  @Named_OrderBy_Sort("TDDESC", "oth_orderBy", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/OTH_ORDERBY$(oth_orderByVar)&amp;sequence=Description" title="Sequence By Description, Date, Journal, Sequence"> Description</a></th>
                  @Named_OrderBy_Sort("TDTDTE", "oth_orderBy", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/OTH_ORDERBY$(oth_orderByVar)&amp;sequence=Date" title="Sequence By Date, Journal, Sequence"> Date</a></th>
              </tr>

              %ROW{
                  %INCLUDE "SetRowClass.icl"

                  @dtw_assign(glDate, V_TDTDTE)
                  @dtw_assign(glPer, V_TDPER#)

                  @PeriodFromCYP(V_TDPER#)
                  @Format_Nbr($(V_TDAMT), F_TDAMT, "2", $(amtEditCode), "Y", "", "")
                  @Format_Date(V_TDTDTE, "D", F_TDTDTE)

                  %if (V_TDAPID=="IV" || V_TDAPID=="PO")
                      @RtvFldDesc("TTTYPE='$(V_TDREF)'", "HDTTYP", "TTDESC", referenceDesc)
                  %else
                      @RtvFldDesc("FLTYPE='$(V_TDAPID)FEED' and FLVALU='$(V_TDREF)'", "SYFLAG", "FLDESC", referenceDesc)
                      %if (referenceDesc == "" && V_TDAPID=="AP")
                          @RtvFldDesc("VMVEND=$(V_TDREF)", "HDVEND", "VMVNA1", referenceDesc)
                      %endif
                  %endif
                  <tr class="$(rowClass)">
                      <td class="colnmbr">$(F_TDAMT)</td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)GLDDGLJrnl.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;glJrnl=@dtw_rurlescseq(V_TDJRNL)&amp;glPer=@dtw_rurlescseq(glPer)&amp;glDate=@dtw_rurlescseq(glDate)&amp;glJrnlSeq=@dtw_rurlescseq(V_TDJSEQ)" title="View General Ledger Journal">$(V_TDJRNL)</a></td>
                      <td class="colalph">$(V_TJTTYP)</td>
                      <td class="colalph" $(helpCursor)><span title="$(referenceDesc)">$(V_TDREF)</span></td>
                      <td class="colnmbr">$(V_TDPER#)</td>
                      <td class="colalph">$(V_TDDESC)</td>
                      <td class="coldate">$(F_TDTDTE)</td>
                      %if (V_TDSEQ# != "0")
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)GLDDAcctJrnlComment.d2w/ENTRY$(genericVarBase)&amp;glJrnl=@dtw_rurlescseq(V_TDJRNL)&amp;glPer=@dtw_rurlescseq(glPer)&amp;glDate=@dtw_rurlescseq(glDate)&amp;glJrnlSeq=@dtw_rurlescseq(V_TDJSEQ)&amp;glJrnlRec=@dtw_rurlescseq(V_TDREC)&amp;glLdSeq=@dtw_rurlescseq(V_TDSEQ#)" onclick="$(commentWinVar)">$(commentView)</a></td>
                      %endif
                  </tr>
              %}
          </table>
      </fieldset>
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %if (formatToPrint != "Y")
      @DTW_ASSIGN(ap_orderBy, "VMVNA1U,APVOU#,APLINE")
      @DTW_ASSIGN(ar_orderBy, "ARAIV#,ARIVDT,ARBLTO,ARISEQ")
      @DTW_ASSIGN(fa_orderBy, "GFRPTS,GFSITE,GFASST")
      @DTW_ASSIGN(iv_orderBy, "IVTRDT DESC,IVITEM")
      @DTW_ASSIGN(po_orderBy, "POTRDT DESC,POITEM")
      @DTW_ASSIGN(gl_orderBy, "TDTDTE,TDJRNL,TDJSEQ,TDREC")
      @DTW_ASSIGN(oth_orderBy, "TDTDTE,TDJRNL,TDJSEQ,TDREC")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, "GLDDSubAP", ap_orderBy, ap_orderByDisplay)
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, "GLDDSubAR", ar_orderBy, ar_orderByDisplay)
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, "GLDDSubFA", fa_orderBy, fa_orderByDisplay)
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, "GLDDSubIV", iv_orderBy, iv_orderByDisplay)
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, "GLDDSubPO", po_orderBy, po_orderByDisplay)
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, "GLDDSubGL", gl_orderBy, gl_orderByDisplay)
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, "GLDDSubOTH", oth_orderBy, oth_orderByDisplay)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(AP_ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Amount")
      %if (ap_orderBy == "APAMT,APVOU#,APLINE")
          @DTW_ASSIGN(ap_orderBy, "APAMT DESC,APVOU#,APLINE")
          @DTW_ASSIGN(ap_orderByDisplay, "Amount (descending), Voucher")
      %else
          @DTW_ASSIGN(ap_orderBy, "APAMT,APVOU#,APLINE")
          @DTW_ASSIGN(ap_orderByDisplay, "Amount, Voucher")
      %endif
  %elseif (sequence == "Source")
      %if (ap_orderBy == "APRPTS,APVOU#,APLINE")
          @DTW_ASSIGN(ap_orderBy, "APRPTS DESC,APVOU#,APLINE")
