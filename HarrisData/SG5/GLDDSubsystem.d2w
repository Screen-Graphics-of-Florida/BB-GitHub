          @DTW_ASSIGN(ap_orderByDisplay, "Bank, Voucher")
      %endif
  %elseif (sequence == "CheckNumber")
      %if (ap_orderBy == "APCHK#,APVOU#,APLINE")
          @DTW_ASSIGN(ap_orderBy, "APCHK# DESC,APVOU#,APLINE")
          @DTW_ASSIGN(ap_orderByDisplay, "Check (descending), Voucher")
      %else
          @DTW_ASSIGN(ap_orderBy, "APCHK#,APVOU#,APLINE")
          @DTW_ASSIGN(ap_orderByDisplay, "Check, Voucher")
      %endif
