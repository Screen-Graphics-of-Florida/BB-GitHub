%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Factor Control Maintenance"
  d2wName                 = "FactorControlMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName             = "HARFCU_E"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.invoiceFormatType.value =="" ||
                      document.Chg.termsCodeValue.value =="" ||
                      document.Chg.maxInvoices.value =="" )
                         {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.daysForShipCompl, 3, 0) &&
                      editNum(document.Chg.lastAssignment, 4, 0) &&
                      editNum(document.Chg.maxInvoices, 5, 0)

                      )
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "FACTORCONTROLMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " HDFFCT ", fileSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @dtw_assign(sec_01, sec_02)
      @dtw_assign(sec_03, "N")

      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "invoiceFormatType")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@ifmt", "invoiceFormatType")      @dtw_assign(Err_FCIFMT, fieldValue)
                          @DecatErr_Field("@@trmv", "termsCodeValue")         @dtw_assign(Err_FCTRMV, fieldValue)
                          @DecatErr_Field("@@dysh", "daysForShipCompl")       @dtw_assign(Err_FCDYSH, fieldValue)
                          @DecatErr_Field("@@asgn", "lastAssignment")         @dtw_assign(Err_FCASGN, fieldValue)
                          @DecatErr_Field("@@maxi", "maxInvoices")            @dtw_assign(Err_FCMAXI, fieldValue)
                      %endif

                      @Decat_Field("@@ifmt")   @dtw_assign(V_FCIFMT, fieldValue)
                      @Decat_Field("@@trmv")   @dtw_assign(V_FCTRMV, fieldValue)
                      @Decat_Field("@@dysh")   @dtw_assign(V_FCDYSH, fieldValue)
                      @Decat_Field("@@asgn")   @dtw_assign(V_FCASGN, fieldValue)
                      @Decat_Field("@@maxi")   @dtw_assign(V_FCMAXI, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(V_FCMAXI,   "5000")
                      %endif

                      @dtw_assign(errFound, "")

                  %else
                      @dtw_assign(focusField, "invoiceFormatType")
                  %endif

                  @RtvFldDesc("FLTYPE='DORS' and FLVALU='$(V_FCIFMT)'", "SYFLAG", "FLDESC", fieldDesc)
                  @SetTextOvr(Err_FCIFMT)
                  <tr><td class="dsphdr"><span $(textOvr)>Invoice Format Type</span></td>
                      <td class="inputalph"><input type="text" name="invoiceFormatType" value="$(V_FCIFMT)" size="5" maxlength="1">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=DORS&amp;flagSrchHdr=@dtw_rurlescseq("Invoice Format Type")&amp;docName=Chg&amp;fldName=invoiceFormatType&amp;fldDesc=invoiceFormatTypeDesc" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage)</a>
                                            <input type="text" disabled name="invoiceFormatTypeDesc" value="$(fieldDesc)" size="30">
                      </td>
                  </tr>
                  @DspErrMsg(Err_FCIFMT)

                  @RtvFldDesc("FLTYPE='FACTTRMVAL' and FLVALU='$(V_FCTRMV)'", "SYFLAG", "FLDESC", fieldDesc)
                  @SetTextOvr(Err_FCTRMV)
                  <tr><td class="dsphdr"><span $(textOvr)>Terms Code Value</span></td>
                      <td class="inputalph"><input type="text" name="termsCodeValue" value="$(V_FCTRMV)" size="5" maxlength="1">
                                            <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=FACTTRMVAL&amp;flagSrchHdr=@dtw_rurlescseq("Terms Code Value")&amp;docName=Chg&amp;fldName=termsCodeValue&amp;fldDesc=termsCodeValueDesc" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage)</a>
                                            <input type="text" disabled name="termsCodeValueDesc" value="$(fieldDesc)" size="30">
                      </td>
                  </tr>
                  @DspErrMsg(Err_FCTRMV)

                  @SetTextOvr(Err_FCDYSH)
                  <tr><td class="dsphdr"><span $(textOvr)>Days For Ship Completion Date</span></td>
                      <td class="inputnmbr"><input type="text" name="daysForShipCompl" value="$(V_FCDYSH)" size="5" maxlength="3"></td>
                  </tr>
                  @DspErrMsg(Err_FCDYSH)

                  @SetTextOvr(Err_FCASGN)
                  <tr><td class="dsphdr"><span $(textOvr)>Last Assignment</span></td>
                      <td class="inputnmbr"><input type="text" name="lastAssignment" value="$(V_FCASGN)" size="5" maxlength="4"></td>
                  </tr>
                  @DspErrMsg(Err_FCASGN)

                  @SetTextOvr(Err_FCMAXI)
                  <tr><td class="dsphdr"><span $(textOvr)>Maximum Number of Invoices Per Assignment</span></td>
                      <td class="inputnmbr"><input type="text" name="maxInvoices" value="$(V_FCMAXI)" size="5" maxlength="5"> $(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_FCMAXI)
              %}
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HARFCU_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (sec_02 == "N")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @RtvFldDesc("", "HDFFCT", "Char(Count(*))", RecCount)
      %if (RecCount>"0")
          @dtw_assign(maintenanceCode,"C")
      %else
          @dtw_assign(maintenanceCode,"A")
      %endif

      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @dtw_mUPPERCASE(invoiceFormatType)
  @dtw_mUPPERCASE(termsCodeValue)

  @dtw_assign(daysForShipCompl,@dtw_rstrip(daysForShipCompl))
  @dtw_assign(lastAssignment,@dtw_rstrip(lastAssignment))
  @dtw_assign(maxInvoices,@dtw_rstrip(maxInvoices))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@ifmt", invoiceFormatType)
  @Concat_Field("@@trmv", termsCodeValue)
  @Concat_Field("@@dysh", daysForShipCompl)
  @Concat_Field("@@asgn", lastAssignment)
  @Concat_Field("@@maxi", maxInvoices)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, "Factor Control", "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(backHome)$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
