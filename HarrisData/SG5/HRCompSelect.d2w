%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title		= "Company"
  d2wName              = "HRCompSelect.d2w"
  attachFolder         = "HRCompany"
  d2wVarBase           = "$(genericVarBase)&amp;hrCompany=@dtw_rurlescseq(hrCompany)"
  nextPrevVar          = "$(d2wVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  wildDftVar           = "REPORT$(d2wVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  advSrchVar           = "&amp;backHome=@dtw_rurlescseq(backHome)"
  programName          = "HHRCOU"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  RPT_MAX_ROWS 	= "10"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  facilityZero         = "0000"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext		= "1"
  totalPages		= "0"	
  attachVarKey         = ""
  attachForDesc        = ""
  quickLinksInUse      = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@hrCompany", "@dtw_rurlescseq(hrCompany)", "1", "a", workURL)
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @HrCoFacUserView(profileHandle, dataBaseID, userPass, hrCompany, facilityNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "Menu.js"
                  %INCLUDE "NumEdit.icl"
                  %INCLUDE "CheckEnterSearch.icl"
                  function validate(searchForm) {
                      if (editNum(document.Search.srchCo, 2, 0) &&
                          editNum(document.Search.srchFac, 4, 0))
                          return true;
                  }
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Trailer Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Trailer Code -->
                  <table $(baseTable)>
                      <tr valign="top">
                          %if (formatToPrint == "")
                               @dtw_assign(pageID, "HRCOMPSELECT")
                              <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                          %endif
                          @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                          @dtw_assign(START_ROW_NUM, "1")
                          <td class="content">
                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, "SELECT * ", stmtSQL)
                              @dtw_concat(fileSQL, " HRCOFC ", fileSQL)
                              @dtw_concat(selectSQL, " CFCOMP=$(hrCompany) and CFFACL = 0", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              %INCLUDE "stmtSQLEnd.icl"
                              @CompSelect_Inquiry(profileHandle, dataBaseID, stmtSQL)
                              @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)

                              @dtw_assign(uv_CompanyName, "CFCOMP")
                              @dtw_assign(uv_FacilityName, "CFFACL")
	                       %INCLUDE "userview.icl"

                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, "SELECT CFCOMP, CFFACL, CFNAME, CFADR1, CFCITY, CFSTID, CFZIP, CFPHON, CFNAMEU, CFHRXR", stmtSQL)
                              @dtw_concat(stmtSQL, ", upper(CFADR1) as CFADR1U", stmtSQL)
                              @dtw_concat(stmtSQL, ", upper(CFCITY) as CFCITYU", stmtSQL)
                              @dtw_concat(fileSQL, " HRCOFC ", fileSQL)
                              @dtw_concat(selectSQL, " CFFACL > 0 AND CFHRXR = $(hrCompany)", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              %INCLUDE "stmtSQLEnd.icl"
                              @CompSelect_Inquiry2(profileHandle, dataBaseID, stmtSQL)
                          </td>
                      </tr>
                  </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) CompSelect_Inquiry (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RetHrCompNam(profileHandle, dataBaseID, hrCompany, facilityZero, coFacName)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
              @dtw_assign(hrCompanyFilled, "$(hrCompany)")
              %while(@dtw_rlength(hrCompanyFilled) != "2") {@dtw_insert("0", hrCompanyFilled, hrCompanyFilled)%}
              @dtw_assign(attachVarKey, "$(hrCompanyFilled)")
              @dtw_assign(attachForDesc, coFacName)
              @dtw_assign(attachPrg1, "HRCOFC Where CFHRXR=$(hrCompany) and CFFACL=0")
                   %if (formatToPrint != "Y")
                      <td class="toolbar">
                          <a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&tblID=52" title="Back Home">$(portalHome)</a>
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "Attachment.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"
      $(hrTagAttr)

      <table $(contentTable)>
          <colgroup>
              <col width="60%">
	       <col width="20%">
	   		
          %ROW {
              @EditPhoneNumber(V_CFPHON)
              <tr><td rowspan="5" class="dspalph"> $(V_CFNAME) <br>
                   %if (V_CFADR1 != "")
                       $(V_CFADR1) <br>
                   %endif
                   %if (V_CFADR2 != "")
                       $(V_CFADR2) <br>
                   %endif
                   $(V_CFCITY), $(V_CFSTID) $(V_CFZIP) &nbsp; <br>

                  <td class="dsphdr">Company</td>
                  <td class="dspnmbr">$(V_CFCOMP)</td>
              </tr>

              <tr><td class="dsphdr">Phone Number</td>
                  <td class="dspnmbr">$(V_CFPHON)</td>
              </tr>

              <tr><td class="dsphdr">Weekly Standard Budget Hours</td>
                  <td class="dspnmbr">$(V_CFSBH)</td>
              </tr>
          %}
      </table>
      $(hrTagAttr)
  %}
%}

%FUNCTION(dtw_sql) CompSelect_Inquiry2 (IN CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;backHome=@dtw_rurlescseq(backHome)">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Name</th>
                      <th class="colhdr">Co/Fac</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchName" size="20" maxlength="30">
                          <input type="hidden" name="operName" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchCo" size="2" maxlength="2"> /
                          <input type="text" class="inputalph" name="srchFac" size="4" maxlength="4">
                          <input type="hidden" name="operCo" value="=">
                          <input type="hidden" name="operFac" value="=">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchName.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif
              <table $(contentTable)>
                  <tr>
                      @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)&amp;backHome=@dtw_rurlescseq(backHome)")
                      @OrderBy_Sort("CFCOMP", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Number" title="Sequence By Company, Facility"> Co/Fac</a></th>
                      @OrderBy_Sort("CFNAMEU", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Name" title="Sequence By Name, Company, Facility"> Name</a></th>
                      @OrderBy_Sort("CFADR1U", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Address" title="Sequence By Address, Name"> Address</a></th>
                      @OrderBy_Sort("CFCITYU", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=City" title="Sequence By City, State, Name"> City</a></th>
                      @OrderBy_Sort("CFSTID", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=State" title="Sequence By State, City, Name"> State</a></th>
                      @OrderBy_Sort("CFPHON", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Phone" title="Sequence By Phone Number, Name"> Phone<br>Number</a></th>
                  </tr>
                  %INCLUDE "NoRecordsFound.icl"
              %ROW{
                  %if (sql_Record_Count != "0")
                      %INCLUDE "SetRowClass.icl"
                      @Format_HRCoFac("$(V_CFCOMP)", "$(V_CFFACL)", "", F_CoFac)
                      <tr class="$(rowClass)">
                          <td class="colnmbr">$(F_CoFac)</td>
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)HRCoFacProfile.d2w/REPORT$(d2wVarBase)&amp;prCompany=@dtw_rurlescseq(V_CFCOMP)&amp;prFacility=@dtw_rurlescseq(V_CFFACL)&amp;backHome=$(d2wName)/REPORT" title="View Company/Facility">$(V_CFNAME)</a></td>
                          <td class="colalph">$(V_CFADR1)</td>
                          <td class="colalph">$(V_CFCITY)</td>
                          <td class="colcode">$(V_CFSTID)</td>
	   	           %if (V_CFPHON > "0")
                              @EditPhoneNumber(V_CFPHON)
                          %endif
                          <td class="colalph">$(V_CFPHON)</td>
                      </tr>
                  %endif
              %}
          </table>
      %INCLUDE "AttachmentSQL.icl"
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%INCLUDE "AttachmentSelect.icl"


%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  @dtw_assign(uv_CompanyName, "CFCOMP")
  @dtw_assign(uv_FacilityName, "CFFACL")
  %INCLUDE "userview.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "SELECT CFCOMP, CFFACL, CFNAME, CFADR1, CFCITY, CFSTID, CFPHON ", stmtSQL)
  @dtw_concat(fileSQL, " HRCOFC ", fileSQL)
  @dtw_concat(selectSQL, " CFFACL > 0 AND CFHRXR = $(hrCompany)", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @CompSelect_XMLQuery(profileHandle, dataBaseID, stmtSQL)

%}

%FUNCTION(dtw_sql) CompSelect_XMLQuery (IN CHAR(64)    profileHandle,
			                    CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("CompList")
          %ROW{
              @XMLIDTag(V_CFCOMP, "Company ID")
                  @XMLTag(V_CFCOMP, "Company")
                  @XMLTag(V_CFFACL, "Facility")
                  @XMLTag(V_CFNAME, "Name")
                  @XMLTag(V_CFADR1, "Address")
                  @XMLTag(V_CFCITY, "City")
                  @XMLTag(V_CFSTID, "State")
                  @XMLTag(V_CFPHON, "PhoneNumber")
              @XMLEndTag("Company")
	   %}

      @XMLEndTag("CompList")
  %}
%}


%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (sec_06 == "N")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "CFCOMP,CFFACL")
              @DTW_ASSIGN(orderByDisplay, "Company/Facility")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      %INCLUDE "SearchReturn.icl"
  %endif
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Number")
      %if (orderBy == "CFCOMP,CFFACL")
          @DTW_ASSIGN(orderBy, "CFCOMP DESC,CFFACL DESC")
          @DTW_ASSIGN(orderByDisplay, "Company (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CFCOMP,CFFACL")
          @DTW_ASSIGN(orderByDisplay, "Company")
      %endif
  %elif (sequence == "Name")
      %if (orderBy == "CFNAMEU,CFCOMP")
          @DTW_ASSIGN(orderBy, "CFNAMEU DESC,CFCOMP")
          @DTW_ASSIGN(orderByDisplay, "Name (descending), Company")
      %else
          @DTW_ASSIGN(orderBy, "CFNAMEU,CFCOMP")
          @DTW_ASSIGN(orderByDisplay, "Name, Company")
      %endif
  %elif (sequence == "Address")
      %if (orderBy == "CFADR1U,CFNAMEU")
          @DTW_ASSIGN(orderBy, "CFADR1U DESC,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "Address (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "CFADR1U,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "Address, Name")
      %endif
  %elif (sequence == "City")
      %if (orderBy == "CFCITYU,CFSTID,CFNAMEU")
          @DTW_ASSIGN(orderBy, "CFCITYU DESC,CFSTID,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "City (descending), State, Name")
      %else
          @DTW_ASSIGN(orderBy, "CFCITYU,CFSTID,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "City, State, Name")
      %endif
  %elif (sequence == "State")
      %if (orderBy == "CFSTID,CFCITYU,CFNAMEU")
          @DTW_ASSIGN(orderBy, "CFSTID DESC,CFCITYU,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "State (descending), City, Name")
      %else
          @DTW_ASSIGN(orderBy, "CFSTID,CFCITYU,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "State, City, Name")
      %endif
  %elif (sequence == "Phone")
      %if (orderBy == "CFPHON,CFNAMEU")
          @DTW_ASSIGN(orderBy, "CFPHON DESC,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "Phone Number (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "CFPHON,CFNAMEU")
          @DTW_ASSIGN(orderByDisplay, "Phone Number, Name")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchCo, 2, 0) &&
                      editNum(document.Search.srchFac, 4, 0) &&
                      editNum(document.Search.srchPhone, 10, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "HRCOFACSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y&amp;backHome=@dtw_rurlescseq(backHome)")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)&amp;backHome=@dtw_rurlescseq(backHome)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Company</td>
                              @dtw_assign(operNbr, "operCo")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchCo" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Facility</td>
                              @dtw_assign(operNbr, "operFac")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchFac" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Name</td>
                              @dtw_assign(operNbr, "operName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchName" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Address</td>
                              @dtw_assign(operNbr, "operAddr")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchAddr" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">City</td>
                              @dtw_assign(operNbr, "operCity")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCity" size="16" maxlength="16"></td>
                          </tr>

                          <tr><td class="dsphdr">State</td>
                              @dtw_assign(operNbr, "operState")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchState" size="2" maxlength="2"><a href="$(homeURL)$(phpPath)StateSearch.php$(altVarBase)&amp;docName=Search&amp;fldName=srchState&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stateDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Zip</td>
                              @dtw_assign(operNbr, "operZip")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchZip" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Phone Number</td>
                              <td>&nbsp;</td>
                              <td class="inputnmbr"><input type="text" name="srchPhone" size="10" maxlength="10"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchCo.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("CFCOMP", "Company", $(srchCo), "", operCo, "N")
  @Build_WildCard ("CFFACL", "Facility", $(srchFac), "", operFac, "N")
  @Build_WildCard ("CFNAMEU", "Name", $(srchName), "U", operName, "A")
  @Build_WildCard ("upper(CFADR1)", "Address", $(srchAddr), "U", operAddr, "A")
  @Build_WildCard ("upper(CFCITY)", "City", $(srchCity), "U", operCity, "A")
  @Build_WildCard ("CFSTID", "State", $(srchState), "U", operState, "A")
  @Build_WildCard ("CFZIP", "Zip", $(srchZip), "", operZip, "A")
  @Build_WildCard ("CFPHON", "Phone Number", $(srchPhone), "", "", "PA")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)&amp;backHome=@dtw_rurlescseq(backHome)")
  %INCLUDE "WildCardUpdate.icl"
%}