%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Participant Inquiry"
  d2wName                 = "WFParticipantInquiryList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfParticipant=@dtw_rurlescseq(wfParticipant)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
  maintainVar             = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @DTW_ASSIGN(backHome, "$(d2wName)/REPORT")
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                       @dtw_assign(pageID, "WFPARTICIPANTINQUIRY")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">

                      %{Participant %}
                          @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                          @dtw_assign(SAVE_MAX_ROWS, RPT_MAX_ROWS)
                          @dtw_assign(START_ROW_NUM, "1")
                          @dtw_assign(RPT_MAX_ROWS, "9999")
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select WFPRPT.*, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(PRDESC,' ') as PRDESC, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(PDDESC,' ') as PDDESC ", stmtSQL)
                          @dtw_concat(fileSQL, " WFPRPT ", fileSQL)
                          @dtw_concat(fileSQL, " left join WFPRHD on PRPROC=PAPROC", fileSQL)
                          @dtw_concat(fileSQL, " left join WFPRDT on PDPROC=PAPROC and PDPONT=PAPONT and PDSEQ=PASEQ ", fileSQL)
                          @dtw_concat(selectSQL, " PAPART='$(wfParticipant)'", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By PRDESC,PDDESC ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @List_Query(profileHandle, dataBaseID, stmtSQL)
                          @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                          @dtw_assign(RPT_MAX_ROWS, SAVE_MAX_ROWS)

                      %{Common User Participant %}
                          @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                          @dtw_assign(SAVE_MAX_ROWS, RPT_MAX_ROWS)
                          @dtw_assign(START_ROW_NUM, "1")
                          @dtw_assign(RPT_MAX_ROWS, "9999")
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select WFPRPT.*, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(PRDESC,' ') as PRDESC, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(PDDESC,' ') as PDDESC, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(PDRATE,0) as PDRATE ", stmtSQL)
                          @dtw_concat(fileSQL, " WFPRPT ", fileSQL)
                          @dtw_concat(fileSQL, " inner join SYCUSF on CUCUSR=PAPART  ", fileSQL)
                          @dtw_concat(fileSQL, " left join WFPRHD on PRPROC=PAPROC", fileSQL)
                          @dtw_concat(fileSQL, " left join WFPRDT on PDPROC=PAPROC and PDPONT=PAPONT and PDSEQ=PASEQ ", fileSQL)
                          @dtw_concat(selectSQL, " CUUSER='$(wfParticipant)'", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By PRDESC,PDDESC ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @CommonUserList_Query(profileHandle, dataBaseID, stmtSQL)
                          @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                          @dtw_assign(RPT_MAX_ROWS, SAVE_MAX_ROWS)

                      %{Delegated Participant %}
                          @dtw_assign(START_ROW_NUM, "1")
                          @dtw_assign(RPT_MAX_ROWS, "9999")
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select WFDELG.*,  ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(USDESC,' ') as USDESC, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(PRDESC,' ') as PRDESC, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(PDDESC,' ') as PDDESC ", stmtSQL)
                          @dtw_concat(fileSQL, " WFDELG ", fileSQL)
                          @dtw_concat(fileSQL, " left join SYUSER on USUSER=DLPART ", fileSQL)
                          @dtw_concat(fileSQL, " left join WFPRHD on PRPROC=DLPROC ", fileSQL)
                          @dtw_concat(fileSQL, " left join WFPRDT on PDPROC=DLPROC and PDPONT=DLPONT and PDSEQ=DLSEQ ", fileSQL)
                          @dtw_concat(selectSQL, " DLDPRT='$(wfParticipant)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By DLFDAT,DLFTIM,USDESC ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @DelegatedList_Query(profileHandle, dataBaseID, stmtSQL)


                      %{My Delegated List %}
                          @dtw_assign(START_ROW_NUM, "1")
                          @dtw_assign(RPT_MAX_ROWS, "9999")
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select WFDELG.*,  ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(USDESC,' ') as USDESC, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(PRDESC,' ') as PRDESC, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(PDDESC,' ') as PDDESC ", stmtSQL)
                          @dtw_concat(fileSQL, " WFDELG ", fileSQL)
                          @dtw_concat(fileSQL, " left join SYUSER on USUSER=DLDPRT ", fileSQL)
                          @dtw_concat(fileSQL, " left join WFPRHD on PRPROC=DLPROC", fileSQL)
                          @dtw_concat(fileSQL, " left join WFPRDT on PDPROC=DLPROC and PDPONT=DLPONT and PDSEQ=DLSEQ ", fileSQL)
                          @dtw_concat(selectSQL, " DLPART='$(wfParticipant)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By DLFDAT,DLFTIM,USDESC ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @MyDelegatedList_Query(profileHandle, dataBaseID, stmtSQL)

                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(programName, "HWFDLM")
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @dtw_assign(HWFDLMAdd, sec_01)

      @dtw_assign(programName, "HWFPTM")
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)

      %INCLUDE "PageTitleWithPrint.icl"

      <table $(contentTable)>
          @RtvFldDesc("USUSER='$(wfParticipant)'", "SYUSER", "USDESC", V_USDESC)
          @Format_Code(wfParticipant, F_wfParticipant)
          <tr><td><h2>$(V_USDESC) $(F_wfParticipant)</h2></td></tr>
      </table>

      $(hrTagAttr)

      <fieldset class="legendBody">
          <legend class="legendTitle">I am a Participant of the following:
              %if (HWFDLMAdd == "Y")
                  <a href="$(homeURL)$(cGIPath)WFParticipantDelegateAll.d2w/REPORT$(d2wVarBase)&amp;delegateFlag=P" onclick="$(commentWinVar)">$(wfAddDelgImage)</a>
              %endif
          </legend>
          <table $(contentTable)>
              @dtw_assign(headOnce, "")

              %ROW{
                  %if (headOnce == "")
                      @dtw_assign(headOnce, "Y")
                      <tr>
                          %if (formatToPrint != "Y" && (HWFDLMAdd=="Y" || sec_02=="Y" || Sec_03=="Y"))
                              <th class="colhdr">$(optionHeading)</th>
                          %endif
                          <th class="colhdr">Process</th>
                          <th class="colhdr">Detail Point</th>
                     </tr>
                  %endif

                  %INCLUDE "SetRowClass.icl"
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;wfProcess=@dtw_rurlescseq(V_PAPROC)&amp;wfPoint=@dtw_rurlescseq(V_PAPONT)&amp;wfSequence=@dtw_rurlescseq(V_PASEQ)&amp;wfParticipantId=@dtw_rurlescseq(V_PAPAID)&amp;frmWfParticipant=@dtw_rurlescseq(V_PAPART)&amp;passedWfParticipant=@dtw_rurlescseq(wfParticipant)&amp;fromD2w=@dtw_rurlescseq(d2wName)")

                  <tr class="$(rowClass)">
                      %if (formatToPrint != "Y" && (HWFDLMAdd=="Y" || sec_02=="Y" || Sec_03=="Y"))
                          <td class="opticon">
                              %if (sec_02=="Y" || sec_03=="Y")
                                  <a href="$(homeURL)$(cGIPath)WFParticipantMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                              %endif
                              %if (HWFDLMAdd=="Y")
                                  <a href="$(homeURL)$(cGIPath)WFDelegateMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=A">$(wfAddDelgImage)</a>
                              %endif
                          </td>
                      %endif
                      <td class="colalph" $(helpCursor)><span title="$(V_PAPROC)">$(V_PRDESC)</span></td>
                      <td class="colalph" $(helpCursor)><span title="$(V_PAPONT)-$(V_PASEQ)">$(V_PDDESC)</span></td>
                  </tr>
              %}
          </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) CommonUserList_Query (IN  CHAR(64) profileHandle,
                                             CHAR(2)   dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(programName, "HWFDLM")
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @dtw_assign(HWFDLMAdd, sec_01)

      @dtw_assign(programName, "HWFPTM")
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)

      <fieldset class="legendBody">
          <legend class="legendTitle">I am part of the Common User who participates in the following:
              %if (HWFDLMAdd == "Y")
                  <a href="$(homeURL)$(cGIPath)WFParticipantDelegateAll.d2w/REPORT$(d2wVarBase)&amp;delegateFlag=C" onclick="$(commentWinVar)">$(wfAddDelgImage)</a>
              %endif
          </legend>

          <table $(contentTable)>
              @dtw_assign(headOnce, "")

              %ROW{
                  %if (headOnce == "")
                      @dtw_assign(headOnce, "Y")
                      <tr>
                          %if (formatToPrint != "Y" && (HWFDLMAdd=="Y" || sec_02=="Y" || Sec_03=="Y"))
                              <th class="colhdr">$(optionHeading)</th>
                          %endif
                          <th class="colhdr">Common User</th>
                          <th class="colhdr">Process</th>
                          <th class="colhdr">Detail Point</th>
                     </tr>
                  %endif

                  %INCLUDE "SetRowClass.icl"
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;wfProcess=@dtw_rurlescseq(V_PAPROC)&amp;wfPoint=@dtw_rurlescseq(V_PAPONT)&amp;wfSequence=@dtw_rurlescseq(V_PASEQ)&amp;wfParticipantId=@dtw_rurlescseq(V_PAPAID)&amp;frmWfParticipant=@dtw_rurlescseq(wfParticipant)&amp;passedWfParticipant=@dtw_rurlescseq(wfParticipant)&amp;fromD2w=@dtw_rurlescseq(d2wName)")

                  <tr class="$(rowClass)">
                      %if (formatToPrint != "Y" && (HWFDLMAdd=="Y" || sec_02=="Y" || Sec_03=="Y"))
                          <td class="opticon">
                              %if (sec_02=="Y" || sec_03=="Y")
                                  <a href="$(homeURL)$(cGIPath)WFParticipantMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                              %endif
                              %if (HWFDLMAdd=="Y")
                                  <a href="$(homeURL)$(cGIPath)WFDelegateMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=A">$(wfAddDelgImage)</a>
                              %endif
                          </td>
                      %endif
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)CommonUserInquiry.d2w/REPORT$(d2wVarBase)&amp;commonUser=@dtw_rurlescseq(V_PAPART)&amp;complexityRating=@dtw_rurlescseq(V_PDRATE)" title="Common User Quickview" onclick="$(inquiryWinVar)">$(V_PAPART)</a></td>
                      <td class="colalph" $(helpCursor)><span title="$(V_PAPROC)">$(V_PRDESC)</span></td>
                      <td class="colalph" $(helpCursor)><span title="$(V_PAPONT)-$(V_PASEQ)">$(V_PDDESC)</span></td>
                  </tr>
              %}
          </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) DelegatedList_Query (IN  CHAR(64) profileHandle,
                                            CHAR(2)   dataBaseID,
                                            CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(programName, "HWFDLM")
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)

      <fieldset class="legendBody">
          <legend class="legendTitle">I am delegated to participate in the following:</legend>
          <table $(contentTable)>
              @dtw_assign(headOnce, "")

              %ROW{
                  %if (headOnce == "")
                      @dtw_assign(headOnce, "Y")
                      <tr>
                          %if (formatToPrint != "Y" && (sec_02=="Y" || Sec_03=="Y"))
                              <th class="colhdr">$(optionHeading)</th>
                          %endif
                          <th class="colhdr">For Participant</th>
                          <th class="colhdr">Effective From Date</th>
                          <th class="colhdr">Effective From Time</th>
                          <th class="colhdr">Effective To Date</th>
                          <th class="colhdr">Effective To Time</th>
                          <th class="colhdr">Process</th>
                          <th class="colhdr">Detail Point</th>
                     </tr>
                  %endif

                  %if (V_DLPROC=="")
                      @dtw_assign(F_PRDESC, "All")
                  %else
                      @dtw_assign(F_PRDESC, V_PRDESC)
                  %endif
                  %if (V_DLPONT<="0")
                      @dtw_assign(F_PDDESC, "All")
                      @dtw_assign(F_DLSEQ, "")
                  %else
                      @dtw_assign(F_PDDESC, V_PDDESC)
                      @dtw_assign(F_DLSEQ, V_DLSEQ)
                  %endif

                  %INCLUDE "SetRowClass.icl"
                  @dtw_assign(maintainVar, "$(genericVarBase)&amp;wfParticipant=@dtw_rurlescseq(V_DLPART)&amp;wfDelegationId=@dtw_rurlescseq(V_DLDLID)&amp;passedWfParticipant=@dtw_rurlescseq(wfParticipant)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=C")

                  @Format_Date(V_DLFDAT, "H", F_DLFDAT)
                  @Format_Date(V_DLTDAT, "H", F_DLTDAT)
                  <tr class="$(rowClass)">
                      %if (formatToPrint != "Y" && (sec_02=="Y" || Sec_03=="Y"))
                          <td class="opticon">
                              %if (sec_02=="Y" || sec_03=="Y")
                                  <a href="$(homeURL)$(cGIPath)WFDelegateMaintain.d2w/MAINTAIN$(maintainVar)">$(changeImageSml)</a>
                              %endif
                          </td>
                      %endif
                      <td class="colalph" $(helpCursor)><span title="$(V_DLPART)">$(V_USDESC)</span></td>
                      <td class="colalph">$(F_DLFDAT)</td>
                      <td class="colnmbr">$(V_DLFTIM)</td>
                      <td class="colalph">$(F_DLTDAT)</td>
                      <td class="colnmbr">$(V_DLTTIM)</td>
                      <td class="colalph" $(helpCursor)><span title="$(V_DLPROC)">$(F_PRDESC)</span></td>
                      <td class="colalph" $(helpCursor)><span title="$(V_DLPONT)-$(V_DLSEQ)">$(F_PDDESC)</span></td>
                  </tr>
              %}
          </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) MyDelegatedList_Query (IN  CHAR(64) profileHandle,
                                              CHAR(2)   dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @dtw_assign(programName, "HWFDLM")
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)

      <fieldset class="legendBody">
          <legend class="legendTitle">I have delegated the following: &nbsp;
              %if (sec_03 == "Y")
                  @Format_Confirm_Desc("Are you sure you want to delete all rows ", "", "", "", "", "", confirmDesc)
                  <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)$(d2wName)/DELETEALL$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)">$(deleteImageSml)</a>
              %endif
          </legend>
          <table $(contentTable)>
              @dtw_assign(headOnce, "")

              %ROW{
                  %if (headOnce == "")
                      @dtw_assign(headOnce, "Y")
                      <tr>
                          %if (formatToPrint != "Y" && (sec_02=="Y" || Sec_03=="Y"))
                              <th class="colhdr">$(optionHeading)</th>
                          %endif
                          <th class="colhdr">Effective From Date</th>
                          <th class="colhdr">Effective From Time</th>
                          <th class="colhdr">Effective To Date</th>
                          <th class="colhdr">Effective To Time</th>
                          <th class="colhdr">Participant</th>
                          <th class="colhdr">Process</th>
                          <th class="colhdr">Detail Point</th>
                     </tr>
                  %endif

                  %if (V_DLPROC=="")
                      @dtw_assign(F_PRDESC, "All")
                  %else
                      @dtw_assign(F_PRDESC, V_PRDESC)
                  %endif
                  %if (V_DLPONT<="0")
                      @dtw_assign(F_PDDESC, "All")
                  %else
                      @dtw_assign(F_PDDESC, V_PDDESC)
                  %endif

                  %INCLUDE "SetRowClass.icl"
                  @dtw_assign(maintainVar, "$(genericVarBase)&amp;wfParticipant=@dtw_rurlescseq(V_DLPART)&amp;wfDelegationId=@dtw_rurlescseq(V_DLDLID)&amp;passedWfParticipant=@dtw_rurlescseq(wfParticipant)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=C")

                  @Format_Date(V_DLFDAT, "H", F_DLFDAT)
                  @Format_Date(V_DLTDAT, "H", F_DLTDAT)
                  <tr class="$(rowClass)">
                      %if (formatToPrint != "Y" && (sec_02=="Y" || Sec_03=="Y"))
                          <td class="opticon">
                              %if (sec_02=="Y" || sec_03=="Y")
                                  <a href="$(homeURL)$(cGIPath)WFDelegateMaintain.d2w/MAINTAIN$(maintainVar)">$(changeImageSml)</a>
                              %endif
                          </td>
                      %endif
                      <td class="colalph">$(F_DLFDAT)</td>
                      <td class="colnmbr">$(V_DLFTIM)</td>
                      <td class="colalph">$(F_DLTDAT)</td>
                      <td class="colnmbr">$(V_DLTTIM)</td>
                      <td class="colalph" $(helpCursor)><span title="$(V_DLDPRT)">$(V_USDESC)</span></td>
                      <td class="colalph" $(helpCursor)><span title="$(V_DLPROC)">$(F_PRDESC)</span></td>
                      <td class="colalph" $(helpCursor)><span title="$(V_DLPONT)-$(V_DLSEQ)">$(F_PDDESC)</span></td>
                  </tr>
              %}
          </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_directcall) Delete_Delegate(IN    CHAR(64)    profileHandle,
                                                CHAR(2)     dataBaseID,
                                                CHAR(32000) edtVar)
{%EXEC {HWFDLD_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(DELETEALL) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @Concat_Field("@@part", wfParticipant)
  @dtw_concat(edtVar, "}{", edtVar)
  @Delete_Delegate(profileHandle, dataBaseID, edtVar)
  <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)">
%}
