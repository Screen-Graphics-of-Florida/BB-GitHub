%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "O/E Data Queue Inquiry"
  d2wName                 = "OEDataQueueInquiry.d2w"
  d2wVarBase              = "$(genericVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  dataQueue               = "OEDTAQ"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {

%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "OEDATAQUEUE")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " OEDTAQIQ ", fileSQL)
                      @dtw_concat(selectSQL, "OQXHND='$(profileHandle)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Create_File(profileHandle, dataBaseID, dataQueue)
                      @DataQueue_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_directcall) Create_File(INOUT CHAR(64)    profileHandle,
                                      INOUT CHAR(2)     dataBaseID,
                                      INOUT CHAR(10)    dataQueue)

{%EXEC {HOEDQP_W.PGM %}
%}
%FUNCTION(dtw_sql) DataQueue_Query (IN  CHAR(64)    profileHandle,
			 	         CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
          %INCLUDE "PageTitleWithPrint.icl"

          $(hrTagAttr)

          %if (formatToPrint == "")
              <table $(contentTable)>
                  <tr><td> %INCLUDE "AssignPageValue.icl" </td></tr>
              </table>
          %endif

          <table $(contentTable)>
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("OQTTYP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Type"  title="Sequence By Transaction Type"> Transaction<br>Type</a></th>
                  @OrderBy_Sort("OQTURN", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Turnaround"    title="Sequence By Turnaround"> Turnaround<br>Number</a></th>
                  @OrderBy_Sort("OQORD#", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Order" title="Sequence By Order Number"> Order<br>Number</a></th>
                  @OrderBy_Sort("OQOCTL", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Control"    title="Sequence By Order Control Number"> Order Control<br>Number</a></th>
                  @OrderBy_Sort("OQPGM", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Program"   title="Sequence By Program"> Program</a></th>
                  @OrderBy_Sort("OQTSUS", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=User"     title="Sequence By User Profile"> User Profile</a></th>
                  @OrderBy_Sort("OQTSWS", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=WorkStation"   title="Sequence By Work Station"> Work Station</a></th>
                  @OrderBy_Sort("OQTSTP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Time"   title="Sequence By Time Stamp, Name"> Time Stamp</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"

              %ROW{
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colalph">$(V_OQTTYP)</td>                                      	
                      <td class="colnmbr">$(V_OQTURN)</td>
                      <td class="colnmbr">$(V_OQORD#)</td>
                      <td class="colnmbr">$(V_OQOCTL)</td>
                      <td class="colalph">$(V_OQPGM)</td>
                      <td class="colnmbr">$(V_OQTSUS)</td>
                      <td class="colalph">$(V_OQTSWS)</td>
                      <td class="colalph">$(V_OQTSTP)</td>
                  </tr>
              %}
          </table>
          %if (sql_Record_Count != "1")
              %INCLUDE "PageBottom.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "OQOCTL")
          @DTW_ASSIGN(orderByDisplay, "Order Control Number")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Type")
      %if (orderBy == "OQTTYP")
          @DTW_ASSIGN(orderBy, "OQTTYP DESC")
          @DTW_ASSIGN(orderByDisplay, "Type (descending)")
      %else
          @DTW_ASSIGN(orderBy, "OQTTYP")
          @DTW_ASSIGN(orderByDisplay, "Type")
      %endif
  %elif (sequence == "Turnaround")
      %if (orderBy == "OQTURN")
          @DTW_ASSIGN(orderBy, "OQTURN DESC")
          @DTW_ASSIGN(orderByDisplay, "Turnaround (descending)")
      %else
          @DTW_ASSIGN(orderBy, "OQTURN")
          @DTW_ASSIGN(orderByDisplay, "Turnaround")
      %endif
  %elif (sequence == "Order")
      %if (orderBy == "OQORD#")
          @DTW_ASSIGN(orderBy, "OQORD# DESC")
          @DTW_ASSIGN(orderByDisplay, "Order Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "OQORD#")
          @DTW_ASSIGN(orderByDisplay, "Order Number")
      %endif
  %elif (sequence == "Control")
      %if (orderBy == "OQOCTL")
          @DTW_ASSIGN(orderBy, "OQOCTL DESC")
          @DTW_ASSIGN(orderByDisplay, "Order Control Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "OQOCTL")
          @DTW_ASSIGN(orderByDisplay, "Order Control Number")
      %endif
  %elif (sequence == "Time")
      %if (orderBy == "OQTSTP")
          @DTW_ASSIGN(orderBy, "OQTSTP DESC")
          @DTW_ASSIGN(orderByDisplay, "Time Stamp (descending)")
      %else
          @DTW_ASSIGN(orderBy, "OQTSTP")
          @DTW_ASSIGN(orderByDisplay, "Time Stamp")
      %endif
  %elif (sequence == "User")
      %if (orderBy == "OQTSUS")
          @DTW_ASSIGN(orderBy, "OQTSUS DESC")
          @DTW_ASSIGN(orderByDisplay, "User Profile (descending)")
      %else
          @DTW_ASSIGN(orderBy, "OQTSUS")
          @DTW_ASSIGN(orderByDisplay, "User Profile")
      %endif
  %elif (sequence == "WorkStation")
      %if (orderBy == "OQTSWS")
          @DTW_ASSIGN(orderBy, "OQTSWS DESC")
          @DTW_ASSIGN(orderByDisplay, "Workstation (descending)")
      %else
          @DTW_ASSIGN(orderBy, "OQTSWS")
          @DTW_ASSIGN(orderByDisplay, "Workstation")
      %endif
  %elif (sequence == "Program")
      %if (orderBy == "OQPGM")
          @DTW_ASSIGN(orderBy, "OQPGM DESC")
          @DTW_ASSIGN(orderByDisplay, "Program (descending)")
      %else
          @DTW_ASSIGN(orderBy, "OQPGM")
          @DTW_ASSIGN(orderByDisplay, "Program")
      %endif
  %endif
	
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}