%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Condition Expression"
  d2wName                 = "WFExpression.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfCondition=@dtw_rurlescseq(wfCondition)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HWFCNE"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  noMsg                   = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "WFEXPRESSION")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select WFCNDE.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(a.FLDESC,' ') as anorFLDESC, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(b.FLDESC,' ') as ptypFLDESC, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(c.FLDESC,' ') as vtypFLDESC, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(d.PMPRMD,CEPFLD) as parmPMPRMD, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(e.PMPRMD,CEVFLD) as valuPMPRMD, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(VIDESC,' ') as VIDESC ", stmtSQL)
                      @dtw_concat(fileSQL, " WFCNDE ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG a on a.FLTYPE='WFCNDCONT' and a.FLVALU=CEANOR ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG b on b.FLTYPE='WFCNDPTYP' and b.FLVALU=CEPTYP ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG c on c.FLTYPE='WFCNDVTYP' and c.FLVALU=CEVTYP and CEVLID=0", fileSQL)
                      @dtw_concat(fileSQL, " left join WFPARM d on d.PMPARM=CEPFLD ", fileSQL)
                      @dtw_concat(fileSQL, " left join WFPARM e on e.PMPARM=CEVFLD ", fileSQL)
                      @dtw_concat(fileSQL, " left join WFVLID on VIVPGM=CEVPGM and VIVLID=CEVLID ", fileSQL)
                      @dtw_concat(selectSQL, " CECOND=$(wfCondition) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)WFExpressionMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      <table $(contentTable)>
          @RtvFldDesc("CMCOND=$(wfCondition)", "WFCNDM", "CMDESC", V_CMDESC)
          @Format_Header_URL("Condition", $(V_CMDESC), $(wfCondition), "$(homeURL)$(cGIPath)WFConditionSelect.d2w/REPORT$(d2wVarBase)")
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint == "")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Expression</th>
                      <th class="colhdr">Parameter Column</th>
                      <th class="colhdr">Value Column</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="15" maxlength="50">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchParmField" size="15" maxlength="30">
                          <input type="hidden" name="operParmField" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchValueField" size="15" maxlength="30">
                          <input type="hidden" name="operValueField" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("CECONDU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Expression"    title="Sequence By Expression, Test Sequence">Expression</a></th>
              @OrderBy_Sort("CETSSQ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TestSequence"  title="Sequence By Test Sequence">Test Sequence</a></th>
              @OrderBy_Sort("anorFLDESC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Anor"          title="Sequence By And/Or, Test Sequence">And/<br>Or</a></th>
              @OrderBy_Sort("Section", sortVar)
              <th class="colhdr$(sortVar)">Section</th>
              @OrderBy_Sort("ptypFLDESC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Type"          title="Sequence By Parameter Type, Test Sequence">Type</a></th>
              @OrderBy_Sort("CEPEXT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ExternalTable" title="Sequence By Parameter External Table, Test Sequence">External Table</a></th>
              @OrderBy_Sort("CEPWHR", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Where"         title="Sequence By Parameter Where, Test Sequence">Where</a></th>
              @OrderBy_Sort("parmPMPRMD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Column"        title="Sequence By Parameter Column, Test Sequence">Column</a></th>
              @OrderBy_Sort("CEOPER", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Operand"       title="Sequence By Operand, Test Sequence">Operand</a></th>
              @OrderBy_Sort("CEVAL1", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ValueOne"      title="Sequence By Value One, Test Sequence">Value One</a></th>
              @OrderBy_Sort("CEVAL2", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ValueTwo"      title="Sequence By Value Two, Test Sequence">Value Two</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;wfExpressionId=@dtw_rurlescseq(V_CEEXID)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;updRecNbr=@dtw_rurlescseq(START_ROW_NUM)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_CECONDE), "$(V_CECOND)-$(V_CETSSQ)", "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)WFExpressionMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)WFExpressionMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromWfExpressionId=@dtw_rurlescseq(V_CEEXID)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)WFExpressionMaintain.d2w/EDIT_DATA$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_CECONDE)</td>
                  <td class="colnmbr">$(V_CETSSQ)</td>
                  <td class="colcode" $(helpCursor)><span title="$(V_CEANOR)">$(V_anorFLDESC)</span></td>
                  %if (V_CEVLID>"0")
                      <td class="colalph" colspan="8" $(helpCursor)><span title="$(V_CEVPGM)-$(V_CEVLID)">Validation: $(V_VIDESC)</span></td>
                  %else
                      <td class="colalph">Parameter:</td>
                      <td class="colalph" $(helpCursor)><span title="$(V_CEPTYP)">$(V_ptypFLDESC)</span></td>
                      <td class="colalph">$(V_CEPEXT)</td>
                      <td class="colalph">$(V_CEPWHR)</td>
                      <td class="colalph" $(helpCursor)><span title="$(V_CEPFLD)">$(V_parmPMPRMD)</span></td>
                      <td class="colalph">$(V_CEOPER)</td>
                      <td class="colalph">&nbsp;</td>
                      <td class="colalph">&nbsp;</td>
                  %endif
              </tr>
              %if (V_CEVLID<="0")
                  <tr class="$(rowClass)">
                      %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                          <td>&nbsp;</td>
                      %endif
                      <td class="colalph">&nbsp;</td>
                      <td class="colalph">&nbsp;</td>
                      <td class="colalph">&nbsp;</td>
                      <td class="colalph">Value:</td>
                      <td class="colalph" $(helpCursor)><span title="$(V_CEVTYP)">$(V_vtypFLDESC)</span></td>
                      <td class="colalph">$(V_CEVEXT)</td>
                      <td class="colalph">$(V_CEVWHR)</td>
                      <td class="colalph" $(helpCursor)><span title="$(V_CEVFLD)">$(V_valuPMPRMD)</span></td>
                      <td class="colalph">&nbsp;</td>
                      <td class="colalph">$(V_CEVAL1)</td>
                      <td class="colalph">$(V_CEVAL2)</td>
                  </tr>
              %endif
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select WFCNDE.*, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(a.FLDESC,' ') as anorFLDESC, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(b.FLDESC,' ') as ptypFLDESC, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(c.FLDESC,' ') as vtypFLDESC, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(d.PMPRMD,CEPFLD) as parmPMPRMD, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(e.PMPRMD,CEVFLD) as valuPMPRMD, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(VIDESC,' ') as VIDESC ", stmtSQL)
  @dtw_concat(fileSQL, " WFCNDE ", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG a on a.FLTYPE='WFCNDCONT' and a.FLVALU=CEANOR ", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG b on b.FLTYPE='WFCNDPTYP' and b.FLVALU=CEPTYP ", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG c on c.FLTYPE='WFCNDVTYP' and c.FLVALU=CEVTYP and CEVLID=0", fileSQL)
  @dtw_concat(fileSQL, " left join WFPARM d on d.PMPARM=CEPFLD ", fileSQL)
  @dtw_concat(fileSQL, " left join WFPARM e on e.PMPARM=CEVFLD ", fileSQL)
  @dtw_concat(fileSQL, " left join WFVLID on VIVPGM=CEVPGM and VIVLID=CEVLID ", fileSQL)
  @dtw_concat(selectSQL, " CECOND=$(wfCondition) ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_XMLQuery (IN  CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("WFExpressionList")
          %ROW{
              @XMLIDTag("$(V_CECOND)-$(V_CEEXID)", "WFExpression ID")
                  @XMLTag(V_CECOND, "ConditionId")
                  @XMLTag(V_CEEXID, "ExpressionId")
                  @XMLTag(V_CETSSQ, "TestSequence")
                  @XMLTag(V_CEANOR, "ExpressionSeparator")
                  @XMLTag(V_CEPTYP, "ParameterType")
                  @XMLTag(V_CEPEXT, "ParameterExternalTable")
                  @XMLTag(V_CEPWHR, "ParameterWhereStatement")
                  @XMLTag(V_CEPFLD, "ParameterColumn")
                  @XMLTag(V_CEOPER, "Operand")
                  @XMLTag(V_CEVTYP, "ValueType")
                  @XMLTag(V_CEVEXT, "ValueExternalTable")
                  @XMLTag(V_CEVWHR, "ValueWhereStatement")
                  @XMLTag(V_CEVFLD, "ValueColumn")
                  @XMLTag(V_CEVAL1, "ValueOne")
                  @XMLTag(V_CEVAL2, "ValueTwo")
                  @XMLTag(V_CEVPGM, "ValidationProgram")
                  @XMLTag(V_CEVLID, "ValidationId")
                  @XMLTag(V_CECONDE, "Condition")
              @XMLEndTag("WFExpression")
          %}
      @XMLEndTag("WFExpressionList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "CETSSQ")
          @DTW_ASSIGN(orderByDisplay, "Test Sequence")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %if (updRecNbr > "0")
      @dtw_assign(START_ROW_NUM, updRecNbr)
      @dtw_assign(updRecNbr, "")
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Expression")
      %if (orderBy == "CECONDU,CETSSQ")
          @DTW_ASSIGN(orderBy, "CECONDU DESC,CETSSQ")
          @DTW_ASSIGN(orderByDisplay, "Expression (descending), Test Sequence")
      %else
          @DTW_ASSIGN(orderBy, "CECONDU,CETSSQ")
          @DTW_ASSIGN(orderByDisplay, "Expression, Test Sequence")
      %endif
  %elif (sequence == "TestSequence")
      %if (orderBy == "CETSSQ")
          @DTW_ASSIGN(orderBy, "CETSSQ DESC")
          @DTW_ASSIGN(orderByDisplay, " Test Sequence (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CETSSQ")
          @DTW_ASSIGN(orderByDisplay, " Test Sequence")
      %endif
  %elif (sequence == "Anor")
      %if (orderBy == "anorFLDESC,CETSSQ")
          @DTW_ASSIGN(orderBy, "anorFLDESC DESC,CETSSQ")
          @DTW_ASSIGN(orderByDisplay, "And/Or (descending),  Test Sequence")
      %else
          @DTW_ASSIGN(orderBy, "anorFLDESC,CETSSQ")
          @DTW_ASSIGN(orderByDisplay, "And/Or, Test Sequence")
      %endif
 %elif (sequence == "Type")
      %if (orderBy == "ptypFLDESC,CETSSQ")
          @DTW_ASSIGN(orderBy, "ptypFLDESC DESC,CETSSQ")
          @DTW_ASSIGN(orderByDisplay, "Parameter Type (descending),  Test Sequence")
      %else
          @DTW_ASSIGN(orderBy, "ptypFLDESC,CETSSQ")
          @DTW_ASSIGN(orderByDisplay, "Parameter Type,  Test Sequence")
      %endif
 %elif (sequence == "ExternalTable")
      %if (orderBy == "CEPEXT,CETSSQ")
          @DTW_ASSIGN(orderBy, "CEPEXT DESC,CETSSQ")
          @DTW_ASSIGN(orderByDisplay, "Parameter External Table (descending),  Test Sequence")
      %else
          @DTW_ASSIGN(orderBy, "CEPEXT,CETSSQ")
          @DTW_ASSIGN(orderByDisplay, "Parameter External Table,  Test Sequence")
      %endif
 %elif (sequence == "Where")
      %if (orderBy == "CEPWHR,CETSSQ")
          @DTW_ASSIGN(orderBy, "CEPWHR DESC,CETSSQ")
          @DTW_ASSIGN(orderByDisplay, "Parameter Where (descending),  Test Sequence")
      %else
          @DTW_ASSIGN(orderBy, "CEPWHR,CETSSQ")
          @DTW_ASSIGN(orderByDisplay, "Parameter Where,  Test Sequence")
      %endif
 %elif (sequence == "Column")
      %if (orderBy == "parmPMPRMD,CETSSQ")
          @DTW_ASSIGN(orderBy, "parmPMPRMD DESC,CETSSQ")
          @DTW_ASSIGN(orderByDisplay, "Parameter Column (descending),  Test Sequence")
      %else
          @DTW_ASSIGN(orderBy, "parmPMPRMD,CETSSQ")
          @DTW_ASSIGN(orderByDisplay, "Parameter Column,  Test Sequence")
      %endif
 %elif (sequence == "Operand")
      %if (orderBy == "CEOPER,CETSSQ")
          @DTW_ASSIGN(orderBy, "CEOPER DESC,CETSSQ")
          @DTW_ASSIGN(orderByDisplay, "Operand (descending),  Test Sequence")
      %else
          @DTW_ASSIGN(orderBy, "CEOPER,CETSSQ")
          @DTW_ASSIGN(orderByDisplay, "Operand,  Test Sequence")
      %endif
 %elif (sequence == "ValueOne")
      %if (orderBy == "CEVAL1,CETSSQ")
          @DTW_ASSIGN(orderBy, "CEVAL1 DESC,CETSSQ")
          @DTW_ASSIGN(orderByDisplay, "Value One (descending),  Test Sequence")
      %else
          @DTW_ASSIGN(orderBy, "CEVAL1,CETSSQ")
          @DTW_ASSIGN(orderByDisplay, "Value One,  Test Sequence")
      %endif
 %elif (sequence == "ValueTwo")
      %if (orderBy == "CEVAL2,CETSSQ")
          @DTW_ASSIGN(orderBy, "CEVAL2 DESC,CETSSQ")
          @DTW_ASSIGN(orderByDisplay, "Value Two (descending),  Test Sequence")
      %else
          @DTW_ASSIGN(orderBy, "CEVAL2,CETSSQ")
          @DTW_ASSIGN(orderByDisplay, "Value Two,  Test Sequence")
      %endif
  %endif
	
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFEXPRESSIONSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Expression</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Parameter Type</td>
                              @dtw_assign(operNbr, "operParmType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchParmType" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Parameter External Table</td>
                              @dtw_assign(operNbr, "operParmExternal")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchParmExternal" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Parameter Column</td>
                              @dtw_assign(operNbr, "operParmField")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchParmField" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Value Type</td>
                              @dtw_assign(operNbr, "operValueType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchValueType" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Value External Table</td>
                              @dtw_assign(operNbr, "operValueExternal")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchValueExternal" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Value Column</td>
                              @dtw_assign(operNbr, "operValueField")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchValueField" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Value One</td>
                              @dtw_assign(operNbr, "operValueOne")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchValueOne" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Value Two</td>
                              @dtw_assign(operNbr, "operValueTwo")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchValueTwo" size="15" maxlength="30"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDesc.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("CECONDU", "Expression", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("upper(b.FLDESC)", "Parameter Type", $(srchParmType), "U", operParmType, "A")
  @Build_WildCard ("CEPEXT", "Parameter External Table", $(srchParmExternal), "U", operParmExternal, "A")
  @Build_WildCard ("coalesce(d.PMPRMDU,CEPFLD)", "Parameter Column", $(srchParmField), "U", operParmField, "A")
  @Build_WildCard ("upper(c.FLDESC)", "Value Type", $(srchValueType), "U", operValueType, "A")
  @Build_WildCard ("CEVEXT", "Value External Table", $(srchValueExternal), "U", operValueExternal, "A")
  @Build_WildCard ("coalesce(e.PMPRMDU,CEVFLD)", "Value Column", $(srchValueField), "U", operValueField, "A")
  @Build_WildCard ("upper(CEVAL1)", "Value One", $(srchValueOne), "U", operValueOne, "A")
  @Build_WildCard ("upper(CEVAL2)", "Value Two", $(srchValueTwo), "U", operValueTwo, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}