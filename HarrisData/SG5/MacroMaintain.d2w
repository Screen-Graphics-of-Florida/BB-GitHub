%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Macro Maintenance"
  d2wName                 = "MacroMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;macroName=@dtw_rurlescseq(macroName)&amp;macroNameDesc=@dtw_rurlescseq(macroNameDesc)&amp;maintenanceCode=D"
  programName             = "HSYMCM_E"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  progTypeTable           = %table
  comment                 = ""
  formatComment           = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function confirmDelete() {return confirm("$(delRecordConf)")}
              function validate(chgForm) {
                  if (document.Chg.macroName.value =="" ||
                      document.Chg.macroNameDesc.value =="")
                         {alert("$(reqFieldError)"); return false;}
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "MACROMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                          @dtw_assign(comment, "")
                      %else
                          @dtw_concat(stmtSQL, "Select * From SYMCRO ", stmtSQL)
                          @dtw_concat(stmtSQL, "Where MMMCRO='$(macroName)' ", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "macroName")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@pgtp", "progType")        @dtw_assign(Err_MMPGTP, fieldValue)
                          @DecatErr_Field("@@mcro", "macroName")       @dtw_assign(Err_MMMCRO, fieldValue)
                          @DecatErr_Field("@@desc", "macroNameDesc")   @dtw_assign(Err_MMDESC, fieldValue)
                          @DecatErr_Field("@@resv", "reserved")        @dtw_assign(Err_MMRESV, fieldValue)
                          @DecatErr_Field("@@incl", "includeName")     @dtw_assign(Err_MMINCL, fieldValue)
                          @DecatErr_Field("@@d2wu", "d2wUsingMacro")   @dtw_assign(Err_MMD2WU, fieldValue)
                      %endif

                      @Decat_Field("@@mcro")   @dtw_assign(V_MMMCRO, fieldValue)
                      @Decat_Field("@@desc")   @dtw_assign(V_MMDESC, fieldValue)
                      @Decat_Field("@@resv")   @dtw_assign(V_MMRESV, fieldValue)
                      @Decat_Field("@@incl")   @dtw_assign(V_MMINCL, fieldValue)
                      @Decat_Field("@@d2wu")   @dtw_assign(V_MMD2WU, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "macroName")
                      %endif
                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_MMMCRO, "")
                      @dtw_assign(focusField, "macroName")
                  %endif

                  %if (focusField == "")
                      @dtw_assign(focusField, "macroNameDesc")
                  %endif

                  @SetTextOvr(Err_MMMCRO)
                  <tr><td class="dsphdr"><span $(textOvr)>Macro Name</span></td>
                         %if (maintenanceCode == "A" || maintenanceCode == "Z")
                             <td class="inputalph"><input name="macroName" type="text" value="$(V_MMMCRO)" size="50" maxlength="50"> $(reqFieldChar) </td>
                         %else
                             <td class="inputalph"><input name="macroName" type="hidden" value="$(V_MMMCRO)" size="50" maxlength="50">$(V_MMMCRO)</td>
                         %endif
                  </tr>
                  @DspErrMsg(Err_MMMCRO)

                  @SetTextOvr(Err_MMDESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="macroNameDesc" type="text" value="$(V_MMDESC)" size="50" maxlength="50"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_MMDESC)

                  @SetTextOvr(Err_MMINCL)
                  <tr><td class="dsphdr"><span $(textOvr)>Include Name</span></td>
                      <td class="inputalph"><input name="includeName" type="text" value="$(V_MMINCL)" size="50" maxlength="50"></td>
                  </tr>
                  @DspErrMsg(Err_MMINCL)

                  @SetTextOvr(Err_MMD2WU)
                  <tr><td class="dsphdr"><span $(textOvr)>Script Using Macro</span></td>
                      <td class="inputalph"><input name="d2wUsingMacro" type="text" value="$(V_MMD2WU)" size="50" maxlength="50"></td>
                  </tr>
                  @DspErrMsg(Err_MMD2WU)

                  @dtw_assign(checked, "")
                  %if (V_MMRESV == "Y")
                      @dtw_assign(checked, "CHECKED")
                  %endif
                  <tr><td class="dsphdr"><span $(textOvr)>Reserved Row On Update</span></td>
                      <td class="dspalph"><input type="checkbox" name="reserved"  value="Y"  $(checked)></td>
                  </tr>
              </table>
              <table $(contentTable)>
                  <tr>
                      <td class="dspalph" colspan="3">Comments:</td>
                  </tr>
                  <tr>
                      <td><textarea name="comments" ROWS=15 COLS=80>$(V_MMCMNT)</textarea></td>
                  </tr>
              </table>
              %}

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                              CHAR(2)     dataBaseID,
                                              CHAR(1)     maintenanceCode,
                                              CHAR(1)     errFound,
                                              CHAR(32000) edtVar,                             	
                                              CHAR(32000) errVar,
                                              CHAR(32000) comments)
{%EXEC {HSYMCM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(progOptSec)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@mcro", macroName)
  @Concat_Field("@@desc", macroNameDesc)
  @Concat_Field("@@resv", reserved)
  @Concat_Field("@@incl", includeName)
  @Concat_Field("@@d2wu", d2wUsingMacro)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar, comments)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(macroNameDesc), $(macroName), "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)Macro.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@mcro", "macroName")
      @Format_ConfMsg_Desc("", $(macroNameDesc), $(macroName), "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)Macro.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;progType=@dtw_rurlescseq(progType)&amp;macroName=@dtw_rurlescseq(macroName)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
