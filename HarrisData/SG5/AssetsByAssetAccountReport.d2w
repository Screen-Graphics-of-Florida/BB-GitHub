%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Assets By Asset Account Report"
  d2wName                 = "AssetsByAssetAccountReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "3"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if ((document.Chg.schedule.value =="") || (document.Chg.schedule.value =="0"))
                     {alert("$(reqFieldError)");
                      document.Chg.schedule.focus();
                      document.Chg.schedule.select();
                      return false;}

                  if (document.Chg.allAssetAccount.checked == true &&
                     (document.Chg.fromAccount.value > "" ))
                     {alert("From and to values are not valid with all selection");
                     document.Chg.fromAccount.focus();
                     document.Chg.fromAccount.select();
                     return false;}

                  if (document.Chg.allAssetAccount.checked == true &&
                     (document.Chg.fromSubaccount.value > "" ))
                     {alert("From and to values are not valid with all selection");
                     document.Chg.fromSubaccount.focus();
                     document.Chg.fromSubaccount.select();
                     return false;}

                  if (document.Chg.allAssetAccount.checked == true &&
                     (document.Chg.toAccount.value > "" ))
                     {alert("From and to values are not valid with all selection");
                     document.Chg.toAccount.focus();
                     document.Chg.toAccount.select();
                     return false;}

                  if (document.Chg.allAssetAccount.checked == true &&
                     (document.Chg.toSubaccount.value > "" ))
                     {alert("From and to values are not valid with all selection");
                     document.Chg.toSubaccount.focus();
                     document.Chg.toSubaccount.select();
                     return false;}

                  if (document.Chg.allAssetAccount.checked == false  &&
                     (document.Chg.fromAccount.value == "" && document.Chg.toAccount.value == "" && document.Chg.fromSubaccount.value == "" && document.Chg.toSubaccount.value == ""))
                     {alert("From to and all selections are all blank");
                     document.Chg.fromAccount.focus();
                     document.Chg.fromAccount.select();
                     return false;}

                  if (editNum(document.Chg.schedule, 2, 0) &&
                      editNum(document.Chg.fromCompany, 2, 0) &&
                      editNum(document.Chg.toCompany, 2, 0) &&
                      editNum(document.Chg.fromFacility, 4, 0) &&
                      editNum(document.Chg.toFacility, 4, 0) &&
                      editNum(document.Chg.fromAccount, 4, 0) &&
                      editNum(document.Chg.toAccount, 4, 0) &&
                      editNum(document.Chg.fromSubaccount, 4, 0) &&
                      editNum(document.Chg.toSubaccount, 4, 0) &&
                      editFromToAll(document.Chg.fromCompany, document.Chg.toCompany, document.Chg.allCompany, 2) &&
                      editFromToAll(document.Chg.fromFacility, document.Chg.toFacility, document.Chg.allFacility, 4)
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ASSETSBYASSETACCOUNT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
                      %INCLUDE "RequiredField.icl"
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "schedule")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@schd", "schedule") @dtw_assign(Err_SCHED,  fieldValue)
                                  @DecatErr_Field("@@sco@", "sortCompany")        @dtw_assign(Err_N1SCO#,  fieldValue)
                                  @DecatErr_Field("@@sfac", "sortFacility")        @dtw_assign(Err_N1SFAC,  fieldValue)
                                  @DecatErr_Field("@@faac", "fromAssetAccount")        @dtw_assign(Err_N1FAAC,  fieldValue)
                                  @DecatErr_Field("@@saac", "sortAssetAccount")        @dtw_assign(Err_N1SAAC,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@schd")  @dtw_assign(V_SCHED,  fieldValue)
                                  @Decat_Field("@@fco@")  @dtw_assign(V_N1FCO#,  fieldValue)
                                  @Decat_Field("@@tco@")  @dtw_assign(V_N1TCO#,  fieldValue)
                                  @Decat_Field("@@aco@")  @dtw_assign(V_N1ACO#,  fieldValue)
                                  @Decat_Field("@@sco@")  @dtw_assign(V_N1SCO#,  fieldValue)
                                  @Decat_Field("@@pco@")  @dtw_assign(V_N1PCO#,  fieldValue)
                                  @Decat_Field("@@ffac")  @dtw_assign(V_N1FFAC,  fieldValue)
                                  @Decat_Field("@@tfac")  @dtw_assign(V_N1TFAC,  fieldValue)
                                  @Decat_Field("@@afac")  @dtw_assign(V_N1AFAC,  fieldValue)
                                  @Decat_Field("@@sfac")  @dtw_assign(V_N1SFAC,  fieldValue)
                                  @Decat_Field("@@pfac")  @dtw_assign(V_N1PFAC,  fieldValue)
                                  @Decat_Field("@@faac")  @dtw_assign(V_N1FAAC,  fieldValue)
                                  @Decat_Field("@@fasu")  @dtw_assign(V_N1FASU,  fieldValue)
                                  @Decat_Field("@@taac")  @dtw_assign(V_N1TAAC,  fieldValue)
                                  @Decat_Field("@@tasu")  @dtw_assign(V_N1TASU,  fieldValue)
                                  @Decat_Field("@@aaac")  @dtw_assign(V_N1AAAC,  fieldValue)
                                  @Decat_Field("@@saac")  @dtw_assign(V_N1SAAC,  fieldValue)
                                  @Decat_Field("@@paac")  @dtw_assign(V_N1PAAC,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1ACO# == "ALL")
                                      @dtw_assign(checkedAllCompany, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllCompany, "")
                                  %endif
                                  %if (V_N1AFAC == "ALL")
                                      @dtw_assign(checkedAllFacility, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllFacility, "")
                                  %endif
                                  %if (V_N1AAAC == "ALL")
                                      @dtw_assign(checkedAllAssetAccount, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllAssetAccount, "")
                                  %endif

                                  %if (V_N1PCO# == "Y")
                                      @dtw_assign(checkedCompanyTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedCompanyTotals, "")
                                  %endif
                                  %if (V_N1PFAC == "Y")
                                      @dtw_assign(checkedFacilityTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedFacilityTotals, "")
                                  %endif
                                  %if (V_N1PAAC == "Y")
                                      @dtw_assign(checkedAssetAccountTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAssetAccountTotals, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedAllCompany, "CHECKED")
                                  @dtw_assign(checkedAllFacility, "CHECKED")
                                  @dtw_assign(checkedAllAssetAccount, "CHECKED")
                              %endif

                               @Default_Zero(V_SCHED)
                               @RtvFldDesc("SMSCHD=$(V_SCHED)", "FASCHD", "SMDESC", V_N1SCDD)
                              @SetTextOvr(Err_SCHED)
                              <tr><td align=right class="dsphdr"><span $(textOvr)>Schedule</td>
                                  <td class="inputnmbr"><input type="text" name="schedule" value="$(V_SCHED)" size="2" maxlength="2">$(reqFieldChar)
                                                        <a href="$(homeURL)$(cGIPath)AssetScheduleSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=schedule&amp;fldDesc=scheduleDescription" onclick="$(searchWinVar)">$(searchImage)</a>
                                                        <input type="text" disabled name="scheduleDescription" value="$(V_N1SCDD)" size="30"></td>
                              </tr>
                              @DspErrMsg(Err_SCHED)
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                                  <td class="colhdr">Print<br>Totals</td>
                              </tr>

                              @SetTextOvr(Err_N1FCO#)
                              <tr><td class="dsphdr"><span $(textOvr)>Company</td>
                                  <td class="inputnmbr"><input type="text" name="fromCompany" value="$(V_N1FCO#)" size="4" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)CoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=fromCompany&amp;fldFac=fromFacility&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                                                        <input type="hidden" name="coFacDesc"></td>
                                  <td class="inputnmbr"><input type="text" name="toCompany" value="$(V_N1TCO#)" size="4" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)CoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=toCompany&amp;fldFac=toFacility&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                                                        <input type="hidden" name="coFacDesc"></td>
                                  <td class="inputalph"><input type="checkbox" name="allCompany" value='ALL' $(checkedAllCompany) onClick="if (this.checked) this.form.fromCompany.value='', this.form.toCompany.value='';"></td>
                                  @Build_Sort_Select("sortCompany", "$(V_N1SCO#)")
                                  <td align=center ><input type="checkbox" name="totalCompany" $(checkedCompanyTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1SCO#)

                              @SetTextOvr(Err_N1FFAC)
                              <tr><td class="dsphdr"><span $(textOvr)>Facility </span></td>
                                  <td class="inputnmbr"><input type="text" name="fromFacility" value="$(V_N1FFAC)" size="4" maxlength="4"></td>
                                  <td class="inputnmbr"><input type="text" name="toFacility" value="$(V_N1TFAC)" size="4" maxlength="4"></td>
                                  <td class="inputalph"><input type="checkbox" name="allFacility" value='ALL' $(checkedAllFacility) onClick="if (this.checked) this.form.fromFacility.value='', this.form.toFacility.value='';"></td>
                                  @Build_Sort_Select("sortFacility", "$(V_N1SFAC)")
                                  <td align=center ><input type="checkbox" name="totalFacility" $(checkedFacilityTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1SFAC)

                              @SetTextOvr(Err_N1FAAC)
                              %if (textOvr == "") @SetTextOvr(Err_N1SAAC) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Asset Account</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromAccount" value="$(V_N1FAAC)" size="4" maxlength="4"> - <input type="text" name="fromSubaccount" value="$(V_N1FASU)" size="4" maxlength="4">
                                                        <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=fromAccount&amp;subFld=fromSubaccount&amp;descFld=accDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                                                        <input type="hidden" name="accDesc"></td>
                                  <td class="inputnmbr"><input type="text" name="toAccount" value="$(V_N1TAAC)" size="4" maxlength="4"> - <input type="text" name="toSubaccount" value="$(V_N1TASU)" size="4" maxlength="4">
                                                        <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=toAccount&amp;subFld=toSubaccount&amp;descFld=accDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                                                        <input type="hidden" name="accDesc"></td>
                                  <td class="inputalph"><input type="checkbox" name="allAssetAccount" value='ALL' $(checkedAllAssetAccount) onClick="if (this.checked) this.form.fromAccount.value='', this.form.fromSubaccount.value='', this.form.toAccount.value='', this.form.toSubaccount.value='';"></td>
                                  @Build_Sort_Select("sortAssetAccount", "$(V_N1SAAC)")
                                  <td align=center ><input type="checkbox" name="totalAssetAccount" $(checkedAssetAccountTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1FAAC)
                              @DspErrMsg(Err_N1SAAC)
                          </table>

                          @dtw_assign(envProgram, "HFAAWF")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HFAAFS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allCompany)
  @dtw_mUPPERCASE(allFacility)
  @dtw_mUPPERCASE(allAssetAccount)

  @dtw_assign(schedule,@dtw_rstrip(schedule))
  @dtw_assign(fromCompany,@dtw_rstrip(fromCompany))
  @dtw_assign(toCompany,@dtw_rstrip(toCompany))
  @dtw_assign(sortCompany,@dtw_rstrip(sortCompany))
  @dtw_assign(fromFacility,@dtw_rstrip(fromFacility))
  @dtw_assign(toFacility,@dtw_rstrip(toFacility))
  @dtw_assign(sortFacility,@dtw_rstrip(sortFacility))
  @dtw_assign(fromAccount,@dtw_rstrip(fromAccount))
  @dtw_assign(fromSubaccount,@dtw_rstrip(fromSubaccount))
  @dtw_assign(toAccount,@dtw_rstrip(toAccount))
  @dtw_assign(toSubaccount,@dtw_rstrip(toSubaccount))
  @dtw_assign(sortAssetAccount,@dtw_rstrip(sortAssetAccount))

  %if (allCompany != "ALL")
      @dtw_assign(allCompany, "")
  %endif
  %if (allFacility != "ALL")
      @dtw_assign(allFacility, "")
  %endif
  %if (allAssetAccount != "ALL")
      @dtw_assign(allAssetAccount, "")
  %endif

  %if (totalCompany != "Y")
      @dtw_assign(totalCompany, "N")
  %endif
  %if (totalFacility != "Y")
      @dtw_assign(totalFacility, "N")
  %endif
  %if (totalAssetAccount != "Y")
      @dtw_assign(totalAssetAccount, "N")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@schd", schedule)
  @Concat_Field("@@fco@", fromCompany)
  @Concat_Field("@@tco@", toCompany)
  @Concat_Field("@@aco@", allCompany)
  @Concat_Field("@@sco@", sortCompany)
  @Concat_Field("@@pco@", totalCompany)
  @Concat_Field("@@ffac", fromFacility)
  @Concat_Field("@@tfac", toFacility)
  @Concat_Field("@@afac", allFacility)
  @Concat_Field("@@sfac", sortFacility)
  @Concat_Field("@@pfac", totalFacility)
  @Concat_Field("@@faac", fromAccount)
  @Concat_Field("@@fasu", fromSubaccount)
  @Concat_Field("@@taac", toAccount)
  @Concat_Field("@@tasu", toSubaccount)
  @Concat_Field("@@aaac", allAssetAccount)
  @Concat_Field("@@saac", sortAssetAccount)
  @Concat_Field("@@paac", totalAssetAccount)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}