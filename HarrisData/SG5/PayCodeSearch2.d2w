%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "WildCardAcct.icl"

%Define {	
  page_title 	           = "Pay Code Search"
  d2wName                 = "PayCodeSearch2.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;prCompany=@dtw_rurlescseq(prCompany)&amp;prFacility=@dtw_rurlescseq(prFacility)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script type="text/javascript">
              function selectCode(paycode, codeDesc){
                  window.opener.document.$(docName).$(fldName).value = paycode;
                  window.opener.document.$(docName).$(fldDesc).value = codeDesc;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(uv_CompanyName, "C2COMP")
                      @dtw_assign(uv_FacilityName, "C2FACL")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select C2CODE, C2DESC, C2HRCD, C2STRT, C2END, C2ACCT, C2SUB, C2SMTY, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(C2DESC) as C2DESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " PRCODE ", fileSQL)
                      @dtw_concat(selectSQL, " C2COMP=$(prCompany) and C2FACL=$(prFacility) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @PayCode_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) PayCode_Search (IN CHAR(64)    profileHandle,
				      CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr">Description</th>
                  <th class="colhdr">Pay Code</th>
              </tr>
              <tr><td class="inputalph"><input type="text" name="srchDesc" size="20" maxlength="20">
                      <input type="hidden" name="operDesc" value="LIKE">
                  </td>
                  <td class="inputnmbr"><input type="text" name="srchCode" size="6" maxlength="3">
                      <input type="hidden" name="operCode" value="LIKE">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
          <script TYPE="text/javascript">
              document.Search.srchDesc.focus();
          </script>
      </form>
	
      %INCLUDE "WildCardPage.icl"

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              @OrderBy_Sort("C2CODE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=paycode" title="Sequence By Pay Code"> Pay Code</a></th>
              @OrderBy_Sort("C2DESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=name" title="Sequence By Description"> Description</a></th>
              @OrderBy_Sort("C2HRCD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=HoursUnit" title="Sequence By Hours/Units, Company/Facility, Pay Code">Hours/<br>Units</a></th>
              @OrderBy_Sort("C2STRT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=StartDate" title="Sequence By Start Date, Company/Facility, Pay Code"> Start<br>Date</a></th>
              @OrderBy_Sort("C2END", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=EndDate" title="Sequence By End Date, Company/Facility, Pay Code">End<br>Date</a></th>
              @OrderBy_Sort("C2ACCT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Account" title="Sequence By Account, Company/Facility, Pay Code">Account</a></th>
              @OrderBy_Sort("C2SMTY", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SummaryType" title="Sequence By Summary Type, Company/Facility, Pay Code">Summary<br>Type</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Quote(V_C2CODE, F_C2CODE)
              @Format_Quote(V_C2DESC, F_C2DESC)
              <tr class="$(rowClass)">
                  @Format_Acct("$(V_C2ACCT)", "$(V_C2SUB)", "", F_AcctSub)
                  @Format_Date(V_C2STRT, "D", F_C2STRT)
                  @Format_Date(V_C2END, "D", F_C2END)
                  <td class="colcode">$(V_C2CODE)</td>
                  <td class="colalph"><a href="javascript:selectCode('$(F_C2CODE)','$(F_C2DESC)')" title="Select Pay Code">$(V_C2DESC)</a></td>
                  <td class="colcode">$(V_C2HRCD)</td>
                  <td class="coldate">$(F_C2STRT)</td>
                  <td class="coldate">$(F_C2END)</td>
                  <td class="colnmbr">$(F_AcctSub)</td>
                  <td class="colcode">$(V_C2SMTY)</td>
              </tr>
      %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "C2DESCU,C2CODE")
      @DTW_ASSIGN(orderByDisplay, "Description, Pay Code")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "paycode")
      %if (orderBy == "C2CODE")
          @DTW_ASSIGN(orderBy, "C2CODE DESC")
          @DTW_ASSIGN(orderByDisplay, "Pay Code (descending)")
      %else
          @DTW_ASSIGN(orderBy, "C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Pay Code")
      %endif
  %elseif (sequence == "name")
      %if (orderBy == "C2DESCU,C2CODE")
          @DTW_ASSIGN(orderBy, "C2DESCU DESC,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Pay Code")
      %else
          @DTW_ASSIGN(orderBy, "C2DESCU,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Description, Pay Code")
      %endif
  %elseif (sequence == "HoursUnit")
      %if (orderBy == "C2HRCD,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderBy, "C2HRCD DESC,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Hours/Unit (descending), Company/Facility, Pay Code")
      %else
          @DTW_ASSIGN(orderBy, "C2HRCD,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Hours/Unit, Company/Facility, Pay Code")
      %endif
  %elseif (sequence == "StartDate")
      %if (orderBy == "C2STRT,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderBy, "C2STRT DESC,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Start Date (descending), Company/Facility, Pay Code")
      %else
          @DTW_ASSIGN(orderBy, "C2STRT,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Start Date, Company/Facility, Pay Code")
      %endif
  %elseif (sequence == "EndDate")
      %if (orderBy == "C2END,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderBy, "C2END DESC,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "End Date (descending), Company/Facility, Pay Code")
      %else
          @DTW_ASSIGN(orderBy, "C2END,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "End Date, Company/Facility, Pay Code")
      %endif
  %elseif (sequence == "Account")
      %if (orderBy == "C2ACCT,C2SUB,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderBy, "C2ACCT DESC,C2SUB DESC,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Account (descending), Company/Facility, Pay Code")
      %else
          @DTW_ASSIGN(orderBy, "C2ACCT,C2SUB,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Account, Company/Facility, Pay Code")
      %endif
  %elseif (sequence == "SummaryType")
      %if (orderBy == "C2SMTY,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderBy, "C2SMTY DESC,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Summary Type (descending), Company/Facility, Pay Code")
      %else
          @DTW_ASSIGN(orderBy, "C2SMTY,C2COMP,C2FACL,C2CODE")
          @DTW_ASSIGN(orderByDisplay, "Summary Type, Company/Facility, Pay Code")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editdate(document.Search.srchStart) &&
                      editdate(document.Search.srchEnd) &&
                      editNum(document.Search.srchAcct, 4, 0) &&
                      editNum(document.Search.srchSub, 4, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Pay Code</td>
                              @dtw_assign(operNbr, "operCode")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchCode" size="3" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchDesc" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Hours Or Units</td>
                              @dtw_assign(operNbr, "operHourUnit")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchHourUnit" size="1" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Start Date</td>
                              @dtw_assign(operNbr, "operStart")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchStart" size="6" maxlength="6"><a href="javascript:calWindow('srchStart');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">End Date</td>
                              @dtw_assign(operNbr, "operEnd")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchEnd" size="6" maxlength="6"><a href="javascript:calWindow('srchEnd');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">G/L Account</td>
                              @dtw_assign(operNbr, "operAcct")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchAcct" size="4" maxlength="4">
                                                          <input type="text" name="srchSub" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Summary Type</td>
                              @dtw_assign(operNbr, "operSumType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchSumType" size="1" maxlength="1"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchCode.focus();
                          </script>
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
		
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("C2CODE", "Pay Code", $(srchCode), "U", operCode, "A")
  @Build_WildCard ("upper(C2DESC)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("C2HRCD", "Hours Or Units", $(srchHourUnit), "U", operHourUnit, "A")
  @Build_WildCard ("C2STRT", "Start Date", $(srchStart), "", operStart, "D")
  @Build_WildCard ("C2END", "End Date", $(srchEnd), "", operEnd, "D")
  @Build_WildCard_Acct ("C2ACCT", "C2SUB", "G/L Account", $(srchAcct), $(srchSub), $(operAcct))
  @Build_WildCard ("C2SMTY", "Summary Type", $(srchSumType), "U", operSumType, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}