%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "XML Decompose"
  d2wName                 = "XMLImport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  submitNoSelection       = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              function validate(chgForm) {
                  if (document.Chg.dadFileName.value =="" ||
                      document.Chg.xmlFileName.value =="")
                     {alert("$(reqFieldError)"); return false;}
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "XMLIMPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")                   @dtw_assign(submitSchedule, fieldValue)
                                  @Decat_Field("@@dadf")                   @dtw_assign(dadFileName, fieldValue)
                                  @Decat_Field("@@xmlf")                   @dtw_assign(xmlFileName, fieldValue)
                                  @DecatErr_Field("@@dadf", "dadFileName") @dtw_assign(Err_dadFileName, fieldValue)
                                  @DecatErr_Field("@@xmlf", "xmlFileName") @dtw_assign(Err_xmlFileName, fieldValue)

                                  %INCLUDE "ScheduleJobErr.icl"      %{ Schedule Entries Errors %}
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                              %endif

                              @SetTextOvr(Err_dadFileName)
                              <tr><td class="dsphdr"><span $(textOvr)>DAD File</span></td>
                                  <td class="inputalph"><input name="dadFileName" type="text" value="$(dadFileName)" size="50" maxlength="200"> $(reqFieldChar) </td>
                              </tr>
                              @DspErrMsg(Err_dadFileName)

                              @SetTextOvr(Err_xmlFileName)
                              <tr><td class="dsphdr"><span $(textOvr)>XML File</span></td>
                                  <td class="inputalph"><input name="xmlFileName" type="text" value="$(xmlFileName)" size="50" maxlength="200"> $(reqFieldChar) </td>
                              </tr>
                              @DspErrMsg(Err_xmlFileName)
                          </table>

                          @dtw_assign(envProgram, "HSYXDB")
                          @dtw_assign(envPrinter, "")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSYXDB_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtwf_exists(dadFileName, dadFileExists)
  @dtwf_exists(xmlFileName, xmlFileExists)

  @dtw_assign(edtVar, "")
  @Concat_Field("@@dadf", dadFileName)
  @Concat_Field("@@xmlf", xmlFileName)
  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  %if (dadFileExists != "Y" || xmlFileExists != "Y")
      @dtw_assign(errFound, "Y")
      @dtw_assign(errVar, "}{")
      %if (dadFileExists != "Y")
          @dtw_concat(errVar, "@@dadfDAD File not found in FFI path}{", errVar)
      %endif
      %if (xmlFileExists != "Y")
          @dtw_concat(errVar, "@@xmlfXML File not found in FFI path}{", errVar)
      %endif
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;scheduleJobSwitch=Y&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %else
      @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)
      %INCLUDE "SubmitScheduleUpdate.icl"
  %endif
%}
