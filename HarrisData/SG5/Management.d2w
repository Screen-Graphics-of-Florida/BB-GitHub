%INCLUDE "$(baseVar)"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "ErrorMessage.icl"

%Define {	
  page_title              = "Management"
  DATABASE                = "*LOCAL"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
              <!-- Start Of Bannerer Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
                  <table $(baseTable)>
                      <tr valign="top">
                          @dtw_assign(pageID, "MANAGEMENT")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                          <td class="content">
                              %INCLUDE "PageTitle.icl"
                              $(hrTagAttr)
                              %INCLUDE "Copyright.icl"
                          </td>
                      </tr>
                  </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
             <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL()
%}