%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "MRP Processing/Reports"
  d2wName                 = "MRPProcessingReports.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if ((document.Chg.plantNumber.value =="") || (document.Chg.plantNumber.value =="0"))
                     {alert("$(reqFieldError)");
                      document.Chg.plantNumber.focus();
                      document.Chg.plantNumber.select();
                      return false;}

                  if ((document.Chg.job1.checked == false) && (document.Chg.job2.checked == true))
                     {alert("Cannot select 'Inventory Use Up Update' without selecting 'Inventory Use Up Report'");
                      return false;}

                  if (editNum(document.Chg.plantNumber, 3, 0))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "MRPPROCESSINGREPORTS")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
                      %INCLUDE "RequiredField.icl"
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "plantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@plnt", "plantNumber") @dtw_assign(Err_N1PLNT,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@plnt")  @dtw_assign(V_N1PLNT,  fieldValue)
                                  @Decat_Field("@@opt2")  @dtw_assign(V_REPORT2, fieldValue)
                                  @Decat_Field("@@opt3")  @dtw_assign(V_REPORT3, fieldValue)
                                  @Decat_Field("@@opt4")  @dtw_assign(V_REPORT4, fieldValue)
                                  @Decat_Field("@@opt5")  @dtw_assign(V_REPORT5, fieldValue)
                                  @Decat_Field("@@opt6")  @dtw_assign(V_REPORT6, fieldValue)
                                  @Decat_Field("@@opt7")  @dtw_assign(V_REPORT7, fieldValue)
                                  @Decat_Field("@@opt8")  @dtw_assign(V_REPORT8, fieldValue)
                                  @Decat_Field("@@iur@")  @dtw_assign(V_JOB1, fieldValue)
                                  @Decat_Field("@@iuu@")  @dtw_assign(V_JOB2, fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_REPORT2 == "1")
                                      @dtw_assign(checkedReport2, "CHECKED")
                                  %else
                                      @dtw_assign(checkedReport2, "")
                                  %endif
                                  %if (V_REPORT3 == "1")
                                      @dtw_assign(checkedReport3, "CHECKED")
                                  %else
                                      @dtw_assign(checkedReport3, "")
                                  %endif
                                  %if (V_REPORT4 == "1")
                                      @dtw_assign(checkedReport4, "CHECKED")
                                  %else
                                      @dtw_assign(checkedReport4, "")
                                  %endif
                                  %if (V_REPORT5 == "1")
                                      @dtw_assign(checkedReport5, "CHECKED")
                                  %else
                                      @dtw_assign(checkedReport5, "")
                                  %endif
                                  %if (V_REPORT6 == "1")
                                      @dtw_assign(checkedReport6, "CHECKED")
                                  %else
                                      @dtw_assign(checkedReport6, "")
                                  %endif
                                  %if (V_REPORT7 == "1")
                                      @dtw_assign(checkedReport7, "CHECKED")
                                  %else
                                      @dtw_assign(checkedReport7, "")
                                  %endif
                                  %if (V_REPORT8 == "1")
                                      @dtw_assign(checkedReport8, "CHECKED")
                                  %else
                                      @dtw_assign(checkedReport8, "")
                                  %endif
                                  %if (V_JOB1 == "1")
                                      @dtw_assign(checkedJob1, "CHECKED")
                                  %else
                                      @dtw_assign(checkedJob1, "")
                                  %endif
                                  %if (V_JOB2 == "1")
                                      @dtw_assign(checkedJob2, "CHECKED")
                                  %else
                                      @dtw_assign(checkedJob2, "")
                                  %endif
                              %else
                                  @RtvDftPlant(plantNumber, plantName)
                                  %if (plantNumber > "0")
                                      @dtw_assign(V_N1PLNT, plantNumber)
                                  %else
                                      @dtw_assign(V_N1PLNT, "0")
                                  %endif
                                  @dtw_assign(checkedReport2, "CHECKED")
                                  @dtw_assign(checkedReport3, "CHECKED")
                                  @dtw_assign(checkedReport4, "CHECKED")
                                  @dtw_assign(checkedReport5, "CHECKED")
                                  @dtw_assign(checkedReport6, "CHECKED")
                                  @dtw_assign(checkedReport7, "CHECKED")
                                  @dtw_assign(checkedReport8, "CHECKED")
                                  @dtw_assign(checkedJob1, "")
                                  @dtw_assign(checkedJob2, "")
                              %endif

                          </table>

                          <table $(contentTable)>
                              @RtvFldDesc("PLPLNT=$(V_N1PLNT)", "HDPLNT", "PLNAME", fieldDesc)
                              @SetTextOvr(Err_N1PLNT)
                              <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                  <td class="inputnmbr"><input name="plantNumber" value="$(V_N1PLNT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=plantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input name="plantName" value="$(fieldDesc)" type="text" size="30" maxlength="30"></td>
                              </tr>
                              @DspErrMsg(Err_N1PLNT)

                              <tr><td>&nbsp;</td></tr>
                              <tr><td>&nbsp;</td></tr>
                          </table>

                          <table $(contentTable)>
                              <tr><td class="dsphdr">Select Any Of The Following Optional Reports:</td></tr>
                          </table>

                          <table $(contentTable)>
                              <tr><td class="inputnmbr"><input name="report2" type="checkbox" VALUE='1' $(checkedReport2)>Master Build Schedule</td>
                              </tr>
                              <tr><td class="inputnmbr"><input name="report3" type="checkbox" VALUE='1' $(checkedReport3)>Material Requirements Planning Preparation</td>
                              </tr>
                              <tr><td class="inputnmbr"><input name="report4" type="checkbox" VALUE='1' $(checkedReport4)>MRP Print</td>
                              </tr>
                              <tr><td class="inputnmbr"><input name="report5" type="checkbox" VALUE='1' $(checkedReport5)>Pegged Requirements</td>
                              </tr>
                              <tr><td class="inputnmbr"><input name="report6" type="checkbox" VALUE='1' $(checkedReport6)>Order Action By Buyer Analyst</td>
                              </tr>
                              <tr><td class="inputnmbr"><input name="report7" type="checkbox" VALUE='1' $(checkedReport7)>Planned Orders By Buyer Analyst</td>
                              </tr>
                              <tr><td class="inputnmbr"><input name="report8" type="checkbox" VALUE='1' $(checkedReport8)>Kanban Action</td>
                              </tr>
                          </table>

                          <table $(contentTable)>
                              <tr><td></td></tr>
                              <tr><td></td></tr>
                              <tr><td class="dsphdr">Select Any Of The Following Optional Jobs:</td></tr>
                          </table>

                          <table $(contentTable) >
                              <tr><td class="inputnmbr"><input name="job1" type="checkbox" VALUE='1' $(checkedJob1)>Inventory Use Up Report</td>
                              </tr>
                              <tr><td class="inputnmbr"><input name="job2" type="checkbox" VALUE='1' $(checkedJob2)>Inventory Use Up Update</td>
                              </tr>
                          </table>

                          <table border>
                              <tr><td class="dsphdr">** WARNING ** Selecting the Inventory Use Up Update option will make<br>changes to the Effectivity Dates in the Product Structure table</td></tr>
                          </table>

                          @dtw_assign(envProgram, "CMRS02")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HMRMRS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"

  @dtw_assign(plantNumber,@dtw_rstrip(plantNumber))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plnt", plantNumber)
  @Concat_Field("@@opt2", report2)
  @Concat_Field("@@opt3", report3)
  @Concat_Field("@@opt4", report4)
  @Concat_Field("@@opt5", report5)
  @Concat_Field("@@opt6", report6)
  @Concat_Field("@@opt7", report7)
  @Concat_Field("@@opt8", report8)
  @Concat_Field("@@iur@", job1)
  @Concat_Field("@@iuu@", job2)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}