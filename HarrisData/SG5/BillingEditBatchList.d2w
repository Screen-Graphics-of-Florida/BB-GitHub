%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Edit List"
  d2wName                 = "BillingEditBatchList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;batchNumber=@dtw_rurlescseq(batchNumber)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
  batchNumber             = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%FUNCTION(dtw_sql) FileB_Query (IN  CHAR(64)    profileHandle,
                                    CHAR(2)     dataBaseID,
                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count == "0")
          @DTW_EXIT()
      %endif

      <table $(contentTable)>
          %ROW{
              <tr><td class="colhdr">Batch<br>Number</td>
                  %if (V_BBSTDT > "0")
                      <td class="colhdr">Shipments<br>Through</td>
                  %endif
                  %if (V_BBRODT > "0")
                      <td class="colhdr">Recurring Orders<br>Through</td>
                  %endif
                  <td class="colhdr">Locations</td>
              </tr>

              <tr class="oddrow">
                  <td class="colnmbr"> $(V_BBBTCH)</td>
                  %if (V_BBSTDT > "0")
                      @Format_Date(V_BBSTDT, "D", F_BBSTDT)
                      <td class="coldate"> $(F_BBSTDT)</td>
                  %endif
                  %if (V_BBRODT > "0")
                      @Format_Date(V_BBRODT, "D", F_BBRODT)
                      <td class="coldate">$(F_BBRODT)</td>
                  %endif
                  <td class="colcode">
                      %if (V_BBFLOC=="1" && V_BBTLOC=="999")
                          All
                      %else
                          $(V_BBFLOC) - $(V_BBTLOC)
                      %endif
                  </td>
              </tr>
          %}
      </table>
  %}
%}

%FUNCTION(dtw_sql) FileC_Query (IN  CHAR(64)    profileHandle,
                                    CHAR(2)     dataBaseID,
                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count == "0")
          @DTW_EXIT()
      %endif

      <table $(contentTable)>
          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  @RtvFldDesc("BCBCDE='$(V_BCBCDE)'", "OEBCDE", "BCDESC", fieldDesc)
                  <td class="colalph">$(V_BCBCDE)</td> 	
                  <td>&nbsp;</td>
                  <td class="colalph">$(fieldDesc)</td>
              </tr>
          %}
      </table>
  %}
%}

%FUNCTION(dtw_sql) FileT_Query (IN  CHAR(64)    profileHandle,
                                    CHAR(2)     dataBaseID,
                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count == "0")
          @DTW_EXIT()
      %endif

      <table $(contentTable)>
          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  @RtvFldDesc("OTOTCD='$(V_BTOTYP)' and OTAPID='OE'", "HDOTYP", "OTDESC", fieldDesc)
                  <td class="colalph">$(V_BTOTYP)</td> 	
                  <td>&nbsp;</td>
                  <td class="colalph">$(fieldDesc)</td>
              </tr>
          %}
      </table>
  %}
%}

%FUNCTION(dtw_directcall) Update_Billing_Edit (IN    CHAR(64)    profileHandle,
                                                     CHAR(2)     dataBaseID,
                                                     CHAR(2)     updCode,
                                               INOUT CHAR(1)     errFound,
                                               INOUT CHAR(32000) edtVar,                             	
                                               INOUT CHAR(32000) errVar)
{%EXEC {HOEESL_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("BBBTCH=$(batchNumber)", "OEBIPB", "char(BBBTCH)", batch)
  %if (batch == "")
       @dtw_assign(confMessage, "Selected Batch Number $(batchNumber) not found")
       <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)BillingEditBatch.d2w/REPORT$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  %INCLUDE "NoFormValidate.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "BILLINGEDITBATCHLIST")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          %INCLUDE "SubmitScheduleTopNS.icl"
                          $(hrTagAttr)

                          @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                          @dtw_assign(SAVE_MAX_ROWS, RPT_MAX_ROWS)
                          @dtw_assign(START_ROW_NUM, "1")
                          @dtw_assign(RPT_MAX_ROWS, "99")

                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " OEBIPB ", fileSQL)
                          @dtw_concat(selectSQL, "BBBTCH = $(batchNumber) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"

                          @FileB_Query(profileHandle, dataBaseID, stmtSQL)

                          @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                          @dtw_assign(RPT_MAX_ROWS, SAVE_MAX_ROWS)
                          <table $(contentTable)>
                              <tr>
                                  <th class="colhdr">Billing Code</th>
                                  <th class="colhdr">Order Type</th>
                              </tr>
                              <tr valign="top">
                                  <td>
                                      @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                                      @dtw_assign(SAVE_MAX_ROWS, RPT_MAX_ROWS)
                                      @dtw_assign(START_ROW_NUM, "1")
                                      @dtw_assign(RPT_MAX_ROWS, "99")

                                      %INCLUDE "stmtSQLClear.icl"
                                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                      @dtw_concat(fileSQL, " OEBIPC ", fileSQL)
                                      @dtw_concat(selectSQL, "BCBTCH = $(batchNumber) ", selectSQL)
                                      %INCLUDE "stmtSQLSelect.icl"
                                      %INCLUDE "stmtSQLEnd.icl"
                                      %INCLUDE "stmtSQLTotalRows.icl"

                                      @FileC_Query(profileHandle, dataBaseID, stmtSQL)

                                      @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                                      @dtw_assign(RPT_MAX_ROWS, SAVE_MAX_ROWS)
                                  </td>
                                  <td>
                                      @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                                      @dtw_assign(SAVE_MAX_ROWS, RPT_MAX_ROWS)
                                      @dtw_assign(START_ROW_NUM, "1")
                                      @dtw_assign(RPT_MAX_ROWS, "99")

                                      %INCLUDE "stmtSQLClear.icl"
                                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                      @dtw_concat(fileSQL, " OEBIPT ", fileSQL)
                                      @dtw_concat(selectSQL, "BTBTCH = $(batchNumber) ", selectSQL)
                                      %INCLUDE "stmtSQLSelect.icl"
                                      %INCLUDE "stmtSQLEnd.icl"
                                      %INCLUDE "stmtSQLTotalRows.icl"

                                      @FileT_Query(profileHandle, dataBaseID, stmtSQL)

                                      @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                                      @dtw_assign(RPT_MAX_ROWS, SAVE_MAX_ROWS)
                                  </td>
                              </tr>
                              <tr><td>
                                  <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(d2wVarBase)">
                                      %INCLUDE "schedulesubmitquestion.icl"
                                  </form>
                                  %INCLUDE "SubmitScheduleBottomNS.icl"
                                  </td>
                              </tr>
                          </table>
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%HTML(UPDATE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(edtVar, "")
  @Concat_Field("@@btch", batchNumber)
  @Concat_Field("@@scde", submitSchedule)
  @dtw_concat(edtVar, "}{", edtVar)

  %if (submitSchedule == "M")
      %INCLUDE "SubmitScheduleMessage.icl"
      @dtw_assign(updCode, "BT")
      @Update_Billing_Edit (profileHandle, dataBaseID, updCode, errFound, edtVar, errVar)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)billing.d2w/REPORT$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(d2wName)/SCHEDULE$(d2wVarBase)&amp;submitSchedule=@dtw_rurlescseq(submitSchedule)">
  %endif
%}

%HTML(SCHEDULE) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "BILLINGEDITBATCHLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTopNS.icl"
                      $(hrTagAttr)
            		
                      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_SCHEDULE$(d2wVarBase)&amp;submitSchedule=@dtw_rurlescseq(submitSchedule)">
                          %if (errFound != "")
                              @EdtVarErr(profileHandle, typeValue, edtVar)
                              @dtw_assign(focusField, "")
                              @ErrVarErr(profileHandle, typeError, errVar)
                              %INCLUDE "scheduleJobErr.icl"    %{ Schedule Entries Errors %}
                              %INCLUDE "scheduleJobValue.icl"  %{ Schedule Entries Values %}
                          %endif
                          @dtw_assign(envProgram, "HOEPEL")
                          @dtw_assign(envPrinter, "HOEPELPF")
                          %INCLUDE "schedulejobNS.icl"
                          %INCLUDE "SubmitScheduleBottomNS.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(Edit_SCHEDULE)
  {
      %INCLUDE "setLibraryList.icl"

      @dtw_assign(edtVar, "")
      @Concat_Field("@@scde", submitSchedule)
      %INCLUDE "scheduleJobConcatNS.icl"    %{ Schedule Entries Values %}
      @dtw_concat(edtVar, "}{", edtVar)

      @dtw_assign(updCode, "BT")
      @Update_Billing_Edit (profileHandle, dataBaseID, updCode, errFound, edtVar, errVar)

      %if (errFound == "")
          %INCLUDE "SubmitScheduleMessage.icl"
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)billing.d2w/REPORT$(genericVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          @EdtVarErr(profileHandle, typeValue, edtVar)
          @ErrVarErr(profileHandle, typeError, errVar)
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/SCHEDULE$(d2wVarBase)&amp;submitSchedule=@dtw_rurlescseq(submitSchedule)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
      %endif
  %}