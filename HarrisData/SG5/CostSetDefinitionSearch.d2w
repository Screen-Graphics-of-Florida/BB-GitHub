%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Cost Set Definition Search"
  d2wName                 = "CostSetDefinitionSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
  advanceSearch           = "N"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectCostSet(costSet, desc){
                  window.opener.document.$(docName).$(fldName).value = costSet;
                  window.opener.document.$(docName).$(fldDesc).value = desc;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select STCSET, STCSSD, STCSLD, upper(STCSLD) as STCSLDU, STDTLR, STEFDT", stmtSQL)
                      @dtw_concat(fileSQL, " SCMSTM ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, "STCSET>0 ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Cost_Set_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) Cost_Set_Search (IN  CHAR(64) profileHandle,
				           CHAR(2)   dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr">Description</th>
                  <th class="colhdr">Cost <br> Set</th>
              </tr>
              <tr><td class="inputalph">
                      <input type="text" name="srchDesc" size="30" maxlength="25">
                      <input type="hidden" name="operDesc" value="LIKE">
                  </td>
                  <td class="inputnmbr">
                      <input type="text" name="srchCostSet" size="2" maxlength="2">
                      <input type="hidden" name="operCostSet" value="=">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
          <script TYPE="text/javascript">
              document.Search.srchDesc.focus();
          </script>
      </form>
	
      %INCLUDE "WildCardPage.icl"

      <table $(contentTable)>
          <tr>	
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("STCSLDU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=description" title="Sequence By Description"> Description</a></th>
              @OrderBy_Sort("STCSET", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=costSet" title="Sequence By Cost Set"> Cost <br> Set</a></th>
              <th class="colhdr">Short<br>Description</th>
              <th class="colhdr">Date of<br>Last Roll</th>
              <th class="colhdr">Effectivity<br>Date</th>
          </tr>
           %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Date(V_STDTLR, "D", F_STDTLR)
              @Format_Date(V_STEFDT, "D", F_STEFDT)
              @Format_Quote(V_STCSLD, F_STCSLD)

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="javascript:selectCostSet($(V_STCSET),'$(F_STCSLD)')" title="Select Cost Set">$(V_STCSLD)</a></td>
                  <td class="colcode">$(V_STCSET)</td>
                  <td class="colalph">$(V_STCSSD)</td>
                  <td class="colalph">$(F_STDTLR)</td>
                  <td class="colalph">$(F_STEFDT)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "STCSLDU, STCSET")
      @DTW_ASSIGN(orderByDisplay, "Description, Cost Set")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY)  {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "description")
      %if (orderBy == "STCSLDU, STCSET")
          @DTW_ASSIGN(orderBy, "STCSLDU DESC, STCSET")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Cost Set")
      %else
          @DTW_ASSIGN(orderBy, "STCSLDU, STCSET")
          @DTW_ASSIGN(orderByDisplay, "Description, Cost Set")
      %endif
  %elif (sequence == "costSet")
      %if (orderBy == "STCSET")
          @DTW_ASSIGN(orderBy, "STCSET DESC")
          @DTW_ASSIGN(orderByDisplay, "Cost Set (descending)")
      %else
          @DTW_ASSIGN(orderBy, "STCSET")
          @DTW_ASSIGN(orderByDisplay, "Cost Set")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("upper(STCSLD)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("STCSET", "Cost Set", $(srchCostSet), "", operCostSet, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}