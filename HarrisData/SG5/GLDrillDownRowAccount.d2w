%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"

%Define {
  page_title              = "G/L Drill Down Report Accounts"
  d2wName                 = "GLDrillDownRowAccount.d2w"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  DTW_PAD_PGM_PARMS       = "YES"
  dspMaxRows              = "$(dspMaxRowsDft)"
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64) profileHandle,
                                   CHAR(2)   dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "headcmt.icl"
          </head>

          <body $(bodyTagAttr) onload="window.focus()" onblur="window.close()">
              <!-- Start Of Banner Code -->
              %INCLUDE "$(cmtBanner)"
              <!-- End Of Banner Code -->

              <h2> $(rowDescr)</h2>
              $(inquiryhrTagAttr)

              <table $(contentTable)>
                  <tr>%if (accountNumber == "0")
                          <th class="colhdr">Account</th>
                          <th class="colhdr">Description</th>
                      %else
                          <th class="colhdr">Co/Fac</th>
                          <th class="colhdr">Name</th>
                      %endif
                      <th class="colhdr">Date<br>Deactivated</th>
                  </tr>

                  %ROW{
                      %while(@dtw_rlength(V_DRFAC) != "4") {@dtw_insert("0", V_DRFAC, V_DRFAC)%}

                      @Format_Date(V_DRDTDE, "D", F_DRDTDE)

                      <tr>%if (accountNumber == "0")
                              @Format_Acct("$(V_DRACCT)", "$(V_DRSUB)", "", F_AcctSub)
                              <td class="colnmbr">$(F_AcctSub)</td>
                          %else
                              <td class="colnmbr">$(V_DRCO)-$(V_DRFAC)</td>
                          %endif
                          <td class="colalph">$(V_DRGRRE)</td>
                          <td class="coldate">$(F_DRDTDE)</td>
                      </tr>
                  %}
              </table>
              $(inquiryhrTagAttr)
              <!-- Start Of Trailer Code -->
              %INCLUDE "$(cmtTrailer)"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "SELECT * ", stmtSQL)
  @dtw_concat(fileSQL, " GLDWRW ", fileSQL)
  @dtw_concat(selectSQL, " DRXHND='$(profileHandle)' and DRGRSN='$(ddReport)' ", selectSQL)
  @dtw_concat(selectSQL, " and DRRCO=$(ddCompany) and DRRFAC=$(ddFacility) ", selectSQL)
  @dtw_concat(selectSQL, " and DRGRR#=$(ddRow) and DRMACC=$(ddAccount)", selectSQL)
  @dtw_concat(selectSQL, " and DRMSUB=$(ddSubAccount) and DRGRC#=$(ddColumn)", selectSQL)
  @dtw_concat(selectSQL, " and DRACCT<>0", selectSQL)
  %if (accountNumber != "0")
      @dtw_concat(selectSQL, " and DRACCT=$(accountNumber) and DRSUB=$(subAccount)", selectSQL)
      @dtw_concat(selectSQL, " and DRCO<>0", selectSQL)
  %else
      @dtw_concat(selectSQL, " and DRCO=0", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " order by DRRCO, DRRFAC, DRGRR#, DRACCT, DRSUB, DRCO, DRFAC  ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  %INCLUDE "stmtSQLTotalRows.icl"
  @List_Query(profileHandle, dataBaseID, stmtSQL)
%}
