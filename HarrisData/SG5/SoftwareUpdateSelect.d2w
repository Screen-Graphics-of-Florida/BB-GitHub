%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "ProblemID.icl"

%Define {
  page_title              = "Software Update"
  d2wName                 = "SoftwareUpdateSelect.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;problemIDNumber=@dtw_rurlescseq(problemIDNumber)&amp;problemDescription=@dtw_rurlescseq(problemDescription)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@problemIDNumber", "@dtw_rurlescseq(problemIDNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@problemDescription", "@dtw_rurlescseq(problemDescription)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- Start Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "SOFTWAREMGMT")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif

                      <td class="content">

%{ quicklinkSeqTable %}
                          @dtw_assign(RPT_MAX_ROWS, "99")
                          @dtw_assign(dspMaxRows, "99")
                          @QuicklinkSequence(profileHandle, dataBaseID, d2wName, quicklinkSeqTable)
                          @dtw_tb_rows(quicklinkSeqTable,quicklinkCount)
%{ remove table updates %} @Remove_Quick_Link("fileupdates")
                          %if (quicklinkCount == "0" || quicklinkCount == "")
                              %{ If the table is empty, then display NO quicklinks. %}
                              @dtw_assign(quicklinkCount, "0")
                          %endif
%{ Problem Heading %}
                          @dtw_assign(RPT_MAX_ROWS, "99")
                          @dtw_assign(dspMaxRows, "10")
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select PLPRID,PLSEQ,PLPRDS,PLCLRL,PLCLLL,PLRFSH,PLPRFS,PLIRFS,PLSTAT,PLTSTP,PLTSUS,PLTSWS,PLTSPT  From SUPRLG Where PLPRID = $(problemIDNumber) ", stmtSQL)
                          @dtw_concat(stmtSQL, " UNION  Select PIPRID AS PLPRID, PISEQ AS PLSEQ, PIPRDS AS PLPRDS, PICLRL AS PLCLRL, PICLLL AS PLCLLL, PIRFSH AS PLRFSH, PIPRFS AS PLPRFS, PIIRFS AS PLIRFS, PISTAT AS PLSTAT, PITSTP AS PLTSTP, PITSUS AS PLTSUS, PITSWS AS PLTSWS, PITSPT AS PLTSWS From SUPRID_D Where PIPRID = $(problemIDNumber) and PIPRID not in (select PLPRID from SUPRLG)", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @ProblemID_Query(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Display Loop %}
                          @dtw_assign(x, "1")
                          %while(x <= quicklinkCount) {
                              @dtw_tb_getv(quicklinkSeqTable, x, "1", quicklinkRef)
                              @dtw_lowercase(quicklinkRef,quicklinkRef)
                              @dtw_tb_getv(quicklinkSeqTable, x, "2", quicklinkTitle)
                              @dtw_tb_getv(quicklinkSeqTable, x, "3", quicklinkMaxRows)
                              %if (quicklinkMaxRows == "0" || quicklinkMaxRows == "" )
                                  @dtw_assign(quicklinkMaxRows, dspMaxRowsDft)
                              %endif
                              @dtw_assign(RPT_MAX_ROWS, quicklinkMaxRows)
                              @dtw_assign(dspMaxRows, quicklinkMaxRows)
%{ Problem Content %}
                              %if (quicklinkRef == "problemcontent")
                                  %INCLUDE "QuickLinkClear.icl"

                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "       Select POSRCM, PODESC, POSRCT, POSRCF, PONEW, POOBJR,'1' as sort1 From SUPRCN   Where POPRID=$(problemIDNumber)", stmtSQL)
                                  @dtw_concat(stmtSQL, " UNION Select POSRCM, PODESC, POSRCT, POSRCF, PONEW, POOBJR,'1' as sort1 From SUPRCN_D Where POPRID=$(problemIDNumber)", stmtSQL)
                                  @dtw_concat(stmtSQL, " UNION Select P2D2WM as POSRCM, ' ' as PODESC, ' ' as POSRCT, ' ' as POSRCF, P2NEW as PONEW, ' ' as POOBJR,'2' as sort1  From SUPRCN2   Where P2PRID=$(problemIDNumber)", stmtSQL)
                                  @dtw_concat(stmtSQL, " UNION Select P2D2WM as POSRCM, ' ' as PODESC, ' ' as POSRCT, ' ' as POSRCF, P2NEW as PONEW, ' ' as POOBJR,'2' as sort1  From SUPRCN2_D Where P2PRID=$(problemIDNumber)", stmtSQL)
                                  @dtw_concat(stmtSQL, " Order By SORT1,POSRCM ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @dtw_assign(sql_Record_Count, "1")
                                  @Query_ProblemContent(profileHandle, dataBaseID, stmtSQL)
                              %endif
%{ Resolution %}
                              %if (quicklinkRef == "resolution")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "       Select * From SUPRRS   Where PRPRID=$(problemIDNumber)  ", stmtSQL)
                                  @dtw_concat(stmtSQL, " UNION Select * From SUPRCN_D Where PRPRID=$(problemIDNumber)", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Query_Resolution(profileHandle, dataBaseID, stmtSQL)
                              %endif
%{ Software Change Notice %}
                              %if (quicklinkRef == "softwarechange")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "       Select * From SUPRSC   Where PSPRID=$(problemIDNumber)  ", stmtSQL)
                                  @dtw_concat(stmtSQL, " UNION Select * From SUPRSC_D Where PSPRID=$(problemIDNumber)", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Query_SCN(profileHandle, dataBaseID, stmtSQL)
                              %endif
%{ Conversion %}
                              %if (quicklinkRef == "conversion")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "       Select PVPRID,PVCONV,PVPFNM,PVCFNM,PVOPGM,PVPFOP,PVCPGM,PVDESC,PVUIPG From SUPRCV   Where PVPRID=$(problemIDNumber) ", stmtSQL)
                                  @dtw_concat(stmtSQL, " UNION Select PVPRID,PVCONV,PVPFNM,PVCFNM,PVOPGM,PVPFOP,PVCPGM,PVDESC,PVUIPG From SUPRCV_D Where PVPRID=$(problemIDNumber)", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Query_Conversion(profileHandle, dataBaseID, stmtSQL)
                              %endif
%{ Table Updates %}
                              %if (quicklinkRef == "fileupdates")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "       Select * From SUPRFF   Where PFUPDT<>'F' ", stmtSQL)
                                  @dtw_concat(stmtSQL, " UNION Select * From SUPRFF_D Where PFUPDT<>'F' ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Query_Fileupdates(profileHandle, dataBaseID, stmtSQL)
                              %endif

%{ Pre-Requisite/Superseded %}
                              %if (quicklinkRef == "prerequisites")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "       Select PDPRSS,PLPRDS,PDDEPF From SUPRFD   Left Join SUPRLG on PDPRSS=PLPRID Where PDPRID=$(problemIDNumber)  ", stmtSQL)
                                  @dtw_concat(stmtSQL, " UNION Select PDPRSS,PLPRDS,PDDEPF From SUPRFD_D Left Join SUPRLG on PDPRSS=PLPRID Where PDPRID=$(problemIDNumber)", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Query_Prerequisites(profileHandle, dataBaseID, stmtSQL)
                              %endif

%{ Readme %}
                              %if (quicklinkRef == "readme")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * From SUREDM   Where PRPRID=$(problemIDNumber) ", stmtSQL)
                                  @dtw_concat(stmtSQL, " UNION ", stmtSQL)
                                  @dtw_concat(stmtSQL, " Select * From SUREDM_D Where PRPRID=$(problemIDNumber)", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Query_Readme(profileHandle, dataBaseID, stmtSQL)
                              %endif

                              @dtw_add(x, "1", x)
                          %}
%{ Quicklink Display Loop END %}

                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
%}

%FUNCTION(dtw_sql) ProblemID_Query (IN CHAR(64)    profileHandle,
				        CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;fromD2w=")
                  <td class="toolbar">
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      %INCLUDE "ConfMessageDisplay.icl"
      $(hrTagAttr)

      <table $(contentTable)>
          %ROW{
              <tr><td class="dsphdr">Software Update</td>
                  <td class="dspalph">$(V_PLPRID)</td>
              </tr>
              <tr><td class="dsphdr">Software Update Description </td>
                  <td class="dspalph">$(V_PlPRDS)</td>
              </tr>

              <tr><td class="dsphdr">Required Refresh Level </td>
                  <td class="dspalph">$(V_PLRFSH)</td>
              </tr>

              <tr><td class="dsphdr">Point Refresh </td>
                  <td class="dspalph">$(V_PLPRFS)</td>
              </tr>

              <tr><td class="dsphdr">Installation Sequence </td>
                  <td class="dspalph">$(V_PLSEQ)</td>
              </tr>

              <tr><td class="dsphdr">Included In Refresh Level </td>
                  <td class="dspalph">$(V_PLIRFS)</td>
              </tr>

              <tr><td class="dsphdr">Control Panel Plus Release Version </td>
                  <td class="dspalph">$(V_PLCLRL)</td>
              </tr>
              <tr><td class="dsphdr">Control Panel Plus Library Level </td>
                  <td class="dspalph">$(V_PLCLLL)</td>
              </tr>
              <tr><td class="dsphdr">Installed </td>
                  <td class="dspcode">$(V_PLTSTP)</td>
              </tr>
          </table>

          $(hrTagAttr)

          %INCLUDE "QuickLinkDisplay.icl"
      %}
  %}
%}

%FUNCTION(dtw_sql) Query_ProblemContent (IN CHAR(64)    profileHandle,
				             CHAR(2)     dataBaseID,
                                            CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="problemcontent"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(sourceURL, "$(homeURL)$(cGIPath)TemporaryFixSelection.d2w/REPORT$(d2wVarBase)")
      %INCLUDE "QuickLinkTopOfForm.icl"
      <table $(contentTable)>
      
           
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  <th class="colhdr">Object Name</th>
                  <th class="colhdr">Description</th>
                  <th class="colhdr">Type</th>
                  <th class="colhdr">Source Table</th>
                  <th class="colhdr">New</th>
                  <th class="colhdr">Change/<br>Recompiled</th>
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @RtvFldDesc("FLTYPE='PROBOBJREQ' and FLVALU='$(V_POOBJR)'", "SYFLAG", "FLDESC", F_POOBJR)
              <tr class="$(rowClass)">
                  <td class="colalph">$(V_POSRCM)</td>
                  <td class="colalph">$(V_PODESC)</td>
                  <td class="colalph">$(V_POSRCT)</td>
                  <td class="colalph">$(V_POSRCF)</td>
                  <td class="colcode">$(V_PONEW)</td>
                  <td class="colalph">$(F_POOBJR)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Query_Resolution (IN CHAR(64)    profileHandle,
				         CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="resolution"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @dtw_chartohex(V_PRRTXT, hexValue)
              @dtw_replace(hexValue, "0D25", "4C82996E", hexValue)
              @dtw_hextochar(hexValue, V_PRRTXT)
              <tr class="$(rowClass)">
                  <td class="dspalph" colspan="3">$(V_PRRTXT)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Query_SCN (IN CHAR(64)    profileHandle,
			          CHAR(2)     dataBaseID,
                                 CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="softwarechange"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @dtw_chartohex(V_PSSTXT, hexValue)
              @dtw_replace(hexValue, "0D25", "4C82996E", hexValue)
              @dtw_hextochar(hexValue, V_PSSTXT)
              <tr class="$(rowClass)">
                  <td class="dspalph" colspan="3">$(V_PSSTXT)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Query_Conversion (IN CHAR(64)    profileHandle,
				         CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="conversion"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  <th class="colhdr">Conversion Sequence</th>
                  <th class="colhdr">Production Table</th>
                  <th class="colhdr">Conversion Table</th>
                  <th class="colhdr">Production Table Operation</th>
    	           <th class="colhdr">Optional Pgm To Call</th>
                  <th class="colhdr">Conversion Program</th>
    	           <th class="colhdr">Conversion Description</th>
    	           <th class="colhdr">User Input Program</th>
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @RtvFldDesc("FLTYPE='PRODFILEOP' and FLVALU='$(V_PVPFOP)'", "SYFLAG", "FLDESC", F_PVPFOP)
              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_PVCONV)</td>
                  <td class="colalph">$(V_PVPFNM)</td>
                  <td class="colalph">$(V_PVCFNM)</td>
                  <td class="colalph">$(F_PVPFOP)</td>
                  <td class="colalph">$(V_PVOPGM)</td>
                  <td class="colalph">$(V_PVCPGM)</td>
                  <td class="colalph">$(V_PVDESC)</td>
                  <td class="colalph">$(V_PVUIPG)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Query_Fileupdates (IN CHAR(64)    profileHandle,
				          CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="fileupdates"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  <th class="colhdr">Table</th>
                  <th class="colhdr">Table Description</th>
    	           <th class="colhdr">Update Type</th>
                  <th class="colhdr">Script To Process</th>
              </tr>
          %endif

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;fileName=@dtw_rurlescseq(V_PFFILE)&amp;fileDesc=@dtw_rurlescseq(V_PFSFDS)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)$(V_PFD2W)/REPORT$(maintainVar)" title="Maintain Table Updates">$(V_PFFILE)</a></td>
                  <td class="colalph">$(V_PFSFDS)</td>
                  <td class="colcode">$(V_PFUPDT)</td>
                  <td class="colalph">$(V_PFD2W)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Query_Prerequisites (IN CHAR(64)    profileHandle,
				            CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="prerequisites"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  <th class="colhdr">Software Update</th>
                  <th class="colhdr">Software Update Description</th>
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @RtvFldDesc("PIPRID=$(V_PDPRSS)", "SUPRID", "PIPRDS", PRProbDesc)
              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_PDPRSS)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)SoftwareUpdateSelect.d2w/REPORT$(genericVarBase)&amp;problemIDNumber=@dtw_rurlescseq(V_PDPRSS)&amp;problemDescription=@dtw_rurlescseq(V_PLPRDS)" title="View Software Update">$(V_PLPRDS)</a></td>
                  %if (V_PDDEPF == "S")
                      <td class="colicon">Superseded</td>
                  %endif
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Query_Readme (IN CHAR(64)    profileHandle,
                                    CHAR(2)     dataBaseID,
                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="readme"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %endif

          %ROW{
              @RtvFldDesc("DFREDM<>' '", "SUREDF", "Coalesce(trim(DFREDM),' ')", V_DFREDM)
          
              %INCLUDE "SetRowClass.icl"
              @dtw_assign(V_PRREDM, "$(V_DFREDM) $(V_PRREDM)")
              @dtw_chartohex(V_PRREDM, hexValue)
              @dtw_replace(hexValue, "0D25", "4C82996E", hexValue)
              @dtw_hextochar(hexValue, V_PRREDM)
              <tr class="$(rowClass)">
                  <td class="dspalph" colspan="3">$(V_PRREDM)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}
