%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Mfg Order Scrap Report"
  d2wName                 = "MfgOrderScrapReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  forPlant                = ""
  sortSeqMax              = "5"
  sortPlantNumber         = "1"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {

                  if (document.Chg.fromTotalCost.value < "0" &&
                      document.Chg.fromTotalCost.value != "")
                      {alert("Negative 'from' Total Cost not allowed");
                      document.Chg.fromTotalCost.focus();
                      document.Chg.fromTotalCost();
                      return false;}
                  if (document.Chg.toTotalCost.value < "0" &&
                      document.Chg.toTotalCost.value != "")
                      {alert("Negative 'to' Total Cost not allowed");
                      document.Chg.toTotalCost.focus();
                      document.Chg.toTotalCost();
                      return false;}
                  if (editNum(document.Chg.fromPlantNumber, 3, 0) &&
                      editNum(document.Chg.toPlantNumber, 3, 0) &&
                      editNum(document.Chg.fromRoutingSequence, 3, 0) &&
                      editNum(document.Chg.toRoutingSequence, 3, 0) &&
                      editdate(document.Chg.fromTransactionDate) &&
                      editdate(document.Chg.toTransactionDate) &&
                      editNum(document.Chg.fromTotalCost, 9, 0) &&
                      editNum(document.Chg.toTotalCost, 9, 0) &&
                      editFromToAll(document.Chg.fromPlantNumber, document.Chg.toPlantNumber, document.Chg.allPlantNumber, 3) &&
                      editFromToAll(document.Chg.fromDepartment, document.Chg.toDepartment, document.Chg.allDepartment, "A") &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromOrderNumber, document.Chg.toOrderNumber, document.Chg.allOrderNumber, "A") &&
                      editFromToAll(document.Chg.fromRoutingSequence, document.Chg.toRoutingSequence, document.Chg.allRoutingSequence, 3) &&
                      editFromToAll(document.Chg.fromTransactionDate, document.Chg.toTransactionDate, document.Chg.allTransactionDate, "D") &&
                      editFromToAll(document.Chg.fromTotalCost, document.Chg.toTotalCost, document.Chg.allTotalCost, 9)
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "MFGORDERSCRAPREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromPlantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@fplt", "fromPlantNumber")        @dtw_assign(Err_N1FPLT,  fieldValue)
                                  @DecatErr_Field("@@splt", "sortPlantNumber")        @dtw_assign(Err_N1SPLT,  fieldValue)
                                  @DecatErr_Field("@@sdpt", "sortDepartment")        @dtw_assign(Err_N1SDPT,  fieldValue)
                                  @DecatErr_Field("@@sitm", "sortItemNumber")        @dtw_assign(Err_N1SITM,  fieldValue)
                                  @DecatErr_Field("@@sord", "sortOrderNumber")        @dtw_assign(Err_N1SORD,  fieldValue)
                                  @DecatErr_Field("@@srsq", "sortRoutingSequence")        @dtw_assign(Err_N1SRSQ,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}

                                  @Decat_Field("@@fplt")  @dtw_assign(V_N1FPLT,  fieldValue)
                                  @Decat_Field("@@tplt")  @dtw_assign(V_N1TPLT,  fieldValue)
                                  @Decat_Field("@@aplt")  @dtw_assign(V_N1APLT,  fieldValue)
                                  @Decat_Field("@@splt")  @dtw_assign(V_N1SPLT,  fieldValue)
                                  @Decat_Field("@@pplt")  @dtw_assign(V_N1PPLT,  fieldValue)

                                  @Decat_Field("@@fdpt")  @dtw_assign(V_N1FDPT,  fieldValue)
                                  @Decat_Field("@@tdpt")  @dtw_assign(V_N1TDPT,  fieldValue)
                                  @Decat_Field("@@adpt")  @dtw_assign(V_N1ADPT,  fieldValue)
                                  @Decat_Field("@@sdpt")  @dtw_assign(V_N1SDPT,  fieldValue)
                                  @Decat_Field("@@pdpt")  @dtw_assign(V_N1PDPT,  fieldValue)

                                  @Decat_Field("@@fitm")  @dtw_assign(V_N1FITM, fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N1TITM, fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N1AITM, fieldValue)
                                  @Decat_Field("@@sitm")  @dtw_assign(V_N1SITM, fieldValue)
                                  @Decat_Field("@@pitm")  @dtw_assign(V_N1PITM, fieldValue)

                                  @Decat_Field("@@ford")  @dtw_assign(V_N1FORD,  fieldValue)
                                  @Decat_Field("@@tord")  @dtw_assign(V_N1TORD,  fieldValue)
                                  @Decat_Field("@@aord")  @dtw_assign(V_N1AORD,  fieldValue)
                                  @Decat_Field("@@sord")  @dtw_assign(V_N1SORD,  fieldValue)
                                  @Decat_Field("@@pord")  @dtw_assign(V_N1PORD,  fieldValue)

                                  @Decat_Field("@@frsq")  @dtw_assign(V_N1FRSQ,  fieldValue)
                                  @Decat_Field("@@trsq")  @dtw_assign(V_N1TRSQ,  fieldValue)
                                  @Decat_Field("@@arsq")  @dtw_assign(V_N1ARSQ,  fieldValue)
                                  @Decat_Field("@@srsq")  @dtw_assign(V_N1SRSQ,  fieldValue)
                                  @Decat_Field("@@prsq")  @dtw_assign(V_N1PRSQ,  fieldValue)

                                  @Decat_Field("@@fdat")  @dtw_assign(V_N1FDAT, fieldValue)
                                  @Decat_Field("@@tdat")  @dtw_assign(V_N1TDAT, fieldValue)
                                  @Decat_Field("@@adat")  @dtw_assign(V_N1ADAT, fieldValue)

                                  @Decat_Field("@@fcst")  @dtw_assign(V_N1FCST, fieldValue)
                                  @Decat_Field("@@tcst")  @dtw_assign(V_N1TCST, fieldValue)
                                  @Decat_Field("@@acst")  @dtw_assign(V_N1ACST, fieldValue)


                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries
 Values %}
                                  %if (V_N1APLT == "ALL")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPlantNumber, "")
                                  %endif
                                  %if (V_N1ADPT == "ALL")
                                      @dtw_assign(checkedallDepartment, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallDepartment, "")
                                  %endif
                                  %if (V_N1AITM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_N1AORD == "ALL")
                                      @dtw_assign(checkedallOrderNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallOrderNumber, "")
                                  %endif
                                  %if (V_N1ARSQ == "ALL")
                                      @dtw_assign(checkedallRoutingSequence, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallRoutingSequence, "")
                                  %endif
                                  %if (V_N1ADAT == "ALL")
                                      @dtw_assign(checkedallTransactionDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallTransactionDate, "")
                                  %endif
                                  %if (V_N1ACST == "ALL")
                                      @dtw_assign(checkedallTotalCost, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallTotalCost, "")
                                  %endif

                                  %if (V_N1PPLT == "Y")
                                      @dtw_assign(checkedPlantNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedPlantNumberTotals, "")
                                  %endif
                                  %if (V_N1PDPT == "Y")
                                      @dtw_assign(checkedDepartmentTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedDepartmentTotals, "")
                                  %endif
                                  %if (V_N1PITM == "Y")
                                      @dtw_assign(checkedItemNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedItemNumberTotals, "")
                                  %endif
                                  %if (V_N1PORD == "Y")
                                      @dtw_assign(checkedOrderNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedOrderNumberTotals, "")
                                  %endif
                                  %if (V_N1PRSQ == "Y")
                                      @dtw_assign(checkedRoutingSequenceTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedRoutingSequenceTotals, "")
                                  %endif
                              %else
                                  @RtvDftPlant(plantNumber, plantName)
                                  %if (plantNumber == "0")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(V_N1FPLT, plantNumber)
                                      @dtw_assign(V_N1TPLT, plantNumber)
                                      @dtw_assign(checkedallPlantNumber, "")
                                      @dtw_assign(focusField, "fromDepartment")
                                  %endif
                                  @dtw_assign(checkedallDepartment, "CHECKED")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallOrderNumber, "CHECKED")
                                  @dtw_assign(checkedallRoutingSequence, "CHECKED")
                                  @dtw_assign(checkedallTransactionDate, "CHECKED")
                                  @dtw_assign(checkedallTotalCost, "CHECKED")

                                  @dtw_assign(checkedPlantNumberTotals, "CHECKED")
                                  @dtw_assign(checkedDepartmentTotals, "")
                                  @dtw_assign(checkedItemNumberTotals, "")
                                  @dtw_assign(checkedOrderNumberTotals, "")
                                  @dtw_assign(checkedRoutingSequenceTotals, "")
                              %endif

                          </table>

                          <table $(contentTable)>

                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                                  <td class="colhdr">Print<br>Totals</td>
                              </tr>

                              @SetTextOvr(Err_N1FPLT)
                              %if (textOvr == "") @SetTextOvr(Err_N1SPLT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                  <td class="inputnmbr"><input name="fromPlantNumber" value="$(V_N1FPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromPlantNumber&amp;fldDesc=fplantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fplantName"  type="hidden"></td>
                                  <td class="inputnmbr"><input name="toPlantNumber" value="$(V_N1TPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toPlantNumber&amp;fldDesc=tplantName" onclick="$(searchWinVar)">  $(searchImage) </a><input name="tplantName"  type="hidden"></td>
                                  <td class="inputalph"><input name="allPlantNumber" value='ALL' $(checkedallPlantNumber) type="checkbox" onClick="if (this.checked) this.form.fromPlantNumber.value='', this.form.toPlantNumber.value='';"></td>
                                  <td class="colcode"><input name="sortPlantNumber" type="hidden"  Value="$(sortPlantNumber)" size="1" maxlength="1">$(sortPlantNumber)</td>
                                  <td align=center ><input name="totalPlantNumber" type="checkbox" $(checkedPlantNumberTotals) disabled VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1FPLT)
                              @DspErrMsg(Err_N1SPLT)

                              @SetTextOvr(Err_N1SDPT)
                              <tr><td class="dsphdr"><span $(textOvr)>Department </span></td>
                                  <td class="inputalph"><input name="fromDepartment" value="$(V_N1FDPT)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=fromDepartment&amp;fldWC=fromWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="fromWorkCenter" type="hidden"><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="toDepartment" value="$(V_N1TDPT)" type="text" size="5" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=toDepartment&amp;fldWC=toWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="toWorkCenter" type="hidden"><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="allDepartment" value='ALL' $(checkedallDepartment) type="checkbox" onClick="if (this.checked) this.form.fromDepartment.value='', this.form.toDepartment.value='';"></td>
                                  @Build_Sort_Select("sortDepartment", "$(V_N1SDPT)")
                                  <td align=center ><input name="totalDepartment" type="checkbox" $(checkedDepartmentTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1SDPT)

                              @SetTextOvr(Err_N1SITM)
                              <tr><td class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N1FITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N1TITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                                  @Build_Sort_Select("sortItemNumber", "$(V_N1SITM)")
                                  <td align=center ><input name="totalItemNumber" type="checkbox" $(checkedItemNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1SITM)

                              @SetTextOvr(Err_N1SORD)
                              <tr><td class="dsphdr"><span $(textOvr)>Order Number</span></td>
                                  <td class="inputalph"><input name="fromOrderNumber" value="$(V_N1FORD)" type="text" size="15" maxlength="9"><a href="$(homeURL)$(phpPath)MfgOrderSearch.php$(altVarBase)&amp;docName=Chg&amp;forPlant=$(forPlant)&amp;fldorder=fromOrderNumber" onclick="$(searchWinVar)">  $(searchImage) </a></td>
                                  <td class="inputalph"><input name="toOrderNumber" value="$(V_N1TORD)" type="text" size="15" maxlength="9"><a href="$(homeURL)$(phpPath)MfgOrderSearch.php$(altVarBase)&amp;docName=Chg&amp;forPlant=$(forPlant)&amp;fldorder=toOrderNumber" onclick="$(searchWinVar)">  $(searchImage) </a></td>
                                  <td class="inputalph"><input name="allOrderNumber" value='ALL' $(checkedallOrderNumber) type="checkbox" onClick="if (this.checked) this.form.fromOrderNumber.value='', this.form.toOrderNumber.value='';"></td>
                                  @Build_Sort_Select("sortOrderNumber", "$(V_N1SORD)")
                                  <td align=center ><input name="totalOrderNumber" type="checkbox" $(checkedOrderNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1SORD)

                              @SetTextOvr(Err_N1SRSQ)
                              <tr><td class="dsphdr"><span $(textOvr)>Routing Sequence</span></td>
                                  <td class="inputnmbr"><input name="fromRoutingSequence" value="$(V_N1FRSQ)" type="text" size="3" maxlength="3"></td>
                                  <td class="inputnmbr"><input name="toRoutingSequence" value="$(V_N1TRSQ)" type="text" size="3" maxlength="3"></td>
                                  <td class="inputalph"><input name="allRoutingSequence" value='ALL' $(checkedallRoutingSequence) type="checkbox" onClick="if (this.checked) this.form.fromRoutingSequence.value='', this.form.toRoutingSequence.value='';"></td>
                                  @Build_Sort_Select("sortRoutingSequence", "$(V_N1SRSQ)")
                                  <td align=center ><input name="totalRoutingSequence" type="checkbox" $(checkedRoutingSequenceTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1SRSQ)

                              <tr><td class="dsphdr">Transaction Date</td>
                                  <td class="inputnmbr"><input name="fromTransactionDate" value="$(V_N1FDAT)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromTransactionDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toTransactionDate" value="$(V_N1TDAT)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toTransactionDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allTransactionDate" value='ALL' $(checkedallTransactionDate) type="checkbox" onClick="if (this.checked) this.form.fromTransactionDate.value='', this.form.toTransactionDate.value='';"></td>
                              </tr>

                              <tr><td class="dsphdr">Total Cost</td>
                                  <td class="inputnmbr"><input name="fromTotalCost" value="$(V_N1FCST)" type="text" size="9" maxlength="9"></td>
                                  <td class="inputnmbr"><input name="toTotalCost" value="$(V_N1TCST)" type="text" size="9" maxlength="9"></td>
                                  <td class="inputalph"><input name="allTotalCost" value='ALL' $(checkedallTotalCost) type="checkbox" onClick="if (this.checked) this.form.fromTotalCost.value='', this.form.toTotalCost.value='';"></td>
                              </tr>

                          </table>

                          @dtw_assign(envProgram, "HSIOSR")
                          @dtw_assign(envPrinter, "HSIOSRPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSIOSS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allPlantNumber)
  @dtw_mUPPERCASE(fromDepartment)
  @dtw_mUPPERCASE(toDepartment)
  @dtw_mUPPERCASE(allDepartment)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(fromOrderNumber)
  @dtw_mUPPERCASE(toOrderNumber)
  @dtw_mUPPERCASE(allOrderNumber)
  @dtw_mUPPERCASE(allRoutingSequence)
  @dtw_mUPPERCASE(allTransactionDate)
  @dtw_mUPPERCASE(allTotalCost)

  @dtw_assign(fromPlantNumber,@dtw_rstrip(fromPlantNumber))
  @dtw_assign(toPlantNumber,@dtw_rstrip(toPlantNumber))
  @dtw_assign(sortPlantNumber,@dtw_rstrip(sortPlantNumber))
  @dtw_assign(sortDepartment,@dtw_rstrip(sortDepartment))
  @dtw_assign(sortItemNumber,@dtw_rstrip(sortItemNumber))
  @dtw_assign(sortOrderNumber,@dtw_rstrip(sortOrderNumber))
  @dtw_assign(fromRoutingSequence,@dtw_rstrip(fromRoutingSequence))
  @dtw_assign(toRoutingSequence,@dtw_rstrip(toRoutingSequence))
  @dtw_assign(sortRoutingSequence,@dtw_rstrip(sortRoutingSequence))
  @dtw_assign(fromTransactionDate,@dtw_rstrip(fromTransactionDate))
  @dtw_assign(toTransactionDate,@dtw_rstrip(toTransactionDate))
  @dtw_assign(fromTotalCost,@dtw_rstrip(fromTotalCost))
  @dtw_assign(toTotalCost,@dtw_rstrip(toTotalCost))

  %if (allPlantNumber != "ALL")
      @dtw_assign(allPlantNumber, "")
  %endif
  %if (allDepartment != "ALL")
      @dtw_assign(allDepartment, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allOrderNumber != "ALL")
      @dtw_assign(allOrderNumber, "")
  %endif
  %if (allRoutingSequence != "ALL")
      @dtw_assign(allRoutingSequence, "")
  %endif
  %if (allTransactionDate != "ALL")
      @dtw_assign(allTransactionDate, "")
  %endif
  %if (allTotalCost != "ALL")
      @dtw_assign(allTotalCost, "")
  %endif

  @dtw_assign(totalPlantNumber, "Y")

  %if (totalDepartment != "Y")
      @dtw_assign(totalDepartment, "N")
  %endif
  %if (totalItemNumber != "Y")
      @dtw_assign(totalItemNumber, "N")
  %endif
  %if (totalOrderNumber != "Y")
      @dtw_assign(totalOrderNumber, "N")
  %endif
  %if (totalRoutingSequence != "Y")
      @dtw_assign(totalRoutingSequence, "N")
  %endif

  @dtw_assign(edtVar, "")

  @Concat_Field("@@fplt", fromPlantNumber)
  @Concat_Field("@@tplt", toPlantNumber)
  @Concat_Field("@@aplt", allPlantNumber)
  @Concat_Field("@@splt", sortPlantNumber)
  @Concat_Field("@@pplt", totalPlantNumber)

  @Concat_Field("@@fdpt", fromDepartment)
  @Concat_Field("@@tdpt", toDepartment)
  @Concat_Field("@@adpt", allDepartment)
  @Concat_Field("@@sdpt", sortDepartment)
  @Concat_Field("@@pdpt", totalDepartment)

  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@sitm", sortItemNumber)
  @Concat_Field("@@pitm", totalItemNumber)

  @Concat_Field("@@ford", fromOrderNumber)
  @Concat_Field("@@tord", toOrderNumber)
  @Concat_Field("@@aord", allOrderNumber)
  @Concat_Field("@@sord", sortOrderNumber)
  @Concat_Field("@@pord", totalOrderNumber)

  @Concat_Field("@@frsq", fromRoutingSequence)
  @Concat_Field("@@trsq", toRoutingSequence)
  @Concat_Field("@@arsq", allRoutingSequence)
  @Concat_Field("@@srsq", sortRoutingSequence)
  @Concat_Field("@@prsq", totalRoutingSequence)

  @Concat_Field("@@fdat", fromTransactionDate)
  @Concat_Field("@@tdat", toTransactionDate)
  @Concat_Field("@@adat", allTransactionDate)

  @Concat_Field("@@fcst", fromTotalCost)
  @Concat_Field("@@tcst", toTotalCost)
  @Concat_Field("@@acst", allTotalCost)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}