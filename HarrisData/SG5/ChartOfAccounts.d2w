%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Chart Of Accounts"
  d2wName                 = "ChartOfAccounts.d2w"
  programName             = "HHDCHU"
  d2wVarBase              = "$(genericVarBase)&amp;inclDebits=@dtw_rurlescseq(inclDebits)&amp;inclCredits=@dtw_rurlescseq(inclCredits)&amp;inclCurrency=@dtw_rurlescseq(inclCurrency)&amp;inclUnits=@dtw_rurlescseq(inclUnits)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchAcct, 4, 0) &&
                      editNum(document.Search.srchSub, 4, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "CHARTOFACCOUNTS")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      @dtw_assign(uv_AccountName, "CHACCT")
                      @dtw_assign(uv_SubaccountName, "CHSUB")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " HDCHRT ", fileSQL)
                      @dtw_concat(selectSQL, "CHACCT>0 ", selectSQL)
                      %if ((inclDebits == "Y") && (inclCredits != "Y"))
                          @dtw_concat(selectSQL, "  and CHNAB='D'", selectSQL)
                      %elseif ((inclDebits != "Y") && (inclCredits == "Y"))
                          @dtw_concat(selectSQL, "  and CHNAB='C'", selectSQL)
                      %elseif ((inclDebits != "Y") && (inclCredits != "Y"))
                          @dtw_concat(selectSQL, "  and CHNAB=' '", selectSQL)
                      %endif
                      %if ((inclCurrency == "Y") && (inclUnits != "Y"))
                          @dtw_concat(selectSQL, "  and CHACSG='D'", selectSQL)
                      %elseif ((inclCurrency != "Y") && (inclUnits == "Y"))
                          @dtw_concat(selectSQL, "  and CHACSG='U'", selectSQL)
                      %elseif ((inclCurrency != "Y") && (inclUnits != "Y"))
                          @dtw_concat(selectSQL, "  and CHACSG=' '", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Chart_OfAccts_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Chart_OfAccts_Query (IN CHAR(64)    profileHandle,
                                           CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                      <td class="toolbar">
                          %if (backHome != "$(d2wName)/report" && backHome != "")
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)&amp;backHome=@dtw_rurlescseq(backHome)" title="Back Home">$(portalHome)</a>
                          %endif
                          %if (sec_01 == "Y")
                              <a href="$(homeURL)$(cGIPath)ChartOfAccountsMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"
	
          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Description</th>
                          <th class="colhdr">Account</th>
                      </tr>
                      <tr><td class="inputalph"><input type="text" name="srchDesc" size="20" maxlength="30">
                              <input type="hidden" name="operDesc" value="LIKE">
                          </td>
                          <td class="inputnmbr"><input name="srchAcct" type="text" size="4" maxlength="4"><input name="srchSub" type="text" size="4" maxlength="4">
                              <input type="hidden" name="operAcct" value="=">
                              <input type="hidden" name="operSub" value="=">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchDesc.focus();
                  </script>
              </form>

              %if (inclDebits == "Y")
                  @dtw_assign(debitsChecked, "CHECKED")
              %else
                  @dtw_assign(debitsChecked, "")
              %endif

              %if (inclCredits == "Y")
                  @dtw_assign(creditsChecked, "CHECKED")
              %else
                  @dtw_assign(creditsChecked, "")
              %endif

              %if (inclCurrency == "Y")
                  @dtw_assign(currencyChecked, "CHECKED")
              %else
                  @dtw_assign(currencyChecked, "")
              %endif

              %if (inclUnits == "Y")
                  @dtw_assign(unitsChecked, "CHECKED")
              %else
                  @dtw_assign(unitsChecked, "")
              %endif

              @dtw_assign(viewCheckBox, "Usage")
              %INCLUDE "WildCardPage.icl"
          %endif
	   		
          <table $(contentTable)>
              <tr>
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("CHACCT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Account" title="Sequence By Account">Account</a></th>
                  @OrderBy_Sort("CHCHDSU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description, Account">Description</a></th>
                  @OrderBy_Sort("CHNAB", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Balance" title="Sequence By Normal Account Balance, Account">Normal<br>Balance</a></th>
                  @OrderBy_Sort("CHACSG", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Usage" title="Sequence By Usage, Account">Usage</a></th>
                  @OrderBy_Sort("CHDTES", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Established" title="Sequence By Date Established, Account">Date<br>Established</a></th>
                  @OrderBy_Sort("CHDTDE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Deactivated" title="Sequence By Date Deactivated, Account">Date<br>Deactivated</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"

              %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;accountNumber=@dtw_rurlescseq(V_CHACCT)&amp;subAccountNumber=@dtw_rurlescseq(V_CHSUB)&amp;accountDesc=@dtw_rurlescseq(V_CHCHDS)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
                  %INCLUDE "SetRowClass.icl"

                  @Format_Acct(V_CHACCT, V_CHSUB, "", F_AcctSub)
                  @Format_Date(V_CHDTES, "D", F_CHDTES)
                  @Format_Date(V_CHDTDE, "D", F_CHDTDE)
                  @RtvFldDesc("FLTYPE='USAGE' and FLVALU='$(V_CHACSG)'", "SYFLAG", "FLDESC", usageDesc)
                  @RtvFldDesc("FLTYPE='ACCTBAL' and FLVALU='$(V_CHNAB)'", "SYFLAG", "FLDESC", normalBalDesc)
                  @RtvFldDesc("CUACC=$(V_CHACCT) and CUSUB=$(V_CHSUB)", "HDCUSE", "char(count(*))", usageCnt)
                  @Format_Confirm_Desc($(V_CHCHDS), $(F_AcctSub), "", "", "", "", confirmDesc)

                  <tr class="$(rowClass)">
                      %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                          <td class="opticon">
                              %if (sec_02 == "Y" || sec_03 == "Y")
                                  <a href="$(homeURL)$(cGIPath)ChartOfAccountsMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                              %endif
                              %if (sec_04 == "Y")
                                  <a href="$(homeURL)$(cGIPath)ChartOfAccountsMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                              %endif
                              %if (sec_03 == "Y")
                                  <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)ChartOfAccountsMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                              %endif
                              %if (usageCnt>"0")
                                  <a href="$(homeURL)$(cGIPath)ChartUsage.d2w/WILDCARD$(genericVarBase)&amp;wildCardSearch=&amp;srchAcct=@dtw_rurlescseq(V_CHACCT)&amp;operAcct==&amp;srchSub=@dtw_rurlescseq(V_CHSUB)&amp;operSub==&amp;orderBy=CUACC,CUSUB&amp;orderByDisplay=Account">$(usageExistsSml)</a>
                              %else
                                  <a href="$(homeURL)$(cGIPath)ChartUsageMaintain.d2w/MAINTAIN$(genericVarBase)&amp;accountNumber=@dtw_rurlescseq(V_CHACCT)&amp;subAccountNumber=@dtw_rurlescseq(V_CHSUB)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(usageSml)</a>
                              %endif
                          </td>
                      %endif
                      <td class="colnmbr">$(F_AcctSub)</td>
                      <td class="colalph">$(V_CHCHDS)</td>
                      <td class="colalph">$(normalBalDesc)</td>
                      <td class="colalph">$(usageDesc)</td>
                      <td class="coldate">$(F_CHDTES)</td>
                      <td class="coldate">$(F_CHDTDE)</td>
                  </tr>
              %}
          </table>
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
          $(hrTagAttr)
          %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  @dtw_assign(uv_AccountName, "CHACCT")
  @dtw_assign(uv_SubaccountName, "CHSUB")
  %INCLUDE "userview.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
  @dtw_concat(fileSQL, " HDCHRT ", fileSQL)
  @dtw_concat(selectSQL, "CHACCT>0 ", selectSQL)
  %if ((inclDebits == "Y") && (inclCredits != "Y"))
      @dtw_concat(selectSQL, "  and CHNAB='D'", selectSQL)
  %elseif ((inclDebits != "Y") && (inclCredits == "Y"))
      @dtw_concat(selectSQL, "  and CHNAB='C'", selectSQL)
  %elseif ((inclDebits != "Y") && (inclCredits != "Y"))
      @dtw_concat(selectSQL, "  and CHNAB=' '", selectSQL)
  %endif
  %if ((inclCurrency == "Y") && (inclUnits != "Y"))
      @dtw_concat(selectSQL, "  and CHACSG='D'", selectSQL)
  %elseif ((inclCurrency != "Y") && (inclUnits == "Y"))
      @dtw_concat(selectSQL, "  and CHACSG='U'", selectSQL)
  %elseif ((inclCurrency != "Y") && (inclUnits != "Y"))
      @dtw_concat(selectSQL, "  and CHACSG=' '", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @Chart_OfAccts_Export_Query(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) Chart_OfAccts_Export_Query (IN CHAR(64)    profileHandle,
                                                  CHAR(2)     dataBaseID,
                                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("ChartOfAccountsList")
          %ROW{
              @RtvFldDesc("FLTYPE='USAGE' and FLVALU='$(V_CHACSG)'", "SYFLAG", "FLDESC", usageDesc)
              @RtvFldDesc("FLTYPE='ACCTBAL' and FLVALU='$(V_CHNAB)'", "SYFLAG", "FLDESC", normalBalDesc)
              %if (V_CHDTES>"0")
                  @Date_CYMD_ISO(V_CHDTES, F_CHDTES)
              %else
                  @dtw_assign(F_CHDTES, "0")
              %endif
              %if (V_CHDTES>"0")
                  @Date_CYMD_ISO(V_CHDTDE, F_CHDTDE)
              %else
                  @dtw_assign(F_CHDTDE, "0")
              %endif
              %if (V_CHUPDT>"0")
                  @Format_Date(V_CHUPDT, "D", F_CHUPDT)
              %else
                  @dtw_assign(F_CHUPDT, "0")
              %endif

	       @XMLIDTag("$(V_CHACCT)-$(V_CHSUB)", "Account ID")
                  @XMLTag(V_CHACCT, "Account")
                  @XMLTag(V_CHSUB, "SubAccount")
                  @XMLTag(V_CHCHDS, "AccountDescription")
                  @XMLTag(normalBalDesc, "NormalBalance")
                  @XMLTag(usageDesc, "AccountUsage")
                  @XMLTag(F_CHDTES, "DateEstablished")
                  @XMLTag(F_CHDTDE, "DateDeactivated")
                  %if (V_HDMCRL > "0")
                      @XMLTag(V_CHRTYP, "CurrencyRateType")
                  %endif
                  @XMLTag(F_CHUPDT, "DateLastMaintained")
              @XMLEndTag("Account")
          %}
      @XMLEndTag("ChartOfAccountsList")
  %}
%}

%HTML(REPORT)
{
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "CHCHDSU,CHACCT,CHSUB")
          @DTW_ASSIGN(orderByDisplay, "Name, Co/Fac")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %elseif (chgDebits == "Y" && inclDebits == "Y")
          @dtw_assign(inclDebits, "")
      %elseif (chgDebits == "Y")
          @dtw_assign(inclDebits, "Y")
      %elseif (chgCredits == "Y" && inclCredits == "Y")
          @dtw_assign(inclCredits, "")
      %elseif (chgCredits == "Y")
          @dtw_assign(inclCredits, "Y")
      %elseif (chgCurrency == "Y" && inclCurrency == "Y")
          @dtw_assign(inclCurrency, "")
      %elseif (chgCurrency == "Y")
          @dtw_assign(inclCurrency, "Y")
      %elseif (chgUnits == "Y" && inclUnits == "Y")
          @dtw_assign(inclUnits, "")
      %elseif (chgUnits == "Y")
          @dtw_assign(inclUnits, "Y")
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %if (inclDebits == "" && inclCredits == "" && chgDebits != "Y" && chgCredits != "Y")
      @dtw_assign(inclDebits, "Y")
      @dtw_assign(inclCredits, "Y")
  %endif
  %if (inclCurrency == "" && inclUnits == "" && chgCurrency != "Y" && chgUnits != "Y")
      @dtw_assign(inclCurrency, "Y")
      @dtw_assign(inclUnits, "Y")
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT)
{
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(EXPORT)
{
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit ()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(ORDERBY)
{
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Account")
      %if (orderBy == "CHACCT,CHSUB")
          @DTW_ASSIGN(orderBy, "CHACCT DESC,CHSUB")
          @DTW_ASSIGN(orderByDisplay, "Account (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CHACCT,CHSUB")
          @DTW_ASSIGN(orderByDisplay, "Account")
      %endif
  %elseif (sequence == "Desc")
      %if (orderBy == "CHCHDSU,CHACCT,CHSUB")
          @DTW_ASSIGN(orderBy, "CHCHDSU DESC,CHACCT,CHSUB")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Account")
      %else
          @DTW_ASSIGN(orderBy, "CHCHDSU,CHACCT,CHSUB")
          @DTW_ASSIGN(orderByDisplay, "Description, Account")
      %endif
  %elseif (sequence == "Balance")
      %if (orderBy == "CHNAB,CHACCT,CHSUB")
          @DTW_ASSIGN(orderBy, "CHNAB DESC,CHACCT,CHSUB")
          @DTW_ASSIGN(orderByDisplay, "Normal Account Balance (descending), Account")
      %else
          @DTW_ASSIGN(orderBy, "CHNAB,CHACCT,CHSUB")
          @DTW_ASSIGN(orderByDisplay, "Normal Account Balance, Account")
      %endif
  %elseif (sequence == "Usage")
      %if (orderBy == "CHACSG,CHACCT,CHSUB")
          @DTW_ASSIGN(orderBy, "CHACSG DESC,CHACCT,CHSUB")
          @DTW_ASSIGN(orderByDisplay, "Usage (descending), Account")
      %else
          @DTW_ASSIGN(orderBy, "CHACSG,CHACCT,CHSUB")
          @DTW_ASSIGN(orderByDisplay, "Usage, Account")
      %endif
  %elseif (sequence == "Established")
      %if (orderBy == "CHDTES,CHACCT,CHSUB")
          @DTW_ASSIGN(orderBy, "CHDTES DESC,CHACCT,CHSUB")
          @DTW_ASSIGN(orderByDisplay, "Date Established (descending), Account")
      %else
          @DTW_ASSIGN(orderBy, "CHDTES,CHACCT,CHSUB")
          @DTW_ASSIGN(orderByDisplay, "Date Established, Account")
      %endif
  %elseif (sequence == "Deactivated")
      %if (orderBy == "CHDTDE,CHACCT,CHSUB")
          @DTW_ASSIGN(orderBy, "CHDTDE DESC,CHACCT,CHSUB")
          @DTW_ASSIGN(orderByDisplay, "Date Deactivated (descending), Account")
      %else
          @DTW_ASSIGN(orderBy, "CHDTDE,CHACCT,CHSUB")
          @DTW_ASSIGN(orderByDisplay, "Date Deactivated, Account")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH)
{
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "dateedit.icl"
	       %INCLUDE "numedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchAcct, 4, 0) &&
                      editNum(document.Search.srchSub, 4, 0) &&
                      editdate(document.Search.srchEstabDate) &&
                      editdate(document.Search.srchDeactDate))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CHARTOFACCOUNTSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Account</td>
                              @dtw_assign(operNbr, "operAcct")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchAcct" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Subaccount</td>
                              @dtw_assign(operNbr, "operSub")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchSub" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Account (alpha)</td>
                              @dtw_assign(operNbr, "operAcctAlpha")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchAcctAlpha" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Subaccount (alpha)</td>
                              @dtw_assign(operNbr, "operSubAlpha")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchSubAlpha" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchDesc" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Date Established</td>
                              @dtw_assign(operNbr, "operEstabDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchEstabDate" size="6" maxlength="6"><a href="javascript:calWindow('srchBeginDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Date Deactivated</td>
                              @dtw_assign(operNbr, "operDeactDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchDeactDate" size="6" maxlength="6"><a href="javascript:calWindow('srchEndDate');">$(calendarImage)</a></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchAcct.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD)
{
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("CHACCT", "Account", $(srchAcct), "", operAcct, "N")
  @Build_WildCard ("CHSUB", "Subaccount", $(srchSub), "", operSub, "N")
  @Build_WildCard ("CHACCT", "Account (Alpha)", $(srchAcctAlpha), "", operAcctAlpha, "DG")
  @Build_WildCard ("CHSUB", "Subaccount (Alpha)", $(srchSubAlpha), "", operSubAlpha, "DG")
  @Build_WildCard ("CHCHDSU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("CHDTES", "Date Established", $(srchEstabDate), "", operEstabDate, "D")
  @Build_WildCard ("CHDTDE", "Date Deactivated", $(srchDeactDate), "", operDeactDate, "D")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
