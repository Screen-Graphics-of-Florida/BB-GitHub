%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Column Relation Maintenance"
  d2wName                 = "ColumnRelationMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;tblID=@dtw_rurlescseq(tblID)&amp;linkID=@dtw_rurlescseq(linkID)&amp;tableName=@dtw_rurlescseq(tableName)&amp;tableDesc=@dtw_rurlescseq(tableDesc)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;relID=@dtw_rurlescseq(relID)&amp;relDesc=@dtw_rurlescseq(relDesc)&amp;maintenanceCode=D"
  programName             = "HSYTCR_E"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.relDesc.value =="" ||
                      document.Chg.column.value =="" ||
                      document.Chg.relCol1.value =="")
                     {alert("$(reqFieldError)"); return false;}
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "COLUMNRELATIONMAINT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, " Select * From SYTBCR Where CRTBID=$(tblID) and CRRLID=$(relID)", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "relDesc")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@desc", "relDesc")    @dtw_assign(Err_CRDESC,  fieldValue)
                          @DecatErr_Field("@@coln", "column")     @dtw_assign(Err_CRCOLN,  fieldValue)
                          @DecatErr_Field("@@rlc1", "relCol1")    @dtw_assign(Err_CRRLC1,  fieldValue)
                          @DecatErr_Field("@@rlc2", "relCol2")    @dtw_assign(Err_CRRLC2,  fieldValue)
                          @DecatErr_Field("@@rlc3", "relCol3")    @dtw_assign(Err_CRRLC3,  fieldValue)
                          @DecatErr_Field("@@rlc4", "relCol4")    @dtw_assign(Err_CRRLC4,  fieldValue)
                          @DecatErr_Field("@@rlc5", "relCol5")    @dtw_assign(Err_CRRLC5,  fieldValue)
                          @DecatErr_Field("@@ftyp", "formatType") @dtw_assign(Err_CRFTYP,  fieldValue)
                      %endif

                      @Decat_Field("@@desc")  @dtw_assign(V_CRDESC,  fieldValue)
                      @Decat_Field("@@coln")  @dtw_assign(V_CRCOLN,  fieldValue)
                      @Decat_Field("@@rlc1")  @dtw_assign(V_CRRLC1,  fieldValue)
                      @Decat_Field("@@rlc2")  @dtw_assign(V_CRRLC2,  fieldValue)
                      @Decat_Field("@@rlc3")  @dtw_assign(V_CRRLC3,  fieldValue)
                      @Decat_Field("@@rlc4")  @dtw_assign(V_CRRLC4,  fieldValue)
                      @Decat_Field("@@rlc5")  @dtw_assign(V_CRRLC5,  fieldValue)
                      @Decat_Field("@@ftyp")  @dtw_assign(V_CRFTYP,  fieldValue)

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "relDesc")
                  %else
                      @dtw_assign(focusField, "relDesc")
                  %endif

                  <tr><td><input name="relID" type="hidden" value="$(relID)"></td></tr>

                  @SetTextOvr(Err_CRDESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="relDesc" type="text" value="$(V_CRDESC)" size="50" maxlength="50"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_CRDESC)

                  @RtvFldDesc("TCTBLN='$(tableName)' and TCCOLN='$(V_CRCOLN)'", "SYTBLC", "TCCTXT", fieldDesc)
                  @SetTextOvr(Err_CRCOLN)
                  <tr><td class="dsphdr"><span $(textOvr)>Column Name</span></td>
                      <td class="inputalph"><input type="text" name="column" value="$(V_CRCOLN)" size="10" maxlength="130"><a href="$(homeURL)$(cGIPath)TableColumnSearch.d2w/REPORT$(d2wVarBase)&amp;docName=Chg&amp;fldName=column&amp;fldDesc=columnDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input name="columnDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_CRCOLN)

                  @RtvFldDesc("TCTBLN='$(tableName)' and TCCOLN='$(V_CRRLC1)'", "SYTBLC", "TCCTXT", fieldDesc)
                  @SetTextOvr(Err_CRRLC1)
                  <tr><td class="dsphdr"><span $(textOvr)>Related Column 1</span></td>
                      <td class="inputalph"><input type="text" name="relCol1" value="$(V_CRRLC1)" size="10" maxlength="130"><a href="$(homeURL)$(cGIPath)TableColumnSearch.d2w/REPORT$(d2wVarBase)&amp;docName=Chg&amp;fldName=relCol1&amp;fldDesc=relCol1Desc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input name="relCol1Desc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_CRRLC1)

                  @RtvFldDesc("TCTBLN='$(tableName)' and TCCOLN='$(V_CRRLC2)'", "SYTBLC", "TCCTXT", fieldDesc)
                  @SetTextOvr(Err_CRRLC2)
                  <tr><td class="dsphdr"><span $(textOvr)>Related Column 2</span></td>
                      <td class="inputalph"><input type="text" name="relCol2" value="$(V_CRRLC2)" size="10" maxlength="130"><a href="$(homeURL)$(cGIPath)TableColumnSearch.d2w/REPORT$(d2wVarBase)&amp;docName=Chg&amp;fldName=relCol2&amp;fldDesc=relCol2Desc" onclick="$(searchWinVar)"> &nbsp; $(searchImage) </a> <input name="relCol2Desc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_CRRLC2)

                  @RtvFldDesc("TCTBLN='$(tableName)' and TCCOLN='$(V_CRRLC3)'", "SYTBLC", "TCCTXT", fieldDesc)
                  @SetTextOvr(Err_CRRLC3)
                  <tr><td class="dsphdr"><span $(textOvr)>Related Column 3</span></td>
                      <td class="inputalph"><input type="text" name="relCol3" value="$(V_CRRLC3)" size="10" maxlength="130"><a href="$(homeURL)$(cGIPath)TableColumnSearch.d2w/REPORT$(d2wVarBase)&amp;docName=Chg&amp;fldName=relCol3&amp;fldDesc=relCol3Desc" onclick="$(searchWinVar)"> &nbsp; $(searchImage) </a> <input name="relCol3Desc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_CRRLC3)

                  @RtvFldDesc("TCTBLN='$(tableName)' and TCCOLN='$(V_CRRLC4)'", "SYTBLC", "TCCTXT", fieldDesc)
                  @SetTextOvr(Err_CRRLC4)
                  <tr><td class="dsphdr"><span $(textOvr)>Related Column 4</span></td>
                      <td class="inputalph"><input type="text" name="relCol4" value="$(V_CRRLC4)" size="10" maxlength="130"><a href="$(homeURL)$(cGIPath)TableColumnSearch.d2w/REPORT$(d2wVarBase)&amp;docName=Chg&amp;fldName=relCol4&amp;fldDesc=relCol4Desc" onclick="$(searchWinVar)"> &nbsp; $(searchImage) </a> <input name="relCol4Desc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_CRRLC4)

                  @RtvFldDesc("TCTBLN='$(tableName)' and TCCOLN='$(V_CRRLC5)'", "SYTBLC", "TCCTXT", fieldDesc)
                  @SetTextOvr(Err_CRRLC5)
                  <tr><td class="dsphdr"><span $(textOvr)>Related Column 5</span></td>
                      <td class="inputalph"><input type="text" name="relCol5" value="$(V_CRRLC5)" size="10" maxlength="130"><a href="$(homeURL)$(cGIPath)TableColumnSearch.d2w/REPORT$(d2wVarBase)&amp;docName=Chg&amp;fldName=relCol5&amp;fldDesc=relCol5Desc" onclick="$(searchWinVar)"> &nbsp; $(searchImage) </a> <input name="relCol5Desc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_CRRLC5)

                  @RtvFldDesc("FLTYPE='FORMATTYPE' and FLVALU='$(V_CRFTYP)'", "SYFLAG", "FLDESC", formatTypeDesc)
                  @SetTextOvr(Err_CRFTYP)
                  <tr><td class="dsphdr"><span $(textOvr)>Type</span></td>
                      <td class="inputalph"><input name="formatType" type="text" value="$(V_CRFTYP)" size="10" maxlength="10"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=FORMATTYPE&amp;flagSrchHdr=@dtw_rurlescseq("Format Type")&amp;docName=Chg&amp;fldName=formatType&amp;fldDesc=formatTypeDesc" onclick="$(searchWinVar)"> &nbsp; $(searchImage) </a><input name="formatTypeDesc" value="$(formatTypeDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_CRFTYP)

              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)	
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                              CHAR(2)     dataBaseID,
                                              CHAR(1)     maintenanceCode,
                                              CHAR(1)     errFound,
                                              CHAR(32000) edtVar,                             	
                                              CHAR(32000) errVar)
{%EXEC {HSYTCR_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(column)
  @dtw_mUPPERCASE(relCol1)
  @dtw_mUPPERCASE(relCol2)
  @dtw_mUPPERCASE(relCol3)
  @dtw_mUPPERCASE(relCol4)
  @dtw_mUPPERCASE(relCol5)
  @dtw_mUPPERCASE(formatType)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif
  %if (maintenanceCode == "A")
      @dtw_assign(relID, "0")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@tbid", tblID)
  @Concat_Field("@@tbln", tableName)
  @Concat_Field("@@rlid", relID)
  @Concat_Field("@@desc", relDesc)
  @Concat_Field("@@coln", column)
  @Concat_Field("@@rlc1", relCol1)
  @Concat_Field("@@rlc2", relCol2)
  @Concat_Field("@@rlc3", relCol3)
  @Concat_Field("@@rlc4", relCol4)
  @Concat_Field("@@rlc5", relCol5)
  @Concat_Field("@@ftyp", formatType)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(relDesc), "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ColumnRelation.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@desc", "relDesc")
      @Format_ConfMsg_Desc("", "$(fieldValue)", "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ColumnRelation.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;relID=@dtw_rurlescseq(relID)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}