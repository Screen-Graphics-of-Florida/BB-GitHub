%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Labor In Process"
  d2wName                 = "LaborInProcess.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;mfgOrder=@dtw_rurlescseq(mfgOrder)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HSI204"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
                  %INCLUDE "Menu.js"
                  %INCLUDE "NumEdit.icl"
                  %INCLUDE "CheckEnterSearch.icl"
                  function validate(searchForm) {
                      if (editNum(document.Search.srchSeq, 3, 0))
                          return true;
                  }
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "LABORINPROCESS")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, "Select HDMLPM.*, coalesce(OHSTC,'') as OHSTC, OHCSDT, OHCDDT, coalesce(OLCAPS,' ') as OLCAPS, coalesce(WCDESC,'') as WCDESC ", stmtSQL)
                          @dtw_concat(fileSQL, " HDMLPM", fileSQL)
                          @dtw_concat(fileSQL, " left join HDMOHM on LPPLT=OHPLT and LPORD=OHORD", fileSQL)
                          @dtw_concat(fileSQL, " left join HDMWCM on WCPLT=LPPLT and WCDEPT=LPDEPT and WCWC=LPWC", fileSQL)

                          @dtw_concat(fileSQL, " left join (", fileSQL)
                          @dtw_concat(fileSQL, "  Select OLPLT,OLORD,OLSEQN, 'Y' as OLCAPS", fileSQL)
                          @dtw_concat(fileSQL, "  from HDMOLD", fileSQL)
                          @dtw_concat(fileSQL, "  inner join HDMWCX on OLPLT=WXPLT and OLDEPT=WXDEPT and OLWC=WXWC and 'Y'=WXAVLC", fileSQL)
                          @dtw_concat(fileSQL, "  inner join (Select WLPLT,WLDEPT,WLWC,WLDATE", fileSQL)
                          @dtw_concat(fileSQL, "              From HDWCLD", fileSQL)
                          @dtw_concat(fileSQL, "              Where WLLLHR>WLLCAP or WLMLHR>WLMCAP)", fileSQL)
                          @dtw_concat(fileSQL, "              as WCLD on OLPLT=WLPLT and OLDEPT=WLDEPT and OLWC=WLWC and F_MAKEDATE(OLDAY)=WLDATE", fileSQL)
                          @dtw_concat(fileSQL, "  Where OLOTYP in ('F','R')", fileSQL)
                          @dtw_concat(fileSQL, "  Group By OLPLT,OLORD,OLSEQN", fileSQL)
                          @dtw_concat(fileSQL, "  ) as TEST on LPPLT=OLPLT and LPORD=OLORD and LPSEQN=OLSEQN", fileSQL)
                          
                          @dtw_concat(selectSQL, " LPPLT=$(plantNumber) and LPORD='$(mfgOrder)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By LPPLT,LPORD,$(orderBy)", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                         
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @LaborInProcess_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) LaborInProcess_Query (IN CHAR(64)    profileHandle,
				             CHAR(2)     dataBaseID,
                                            CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)LaborInProcessMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      <table $(contentTable)>
          @Format_Header_URL("Plant", $(plantName), $(plantNumber), "$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(d2wVarBase)")
          @Format_Header_URL("Mfg Order", $(mfgOrder), "", "$(homeURL)$(phpPath)hdList.php?$(altVarBase)&tblID=445&pagID=0&tag=QSEARCH&fKey1=OHPLT&fVal1=$(plantNumber)&fKey2=OHORD&fVal2=$(mfgOrder)")
      </table>
      %INCLUDE "ConfMessageDisplay.icl"
	
      $(hrTagAttr)	

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Rtg<br>Seq</th>
                      <th class="colhdr">Dept</th>
                      <th class="colhdr">Work<br>Center</th>
                  </tr>

                  <tr><td><input type="text" class="inputnmbr" name="srchSeq" size="3" maxlength="3">
                          <input type="hidden" name="operseq" value="=">
                      </td>
                      <td><input type="text" class="inputalph" name="srchDept" size="5" maxlength="5">
                          <input type="hidden" name="operdept" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchWC" size="5" maxlength="5">
                          <input type="hidden" name="operwc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchSeq.focus();
              </script>
          </form>
	
          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("LPSEQN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SEQN" title="Sequence By Routing Sequence"> Rtg<br>Seq</a></th>
              @OrderBy_Sort("LPDEPT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DEPT" title="Sequence By Department)"> Dept</a></th>	
              @OrderBy_Sort("LPWC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=WC" title="Sequence By Work Center"> Work<br>Center</a></th>
              @OrderBy_Sort("WCDESC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=WCDESC" title="Sequence By Descriptoin"> Description</a></th>
              <th class="colhdr">Cap<br>Const</th>
              @OrderBy_Sort("LPRTYP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RTYP" title="Sequence By Routing Type">Rtg<br>Typ</a></th>
              @OrderBy_Sort("LPALTC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ALTC" title="Sequence By Alternate Operation">Alt<br>Opr</a></th>
              @OrderBy_Sort("LPMHRS", sortVar)
              <th class="colhdr$(sortVar)" COLSPAN="2"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MHRS" title="Sequence By Measured Hours">Measured<br>Hours</a></th>
              @OrderBy_Sort("LPMPON", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=MPON" title="Sequence By Crew Size">Crew<br>Size</a></th>
              @OrderBy_Sort("LPSUHR", sortVar)
              <th class="colhdr$(sortVar)" colspan="2"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SUHR" title="Sequence By Standard Setup Hours">Setup<br>Hours</a></th>
              @OrderBy_Sort("LPREAS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=REAS" title="Sequence By Reason Code"> R<br>S</a></th>
              @OrderBy_Sort("LPRELC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RELC" title="Sequence By Release Code"> Rel</a></th>
              @OrderBy_Sort("LPOPRC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=OPRC" title="Sequence By Operation Complete"> Cmp</a></th>
              @OrderBy_Sort("LPLADT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=LADT" title="Sequence By Last Activity Date"> Last Act<br>Date</a></th>
              %if (V_HDSCRL != "")
                  @OrderBy_Sort("LPCCCD", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CCCD" title="Sequence By Cost Categories">Cost<br>Catg</a></th>
              %endif
          </tr>		
          %INCLUDE "NoRecordsFound.icl"

      %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc("Routing Sequence", $(V_LPSEQN), "", "", "", "", confirmDesc)
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;sequenceNumber=@dtw_rurlescseq(V_LPSEQN)")
	       <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)LaborInProcessMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)LaborInProcessMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href=$(homeURL)$(cGIPath)LaborInProcessMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D>$(deleteImageSml)</a>
                          %endif
    		           %if (V_LPNTCD == "Y")
                              <a href="$(homeURL)$(cGIPath)LaborInProcessNotes.d2w/REPORT$(maintainVar)">$(commentExistImage)</a>
                          %else
                              <a href="$(homeURL)$(cGIPath)LaborInProcessNotes.d2w/REPORT$(maintainVar)">$(commentImage)</a>
                          %endif
                          %if (sec_05 == "Y" && V_HDSCRL != "" && V_LPALTC != "A")
                              <a href="$(homeURL)$(cGIPath)LaborInProcessCostCategory.d2w/REPORT$(maintainVar)">$(costCategorySml)</a>
                          %endif
                      </td>
                  %endif
                  @Format_Nbr($(V_LPMHRS), F_LPMHRS, "4", $(hrsEditCode), "", "", "")
                  @Format_Nbr($(V_LPMPON), F_LPMPON, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_LPSUHR), F_LPSUHR, "2", $(hrsEditCode), "", "", "")
                  @Format_Date(V_LPLADT, "D", F_LPLADT)
                  @RtvFldDesc("(FLTYPE='RTGTYPE' and FLVALU='$(V_LPRTYP)')", "SYFLAG", "FLDESC", rtypDesc)
                  @RtvFldDesc("FLTYPE='ALTOPER' and FLVALU='$(V_LPALTC)'", "SYFLAG", "FLDESC", altcDesc)
                  @RtvFldDesc("FLTYPE='RTMHRC' and FLVALU='$(V_LPMHRC)'", "SYFLAG", "FLDESC", mhrcDesc)
                  @RtvFldDesc("FLTYPE='RTSURC' and FLVALU='$(V_LPSURC)'", "SYFLAG", "FLDESC", surcDesc)
                  <td class="colnmbr">$(V_LPSEQN)</td>
                  <td class="colalph">$(V_LPDEPT)</td>

                  @dtw_assign(AllowWLA, "Y")
                  %if (V_LPALTC != "A")
                      @RtvFldDesc("OLPLT=$(V_LPPLT) and OLORD='$(V_LPORD)' and OLSEQN=$(V_LPSEQN)", "HDMOLD", "MIN(OLDAY)", olStart)
                      @RtvFldDesc("OLPLT=$(V_LPPLT) and OLORD='$(V_LPORD)' and OLSEQN=$(V_LPSEQN)", "HDMOLD", "MAX(OLDAY)", olEnd)
                      @Date_CYMD_ISO(olStart, F_START)
                      @Date_CYMD_ISO(olEnd, F_END)
                  %elif (V_OHCSDT != "" && V_OHCDDT != "")
                      @dtw_assign(F_START, V_OHCSDT)
                      @dtw_assign(F_END, V_OHCDDT)
                  %else
                      @dtw_assign(AllowWLA, "N")
                  %endif 
                  %if (AllowWLA == "Y" && (V_OHSTC == "A" || V_OHSTC == "P") && (V_LPRTYP == "D" || V_LPRTYP == "P"))
                  	  @dtw_assign(workloadWinName, V_LPWC)
                      <td class="colalph"><a href="$(homeURL)$(phpPath)WorkLoadAnalysis.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(plantNumber)&amp;forDept=@dtw_rurlescseq($(V_LPDEPT))&amp;forWC=@dtw_rurlescseq($(V_LPWC))&amp;startDate=@dtw_rurlescseq($(F_START))&amp;endDate=@dtw_rurlescseq($(F_END))" onclick="$(workloadWinVar)" title="View Work Load Analysis"> $(V_LPWC) </a></td>
                  %else
                      <td class="colalph">$(V_LPWC)</td>
                  %endif
                  <td class="colalph">$(V_WCDESC)</td>
                  <td class="colalph">$(V_OLCAPS)</td>
                  <td class="colcode" $(helpCursor)><span title="$(rtypDesc)">$(V_LPRTYP)</span></td>
                  <td class="colcode" $(helpCursor)><span title="$(altcDesc)">$(V_LPALTC)</span></td>
                  <td class="colnmbr">$(F_LPMHRS)</td>
                  <td class="colcode" $(helpCursor)><span title="$(mhrcDesc)">$(V_LPMHRC)</span></td>
                  <td class="colnmbr">$(F_LPMPON)</td>
                  <td class="colnmbr">$(F_LPSUHR)</td>
                  <td class="colcode" $(helpCursor)><span title="$(surcDesc)">$(V_LPSURC)</span></td>
                  <td class="colcode">$(V_LPREAS)</td>
                  <td class="colcode">$(V_LPRELC)</td>
                  <td class="colcode">$(V_LPOPRC)</td>
                  <td class="colnmbr">$(F_LPLADT)</td>
                  %if (V_HDSCRL != "")
                      <td class="colcode">$(V_LPCCCD)</td>
                  %endif
	       </tr>
	   %}
      </table>
      %if (sql_Record_Count != "1")
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
          $(hrTagAttr)
          %INCLUDE "Copyright.icl"
      %endif
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "LPSEQN")
          @DTW_ASSIGN(orderByDisplay, "Routing Sequence")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "SEQN")
      %if (orderBy == "LPSEQN")
          @DTW_ASSIGN(orderBy, "LPSEQN DESC")
          @DTW_ASSIGN(orderByDisplay, "Routing Sequence (descending)")
      %else
          @DTW_ASSIGN(orderBy, "LPSEQN")
          @DTW_ASSIGN(orderByDisplay, "Routing Sequence")
      %endif
  %elif (sequence == "DEPT")
      %if (orderBy == "LPDEPT")
          @DTW_ASSIGN(orderBy, "LPDEPT DESC")
          @DTW_ASSIGN(orderByDisplay, "Department (descending)")
      %else
          @DTW_ASSIGN(orderBy, "LPDEPT")
          @DTW_ASSIGN(orderByDisplay, "Department")
      %endif
  %elif (sequence == "WC")
      %if (orderBy == "LPWC")
          @DTW_ASSIGN(orderBy, "LPWC DESC")
          @DTW_ASSIGN(orderByDisplay, "Work Center (descending)")
      %else
          @DTW_ASSIGN(orderBy, "LPWC")
          @DTW_ASSIGN(orderByDisplay, "Work Center")
      %endif
  %elif (sequence == "WCDESC")
      %if (orderBy == "WCDESC")
          @DTW_ASSIGN(orderBy, "WCDESC DESC")
          @DTW_ASSIGN(orderByDisplay, "Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "WCDESC")
          @DTW_ASSIGN(orderByDisplay, "Description")
      %endif
  %elif (sequence == "RTYP")
      %if (orderBy == "LPRTYP")
          @DTW_ASSIGN(orderBy, "LPRTYP DESC")
          @DTW_ASSIGN(orderByDisplay, "Routing Type (descending)")
      %else
          @DTW_ASSIGN(orderBy, "LPRTYP")
          @DTW_ASSIGN(orderByDisplay, "Routing Type")
      %endif
  %elif (sequence == "ALTC")
      %if (orderBy == "LPALTC")
          @DTW_ASSIGN(orderBy, "LPALTC DESC")
          @DTW_ASSIGN(orderByDisplay, "Alternate Operation (descending)")
      %else
          @DTW_ASSIGN(orderBy, "LPALTC")
          @DTW_ASSIGN(orderByDisplay, "Alternate Operation")
      %endif
  %elif (sequence == "MHRS")
      %if (orderBy == "LPMHRS")
          @DTW_ASSIGN(orderBy, "LPMHRS DESC")
          @DTW_ASSIGN(orderByDisplay, "Measured Hours (descending)")
      %else
          @DTW_ASSIGN(orderBy, "LPMHRS")
          @DTW_ASSIGN(orderByDisplay, "Measured Hours")
      %endif
  %elif (sequence == "MPON")
      %if (orderBy == "LPMPON")
          @DTW_ASSIGN(orderBy, "LPMPON DESC")
          @DTW_ASSIGN(orderByDisplay, "Crew Size (descending)")
      %else
          @DTW_ASSIGN(orderBy, "LPMPON")
          @DTW_ASSIGN(orderByDisplay, "Crew Size")
      %endif
  %elif (sequence == "SUHR")
      %if (orderBy == "LPSUHR")
          @DTW_ASSIGN(orderBy, "LPSUHR DESC")
          @DTW_ASSIGN(orderByDisplay, "Set Up Hours (descending)")
      %else
          @DTW_ASSIGN(orderBy, "LPSUHR")
          @DTW_ASSIGN(orderByDisplay, "Set Up Hours")
      %endif
  %elif (sequence == "REAS")
      %if (orderBy == "LPREAS")
          @DTW_ASSIGN(orderBy, "LPREAS DESC")
          @DTW_ASSIGN(orderByDisplay, "Reason Code (descending)")
      %else
          @DTW_ASSIGN(orderBy, "LPREAS")
          @DTW_ASSIGN(orderByDisplay, "Reason Code")
      %endif
  %elif (sequence == "RELC")
      %if (orderBy == "LPRELC")
          @DTW_ASSIGN(orderBy, "LPRELC DESC")
          @DTW_ASSIGN(orderByDisplay, "Release Code (descending)")
      %else
          @DTW_ASSIGN(orderBy, "LPRELC")
          @DTW_ASSIGN(orderByDisplay, "Release Code")
      %endif
  %elif (sequence == "OPRC")
      %if (orderBy == "LPOPRC")
          @DTW_ASSIGN(orderBy, "LPOPRC DESC")
          @DTW_ASSIGN(orderByDisplay, "Operation Complete (descending)")
      %else
          @DTW_ASSIGN(orderBy, "LPOPRC")
          @DTW_ASSIGN(orderByDisplay, "Operation Complete")
      %endif
  %elif (sequence == "LADT")
      %if (orderBy == "LPLADT")
          @DTW_ASSIGN(orderBy, "LPLADT DESC")
          @DTW_ASSIGN(orderByDisplay, "Last Activity Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "LPLADT")
          @DTW_ASSIGN(orderByDisplay, "Last Activity Date")
      %endif
  %elif (sequence == "CCCD")
      %if (orderBy == "LPCCCD")
          @DTW_ASSIGN(orderBy, "LPCCCD DESC")
          @DTW_ASSIGN(orderByDisplay, "Cost Categories (descending)")
      %else
          @DTW_ASSIGN(orderBy, "LPCCCD")
          @DTW_ASSIGN(orderByDisplay, "Cost Categories")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchSeq, 3, 0) &&
                      editNum(document.Search.srchMhrs, 3, 4) &&
                      editNum(document.Search.srchSuhr, 3, 2) &&
                      editNum(document.Search.srchMpon, 3, 2) &&
                      editdate(document.Search.srchLadt))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "LABORINPROCESSSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"
                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Routing Sequence</td>
                              @dtw_assign(operNbr, "operseq")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchSeq" size="3" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Department</td>
                              @dtw_assign(operNbr, "operdept")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchDept" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">Work Center</td>
                              @dtw_assign(operNbr, "operwc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchWC" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">Routing Type</td>
                              @dtw_assign(operNbr, "operrtyp")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchRtyp" size="2" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Alternate Operation</td>
                              @dtw_assign(operNbr, "operaltc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchAltc" size="2" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Measured Hours</td>
                              @dtw_assign(operNbr, "opermhrs")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchMhrs" size="8" maxlength="8"></td>
                          </tr>

                          <tr><td class="dsphdr">Measured Hours Ref Code</td>
                              @dtw_assign(operNbr, "opermhrc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchMhrc" size="2" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Crew Size</td>
                              @dtw_assign(operNbr, "opermpon")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchMpon" size="6" maxlength="6"></td>
                          </tr>

                          <tr><td class="dsphdr">Set Up Hours</td>
                              @dtw_assign(operNbr, "opersuhr")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchSuhr" size="8" maxlength="8"></td>
                          </tr>

                          <tr><td class="dsphdr">Set Up Hours Ref Code</td>
                              @dtw_assign(operNbr, "opersurc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchSurc" size="2" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Reason Code</td>
                              @dtw_assign(operNbr, "operreas")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchReas" size="2" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Release Code</td>
                              @dtw_assign(operNbr, "operrelc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchRelc" size="2" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Operation Complete</td>
                              @dtw_assign(operNbr, "operoprc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchOprc" size="2" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Last Activity Date</td>
                              @dtw_assign(operNbr, "operladt")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchLadt" size="6" maxlength="6"><a href="javascript:calWindow('srchLadt');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Routing Notes</td>
                              @dtw_assign(operNbr, "operntcd")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchNtcd" size="2" maxlength="1"></td>
                          </tr>

                          %if (V_HDSCRL != "")
                              <tr><td class="dsphdr">Cost Categories</td>
                                  @dtw_assign(operNbr, "opercccd")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"> <input type="text" name="srchCccd" size="2" maxlength="1"></td>
                              </tr>
                          %endif

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchSeq.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("LPSEQN", "Routing Sequence", $(srchSeq), "", operseq, "N")
  @Build_WildCard ("LPDEPT", "Department", $(srchDept), "U", operdept, "A")
  @Build_WildCard ("LPWC", "Work Center", $(srchWC), "U", operwc, "A")
  @Build_WildCard ("LPRTYP", "Routing Type", $(srchRtyp), "U", operrtyp, "A")
  @Build_WildCard ("LPALTC", "Alternate Operation", $(srchAltc), "U", operaltc, "A")
  @Build_WildCard ("LPMHRS", "Measured Hours", $(srchMhrs), "", opermhrs, "N")
  @Build_WildCard ("LPMHRC", "Measured Hours Ref Code", $(srchMhrc), "U", opermhrc, "A")
  @Build_WildCard ("LPMPON", "Crew Size", $(srchMpon), "", opermpon, "N")
  @Build_WildCard ("LPSUHR", "Set Up Hours", $(srchSuhr), "", opersuhr, "N")
  @Build_WildCard ("LPSURC", "Set Up Hours Ref Code", $(srchSurc), "U", opersurc, "A")
  @Build_WildCard ("LPREAS", "Reason Code", $(srchReas), "U", operreas, "A")
  @Build_WildCard ("LPRELC", "Release Code", $(srchRelc), "U", operrelc, "A")
  @Build_WildCard ("LPOPRC", "Operation Complete", $(srchOprc), "U", operoprc, "A")
  @Build_WildCard ("LPLADT", "Last Activity Date", $(srchLadt), "", operladt, "D")
  @Build_WildCard ("LPNTCD", "Routing Notes", $(srchNtcd), "U", operntcd, "A")
  %if (V_HDSCRL != "")
      @Build_WildCard ("LPCCCD", "Cost Categories", $(srchCccd), "U", opercccd, "A")
  %endif
		
  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}