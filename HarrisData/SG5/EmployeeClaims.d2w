%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Employee Claims"
  d2wName                 = "EmployeeClaims.d2w"
  d2wVarBase              = "$(genericVarBase)$(employeeVarBase)&amp;benefitCode=@dtw_rurlescseq(benefitCode)&amp;planCode=@dtw_rurlescseq(planCode)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  DTW_PAD_PGM_PARMS       = "YES"
  rowIndexNext            = "1"
  totalPages              = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @dtw_assign(applicationID, "PE")
  @dtw_assign(UVPREmpl, "00000")
  %INCLUDE "EmplUV.icl"
  @dtw_assign(peUserPass, userPass)

  %if (peUserPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function goToPage(selectedPage) {if (selectedPage != "") {self.location=selectedPage;}}
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "EMPLOYEECLM")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          @dtw_assign(programName, "HPECLE")
                          @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                          %if (sec_05 == "Y")

                              %INCLUDE "stmtSQLClear.icl"
                              @dtw_concat(stmtSQL, "SELECT CLCOVR, CLPLAN, CLCLAM, CLCLAS, CLDOCL, CLSDOS, CLEDOS, ", stmtSQL)
                              @dtw_concat(stmtSQL, "       CLCAMT, CLPAMT, CLELAM, CLCHCK", stmtSQL)
                              @dtw_concat(fileSQL, " CBCLAM ", fileSQL)
                              @dtw_concat(selectSQL, " CLCOMP=$(prCompany) and CLFACL=$(prFacility) and CLEMPL=$(hrEmployee) and CLCOVR='$(benefitCode)' and CLPLAN = '$(planCode)' ", selectSQL)
                              %INCLUDE "stmtSQLSelect.icl"
                              @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                              %INCLUDE "stmtSQLEnd.icl"
                              %INCLUDE "stmtSQLTotalRows.icl"
                              @Claims_Query(profileHandle, dataBaseID, stmtSQL)
                          %endif
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Claims_Query (IN  CHAR(64)    profileHandle,
				      CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
             <col width="80%">
             <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/report") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
          @Ret_Format_EmplName(prCompany, prFacility, UVPREmpl, hrCompany, hrEmployee, "H", F_EmpName)
          <tr><td><h2>$(F_EmpName)</h2></td></tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"
      $(hrTagAttr)

          %if (formatToPrint != "Y")
               %INCLUDE "AssignPageValue.icl"
          %endif
          <table $(contentTable)>
          <tr>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("CLCOVR", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BenefitCode" title="Sequence By Benefit Code, Plan Code, Claim Number, Date Of Claim (descending)"> Benefit<br>Code</a></th>
              @OrderBy_Sort("CLPLAN", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlanCode" title="Sequence By Plan Code, Benefit Code, Claim Number, Date Of Claim (descending)"> Plan<br>Code</a></th>
              @OrderBy_Sort("CLCLAM", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ClaimNumber" title="Sequence By Claim Number, Plan Code, Benefit Code, Date Of Claim (descending)"> Claim<br>Number</a></th>	
              @OrderBy_Sort("CLDOCL", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DateOfClaim" title="Sequence By Date Of Claim, Benefit Code, Plan Code, Claim Number,"> Date Of Claim</a></th>
              @OrderBy_Sort("CLSDOS", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ServiceDate" title="Sequence By Start Date Of Service, Benefit Code, Plan Code, Claim Number">Start Date<br> Of Service</a></th>
	              <th class="colhdr">End Date<br>Of Service</th>
              @OrderBy_Sort("CLCAMT", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ClaimAmount" title="Sequence By Claim Amount, Benefit Code, Plan Code, Claim Number, Date Of Claim (descending)"> Claim Amount</a></th>
              @OrderBy_Sort("CLELAM", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=EligibleAmount" title="Sequence By Eligible Amount, Benefit Code, Plan Code, Claim Number, Date Of Claim (descending)"> Eligible Amount</a></th>
              @OrderBy_Sort("CLPAMT", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PaymentsToDate" title="Sequence By Payments To Date, Benefit Code, Plan Code, Claim Number, Date Of Claim (descending)"> Payments To Date</a></th>
          </tr>		

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @Format_Date(V_CLDOCL, "D", F_CLDOCL)
              @Format_Date(V_CLSDOS, "D", F_CLSDOS)
              @Format_Date(V_CLEDOS, "D", F_CLEDOS)

              %INCLUDE "SetRowClass.icl"

              <tr class="$(rowClass)">
                  <td class="colcode">$(V_CLCOVR)</td>
                  <td class="colcode">$(V_CLPLAN)</td>
                  <td class="colnmbr">$(V_CLCLAM)</td>
                  <td class="coldate">$(F_CLDOCL)</td>
                  <td class="coldate">$(F_CLSDOS)</td>
                  <td class="coldate">$(F_CLEDOS)</td>
                  @Format_Nbr($(V_CLCAMT), F_CLCAMT, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_CLCAMT)</td>
                  @Format_Nbr($(V_CLELAM), F_CLELAM, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_CLELAM)</td>
                  @dtw_assign(programName, "HPRCHI")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  %if (V_CLPAMT != ".00")
                      @Format_Nbr($(V_CLPAMT), F_CLPAMT, "2", $(amtEditCode), "", "", "")
                      %if (sec_05 == "Y")
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)HRClaimHistory.d2w/report$(d2wVarBase)&amp;claimNumber=@dtw_rurlescseq(V_CLCLAM)" onclick="$(inquiryWinVar)" title="Display Claim Payment History">$(F_CLPAMT)</a></td>
                      %else
                          <td class="colnmbr">$(F_CLPAMT)</td>
                      %endif
                  %else
                      <td class="colnmbr">&nbsp;</td>
                  %endif
              </tr>
          %}
      </table>
      %if (sql_Record_Count != "0")
          %INCLUDE "PageBottom.icl"
      %endif
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(programName, "HPECLE")
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "CLCOVR,CLPLAN,CLCLAM,CLDOCL DESC")
              @DTW_ASSIGN(orderByDisplay, "Benefit Code, Plan Code, Claim Number, Date Of Claim (descending)")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "BenefitCode")
      %if (orderBy == "CLCOVR,CLPLAN,CLCLAM,CLDOCL DESC")
          @DTW_ASSIGN(orderBy, "CLCOVR DESC,CLPLAN,CLCLAM,CLDOCL DESC")
          @DTW_ASSIGN(orderByDisplay, "Benefit Code (descending), Plan Code, Claim Number, Date Of Claim (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CLCOVR,CLPLAN,CLCLAM,CLDOCL DESC")
          @DTW_ASSIGN(orderByDisplay, "Benefit Code, Plan Code, Claim Number, Date Of Claim (descending)")
      %endif
  %elif (sequence == "PlanCode")
      %if (orderBy == "CLPLAN,CLCOVR,CLCLAM,CLDOCL DESC")
          @DTW_ASSIGN(orderBy, "CLPLAN DESC,CLCOVR,CLCLAM,CLDOCL DESC")
          @DTW_ASSIGN(orderByDisplay, "Plan Code (descending), Benefit Code, Claim Number, Date Of Claim (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CLPLAN,CLCOVR,CLCLAM,CLDOCL DESC")
          @DTW_ASSIGN(orderByDisplay, "Plan Code, Benefit Code, Claim Number, Date Of Claim (descending)")
      %endif
  %elif (sequence == "ClaimNumber")
      %if (orderBy == "CLCLAM,CLPLAN,CLCOVR,CLDOCL DESC")
          @DTW_ASSIGN(orderBy, "CLCLAM DESC,CLPLAN,CLCOVR,CLDOCL DESC")
          @DTW_ASSIGN(orderByDisplay, "Claim Number (descending), Plan Code, Benefit Code, Date Of Claim (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CLCLAM,CLPLAN,CLCOVR,CLDOCL DESC")
          @DTW_ASSIGN(orderByDisplay, "Claim Number, Plan Code, Benefit Code, Date Of Claim (descending)")
      %endif
  %elif (sequence == "DateOfClaim")
      %if (orderBy == "CLDOCL,CLCOVR,CLPLAN,CLCLAM")
          @DTW_ASSIGN(orderBy, "CLDOCL DESC,CLCOVR,CLPLAN,CLCLAM")
          @DTW_ASSIGN(orderByDisplay, "Date Of Claim (descending), Benefit Code, Plan Code, Claim Number")
      %else
          @DTW_ASSIGN(orderBy, "CLDOCL,CLCOVR,CLPLAN,CLCLAM")
          @DTW_ASSIGN(orderByDisplay, "Date Of Claim, Benefit Code, Plan Code, Claim Number")
      %endif
  %elif (sequence == "ServiceDate")
      %if (orderBy == "CLSDOS,CLCOVR,CLPLAN,CLCLAM")
          @DTW_ASSIGN(orderBy, "CLSDOS DESC,CLCOVR,CLPLAN,CLCLAM")
          @DTW_ASSIGN(orderByDisplay, "Start Date Of Service (descending), Benefit Code, Plan Code, Claim Number")
      %else
          @DTW_ASSIGN(orderBy, "CLSDOS,CLCOVR,CLPLAN,CLCLAM")
          @DTW_ASSIGN(orderByDisplay, "Start Date Of Service, Benefit Code, Plan Code, Claim Number")
      %endif
  %elif (sequence == "ClaimAmount")
      %if (orderBy == "CLCAMT,CLCOVR,CLPLAN,CLCLAM,CLDOCL DESC")
          @DTW_ASSIGN(orderBy, "CLCAMT DESC,CLCOVR,CLPLAN,CLCLAM,CLDOCL DESC")
          @DTW_ASSIGN(orderByDisplay, "Claim Amount (descending), Benefit Code, Plan Code, Claim Number, Date Of Claim (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CLCAMT,CLCOVR,CLPLAN,CLCLAM,CLDOCL DESC")
          @DTW_ASSIGN(orderByDisplay, "Claim Amount, Benefit Code, Plan Code, Claim Number, Date Of Claim (descending)")
      %endif
  %elif (sequence == "EligibleAmount")
      %if (orderBy == "CLELAM,CLCOVR,CLPLAN,CLCLAM,CLDOCL DESC")
          @DTW_ASSIGN(orderBy, "CLELAM DESC,CLCOVR,CLPLAN,CLCLAM,CLDOCL DESC")
          @DTW_ASSIGN(orderByDisplay, "Eligible Amount (descending), Benefit Code, Plan Code, Claim Number, Date Of Claim (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CLELAM,CLCOVR,CLPLAN,CLCLAM,CLDOCL DESC")
          @DTW_ASSIGN(orderByDisplay, "Eligible Amount, Benefit Code, Plan Code, Claim Number, Date Of Claim (descending)")
      %endif
  %elif (sequence == "PaymentsToDate")
      %if (orderBy == "CLPAMT,CLCOVR,CLPLAN,CLCLAM,CLDOCL DESC")
          @DTW_ASSIGN(orderBy, "CLPAMT DESC,CLCOVR,CLPLAN,CLCLAM,CLDOCL DESC")
          @DTW_ASSIGN(orderByDisplay, "Payments To Date (descending), Benefit Code, Plan Code, Claim Number, Date Of Claim (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CLPAMT,CLCOVR,CLPLAN,CLCLAM,CLDOCL DESC")
          @DTW_ASSIGN(orderByDisplay, "Payments To Date, Benefit Code, Plan Code, Claim Number, Date Of Claim (descending)")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}