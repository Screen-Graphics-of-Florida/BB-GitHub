%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "WildCard.icl"


%Define {
  page_title              = "Sales Forecast Inquiry"
  d2wName                 = "SalesForecastInquiry4.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;type=@dtw_rurlescseq(type)&amp;reference=@dtw_rurlescseq(reference)&amp;year=@dtw_rurlescseq(year)&amp;fdky=@dtw_rurlescseq(fdky)&amp;cust=@dtw_rurlescseq(cust)&amp;FDCUST=@dtw_rurlescseq(FDCUST)&amp;ccls=@dtw_rurlescseq(ccls)&amp;FDCCLS=@dtw_rurlescseq(FDCCLS)&amp;creg=@dtw_rurlescseq(creg)&amp;FDCRGN=@dtw_rurlescseq(FDCRGN)&amp;loc=@dtw_rurlescseq(loc)&amp;FDLOC=@dtw_rurlescseq(FDLOC#)&amp;slmn=@dtw_rurlescseq(slmn)&amp;FDSLSM=@dtw_rurlescseq(FDSLSM)&amp;pcls=@dtw_rurlescseq(pcls)&amp;FDPCLS=@dtw_rurlescseq(FDPCLS)&amp;bac=@dtw_rurlescseq(bac)&amp;FDBAC=@dtw_rurlescseq(FDBAC)&amp;ptyp=@dtw_rurlescseq(ptyp)&amp;FDPTYP=@dtw_rurlescseq(FDPTYP)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
  periodFormat            = "00"
  quantityFormat          = "00"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@type", "@dtw_rurlescseq(type)", "1", "a", workURL)
  @dtw_replace(workURL, "@@reference", "@dtw_rurlescseq(reference)", "1", "a", workURL)
  @dtw_replace(workURL, "@@year", "@dtw_rurlescseq(year)", "1", "a", workURL)
  @dtw_replace(workURL, "@@fdky", "@dtw_rurlescseq(fdky)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                 if (editNum(document.Search.srchplt, 3, 0))
                     return true;
                  }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "SALESFORECASTINQUIRY4")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select FFPLT, FFITEM, IMIMDS, IMIMDSU, IMPTYP", stmtSQL)
                      @dtw_concat(fileSQL, " HDMFD2 join HDIMST ON FFITEM=IMITEM ", fileSQL)
                      @dtw_concat(selectSQL, " FFFTYP=$(type) and FFREFN='$(reference)' and FFYEAR=$(year) and FFFDKY='$(fdky)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64) profileHandle,
                                   CHAR(2)   dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      @RtvFldDesc("FTFTYP='$(type)' and FTREFN='$(reference)' and FTYEAR='$(year)' ", "HDMFDF", "FTFCLD", longDescription)
      @RtvFldDesc("FTFTYP='$(type)' and FTREFN='$(reference)' and FTYEAR='$(year)' ", "HDMFDF", "FTSDAT", startDate)
      @RtvFldDesc("FTFTYP='$(type)' and FTREFN='$(reference)' and FTYEAR='$(year)' ", "HDMFDF", "FTEDAT", endDate)
      @Format_Date_ISO(startDate, "H", F_FTSDAT)
      @Format_Date_ISO(endDate, "H", F_FTEDAT)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      <table $(contentTable)>
          @Format_Header_URL("Forecast Type", $(longDescription), $(type), "")
          @Format_Header_URL("Reference", $(reference), "", "")
          @Format_Header_URL("Forecast Year", $(year), "", "")
          %if (cust == "1")
              @RtvFldDesc("CMCUST=$(FDCUST)", "HDCUST", "CMCNA1", fieldDesc)
              @Format_Header_URL("Customer", $(fieldDesc), $(FDCUST), "")
          %elif (ccls == "1")
              @RtvFldDesc("CCCCLS='$(FDCCLS)' ", "HDCCLS", "CCCCDS", fieldDesc)
              @Format_Header_URL("Customer Class", $(fieldDesc), $(FDCCLS), "")
          %elif (creg == "1")
              @RtvFldDesc("RGCRGN='$(FDCRGN)' ", "HDCRGN", "RGCRDS", fieldDesc)
              @Format_Header_URL("Customer Region", $(fieldDesc), $(FDCRGN), "")
          %elif (loc == "1")
              @RtvFldDesc("LOLO#=$(FDLOC#)", "HDLCTN", "LOLNA1", fieldDesc)
              @Format_Header_URL("Location", $(fieldDesc), $(FDLOC#), "")
          %elif (slmn == "1")
              @RtvFldDesc("SMSLSM=$(FDSLSM)", "HDSLSM", "SMSNA1", fieldDesc)
              @Format_Header_URL("Salesman", $(fieldDesc), $(FDSLSM), "")
          %elif (pcls == "1")
              @RtvFldDesc("PCPCLS='$(FDPCLS)' ", "HDPCLS", "PCPCDS", fieldDesc)
              @Format_Header_URL("Product Class", $(fieldDesc), $(FDPCLS), "")
          %elif (bac == "1")
              @RtvFldDesc("BMBUYR=$(FDBAC)", "HDBUYR", "BMBNA1", fieldDesc)
              @Format_Header_URL("Buyer/Analyst", $(fieldDesc), $(FDBAC), "")
          %elif (ptyp == "1")
              @Format_Header_URL("Part Type", $(FDPTYP), "", "")
          %endif
          %if (cust == "2")
              @RtvFldDesc("CMCUST=$(FDCUST)", "HDCUST", "CMCNA1", fieldDesc)
              @Format_Header_URL("Customer", $(fieldDesc), $(FDCUST), "")
          %elif (ccls == "2")
              @RtvFldDesc("CCCCLS='$(FDCCLS)' ", "HDCCLS", "CCCCDS", fieldDesc)
              @Format_Header_URL("Customer Class", $(fieldDesc), $(FDCCLS), "")
          %elif (creg == "2")
              @RtvFldDesc("RGCRGN='$(FDCRGN)' ", "HDCRGN", "RGCRGN", fieldDesc)
              @Format_Header_URL("Customer Region", $(fieldDesc), $(FDCRGN), "")
          %elif (loc == "2")
              @RtvFldDesc("LOLO#=$(FDLOC#)", "HDLCTN", "LOLNA1", fieldDesc)
              @Format_Header_URL("Location", $(fieldDesc), $(FDLOC#), "")
          %elif (slmn == "2")
              @RtvFldDesc("SMSLSM=$(FDSLSM)", "HDSLSM", "SMSNA1", fieldDesc)
              @Format_Header_URL("Salesman", $(fieldDesc), $(FDSLSM), "")
          %elif (pcls == "2")
              @RtvFldDesc("PCPCLS='$(FDPCLS)' ", "HDPCLS", "PCPCDS", fieldDesc)
              @Format_Header_URL("Product Class", $(fieldDesc), $(FDPCLS), "")
          %elif (bac == "2")
              @RtvFldDesc("BMBUYR=$(FDBAC)", "HDBUYR", "BMBNA1", fieldDesc)
              @Format_Header_URL("Buyer/Analyst", $(fieldDesc), $(FDBAC), "")
          %elif (ptyp == "2")
              @Format_Header_URL("Part Type", $(FDPTYP), "", "")
          %endif
          %if (cust == "3")
              @RtvFldDesc("CMCUST=$(FDCUST)", "HDCUST", "CMCNA1", fieldDesc)
              @Format_Header_URL("Customer", $(fieldDesc), $(FDCUST), "")
          %elif (ccls == "3")
              @RtvFldDesc("CCCCLS='$(FDCCLS)' ", "HDCCLS", "CCCCDS", fieldDesc)
              @Format_Header_URL("Customer Class", $(fieldDesc), $(FDCCLS), "")
          %elif (creg == "3")
              @RtvFldDesc("RGCRGN='$(FDCRGN)' ", "HDCRGN", "RGCRGN", fieldDesc)
              @Format_Header_URL("Customer Region", $(fieldDesc), $(FDCRGN), "")
          %elif (loc == "3")
              @RtvFldDesc("LOLO#=$(FDLOC#)", "HDLCTN", "LOLNA1", fieldDesc)
              @Format_Header_URL("Location", $(fieldDesc), $(FDLOC#), "")
          %elif (slmn == "3")
              @RtvFldDesc("SMSLSM=$(FDSLSM)", "HDSLSM", "SMSNA1", fieldDesc)
              @Format_Header_URL("Salesman", $(fieldDesc), $(FDSLSM), "")
          %elif (pcls == "3")
              @RtvFldDesc("PCPCLS='$(FDPCLS)' ", "HDPCLS", "PCPCDS", fieldDesc)
              @Format_Header_URL("Product Class", $(fieldDesc), $(FDPCLS), "")
          %elif (bac == "3")
              @RtvFldDesc("BMBUYR=$(FDBAC)", "HDBUYR", "BMBNA1", fieldDesc)
              @Format_Header_URL("Buyer/Analyst", $(fieldDesc), $(FDBAC), "")
          %elif (ptyp == "3")
              @Format_Header_URL("Part Type", $(FDPTYP), "", "")
          %endif
          %IF (startDate != "")
              @Format_Header_URL("Start Date", $(F_FTSDAT), "", "")
          %endif
          %IF (endDate != "")
              @Format_Header_URL("End Date", $(F_FTEDAT), "", "")
          %endif
      </table>

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST name="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr"> Plant</th>
                      <th class="colhdr"> Item Number</th>
                      <th class="colhdr"> Description</th>
                  </tr>
                  <tr>
                      <td><input type="text" class="inputnum" name="srchplt" size="3"
 maxlength="3">
                          <input type="hidden" name="operplt" value="=">
                      </td>
                      <td><input type="text" class="inputalph" name="srchitem" size="15" maxlength="15">
                          <input type="hidden" name="operitem" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchdesc" size="30" maxlength="30">
                          <input type="hidden" name="operdesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchplt.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")

          <tr>
                  @OrderBy_Sort("FFPLT", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Plant" title="Sequence By Plant, Item"> Plant</a></th>
                  @OrderBy_Sort("FDITEM", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Item" title="Sequence By Item, Plant"> Item Number</a></th>
                  @OrderBy_Sort("IMIMDSU", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description"> Description</a></th>
                  @OrderBy_Sort("IMPTYP", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PartType" title="Sequence By Part Type, Plant, Item"> Part Type</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{

              %INCLUDE "SetRowClass.icl"
              @Format_Nbr(V_FFPLT, F_FFPLT, "0", "Z", "", "", "")

              <tr class="$(rowClass)">
                  <td class="colnmbr">$(F_FFPLT)</td>
                  <td class="colalph">$(V_FFITEM)</td>
                  <td class="colalph">
                                      <a href="$(homeURL)$(cGIPath)SalesForecastInquiry8.d2w/LOAD$(d2wVarBase)&amp;plant=@dtw_rurlescseq(V_FFPLT)&amp;item=@dtw_rurlescseq(V_FFITEM)&amp;parttype=@dtw_rurlescseq(V_IMPTYP)&amp;periodFormat=@dtw_rurlescseq(periodFormat)&amp;quantityFormat=@dtw_rurlescseq(quantityFormat)" title="View Forecast">$(V_IMIMDS)</a></td>
                  <td class="colcode">$(V_IMPTYP)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"

  %if (formatToPrint == "Y")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else

      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "FFFTYP,FFREFN,FFYEAR,FFFDKY,FFPLT,FFITEM")
          @DTW_ASSIGN(orderByDisplay, "Plant")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Plant")
      %if (orderBy == "FFPLT")
          @DTW_ASSIGN(orderBy, "FFPLT DESC")
          @DTW_ASSIGN(orderByDisplay, "Plant (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FFPLT")
          @DTW_ASSIGN(orderByDisplay, "Plant")
      %endif
  %elif (sequence == "Item")
      %if (orderBy == "FFITEM")
          @DTW_ASSIGN(orderBy, "FFITEM DESC")
          @DTW_ASSIGN(orderByDisplay, "Item Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FFITEM")
          @DTW_ASSIGN(orderByDisplay, "Item Number")
      %endif
  %elif (sequence == "Desc")
      %if (orderBy == "IMIMDSU")
          @DTW_ASSIGN(orderBy, "IMIMDSU DESC")
          @DTW_ASSIGN(orderByDisplay, "Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "IMIMDSU")
          @DTW_ASSIGN(orderByDisplay, "Description")
      %endif
  %elif (sequence == "PartType")
      %if (orderBy == "IMPTYP")
          @DTW_ASSIGN(orderBy, "IMPTYP DESC")
          @DTW_ASSIGN(orderByDisplay, "Part Type (descending)")
      %else
          @DTW_ASSIGN(orderBy, "IMPTYP")
          @DTW_ASSIGN(orderByDisplay, "Part Type ")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

      @Build_WildCard ("FFPLT", "plant", $(srchplt), "", operplt, "N")
      @Build_WildCard ("FFITEM", "item", $(srchitem), "U", operitem, "A")
      @Build_WildCard ("IMIMDSU", "desc", $(srchdesc), "U", operdesc, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
