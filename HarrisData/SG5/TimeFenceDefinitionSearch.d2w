%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Time Fence Definition Search"
  d2wName                 = "TimeFenceDefinitionSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName      	   = ""
  fldName      	   = ""
  fldDesc                 = ""
  advanceSearch           = "N"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectTimeFence(timeFence, timeFenceDesc){
                  window.opener.document.$(docName).$(fldName).value = timeFence;
                  window.opener.document.$(docName).$(fldDesc).value = timeFenceDesc;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select HDMTFM.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(TFDESC) as TFDESCU " , stmtSQL)
                      @dtw_concat(fileSQL, " HDMTFM ", fileSQL)
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, " TFDEF='$(timeFence)'", selectSQL)
                      %elif (wildCardSearch!="")
                          @dtw_concat(selectSQL, " TFDEF<>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @TimeFence_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) TimeFence_Search (IN  CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a NAME="top"></a>
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr"> Description</th>
                      <th class="colhdr"> Time Fence</th>
                  </tr>
                  <tr><td class="inputalph">
                          <input type="text" name="srchDesc" size="20" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td class="inputalph">
                          <input type="text" name="srchTimeFence" size="5" maxlength="5">
                          <input type="hidden" name="operTimeFence" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>
	
          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("TFDEF", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TFDEF" title="Sequence By Time Fence"> Time Fence</a></th>
                  @OrderBy_Sort("TFDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TFDESC" title="Sequence By Description"> Description</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %else
          <table $(contentTable)>
      %endif		

          %ROW{

              @Format_Quote(V_TFDESC, F_TFDESC)

	       %if (moreInfo != "Y")	
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="colalph">$(V_TFDEF)</td>                                      	
                      <td class="colalph"><a href="javascript:selectTimeFence('$(V_TFDEF)','$(F_TFDESC)')" title="Select Time Fence">$(V_TFDESC)</a></td>
                      <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;timeFence=@dtw_rurlescseq(V_TFDEF)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                  </tr>

              %else
                  %{ More Information Page %}

                  <tr><td><a href="javascript:selectTimeFence('$(V_TFDEF)','$(F_TFDESC)')" title="Select Time Fence">$(selectImageLrg)</a></td></tr>

                  <tr><td class="dsphdr">Time Fence Definition</td>
                      <td class="dspalph">$(V_TFDEF)</td>
                  </tr>

                  <tr><td class="dsphdr">Description</td>
                      <td class="dspalph">$(V_TFDESC)</td></tr>
                  </table>

                  <fieldset class="legendBody">
                      <legend class="legendTitle">Demand Time Fence Definition</legend>
                      <table $(contentTable)>
                          <tr><td class="dsphdr">Number Of Days</td>
                              <td class="dspnmbr">$(V_TFDDAY)</td>
                          </tr>
        	   		
        		   @RtvFldDesc("FLTYPE='DEMANDPOL' and FLVALU='$(V_TFDDMP)'", "SYFLAG", "FLDESC", fieldDesc)
                          <tr><td class="dsphdr">Demand Policy</td>
                              <td class="dspalph">$(fieldDesc)</td>
                          </tr>
        	   	
        		   @RtvFldDesc("FLTYPE='ORDERACTN' and FLVALU='$(V_TFDORA)'", "SYFLAG", "FLDESC", fieldDesc)
                          <tr><td class="dsphdr">Order Action</td>
                              <td class="dspalph">$(fieldDesc)</td></tr>

        		   @RtvFldDesc("FLTYPE='DEMANDFSPR' and FLVALU='$(V_TFFSPR)'", "SYFLAG", "FLDESC", fieldDesc)
                          <tr><td class="dsphdr">Forecast Spreader</td>
                              <td class="dspalph">$(fieldDesc)</td></tr>
                      </table>
                  </fieldset>

                  <fieldset class="legendBody">
                      <legend class="legendTitle">Planning Time Fence Definition</legend>
                      <table $(contentTable)>
                          <tr><td class="dsphdr">Number Of Days</td>
                              <td class="dspnmbr">$(V_TFPDAY)</td>
                          </tr>
        	   		
        		   @RtvFldDesc("FLTYPE='DEMANDPOL' and FLVALU='$(V_TFPDMP)'", "SYFLAG", "FLDESC", fieldDesc)
                          <tr><td class="dsphdr">Demand Policy</td>
                              <td class="dspalph">$(fieldDesc)</td>
                          </tr>
        	   	
        		   @RtvFldDesc("FLTYPE='ORDERACTN' and FLVALU='$(V_TFPORA)'", "SYFLAG", "FLDESC", fieldDesc)
                          <tr><td class="dsphdr">Order Action</td>
                              <td class="dspalph">$(fieldDesc)</td></tr>
                      </table>
                  </fieldset>

                  <fieldset class="legendBody">
                      <legend class="legendTitle">Future</legend>
                      <table $(contentTable)>
        		   @RtvFldDesc("FLTYPE='DEMANDPOL' and FLVALU='$(V_TFFDMP)'", "SYFLAG", "FLDESC", fieldDesc)
                          <tr><td class="dsphdr">Demand Policy</td>
                              <td class="dspalph">$(fieldDesc)</td>
                          </tr>
        	   	
        		   @RtvFldDesc("FLTYPE='ORDERACTN' and FLVALU='$(V_TFFORA)'", "SYFLAG", "FLDESC", fieldDesc)
                          <tr><td class="dsphdr">Order Action</td>
                              <td class="dspalph">$(fieldDesc)</td></tr>
                      </table>
                  </fieldset>
              %endif
          %}
      %if (moreInfo != "Y")	
          </table>
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
      %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "TFDESCU,TFDEF")
      @DTW_ASSIGN(orderByDisplay, "Description, Time Fence")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(orderBy, "TFDEF")
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "TFDEF")
      %if (orderBy == "TFDEF")
          @DTW_ASSIGN(orderBy, "TFDEF DESC")
          @DTW_ASSIGN(orderByDisplay, "Time Fence (descending)")
      %else
          @DTW_ASSIGN(orderBy, "TFDEF")
          @DTW_ASSIGN(orderByDisplay, "Time Fence")
      %endif
  %elif (sequence == "TFDESC")
      %if (orderBy == "TFDESCU,TFDEF")
          @DTW_ASSIGN(orderBy, "TFDESCU DESC,TFDEF")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Time Fence")
      %else
          @DTW_ASSIGN(orderBy, "TFDESCU,TFDEF")
          @DTW_ASSIGN(orderByDisplay, "Description, Time Fence")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("TFDEF", "Time Fence", $(srchTimeFence), "U", operTimeFence, "A")
  @Build_WildCard ("upper(TFDESC)", "Description", $(srchDesc), "U", operDesc, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}