%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "Employee.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "QuickLink.icl"

%Define {
  page_title 	        = "Employee Check"
  d2wName              = "EmployeeCheckSelect.d2w"
  attachFolder         = "EmployeeCheck"
  d2wVarBase           = "$(genericVarBase)$(employeeVarBase)&amp;processingReference=@dtw_rurlescseq(processingReference)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName          = "HPRCHI"
  CHI_06               = ""
  CHI_07               = ""
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  RPT_MAX_ROWS         = "99"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext	        = "1"
  totalPages	        = "0"	
  quickLinkByUser      = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
  @dtw_replace(workURL, "@@processingReference", "@dtw_rurlescseq(processingReference)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @RtvFldDesc("EHPREF=$(processingReference)", "PRCKHS", "EHEMPL", chkEmpl)
  @dtw_assign(applicationID, "PR")
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N" || chkEmpl != prEmployee)
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "EMPLOYEECHECK")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">

%{ QuickLink Table %}     %INCLUDE "QuickLinkTable.icl"

%{ QuickLink By User %}   %INCLUDE "QuickLinkByUser.icl"

%{ Check Heading %}
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " PRCKHS ", fileSQL)
                          @dtw_concat(selectSQL, " EHPREF=$(processingReference)", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                          @Check_Select_Header(profileHandle, dataBaseID, stmtSQL)


%{ Quicklink Begin %}     %INCLUDE "QuickLinkBegLoop.icl"

    %{ grosstonet %}
                              %if (quicklinkRef == "grosstonet")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " PRCKHS ", fileSQL)
                                  @dtw_concat(selectSQL, " EHPREF=$(processingReference)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Check_Select_GrossToNet(profileHandle, dataBaseID, stmtSQL)
    %{ earningssummary %}
                              %elif (quicklinkRef == "earningssummary")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " PRCKHS ", fileSQL)
                                  @dtw_concat(selectSQL, " EHPREF=$(processingReference)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Check_Select_EarningsSummary(profileHandle, dataBaseID, stmtSQL)
    %{ directdeposits %}
                              %elif (quicklinkRef == "directdeposits")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " PRCKHS inner join PREACH on EHCOMP=ACCOMP and EHFACL=ACFACL and EHEMPL=ACEMPL ", fileSQL)
                                  @dtw_concat(selectSQL, " EHPREF=$(processingReference)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Check_Select_DirectDeposits(profileHandle, dataBaseID, stmtSQL)
    %{ employeetaxes %}
                              %elif (quicklinkRef == "employeetaxes")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " PRCKHS ", fileSQL)
                                  @dtw_concat(selectSQL, " EHPREF=$(processingReference)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Check_Select_EmployeeTaxes(profileHandle, dataBaseID, stmtSQL)

    %{ employertaxes %}
                              %elif (quicklinkRef == "employertaxes")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " PRCKHS ", fileSQL)
                                  @dtw_concat(selectSQL, " EHPREF=$(processingReference)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Check_Select_EmployerTaxes(profileHandle, dataBaseID, stmtSQL)

    %{ overridesaccruals %}
                              %elif (quicklinkRef == "overridesaccruals")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " PRCKHS ", fileSQL)
                                  @dtw_concat(selectSQL, " EHPREF=$(processingReference)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Check_Select_OverridesAccruals(profileHandle, dataBaseID, stmtSQL)

    %{ deductions %}
                              %elif (quicklinkRef == "deductions")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " PRCKHS inner join PRDEDH on EHPREF=VHREF ", fileSQL)
                                  @dtw_concat(fileSQL, "        inner join HRDEDM on VHDDNO=HVDDNO ", fileSQL)
                                  @dtw_concat(selectSQL, " EHPREF=$(processingReference)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Check_Select_Deductions(profileHandle, dataBaseID, stmtSQL)

    %{ paydetail %}
                              %elif (quicklinkRef == "paydetail")
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "Select PRDTHS.* ", stmtSQL)
                                  @dtw_concat(fileSQL, " HREMPL inner join PRDTHS on EMCOMP=SHCOMP and EMFACL=SHFACL and EMEMPL=SHEMPL ", fileSQL)
                                  @dtw_concat(selectSQL, " SHPREF=$(processingReference)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Check_Select_PayDetail(profileHandle, dataBaseID, stmtSQL)
                              %endif

     %{ Attachments %}        %INCLUDE "AttachmentSQL.icl"

%{ Quicklink End %}       %INCLUDE "QuickLinkEndLoop.icl"

                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Check_Select_Header (IN CHAR(64)    profileHandle,
				                CHAR(2)     dataBaseID,
                                               CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMTYPE", PAYTYPECODE)
      %if ((sec_06 == "N" && PAYTYPECODE == "H") || (sec_07 == "N" && PAYTYPECODE != "H"))
          %INCLUDE "ProgSecurityError.icl"
      %else
          @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
      %endif

      %ROW {
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1> $(page_title)</h1></td>
                  @dtw_assign(attachVarKey, $(V_EHPREF))
                  @dtw_assign(attachForDesc, "$(F_EmpName) Check Number $(V_EHCKNO)")
                  %while(@dtw_rlength(attachVarKey) != "11") {@dtw_insert("0", attachVarKey, attachVarKey)%}
                  @dtw_assign(attachPrg1, "PRCKHS Where EHPREF=$(processingReference)")
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="BackHome">$(portalHome)</a>
                          %endif
                          %INCLUDE "Attachment.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>

              <tr><td><h2>$(F_EmpName)</h2></td></tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"

          $(hrTagAttr)

          <table $(contentTable)>
              <tr><td class="dsphdr">Check Number</td>
                  %if(V_EHCKNO == "0"  && V_EHRCCD == "H")
                      <td class="dspalph">Direct Deposit</td>
                  %else
                      <td class="dspalph">$(V_EHCKNO)</td>
                  %endif
              </tr>
              @Format_Date(V_EHCKDT, "H", F_EHCKDT)
              <tr><td class="dsphdr">Check Date</td>
                  <td class="dspalph">$(F_EHCKDT)</td>
              </tr>
              @Format_Date(V_EHPPDT, "H", F_EHPPDT)
              <tr><td class="dsphdr">Pay Period End Date</td>
                  <td class="dspalph">$(F_EHPPDT)</td>
              </tr>
              %if (V_EHRCCD == "H")
                  @dtw_assign(checkType, "Regular")
              %elif (V_EHRCCD == "V")
                  @dtw_assign(checkType, "Void")
              %elif (V_EHRCCD == "M")
                  @dtw_assign(checkType, "Manual/History Adjustment")
              %elif (V_EHRCCD == "4")
                  @dtw_assign(checkType, "Non Elective Contriubution")
              %endif
              <tr><td class="dsphdr">Check Type</td>
                  <td class="dspalph">$(checkType)</td>
              </tr>
          </table>
          $(hrTagAttr)
          %INCLUDE "QuickLinkDisplay.icl"
      %}
  %}
%}

%FUNCTION(dtw_sql) Check_Select_GrossToNet (IN  CHAR(64)    profileHandle,
				                 CHAR(2)     dataBaseID,
                                                CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="grosstonet"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %ROW{
              <tr><td class="dsphdr">Gross Pay</td>
                  @Format_Nbr($(V_EHRSP), F_EHRSP, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_EHRSP)</td>
              </tr>

              <tr><td class="dsphdr">Employee Taxes </td>
                  @Format_Nbr(@dtw_radd(V_EHEFIT, @dtw_radd(V_EHEFCT, @dtw_radd(V_EHESIT, @dtw_radd(V_EHESDI, @dtw_radd(V_EHESWC, @dtw_radd(V_EHESUI, @dtw_radd(V_EHESUS, @dtw_radd(V_EHELT1, V_EHELT2)))))))), F_EHELT2, "2", $(amtEditCode), "", "", "")
                  <td class="colnmbr">$(F_EHELT2)</td>
              </tr>

              @RetTotDed(profileHandle, dataBaseID, V_EHPREF, totDed)
              @Format_Nbr($(totDed), F_TotDed, "2", $(amtEditCode), "", "", "")
              <tr><td class="dsphdr">Voluntary Deductions </td>
                  <td class="colnmbr">$(F_TotDed)</td>
              </tr>

              %if (V_EHFRIN != ".00")
                  @Format_Nbr($(V_EHFRIN), F_EHFRIN, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Fringe Benefits </td>
                      <td class="colnmbr">$(F_EHFRIN)</td>
                  </tr>
              %endif

              %if (V_EHEEIC != ".00")
                  @Format_Nbr($(V_EHEEIC), F_EHEEIC, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Earned Income Credit</td>
                      <td class="colnmbr">$(F_EHEEIC)</td>
                  </tr>
              %endif

              %if (V_EHNONE != ".00")
                  @Format_Nbr($(V_EHNONE), F_EHNONE, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Nontaxable </td>
                      <td class="colnmbr">$(F_EHNONE)</td>
                  </tr>
              %endif

              %if (V_EHCSTP != ".00")
                  @Format_Nbr($(V_EHCSTP), F_EHCSTP, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Cash Tips </td>
                      <td class="colnmbr">$(F_EHCSTP)</td>
                  </tr>
              %endif

              %if (V_EHMEAL != ".00")
                  @Format_Nbr($(V_EHMEAL), F_EHMEAL, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Meal Allowance</td>
                      <td class="colnmbr">$(F_EHMEAL)</td>
                  </tr>
              %endif

              @Format_Nbr($(V_EHNETP), F_EHNETP, "2", $(amtEditCode), "", "", "")
              <tr><td class="dsphdr">Net Pay</td>
                  <td class="colnmbr">$(F_EHNETP)</td>
              </tr>
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Check_Select_DirectDeposits (IN  CHAR(64)    profileHandle,
				                     CHAR(2)     dataBaseID,
                                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="directdeposits"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          @dtw_assign(totalDirectDeposit, "0")

          %ROW{
              %if (V_EHDD01 == ".00" && V_EHDD02 == ".00" && V_EHDD03 == ".00" && V_EHDD04 == ".00" && V_EHDD05 == ".00" && V_EHDD06 == ".00" && V_EHDD07 == ".00")
                  %INCLUDE "QuickLinkNoInfoMsg.icl"
              %else
                  <tr><td class="colhdr">Account</td>
                      <td class="colhdr">Type</td>
                      <td class="colhdr">Deposit Amount</td>
                  </tr>

                  %if (V_EHDD01 != ".00")
    		       @dtw_add($(V_EHDD01), totalDirectDeposit, totalDirectDeposit)
                      @Format_Nbr($(V_EHDD01), F_EHDD01, "2", $(amtEditCode), "", "", "")
                      <tr><td class="colalph">$(V_ACACT1)</td>
                          %if (V_ACTYP1 == "C")
                              @dtw_assign(accountType1, "Checking")
                          %else
                              @dtw_assign(accountType1, "Savings")

                          %endif
                          <td class="colalph">$(accountType1)</td>
                          <td class="colnmbr">$(F_EHDD01)</td>
                      </tr>
                  %endif

                  %if (V_EHDD02 != ".00")
    		       @dtw_add($(V_EHDD02), totalDirectDeposit, totalDirectDeposit)
                      @Format_Nbr($(V_EHDD02), F_EHDD02, "2", $(amtEditCode), "", "", "")
                      <tr><td class="colalph">$(V_ACACT2)</td>
                          %if (V_ACTYP2 == "C")
                              @dtw_assign(accountType2, "Checking")
                          %else
                              @dtw_assign(accountType2, "Savings")
                          %endif
                          <td class="colalph">$(accountType2)</td>
                          <td class="colnmbr">$(F_EHDD02)</td>
                      </tr>
                  %endif

                  %if (V_EHDD03 != ".00")
    		       @dtw_add($(V_EHDD03), totalDirectDeposit, totalDirectDeposit)
                      @Format_Nbr($(V_EHDD03), F_EHDD03, "2", $(amtEditCode), "", "", "")
                      <tr><td class="colalph">$(V_ACACT3)</td>
                          %if (V_ACTYP3 == "C")
                              @dtw_assign(accountType3, "Checking")
                          %else
                              @dtw_assign(accountType3, "Savings")
                          %endif
                          <td class="colalph">$(accountType3)</td>
                          <td class="colnmbr">$(F_EHDD03)</td>
                      </tr>
                  %endif

                  %if (V_EHDD04 != ".00")
    		       @dtw_add($(V_EHDD04), totalDirectDeposit, totalDirectDeposit)
                      @Format_Nbr($(V_EHDD04), F_EHDD04, "2", $(amtEditCode), "", "", "")
                      <tr><td class="colalph">$(V_ACACT4)</td>
                          %if (V_ACTYP4 == "C")
                              @dtw_assign(accountType4, "Checking")
                          %else
                              @dtw_assign(accountType4, "Savings")
                          %endif
                          <td class="colalph">$(accountType4)</td>
                          <td class="colnmbr">$(F_EHDD04)</td>
                      </tr>
                  %endif

                  %if (V_EHDD05 != ".00")
    		       @dtw_add($(V_EHDD05), totalDirectDeposit, totalDirectDeposit)
                      @Format_Nbr($(V_EHDD05), F_EHDD05, "2", $(amtEditCode), "", "", "")
                      <tr><td class="colalph">$(V_ACACT5)</td>
                          %if (V_ACTYP5 == "C")
                              @dtw_assign(accountType5, "Checking")
                          %else
                              @dtw_assign(accountType5, "Savings")
                          %endif
                          <td class="colalph">$(accountType5)</td>
                          <td class="colnmbr">$(F_EHDD05)</td>
                      </tr>
                  %endif


                  %if (V_EHDD06 != ".00")
    		       @dtw_add($(V_EHDD06), totalDirectDeposit, totalDirectDeposit)
                      @Format_Nbr($(V_EHDD06), F_EHDD06, "2", $(amtEditCode), "", "", "")
                      <tr><td class="colalph">$(V_ACACT6)</td>
                          %if (V_ACTYP6 == "C")
                              @dtw_assign(accountType6, "Checking")
                          %else
                              @dtw_assign(accountType6, "Savings")
                          %endif
                          <td class="colalph">$(accountType6)</td>
                          <td class="colnmbr">$(F_EHDD06)</td>
                      </tr>
                  %endif

                  %if (V_EHDD07 != ".00")
    		       @dtw_add($(V_EHDD07), totalDirectDeposit, totalDirectDeposit)
                      @Format_Nbr($(V_EHDD07), F_EHDD07, "2", $(amtEditCode), "", "", "")
                      <tr><td class="colalph">$(V_ACACT7)</td>
                          %if (V_ACTYP7 == "C")
                              @dtw_assign(accountType7, "Checking")
                          %else
                              @dtw_assign(accountType7, "Savings")
                          %endif
                          <td class="colalph">$(accountType7)</td>
                          <td class="colnmbr">$(F_EHDD07)</td>
                      </tr>
                  %endif


                  <tr><td class="colnmbr" colspan="2">Total</td>
                      @Format_Nbr($(totalDirectDeposit), F_totalDirectDeposit, "2", $(amtEditCode), "", "", "")
                      <td class="coltotal">$(F_totalDirectDeposit)</td>
                  </tr>
              %endif
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Check_Select_EarningsSummary (IN  CHAR(64)    profileHandle,
				                      CHAR(2)     dataBaseID,
                                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="earningssummary"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %ROW{
              <tr><td class="colhdr">Description</td>
                  <td class="colhdr">Hours</td>
                  <td class="colhdr">Units</td>
                  <td class="colhdr">Earnings</td>
              </tr>
              @dtw_assign(workedHours, "0")
              @dtw_assign(notWorked, "0")
              @dtw_assign(totalUnits, "0")
              @dtw_assign(totalEarnings, "0")
              @dtw_assign(holdHours, "0")

              %if (V_EHREGH != ".00" || V_EHREGE != ".00")
                  <tr><td class="dsphdr">Regular</td>
                      @dtw_assign(earnType, "R")
                      @RetHoursUnits(profileHandle, dataBaseID, V_EHPREF, earnType, regHours, regUnits, wrkHours)
    		           @dtw_add(wrkHours, workedHours, workedHours)
    	   	       %if(wrkHours != V_EHREGH)
    	   		   @dtw_subtract(regHours, wrkHours, holdHours)
    		           @dtw_add(holdHours, notWorked, notWorked)
    	   	       %endif
    	   	       @dtw_add(regUnits, totalUnits, totalUnits)
    	   	       @dtw_add($(V_EHREGE), totalEarnings, totalEarnings)
    	   	       %if(regUnits == ".00")
    		           @dtw_assign(regUnits, "")
    	   	       %endif
                      @Format_Nbr($(regHours), F_regHours, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_regHours)</td>
    	           %if(regUnits == "")
                         <td class="colnmbr">$(regUnits)</td>
                      %else
                         @Format_Nbr($(regUnits), F_regUnits, "2", $(hrsEditCode), "", "", "")
                         <td class="colnmbr">$(F_regUnits)</td>
                      %endif
                      @Format_Nbr($(V_EHREGE), F_EHREGE, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_EHREGE)</td>
                  </tr>
              %endif
              %if (V_EHOVTH != ".00" || V_EHOVTE != ".00")
                  <tr><td class="dsphdr">Overtime</td>
                      @dtw_assign(earnType, "O")
                      @RetHoursUnits(profileHandle, dataBaseID, V_EHPREF, earnType, ovtHours, ovtUnits, wrkHours)
    		       @dtw_add(wrkHours, workedHours, workedHours)
    	   	       %if(wrkHours != V_EHOVTH)
    	   		   @dtw_subtract(ovtHours, wrkHours, holdHours)
    		           @dtw_add(holdHours, notWorked, notWorked)
    	   	       %endif
    	   	       @dtw_add(ovtUnits, totalUnits, totalUnits)
    	   	       @dtw_add(V_EHOVTE, totalEarnings, totalEarnings)
    	   	       %if(ovtUnits == ".00")
    		           @dtw_assign(ovtUnits, "")
    	   	       %endif
                      @Format_Nbr($(ovtHours), F_ovtHours, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_ovtHours)</td>
    	           %if(ovtUnits == "")
                         <td class="colnmbr">$(ovtUnits)</td>
                      %else
                         @Format_Nbr($(ovtUnits), F_ovtUnits, "2", $(hrsEditCode), "", "", "")
                         <td class="colnmbr">$(F_ovtUnits)</td>
                      %endif
                      @Format_Nbr($(V_EHOVTE), F_EHOVTE, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_EHOVTE)</td>
                  </tr>
              %endif
              %if (V_EHDBLH != ".00" || V_EHDBLE != ".00")
                  <tr><td class="dsphdr">Double Time</td>
                      @dtw_assign(earnType, "D")
                      @RetHoursUnits(profileHandle, dataBaseID, V_EHPREF, earnType, dblHours, dblUnits, wrkHours)
                      @dtw_add(wrkHours, workedHours, workedHours)
    	   	       %if(wrkHours != V_EHDBLH)
    	   		   @dtw_subtract(dblHours, wrkHours, holdHours)
    		           @dtw_add(holdHours, notWorked, notWorked)
    	   	       %endif
    	   	       @dtw_add(dblUnits, totalUnits, totalUnits)
    	   	       @dtw_add(V_EHDBLE, totalEarnings, totalEarnings)
    	   	       %if(dblUnits == ".00")
    		           @dtw_assign(dblUnits, "")
    	   	       %endif
                      @Format_Nbr($(dblHours), F_dblHours, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_dblHours)</td>
    	           %if(dblUnits == "")
                         <td class="colnmbr">$(dblUnits)</td>
                      %else
                         @Format_Nbr($(dblUnits), F_dblUnits, "2", $(hrsEditCode), "", "", "")
                         <td class="colnmbr">$(F_dblUnits)</td>
                      %endif
                      @Format_Nbr($(V_EHDBLE), F_EHDBLE, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_EHDBLE)</td>
                  </tr>
              %endif
              %if (V_EHVACH != ".00" || V_EHVACE != ".00")
                  <tr><td class="dsphdr">Vacation</td>
                      @dtw_assign(earnType, "V")
                      @RetHoursUnits(profileHandle, dataBaseID, V_EHPREF, earnType, vacHours, vacUnits, wrkHours)
    		       @dtw_add(wrkHours, workedHours, workedHours)
    	   	       %if(wrkHours != V_EHVACH)
    	   		   @dtw_subtract(vacHours, wrkHours, holdHours)
    		           @dtw_add(holdHours, notWorked, notWorked)
    	   	       %endif
    	   	       @dtw_add(vacUnits, totalUnits, totalUnits)
    	   	       @dtw_add(V_EHVACE, totalEarnings, totalEarnings)
    	   	       %if(vacUnits == ".00")
    		           @dtw_assign(vacUnits, "")
    	   	       %endif
                      @Format_Nbr($(vacHours), F_vacHours, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_vacHours)</td>
    	           %if(vacUnits == "")
                         <td class="colnmbr">$(vacUnits)</td>
                      %else
                         @Format_Nbr($(vacUnits), F_vacUnits, "2", $(hrsEditCode), "", "", "")
                         <td class="colnmbr">$(F_vacUnits)</td>
                      %endif
                      @Format_Nbr($(V_EHVACE), F_EHVACE, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_EHVACE)</td>
                  </tr>
              %endif
              %if (V_EHHOLH != ".00" || V_EHHOLE != ".00")
                  <tr><td class="dsphdr">Holiday</td>
                      @dtw_assign(earnType, "H")
                      @RetHoursUnits(profileHandle, dataBaseID, V_EHPREF, earnType, holHours, holUnits, wrkHours)
    		       @dtw_add(wrkHours, workedHours, workedHours)
    	   	       %if(wrkHours != V_EHHOLH)
    	   		   @dtw_subtract(holHours, wrkHours, holdHours)
    		           @dtw_add(holdHours, notWorked, notWorked)
    	   	       %endif
    	   	       @dtw_add(holUnits, totalUnits, totalUnits)
    	   	       @dtw_add(V_EHHOLE, totalEarnings, totalEarnings)
    	   	       %if(holUnits == ".00")
    		           @dtw_assign(holUnits, "")
    	   	       %endif
                      @Format_Nbr($(holHours), F_holHours, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_holHours)</td>
    	           %if(holUnits == "")
                         <td class="colnmbr">$(holUnits)</td>
                      %else
                         @Format_Nbr($(holUnits), F_holUnits, "2", $(hrsEditCode), "", "", "")
                         <td class="colnmbr">$(F_holUnits)</td>
                      %endif
                      @Format_Nbr($(V_EHHOLE), F_EHHOLE, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_EHHOLE)</td>
                  </tr>
              %endif
              %if (V_EHSICH != ".00" || V_EHSCKE != ".00")
                  <tr><td class="dsphdr">Sick</td>
                      @dtw_assign(earnType, "S")
                      @RetHoursUnits(profileHandle, dataBaseID, V_EHPREF, earnType, sicHours, sicUnits, wrkHours)
    		       @dtw_add(wrkHours, workedHours, workedHours)
    	   	       %if(wrkHours != V_EHSICH)
    	                   @dtw_subtract(sicHours, wrkHours, holdHours)
    		           @dtw_add(holdHours, notWorked, notWorked)
    	   	       %endif
    	   	       @dtw_add(sicUnits, totalUnits, totalUnits)
    	   	       @dtw_add(V_EHSCKE, totalEarnings, totalEarnings)
    	   	       %if(sicUnits == ".00")
    		           @dtw_assign(sicUnits, "")
    	   	       %endif
                      @Format_Nbr($(sicHours), F_sicHours, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_sicHours)</td>
    	           %if(sicUnits == "")
                         <td class="colnmbr">$(sicUnits)</td>
                      %else
                         @Format_Nbr($(sicUnits), F_sicUnits, "2", $(hrsEditCode), "", "", "")
                         <td class="colnmbr">$(F_sicUnits)</td>
                      %endif
                      @Format_Nbr($(V_EHSCKE), F_EHSCKE, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_EHSCKE)</td>
                  </tr>
              %endif
              %if (V_EHOTHH != ".00" || V_EHOTHE != ".00")
                  <tr><td class="dsphdr">Other Taxable</td>
                      @dtw_assign(earnType, "T")
                      @RetHoursUnits(profileHandle, dataBaseID, V_EHPREF, earnType, othHours, othUnits, wrkHours)
    		       @dtw_add(wrkHours, workedHours, workedHours)
    	   	       %if(wrkHours != V_EHOTHH)
    	   		   @dtw_subtract(othHours, wrkHours, holdHours)
    		           @dtw_add(holdHours, notWorked, notWorked)
    	   	       %endif
    	   	       @dtw_add(othUnits, totalUnits, totalUnits)
    	   	       @dtw_add(V_EHOTHE, totalEarnings, totalEarnings)
    	   	       %if(othUnits == ".00")
    		           @dtw_assign(othUnits, "")
    	   	       %endif
                      @Format_Nbr($(othHours), F_othHours, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr">$(F_othHours)</td>
    	           %if(othUnits == "")
                         <td class="colnmbr">$(othUnits)</td>
                      %else
                         @Format_Nbr($(othUnits), F_othUnits, "2", $(hrsEditCode), "", "", "")
                         <td class="colnmbr">$(F_othUnits)</td>
                      %endif
                      @Format_Nbr($(V_EHOTHE), F_EHOTHE, "2", $(amtEditCode), "", "", "")
                      <td class="colnmbr">$(F_EHOTHE)</td>
                  </tr>
              %endif
              %if (V_EHNONE != ".00")
                  @Format_Nbr($(V_EHNONE), F_EHNONE, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Nontaxable</td>
    	   	       @dtw_add(V_EHNONE, totalEarnings, totalEarnings)
                      <td class="colnmbr"></td>
                      <td class="colnmbr"></td>
                      <td class="colnmbr">$(F_EHNONE)</td>
                  </tr>
              %endif
              %if (V_EHFRIN != ".00")
                  @Format_Nbr($(V_EHFRIN), F_EHFRIN, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Fringe Benefits</td>
    	   	       @dtw_add(V_EHFRIN, totalEarnings, totalEarnings)
                      <td class="colnmbr"></td>
                      <td class="colnmbr"></td>
                      <td class="colnmbr">$(F_EHFRIN)</td>
                  </tr>
              %endif
              %if (V_EHCOME != ".00")
                  @Format_Nbr($(V_EHCOME), F_EHCOME, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Commission</td>
    	   	       @dtw_add(V_EHCOME, totalEarnings, totalEarnings)
                      <td class="colnmbr"></td>
                      <td class="colnmbr"></td>
                      <td class="colnmbr">$(F_EHCOME)</td>
                  </tr>
              %endif
              %if (V_EHBNSE != ".00")
                  @Format_Nbr($(V_EHBNSE), F_EHBNSE, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Bonus</td>
    	   	       @dtw_add(V_EHBNSE, totalEarnings, totalEarnings)
                      <td class="colnmbr"></td>
                      <td class="colnmbr"></td>
                      <td class="colnmbr">$(F_EHBNSE)</td>
                  </tr>
              %endif
              %if (V_EHCSTP != ".00")
                  @Format_Nbr($(V_EHCSTP), F_EHCSTP, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Cash Tips</td>
    	   	       @dtw_add(V_EHCSTP, totalEarnings, totalEarnings)
                      <td class="colnmbr"></td>
                      <td class="colnmbr"></td>
                      <td class="colnmbr">$(F_EHCSTP)</td>
                  </tr>
              %endif
              %if (V_EHCHTP != ".00")
                  @Format_Nbr($(V_EHCHTP), F_EHCHTP, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Charge Tips</td>
    	   	       @dtw_add(V_EHCHTP, totalEarnings, totalEarnings)
                      <td class="colnmbr"></td>
                      <td class="colnmbr"></td>
                      <td class="colnmbr">$(F_EHCHTP)</td>
                  </tr>
              %endif
              %if (V_EHGRTP != ".00")
                  @Format_Nbr($(V_EHGRTP), F_EHGRTP, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Gross Reciepts</td>
                      <td class="colnmbr"></td>
                      <td class="colnmbr"></td>
                      <td class="colnmbr">$(F_EHGRTP)</td>
                  </tr>
              %endif
              %if (V_EHMEAL != ".00")
                  @Format_Nbr($(V_EHMEAL), F_EHMEAL, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Meal Allowance</td>
    	   	       @dtw_add(V_EHMEAL, totalEarnings, totalEarnings)
                      <td class="colnmbr"></td>
                      <td class="colnmbr"></td>
                      <td class="colnmbr">$(F_EHMEAL)</td>
                  </tr>
              %endif
	       %if(totalUnits == "0")
    	           @dtw_assign(totalUnits, "")
    	       %endif
              <tr><td class="colalph">Total Worked</td>
                  @Format_Nbr($(workedHours), F_workedHours, "2", $(hrsEditCode), "", "", "")
                  <td class="coltotal">$(F_workedHours)</td>
    	           %if(totalUnits == "")
                      <td class="coltotal">$(totalUnits)</td>
                  %else
                      @Format_Nbr($(totalUnits), F_totalUnits, "2", $(hrsEditCode), "", "", "")
                      <td class="coltotal">$(F_totalUnits)</td>
                  %endif
                  @Format_Nbr($(totalEarnings), F_totalEarnings, "2", $(amtEditCode), "", "", "")
                  <td class="coltotal">$(F_totalEarnings)</td>
              </tr>
              %if (notWorked != "0")
                  @Format_Nbr($(notWorked), F_notWorked, "2", $(hrsEditCode), "", "", "")
                  <tr><td class="colalph">Total Not Worked</td>
                      <td class="colnmbr">$(F_notWorked)</td>
                      <td class="colnmbr"></td>
                      <td class="colnmbr"></td>
                  </tr>
              %endif
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Check_Select_EmployeeTaxes (IN  CHAR(64)    profileHandle,
				                    CHAR(2)     dataBaseID,
                                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="employeetaxes"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %ROW{
              <tr><th class="colhdr"> Tax Type</th>
                  <th class="colhdr"> Tax ID</th>
                  <th class="colhdr"> Employee Tax</th>
              </tr>	

              @Format_Nbr($(V_EHEFIT), F_EHEFIT, "2", $(amtEditCode), "", "", "")
              <tr class="$(rowClass)">
                  <td class="dsphdr"> Federal Tax</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr"> $(F_EHEFIT)</td>
              </tr>

              @Format_Nbr($(V_EHEHI), F_EHEHI, "2", $(amtEditCode), "", "", "")
              <tr class="$(rowClass)">
                  <td class="dsphdr"> FICA HI Tax</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr"> $(F_EHEHI)</td>
              </tr>

              @Format_Nbr($(V_EHEOA), F_EHEOA, "2", $(amtEditCode), "", "", "")
              <tr class="$(rowClass)">
                  <td class="dsphdr"> FICA OASDI Tax</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr"> $(F_EHEOA)</td>
              </tr>

              @dtw_assign(totalEmployeeFica, "0")
              @dtw_add(V_EHEHI, V_EHEOA, totalEmployeeFica)

              @Format_Nbr($(totalEmployeeFica), F_totalEmployeeFica, "2", $(amtEditCode), "", "", "")
              <tr class="$(rowClass)">
                  <td class="colnmbr" colspan="2">Total FICA Tax</td>
                  <td class="coltotal"> $(F_totalEmployeeFica)</td>
              </tr>

              %if ($(V_EHEEIC) != ".00")
                  @Format_Nbr($(V_EHEEIC), F_EHEEIC, "2", $(amtEditCode), "", "", "")
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> EIC</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr"> $(F_EHEEIC)</td>
                  </tr>
              %endif

              %if ($(V_EHESIT) != ".00")
                  @Format_Nbr($(V_EHESIT), F_EHESIT, "2", $(amtEditCode), "", "", "")
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> State Tax</td>
                      <td class="colcode"> $(V_EHSTID)</td>
                      <td class="colnmbr"> $(F_EHESIT)</td>
                  </tr>
              %endif

              %if ($(V_EHESUI) != ".00")
                  @Format_Nbr($(V_EHESUI), F_EHESUI, "2", $(amtEditCode), "", "", "")
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> State Unemployment</td>
                      <td class="colcode"> $(V_ESURPS)</td>
                      <td class="colnmbr"> $(F_EHESUI)</td>
                  </tr>
              %endif

              %if ($(V_EHESUS) != ".00")
                  @Format_Nbr($(V_EHESUS), F_EHESUS, "2", $(amtEditCode), "", "", "")
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> State Unemployment Surtax</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr"> $(F_EHESUS)</td>
                  </tr>
              %endif

              %if ($(V_EHESDI)  != ".00")
                  @Format_Nbr($(V_EHESDI), F_EHESDI, "2", $(amtEditCode), "", "", "")
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> SDI Tax</td>
                      <td class="colcode"> $(V_EHSDID)</td>
                      <td class="colnmbr"> $(F_EHESDI)</td>
                  </tr>
              %endif

              %if ($(V_EHESWC) != ".00")
                  @Format_Nbr($(V_EHESWC), F_EHESWC, "2", $(amtEditCode), "", "", "")
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> SWC Tax</td>
                      <td class="colcode"> $(V_EHSWID)</td>
                      <td class="colnmbr"> $(F_EHESWC)</td>
                  </tr>
              %endif

              %if ($(V_EHELT1) != ".00")
                  @Format_Nbr($(V_EHELT1), F_EHELT1, "2", $(amtEditCode), "", "", "")
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> Local Tax 1</td>
                      <td class="colcode"> $(V_EHLOC1)</td>
                      <td class="colnmbr"> $(F_EHELT1)</td>
                  </tr>
              %endif

              %if ($(V_EHELT2) != ".00")
                  @Format_Nbr($(V_EHELT2), F_EHELT2, "2", $(amtEditCode), "", "", "")
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> Local Tax 2</td>
                      <td class="colcode"> $(V_EHLOC2)</td>
                      <td class="colnmbr"> $(F_EHELT2)</td>
                  </tr>
              %endif

              @dtw_assign(totalEmplTax, "0")
              @dtw_add(V_EHEFIT, totalEmplTax, totalEmplTax)
              @dtw_add(V_EHEHI, totalEmplTax, totalEmplTax)
              @dtw_add(V_EHEOA, totalEmplTax, totalEmplTax)
              @dtw_add(V_EHEEIC, totalEmplTax, totalEmplTax)
              @dtw_add(V_EHESIT, totalEmplTax, totalEmplTax)
              @dtw_add(V_EHESUI, totalEmplTax, totalEmplTax)
              @dtw_add(V_EHESUS, totalEmplTax, totalEmplTax)
              @dtw_add(V_EHESDI, totalEmplTax, totalEmplTax)
              @dtw_add(V_EHESWC, totalEmplTax, totalEmplTax)
              @dtw_add(V_EHELT1, totalEmplTax, totalEmplTax)
              @dtw_add(V_EHELT2, totalEmplTax, totalEmplTax)

              <tr class="$(rowClass)">
                  <td class="colnmbr" colspan="2">Total Taxes</td>
                  @Format_Nbr($(totalEmplTax), F_totalEmplTax, "2", $(hrsEditCode), "", "", "")
                  <td class="coltotal"> $(F_totalEmplTax)</td>
              </tr>

          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Check_Select_EmployerTaxes (IN  CHAR(64)    profileHandle,
				                    CHAR(2)     dataBaseID,
                                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="employertaxes"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %ROW{
              <tr><th class="colhdr"> Tax Type</th>
                  <th class="colhdr"> Tax ID</th>
                  <th class="colhdr"> Employee Tax</th>
                  <th class="colhdr"> Employer Tax</th>
                  <th class="colhdr"> Taxable Wages</th>
                  <th class="colhdr"> Exempt Wages</th>	
                  <th class="colhdr"> Deferred Wages</th>
              </tr>	

              @Format_Nbr($(V_EHEFIT), F_EHEFIT, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_EHTFIT), F_EHTFIT, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_EHXFIT), F_EHXFIT, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_EHDFIT), F_EHDFIT, "2", $(amtEditCode), "", "", "")
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr"> Federal Tax</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr"> $(F_EHEFIT)</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr"> $(F_EHTFIT)</td>
                  <td class="colnmbr"> $(F_EHXFIT)</td>
                  <td class="colnmbr"> $(F_EHDFIT)</td>
              </tr>

              @Format_Nbr($(V_EHEHI), F_EHEHI, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_EHRHI), F_EHRHI, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_EHCHIB), F_EHCHIB, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_EHXFIC), F_EHXFIC, "2", $(amtEditCode), "", "", "")
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr"> FICA HI Tax</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr"> $(F_EHEHI)</td>
                  <td class="colnmbr"> $(F_EHRHI)</td>
                  <td class="colnmbr"> $(F_EHCHIB)</td>
                  <td class="colnmbr"> $(F_EHXFIC)</td>
                  <td class="colnmbr">&nbsp;</td>
              </tr>

              @Format_Nbr($(V_EHEOA), F_EHEOA, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_EHROA), F_EHROA, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_EHTOAS), F_EHTOAS, "2", $(amtEditCode), "", "", "")
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr"> FICA OASDI Tax</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr"> $(F_EHEOA)</td>
                  <td class="colnmbr"> $(F_EHROA)</td>
                  <td class="colnmbr"> $(F_EHTOAS)</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr">&nbsp;</td>
              </tr>

              @dtw_assign(totalEmployeeFica, "0")
              @dtw_add(V_EHEHI, V_EHEOA, totalEmployeeFica)
              @dtw_assign(totalEmployerFica, "0")
              @dtw_add(V_EHRHI, V_EHROA, totalEmployerFica)

              @Format_Nbr($(totalEmployeeFica), F_totalEmployeeFica, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(totalEmployerFica), F_totalEmployerFica, "2", $(amtEditCode), "", "", "")
              %INCLUDE "SetRowClass.icl"
              <tr>
                  <td class="colnmbr" colspan="2">Total FICA Tax</td>
                  <td class="coltotal"> $(F_totalEmployeeFica)</td>
                  <td class="coltotal"> $(F_totalEmployerFica)</td>
              </tr>

              %if (($(V_EHRFUI) != ".00")  || ($(V_EHTFUI) != ".00") || ($(V_EHXFUT) != ".00"))
                  @Format_Nbr($(V_EHRFUI), F_EHRFUI, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHTFUI), F_EHTFUI, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHXFUT), F_EHXFUT, "2", $(amtEditCode), "", "", "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> FUI Tax</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr"> $(F_EHRFUI)</td>
                      <td class="colnmbr"> $(F_EHTFUI)</td>
                      <td class="colnmbr"> $(F_EHXFUT)</td>
                      <td class="colnmbr">&nbsp;</td>
                  </tr>
              %endif

              %if ($(V_EHEEIC) != ".00")
                  @Format_Nbr($(V_EHEEIC), F_EHEEIC, "2", $(amtEditCode), "", "", "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> EIC</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr"> $(F_EHEEIC)</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                  </tr>
              %endif

              %if (($(V_EHTSIT) != ".00") || ($(V_EHXSIT) != ".00") || ($(V_EHDSIT) != ".00") || ($(V_EHESIT) != ".00"))
                  @Format_Nbr($(V_EHESIT), F_EHESIT, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHTSIT), F_EHTSIT, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHXSIT), F_EHXSIT, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHDSIT), F_EHDSIT, "2", $(amtEditCode), "", "", "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> State Tax</td>
                      <td class="colcode"> $(V_EHSTID)</td>
                      <td class="colnmbr"> $(F_EHESIT)</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr"> $(F_EHTSIT)</td>
                      <td class="colnmbr"> $(F_EHXSIT)</td>
                      <td class="colnmbr"> $(F_EHDSIT)</td>
                  </tr>
              %endif

              @Format_Nbr($(V_EHTSUI), F_EHTSUI, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_EHXSUT), F_EHXSUT, "2", $(amtEditCode), "", "", "")
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr"> Total SUI Wages</td>
                  <td class="colcode"> $(V_ESURPS)</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr"> $(F_EHTSUI)</td>
                  <td class="colnmbr"> $(F_EHXSUT)</td>
                  <td class="colnmbr">&nbsp;</td>
              </tr>

              %if (($(V_EHESUI) != ".00") || ($(V_EHCESB) != ".00"))
                  @Format_Nbr($(V_EHESUI), F_EHESUI, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHCESB), F_EHCESB, "2", $(amtEditCode), "", "", "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> Employee SUI Tax</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr"> $(F_EHESUI)</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr"> $(F_EHCESB)</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                  </tr>
              %endif

              @Format_Nbr($(V_EHRSUI), F_EHRSUI, "2", $(amtEditCode), "", "", "")
              @Format_Nbr($(V_EHCRSB), F_EHCRSB, "2", $(amtEditCode), "", "", "")
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr"> Employer SUI Tax</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr"> $(F_EHRSUI)</td>
                  <td class="colnmbr"> $(F_EHCRSB)</td>
                  <td class="colnmbr">&nbsp;</td>
                  <td class="colnmbr">&nbsp;</td>
              </tr>

              %if (($(V_EHESUS) != ".00") || ($(V_EHESSW) != ".00"))
                  @Format_Nbr($(V_EHESUS), F_EHESUS, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHESSW), F_EHESSW, "2", $(amtEditCode), "", "", "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> Employee SUI Surtax</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr"> $(F_EHESUS)</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr"> $(F_EHESSW)</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                  </tr>
              %endif

              %if (($(V_EHRSUS) != ".00") || ($(V_EHRSSW) != ".00"))
                  @Format_Nbr($(V_EHRSUS), F_EHRSUS, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHRSSW), F_EHRSSW, "2", $(amtEditCode), "", "", "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> Employer SUI Surtax</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr"> $(F_EHRSUS)</td>
                      <td class="colnmbr"> $(F_EHRSSW)</td>
                      <td class="colnmbr">&nbsp;</td>
                      <td class="colnmbr">&nbsp;</td>
                  </tr>
              %endif

              %if (($(V_EHESDI) != ".00") || ($(V_EHRSDI) != ".00") || ($(V_EHTSDI) != ".00") || ($(V_EHXSDI) != ".00"))
                  @Format_Nbr($(V_EHESDI), F_EHESDI, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHRSDI), F_EHRSDI, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHTSDI), F_EHTSDI, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHXSDI), F_EHXSDI, "2", $(amtEditCode), "", "", "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> SDI Tax</td>
                      <td class="colcode"> $(V_EHSDID)</td>
                      <td class="colnmbr"> $(F_EHESDI)</td>
                      <td class="colnmbr"> $(F_EHRSDI)</td>
                      <td class="colnmbr"> $(F_EHTSDI)</td>
                      <td class="colnmbr"> $(F_EHXSDI)</td>
                      <td class="colnmbr">&nbsp;</td>
                  </tr>
              %endif

              %if (($(V_EHESWC) != ".00") || ($(V_EHRSWC) != ".00") || ($(V_EHTSWC) != ".00") || ($(V_EHXSWC) != ".00"))
                  @Format_Nbr($(V_EHESWC), F_EHESWC, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHRSWC), F_EHRSWC, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHTSWC), F_EHTSWC, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHXSWC), F_EHXSWC, "2", $(amtEditCode), "", "", "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> SWC Tax</td>
                      <td class="colcode"> $(V_EHSWID)</td>
                      <td class="colnmbr"> $(F_EHESWC)</td>
                      <td class="colnmbr"> $(F_EHRSWC)</td>
                      <td class="colnmbr"> $(F_EHTSWC)</td>
                      <td class="colnmbr"> $(F_EHXSWC)</td>
                      <td class="colnmbr">&nbsp;</td>
                  </tr>
              %endif

              %if (($(V_EHELT1) != ".00") || ($(V_EHRLT1) != ".00") || ($(V_EHTLIT) != ".00") || ($(V_EHXLIT) != ".00") || ($(V_EHDLIT) != ".00"))
                  @Format_Nbr($(V_EHELT1), F_EHELT1, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHRLT1), F_EHRLT1, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHTLIT), F_EHTLIT, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHXLIT), F_EHXLIT, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHDLIT), F_EHDLIT, "2", $(amtEditCode), "", "", "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> Local Tax 1</td>
                      <td class="colcode"> $(V_EHLOC1)</td>
                      <td class="colnmbr"> $(F_EHELT1)</td>
                      <td class="colnmbr"> $(F_EHRLT1)</td>
                      <td class="colnmbr"> $(F_EHTLIT)</td>
                      <td class="colnmbr"> $(F_EHXLIT)</td>
                      <td class="colnmbr"> $(F_EHDLIT)</td>
                  </tr>
              %endif

              %if (($(V_EHELT2) != ".00") || ($(V_EHRLT2) != ".00") || ($(V_EHTLT2) != ".00") || ($(V_EHXLT2) != ".00") || ($(V_EHDLT2) != ".00"))
                  @Format_Nbr($(V_EHELT2), F_EHELT2, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHRLT2), F_EHRLT2, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHTLT2), F_EHTLT2, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHXLT2), F_EHXLT2, "2", $(amtEditCode), "", "", "")
                  @Format_Nbr($(V_EHDLT2), F_EHDLT2, "2", $(amtEditCode), "", "", "")
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr"> Local Tax 2</td>
                      <td class="colcode"> $(V_EHLOC2)</td>
                      <td class="colnmbr"> $(F_EHELT2)</td>
                      <td class="colnmbr"> $(F_EHRLT2)</td>
                      <td class="colnmbr"> $(F_EHTLT2)</td>
                      <td class="colnmbr"> $(F_EHXLT2)</td>
                      <td class="colnmbr"> $(F_EHDLT2)</td>
                  </tr>
              %endif

              @dtw_assign(totalEmplTax, "0")
              @dtw_add(V_EHEFIT, totalEmplTax, totalEmplTax)
              @dtw_add(V_EHEHI, totalEmplTax, totalEmplTax)
              @dtw_add(V_EHEOA, totalEmplTax, totalEmplTax)
              @dtw_add(V_EHEEIC, totalEmplTax, totalEmplTax)
              @dtw_add(V_EHESIT, totalEmplTax, totalEmplTax)
              @dtw_add(V_EHESUI, totalEmplTax, totalEmplTax)
              @dtw_add(V_EHESUS, totalEmplTax, totalEmplTax)
              @dtw_add(V_EHESDI, totalEmplTax, totalEmplTax)
              @dtw_add(V_EHESWC, totalEmplTax, totalEmplTax)
              @dtw_add(V_EHELT1, totalEmplTax, totalEmplTax)
              @dtw_add(V_EHELT2, totalEmplTax, totalEmplTax)

              @dtw_assign(totalEmployerTax, "0")
              @dtw_add(V_EHRHI, totalEmployerTax, totalEmployerTax)
              @dtw_add(V_EHROA, totalEmployerTax, totalEmployerTax)
              @dtw_add(V_EHRFUI, totalEmployerTax, totalEmployerTax)
              @dtw_add(V_EHRSUI, totalEmployerTax, totalEmployerTax)
              @dtw_add(V_EHRSUS, totalEmployerTax, totalEmployerTax)
              @dtw_add(V_EHRSDI, totalEmployerTax, totalEmployerTax)
              @dtw_add(V_EHRSWC, totalEmployerTax, totalEmployerTax)
              @dtw_add(V_EHRLT1, totalEmployerTax, totalEmployerTax)
              @dtw_add(V_EHRLT2, totalEmployerTax, totalEmployerTax)

              <tr><td class="colnmbr" colspan="2">Total Taxes</td>
                  @Format_Nbr($(totalEmplTax), F_totalEmplTax, "2", $(hrsEditCode), "", "", "")
                  @Format_Nbr($(totalEmployerTax), F_totalEmployerTax, "2", $(hrsEditCode), "", "", "")
                  <td class="coltotal">$(F_totalEmplTax)</td>
                  <td class="coltotal">$(F_totalEmployerTax)</td>
              </tr>

          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Check_Select_OverridesAccruals (IN  CHAR(64)    profileHandle,
				                        CHAR(2)     dataBaseID,
                                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="overridesaccruals"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %ROW{
              @Format_Nbr($(V_EHCRWK), F_EHCRWK, "1", $(qtyEditCode), "", "", "")
              <tr><td class="dsphdr"> Credit Service Weeks</td>
                  <td class="colnmbr"> $(F_EHCRWK)</td>
              </tr>
    	   		
              @Format_Nbr($(V_EHEQDY), F_EHEQDY, "0", $(qtyEditCode), "", "", "")
              <tr><td class="dsphdr"> Equivalent Days</td>
                  <td class="colnmbr"> $(F_EHEQDY)</td>
              </tr>

              %if (V_EHR401 != ".00")
                  @Format_Nbr($(V_EHR401), F_EHR401, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr"> Employer 401(k) Match</td>
                      <td class="colnmbr"> $(F_EHR401)</td>
                  </tr>
	       %endif	

              %if (V_EHD401 != ".00")
                  @Format_Nbr($(V_EHD401), F_EHD401, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr"> 401(k) Discretionary</td>
                      <td class="colnmbr"> $(F_EHD401)</td>
                  </tr>
	       %endif	

              @Format_Nbr($(V_EHACHR), F_EHACHR, "2", $(hrsEditCode), "", "", "")
              <tr><td class="dsphdr"> Hours For Accruals</td>
                  <td class="colnmbr"> $(F_EHACHR)</td>
              </tr>
              <tr><td class="colhdr"> Accrual Type</td>
                  <td class="colhdr"> Process</td>
                  <td class="colhdr"> Hours</td>
                  <td class="colhdr"> Dollars</td>
  	   	   </tr>	
              @Format_Nbr($(V_EHACVH), F_EHACVH, "2", $(hrsEditCode), "", "", "")
              @Format_Nbr($(V_EHACVD), F_EHACVD, "2", $(amtEditCode), "", "", "")
              <tr><td class="dsphdr"> Vacation</td>
                  <td class="colcode">$(V_EHAVSC)</td>
                  <td class="colnmbr"> $(F_EHACVH)</td>
                  <td class="colnmbr"> $(F_EHACVD)</td>
  	   	   </tr>	
              @Format_Nbr($(V_EHACSH), F_EHACSH, "2", $(hrsEditCode), "", "", "")
              @Format_Nbr($(V_EHACSD), F_EHACSD, "2", $(amtEditCode), "", "", "")
              <tr><td class="dsphdr"> Sick</td>
                  <td class="colcode">$(V_EHASSC)</td>
                  <td class="colnmbr"> $(F_EHACSH)</td>
                  <td class="colnmbr"> $(F_EHACSD)</td>
  	   	   </tr>	
              %if ((V_EHACMH != ".00")  || (V_EHACMD != ".00"))
                  @Format_Nbr($(V_EHACMH), F_EHACMH, "2", $(hrsEditCode), "", "", "")
                  @Format_Nbr($(V_EHACMD), F_EHACMD, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr"> Miscellaneous</td>
                      <td class="colcode">$(V_EHACMS)</td>
                      <td class="colnmbr"> $(F_EHACMH)</td>
                      <td class="colnmbr"> $(F_EHACMD)</td>
                  </tr>
              %endif   			

              %if ((V_EHCOME != ".00")  || (V_EHBNSE != ".00"))
                  <tr><td class="colhdr"> Comm/Bonus Withholding</td>
                      <td class="colhdr"> FIT %</td>
                      <td class="colhdr"> SIT %</td>
                  </tr>
	          		
                  %if (V_EHCOME != ".00")
                      @Format_Nbr(@dtw_rmultiply(V_EHCEFP, "100"), F_EHCEFP, "1", $(pctEditCode), "", "", "")
                      @Format_Nbr(@dtw_rmultiply(V_EHCESP, "100"), F_EHCESP, "3", $(pctEditCode), "", "", "")
                      <tr><td class="dsphdr"> Commission W/H Percent</td>
                          <td class="colnmbr"> $(F_EHCEFP)</td>
                          <td class="colnmbr"> $(F_EHCESP)</td>
                      </tr>
                  %endif   			

                  %if (V_EHBNSE != ".00")
                      @Format_Nbr(@dtw_rmultiply(V_EHBEFP, "100"), F_EHBEFP, "1", $(pctEditCode), "", "", "")
                      @Format_Nbr(@dtw_rmultiply(V_EHBESP, "100"), F_EHBESP, "3", $(pctEditCode), "", "", "")
                      <tr><td class="dsphdr"> Bonus W/H Percent</td>
                          <td class="colnmbr"> $(F_EHBEFP)</td>
                          <td class="colnmbr"> $(F_EHBESP)</td>
                      </tr>
                  %endif   			
              %endif   			
          %}	
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Check_Select_Deductions (IN  CHAR(64)    profileHandle,
				                 CHAR(2)     dataBaseID,
                                                CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="deductions"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          @dtw_assign(totalDeductions, "0")
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %endif

          %ROW {
              %if (oneTime == "")
                  @dtw_assign(oneTime, "N")
                  <table $(contentTable)>
                      @Format_Nbr($(V_EHDDER), F_EHDDER, "2", $(amtEditCode), "", "", "")
                      <tr><td class="dsphdr">Earnings For Deductions</td>
                          <td class="colnmbr"> $(F_EHDDER)</td>
                      </tr>
                  </table>

                  <table $(contentTable)>
       	       <tr>
       	          <th class="colhdr">Deduction<br>Number</th>
       	          <th class="colhdr">Description</th>
                         <th class="colhdr">Amount</th>
       	       </tr>
              %endif

              @dtw_add(V_VHAMT, totalDeductions, totalDeductions)
              %INCLUDE "SetRowClass.icl"
              @Format_Nbr($(V_VHAMT), F_VHAMT, "2", $(amtEditCode), "", "", "")
              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_VHDDNO)</td>
                  <td class="colalph">$(V_HVLDSC)</td>
                  <td class="colnmbr">$(F_VHAMT)</td>
              </tr>
          %}	
    	   %if (sql_Record_Count > "1")
              <tr><td class="colnmbr" colspan="2">Total</td>
                  @Format_Nbr($(totalDeductions), F_totalDeductions, "2", $(hrsEditCode), "", "", "")
                  <td class="coltotal">$(F_totalDeductions)</td>
              </tr>
          %endif
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Check_Select_PayDetail (IN  CHAR(64)    profileHandle,
				                 CHAR(2)     dataBaseID,
                                                CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="paydetail"></a>
      @dtw_assign(displayMaxRowsMsg, "Y")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
	   %else
	       <tr>
      	           <th class="colhdr">Date</th>
      	           <th class="colhdr">Pay<br>Code</th>
      	           <th class="colhdr">Description</th>
      	           <th class="colhdr">Hours</th>
      	           <th class="colhdr">Units</th>
                  <th class="colhdr">Earnings</th>
                  <th class="colhdr">Pay<br>Rate</th>
                  <th class="colhdr">Shift</th>
                  <th class="colhdr">Dept</th>
                  <th class="colhdr">Job</th>
	       </tr>
	   %endif

          @dtw_assign(workedHours, "0")
          @dtw_assign(notWorked, "0")
          @dtw_assign(totalUnits, "0")
          @dtw_assign(totalEarnings, "0")

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Date(V_SHDTWK, "D", F_SHDTWK)
              @RtvFldDesc("C2COMP=$(prCompany) and C2FACL=$(prFacility) and C2CODE='$(V_SHCODE)'", "PRCODE", "C2DESC", payCodeDesc)
	       <tr class="$(rowClass)">
                  <td class="coldate">$(F_SHDTWK)</td>
	       	   <td class="colcode">$(V_SHCODE)</td>
	           <td class="colalph"><a href="$(homeURL)$(cGIPath)employeePayDetailSelect.d2w/report$(d2wVarBase)&amp;detailSequence=@dtw_rurlescseq(V_SHSEQ)" title="View Detail Pay History">$(payCodeDesc)</a></td>	   	
	       	   %if (V_SHHRUN == "H")
                      @Format_Nbr($(V_SHHOUR), F_SHHOUR, "2", $(hrsEditCode), "", "", "")
	       	       <td class="colnmbr">$(F_SHHOUR)</td>
                      <td class="colnmbr"></td>
	       	       %if (V_SHWORK == "Y")
	       	           @dtw_add(V_SHHOUR, workedHours, workedHours)
	       	       %else
	       	           @dtw_add(V_SHHOUR, notWorked, notWorked)
	       	       %endif
	       	   %elif (V_SHHRUN == "U")
                      @Format_Nbr($(V_SHHOUR), F_SHHOUR, "2", $(hrsEditCode), "", "", "")
                      <td class="colnmbr"></td>
                      <td class="colnmbr">$(F_SHHOUR)</td>
	       	       @dtw_add(V_SHHOUR, totalUnits, totalUnits)
	       	   %else
                      <td class="colnmbr"></td>
                      <td class="colnmbr"></td>
	       	   %endif
	       	   @dtw_add(V_SHEARN, totalEarnings, totalEarnings)
                   @Format_Nbr($(V_SHEARN), F_SHEARN, "2", $(amtEditCode), "", "", "")
	       	   <td class="colnmbr">$(F_SHEARN)</td>
	       	   %if (V_SHOVRT == ".000")
	       	       @dtw_assign(V_SHOVRT, "")
	       	       <td class="colnmbr">$(V_SHOVRT)</td>
                  %else
                      @Format_Nbr($(V_SHOVRT), F_SHOVRT, $(rteNbrDec), $(rteEditCode), "", "", "")
                      <td class="colnmbr">$(F_SHOVRT)</td>
                  %endif
	           <td class="colcode">$(V_SHSHFW)</td>
	       	   <td class="colcode">$(V_SHDEPT)</td>
	       	   <td class="colalph">$(V_SHJOB)</td>
	       </tr>	

          %}

          @Format_Nbr($(workedHours), F_workedHours, "2", $(hrsEditCode), "", "", "")
          @Format_Nbr($(totalEarnings), F_totalEarnings, "2", $(amtEditCode), "", "", "")
          <tr><td class="colnmbr" colspan="3">Total</td>
              <td class="coltotal"> $(F_workedHours)</td>
	      	    %if (totalUnits == "0")
	                @dtw_assign(totalUnits, "")
                       <td class="colnmbr">$(totalUnits)</td>
                   %else
                       @Format_Nbr($(totalUnits), F_totalUnits, "2", $(hrsEditCode), "", "", "")
                       <td class="colnmbr">$(F_totalUnits)</td>
	      	    %endif
              <td class="coltotal">$(F_totalEarnings)</td>
              <td class="colnmbr"></td>
              <td class="colnmbr"></td>
              <td class="colnmbr"></td>
              <td class="colnmbr"></td>
              <td>&nbsp;</td>
          </tr>
          %if (notWorked != "0")
              @Format_Nbr($(notWorked), F_notWorked, "2", $(hrsEditCode), "", "", "")
              <tr><td>&nbsp;</td>
                  <td>&nbsp;</td>
                  <td class="colalph">Not Worked</td>
                  <td class="colnmbr">$(F_notWorked)</td>
                  <td class="colnmbr"></td>
                  <td class="colnmbr"></td>
              </tr>
          %endif
      </table>
      </fieldset>
  %}
%}

%INCLUDE "AttachmentSelect.icl"

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  @RtvFldDesc("EMCOMP=$(prCompany) and EMFACL=$(prFacility) and EMEMPL=$(prEmployee)", "HREMPL", "EMTYPE", PAYTYPECODE)

  %if ((sec_05 == "N") || (sec_06 == "N" && PAYTYPECODE == "H") || (sec_07 == "N" && PAYTYPECODE != "H"))
      %INCLUDE "ProgSecurityError.icl"
  %else
      @dtw_assign(CHI_06, sec_06)
      @dtw_assign(CHI_07, sec_07)
      @Set_SQL(stmtSQL)
  %endif
%}