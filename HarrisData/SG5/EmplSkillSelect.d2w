%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title 	        = "Employee Education/Skill"
  d2wName              = "EmplSkillSelect.d2w"
  attachFolder         = "EmployeeSkill"
  d2wVarBase           = "$(genericVarBase)$(employeeVarBase)&amp;sequenceNbr=@dtw_rurlescseq(sequenceNbr)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName          = "HPEEDU"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  RPT_MAX_ROWS         = "99"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext	        = "1"
  totalPages	        = "0"	
  attachVarKey         = ""
  attachForDesc        = ""
  quickLinksInUse      = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
  @dtw_replace(workURL, "@@sequenceNbr", "@dtw_rurlescseq(sequenceNbr)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "EMPLSKILLSELECT")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          @dtw_concat(stmtSQL, "Select * From PEEDUC ", stmtSQL)
                          @dtw_concat(stmtSQL, " Where DCCOMP=$(hrCompany) and DCEMPL=$(hrEmployee) and DCSEQ=$(sequenceNbr)", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @EmplEduc_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) EmplEduc_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @Ret_Format_EmplName(UVComp, UVFac, UVPREmpl, hrCompany, hrEmployee, "H", F_EmpName)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              @dtw_assign(seqNbrFilled, "$(sequenceNbr)")
              %while(@dtw_rlength(seqNbrFilled) != "4") {@dtw_insert("0", seqNbrFilled, seqNbrFilled)%}
              @dtw_assign(attVar, "Skill_$(seqNbrFilled)")
              %INCLUDE "emplAttachment.icl"
              @dtw_assign(attachForDesc, "$(F_EmpName) Educ/Skill Seq $(sequenceNbr)")
              @dtw_assign(attachPrg1, "HREMPL inner join PEEDUC on EMCOMP=DCCOMP and EMFACL=DCFACL and EMEMPL=DCEMPL Where EMEMID=$(employeeID) and DCSEQ=$(sequenceNbr)")

              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %INCLUDE "Attachment.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
          <tr><td><h2> $(F_EmpName)</h2></td></tr>

      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %ROW {
          <table $(contentTable)>
             <tr><td class="dsphdr">Sequence Number</td>
                 <td class="dspalph">$(V_DCSEQ)</td></tr>
             <tr><td class="dsphdr">Subject</td>
                 <td class="dspalph">$(V_DCSUBJ)</td>
             </tr>
             <tr><td class="dsphdr">Skill</td>
                 <td class="dspalph">$(V_DCSKIL)</td>
             </tr>
             <tr><td class="dsphdr">School/Course</td>
                 <td class="dspalph">$(V_DCSCHL)</td>
             </tr>
             <tr><td class="dsphdr">Time/Duration</td>
                 <td class="dspalph">$(V_DCDUR)</td>
             </tr>
             <tr><td class="dsphdr">Degree</td>
                 <td class="dspalph">$(V_DCDGRE)</td>
             </tr>
             @Format_Date(V_DCDTCM, "H", F_DCDTCM)
             <tr><td class="dsphdr">Date Complete</td>
                 <td class="dspalph">$(F_DCDTCM)</td>
             </tr>
             @Format_Nbr($(V_DCRFND), F_DCRFND, "2", $(amtEditCode), "", "", "")
             <tr><td class="dsphdr">Tuition Refund</td>
                 <td class="dspalph">$(F_DCRFND)</td>
             </tr>
          </table>
          %INCLUDE "AttachmentSQL.icl"
      %}	
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%INCLUDE "AttachmentSelect.icl"

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}