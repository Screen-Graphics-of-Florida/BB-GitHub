%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "401(k) Rates Maintenance"
  d2wName                 = "401kRatesMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;coNumber=@dtw_rurlescseq(coNumber)&amp;facNumber=@dtw_rurlescseq(facNumber)&amp;maintenanceCode=D"
  programName             = "HPR4KM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  anppTable               = %table
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  function validate(chgForm) {
                      if (document.Chg.coNumber.value =="" ||
                          document.Chg.facNumber.value =="" ||
                          document.Chg.deduction1.value =="" ||
                          document.Chg.apCalc.value ==""
                                                       )
                         {alert("$(reqFieldError)"); return false;}
                      if (editNum(document.Chg.coNumber,                     2, 0) &&
                          editNum(document.Chg.facNumber,                    4, 0) &&
                          editNum(document.Chg.deduction1,                   3, 0) &&
                          editNum(document.Chg.deduction2,                   3, 0) &&
                          editNum(document.Chg.deduction3,                   3, 0) &&
                          editNum(document.Chg.deduction4,                   3, 0) &&
                          editNum(document.Chg.deduction5,                   3, 0) &&
                          editNum(document.Chg.employeeMin,                  3, 2) &&
                          editNum(document.Chg.employerMaxMatchHourly,       3, 2) &&
                          editNum(document.Chg.employerMaxMatchSalary,       3, 2) &&
                          editNum(document.Chg.employerMatchPercentHourly,   3, 2) &&
                          editNum(document.Chg.employerMatchPercentSalary,   3, 2))
                          return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
	           %INCLUDE "numedit.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "R401KMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "SELECT * FROM PR401K WHERE K4COMP=$(coNumber) and K4FACL=$(facNumber) ", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=188")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "deduction1")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@comp", "coNumber")                     @dtw_assign(Err_K4COMP, fieldValue)
                          @DecatErr_Field("@@facl", "facNumber")                    @dtw_assign(Err_K4FACL, fieldValue)
                          @DecatErr_Field("@@ded1", "deduction1")                   @dtw_assign(Err_K4DED1, fieldValue)
                          @DecatErr_Field("@@ded2", "deduction2")                   @dtw_assign(Err_K4DED2, fieldValue)
                          @DecatErr_Field("@@ded3", "deduction3")                   @dtw_assign(Err_K4DED3, fieldValue)
                          @DecatErr_Field("@@ded4", "deduction4")                   @dtw_assign(Err_K4DED4, fieldValue)
                          @DecatErr_Field("@@ded5", "deduction5")                   @dtw_assign(Err_K4DED5, fieldValue)
                          @DecatErr_Field("@@emcn", "employeeMin")                  @dtw_assign(Err_K4EMCN, fieldValue)
                          @DecatErr_Field("@@rmxh", "employerMaxMatchHourly")       @dtw_assign(Err_K4RMXH, fieldValue)
                          @DecatErr_Field("@@rmxs", "employerMaxMatchSalary")       @dtw_assign(Err_K4RMXS, fieldValue)
                          @DecatErr_Field("@@rmah", "employerMatchPercentHourly")   @dtw_assign(Err_K4RMAH, fieldValue)
                          @DecatErr_Field("@@rmas", "employerMatchPercentSalary")   @dtw_assign(Err_K4RMAS, fieldValue)
                          @DecatErr_Field("@@anpp", "apCalc")                       @dtw_assign(Err_K4ANPP, fieldValue)
                          @DecatErr_Field("@@tstp", "timeStamp")            @dtw_assign(Err_K4TSTP, fieldValue)
                      %endif

                      @Decat_Field("@@comp")   @dtw_assign(V_K4COMP, fieldValue)
                      @Decat_Field("@@facl")   @dtw_assign(V_K4FACL, fieldValue)
                      @Decat_Field("@@ded1")   @dtw_assign(V_K4DED1, fieldValue)
                      @Decat_Field("@@ded2")   @dtw_assign(V_K4DED2, fieldValue)
                      @Decat_Field("@@ded3")   @dtw_assign(V_K4DED3, fieldValue)
                      @Decat_Field("@@ded4")   @dtw_assign(V_K4DED4, fieldValue)
                      @Decat_Field("@@ded5")   @dtw_assign(V_K4DED5, fieldValue)
                      @Decat_Field("@@emcn")   @dtw_assign(V_K4EMCN, fieldValue)
                      @Decat_Field("@@rmxh")   @dtw_assign(V_K4RMXH, fieldValue)
                      @Decat_Field("@@rmxs")   @dtw_assign(V_K4RMXS, fieldValue)
                      @Decat_Field("@@rmah")   @dtw_assign(V_K4RMAH, fieldValue)
                      @Decat_Field("@@rmas")   @dtw_assign(V_K4RMAS, fieldValue)
                      @Decat_Field("@@anpp")   @dtw_assign(V_K4ANPP, fieldValue)
                      @Decat_Field("@@tstp")   @dtw_assign(V_K4TSTP, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(V_K4ANPP, "A")
                          @dtw_assign(focusField, "deduction1")
                          @dtw_assign(V_K4COMP, coNumber)
                          @dtw_assign(V_K4FACL, facNumber)
                          @dtw_assign(V_K4DED1, "0")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "coNumber")
                      @dtw_assign(V_K4EMCN, "@dtw_rformat(@dtw_rmultiply(V_K4EMCN, "100"),"","2")")
                      @dtw_assign(V_K4RMXH, "@dtw_rformat(@dtw_rmultiply(V_K4RMXH, "100"),"","2")")
                      @dtw_assign(V_K4RMXS, "@dtw_rformat(@dtw_rmultiply(V_K4RMXS, "100"),"","2")")
                      @dtw_assign(V_K4RMAH, "@dtw_rformat(@dtw_rmultiply(V_K4RMAH, "100"),"","2")")
                      @dtw_assign(V_K4RMAS, "@dtw_rformat(@dtw_rmultiply(V_K4RMAS, "100"),"","2")")
                  %else
                      @dtw_assign(focusField, "deduction1")
                      @dtw_assign(V_K4EMCN, "@dtw_rformat(@dtw_rmultiply(V_K4EMCN, "100"),"","2")")
                      @dtw_assign(V_K4RMXH, "@dtw_rformat(@dtw_rmultiply(V_K4RMXH, "100"),"","2")")
                      @dtw_assign(V_K4RMXS, "@dtw_rformat(@dtw_rmultiply(V_K4RMXS, "100"),"","2")")
                      @dtw_assign(V_K4RMAH, "@dtw_rformat(@dtw_rmultiply(V_K4RMAH, "100"),"","2")")
                      @dtw_assign(V_K4RMAS, "@dtw_rformat(@dtw_rmultiply(V_K4RMAS, "100"),"","2")")
                  %endif
              	  @SetTextOvr(Err_K4TSTP)
                  <tr><td class="dsphdr"><span $(textOvr)>.</span></td>
                  	  <td><input name="timeStamp" type="hidden" value="$(V_K4TSTP)"></td> 
                  </tr>
                  @DspErrMsg(Err_K4TSTP)

                  @Format_HRCoFac("$(V_K4COMP)", "$(V_K4FACL)", "", F_CoFac)
                  @Format_Code(F_CoFac, F2_CoFac)
                  @RtvFldDesc("CFCOMP=$(V_K4COMP) and CFFACL=$(V_K4FACL)", "HRCOFC", "CFNAME", fieldDesc)
                  @SetTextOvr(Err_K4COMP)
                  <tr><td class="dsphdr"><span $(textOvr)>Company/Facility</span></td>
                      %if (maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="coNumber" value="$(V_K4COMP)" type="text" size="4" maxlength="2"> / <input name="facNumber" value="$(V_K4FACL)" type="text" size="4" maxlength="4"> $(reqFieldChar) <a href="$(homeURL)$(phpPath)HRCoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=coNumber&amp;fldFac=facNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage)</a><input disabled name="coFacDesc" value="$(fieldDesc)"  type="text" size="30" maxlength="30"></td>
                      %else
                          <td class="dspalph"><input name="coNumber" value="$(V_K4COMP)" type="hidden" size="4" maxlength="2"> <input name="facNumber" value="$(V_K4FACL)" type="hidden" size="4" maxlength="4">$(fieldDesc)  $(F2_CoFac)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_K4COMP)
                  @DspErrMsg(Err_K4FACL)

                  @RtvFldDesc("HVDDNO=$(V_K4DED1) ", "HRDEDM", "CHAR(HVDDNM)", deductionDesc)
                  @SetTextOvr(Err_K4DED1)
                  <tr><td class="dsphdr"><span $(textOvr)>401(k) Deduction Numbers</span></td>
                      <td class="inputnmbr"><input name="deduction1" value="$(V_K4DED1)" type="text" size="3" maxlength="3">$(reqFieldChar) <a href="$(homeURL)$(cGIPath)DeductionSearch.d2w/ENTRY$(d2wVarBase)&amp;prCompany=@dtw_rurlescseq(coNumber)&amp;prFacility=@dtw_rurlescseq(facNumber)&amp;docName=Chg&amp;fldName=deduction1&amp;fldDesc=deductionDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="deductionDesc" value="$(deductionDesc)" size="30" disabled></td>
                  </tr>
                  @DspErrMsg(Err_K4DED1)

                  @RtvFldDesc("HVDDNO=$(V_K4DED2) ", "HRDEDM", "CHAR(HVDDNM)", deductionDesc2)
                  @SetTextOvr(Err_K4DED2)
                  <tr><td class="dsphdr"><span $(textOvr)>&nbsp;</span></td>
                      <td class="inputnmbr"><input name="deduction2" value="$(V_K4DED2)" type="text" size="3" maxlength="3">&nbsp;<a href="$(homeURL)$(cGIPath)DeductionSearch.d2w/ENTRY$(d2wVarBase)&amp;prCompany=@dtw_rurlescseq(coNumber)&amp;prFacility=@dtw_rurlescseq(facNumber)&amp;docName=Chg&amp;fldName=deduction2&amp;fldDesc=deductionDesc2" onclick="$(searchWinVar)"> $(searchImage) </a><input name="deductionDesc2" value="$(deductionDesc2)" size="30" disabled></td>
                  </tr>
                  @DspErrMsg(Err_K4DED2)

                  @RtvFldDesc("HVDDNO=$(V_K4DED3) ", "HRDEDM", "CHAR(HVDDNM)", deductionDesc3)
                  @SetTextOvr(Err_K4DED3)
                  <tr><td class="dsphdr"><span $(textOvr)>&nbsp;</span></td>
                      <td class="inputnmbr"><input name="deduction3" value="$(V_K4DED3)" type="text" size="3" maxlength="3">&nbsp; <a href="$(homeURL)$(cGIPath)DeductionSearch.d2w/ENTRY$(d2wVarBase)&amp;prCompany=@dtw_rurlescseq(coNumber)&amp;prFacility=@dtw_rurlescseq(facNumber)&amp;docName=Chg&amp;fldName=deduction3&amp;fldDesc=deductionDesc3" onclick="$(searchWinVar)"> $(searchImage) </a><input name="deductionDesc3" value="$(deductionDesc3)"  size="30" disabled></td>
                  </tr>
                  @DspErrMsg(Err_K4DED3)

                  @RtvFldDesc("HVDDNO=$(V_K4DED4) ", "HRDEDM", "CHAR(HVDDNM)", deductionDesc4)
                  @SetTextOvr(Err_K4DED4)
                  <tr><td class="dsphdr"><span $(textOvr)>&nbsp;</span></td>
                      <td class="inputnmbr"><input name="deduction4" value="$(V_K4DED4)" type="text" size="3" maxlength="3">&nbsp; <a href="$(homeURL)$(cGIPath)DeductionSearch.d2w/ENTRY$(d2wVarBase)&amp;prCompany=@dtw_rurlescseq(coNumber)&amp;prFacility=@dtw_rurlescseq(facNumber)&amp;docName=Chg&amp;fldName=deduction4&amp;fldDesc=deductionDesc4" onclick="$(searchWinVar)"> $(searchImage) </a><input name="deductionDesc4" value="$(deductionDesc4)" size="30" disabled></td>
                  </tr>
                  @DspErrMsg(Err_K4DED4)

                  @RtvFldDesc("HVDDNO=$(V_K4DED5) ", "HRDEDM", "CHAR(HVDDNM)", deductionDesc5)
                  @SetTextOvr(Err_K4DED5)
                  <tr><td class="dsphdr"><span $(textOvr)>&nbsp;</span></td>
                      <td class="inputnmbr"><input name="deduction5" value="$(V_K4DED5)" type="text" size="3" maxlength="3">&nbsp; <a href="$(homeURL)$(cGIPath)DeductionSearch.d2w/ENTRY$(d2wVarBase)&amp;prCompany=@dtw_rurlescseq(coNumber)&amp;prFacility=@dtw_rurlescseq(facNumber)&amp;docName=Chg&amp;fldName=deduction5&amp;fldDesc=deductionDesc5" onclick="$(searchWinVar)"> $(searchImage) </a><input name="deductionDesc5" value="$(deductionDesc5)"  size="30" disabled></td>
                  </tr>
                  @DspErrMsg(Err_K4DED5)

                  @SetTextOvr(Err_K4ANPP)
                  <tr><td class="dsphdr"><span $(textOvr)>Annual/Pay Period Calculation</span></td>
                      @dtw_tb_rows(anppTable, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(anppTable, x, "1") != V_K4ANPP) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(anppTable, "apCalc", "2", "1", "N", "", x, "1")  $(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_K4ANPP)

                  @Default_Zero(V_K4EMCN)
                  @SetTextOvr(Err_K4EMCN)
                  <tr><td class="dsphdr"><span $(textOvr)>Employee Minimum Contribution %</span></td>
                      <td class="inputnmbr"><input name="employeeMin" value="$(V_K4EMCN)" type="text" size="5" maxlength="6"></td>
                  </tr>
                  @DspErrMsg(Err_K4EMCN)
              </table>

              <table $(contentTable)>
                  <tr><td>&nbsp;</td>
                      <td class="colhdr">Hourly<br>Percent</td>
                      <td class="colhdr">Salary<br>Percent</td>
                  </tr>

                  @Default_Zero(V_K4RMXH)
                  @Default_Zero(V_K4RMXS)
                  @SetTextOvr(Err_K4RMXH)
                  @SetTextOvr(Err_K4RMXS)
                  <tr><td class="dsphdr"><span $(textOvr)>Employer Maximum Match</span></td>
                      <td class="inputnmbr"><input name="employerMaxMatchHourly" value="$(V_K4RMXH)" type="text" size="5" maxlength="6"></td>
                      <td class="inputnmbr"><input name="employerMaxMatchSalary" value="$(V_K4RMXS)" type="text" size="5" maxlength="6"></td>
                  </tr>
                  @DspErrMsg(Err_K4RMXH)
                  @DspErrMsg(Err_K4RMXS)

                  @Default_Zero(V_K4RMAH)
                  @Default_Zero(V_K4RMAS)
                  @SetTextOvr(Err_K4RMAH)
                  @SetTextOvr(Err_K4RMAS)
                  <tr><td class="dsphdr"><span $(textOvr)>Employer Match</span></td>
                      <td class="inputnmbr"><input name="employerMatchPercentHourly" value="$(V_K4RMAH)" type="text" size="5" maxlength="6"></td>
                      <td class="inputnmbr"><input name="employerMatchPercentSalary" value="$(V_K4RMAS)" type="text" size="5" maxlength="6"></td>
                  </tr>
                  @DspErrMsg(Err_K4RMAH)
                  @DspErrMsg(Err_K4RMAS)


              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)


{%EXEC {HPR4KM_W.PGM %}
%}

%FUNCTION(dtw_directcall) Validate_CoFac(INOUT CHAR(64) profileHandle,
                                         INOUT CHAR(2) dataBaseID,
                                         INOUT CHAR(1) maintCode,
                                         INOUT CHAR(1) errFound,
                                         INOUT CHAR(32000) edtVar,                             	
                                         INOUT CHAR(32000) errVar)
{%EXEC {HPR4KM_W1.PGM %}
%}

%FUNCTION(DTW_SQL) anpp_Query
		(IN 	CHAR(64) profileHandle,
		        char(2)  dataBaseID,
		        char(10) type,
		 OUT  	anppTable)
       {call $(pgmLibrary)hsyfvp_w
%}



%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @anpp_Query(profileHandle, dataBaseID, "APCALC    ", anppTable)
          @dtw_tb_insertrow(anppTable, "0", "1")
	   @dtw_tb_setv(anppTable, "", "1", "2")
      @Set_SQL(stmtSQL)
  %endif
%}
%HTML(ADD) {
  @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
  %if (backURL == "")
      @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=188")
  %endif
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.coNumber, 2, 0) &&
                      editNum(document.Chg.facNumber,4, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "" && noMenu !="Y")
                      @dtw_assign(pageID, "R401KMAINTAIN")
                     <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      <table $(contentTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1>Add Company/Facility</h1></td>
                              <td class="toolbar">
                                  %INCLUDE "MaintainTopNoTable.icl"
                              </td>
                          </tr>
                      </table>

                      $(hrTagAttr)
                      %INCLUDE "RequiredField.icl"
                      %INCLUDE "ErrorDisplay.icl"

                      <form class="formClass" METHOD=POST name=Chg ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_CoFac$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
                          <table $(contentTable)>
                              %if (errFound != "" || maintenanceCode == "A")
                                  %if (errFound == "" && maintenanceCode == "A")
                                      @dtw_assign(edtVar, "")
                                  %else
                                      @EdtVarErr(profileHandle, typeValue, edtVar)
                                      @dtw_assign(focusField, "")
                                      @ErrVarErr(profileHandle, typeError, errVar)
                                      @DecatErr_Field("@@comp", "coNumber")    @dtw_assign(Err_K4COMP,  fieldValue)
                                      @DecatErr_Field("@@facl", "facNumber")   @dtw_assign(Err_K4FACL,  fieldValue)
                                  %endif

                                  @Decat_Field("@@comp")   @dtw_assign(V_K4COMP,  fieldValue)
                                  @Decat_Field("@@facl")   @dtw_assign(V_K4FACL,  fieldValue)

                                  %if (errFound == "" && maintenanceCode == "A")
                                      @dtw_assign(V_K4COMP, "0")
                                      @dtw_assign(V_K4FACL, "0")
                                  %endif
                                  @dtw_assign(errFound, "")

                              %elif (maintenanceCode == "Z")
                                  @dtw_assign(V_K4COMP, "0")
                                  @dtw_assign(V_K4FACL, "0")
                              %endif

                              @Format_HRCoFac("$(V_K4COMP)", "$(V_K4FACL)", "", F_CoFac)
                              @Format_Code(F_CoFac, F2_CoFac)
                              @RtvFldDesc("CFCOMP=$(V_K4COMP) and CFFACL=$(V_K4FACL)", "HRCOFC", "CFNAME", fieldDesc)
                              @SetTextOvr(Err_K4COMP)
                              <tr><td class="dsphdr"><span $(textOvr)>Company/Facility</span></td>
                                  <td class="inputnmbr"><input name="coNumber" value="$(V_K4COMP)" type="text" size="4" maxlength="2"> / <input name="facNumber" value="$(V_K4FACL)" type="text" size="4" maxlength="4"> $(reqFieldChar) <a href="$(homeURL)$(phpPath)HRCoFacSearch.php$(altVarBase)&amp;docName=Chg&amp;fldCo=coNumber&amp;fldFac=facNumber&amp;fldDesc=coFacDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input disabled name="coFacDesc" value="$(fieldDesc)"  type="text" size="30" maxlength="30"></td>
                                  @DspErrMsg(Err_K4COMP)
                                  @DspErrMsg(Err_K4FACL)
                              </tr>


                          </table>
                          @dtw_assign(focusField, "coNumber")

                          <script TYPE="text/javascript">
                              document.Chg.$(focusField).focus();
                          </script>

                      </form>
                      %INCLUDE "MaintainBottom.icl"
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>

          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%HTML(Edit_CoFac) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(itemNumber)
  @dtw_assign(coNumber,@dtw_rstrip(coNumber))
  @dtw_assign(facNumber,@dtw_rstrip(facNumber))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintCode, "A")
  %else
      @dtw_assign(maintCode, maintenanceCode)
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@comp", coNumber)
  @Concat_Field("@@facl", facNumber)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_CoFac(profileHandle, dataBaseID, maintCode, errFound, edtVar, errVar)

  %if (errFound == "")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;coNumber=@dtw_rurlescseq(coNumber)&amp;facNumber=@dtw_rurlescseq(facNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/ADD$(d2wVarBase)&amp;coNumber=@dtw_rurlescseq(coNumber)&amp;facNumber=@dtw_rurlescseq(facNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(apCalc)

  @dtw_assign(coNumber,@dtw_rstrip(coNumber))
  @dtw_assign(facNumber,@dtw_rstrip(facNumber))
  @dtw_assign(deduction1,@dtw_rstrip(deduction1))
  @dtw_assign(deduction2,@dtw_rstrip(deduction2))
  @dtw_assign(deduction3,@dtw_rstrip(deduction3))
  @dtw_assign(deduction4,@dtw_rstrip(deduction4))
  @dtw_assign(deduction5,@dtw_rstrip(deduction5))
  @dtw_assign(codeDesc,@dtw_rstrip(codeDesc))
  @dtw_assign(employeeMin,@dtw_rstrip(employeeMin))
  @dtw_assign(employerMaxMatchHourly,@dtw_rstrip(employerMaxMatchHourly))
  @dtw_assign(employerMaxMatchSalary,@dtw_rstrip(employerMaxMatchSalary))
  @dtw_assign(employerMatchPercentHourly,@dtw_rstrip(employerMatchPercentHourly))
  @dtw_assign(employerMatchPercentSalary,@dtw_rstrip(employerMatchPercentSalary))
  @dtw_assign(apCalc,@dtw_rstrip(apCalc))


  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@comp", coNumber)
  @Concat_Field("@@facl", facNumber)
  @Concat_Field("@@ded1", deduction1)
  @Concat_Field("@@ded2", deduction2)
  @Concat_Field("@@ded3", deduction3)
  @Concat_Field("@@ded4", deduction4)
  @Concat_Field("@@ded5", deduction5)
  @Concat_Field("@@emcn", employeeMin)
  @Concat_Field("@@rmxh", employerMaxMatchHourly)
  @Concat_Field("@@rmxs", employerMaxMatchSalary)
  @Concat_Field("@@rmah", employerMatchPercentHourly)
  @Concat_Field("@@rmas", employerMatchPercentSalary)
  @Concat_Field("@@anpp", apCalc)
  @Concat_Field("@@tstp", timeStamp)

  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)
  @DecatErr_Field("@@comp", "coNumber")      @dtw_assign(Err_K4COMP, fieldValue)

  %if (errFound == "")
      @Format_HRCoFac("$(coNumber)", "$(facNumber)", "", F_CoFac)
      @RtvFldDesc("CFCOMP=$(coNumber) and CFFACL=$(facNumber)", "HRCOFC", "CFNAME", fieldDesc)
      @Format_ConfMsg_Desc(maintenanceCode, $(fieldDesc), $(F_CoFac), "", "", "", "", confMessage)
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=188&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %elif ((maintenanceCode == "C" || maintenanceCode == "D") && errFound != "" && fieldValue != "")
      @Format_HRCoFac("$(coNumber)", "$(facNumber)", "", F_CoFac)
      @RtvFldDesc("CFCOMP=$(coNumber) and CFFACL=$(facNumber)", "HRCOFC", "CFNAME", fieldDesc)
      @Format_ConfMsg_Desc("E", $(fieldDesc), $(F_CoFac), "<br>$(fieldValue)", "", "", "", confMessage)
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=188&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;coNumber=@dtw_rurlescseq(coNumber)&amp;facNumber=@dtw_rurlescseq(facNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
