%INCLUDE "$(baseVar)"
%INCLUDE "EdtVar.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title 	        = "Employee Property Select"
  d2wName              = "EmplPropertySelect.d2w"
  attachFolder         = "EmployeeProperty"
  d2wVarBase           = "$(genericVarBase)$(employeeVarBase)&amp;sequenceNumber=@dtw_rurlescseq(sequenceNumber)&amp;propertyType=@dtw_rurlescseq(propertyType)&amp;propertyTypeDesc=@dtw_rurlescseq(propertyTypeDesc)&amp;propertyDesc=@dtw_rurlescseq(propertyDesc)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(d2wName)"
  programName          = "HPEPRO"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  applicationID        = "PE"
  dspMaxRows           = "$(dspMaxRowsDft)"
  hrCodeType           = "N"
  prtMaxRows           = "$(prtMaxRowsDft)"
  updateError          = " "
  UVCo                 = "00"
  UVFAC                = "0000"
  VPREmpl              = "00000"
  attachVarKey         = ""
  attachForDesc        = ""
  quickLinksInUse      = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
  @dtw_replace(workURL, "@@sequenceNumber", "@dtw_rurlescseq(sequenceNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@fromD2w", "@dtw_rurlescseq(fromD2w)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @dtw_assign(UVCo, "00")
  @dtw_assign(UVFac, "0000")
  @dtw_assign(UVPREmpl, "00000")
  %INCLUDE "EmplUV.icl"
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->

              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                          @dtw_assign(pageID, "PROPMAINTAIN")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          @dtw_concat(stmtSQL, "Select * From PEPROP Where PRCOMP = $(hrCompany) and ", stmtSQL)
                          @dtw_concat(stmtSQL, "  PREMPL = $(hrEmployee) and PRSEQ = $(sequenceNumber)", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @Property_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
    %endif
  %}

%FUNCTION(dtw_sql) Property_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)

{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @Ret_Format_EmplName(UVCo, UVFac, UVPREmpl, hrCompany, hrEmployee, "H", F_EmpName)
      <table $(contentTable)>
	   <colgroup>
	       <col width="80%">
	       <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              @dtw_assign(seqNbrFilled, "$(sequenceNumber)")
              %while(@dtw_rlength(seqNbrFilled) != "4") {@dtw_insert("0", seqNbrFilled, seqNbrFilled)%}
              @dtw_assign(attVar, "Property_$(seqNbrFilled)")
              %INCLUDE "emplAttachment.icl"
              @dtw_assign(attachForDesc, "$(F_EmpName) Property Seq $(sequenceNumber)")
              @dtw_assign(attachPrg1, "HREMPL inner join PEPROP on EMCOMP=PRCOMP and EMFACL=PRFACL and EMEMPL=PREMPL Where EMEMID=$(employeeID) and PRSEQ=$(sequenceNumber)")

              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %INCLUDE "Attachment.icl"
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)EmplPropertyMaintain.d2w/REPORT$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (sec_01=="Y" && sec_04=="Y")
                          <a href="$(homeURL)$(cGIPath)EmplPropertyMaintain.d2w/REPORT$(d2wVarBase)&amp;maintenanceCode=Z">$(copyImageLrg)</a>
                      %endif
                      %if (sec_02 == "Y" || sec_03 == "Y")
                          <a href="$(homeURL)$(cGIPath)EmplPropertyMaintain.d2w/REPORT$(d2wVarBase)&amp;maintenanceCode=C">$(changeImageLrg)</a>
                      %endif
                      %if (sec_03 == "Y")
                          @Format_Confirm_Desc($(propertyDesc), "", $(propertyTypeDesc), $(propertyType), "", "", confirmDesc)
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)EmplPropertyMaintain.d2w/Edit_Data$(d2wVarBase)&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>

          <tr><td><h2>$(F_EmpName)</h2></td></tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)
      <table $(contentTable)>
          %ROW {
              <tr><td class="dsphdr">Sequence Number</td>
                  <td class="dspalph">$(V_PRSEQ)</td>
              </tr>
              <tr><td class="dsphdr">Property Type</td>
                  @RtvFldDesc("ODCOMP=$(V_PRCOMP) and ODTYPE='N' and ODCODE='$(V_PRTYPR)' ", "PECODE", "ODDESC", HrCodeDesc)
                  <td class="dspalph">$(HrCodeDesc)</td>
              </tr>

              <tr><td class="dsphdr">Property Description</td>
                  <td class="dspalph">$(V_PRDESC)</td>
              </tr>

              @Format_Date(V_PRISSU, "H", F_PRISSU)
              <tr><td class="dsphdr">Issue Date</td>
                  <td class="dspdate">$(F_PRISSU)</td>
              </tr>
              @Format_Date(V_PRRENW, "H", F_PRRENW)
              <tr><td class="dsphdr">Renewal Date</td>
                  <td class="dspnmbr">$(F_PRRENW)</td>
              </tr>
          %}	
      </table>
              %INCLUDE "AttachmentSQL.icl"
      $(hrTagAttr)	
      %INCLUDE "Copyright.icl"
  %}
%}

%INCLUDE "AttachmentSelect.icl"

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
 %else
   @Set_SQL(stmtSQL)
 %endif
%}