%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Report Description Search"
  d2wName                 = "ReportDescriptionSearch.d2w"
  d2wVarBase              = "$(genericVarBase))&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	          %INCLUDE "numedit.icl"
              function selectReport(report, desc){
                  window.opener.document.$(docName).$(fldName).value = report;
                  window.opener.document.$(docName).$(fldDesc).value = desc;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " GLWRDM ", fileSQL)
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, " GAGRRN='$(report)'", selectSQL)
                      %elseif (wildCardSearch!="")
                          @dtw_concat(selectSQL, " GAGRRN<>' '", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @ReportDescription_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) ReportDescription_Search (IN CHAR(64)    profileHandle,
     	                                CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Report Description</th>
                      <th class="colhdr">Report</th>
                      <th class="colhdr">User ID</th>
                      <th class="colhdr">Category</th>
                  </tr>
                  <tr>
                      <td class="inputalph">
                          <input type="text" name="srchReportDescription" size="30" maxlength="30">
                          <input type="hidden" name="operReportDescription" value="LIKE">
                      </td>
                      <td class="inputalph">
                          <input type="text" name="srchReport" size="15" maxlength="10">
                          <input type="hidden" name="operReport" value="LIKE">
                      </td>
                      <td class="inputalph">
                          <input type="text" name="srchUserID" size="15" maxlength="10">
                          <input type="hidden" name="operUserID" value="LIKE">
                      </td>
                      <td class="inputalph">
                          <input type="text" name="srchCategory" size="6" maxlength="4">
                          <input type="hidden" name="operCategory" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchReportDescription.focus();
              </script>
          </form>
	
          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("GAGRRDU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Report Description">Report Description</a></th>
                  @OrderBy_Sort("GAGRRN", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Report" title="Sequence By Report">Report</a></th>
                  @OrderBy_Sort("GAGRUI", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=User" title="Sequence By User ID">User ID</a></th>
                  @OrderBy_Sort("GAGRCT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Category" title="Sequence By Category">Category</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %else
          <table $(contentTable)>
      %endif		

              %ROW{
                  %INCLUDE "SetRowClass.icl"
                  @Format_Quote(V_GAGRRN, F_GAGRRN)
                  @Format_Quote(V_GAGRRD, F_GAGRRD)

    	     %if (moreInfo != "Y")	
                      <tr class="$(rowClass)">
                          <td class="colalph"><a href="javascript:selectReport('$(F_GAGRRN)','$(F_GAGRRD)')" title="Select Report Description">$(V_GAGRRD)</a></td>
                          <td class="colalph"> $(V_GAGRRN)</td>                                      	
                          <td class="colalph">$(V_GAGRUI)</td>
                          <td class="colcode">$(V_GAGRCT)</td>
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;report=@dtw_rurlescseq(V_GAGRRN)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                      </tr>

                  %else
                      %{ More Information Screen %}

                      <tr><td><a href="javascript:selectReport('$(F_GAGRRN)','$(F_GAGRRD)')" title="Select Report Description">$(selectImageLrg)</a>
                      </td></tr>

                      <tr><td class="dsphdr">Report</td>
                          <td class="dspalph">$(V_GAGRRN)</td>
                      </tr>
    	   		
                      <tr><td class="dsphdr">Report Description</td>
                          <td class="dspalph">$(V_GAGRRD)</td>
                      </tr>

                      <tr><td class="dsphdr">Report Heading One</td>
                          <td class="dspalph">$(V_GAGRH1)</td></tr>

                      <tr><td class="dsphdr"> Or Field Name</td>
                          <td class="dspalph">$(V_GAGRF1)</td></tr>

                      <tr><td class="dsphdr">Report Heading Two</td>
                          <td class="dspalph">$(V_GAGRH2)</td></tr>

                      <tr><td class="dsphdr"> Or Field Name</td>
                          <td class="dspalph">$(V_GAGRF2)</td></tr>

                      <tr><td class="dsphdr">Report Heading Three</td>
                          <td class="dspalph">$(V_GAGRH3)</td></tr>

                      <tr><td class="dsphdr"> Or Field Name</td>
                          <td class="dspalph">$(V_GAGRF3)</td></tr>

                      <tr><td class="dsphdr">Report Category</td>
                          <td class="dspalph">$(V_GAGRCT)</td></tr>

                      <tr><td class="dsphdr">Report Page Size</td>
                          <td class="dspalph">$(V_GARSSZ)</td></tr>

                      <tr><td class="dsphdr">User ID</td>
                          <td class="dspalph">$(V_GAGRUI)</td></tr>

                       @Format_Date(V_GALMNT, "D", F_GALMNT)
                      <tr><td class="dsphdr">Date Last Maintained</td>
                          <td class="dspalph">$(F_GALMNT)</td></tr>

                       @Format_Date(V_GALPRC, "D", F_GALPRC)
                      <tr><td class="dsphdr">Date Last Processed</td>
                          <td class="dspalph">$(F_GALPRC)</td></tr>
                  %endif
              %}
          </table>
	   %if (moreInfo != "Y")	
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
	   %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "GAGRRD,GAGRRN")
      @DTW_ASSIGN(orderByDisplay, "Name, Number")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}
%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(orderBy, "GAGRRN")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Description")
      %if (orderBy == "GAGRRDU")
          @DTW_ASSIGN(orderBy, "GAGRRDU DESC")
          @DTW_ASSIGN(orderByDisplay, "Report Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "GAGRRDU")
          @DTW_ASSIGN(orderByDisplay, "Report Description")
      %endif
  %elseif (sequence == "Report")
      %if (orderBy == "GAGRRN")
          @DTW_ASSIGN(orderBy, "GAGRRN DESC")
          @DTW_ASSIGN(orderByDisplay, "Report (descending)")
      %else
          @DTW_ASSIGN(orderBy, "GAGRRN")
          @DTW_ASSIGN(orderByDisplay, "Report")
      %endif
  %elseif (sequence == "User")
      %if (orderBy == "GAGRUI")
          @DTW_ASSIGN(orderBy, "GAGRUI DESC")
          @DTW_ASSIGN(orderByDisplay, "User ID (descending)")
      %else
          @DTW_ASSIGN(orderBy, "GAGRUI")
          @DTW_ASSIGN(orderByDisplay, "User ID ")
      %endif
  %elseif (sequence == "Category")
      %if (orderBy == "GAGRCT")
          @DTW_ASSIGN(orderBy, "GAGRCT DESC")
          @DTW_ASSIGN(orderByDisplay, "Category (descending)")
      %else
          @DTW_ASSIGN(orderBy, "GAGRCT")
          @DTW_ASSIGN(orderByDisplay, "Category")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("GAGRRN", "Report", $(srchReport), "U", operReport, "A")
  @Build_WildCard ("upper(GAGRRD)", "Report Description", $(srchReportDescription), "U", operReportDescription, "A")
  @Build_WildCard ("GAGRUI", "User ID", $(srchUserID), "U", operUserID, "A")
  @Build_WildCard ("GAGRCT", "Category", $(srchCategory), "U", operCategory, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}