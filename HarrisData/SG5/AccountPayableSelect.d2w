%FUNCTION(dtw_sql) AP_Select_Aging (IN  CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="aging"></a>
      %if (backHome == "")
          @dtw_assign(backHome, "$(d2wName)/REPORT")
      %endif
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      @dtw_assign(oneTime, "")
      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %endif
          %ROW{
              %if (sql_Record_Count > "0")
                  %if (oneTime == "")
                      @dtw_assign(oneTime, "Y")
                      @dtw_assign(StrtCPAGE2, @dtw_rAdd(V_CPAGE1, "1"))
                      @dtw_assign(StrtCPAGE3, @dtw_rAdd(V_CPAGE2, "1"))
                      @dtw_assign(StrtCPAGE4, @dtw_rAdd(V_CPAGE3, "1"))
                      @dtw_assign(StrtCPAGE5, @dtw_rAdd(V_CPAGE4, "1"))
                      @dtw_assign(StrtCPAGE6, @dtw_rAdd(V_CPAGE5, "1"))
                      <tr>
                          %if (V_CPBAON=="D")
                              @Format_Column_Header("", "Based On Due Date")
                          %else
                              @Format_Column_Header("", "Based On Invoice Date")
                          %endif
                          @Format_Column_Header("", "Current")
                          @Format_Column_Header("", "1 - $(V_CPAGE1)")
                          @Format_Column_Header("", "$(StrtCPAGE2) - $(V_CPAGE2)")
                          @Format_Column_Header("", "$(StrtCPAGE3) - $(V_CPAGE3)")
                          @Format_Column_Header("", "$(StrtCPAGE4) - $(V_CPAGE4)")
                          @Format_Column_Header("", "$(StrtCPAGE5) - $(V_CPAGE5)")
                          @Format_Column_Header("", "$(StrtCPAGE6) - over")
                          @Format_Column_Header("", "Total")
                      </tr>
                  %endif
              %endif

              %INCLUDE "SetRowClass.icl"

              %if (V_AICRDT=="C")
                  @dtw_assign(AmountHeader, "Credit")
              %else
                  @dtw_assign(AmountHeader, "Invoice")
              %endif

              @Format_Nbr($(V_AIAG0A), F_AIAG0A, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr($(V_AIAG1A), F_AIAG1A, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr($(V_AIAG2A), F_AIAG2A, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr($(V_AIAG3A), F_AIAG3A, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr($(V_AIAG4A), F_AIAG4A, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr($(V_AIAG5A), F_AIAG5A, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr($(V_AIAG6A), F_AIAG6A, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr($(V_AIAGTA), F_AIAGTA, "2", $(amtEditCode), "Y", "", "")

              <tr class="$(rowClass)">
                  <td class="dsphdr">$(AmountHeader) Amount</td>
                  %if (V_AIAG0C>"0")
                      <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=195&amp;fKey1=AIBCKT&amp;fVal1=1&amp;fKey2=CREDITINV&amp;fVal2=@dtw_rurlescseq(V_AICRDT)&amp;fDsc2=null" title="View Open Invoices">$(F_AIAG0A)</a></td>
                  %else
                      <td class="colnmbr">$(F_AIAG0A)</td>
                  %endif
                  %if (V_AIAG1C>"0")
                      <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=195&amp;fKey1=AIBCKT&amp;fVal1=2&amp;fKey2=CREDITINV&amp;fVal2=@dtw_rurlescseq(V_AICRDT)&amp;fDsc2=null" title="View Open Invoices">$(F_AIAG1A)</a></td>
                  %else
                      <td class="colnmbr">$(F_AIAG1A)</td>
                  %endif
                  %if (V_AIAG2C>"0")
                      <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=195&amp;fKey1=AIBCKT&amp;fVal1=3&amp;fKey2=CREDITINV&amp;fVal2=@dtw_rurlescseq(V_AICRDT)&amp;fDsc2=null" title="View Open Invoices">$(F_AIAG2A)</a></td>
                  %else
                      <td class="colnmbr">$(F_AIAG2A)</td>
                  %endif
                  %if (V_AIAG3C>"0")
                      <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=195&amp;fKey1=AIBCKT&amp;fVal1=4&amp;fKey2=CREDITINV&amp;fVal2=@dtw_rurlescseq(V_AICRDT)&amp;fDsc2=null" title="View Open Invoices">$(F_AIAG3A)</a></td>
                  %else
                      <td class="colnmbr">$(F_AIAG3A)</td>
                  %endif
                  %if (V_AIAG4C>"0")
                      <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=195&amp;fKey1=AIBCKT&amp;fVal1=5&amp;fKey2=CREDITINV&amp;fVal2=@dtw_rurlescseq(V_AICRDT)&amp;fDsc2=null" title="View Open Invoices">$(F_AIAG4A)</a></td>
                  %else
                      <td class="colnmbr">$(F_AIAG4A)</td>
                  %endif
                  %if (V_AIAG5C>"0")
                      <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=195&amp;fKey1=AIBCKT&amp;fVal1=6&amp;fKey2=CREDITINV&amp;fVal2=@dtw_rurlescseq(V_AICRDT)&amp;fDsc2=null" title="View Open Invoices">$(F_AIAG5A)</a></td>
                  %else
                      <td class="colnmbr">$(F_AIAG5A)</td>
                  %endif
                  %if (V_AIAG6C>"0")
                      <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=195&amp;fKey1=AIBCKT&amp;fVal1=7&amp;fKey2=CREDITINV&amp;fVal2=@dtw_rurlescseq(V_AICRDT)&amp;fDsc2=null" title="View Open Invoices">$(F_AIAG6A)</a></td>
                  %else
                      <td class="colnmbr">$(F_AIAG6A)</td>
                  %endif
                  %if (V_AIAGTC>"0")
                      <td class="colnmbr"><a href="$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=195&amp;fKey1=CREDITINV&amp;fVal1=@dtw_rurlescseq(V_AICRDT)&amp;fDsc1=null" title="View Open Invoices">$(F_AIAGTA)</a></td>
                  %else
                      <td class="colnmbr">$(F_AIAGTA)</td>
                  %endif
              </tr>

              %INCLUDE "SetRowClass.icl"

              @Format_Nbr($(V_AIAG0C), F_AIAG0C, "0", $(amtEditCode), "Y", "", "")
              @Format_Nbr($(V_AIAG1C), F_AIAG1C, "0", $(amtEditCode), "Y", "", "")
              @Format_Nbr($(V_AIAG2C), F_AIAG2C, "0", $(amtEditCode), "Y", "", "")
              @Format_Nbr($(V_AIAG3C), F_AIAG3C, "0", $(amtEditCode), "Y", "", "")
              @Format_Nbr($(V_AIAG4C), F_AIAG4C, "0", $(amtEditCode), "Y", "", "")
              @Format_Nbr($(V_AIAG5C), F_AIAG5C, "0", $(amtEditCode), "Y", "", "")
              @Format_Nbr($(V_AIAG6C), F_AIAG6C, "0", $(amtEditCode), "Y", "", "")
              @Format_Nbr($(V_AIAGTC), F_AIAGTC, "0", $(amtEditCode), "Y", "", "")

              <tr class="$(rowClass)">
                  <td class="dsphdr">$(AmountHeader) Count</td>
                  <td class="colnmbr">$(F_AIAG0C)</td>
                  <td class="colnmbr">$(F_AIAG1C)</td>
                  <td class="colnmbr">$(F_AIAG2C)</td>
                  <td class="colnmbr">$(F_AIAG3C)</td>
                  <td class="colnmbr">$(F_AIAG4C)</td>
                  <td class="colnmbr">$(F_AIAG5C)</td>
                  <td class="colnmbr">$(F_AIAG6C)</td>
                  <td class="colnmbr">$(F_AIAGTC)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) AP_Select_UnpostedSubLedger (IN  CHAR(64)    profileHandle,
                                                    CHAR(2)     dataBaseID,
                                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="unpostedsubledger"></a>
      %if (backHome == "")
          @dtw_assign(backHome, "$(d2wName)/REPORT")
      %endif
      @dtw_assign(moreURL, "$(homeURL)$(cGIPath)GLUnpostSubLedger.d2w/REPORT$(d2wVarBase)&amp;SubLedger=AP")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("WFFILE", "Sub-Ledger")
                  @Format_Column_Header("WFPER#", "Period")
                  @Format_Column_Header("WFJRNL", "Journal")
                  @Format_Column_Header("WFDATE", "Transaction Date")
                  @Format_Column_Header("WFTTYP", "Transaction Type")
                  @Format_Column_Header("WFDESC", "Description")
                  @Format_Column_Header("WFUAMT", "Amount")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @dtw_assign(F_WFPER#, V_WFPER#)
              @PeriodFromCYP(F_WFPER#)
              @Format_Date(V_WFDATE, "D", F_WFDATE)
              @Format_Nbr($(V_WFUAMT), F_WFUAMT, "2", $(amtEditCode), "Y", "", "")

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)GLHDAPTRJrnl.d2w/ENTRY$(genericVarBase)&amp;glJournal=@dtw_rurlescseq(V_WFJRNL)&amp;glPer=@dtw_rurlescseq(V_WFPER#)&amp;glDate=@dtw_rurlescseq(V_WFDATE)&amp;glTransType=@dtw_rurlescseq(V_WFTTYP)&amp;glFrCur=@dtw_rurlescseq(V_WFFCUR)" title="View Unposted $(V_WFDESC)">$(V_WFFILE)</a></td>
                  <td class="colnmbr">$(F_WFPER#)</td>
                  <td class="colalph">$(V_WFJRNL)</td>
                  <td class="colnmbr">$(F_WFDATE)</td>
                  <td class="colalph" $(helpCursor)><span title="$(V_WFTTYP)">$(V_transFLDESC)</span></td>
                  <td class="colalph">$(V_WFDESC)</td>
                  <td class="colnmbr">$(F_WFUAMT)</td>
              </tr>
	   %}
      </table>
      </fieldset>
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"

  @Set_SQL(stmtSQL)
%}