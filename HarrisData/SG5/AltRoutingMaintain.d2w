%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Alternate Routing Maintenance"
  d2wName                 = "AltRoutingMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;configurationType=@dtw_rurlescseq(configurationType)&amp;configurationID=@dtw_rurlescseq(configurationID)&amp;sequenceNumber=@dtw_rurlescseq(sequenceNumber)&amp;maintenanceCode=D"
  programName             = "HPD024"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  W_MHRC                  = ""
  W_MHRS                  = "0"
  W_PPHRS                 = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@plantNumber", "@dtw_rurlescseq(plantNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@itemNumber", "@dtw_rurlescseq(itemNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@configurationType", "@dtw_rurlescseq(configurationType)", "1", "a", workURL)
  @dtw_replace(workURL, "@@configurationID", "@dtw_rurlescseq(configurationID)", "1", "a", workURL)
  @dtw_replace(workURL, "@@sequenceNumber", "@dtw_rurlescseq(sequenceNumber)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @ItemUserView(profileHandle, dataBaseID, userPass, itemNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
        <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  function validate(chgForm) {
                      if (document.Chg.sequenceNumber.value =="" ||
                          document.Chg.department.value =="" ||
                          document.Chg.workcenter.value =="")
                             {alert("$(reqFieldError)");
                              return false;}
                      if (editNum(document.Chg.sequenceNumber, 3, 0) &&
                          editNum(document.Chg.piecesperhour, 8, 5) &&
                          editNum(document.Chg.measuredhours, 3, 4) &&
                          editNum(document.Chg.crewsize, 3, 2) &&
                          editNum(document.Chg.setuphours, 3, 2) &&
                          editNum(document.Chg.perunitrate, 8, 5) &&
                          editNum(document.Chg.transitdays, 3, 1))
                          return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
	                 %INCLUDE "numedit.icl"
              </script>
              %INCLUDE "$(genericHead)"
        </head>

        <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "ALTROUTINGMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "SELECT * FROM HDMART WHERE RAPLT=$(plantNumber) and RAPN='$(itemNumber)' and RACFGT='$(configurationType)' and RACFGI='$(configurationID)' and RASEQN=$(sequenceNumber)", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
        </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
      @RtvFldDesc("CHPLT=$(plantNumber) and CHITEM='$(itemNumber)' and CHCFGT='$(configurationType)' and CHCFGI='$(configurationID)' ", "HDCFGH", "CHCDSC", ConfigTypeDescription)
      %INCLUDE "MaintainTop.icl"

      <table $(contentTable)>
          @Format_Header("Plant", $(plantName), $(plantNumber))
          @Format_Header("Item", $(itemDescription), $(itemNumber))
          @Format_Header("Type/ID", $(ConfigTypeDescription), "$(configurationType)/$(configurationID)")
      </table>

      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;configurationType=@dtw_rurlescseq(configurationType)&amp;configurationID=@dtw_rurlescseq(configurationID)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "sequenceNumber")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@plt@", "plantNumber")        @dtw_assign(Err_RAPLT, fieldValue)
                          @DecatErr_Field("@@pn@@", "itemNumber")         @dtw_assign(Err_RAPN, fieldValue)
                          @DecatErr_Field("@@ctyp", "configurationType")        @dtw_assign(Err_RACFGT, fieldValue)
                          @DecatErr_Field("@@cid@", "configurationID")        @dtw_assign(Err_RACFGI, fieldValue)
                          @DecatErr_Field("@@seqn", "sequenceNumber")     @dtw_assign(Err_RASEQN, fieldValue)
                          @DecatErr_Field("@@dept", "department")         @dtw_assign(Err_RADEPT,   fieldValue)
                          @DecatErr_Field("@@wc@@", "workcenter")         @dtw_assign(Err_RAWC, fieldValue)
                          @DecatErr_Field("@@son@", "operationNumber")    @dtw_assign(Err_RASON,  fieldValue)
                          @DecatErr_Field("@@otyp", "routingtype")        @dtw_assign(Err_RAOTYP, fieldValue)
                          @DecatErr_Field("@@altc", "alternateoperation") @dtw_assign(Err_RAALTC, fieldValue)
                          @DecatErr_Field("@@pphr", "piecesperhour")      @dtw_assign(Err_PPHR, fieldValue)
                          @DecatErr_Field("@@mhrs", "measuredhours")      @dtw_assign(Err_RAMHRS, fieldValue)
                          @DecatErr_Field("@@mhrc", "measuredhoursref")   @dtw_assign(Err_RAMHRC, fieldValue)
                          @DecatErr_Field("@@mpon", "crewsize")           @dtw_assign(Err_RAMPON, fieldValue)
                          @DecatErr_Field("@@suhr", "setuphours")         @dtw_assign(Err_RASUHR, fieldValue)
                          @DecatErr_Field("@@surc", "setuphoursref")      @dtw_assign(Err_RASURC, fieldValue)
                          @DecatErr_Field("@@psuc", "perunitrate")        @dtw_assign(Err_RAPSUC, fieldValue)
                          @DecatErr_Field("@@mtd@", "transitdays")        @dtw_assign(Err_RAMTD, fieldValue)
                      %endif

                      @Decat_Field("@@plt@")   @dtw_assign(V_RAPLT, fieldValue)
                      @Decat_Field("@@pn@@")   @dtw_assign(V_RAPN, fieldValue)
                      @Decat_Field("@@ctyp")   @dtw_assign(V_RACFGT, fieldValue)
                      @Decat_Field("@@cid@")   @dtw_assign(V_RACFGI, fieldValue)
                      @Decat_Field("@@seqn")   @dtw_assign(V_RASEQN, fieldValue)
                      @Decat_Field("@@dept")   @dtw_assign(V_RADEPT, fieldValue)
                      @Decat_Field("@@wc@@")   @dtw_assign(V_RAWC,  fieldValue)
                      @Decat_Field("@@son@")   @dtw_assign(V_RASON, fieldValue)
                      @Decat_Field("@@otyp")   @dtw_assign(V_RAOTYP,  fieldValue)
                      @Decat_Field("@@altc")   @dtw_assign(V_RAALTC, fieldValue)
                      @Decat_Field("@@mhrs")   @dtw_assign(V_RAMHRS, fieldValue)
                      @Decat_Field("@@mhrc")   @dtw_assign(V_RAMHRC, fieldValue)
                      @Decat_Field("@@mpon")   @dtw_assign(V_RAMPON, fieldValue)
                      @Decat_Field("@@suhr")   @dtw_assign(V_RASUHR, fieldValue)
                      @Decat_Field("@@surc")   @dtw_assign(V_RASURC, fieldValue)
                      @Decat_Field("@@psuc")   @dtw_assign(V_RAPSUC, fieldValue)
                      @Decat_Field("@@lgrd")   @dtw_assign(V_RALGRD, fieldValue)
                      @Decat_Field("@@mach")   @dtw_assign(V_RAMACH, fieldValue)
                      @Decat_Field("@@mtd@")   @dtw_assign(V_RAMTD, fieldValue)
                      @Decat_Field("@@ntcd")   @dtw_assign(V_RANTCD, fieldValue)
                      @Decat_Field("@@cccd")   @dtw_assign(V_RACCCD, fieldValue)
                      @Decat_Field("@@maho")   @dtw_assign(V_RAMAHO, fieldValue)
                      @Decat_Field("@@fseq")   @dtw_assign(frmseq, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(V_RASEQN, "")
                          @dtw_assign(V_RAOTYP, "D")
                          @dtw_assign(V_RAALTC, "P")
                          @dtw_assign(focusField, "sequenceNumber")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(frmseq, $(sequenceNumber))
                      @dtw_assign(V_RASEQN, "")
                      @dtw_assign(focusField, "sequenceNumber")
                  %else
                      @dtw_assign(focusField, "department")
                      %if (V_RAMHRS != "0")
                          %if (V_RAMHRC== "P")
                              @DTW_DIVIDE("1", V_RAMHRS, W_PPHRS)
                          %endif
                          %if (V_RAMHRC== "H")
                              @DTW_DIVIDE("100", V_RAMHRS, W_PPHRS)
                          %endif
                          %if (V_RAMHRC== "M")
                              @DTW_DIVIDE("1000", V_RAMHRS, W_PPHRS)
                          %endif

                      %endif
                  %endif

                  @SetTextOvr(Err_RASEQN)
                  <tr><td class="dsphdr"><span $(textOvr)>Routing Sequence</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputnmbr"><input name="sequenceNumber" type="text" value="$(V_RASEQN)" size="3" maxlength="3"> $(reqFieldChar) </td>
                      %else
                          <td class="inputnmbr"><input name="sequenceNumber" type="hidden" value="$(V_RASEQN)" size="3" maxlength="3">$(V_RASEQN)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_RASEQN)

                  <tr><td><input type="hidden" name="frmseq" value="$(frmseq)" </td></tr>
                  @Default_Zero(V_RAPLT)
                  @dtw_assign(deptwcDesc, "")
                  @RtvFldDesc("WCPLT=$(V_RAPLT) and WCDEPT='$(V_RADEPT)' and WCWC='$(V_RAWC)'", "HDMWCM", "WCDESC", deptwcDesc)
                  @SetTextOvr(Err_RADEPT)
                  <tr><td class="dsphdr"><span $(textOvr)>Department / Work Center</span></td>
                      <td class="inputalph"><input name="department" value="$(V_RADEPT)" type="text" size="5" maxlength="5"> / <input name="workcenter" value="$(V_RAWC)" type="text" size="5" maxlength="5"> $(reqFieldChar) <a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(plantNumber)&amp;docName=Chg&amp;flddept=department&amp;fldWC=workcenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input disabled name="WCDesc" value="$(deptwcDesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_RADEPT)

                  @RtvFldDesc("SDSON='$(V_RASON)'", "HDMSDM", "SDDESC", sddesc)
                  @SetTextOvr(Err_RASON)
                  <tr><td class="dsphdr"><span $(textOvr)>Operation Number</span></td>
                      <td class="inputalph"><input name="operationNumber" value="$(V_RASON)" type="text" size="5" maxlength="5"> <a href="$(homeURL)$(cGIPath)OperationSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldoper=operationNumber&amp;fldDesc=sddesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="sddesc" value="$(sddesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_RASON)
    	      		
                  @RtvFldDesc("FLTYPE='RTGTYPE' and FLVALU='$(V_RAOTYP)'", "SYFLAG", "FLDESC", rtypDesc)
                  @SetTextOvr(Err_RAOTYP)
                  <tr><td class="dsphdr"><span $(textOvr)>Routing Type</span></td>
                      <td class="inputalph"><input name="routingtype" type="text" value="$(V_RAOTYP)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=RTGTYPE&amp;flagSrchHdr=@dtw_rurlescseq("Routing Type")&amp;docName=Chg&amp;fldName=routingtype&amp;fldDesc=routingtypeDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                      <input name="routingtypeDesc" value="$(rtypDesc)" type="text" size="30" disabled></td>
                  </tr>
                  @DspErrMsg(Err_RAOTYP)

                  @RtvFldDesc("FLTYPE='ALTOPER' and FLVALU='$(V_RAALTC)'", "SYFLAG", "FLDESC", altcDesc)
                  @SetTextOvr(Err_RAALTC)
                  <tr><td class="dsphdr"><span $(textOvr)>Alternate Operation</span></td>
                      <td class="inputalph"><input type="text" name="alternateoperation" value="$(V_RAALTC)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=ALTOPER&amp;flagSrchHdr=@dtw_rurlescseq("Alternate Operation")&amp;docName=Chg&amp;fldName=alternateoperation&amp;fldDesc=alternateoperationDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                      <input name="alternateoperationDesc" value="$(altcDesc)" type="text" size="30" disabled></td>
                  </tr>
                  @DspErrMsg(Err_RAALTC)

                  @DTW_FORMAT(W_PPHRS,"","5",PHR)
                  @SetTextOvr(Err_PPHR)
                  <tr><td class="dsphdr"><span $(textOvr)>Pieces Per Hour</span></td>
                      <td class="inputnmbr"><input type="text" name="piecesperhour"   value=$(PHR) size="14" maxlength="14"></td>
                  </tr>
                  @DspErrMsg(Err_PPHR)
    	   		
                  %if ((W_MHRS != ".0000") && (W_MHRS != "0"))
                      @dtw_assign(V_RAMHRS, W_MHRS)
                  %Endif
                  @SetTextOvr(Err_RAMHRS)
                  <tr><td class="dsphdr"><span $(textOvr)>Measured Hours</span></td>
                      <td class="inputnmbr"><input type="text" name="measuredhours" value="$(V_RAMHRS)" size="8" maxlength="8"></td>
                  </tr>
                  @DspErrMsg(Err_RAMHRS)
    	   		
                  %If (W_MHRC != "")
                      @dtw_assign(V_RAMHRC, W_MHRC)
                  %Endif
                  @RtvFldDesc("FLTYPE='RTMHRC' and FLVALU='$(V_RAMHRC)'", "SYFLAG", "FLDESC", mhrcDesc)
                  @SetTextOvr(Err_RAMHRC)
                  <tr><td class="dsphdr"><span $(textOvr)>Measured Hours Ref Code</span></td>
                      <td class="inputalph"><input type="text" name="measuredhoursref" value="$(V_RAMHRC)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=RTMHRC&amp;flagSrchHdr=@dtw_rurlescseq("Measured Hours Reference Code")&amp;docName=Chg&amp;fldName=measuredhoursref&amp;fldDesc=measuredhoursrefDesc" onclick="$(searchWinVar)"> $(searchImage) </a>
                      <input name="measuredhoursrefDesc" value="$(mhrcDesc)" type="text" size="30" disabled></td>
                  </tr>
                  @DspErrMsg(Err_RAMHRC)
    	   		
                  @SetTextOvr(Err_RASUHR)
                  <tr><td class="dsphdr"><span $(textOvr)>Standard Setup Hours</span></td>
                      <td class="inputnmbr"><input type="text" name="setuphours" value="$(V_RASUHR)" size="6" maxlength="6"></td>
                  </tr>
                  @DspErrMsg(Err_RASUHR)
    	   		
                  @RtvFldDesc("FLTYPE='RTSURC' and FLVALU='$(V_RASURC)'", "SYFLAG", "FLDESC", surcDesc)
                  @SetTextOvr(Err_RASURC)
                  <tr><td class="dsphdr"><span $(textOvr)>Setup Hours Reference Code</span></td>
                      <td class="inputalph"><input type="text" name="setuphoursref" value="$(V_RASURC)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=RTSURC&amp;flagSrchHdr=@dtw_rurlescseq("Setup Hours Reference Code")&amp;docName=Chg&amp;fldName=setuphoursref&amp;fldDesc=setuphoursrefDesc" onclick="$(searchWinVar)">  $(searchImage) </a>
                      <input name="setuphoursrefDesc" value="$(surcDesc)" type="text" size="30" disabled></td>
                  </tr>
                  @DspErrMsg(Err_RASURC)
    	   		
                  @SetTextOvr(Err_RAMPON)
                  <tr><td class="dsphdr"><span $(textOvr)>Crew Size</span></td>
                      <td class="inputnmbr"><input type="text" name="crewsize" value="$(V_RAMPON)" size="6" maxlength="6"></td>
                  </tr>
                  @DspErrMsg(Err_RAMPON)
    	   		
                  @SetTextOvr(Err_RAPSUC)
                  <tr><td class="dsphdr"><span $(textOvr)>Per Unit Rate</span></td>
                      <td class="inputnmbr"><input type="text" name="perunitrate" value="$(V_RAPSUC)" size="14" maxlength="14"></td>
                  </tr>
                  @DspErrMsg(Err_RAPSUC)
    	   		
                  @SetTextOvr(Err_RALGRD)
                  <tr><td class="dsphdr"><span $(textOvr)>Labor Grade</span></td>
                      <td class="inputalph"><input type="text" name="laborgrade" value="$(V_RALGRD)" size="2" maxlength="2"></td>
                  </tr>
                  @DspErrMsg(Err_RALGRD)
    	   		
                  @SetTextOvr(Err_RAMACH)
                  <tr><td class="dsphdr"><span $(textOvr)>Machine Number</span></td>
                      <td class="inputalph"><input type="text" name="machinenumber" value="$(V_RAMACH)" size="5" maxlength="5"></td>
                  </tr>
                  @DspErrMsg(Err_RAMACH)
    	   		
                  @SetTextOvr(Err_RAMTD)
                  <tr><td class="dsphdr"><span $(textOvr)>Transit Days</span></td>
                      <td class="inputalph"><input type="text" name="transitdays" value="$(V_RAMTD)" size="5" maxlength="5"></td>
                  </tr>
                  @DspErrMsg(Err_RAMTD)
    	   		
                  @SetTextOvr(Err_RAMAHO)
                  <tr><td class="dsphdr"><span $(textOvr)>Machine Hours Only</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_RAMAHO) && (x < maxRows))
                          {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "machhoursonly", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_RAMAHO)
    	   		
                  @SetTextOvr(Err_RANTCD)
                  <tr><td class="dsphdr"><span $(textOvr)>Routing Notes</span></td>
                      <td class="inputalph"><input type="hidden" name="routingnotes" value="$(V_RANTCD)" size="1" maxlength="1">$(V_RANTCD)</td>
                  </tr>
                  @DspErrMsg(Err_RANTCD)
    	   		
                  @SetTextOvr(Err_RACCCD)
                  <tr><td class="dsphdr"><span $(textOvr)>Cost Categories</span></td>
                      <td class="inputalph"><input type="hidden" name="costcategories" value="$(V_RACCCD)" size="1" maxlength="1">$(V_RACCCD)</td>
                  </tr>
                  @DspErrMsg(Err_RACCCD)

              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar,
                                        INOUT CHAR(1) W_MHRC,
                                        INOUT DEC(7, 4) W_MHRS,
                                        INOUT DEC(13, 5) W_PPHRS,
                                        INOUT CHAR(10) SUBR)
{%EXEC {HPD024_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @yn01_Table_Query(profileHandle, dataBaseID, "BY        ", yn01Table)

      @Set_SQL(stmtSQL)
  %endif
%}

%FUNCTION(dtw_directcall) Validate_COPYALL(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar,
                                        INOUT CHAR(1) W_MHRC,
                                        INOUT DEC(7, 4) W_MHRS,
                                        INOUT DEC(13, 5) W_PPHRS,
                                        INOUT CHAR(10) SUBR)
{%EXEC {HPD024_W.PGM %}
%}

%HTML(COPYALL) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  @RtvFldDesc("CHPLT=$(plantNumber) and CHITEM='$(itemNumber)' and CHCFGT='$(configurationType)' and CHCFGI='$(configurationID)' ", "HDCFGH", "CHCDSC", ConfigTypeDescription)

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
	       %INCLUDE "numedit.icl"
              %INCLUDE "NewWindowOpen.icl"
              function validate(chgForm) {
                 if (document.Chg.toconfigurationType.value =="" ||
                     document.Chg.toconfigurationID.value =="")
                       {alert("$(reqFieldError)");
                           return false;}
                 return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ALTROUTINGMAINTAIN")
                  @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
                  @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
                  @RtvFldDesc("CHPLT=$(plantNumber) and CHITEM='$(itemNumber)' and CHCFGT='$(configurationType)' and CHCFGI='$(configurationID)' ", "HDCFGH", "CHCDSC", ConfigTypeDescription)
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      <table $(baseTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1>Copy Alternate Routing</h1></td>
                              <td class="toolbar">
                                  %INCLUDE "MaintainTopNoTable.icl"
                              </td>
                          </tr>
                      </table>
                      <table $(contentTable)>
                          @Format_Header("Plant", $(plantName), $(plantNumber))
                          @Format_Header("Item", $(itemDescription), $(itemNumber))
                          @Format_Header("Type/ID", $(ConfigTypeDescription), "$(configurationType)/$(configurationID)")
                      </table>

                      $(hrTagAttr)
                      %INCLUDE "RequiredField.icl"
                      %INCLUDE "ErrorDisplay.icl"

                      <form class="formClass" METHOD=POST name="Chg" onSubmit="return validate(document.Chg)"  ACTION="$(homeURL)$(cGIPath)$(d2wName)/EDIT_COPYALL$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;configurationType=@dtw_rurlescseq(configurationType)&amp;configurationID=@dtw_rurlescseq(configurationID)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "toconfigurationType")
                              %if (errFound != "" || maintenanceCode == "A")
                                  %if (errFound == "" && maintenanceCode == "A")
                                      @dtw_assign(edtVar, "")
                                  %else
                                      @EdtVarErr(profileHandle, typeValue, edtVar)
                                      @ErrVarErr(profileHandle, typeError, errVar)
                                      @DecatErr_Field("@@cfgt", "toconfigurationType")   @dtw_assign(Err_TOTYPE,  fieldValue)
                                  %endif

                                  @Decat_Field("@@ttyp")   @dtw_assign(V_RACFGT,  fieldValue)
                                  @Decat_Field("@@tid@")   @dtw_assign(V_RACFGI,  fieldValue)

                                  @dtw_assign(errFound, "")

                              %elif (maintenanceCode == "Z")
                                  @dtw_assign(V_RACFGT, "")
                                  @dtw_assign(V_RACFGI, "")
                              %endif

                                  @dtw_assign(configdesc, "")
                                  @RtvFldDesc("CHPLT=$(plantNumber) and CHITEM='$(itemNumber)' and CHCFGT='$(toconfigurationType)' and CHCFGI='$(toconfigurationID)' ", "HDCFGH", "CHCDSC", configdesc)
                                  @SetTextOvr(Err_TOTYPE)
                                  <tr><td class="dsphdr"><span $(textOvr)>To Configuration Type/ID</span></td>
                                      <td class="inputalph"><input name="toconfigurationType" type="text" value="$(V_RACFGT)" size="5" maxlength="5"> / <input name="toconfigurationID" type="text" value="$(V_RACFGI)" size="5" maxlength="5"> $(reqFieldChar)  <a href="$(homeURL)$(cGIPath)ConfigHeaderSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldreleased=@dtw_rurlescseq(fldreleased)&amp;fldplt=@dtw_rurlescseq($(plantNumber))&amp;flditem=@dtw_rurlescseq($(itemNumber))&amp;fldtype=toconfigurationType&amp;fldid=toconfigurationID&amp;fldDesc=configdesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input disabled name="configdesc" value="$(configdesc)"  type="text" size="30" maxlength="30"></td>
                                  </tr>
                                  @DspErrMsg(Err_TOTYPE)

                          </table>
                          %INCLUDE "MaintainBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </form>
                  </td>
              </tr>
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(EDIT_COPYALL) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(itemNumber)
  @dtw_mUPPERCASE(configurationType)
  @dtw_mUPPERCASE(configurationID)
  @dtw_mUPPERCASE(toconfigurationType)
  @dtw_mUPPERCASE(toconfigurationID)

  @dtw_assign(plantNumber,@dtw_rstrip(plantNumber))

  @dtw_assign(SUBR, "SRCpyAll")

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@pn@@", itemNumber)
  @Concat_Field("@@ftyp", configurationType)
  @Concat_Field("@@fid@", configurationID)
  @Concat_Field("@@ttyp", toconfigurationType)
  @Concat_Field("@@tid@", toconfigurationID)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_COPYALL(profileHandle, dataBaseID, maintCode, errFound, edtVar, errVar, W_MHRC, W_MHRS, W_PPHRS, SUBR)

  %if (errFound == "")
      @dtw_assign(configurationType, toconfigurationType)
      @dtw_assign(configurationID, toconfigurationID)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)AltRoutings.d2w/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;configurationType=@dtw_rurlescseq(configurationType)&amp;configurationID=@dtw_rurlescseq(configurationID)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/COPYALL$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;configurationType=@dtw_rurlescseq(configurationType)&amp;configurationID=@dtw_rurlescseq(configurationID)&amp;toconfigurationType=@dtw_rurlescseq(toconfigurationType)&amp;toconfigurationID=@dtw_rurlescseq(toconfigurationID)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}

%FUNCTION(dtw_directcall) Validate_DELETEALL(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar,
                                        INOUT CHAR(1) W_MHRC,
                                        INOUT DEC(7, 4) W_MHRS,
                                        INOUT DEC(13, 5) W_PPHRS,
                                        INOUT CHAR(10) SUBR)
{%EXEC {HPD024_W.PGM %}
%}

%HTML(SRS3Del) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(SUBR, "SRS3Del")

  @dtw_assign(edtVar, "")
  @Concat_Field("@@fplt", plantNumber)
  @Concat_Field("@@fitm", itemNumber)
  @Concat_Field("@@ftyp", configurationType)
  @Concat_Field("@@fid@", configurationID)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_DELETEALL(profileHandle, dataBaseID, maintCode, errFound, edtVar, errVar, W_MHRC, W_MHRS, W_PPHRS, SUBR)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, "All Routings", "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)AltRoutings.d2w/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;configurationType=@dtw_rurlescseq(configurationType)&amp;configurationID=@dtw_rurlescseq(configurationID)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @DecatErr_Field("@@plt@", "plantNumber")
      @Format_ConfMsg_Desc("", $(fieldValue), "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)AltRoutings.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;configurationType=@dtw_rurlescseq(configurationType)&amp;configurationID=@dtw_rurlescseq(configurationID)&amp;sequenceNumber=@dtw_rurlescseq(sequenceNumber)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %endif
%}

%HTML(SRS7Del) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(SUBR, "SRS7Del")

  @dtw_assign(edtVar, "")
  @Concat_Field("@@fplt", plantNumber)
  @Concat_Field("@@fitm", itemNumber)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_DELETEALL(profileHandle, dataBaseID, maintCode, errFound, edtVar, errVar, W_MHRC, W_MHRS, W_PPHRS, SUBR)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, "All Routings", "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)AltRoutingConfiguration.d2w/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
  %else
      @DecatErr_Field("@@plt@", "plantNumber")
      @Format_ConfMsg_Desc("", $(fieldValue), "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)AltRoutingConfiguration.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(configurationType)
  @dtw_mUPPERCASE(configurationID)
  @dtw_mUPPERCASE(department)
  @dtw_mUPPERCASE(workcenter)
  @dtw_mUPPERCASE(operationNumber)
  @dtw_mUPPERCASE(routingtype)
  @dtw_mUPPERCASE(alternateoperation)
  @dtw_mUPPERCASE(measuredhoursref)
  @dtw_mUPPERCASE(setuphoursref)
  @dtw_mUPPERCASE(laborgrade)
  @dtw_mUPPERCASE(machinenumber)
  @dtw_mUPPERCASE(machhoursonly)

  @dtw_assign(plantNumber,@dtw_rstrip(plantNumber))
  @dtw_assign(sequenceNumber,@dtw_rstrip(sequenceNumber))
  @dtw_assign(piecesperhour,@dtw_rstrip(piecesperhour))
  @dtw_assign(measuredhours,@dtw_rstrip(measuredhours))
  @dtw_assign(crewsize,@dtw_rstrip(crewsize))
  @dtw_assign(setuphours,@dtw_rstrip(setuphours))
  @dtw_assign(perunitrate,@dtw_rstrip(perunitrate))
  @dtw_assign(transitdays,@dtw_rstrip(transitdays))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@pn@@", itemNumber)
  @Concat_Field("@@ctyp", configurationType)
  @Concat_Field("@@cid@", configurationID)
  @Concat_Field("@@seqn", sequenceNumber)
  @Concat_Field("@@dept", department)
  @Concat_Field("@@wc@@", workcenter)
  @Concat_Field("@@son@", operationNumber)
  @Concat_Field("@@otyp", routingtype)
  @Concat_Field("@@altc", alternateoperation)
  @Concat_Field("@@mhrs", measuredhours)
  @Concat_Field("@@mhrc", measuredhoursref)
  @Concat_Field("@@mpon", crewsize)
  @Concat_Field("@@suhr", setuphours)
  @Concat_Field("@@surc", setuphoursref)
  @Concat_Field("@@psuc", perunitrate)
  @Concat_Field("@@mtd@", transitdays)
  @Concat_Field("@@lgrd", laborgrade)
  @Concat_Field("@@mach", machinenumber)
  @Concat_Field("@@maho", machhoursonly)
  @Concat_Field("@@ntcd", routingnotes)
  @Concat_Field("@@cccd", costcategories)
  @Concat_Field("@@pphr", piecesperhour)
  @Concat_Field("@@fseq", frmseq)
  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif
  @dtw_concat(edtVar, "}{", edtVar)

  @dtw_assign(W_MHRC, "")
  @dtw_assign(W_MHRS, "0")
  @dtw_assign(W_PPHRS, piecesperhour)
  @dtw_assign(SUBR, "SRC4E")

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar, W_MHRC, W_MHRS, W_PPHRS, SUBR)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, "Routing Sequence", $(sequenceNumber), "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)AltRoutings.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;configurationType=@dtw_rurlescseq(configurationType)&amp;configurationID=@dtw_rurlescseq(configurationID)&amp;sequenceNumber=@dtw_rurlescseq(sequenceNumber)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@dept", "department")
      @Format_ConfMsg_Desc("", "Routing Sequence", $(sequenceNumber), "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)AltRoutings.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;configurationType=@dtw_rurlescseq(configurationType)&amp;configurationID=@dtw_rurlescseq(configurationID)&amp;sequenceNumber=@dtw_rurlescseq(sequenceNumber)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;configurationType=@dtw_rurlescseq(configurationType)&amp;configurationID=@dtw_rurlescseq(configurationID)&amp;sequenceNumber=@dtw_rurlescseq(sequenceNumber)&amp;W_MHRC=@dtw_rurlescseq(W_MHRC)&amp;W_MHRS=@dtw_rurlescseq(W_MHRS)&amp;W_PPHRS=@dtw_rurlescseq(W_PPHRS)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
