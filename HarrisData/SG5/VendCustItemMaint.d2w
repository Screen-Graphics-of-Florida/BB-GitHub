%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "$(vendCustHdg) Maintenance"
  d2wName                 = "VendCustItemMaint.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;vendCustNumber=@dtw_rurlescseq(vendCustNumber)&amp;vendCustName=@dtw_rurlescseq(vendCustName)&amp;vendCustFlag=@dtw_rurlescseq(vendCustFlag)&amp;vendCustId=@dtw_rurlescseq(vendCustId)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;custItemNo=@dtw_rurlescseq(custItemNo)&amp;maintenanceCode=D"
  programName             = "HHDVCM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  helpExt                 = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (vendCustFlag == "C")
      @dtw_assign(helpExt, " (Customer)")
      @dtw_assign(customerNumber, $(vendCustNumber))
      @CustomerUserView(profileHandle, dataBaseID, userPass, customerNumber, " ")
  %else
      @dtw_assign(helpExt, " (Vendor)")
      @dtw_assign(vendorNumber, $(vendCustNumber))
      @VendorUserView(profileHandle, dataBaseID, userPass, vendorNumber)
  %endif

  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
	           %INCLUDE "numedit.icl"
                  function confirmDelete() {return confirm("$(delRecordConf)")}
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  function validate(chgForm) {
                      if (document.Chg.itemNumber.value =="")
                             {alert("$(reqFieldError)"); return false;}
                      if (editNum(document.Chg.minQty, 9, 4) &&
                          editNum(document.Chg.minValue, 8, 5) &&
                          editNum(document.Chg.minWeight, 5, 2) &&
                          editNum(document.Chg.piecesPer, 5, 4) &&
                          editNum(document.Chg.leadTime, 3, 0))
                          return true;
                  }
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (maintenanceCode == "Z")
                          @dtw_assign(pageID, "VENDCUSTITEMMAINTADD")
                      %else
                          @dtw_assign(pageID, "VENDCUSTITEMMAINTCHG")
                      %endif
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "Select * From HDVCIT Where VCVCF='$(vendCustFlag)' and VCVNCS=$(vendCustNumber) and VCITEM='$(itemNumber)'", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (vendCustFlag == "C")
          @dtw_assign(vendCustHdg, "Customer Item")
      %else
          @dtw_assign(vendCustHdg, "Vendor Item")
      %endif

      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          %if (vendCustFlag == "C")
              @Format_Header("Customer", $(vendCustName), $(vendCustNumber))
          %else
              @Format_Header("Vendor", $(vendCustName), $(vendCustNumber))
          %endif
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      %if (vendCustFlag == "V")
          @dtw_assign(uomHdg, "Purchasing U/M")
          @dtw_assign(piecesHdg, "Pieces Per Stocking U/M")
      %else
          @dtw_assign(uomHdg, "EDI U/M")
          @dtw_assign(piecesHdg, "Pieces Per EDI U/M")
      %endif

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "itemNumber")
                      %else
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @dtw_assign(focusField, "")
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@vcf@", "vendCustFlag")   @dtw_assign(Err_VCVCF,  fieldValue)
                          @DecatErr_Field("@@vncs", "vendCustNumber")   @dtw_assign(Err_VCVNCS, fieldValue)
                          @DecatErr_Field("@@item", "itemNumber")   @dtw_assign(Err_VCITEM, fieldValue)
                          @DecatErr_Field("@@vcit", "custItemNo")   @dtw_assign(Err_VCVCIT, fieldValue)
                          @DecatErr_Field("@@moq@", "minQty")   @dtw_assign(Err_VCMOQ,  fieldValue)
                          @DecatErr_Field("@@mow@", "minWeight")   @dtw_assign(Err_VCMOW,  fieldValue)
                          @DecatErr_Field("@@mpa@", "minValue")   @dtw_assign(Err_VCMPA,  fieldValue)
                          @DecatErr_Field("@@mwrn", "belowMinWarn")   @dtw_assign(Err_VCMWRN, fieldValue)
                          @DecatErr_Field("@@ads@", "dropShipItem")   @dtw_assign(Err_VCADS,  fieldValue)
                          @DecatErr_Field("@@edi@", "ediCapable")   @dtw_assign(Err_VCEDI,  fieldValue)
                          @DecatErr_Field("@@uomb", "unitMeasure")   @dtw_assign(Err_VCUOMB, fieldValue)
                          @DecatErr_Field("@@pcpb", "piecesPer")   @dtw_assign(Err_VCPCPB, fieldValue)
                          @DecatErr_Field("@@lt@@", "leadTime")   @dtw_assign(Err_VCLT,   fieldValue)
                      %endif

                      @Decat_Field("@@vcf@")   @dtw_assign(V_VCVCF,  fieldValue)
                      @Decat_Field("@@vncs")   @dtw_assign(V_VCVNCS, fieldValue)
                      @Decat_Field("@@item")   @dtw_assign(V_VCITEM, fieldValue)
                      @Decat_Field("@@vcit")   @dtw_assign(V_VCVCIT, fieldValue)
                      @Decat_Field("@@moq@")   @dtw_assign(V_VCMOQ,  fieldValue)
                      @Decat_Field("@@mow@")   @dtw_assign(V_VCMOW,  fieldValue)
                      @Decat_Field("@@mpa@")   @dtw_assign(V_VCMPA,  fieldValue)
                      @Decat_Field("@@mwrn")   @dtw_assign(V_VCMWRN, fieldValue)
                      @Decat_Field("@@ads@")   @dtw_assign(V_VCADS,  fieldValue)
                      @Decat_Field("@@edi@")   @dtw_assign(V_VCEDI,  fieldValue)
                      @Decat_Field("@@uomb")   @dtw_assign(V_VCUOMB, fieldValue)
                      @Decat_Field("@@pcpb")   @dtw_assign(V_VCPCPB, fieldValue)
                      @Decat_Field("@@lt@@")   @dtw_assign(V_VCLT,   fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(V_VCMWRN, "N")
                          @dtw_assign(V_VCADS, "N")
                          @dtw_assign(V_VCEDI, "N")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(focusField, "itemNumber")
                      @dtw_assign(V_VCITEM,  "")
                      @dtw_assign(V_VCVCIT,  "")

                  %else
                      @dtw_assign(focusField, "custItemNo")
                  %endif

                  @SetTextOvr(Err_VCITEM)
                  <tr><td class="dsphdr"><span $(textOvr)>Item Number</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="itemNumber" type="text" value="$(V_VCITEM)" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=itemNumber&amp;fldDesc=itemDesc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input disabled name="itemDesc" type="text" size="30" maxlength="30"></td>
                      %else
                          <td class="inputalph"><input name="itemNumber" type="hidden" value="$(V_VCITEM)" size="15" maxlength="15">$(V_VCITEM) &nbsp; $(itemDescr)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_VCITEM)

                  @SetTextOvr(Err_VCVCIT)
                  <tr><td class="dsphdr"><span $(textOvr)>$(vendCustHdg)</span></td>
                      <td class="inputalph"><input name="custItemNo" type="text" value="$(V_VCVCIT)" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_VCVCIT)

                  @SetTextOvr(Err_VCMOQ)
                  <tr><td class="dsphdr"><span $(textOvr)>Minimum Qty Per Line</span></td>
                      <td class="inputnmbr"><input name="minQty" type="text" value="$(V_VCMOQ)" size="15" maxlength="15"></td>
                  </tr>
                  @DspErrMsg(Err_VCMOQ)
	   		
                  @SetTextOvr(Err_VCMPA)
                  <tr><td class="dsphdr"><span $(textOvr)>Minimum Value Per Line</span></td>
                      <td class="inputnmbr"><input name="minValue" type="text" value="$(V_VCMPA)" size="15" maxlength="15"></td>
                  </tr>
                  @DspErrMsg(Err_VCMPA)
	   		
                  @SetTextOvr(Err_VCMOW)
                  <tr><td class="dsphdr"><span $(textOvr)>Minimum Weight Per Line</span></td>
                      <td class="inputnmbr"><input name="minWeight" type="text" value="$(V_VCMOW)" size="9" maxlength="9"></td>
                  </tr>
                  @DspErrMsg(Err_VCMOW)
	   		
                  @SetTextOvr(Err_VCMWRN)
                  <tr><td class="dsphdr"><span $(textOvr)>Below Minimum Warning</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_VCMWRN) && (x < maxRows))
                            {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "belowMinWarn", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_VCMWRN)
	   		
                  @SetTextOvr(Err_VCADS)
                  <tr><td class="dsphdr"><span $(textOvr)>Drop Ship Item</span></td>
                      @dtw_tb_rows(yn02Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn02Table, x, "1") != V_VCADS) && (x < maxRows))
                            {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn02Table, "dropShipItem", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_VCADS)
	   		
                  @SetTextOvr(Err_VCEDI)
                  <tr><td class="dsphdr"><span $(textOvr)>EDI Capable</span></td>
                      @dtw_tb_rows(yn03Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn03Table, x, "1") != V_VCEDI) && (x < maxRows))
                            {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn03Table, "ediCapable", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_VCEDI)
	   		
                  %if (vendCustFlag=="V" || V_HDEDRL>"0")
                      @RtvFldDesc("UMUOM='$(V_VCUOMB)'", "HDUOM", "UMUMLD", fieldDesc)
                      @SetTextOvr(Err_VCUOMB)
                      <tr><td class="dsphdr"><span $(textOvr)>$(uomHdg)</span></td>
                          <td class="inputnmbr"><input name="unitMeasure" type="text" value="$(V_VCUOMB)" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)UnitOfMeasureSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=unitMeasure&amp;fldDesc=unitMeasureDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="unitMeasureDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                      </tr>
                      @DspErrMsg(Err_VCUOMB)
    			
                      @SetTextOvr(Err_VCPCPB)
                      <tr><td class="dsphdr"><span $(textOvr)>$(piecesHdg)</span></td>
                          <td class="inputnmbr"><input name="piecesPer" type="text" value="$(V_VCPCPB)" size="11" maxlength="11"></td>
                      </tr>
                      @DspErrMsg(Err_VCPCPB)
                  %else
                      <tr><td class="inputalph"><input type="hidden" name="unitMeasure" value="$(V_VCUOMB)"></td>
                          <td class="inputnmbr"><input type="hidden" name="piecesPer" value="$(V_VCPCPB)"></td></tr>
                  %endif
	   		
                  %if (vendCustFlag == "V")
                      @SetTextOvr(Err_WIWHS)
                      <tr><td class="dsphdr"><span $(textOvr)>Lead Time</span></td>
                          <td class="inputnmbr"><input name="leadTime" type="text" value="$(V_VCLT)" size="3" maxlength="3"></td>
                      </tr>
                      @DspErrMsg(Err_WIWHS)
                  %else
                      <tr><td class="inputnmbr"><input type="hidden" name="leadTime" value="$(V_VCLT)"></td></tr>
                  %endif
              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDVCM_W.PGM %}
%}

%HTML(ITEM) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescr)
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @yn02_Table_Query(profileHandle, dataBaseID, "YORN      ", yn02Table)
      @yn03_Table_Query(profileHandle, dataBaseID, "YORN      ", yn03Table)

      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(itemNumber)
  @dtw_mUPPERCASE(unitMeasure)

  @dtw_assign(minQty,@dtw_rstrip(minQty))
  @dtw_assign(minWeight,@dtw_rstrip(minWeight))
  @dtw_assign(minValue,@dtw_rstrip(minValue))
  @dtw_assign(piecesPer,@dtw_rstrip(piecesPer))
  @dtw_assign(leadTime,@dtw_rstrip(leadTime))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@vcf@", vendCustFlag)
  @Concat_Field("@@vncs", vendCustNumber)
  @Concat_Field("@@item", itemNumber)
  @Concat_Field("@@vcit", custItemNo)
  @Concat_Field("@@moq@", minQty)
  @Concat_Field("@@mow@", minWeight)
  @Concat_Field("@@mpa@", minValue)
  @Concat_Field("@@mwrn", belowMinWarn)
  @Concat_Field("@@ads@", dropShipItem)
  @Concat_Field("@@edi@", ediCapable)
  @Concat_Field("@@uomb", unitMeasure)
  @Concat_Field("@@pcpb", piecesPer)
  @Concat_Field("@@lt@@", leadTime)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)
  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(custItemNo), "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)vendcustitem.d2w/REPORT$(genericVarBase)&amp;vendCustNumber=@dtw_rurlescseq(vendCustNumber)&amp;vendCustName=@dtw_rurlescseq(vendCustName)&amp;vendCustFlag=@dtw_rurlescseq(vendCustFlag)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@item", "itemNumber")
      @Format_ConfMsg_Desc("", $(custItemNo), "", "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)vendcustitem.d2w/REPORT$(genericVarBase)&amp;vendCustNumber=@dtw_rurlescseq(vendCustNumber)&amp;vendCustName=@dtw_rurlescseq(vendCustName)&amp;vendCustFlag=@dtw_rurlescseq(vendCustFlag)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/ITEM$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;itemDescr=@dtw_rurlescseq(itemDescr)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}