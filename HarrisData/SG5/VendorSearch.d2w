%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Vendor Search"
  d2wName                 = "VendorSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;forVendor=@dtw_rurlescseq(forVendor)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;lineNumber=@dtw_rurlescseq(lineNumber)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %if (orderControlNumber == "")
                  function selectVendor(vendorNumber, vendorName){
                      window.opener.document.$(docName).$(fldName).value = vendorNumber;
                      window.opener.document.$(docName).$(fldDesc).value = vendorName;
                      window.opener.document.$(docName).$(fldName).focus();
                      window.close();
                  }
              %endif
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(uv_VendorName, "VMVEND")
                      @dtw_assign(uv_VendorTypeName, "VMVTYP")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " HDVEND ", fileSQL)
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, " VMVEND=$(vendorNumber)", selectSQL)
                      %elseif (forVendor != "")
                          @dtw_concat(selectSQL, " (VMVEND=$(forVendor) or VMRTVD=$(forVendor)) ", selectSQL)
                      %elseif (wildCardSearch!="" || uv_Sql!="")
                          @dtw_concat(selectSQL, " VMVEND>0 ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"

                      @Vendor_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Vendor_Search (IN  CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"

      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr"> Name</th></tr>
                  <tr><td><input type="text" class="inputalph" name="srchName" size="26" maxlength="26">
                          <input type="hidden" name="operName" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchName.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("VMVEND", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Number"  title="Sequence By Number"> Number</a></th>
                  @OrderBy_Sort("VMVNA1U", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Name"  title="Sequence By Name"> Name</a></th>
                  @OrderBy_Sort("VMVNA2U", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Address" title="Sequence By Address"> Address</a></th>
                  @OrderBy_Sort("VMVCTYU", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=City" title="Sequence By City, Name"> City</a></th>
                  @OrderBy_Sort("VMST", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=State" title="Sequence By State, Name"> State</a></th>
                  @OrderBy_Sort("VMZIP", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Zip" title="Sequence By Zip, Name"> Zip</a></th>
                  @OrderBy_Sort("VMPHON", sortVar)
                  <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Phone" title="Sequence By Phone"> Phone Number</a></th>
              </tr>
               %INCLUDE "NoRecordsFound.icl"
      %else
          <table $(contentTable)>
      %endif		

              %ROW{
                  @EditPhoneNumber(V_VMPHON)
                  %INCLUDE "SetRowClass.icl"
                  @Format_Quote(V_VMVNA1, F_VMVNA1)

    	           %if (moreInfo != "Y")	
                      <tr class="$(rowClass)">
                          <td class="colalph">$(V_VMVEND)</td>
                          <td class="colalph">
                              %if (orderControlNumber == "")
                                  <a href="javascript:selectVendor($(V_VMVEND), '$(F_VMVNA1)')" title="Select Vendor">$(V_VMVNA1)</a>
                              %else
                                  <a href="$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(d2wVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_VMVEND)" title="Select Vendor">$(V_VMVNA1)</a>
                              %endif
                          </td>
                          <td class="colalph">$(V_VMVNA2)</td>
                          <td class="colalph">$(V_VMVCTY)</td>
                          <td class="colcode">$(V_VMST)</td>
                          <td class="colnmbr">$(V_VMZIP)</td>
                          <td class="colnmbr">$(V_VMPHON)</td>
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)$(orderByVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_VMVEND)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                      </tr>

                  %else
                      @RtvFldDesc("CPSCR1<>' '", "APCTRL", "CPSCR1", UDF1)
                      @RtvFldDesc("CPSCR2<>' '", "APCTRL", "CPSCR2", UDF2)
                      @RtvFldDesc("CPSCR3<>' '", "APCTRL", "CPSCR3", UDF3)
                      @RtvFldDesc("CPSCR4<>' '", "APCTRL", "CPSCR4", UDF4)
                      @RtvFldDesc("CPSCR5<>' '", "APCTRL", "CPSCR5", UDF5)

                      <tr>
                          <td>
                              %if (orderControlNumber == "")
                                  <a href="javascript:selectVendor($(V_VMVEND), '$(F_VMVNA1)')" title="Select Vendor">$(selectImageLrg)</a>
                              %else
                                  <a href="$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(d2wVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_VMVEND)" title="Select Vendor">$(selectImageLrg)</a>
                              %endif
                          </td>
                      </tr>

                      <tr><td class="dsphdr">Vendor Number</td>
                          <td class="dspalph">$(V_VMVEND)</td>
                      </tr>

                      <tr><td class="dsphdr">Vendor Name</td>
                          <td class="dspalph">$(V_VMVNA1)</td></tr>

                      <tr><td class="dsphdr">Address</td>
                          <td class="dspalph">$(V_VMVNA2)</td></tr>	

                      <tr><td class="dsphdr">City</td>
                          <td class="dspalph">$(V_VMVCTY)</td></tr>

                      @RtvFldDesc("STID='$(V_VMST)'", "HDSTID", "STDESC", fieldDesc)
                      <tr><td class="dsphdr">State</td>
                          <td class="dspalph">$(fieldDesc)</td></tr>

                      <tr><td class="dsphdr">Zip</td>
                          <td class="dspalph">$(V_VMZIP)</td></tr>

                      <tr><td class="dsphdr">Phone Number</td>
                          <td class="dspnmbr">$(V_VMPHON)</td></tr>

                      @RtvFldDesc("CNCTCD='$(V_VMCTRY)'", "HDCTRY", "CNCDES", fieldDesc)
                      <tr><td class="dsphdr">Country</td>
                          <td class="dspalph">$(fieldDesc)</td></tr>

                      %if (UDF1 != "")
                          <tr><td class="dsphdr">$(UDF1)</td>
                              <td class="dspalph">$(V_VMUDF1)</td></tr>
                      %endif

                      %if (UDF2 != "")
                          <tr><td class="dsphdr">$(UDF2)</td>
                              <td class="dspalph">$(V_VMUDF2)</td></tr>
                      %endif

                      %if (UDF3 != "")
                          <tr><td class="dsphdr">$(UDF3)</td>
                              <td class="dspalph">$(V_VMUDF3)</td></tr>
                      %endif

                      %if (UDF4 != "")
                          <tr><td class="dsphdr">$(UDF4)</td>
                              <td class="dspalph">$(V_VMUDF4)</td></tr>
                      %endif

                      %if (UDF5 != "")
                          <tr><td class="dsphdr">$(UDF5)</td>
                              <td class="dspalph">$(V_VMUDF5)</td></tr>
                      %endif
                  %endif
              %}
          </table>
	   %if (moreInfo != "Y")	
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
	   %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "VMVNA1U,VMVEND")
      @DTW_ASSIGN(orderByDisplay, "Name")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Name")
      %if (orderBy == "VMVNA1U")
          @DTW_ASSIGN(orderBy, "VMVNA1U DESC")
          @DTW_ASSIGN(orderByDisplay, "Name (descending)")
      %else
          @DTW_ASSIGN(orderBy, "VMVNA1U")
          @DTW_ASSIGN(orderByDisplay, "Name")
      %endif
  %elseif (sequence == "Number")
      %if (orderBy == "VMVEND")
          @DTW_ASSIGN(orderBy, "VMVEND DESC")
          @DTW_ASSIGN(orderByDisplay, "Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "VMVEND")
          @DTW_ASSIGN(orderByDisplay, "Number")
      %endif
  %elseif (sequence == "Address")
      %if (orderBy == "VMVNA2U,VMVNA3U,VMVNA4U")
          @DTW_ASSIGN(orderBy, "VMVNA2U DESC,VMVNA3U DESC,VMVNA4U DESC")
          @DTW_ASSIGN(orderByDisplay, "Address (descending)")
      %else
          @DTW_ASSIGN(orderBy, "VMVNA2U,VMVNA3U,VMVNA4U")
          @DTW_ASSIGN(orderByDisplay, "Address")
      %endif
  %elseif (sequence == "City")
      %if (orderBy == "VMVCTYU,VMVNA1U")
          @DTW_ASSIGN(orderBy, "VMVCTYU DESC,VMVNA1U")
          @DTW_ASSIGN(orderByDisplay, "City (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "VMVCTYU,VMVNA1U")
          @DTW_ASSIGN(orderByDisplay, "City, Name")
      %endif
  %elseif (sequence == "State")
      %if (orderBy == "VMST,VMVNA1U")
          @DTW_ASSIGN(orderBy, "VMST DESC,VMVNA1U")
          @DTW_ASSIGN(orderByDisplay, "State (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "VMST,VMVNA1U")
          @DTW_ASSIGN(orderByDisplay, "State, Name")
      %endif
  %elseif (sequence == "Zip")
      %if (orderBy == "VMZIP,VMVNA1U")
          @DTW_ASSIGN(orderBy, "VMZIP DESC,VMVNA1U")
          @DTW_ASSIGN(orderByDisplay, "Zip (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "VMZIP,VMVNA1U")
          @DTW_ASSIGN(orderByDisplay, "Zip, Name")
      %endif
  %elseif (sequence == "Phone")
      %if (orderBy == "VMPHON")
          @DTW_ASSIGN(orderBy, "VMPHON DESC")
          @DTW_ASSIGN(orderByDisplay, "Phone (descending)")
      %else
          @DTW_ASSIGN(orderBy, "VMPHON")
          @DTW_ASSIGN(orderByDisplay, "Phone")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchPhone, 11, 0) &&
                      editNum(document.Search.srchNumber, 7, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "vendorsearch")
                  <td>
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)

                      @RtvFldDesc("CPSCR1<>' '", "APCTRL", "CPSCR1", UDF1)
                      @RtvFldDesc("CPSCR2<>' '", "APCTRL", "CPSCR2", UDF2)
                      @RtvFldDesc("CPSCR3<>' '", "APCTRL", "CPSCR3", UDF3)
                      @RtvFldDesc("CPSCR4<>' '", "APCTRL", "CPSCR4", UDF4)
                      @RtvFldDesc("CPSCR5<>' '", "APCTRL", "CPSCR5", UDF5)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Vendor Number</td>
                              @dtw_assign(operNbr, "operNumber")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchNumber" size="7" maxlength="7"></td>
                          </tr>

                          <tr><td class="dsphdr">Vendor Name</td>
                              @dtw_assign(operNbr, "operName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchName" size="26" maxlength="26"></td>
                          </tr>

                          <tr><td class="dsphdr">Address</td>
                              <td>&nbsp;</td>
                              <td class="inputalph"><input type="text" name="srchAddress" size="26" maxlength="26"></td>	
                          </tr>

                          <tr><td class="dsphdr">State</td>
                              @dtw_assign(operNbr, "operState")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchState" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Zip</td>
                              @dtw_assign(operNbr, "operZip")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchZip" size="14" maxlength="14"></td>
                          </tr>

                          <tr><td class="dsphdr">Phone Number</td>
                              <td>&nbsp;</td>
                              <td class="inputnmbr"> <input type="text" name="srchPhone" size="11" maxlength="11"></td>
                          </tr>

                          <tr><td class="dsphdr">Country</td>
                              @dtw_assign(operNbr, "operCountry")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCountry" size="3" maxlength="3"></td>
                          </tr>

                          %if (UDF1 != "")		
                              <tr><td class="dsphdr">$(UDF1)</td>
                                  @dtw_assign(operNbr, "operUdf1")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchUdf1" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (UDF2 != "")		
                              <tr><td class="dsphdr">$(UDF2)</td>
                                  @dtw_assign(operNbr, "operUdf2")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchUdf2" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (UDF3 != "")		
                              <tr><td class="dsphdr">$(UDF3)</td>
                                  @dtw_assign(operNbr, "operUdf3")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchUdf3" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (UDF4 != "")		
                              <tr><td class="dsphdr">$(UDF4)</td>
                                  @dtw_assign(operNbr, "operUdf4")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchUdf4" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %if (UDF5 != "")		
                              <tr><td class="dsphdr">$(UDF5)</td>
                                  @dtw_assign(operNbr, "operUdf5")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchUdf5" size="15" maxlength="15"></td>
                              </tr>
                          %endif

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchName.focus();
                          </script>
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @RtvFldDesc("CPSCR1<>' '", "APCTRL", "CPSCR1", UDF1)
  @RtvFldDesc("CPSCR2<>' '", "APCTRL", "CPSCR2", UDF2)
  @RtvFldDesc("CPSCR3<>' '", "APCTRL", "CPSCR3", UDF3)
  @RtvFldDesc("CPSCR4<>' '", "APCTRL", "CPSCR4", UDF4)
  @RtvFldDesc("CPSCR5<>' '", "APCTRL", "CPSCR5", UDF5)

  @Build_WildCard ("VMVNA1U", "Name", $(srchName), "U", operName, "A")

  @dtw_assign(srchAddress,@dtw_rstrip(srchAddress))
  %if (srchAddress != "")
      @dtw_mUPPERCASE(srchAddress)
      @dtw_replace(srchAddress, "?", "_", "1", "a", srchAddress)
      @dtw_replace(srchAddress, "*", "%", "1", "a", srchAddress)
      @dtw_concat(wildCardTemp, " AND (trim(VMVNA2U) LIKE '$(srchAddress)'", wildCardTemp)
      @dtw_concat(wildCardTemp, " OR   trim(VMVNA3U) LIKE '$(srchAddress)'", wildCardTemp)
      @dtw_concat(wildCardTemp, " OR   trim(VMVNA4U) LIKE '$(srchAddress)'", wildCardTemp)
      @dtw_concat(wildCardTemp, " OR   trim(VMVCTYU) LIKE '$(srchAddress)')", wildCardTemp)
  %endif
		
  @Build_WildCard ("VMVEND", "Vendor Number", $(srchNumber), "", operNumber, "N")
  @Build_WildCard ("VMST", "State", $(srchState), "U", operState, "A")
  @Build_WildCard ("VMZIP", "Zip", $(srchZip), "U", operZip, "A")
  @Build_WildCard ("VMPHON", "Phone Number", $(srchPhone), "", "", "P")
  @Build_WildCard ("VMCTRY", "Country", $(srchCountry), "U", operCountry, "A")
  @Build_WildCard ("VMUDF1", "$(UDF1)", $(srchUdf1), "U", operUdf1, "A")
  @Build_WildCard ("VMUDF2", "$(UDF2)", $(srchUdf2), "U", operUdf2, "A")
  @Build_WildCard ("VMUDF3", "$(UDF3)", $(srchUdf3), "U", operUdf3, "A")
  @Build_WildCard ("VMUDF4", "$(UDF4)", $(srchUdf4), "U", operUdf4, "A")
  @Build_WildCard ("VMUDF5", "$(UDF5)", $(srchUdf5), "U", operUdf5, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}

%HTML(UPDATE) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Update OEDTWK Set O1VEN1=$(vendorNumber) ", stmtSQL)
  @dtw_concat(stmtSQL, " Where O1OCTL=$(orderControlNumber) and O1ORL#=$(lineNumber) @@endsql ", stmtSQL)
  @SQL_Update(stmtSQL, status)

  <script TYPE="text/javascript">
      opener.location.href=opener.location.href;
      window.close()
  </script>
%}
