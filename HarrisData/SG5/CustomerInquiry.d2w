%INCLUDE "$(baseVar)"
%INCLUDE "ARControl$(dataBaseID).icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"

%Define {	
  page_title              = "Customer Inquiry"
  d2wName                 = "CustomerInquiry.d2w"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  BillToShipTo            = ""
%}
	
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onLoad="window.focus()" onBlur="window.close()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->

          %INCLUDE "PageTitle.icl"

          $(inquiryhrTagAttr)

          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      @dtw_assign(BillToShipTo, "Bill-To")
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " HDCUST ", fileSQL)
                      @dtw_concat(selectSQL, "CMCUST=$(customerNumber) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By CMCUST ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Customer_Inquiry(profileHandle, dataBaseID, stmtSQL)
                  </td>
                  %if (shipToCustomer != "" && shipToCustomer != $(customerNumber))
                      @dtw_assign(BillToShipTo, "Ship-To")
                      <td>
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " HDCUST ", fileSQL)
                          @dtw_concat(selectSQL, "CMCUST=$(shipToCustomer) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By CMCUST ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @Customer_Inquiry(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  %endif
              </tr>
          </table>

          $(inquiryhrTagAttr)
          %INCLUDE "Copyright.icl"

          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Customer_Inquiry (IN CHAR(64)    profileHandle,
				         CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (shipToCustomer != "" && shipToCustomer != $(customerNumber))
          <fieldset class="legendBody">
             <legend class="legendTitle">$(BillToShipTo)</legend>
      %endif

      <table $(contentTable)>
          %ROW{
              @EditPhoneNumber(V_CMPHON)
              <tr><td class="dsphdr">Customer</td>
                  <td class="dspalph">$(V_CMCUST)</td>
              </tr>

              <tr><td class="dsphdr">Customer Name</td>
                  <td class="dspalph">$(V_CMCNA1)</td></tr>

              <tr><td class="dsphdr">Address</td>
                  <td class="dspalph">$(V_CMCNA2)</td></tr>	

              <tr><td class="dsphdr">City</td>
                  <td class="dspalph">$(V_CMCCTY)</td></tr>

              @RtvFldDesc("STID='$(V_CMST)'", "HDSTID", "STDESC", fieldDesc)
              <tr><td class="dsphdr">State</td>
                  <td class="dspalph">$(fieldDesc)</td></tr>

              <tr><td class="dsphdr">Zip</td>
                  <td class="dspalph">$(V_CMZIP)</td></tr>

              <tr><td class="dsphdr">Phone Number</td>
                  <td class="dspnmbr">$(V_CMPHON)</td></tr>

              @RtvFldDesc("CNCTCD='$(V_CMCTRY)'", "HDCTRY", "CNCDES", fieldDesc)
              <tr><td class="dsphdr">Country</td>
                  <td class="dspalph">$(fieldDesc)</td></tr>

              %if (V_CRSCR1 != "")
                  <tr><td class="dsphdr">$(V_CRSCR1)</td>
                      <td class="dspalph">$(V_CMUDF1)</td></tr>
              %endif

              %if (V_CRSCR2 != "")
                  <tr><td class="dsphdr">$(V_CRSCR2)</td>
                      <td class="dspalph">$(V_CMUDF2)</td></tr>
              %endif

              %if (V_CRSCR3 != "")
                  <tr><td class="dsphdr">$(V_CRSCR3)</td>
                      <td class="dspalph">$(V_CMUDF3)</td></tr>
              %endif

              %if (V_CRSCR4 != "")
                  <tr><td class="dsphdr">$(V_CRSCR4)</td>
                      <td class="dspalph">$(V_CMUDF4)</td></tr>
              %endif

              %if (V_CRSCR5 != "")
                  <tr><td class="dsphdr">$(V_CRSCR5)</td>
                      <td class="dspalph">$(V_CMUDF5)</td></tr>
              %endif
          %}
      </table>
      %if (shipToCustomer != "" && shipToCustomer != $(customerNumber))
          </fieldset>
      %endif
  %}
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  @Set_SQL(stmtSQL)
%}