%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Cost Element Where Used Report"
  d2wName                 = "CostElementWhereUsedReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;apid=@dtw_rurlescseq(apid)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {

                      if  (editNum(document.Chg.fromPlantNumber, 3, 0) &&
                           editNum(document.Chg.toPlantNumber, 3, 0) &&
                           editNum(document.Chg.fromCostSet, 2, 0) &&
                           editNum(document.Chg.toCostSet, 2, 0) &&
                           editNum(document.Chg.fromCostElement, 3, 0) &&
                           editNum(document.Chg.toCostElement, 3, 0) &&
                           editFromToAll(document.Chg.fromPlantNumber, document.Chg.toPlantNumber, document.Chg.allPlantNumber, 3) &&
                           editFromToAll(document.Chg.fromCostSet, document.Chg.toCostSet, document.Chg.allCostSet, 2) &&
                           editFromToAll(document.Chg.fromCostElement, document.Chg.toCostElement, document.Chg.allCostElement, 3)
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "COSTELEMENTWHEREUSEDREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromPlantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@fplt", "fromPlantNumber")        @dtw_assign(Err_N1FPLNT,  fieldValue)
                                  @DecatErr_Field("@@tplt", "toPlantNumber")        @dtw_assign(Err_N1TPLNT,  fieldValue)
                                  @DecatErr_Field("@@aplt", "allPlantNumber")        @dtw_assign(Err_N1APLNT,  fieldValue)
                                  @DecatErr_Field("@@fset", "fromCostSet")        @dtw_assign(Err_N1FCSET,  fieldValue)
                                  @DecatErr_Field("@@tset", "toCostSet")        @dtw_assign(Err_N1TCSET,  fieldValue)
                                  @DecatErr_Field("@@aset", "allCostSet")        @dtw_assign(Err_N1ACSET,  fieldValue)
                                  @DecatErr_Field("@@felm", "fromCostElement")        @dtw_assign(Err_N1FCELM,  fieldValue)
                                  @DecatErr_Field("@@telm", "toCostElement")        @dtw_assign(Err_N1TCELM,  fieldValue)
                                  @DecatErr_Field("@@aelm", "allCostElement")        @dtw_assign(Err_N1ACELM,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@fplt")  @dtw_assign(V_N1FPLNT, fieldValue)
                                  @Decat_Field("@@tplt")  @dtw_assign(V_N1TPLNT, fieldValue)
                                  @Decat_Field("@@aplt")  @dtw_assign(V_N1APLNT, fieldValue)
                                  @Decat_Field("@@fset")  @dtw_assign(V_N1FCSET, fieldValue)
                                  @Decat_Field("@@tset")  @dtw_assign(V_N1TCSET, fieldValue)
                                  @Decat_Field("@@aset")  @dtw_assign(V_N1ACSET, fieldValue)
                                  @Decat_Field("@@felm")  @dtw_assign(V_N1FCELM, fieldValue)
                                  @Decat_Field("@@telm")  @dtw_assign(V_N1TCELM, fieldValue)
                                  @Decat_Field("@@aelm")  @dtw_assign(V_N1ACELM, fieldValue)

                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries
 Values %}

                                  %if (V_N1APLNT == "ALL")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPlantNumber, "")
                                  %endif
                                  %if (V_N1ACSET == "ALL")
                                      @dtw_assign(checkedallCostSet, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallCostSet, "")
                                  %endif
                                  %if (V_N1ACELM == "ALL")
                                      @dtw_assign(checkedallCostElement, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallCostElement, "")
                                  %endif

                              %else

                                  @RtvDftPlant(plantNumber, plantName)
                                  %if (plantNumber == "0")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(V_N1FPLNT, plantNumber)
                                      @dtw_assign(V_N1TPLNT, plantNumber)
                                      @dtw_assign(checkedallPlantNumber, "")
                                  %endif
                                  @dtw_assign(checkedallCostSet, "CHECKED")
                                  @dtw_assign(checkedallCostElement, "CHECKED")
                              %endif
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_N1FPLNT)
                              %if (textOvr == "") @SetTextOvr(Err_N1TPLNT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1APLNT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                  <td class="inputnmbr"><input name="fromPlantNumber" value="$(V_N1FPLNT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromPlantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toPlantNumber" value="$(V_N1TPLNT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toPlantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName" type="hidden"></td>
                                  <td class="inputalph"><input name="allPlantNumber" value='ALL' $(checkedallPlantNumber) type="checkbox" onClick="if (this.checked) this.form.fromPlantNumber.value='', this.form.toPlantNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FPLNT)
                              @DspErrMsg(Err_N1TPLNT)
                              @DspErrMsg(Err_N1APLNT)

                              @SetTextOvr(Err_N1FCSET)
                              %if (textOvr == "") @SetTextOvr(Err_N1TCSET) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ACSET) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Cost Set</span></td>
                                  <td class="inputnmbr"><input name="fromCostSet" value="$(V_N1FCSET)" type="text" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)CostElementSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldCostSet=fromCostSet&amp;fldCostElement=fromCostElement&amp;fldDesc=fcostSetDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fcostSetDesc" type="hidden"  </td>
                                  <td class="inputnmbr"><input name="toCostSet" value="$(V_N1TCSET)" type="text" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)CostElementSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldCostSet=toCostSet&amp;fldCostElement=toCostElement&amp;fldDesc=tcostSetDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="tcostSetDesc"  type="hidden"</td>
                                  <td class="inputalph"><input name="allCostSet" value='ALL' $(checkedallCostSet) type="checkbox" onClick="if (this.checked) this.form.fromCostSet.value='', this.form.toCostSet.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FCSET)
                              @DspErrMsg(Err_N1TCSET)
                              @DspErrMsg(Err_N1ACSET)

                              @SetTextOvr(Err_N1FCELM)
                              %if (textOvr == "") @SetTextOvr(Err_N1TCELM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ACELM) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Cost Element</span></td>
                                  <td class="inputnmbr"><input name="fromCostElement" value="$(V_N1FCELM)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(cGIPath)CostElementSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldCostSet=fromCostSet&amp;fldCostElement=fromCostElement&amp;fldDesc=fcostSetDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fcostSetDesc" type="hidden"</td>
                                  <td class="inputnmbr"><input name="toCostElement" value="$(V_N1TCELM)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(cGIPath)CostElementSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldCostSet=toCostSet&amp;fldCostElement=toCostElement&amp;fldDesc=tcostSetDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="tcostSetDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allCostElement" value='ALL' $(checkedallCostElement) type="checkbox" onClick="if (this.checked) this.form.fromCostElement.value='', this.form.toCostElement.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FCELM)
                              @DspErrMsg(Err_N1TCELM)
                              @DspErrMsg(Err_N1ACELM)
                          </table>

                          @dtw_assign(envProgram, "HSCEWR")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSCEWS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allPlantNumber)
  @dtw_mUPPERCASE(allCostSet)
  @dtw_mUPPERCASE(allCostElement)

  @dtw_assign(fromPlantNumber,@dtw_rstrip(fromPlantNumber))
  @dtw_assign(toPlantNumber,@dtw_rstrip(toPlantNumber))
  @dtw_assign(fromCostSet,@dtw_rstrip(fromCostSet))
  @dtw_assign(toCostSet,@dtw_rstrip(toCostSet))
  @dtw_assign(fromCostElement,@dtw_rstrip(fromCostElement))
  @dtw_assign(toCostElement,@dtw_rstrip(toCostElement))

  %if (allPlantNumber != "ALL")
      @dtw_assign(allPlantNumber, "")
  %endif
  %if (allCostSet != "ALL")
      @dtw_assign(allCostSet, "")
  %endif
  %if (allCostElement != "ALL")
      @dtw_assign(allCostElement, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@fplt", fromPlantNumber)
  @Concat_Field("@@tplt", toPlantNumber)
  @Concat_Field("@@aplt", allPlantNumber)
  @Concat_Field("@@fset", fromCostSet)
  @Concat_Field("@@tset", toCostSet)
  @Concat_Field("@@aset", allCostSet)
  @Concat_Field("@@felm", fromCostElement)
  @Concat_Field("@@telm", toCostElement)
  @Concat_Field("@@aelm", allCostElement)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}