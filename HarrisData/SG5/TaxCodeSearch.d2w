%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Tax Code Search"
  d2wName                 = "TaxCodeSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
  advanceSearch           = "N"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectTaxCode(taxCode, desc){
                  window.opener.document.$(docName).$(fldName).value = taxCode;
		          if (window.opener.document.$(docName).$(fldDesc))
	 	             {window.opener.document.$(docName).$(fldDesc).value = desc;} 
		          else if (window.opener.document.getElementById('$(fldDesc)'))
		                  {window.opener.document.getElementById('$(fldDesc)').innerHTML = desc;}
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select TCCODE, TCDESC, upper(TCDESC) as TCDESCU, TCTXBL ", stmtSQL)
                      @dtw_concat(fileSQL, " HDTAXC ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, "TCCODE<>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Tax_Code_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Tax_Code_Search (IN CHAR(64) profileHandle,
				        CHAR(2)   dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr"> Description</th>
                  <th class="colhdr"> Tax<br>Code</th>
              </tr>
              <tr><td class="inputalph">
                      <input type="text" name="srchDesc" size="15" maxlength="30">
                      <input type="hidden" name="operDesc" value="LIKE">
                  </td>
                  <td class="inputalph">
                      <input type="text" name="srchTaxCode" size="4" maxlength="4">
                      <input type="hidden" name="operTaxCode" value="LIKE">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
          <script TYPE="text/javascript">
              document.Search.srchDesc.focus();
          </script>
      </form>

      %INCLUDE "WildCardPage.icl"

      <table $(contentTable)>
          <tr>	
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("TCDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=description" title="Sequence By Description, Tax Code"> Description</a></th>
              @OrderBy_Sort("TCCODE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=taxCode" title="Sequence By Tax Code, Description"> Tax<br>Code</a></th>
              @OrderBy_Sort("TCTXBL", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=taxable" title="Sequence By Taxable, Tax Code"> Taxable</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Quote(V_TCCODE, F_TCCODE)
              @Format_Quote(V_TCDESC, F_TCDESC)

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="javascript:selectTaxCode('$(F_TCCODE)', '$(F_TCDESC)')" title="Select Tax Code)">$(V_TCDESC)</a></td>
                  <td class="colcode">$(V_TCCODE)</td>
                  <td class="colcode">$(V_TCTXBL)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "TCDESCU,TCCODE")
      @DTW_ASSIGN(orderByDisplay, "Description, Tax Code")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "description")
      %if (orderBy == "TCDESCU,TCCODE")
          @DTW_ASSIGN(orderBy, "TCDESCU DESC,TCCODE")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Tax Code")
      %else
          @DTW_ASSIGN(orderBy, "TCDESCU,TCCODE")
          @DTW_ASSIGN(orderByDisplay, "Description, Tax Code")
      %endif
  %elif (sequence == "taxCode")
      %if (orderBy == "TCCODE")
          @DTW_ASSIGN(orderBy, "TCCODE DESC")
          @DTW_ASSIGN(orderByDisplay, "Tax Code (descending)")
      %else
          @DTW_ASSIGN(orderBy, "TCCODE")
          @DTW_ASSIGN(orderByDisplay, "Tax Code")
      %endif
  %elif (sequence == "taxable")
      %if (orderBy == "TCTXBL,TCCODE")
          @DTW_ASSIGN(orderBy, "TCTXBL DESC,TCCODE")
          @DTW_ASSIGN(orderByDisplay, "Taxable (descending), Tax Code")
      %else
          @DTW_ASSIGN(orderBy, "TCTXBL,TCCODE")
          @DTW_ASSIGN(orderByDisplay, "Taxable, Tax Code")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("upper(TCDESC)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("TCCODE", "Tax Code", $(srchTaxCode), "U", operTaxCode, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}