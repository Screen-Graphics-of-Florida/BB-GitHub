%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Vendor/Customer Item List"
  d2wName                 = "VendCustItemList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)&amp;apid=@dtw_rurlescseq(apid)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "2"
  helpExt                 = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  %if (apid == "OE")
      @dtw_assign(helpExt, " (Customer)")
      @dtw_assign(page_title, "Customer Item List")
  %else
      @dtw_assign(helpExt, " (Vendor)")
      @dtw_assign(page_title, "Vendor Item List")
  %endif
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromCustomerVendorNumber, 7, 0) &&
                      editNum(document.Chg.toCustomerVendorNumber, 7, 0) &&
                      editFromToAll(document.Chg.fromCustomerVendorNumber, document.Chg.toCustomerVendorNumber, document.Chg.allCustomerVendorNumber, 7) &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A"))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CUSTOMERVENDORITEMLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromCustomerVendorNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@scvn", "sortCustomerVendorNumber")        @dtw_assign(Err_N1SVN#,  fieldValue)
                                  @DecatErr_Field("@@sitm", "sortItemNumber")        @dtw_assign(Err_N1SITM,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@pwhs")  @dtw_assign(V_N1PWHS,  fieldValue)
                                  @Decat_Field("@@pcmt")  @dtw_assign(V_N1PCMT,  fieldValue)
                                  @Decat_Field("@@fcvn")  @dtw_assign(V_N1FVN#,  fieldValue)
                                  @Decat_Field("@@tcvn")  @dtw_assign(V_N1TVN#,  fieldValue)
                                  @Decat_Field("@@acvn")  @dtw_assign(V_N1AVN#,  fieldValue)
                                  @Decat_Field("@@scvn")  @dtw_assign(V_N1SVN#,  fieldValue)
                                  @Decat_Field("@@fitm")  @dtw_assign(V_N1FITM,  fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N1TITM,  fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N1AITM,  fieldValue)
                                  @Decat_Field("@@sitm")  @dtw_assign(V_N1SITM,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1PWHS == "1")
                                      @dtw_assign(checkedWarehouseDetail, "CHECKED")
                                  %else
                                      @dtw_assign(checkedWarehouseDetail, "")
                                  %endif
                                  %if (V_N1PCMT == "1")
                                      @dtw_assign(checkedComments, "CHECKED")
                                  %else
                                      @dtw_assign(checkedComments, "")
                                  %endif
                                  %if (V_N1AVN# == "ALL")
                                      @dtw_assign(checkedallCustomerVendorNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallCustomerVendorNumber, "")
                                  %endif
                                  %if (V_N1AITM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedWarehouseDetail, "")
                                  @dtw_assign(checkedComments, "")
                                  @dtw_assign(checkedallCustomerVendorNumber, "CHECKED")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                              %endif

                          </table>

                          <table $(contentTable)>

                              <tr><td class="dsphdr"><span $(textOvr)>Select Options</span></td>
                                  <td class="inputnmbr"><input name="warehouseDetail" type="checkbox" VALUE='1' $(checkedWarehouseDetail)>Warehouse Detail</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="comments" type="checkbox" VALUE='1' $(checkedComments)>Comments</td>
                              </tr>

                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                              </tr>

                              %if (apid == "OE")
                                  @SetTextOvr(Err_N1FVN#)
                                  %if (textOvr == "") @SetTextOvr(Err_N1SVN#) %endif
                                  <tr><td  class="dsphdr"><span $(textOvr)>Customer Number</span></td>
                                      <td class="inputnmbr"><input name="fromCustomerVendorNumber" value="$(V_N1FVN#)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromCustomerVendorNumber&amp;fldDesc=fcustomerName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="fcustomerName" type="hidden"></td>
                                      <td class="inputnmbr"><input name="toCustomerVendorNumber" value="$(V_N1TVN#)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)CustomerSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toCustomerVendorNumber&amp;fldDesc=fcustomerName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="fcustomerName" type="hidden"></td>
                                      <td class="inputalph"><input name="allCustomerVendorNumber" value='ALL' $(checkedallCustomerVendorNumber) type="checkbox" onClick="if (this.checked) this.form.fromCustomerVendorNumber.value='', this.form.toCustomerVendorNumber.value='';"></td>
                                      @Build_Sort_Select("sortCustomerVendorNumber", "$(V_N1SVN#)")
                                  </tr>
                                  @DspErrMsg(Err_N1SVN#)

                              %else

                                  @SetTextOvr(Err_N1FVN#)
                                  %if (textOvr == "") @SetTextOvr(Err_N1SVN#) %endif
                                  <tr><td  class="dsphdr"><span $(textOvr)>Vendor Number</span></td>
                                      <td class="inputnmbr"><input name="fromCustomerVendorNumber" value="$(V_N1FVN#)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromCustomerVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="vendorName" type="hidden"></td>
                                      <td class="inputnmbr"><input name="toCustomerVendorNumber" value="$(V_N1TVN#)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toCustomerVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="vendorName" type="hidden"></td>
                                      <td class="inputalph"><input name="allCustomerVendorNumber" value='ALL' $(checkedallCustomerVendorNumber) type="checkbox" onClick="if (this.checked) this.form.fromCustomerVendorNumber.value='', this.form.toCustomerVendorNumber.value='';"></td>
                                      @Build_Sort_Select("sortCustomerVendorNumber", "$(V_N1SVN#)")
                                  </tr>
                                  @DspErrMsg(Err_N1SVN#)
                              %endif

                              @SetTextOvr(Err_N1FITM)
                              %if (textOvr == "") @SetTextOvr(Err_N1SITM) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N1FITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N1TITM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                                  @Build_Sort_Select("sortItemNumber", "$(V_N1SITM)")
                              </tr>
                              @DspErrMsg(Err_N1SITM)
                          </table>

                          @dtw_assign(envProgram, "HHDVIL")
                          @dtw_assign(envPrinter, "HHDVILPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HHDVIS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  %if (errFound == "Y")
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @Decat_Field("@@apid")
      %if (apid != fieldValue)
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)&amp;apid=@dtw_rurlescseq(fieldValue)&amp;errFound=Y&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
      %endif
  %endif
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allCustomerVendorNumber)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)

  @dtw_assign(fromCustomerVendorNumber,@dtw_rstrip(fromCustomerVendorNumber))
  @dtw_assign(toCustomerVendorNumber,@dtw_rstrip(toCustomerVendorNumber))
  @dtw_assign(sortCustomerVendorNumber,@dtw_rstrip(sortCustomerVendorNumber))
  @dtw_assign(sortItemNumber,@dtw_rstrip(sortItemNumber))

  %if (allCustomerVendorNumber != "ALL")
      @dtw_assign(allCustomerVendorNumber, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@apid", apid)
  @Concat_Field("@@pwhs", warehouseDetail)
  @Concat_Field("@@pcmt", comments)
  @Concat_Field("@@fcvn", fromCustomerVendorNumber)
  @Concat_Field("@@tcvn", toCustomerVendorNumber)
  @Concat_Field("@@acvn", allCustomerVendorNumber)
  @Concat_Field("@@scvn", sortCustomerVendorNumber)
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@sitm", sortItemNumber)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}