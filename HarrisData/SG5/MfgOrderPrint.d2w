%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Manufacturing Order Print"
  d2wName                 = "MfgOrderPrint.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  forPlant                = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              function confirmSbmSched()  {return confirm("Confirm $(page_title)");}
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {

                      if ((document.Chg.plantNumber.value =="") || (document.Chg.plantNumber.value =="0") || (document.Chg.plantNumber.value =="00") || (document.Chg.plantNumber.value =="000"))
                     {alert("$(reqFieldError)");
                      document.Chg.plantNumber.focus();
                      document.Chg.plantNumber.select();
                      return false;}

                  if (editNum(document.Chg.plantNumber, 3, 0) &&
                      editNum(document.Chg.fromBuyerAnalyst, 7, 0) &&
                      editNum(document.Chg.toBuyerAnalyst, 7, 0) &&
                      editNum(document.Chg.fromSalesOrder, 8, 0) &&
                      editNum(document.Chg.toSalesOrder, 8, 0) &&
                      editNum(document.Chg.fromSalesOrderLine, 3, 0) &&
                      editNum(document.Chg.toSalesOrderLine, 3, 0) &&
                   %{   editNum(document.Chg.horizonDate, 6, 0) && %}
                   %{   editdate(document.Chg.horizonDate) && %}
                      editFromToAll(document.Chg.fromOrderNumber, document.Chg.toOrderNumber, document.Chg.allOrderNumber, "A") &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromDepartment, document.Chg.toDepartment, document.Chg.allDepartment, "A") &&
                      editFromToAll(document.Chg.fromWorkCenter, document.Chg.toWorkCenter, document.Chg.allWorkCenter, "A") &&
                      editFromToAll(document.Chg.fromProductClass, document.Chg.toProductClass, document.Chg.allProductClass, "A") &&
                      editFromToAll(document.Chg.fromBuyerAnalyst, document.Chg.toBuyerAnalyst, document.Chg.allBuyerAnalyst, "7") &&
                      editFromToAll(document.Chg.fromReference, document.Chg.toReference, document.Chg.allReference, "A") &&
                      editFromToAll(document.Chg.fromSalesOrder, document.Chg.toSalesOrder, document.Chg.allSalesOrder, "8") &&
                      editFromToAll(document.Chg.fromSalesOrderLine, document.Chg.toSalesOrderLine, document.Chg.allSalesOrderLine, "3") &&
                      editFromToAll(document.Chg.fromUser, document.Chg.toUser, document.Chg.allUser, "A")
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      %if (printReportConfirm == "Y")
          <body $(bodyTagAttr)>
      %else
          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
      %endif
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "MFGORDERPRINT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %if (printReportConfirm == "Y")
                          @dtw_assign(sbmSchConfirm, "onClick=""return confirmSbmSched()""")
                      %endif
                      %if (fromMO != "" && backHome == "@@backHome")
                          %if (fromPlant != "")
                              @dtw_assign(backHome, "hdList.php$(altVarBase)&tblID=445&tag=QSEARCH&fKey1=OHPLT&fVal1=$(fromPlant)&fKey2=OHORD&fVal2=$(fromMO)")
                          %else
                              @dtw_assign(backHome, "hdList.php$(altVarBase)&tblID=445&tag=QSEARCH&fKey1=OHORD&fVal1=$(fromMO)")
                          %endif
                      %endif
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
                      %INCLUDE "RequiredField.icl"
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "plantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@plt@", "plantNumber")        @dtw_assign(Err_N1PLT,  fieldValue)
                                  @DecatErr_Field("@@fsor", "fromSalesOrder")     @dtw_assign(Err_N1FSORD,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}

                                  @Decat_Field("@@plt@")  @dtw_assign(V_N1PLT,  fieldValue)

                                  @Decat_Field("@@hzdt")  @dtw_assign(V_N1HZDT,  fieldValue)

                                  @Decat_Field("@@summ")  @dtw_assign(V_N1SEL,  fieldValue)
                                  
                                  @Decat_Field("@@grpd")  @dtw_assign(V_N1GRPD,  fieldValue)

                                  @Decat_Field("@@ford")  @dtw_assign(V_N1FORD,  fieldValue)
                                  @Decat_Field("@@tord")  @dtw_assign(V_N1TORD,  fieldValue)
                                  @Decat_Field("@@aord")  @dtw_assign(V_N1AORD,  fieldValue)

                                  @Decat_Field("@@fitm")  @dtw_assign(V_N1FITEM, fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N1TITEM, fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N1AITEM, fieldValue)

                                  @Decat_Field("@@fdpt")  @dtw_assign(V_N1FDEPT,  fieldValue)
                                  @Decat_Field("@@tdpt")  @dtw_assign(V_N1TDEPT,  fieldValue)
                                  @Decat_Field("@@adpt")  @dtw_assign(V_N1ADEPT,  fieldValue)

                                  @Decat_Field("@@fwc@")  @dtw_assign(V_N1FWC,  fieldValue)
                                  @Decat_Field("@@twc@")  @dtw_assign(V_N1TWC,  fieldValue)
                                  @Decat_Field("@@awc@")  @dtw_assign(V_N1AWC,  fieldValue)

                                  @Decat_Field("@@fpcl")  @dtw_assign(V_N1FPCLS,  fieldValue)
                                  @Decat_Field("@@tpcl")  @dtw_assign(V_N1TPCLS,  fieldValue)
                                  @Decat_Field("@@apcl")  @dtw_assign(V_N1APCLS,  fieldValue)

                                  @Decat_Field("@@fbac")  @dtw_assign(V_N1FBUY,  fieldValue)
                                  @Decat_Field("@@tbac")  @dtw_assign(V_N1TBUY,  fieldValue)
                                  @Decat_Field("@@abac")  @dtw_assign(V_N1ABUY,  fieldValue)

                                  @Decat_Field("@@fref")  @dtw_assign(V_N1FREF,  fieldValue)
                                  @Decat_Field("@@tref")  @dtw_assign(V_N1TREF,  fieldValue)
                                  @Decat_Field("@@aref")  @dtw_assign(V_N1AREF,  fieldValue)

                                  @Decat_Field("@@fsor")  @dtw_assign(V_N1FSORD, fieldValue)
                                  @Decat_Field("@@tsor")  @dtw_assign(V_N1TSORD, fieldValue)
                                  @Decat_Field("@@asor")  @dtw_assign(V_N1ASORD, fieldValue)

                                  @Decat_Field("@@fsol")  @dtw_assign(V_N1FSORL, fieldValue)
                                  @Decat_Field("@@tsol")  @dtw_assign(V_N1TSORL, fieldValue)
                                  @Decat_Field("@@asol")  @dtw_assign(V_N1ASORL, fieldValue)

                                  @Decat_Field("@@fusr")  @dtw_assign(V_N1FUSER, fieldValue)
                                  @Decat_Field("@@tusr")  @dtw_assign(V_N1TUSER, fieldValue)
                                  @Decat_Field("@@ausr")  @dtw_assign(V_N1AUSER, fieldValue)

                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries
 Values %}
                                  @RtvFldDesc("PLPLNT=$(V_N1PLT)", "HDPLNT", "PLNAME", plantDesc)
                                  %if (V_N1SEL == "02")
                                      @dtw_assign(yes, "")
                                      @dtw_assign(no, "CHECKED")
                                  %else
                                      @dtw_assign(yes, "CHECKED")
                                      @dtw_assign(no, "")
                                  %endif
                                  %if (V_N1GRPD == "02")
                                      @dtw_assign(yesGroup, "")
                                      @dtw_assign(noGroup, "CHECKED")
                                  %else
                                      @dtw_assign(yesGroup, "CHECKED")
                                      @dtw_assign(noGroup, "")
                                  %endif
                                  %if (V_N1AORD == "ALL")
                                      @dtw_assign(checkedallOrderNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallOrderNumber, "")
                                  %endif
                                  %if (V_N1AITEM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_N1ADEPT == "ALL")
                                      @dtw_assign(checkedallDepartment, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallDepartment, "")
                                  %endif
                                  %if (V_N1AWC == "ALL")
                                      @dtw_assign(checkedallWorkCenter, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallWorkCenter, "")
                                  %endif
                                  %if (V_N1APCLS == "ALL")
                                      @dtw_assign(checkedallProductClass, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallProductClass, "")
                                  %endif
                                  %if (V_N1ABUY == "ALL")
                                      @dtw_assign(checkedallBuyerAnalyst, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallBuyerAnalyst, "")
                                  %endif
                                  %if (V_N1AREF == "ALL")
                                      @dtw_assign(checkedallReference, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallReference, "")
                                  %endif
                                  %if (V_N1ASORD == "ALL")
                                      @dtw_assign(checkedallSalesOrder, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallSalesOrder, "")
                                  %endif
                                  %if (V_N1ASORL == "ALL")
                                      @dtw_assign(checkedallSalesOrderLine, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallSalesOrderLine, "")
                                  %endif
                                  %if (V_N1AUSER == "ALL")
                                      @dtw_assign(checkedallUser, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallUser, "")
                                  %endif

                              %elif (fromPlant != "")
                                  @dtw_assign(V_N1PLT,  fromPlant)
                                  @RtvFldDesc("PLPLNT=$(V_N1PLT)", "HDPLNT", "PLNAME", plantDesc)
                                  @dtw_assign(yes, "CHECKED")
                                  @dtw_assign(no, "")
                                  %if (mfgOrderPrintGrouped == "Y")
                                      @dtw_assign(yesGroup, "CHECKED")
                                      @dtw_assign(noGroup, "")
                                  %else
                                      @dtw_assign(yesGroup, "")
                                      @dtw_assign(noGroup, "CHECKED")
                                  %endif

                                  @dtw_assign(V_N1FORD,  fromMO)
                                  @dtw_assign(V_N1TORD,  thruMO)
                                  @dtw_assign(checkedallOrderNumber, "")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallDepartment, "CHECKED")
                                  @dtw_assign(checkedallWorkCenter, "CHECKED")
                                  @dtw_assign(checkedallProductClass, "CHECKED")
                                  @dtw_assign(checkedallBuyerAnalyst, "CHECKED")
                                  @dtw_assign(checkedallReference, "CHECKED")
                                  @dtw_assign(checkedallSalesOrder, "CHECKED")
                                  @dtw_assign(checkedallSalesOrderLine, "CHECKED")
                                  %if (fromUser != "")
                                      @dtw_assign(V_N1FUSER, fromUser)
                                      @dtw_assign(V_N1TUSER, fromUser)
                                      @dtw_assign(checkedallUser, "")
                                  %else
                                      @dtw_assign(checkedallUser, "CHECKED")
                                  %endif
                              %else
                                  @RtvDftPlant(V_N1PLT, plantDesc)
                                  @dtw_assign(yes, "CHECKED")
                                  @dtw_assign(no, "")
                                  %if (mfgOrderPrintGrouped == "Y")
                                      @dtw_assign(yesGroup, "CHECKED")
                                      @dtw_assign(noGroup, "")
                                  %else
                                      @dtw_assign(yesGroup, "")
                                      @dtw_assign(noGroup, "CHECKED")
                                  %endif
                                  
                                  @dtw_assign(checkedallOrderNumber, "CHECKED")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallDepartment, "CHECKED")
                                  @dtw_assign(checkedallWorkCenter, "CHECKED")
                                  @dtw_assign(checkedallProductClass, "CHECKED")
                                  @dtw_assign(checkedallBuyerAnalyst, "CHECKED")
                                  @dtw_assign(checkedallReference, "CHECKED")
                                  @dtw_assign(checkedallSalesOrder, "CHECKED")
                                  @dtw_assign(checkedallSalesOrderLine, "CHECKED")
                                  @dtw_assign(checkedallUser, "CHECKED")
                              %endif

                              @SetTextOvr(Err_N1PLT)
                              <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                  <td class="inputnmbr"><input name="plantNumber" type="text" value="$(V_N1PLT)" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=plantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input disabled name="plantName" value="$(plantDesc)" type="text" size="30"></td>
                              </tr>
                              @DspErrMsg(Err_N1PLT)

                              <tr><td class="dsphdr">Enter Print Horizon Date</td>
                                  <td class="inputnmbr"><input name="horizonDate" type="text" value="$(V_N1HZDT)" size="15" maxlength="30"><a href="javascript:calWindow('horizonDate');">$(calendarImage)</a></td>
                              </tr>

                              <tr><td  class="dsphdr">Print Summary Material Requirements</td>
                                  <td class="inputnmbr"><input name="printSumMatReq" type="radio" VALUE='01' $(yes)>Yes</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="printSumMatReq" type="radio" VALUE='02' $(no)>No</td>
                              </tr>
                              
                              <tr><td  class="dsphdr">Print Grouped By Order</td>
                                  <td class="inputnmbr"><input name="printGrouped" type="radio" VALUE='01' $(yesGroup)>Yes</td>
                              </tr>
                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="printGrouped" type="radio" VALUE='02' $(noGroup)>No</td>
                              </tr>
                              
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              <tr><td  class="dsphdr">Order Number</td>
                                  <td class="inputalph"><input name="fromOrderNumber" value="$(V_N1FORD)" type="text" size="15" maxlength="9"><a href="$(homeURL)$(phpPath)MfgOrderSearch.php$(altVarBase)&amp;docName=Chg&amp;forPlant=$(forPlant)&amp;fldorder=fromOrderNumber" onclick="$(searchWinVar)"> $(searchImage) </a></td>
                                  <td class="inputalph"><input name="toOrderNumber" value="$(V_N1TORD)" type="text" size="15" maxlength="9"><a href="$(homeURL)$(phpPath)MfgOrderSearch.php$(altVarBase)&amp;docName=Chg&amp;forPlant=$(forPlant)&amp;fldorder=toOrderNumber" onclick="$(searchWinVar)">  $(searchImage) </a></td>
                                  <td class="inputalph"><input name="allOrderNumber" value='ALL' $(checkedallOrderNumber) type="checkbox" onClick="if (this.checked) this.form.fromOrderNumber.value='', this.form.toOrderNumber.value='';"></td>
                              </tr>

                              <tr><td  class="dsphdr">Item Number</td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N1FITEM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N1TITEM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                              </tr>

                              <tr><td  class="dsphdr">Department</td>
                                  <td class="inputalph"><input name="fromDepartment" value="$(V_N1FDEPT)" type="text" size="15" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=fromDepartment&amp;fldWC=fromWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="toDepartment" value="$(V_N1TDEPT)" type="text" size="15" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=toDepartment&amp;fldWC=toWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="allDepartment" value='ALL' $(checkedallDepartment) type="checkbox" onClick="if (this.checked) this.form.fromDepartment.value='', this.form.toDepartment.value='';"></td>
                              </tr>

                              <tr><td  class="dsphdr">Work Center</td>
                                  <td class="inputalph"><input name="fromWorkCenter" value="$(V_N1FWC)" type="text" size="15" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=fromDepartment&amp;fldWC=fromWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="toWorkCenter" value="$(V_N1TWC)" type="text" size="15" maxlength="5"><a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(forplt)&amp;docName=Chg&amp;fldPlant=WCPlant&amp;fldPltName=WCPltName&amp;flddept=toDepartment&amp;fldWC=toWorkCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="WCPlant"  type="hidden"><input name="WCPltName"  type="hidden"> <input name="WCDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="allWorkCenter" value='ALL' $(checkedallWorkCenter) type="checkbox" onClick="if (this.checked) this.form.fromWorkCenter.value='', this.form.toWorkCenter.value='';"></td>
                              </tr>

                              <tr><td  class="dsphdr">Product Class</td>
                                  <td class="inputalph"><input name="fromProductClass" value="$(V_N1FPCLS)" type="text" size="15" maxlength="4"><a href="$(homeURL)$(cGIPath)ProdClassSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromProductClass&amp;fldDesc=fproductClassDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fproductClassDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="toProductClass" value="$(V_N1TPCLS)" type="text" size="15" maxlength="4"><a href="$(homeURL)$(cGIPath)ProdClassSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toProductClass&amp;fldDesc=tproductClassDesc" onclick="$(searchWinVar)">  $(searchImage) </a><input name="tproductClassDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allProductClass" value='ALL' $(checkedallProductClass) type="checkbox" onClick="if (this.checked) this.form.fromProductClass.value='', this.form.toProductClass.value='';"></td>
                              </tr>

                              <tr><td  class="dsphdr">Buyer/Analyst</td>
                                  <td class="inputnmbr"><input name="fromBuyerAnalyst" value="$(V_N1FBUY)" type="text" size="15" maxlength="7"><a href="$(homeURL)$(cGIPath)BuyerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromBuyerAnalyst&amp;fldDesc=analystName&amp;buyerAnalyst=Analyst" onclick="$(searchWinVar)"> $(searchImage) </a><input name="analystName" type="hidden"><input name="Analyst" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toBuyerAnalyst" value="$(V_N1TBUY)" type="text" size="15" maxlength="7"><a href="$(homeURL)$(cGIPath)BuyerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toBuyerAnalyst&amp;fldDesc=analystName&amp;buyerAnalyst=Analyst" onclick="$(searchWinVar)"> $(searchImage) </a><input name="analystName" type="hidden"><input name="Analyst" type="hidden"></td>
                                  <td class="inputalph"><input name="allBuyerAnalyst" value='ALL' $(checkedallBuyerAnalyst) type="checkbox" onClick="if (this.checked) this.form.fromBuyerAnalyst.value='', this.form.toBuyerAnalyst.value='';"></td>
                              </tr>

                              <tr><td  class="dsphdr">Reference Number</td>
                                  <td class="inputalph"><input name="fromReference" value="$(V_N1FREF)" type="text" size="20" maxlength="20"></td>
                                  <td class="inputalph"><input name="toReference" value="$(V_N1TREF)" type="text" size="20" maxlength="20"></td>
                                  <td class="inputalph"><input name="allReference" value='ALL' $(checkedallReference) type="checkbox" onClick="if (this.checked) this.form.fromReference.value='', this.form.toReference.value='';"></td>
                              </tr>

                              @SetTextOvr(Err_N1FSORD)
                              <tr><td  class="dsphdr"><span $(textOvr)>Sales Order Number</span></td>
                                  <td class="inputnmbr"><input name="fromSalesOrder" value="$(V_N1FSORD)" type="text" size="15" maxlength="8"></td>
                                  <td class="inputnmbr"><input name="toSalesOrder" value="$(V_N1TSORD)" type="text" size="15" maxlength="8"></td>
                                  <td class="inputalph"><input name="allSalesOrder" value='ALL' $(checkedallSalesOrder) type="checkbox" onClick="if (this.checked) this.form.fromSalesOrder.value='', this.form.toSalesOrder.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FSORD)

                              <tr><td  class="dsphdr">S/O Line Number</td>
                                  <td class="inputnmbr"><input name="fromSalesOrderLine" value="$(V_N1FSORL)" type="text" size="15" maxlength="3"></td>
                                  <td class="inputnmbr"><input name="toSalesOrderLine" value="$(V_N1TSORL)" type="text" size="15" maxlength="3"></td>
                                  <td class="inputalph"><input name="allSalesOrderLine" value='ALL' $(checkedallSalesOrderLine) type="checkbox" onClick="if (this.checked) this.form.fromSalesOrderLine.value='', this.form.toSalesOrderLine.value='';"></td>
                              </tr>

                              <tr><td  class="dsphdr">User ID</td>
                                  <td class="inputalph"><input name="fromUser" value="$(V_N1FUSER)" type="text" size="15" maxlength="10"></td>
                                  <td class="inputalph"><input name="toUser" value="$(V_N1TUSER)" type="text" size="15" maxlength="10"></td>
                                  <td class="inputalph"><input name="allUser" value='ALL' $(checkedallUser) type="checkbox" onClick="if (this.checked) this.form.fromUser.value='', this.form.toUser.value='';"></td>
                              </tr>
                          </table>

                          @dtw_assign(envProgram, "CSIS01")
                          @dtw_assign(envPrinter, "HSI207PF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSIMOP_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(fromOrderNumber)
  @dtw_mUPPERCASE(toOrderNumber)
  @dtw_mUPPERCASE(allOrderNumber)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(fromDepartment)
  @dtw_mUPPERCASE(toDepartment)
  @dtw_mUPPERCASE(allDepartment)
  @dtw_mUPPERCASE(fromWorkCenter)
  @dtw_mUPPERCASE(toWorkCenter)
  @dtw_mUPPERCASE(allWorkCenter)
  @dtw_mUPPERCASE(fromProductClass)
  @dtw_mUPPERCASE(toProductClass)
  @dtw_mUPPERCASE(allProductClass)
  @dtw_mUPPERCASE(allBuyerAnalyst)
  @dtw_mUPPERCASE(fromReference)
  @dtw_mUPPERCASE(toReference)
  @dtw_mUPPERCASE(allReference)
  @dtw_mUPPERCASE(allSalesOrder)
  @dtw_mUPPERCASE(allSalesOrderLine)
  @dtw_mUPPERCASE(fromUser)
  @dtw_mUPPERCASE(toUser)
  @dtw_mUPPERCASE(allUser)

  @dtw_assign(plantNumber,@dtw_rstrip(plantNumber))
  @dtw_assign(horizonDate,@dtw_rstrip(horizonDate))
  @dtw_assign(fromBuyerAnalyst,@dtw_rstrip(fromBuyerAnalyst))
  @dtw_assign(toBuyerAnalyst,@dtw_rstrip(toBuyerAnalyst))
  @dtw_assign(fromSalesOrder,@dtw_rstrip(fromSalesOrder))
  @dtw_assign(toSalesOrder,@dtw_rstrip(toSalesOrder))
  @dtw_assign(fromSalesOrderLine,@dtw_rstrip(fromSalesOrderLine))
  @dtw_assign(toSalesOrderLine,@dtw_rstrip(toSalesOrderLine))

  %if (allOrderNumber != "ALL")
      @dtw_assign(allOrderNumber, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allDepartment != "ALL")
      @dtw_assign(allDepartment, "")
  %endif
  %if (allWorkCenter != "ALL")
      @dtw_assign(allWorkCenter, "")
  %endif
  %if (allProductClass != "ALL")
      @dtw_assign(allProductClass, "")
  %endif
  %if (allBuyerAnalyst != "ALL")
      @dtw_assign(allBuyerAnalyst, "")
  %endif
  %if (allReference != "ALL")
      @dtw_assign(allReference, "")
  %endif
  %if (allSalesOrder != "ALL")
      @dtw_assign(allSalesOrder, "")
  %endif
  %if (allSalesOrderLine != "ALL")
      @dtw_assign(allSalesOrderLine, "")
  %endif
  %if (allUser != "ALL")
      @dtw_assign(allUser, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@hzdt", horizonDate)
  @Concat_Field("@@summ", printSumMatReq)
  @Concat_Field("@@grpd", printGrouped)
  @Concat_Field("@@ford", fromOrderNumber)
  @Concat_Field("@@tord", toOrderNumber)
  @Concat_Field("@@aord", allOrderNumber)
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@fdpt", fromDepartment)
  @Concat_Field("@@tdpt", toDepartment)
  @Concat_Field("@@adpt", allDepartment)
  @Concat_Field("@@fwc@", fromWorkCenter)
  @Concat_Field("@@twc@", toWorkCenter)
  @Concat_Field("@@awc@", allWorkCenter)
  @Concat_Field("@@fpcl", fromProductClass)
  @Concat_Field("@@tpcl", toProductClass)
  @Concat_Field("@@apcl", allProductClass)
  @Concat_Field("@@fbac", fromBuyerAnalyst)
  @Concat_Field("@@tbac", toBuyerAnalyst)
  @Concat_Field("@@abac", allBuyerAnalyst)
  @Concat_Field("@@fref", fromReference)
  @Concat_Field("@@tref", toReference)
  @Concat_Field("@@aref", allReference)
  @Concat_Field("@@fsor", fromSalesOrder)
  @Concat_Field("@@tsor", toSalesOrder)
  @Concat_Field("@@asor", allSalesOrder)
  @Concat_Field("@@fsol", fromSalesOrderLine)
  @Concat_Field("@@tsol", toSalesOrderLine)
  @Concat_Field("@@asol", allSalesOrderLine)
  @Concat_Field("@@fusr", fromUser)
  @Concat_Field("@@tusr", toUser)
  @Concat_Field("@@ausr", allUser)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}