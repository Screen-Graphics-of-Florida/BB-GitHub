%INCLUDE "$(baseVar)"
%INCLUDE "EdtVar.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Product Configuration"
  d2wName                 = "OrderEntryOptionQuantity.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;feature=@dtw_rurlescseq(feature)&amp;option=@dtw_rurlescseq(option)&amp;columnId=@dtw_rurlescseq(columnId)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  <html>
      <head>
          %INCLUDE "headcmt.icl"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "NumZero.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  testfield = document.Chg.ordQty.value;
                  var negPos=testfield.indexOf('-');
                  if (negPos>=0) {alert ("Negative quantity is not allowed.  Please try again."); return false;}
                  if (editZero(document.Chg.ordQty, 9, 4))
                      return true;
              }
          </script>
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  <td class="toolbar">
                      <a href="javascript:check(document.Chg)">$(selectAcceptImage)</a>
                      %INCLUDE "CloseWindow.icl"
                  </td>
              </tr>
          </table>
          <table $(contentTable)>
              @RtvFldDesc("SAOCTL=$(orderControlNumber) and SAFEAT='$(feature)' and SAOPTN=' ' and SABLVL=' ' ", "HDOPWW", "SADESC", featureDesc)
              @RtvFldDesc("SAOCTL=$(orderControlNumber) and SAFEAT='$(feature)' and SAOPTN='$(option)'", "HDOPWW", "SADESC", optionDesc)
              @Format_Header("Feature", $(featureDesc), $(feature))
              @Format_Header("Option", $(optionDesc), $(option))
          </table>
          $(hrTagAttr)
          %if (fromOrdQty == "")
              @RtvFldDesc("SAOCTL=$(orderControlNumber) and SAFEAT='$(feature)' and SAOPTN='$(option)'", "HDOPWW", "SAOQTY", fromOrdQty)
          %endif
          %INCLUDE "RequiredField.icl"

              <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)" onSubmit="return false;">
                  <table $(contentTable)>
                      <tr><td class="dsphdr">Selected Quantity</td>
                          <td class="inputnmbr"><input type="text" name="ordQty" value="$(fromOrdQty)" size="15" maxlength="15"> $(reqFieldChar)</td>
                      </tr>
                  </table>
              </form>
          $(hrTagAttr)
          <a href="javascript:check(document.Chg)">$(selectAcceptImage)</a>
          %INCLUDE "CloseWindow.icl"
      </body>
  </html>
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Update HDOPWW Set SAOQTY=$(ordQty) ", stmtSQL)
  @dtw_concat(stmtSQL, " Where SAOCTL=$(orderControlNumber) and SAFEAT='$(feature)' and SAOPTN='$(option)'  @@endsql", stmtSQL)
  @SQL_Update(stmtSQL, status)
  
  @Format_Nbr(ordQty, F_ordQty, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")

  <script TYPE="text/javascript">
      if (opener.document.getElementById("req$(columnId)")) {
          opener.document.getElementById("req$(columnId)").innerHTML = "$(F_ordQty)";
      }
      if (opener.document.getElementById("sel$(columnId)")) {
          opener.document.getElementById("sel$(columnId)").innerHTML = "$(F_ordQty)";
      }
      window.close();
  </script>
%}