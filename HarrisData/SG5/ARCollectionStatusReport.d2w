%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "A/R Collection Status Report"
  d2wName                 = "ARCollectionStatusReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "6"
  V_CRPRMC                = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  %if (V_HDMCRL > "0")
      @RtvFldDesc("CRPRMC>' '", "ARCTRL", "CRPRMC", V_CRPRMC)
  %endif
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {

                  if (editNum(document.Chg.fromCustomerNumber, 7, 0) &&
                      editNum(document.Chg.toCustomerNumber, 7, 0) &&
                      editdate(document.Chg.fromCallDate) &&
                      editdate(document.Chg.toCallDate) &&
                      editdate(document.Chg.fromResponseDate) &&
                      editdate(document.Chg.toResponseDate) &&
                      editFromToAll(document.Chg.fromCollectionStatus, document.Chg.toCollectionStatus, document.Chg.allCollectionStatus, "A") &&
                      editFromToAll(document.Chg.fromCustomerNumber, document.Chg.toCustomerNumber, document.Chg.allCustomerNumber, 7) &&
                      editFromToAll(document.Chg.fromAlphaSequence, document.Chg.toAlphaSequence, document.Chg.allAlphaSequence, "A") &&
                      editFromToAll(document.Chg.fromCallDate, document.Chg.toCallDate, document.Chg.allCallDate, "D") &&
                      editFromToAll(document.Chg.fromResponseDate, document.Chg.toResponseDate, document.Chg.allResponseDate, "D") &&
                      editFromToAll(document.Chg.fromUserID, document.Chg.toUserID, document.Chg.allUserID, "A")
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ARCOLLECTIONSTATUSREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromCollectionStatus")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@pcmn", "printComments")
                                  @dtw_assign(Err_N1PCMN,  fieldValue)
                                  @DecatErr_Field("@@pful", "includeCallsPaidInFull") @dtw_assign(Err_N1PFUL,  fieldValue)
                                  @DecatErr_Field("@@scol", "sortCollectionStatus")        @dtw_assign(Err_SSTAT,  fieldValue)
                                  @DecatErr_Field("@@scus", "sortCustomerNumber")        @dtw_assign(Err_SCUST,  fieldValue)
                                  @DecatErr_Field("@@salp", "sortAlphaSequence")        @dtw_assign(Err_SALPH,  fieldValue)
                                  @DecatErr_Field("@@sdte", "sortCallDate")        @dtw_assign(Err_SDTEN,  fieldValue)
                                  @DecatErr_Field("@@sdtr", "sortResponseDate")        @dtw_assign(Err_SDTRQ,  fieldValue)
                                  @DecatErr_Field("@@suse", "sortUserID")        @dtw_assign(Err_SUSER,  fieldValue)
                                  %if (V_CRPRMC == "Y")
                                      @DecatErr_Field("@@idcr", "currencyID") @dtw_assign(Err_IDCR,  fieldValue)
                                      @DecatErr_Field("@@curt", "currencyType") @dtw_assign(Err_CURT,  fieldValue)
                                  %endif
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@pcmn")  @dtw_assign(V_N1PCMN,  fieldValue)
                                  @Decat_Field("@@pful")  @dtw_assign(V_N1PFUL,  fieldValue)
                                  @Decat_Field("@@ftat")  @dtw_assign(V_FSTAT,  fieldValue)
                                  @Decat_Field("@@ttat")  @dtw_assign(V_TSTAT,  fieldValue)
                                  @Decat_Field("@@atat")  @dtw_assign(V_ASTAT,  fieldValue)
                                  @Decat_Field("@@stat")  @dtw_assign(V_SSTAT,  fieldValue)
                                  @Decat_Field("@@fcus")  @dtw_assign(V_FCUST,  fieldValue)
                                  @Decat_Field("@@tcus")  @dtw_assign(V_TCUST,  fieldValue)
                                  @Decat_Field("@@acus")  @dtw_assign(V_ACUST,  fieldValue)
                                  @Decat_Field("@@scus")  @dtw_assign(V_SCUST,  fieldValue)
                                  @Decat_Field("@@falp")  @dtw_assign(V_FALPH,  fieldValue)
                                  @Decat_Field("@@talp")  @dtw_assign(V_TALPH,  fieldValue)
                                  @Decat_Field("@@aalp")  @dtw_assign(V_AALPH,  fieldValue)
                                  @Decat_Field("@@salp")  @dtw_assign(V_SALPH,  fieldValue)
                                  @Decat_Field("@@fdte")  @dtw_assign(V_FDTEN,  fieldValue)
                                  @Decat_Field("@@tdte")  @dtw_assign(V_TDTEN,  fieldValue)
                                  @Decat_Field("@@adte")  @dtw_assign(V_ADTEN,  fieldValue)
                                  @Decat_Field("@@sdte")  @dtw_assign(V_SDTEN,  fieldValue)
                                  @Decat_Field("@@fdtr")  @dtw_assign(V_FDTRQ,  fieldValue)
                                  @Decat_Field("@@tdtr")  @dtw_assign(V_TDTRQ,  fieldValue)
                                  @Decat_Field("@@adtr")  @dtw_assign(V_ADTRQ,  fieldValue)
                                  @Decat_Field("@@sdtr")  @dtw_assign(V_SDTRQ,  fieldValue)
                                  @Decat_Field("@@fuse")  @dtw_assign(V_FUSER,  fieldValue)
                                  @Decat_Field("@@tuse")  @dtw_assign(V_TUSER,  fieldValue)
                                  @Decat_Field("@@ause")  @dtw_assign(V_AUSER,  fieldValue)
                                  @Decat_Field("@@suse")  @dtw_assign(V_SUSER,  fieldValue)
                                  %if (V_CRPRMC == "Y")
                                      @Decat_Field("@@idcr")  @dtw_assign(V_IDCR,  fieldValue)
                                      @Decat_Field("@@curt")  @dtw_assign(V_CURT,  fieldValue)
                                  %endif
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1PCMN == "1")
                                      @dtw_assign(checkedPrintComments, "CHECKED")
                                  %else
                                      @dtw_assign(checkedPrintComments, "")
                                  %endif
                                  %if (V_N1PFUL == "1")
                                      @dtw_assign(checkedIncludeCallsPaidInFull, "CHECKED")
                                  %else
                                      @dtw_assign(checkedIncludeCallsPaidInFull, "")
                                  %endif
                                  %if (V_ASTAT == "ALL")
                                      @dtw_assign(checkedAllCollectionStatus, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllCollectionStatus, "")
                                  %endif
                                  %if (V_ACUST == "ALL")
                                      @dtw_assign(checkedAllCustomerNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllCustomerNumber, "")
                                  %endif
                                  %if (V_AALPH == "ALL")
                                      @dtw_assign(checkedAllAlphaSequence, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllAlphaSequence, "")
                                  %endif
                                  %if (V_ADTEN == "ALL")
                                      @dtw_assign(checkedAllCallDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllCallDate, "")
                                  %endif
                                  %if (V_ADTRQ == "ALL")
                                      @dtw_assign(checkedAllResponseDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllResponseDate, "")
                                  %endif
                                  %if (V_AUSER == "ALL")
                                      @dtw_assign(checkedAllUserID, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllUserID, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedPrintComments, "")
                                  @dtw_assign(checkedIncludeCallsPaidInFull, "CHECKED")
                                  @dtw_assign(checkedAllCollectionStatus, "CHECKED")
                                  @dtw_assign(checkedAllCustomerNumber, "CHECKED")
                                  @dtw_assign(checkedAllAlphaSequence, "CHECKED")
                                  @dtw_assign(checkedAllCallDate, "CHECKED")
                                  @dtw_assign(checkedAllResponseDate, "CHECKED")
                                  @dtw_assign(checkedAllUserID, "CHECKED")
                                  %if (V_CRPRMC == "Y")
                                      @dtw_assign(V_IDCR, "I")
                                      @dtw_assign(currencyType, "")
                                  %endif
                              %endif
                          </table>

                          <table $(contentTable)>
                              <tr><td><input type="hidden" name="multiCurrency" value="$(V_CRPRMC)"></td></tr>

                              @SetTextOvr(Err_N1PCMN)
                              <tr><td class="dsphdr"><span $(textOvr)>Select Options </span></td>
                                  <td class="inputnmbr"><input name="printComments" type="checkbox" VALUE='1' $(checkedPrintComments)>Print Comments</td>
                              </tr>
                              @DspErrMsg(Err_N1PCMN)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="includeCallsPaidInFull" type="checkbox" VALUE='1' $(checkedIncludeCallsPaidInFull)>Include Calls Paid In Full</td>
                              </tr>

                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                              </tr>

                              @SetTextOvr(Err_FSTAT)
                              %if (textOvr == "") @SetTextOvr(Err_SSTAT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Collection Status</span></td>
                                  <td class="inputalph"><input name="fromCollectionStatus" value="$(V_FSTAT)" type="text" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)ARCollectionStatusSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromCollectionStatus&amp;fldDesc=fstatDesc" onclick="$(searchWinVar)">$(searchImage) </a> <input name="fstatDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="toCollectionStatus" value="$(V_TSTAT)" type="text" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)ARCollectionStatusSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toCollectionStatus&amp;fldDesc=tstatDesc" onclick="$(searchWinVar)">$(searchImage) </a> <input name="tstatDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allCollectionStatus" value='ALL' $(checkedAllCollectionStatus) type="checkbox" onClick="if (this.checked) this.form.fromCollectionStatus.value='', this.form.toCollectionStatus.value='';"></td>
                                  @Build_Sort_Select("sortCollectionStatus", "$(V_SSTAT)")
                              </tr>
                              @DspErrMsg(Err_SSTAT)

                              @SetTextOvr(Err_FCUST)
                              %if (textOvr == "") @SetTextOvr(Err_SCUST) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Customer Number</span></td>
                                  <td class="inputnmbr"><input name="fromCustomerNumber" value="$(V_FCUST)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)customersearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromCustomerNumber&amp;fldDesc=fcusName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="fcusName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toCustomerNumber" value="$(V_TCUST)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)customersearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toCustomerNumber&amp;fldDesc=tcusName" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="tcusName" type="hidden"></td>
                                  <td class="inputalph"><input name="allCustomerNumber" value='ALL' $(checkedAllCustomerNumber) type="checkbox" onClick="if (this.checked) this.form.fromCustomerNumber.value='', this.form.toCustomerNumber.value='';"></td>
                                  @Build_Sort_Select("sortCustomerNumber", "$(V_SCUST)")
                              </tr>
                              @DspErrMsg(Err_SCUST)

                              @SetTextOvr(Err_FALPH)
                              %if (textOvr == "") @SetTextOvr(Err_SALPH) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Alpha Sequence</span></td>
                                  <td class="inputalph"><input name="fromAlphaSequence" value="$(V_FALPH)" type="text" size="4" maxlength="4"></td>
                                     <td class="inputalph"><input name="toAlphaSequence" value="$(V_TALPH)" type="text" size="4" maxlength="4"></td>
                                  <td class="inputalph"><input name="allAlphaSequence" value='ALL' $(checkedAllAlphaSequence) type="checkbox" onClick="if (this.checked) this.form.fromAlphaSequence.value='', this.form.toAlphaSequence.value='';"></td>
                                  @Build_Sort_Select("sortAlphaSequence", "$(V_SALPH)")
                              </tr>
                              @DspErrMsg(Err_SALPH)

                              @SetTextOvr(Err_FDTEN)
                              %if (textOvr == "") @SetTextOvr(Err_SDTEN) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Call Date</span></td>
                                  <td class="inputnmbr"><input name="fromCallDate" value="$(V_FDTEN)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromCallDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toCallDate" value="$(V_TDTEN)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toCallDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allCallDate" value='ALL' $(checkedAllCallDate) type="checkbox" onClick="if (this.checked) this.form.fromCallDate.value='', this.form.toCallDate='';"></td>
                                  @Build_Sort_Select("sortCallDate", "$(V_SDTEN)")
                              </tr>
                              @DspErrMsg(Err_SDTEN)

                              @SetTextOvr(Err_FDTRQ)
                              %if (textOvr == "") @SetTextOvr(Err_SDTRQ) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Response Date</span></td>
                                  <td class="inputnmbr"><input name="fromResponseDate" value="$(V_FDTRQ)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('fromResponseDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="toResponseDate" value="$(V_TDTRQ)" type="text" size="6" maxlength="6"><a href="javascript:calWindow('toResponseDate');">$(calendarImage)</a></td>
                                  <td class="inputalph"><input name="allResponseDate" value='ALL' $(checkedAllResponseDate) type="checkbox" onClick="if (this.checked) this.form.fromResponseDate.value='', this.form.toResponseDate='';"></td>
                                  @Build_Sort_Select("sortResponseDate", "$(V_SDTRQ)")
                              </tr>
                              @DspErrMsg(Err_SDTRQ)

                              @SetTextOvr(Err_FUSER)
                              %if (textOvr == "") @SetTextOvr(Err_SUSER) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>User ID</span></td>
                                  <td class="inputalph"><input name="fromUserID" value="$(V_FUSER)" type="text" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input name="toUserID" value="$(V_TUSER)" type="text" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input name="allUserID" value='ALL' $(checkedAllUserID) type="checkbox" onClick="if (this.checked) this.form.fromUserID.value='', this.form.toUserID.value='';"></td>
                                  @Build_Sort_Select("sortUserID", "$(V_SUSER)")
                              </tr>
                              @DspErrMsg(Err_SUSER)


                              %if (V_CRPRMC == "Y")
                                  @SetTextOvr(Err_IDCR )
                                  <tr><td class="dsphdr"><span $(textOvr)>Invoice/Domestic Currency (I,D)</span></td>
                                         <td class="inputalph"><input name="currencyID" value="$(V_IDCR)" type="text" size="1" maxlength="1"></td>
                                  </tr>
                                  @DspErrMsg(Err_IDCR)

                                 <tr><td class="dsphdr">--OR--</td></tr>

                                  @SetTextOvr(Err_CURT)
                                     <tr><td class="dsphdr"><span $(textOvr)>Convert To Currency Type</span></td>
                                         <td class="inputalph"><input name="currencyType" value="$(V_CURT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(cGIPath)CurrencyTypeSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=currencyType&amp;fldDesc=currencyTypeDesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input name="currencyTypeDesc" type="hidden"></td>
                                  </tr>
                                  @DspErrMsg(Err_CURT)
                              %endif

                          </table>
                          @dtw_assign(envProgram, "HARCSR")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HARCRS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(fromCollectionStatus)
  @dtw_mUPPERCASE(toCollectionStatus)
  @dtw_mUPPERCASE(allCollectionStatus)
  @dtw_mUPPERCASE(allCustomerNumber)
  @dtw_mUPPERCASE(fromAlphaSequence)
  @dtw_mUPPERCASE(toAlphaSequence)
  @dtw_mUPPERCASE(allAlphaSequence)
  @dtw_mUPPERCASE(allCallDate)
  @dtw_mUPPERCASE(allResponseDate)
  @dtw_mUPPERCASE(fromUserID)
  @dtw_mUPPERCASE(toUserID)
  @dtw_mUPPERCASE(allUserID)
  @dtw_mUPPERCASE(currencyID)
  @dtw_mUPPERCASE(currencyType)

  @dtw_assign(sortCollectionStatus,@dtw_rstrip(sortCollectionStatus))
  @dtw_assign(fromCustomerNumber,@dtw_rstrip(fromCustomerNumber))
  @dtw_assign(toCustomerNumber,@dtw_rstrip(toCustomerNumber))
  @dtw_assign(sortCustomerNumber,@dtw_rstrip(sortCustomerNumber))
  @dtw_assign(sortAlphaSequence,@dtw_rstrip(sortAlphaSequence))
  @dtw_assign(fromCallDate,@dtw_rstrip(fromCallDate))
  @dtw_assign(toCallDate,@dtw_rstrip(toCallDate))
  @dtw_assign(sortCallDate,@dtw_rstrip(sortCallDate))
  @dtw_assign(fromResponseDate,@dtw_rstrip(fromResponseDate))
  @dtw_assign(toResponseDate,@dtw_rstrip(toResponseDate))
  @dtw_assign(sortResponseDate,@dtw_rstrip(sortResponseDate))
  @dtw_assign(sortUserID,@dtw_rstrip(sortUserID))

  %if (allCollectionStatus != "ALL")
      @dtw_assign(allCollectionStatus, "")
  %endif
  %if (allCustomerNumber != "ALL")
      @dtw_assign(allCustomerNumber, "")
  %endif
  %if (allAlphaSequence != "ALL")
      @dtw_assign(allAlphaSequence, "")
  %endif
  %if (allCallDate != "ALL")
      @dtw_assign(allCallDate, "")
  %endif
  %if (allResponseDate != "ALL")
      @dtw_assign(allResponseDate, "")
  %endif
  %if (allUserID != "ALL")
      @dtw_assign(allUserID, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@mult", multiCurrency)
  @Concat_Field("@@pcmn", printComments)
  @Concat_Field("@@pful", includeCallsPaidInFull)
  @Concat_Field("@@ftat", fromCollectionStatus)
  @Concat_Field("@@ttat", toCollectionStatus)
  @Concat_Field("@@atat", allCollectionStatus)
  @Concat_Field("@@stat", sortCollectionStatus)
  @Concat_Field("@@fcus", fromCustomerNumber)
  @Concat_Field("@@tcus", toCustomerNumber)
  @Concat_Field("@@acus", allCustomerNumber)
  @Concat_Field("@@scus", sortCustomerNumber)
  @Concat_Field("@@falp", fromAlphaSequence)
  @Concat_Field("@@talp", toAlphaSequence)
  @Concat_Field("@@aalp", allAlphaSequence)
  @Concat_Field("@@salp", sortAlphaSequence)
  @Concat_Field("@@fdte", fromCallDate)
  @Concat_Field("@@tdte", toCallDate)
  @Concat_Field("@@adte", allCallDate)
  @Concat_Field("@@sdte", sortCallDate)
  @Concat_Field("@@fdtr", fromResponseDate)
  @Concat_Field("@@tdtr", toResponseDate)
  @Concat_Field("@@adtr", allResponseDate)
  @Concat_Field("@@sdtr", sortResponseDate)
  @Concat_Field("@@fuse", fromUserID)
  @Concat_Field("@@tuse", toUserID)
  @Concat_Field("@@ause", allUserID)
  @Concat_Field("@@suse", sortUserID)
  %if (multiCurrency == "Y")
      @Concat_Field("@@idcr", currencyID)
      @Concat_Field("@@curt", currencyType)
  %endif


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}