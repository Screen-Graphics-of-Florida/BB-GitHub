%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Drill Down Program"
  d2wName                 = "GLDDPgm.d2w"
  d2wVarBase              = "$(genericVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HGLDPU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "GLDDPGM")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "SELECT DPAPID, DPDDFL, DPPGM, DPTITL, DPUPDT, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(DPTITL) as DPTITLU " , stmtSQL)
                      @dtw_concat(fileSQL, " GLDDPG ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, " DPAPID<>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64) profileHandle,
                                   CHAR(2)   dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)GLDDPgmMaintain.d2w/MAINTAIN$(genericVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Ap<br>Id</th>
                      <th class="colhdr">File</th>
                      <th class="colhdr">Program</th>
                      <th class="colhdr">Title</th></tr>
                  <tr><td><input type="text" class="inputalph" name="srchApId" size="2" maxlength="2">
                          <input type="hidden" name="operApId" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchFile" size="10" maxlength="10">
                          <input type="hidden" name="operFile" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchPgm" size="10" maxlength="50">
                          <input type="hidden" name="operPgm" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchTitle" size="10" maxlength="50">
                          <input type="hidden" name="operTitle" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchApId.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("DPAPID", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApId" title="Sequence By Application Id, File"> Ap<br>Id</a></th>
              @OrderBy_Sort("DPDDFL", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=File" title="Sequence By File, Application Id"> File</a></th>
              @OrderBy_Sort("DPPGM", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Pgm" title="Sequence By Program, Application Id, File"> Program</a></th>
              @OrderBy_Sort("DPTITL", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Title" title="Sequence By Title, Application Id, File"> Title</a></th>
              @OrderBy_Sort("DPUPDT", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Upgrade" title="Sequence By Update In Upgrade, Application Id, File"> Update<br>In<br>Upgrade</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(genericVarBase)&amp;ddApId=@dtw_rurlescseq(V_DPAPID)&amp;ddFileName=@dtw_rurlescseq(V_DPDDFL)&amp;ddPgm=@dtw_rurlescseq(V_DPPGM)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_DPTITL), "$(V_DPPGM) / $(V_DPAPID) / $(V_DPDDFL)", "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)GLDDPgmMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_04 == "Y")
                              <a href="$(homeURL)$(cGIPath)GLDDPgmMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)GLDDPgmMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_DPAPID)</td>
                  <td class="colalph">$(V_DPDDFL)</td>
                  <td class="colalph">$(V_DPPGM)</td>
                  <td class="colalph">$(V_DPTITL)</td>
                  <td class="colcode">$(V_DPUPDT)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "SELECT DPAPID, DPDDFL, DPPGM, DPTITL, DPUPDT, ", stmtSQL)
  @dtw_concat(stmtSQL, " upper(DPTITL) as DPTITLU " , stmtSQL)
  @dtw_concat(fileSQL, " GLDDPG ", fileSQL)
  %if (wildCardSearch!="")
      @dtw_concat(selectSQL, " DPAPID<>' ' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  %INCLUDE "stmtSQLTotalRows.icl"
  @List_Export_Query(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_Export_Query (IN CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("DrillDownProgramList")
          %ROW{
              @XMLIDTag("$(V_DPAPID)-$(V_DPDDFL)", "DrillDownProgram ID")
                  @XMLTag(V_DPAPID, "ApId")
                  @XMLTag(V_DPDDFL, "File")
                  @XMLTag(V_DPPGM, "Program")
                  @XMLTag(V_DPTITL, "PgmTitle")
                  @XMLTag(V_DPUPDT, "UpdateUpgrade")
              @XMLEndTag("DrillDownProgram")
          %}
      @XMLEndTag("DrillDownProgramList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "DPAPID,DPDDFL")
          @DTW_ASSIGN(orderByDisplay, "Application Id, File")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit ()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "ApId")
      %if (orderBy == "DPAPID,DPDDFL")
          @DTW_ASSIGN(orderBy, "DPAPID DESC,DPDDFL")
          @DTW_ASSIGN(orderByDisplay, "Application Id (descending), File")
      %else
          @DTW_ASSIGN(orderBy, "DPAPID,DPDDFL")
          @DTW_ASSIGN(orderByDisplay, "Application Id, File")
      %endif
  %elseif (sequence == "File")
      %if (orderBy == "DPDDFL,DPAPID")
          @DTW_ASSIGN(orderBy, "DPDDFL DESC,DPAPID")
          @DTW_ASSIGN(orderByDisplay, "File (descending), Application Id")
      %else
          @DTW_ASSIGN(orderBy, "DPDDFL,DPAPID")
          @DTW_ASSIGN(orderByDisplay, "File, Application Id")
      %endif
  %elseif (sequence == "Pgm")
      %if (orderBy == "DPPGM,DPAPID,DPDDFL")
          @DTW_ASSIGN(orderBy, "DPPGM DESC,DPAPID,DPDDFL")
          @DTW_ASSIGN(orderByDisplay, "Program (descending), Application Id, File")
      %else
          @DTW_ASSIGN(orderBy, "DPPGM,DPAPID,DPDDFL")
          @DTW_ASSIGN(orderByDisplay, "Program, Application Id, File")
      %endif
  %elseif (sequence == "Title")
      %if (orderBy == "DPTITL,DPAPID,DPDDFL")
          @DTW_ASSIGN(orderBy, "DPTITL DESC,DPAPID,DPDDFL")
          @DTW_ASSIGN(orderByDisplay, "Title (descending), Application Id, File")
      %else
          @DTW_ASSIGN(orderBy, "DPTITL,DPAPID,DPDDFL")
          @DTW_ASSIGN(orderByDisplay, "Title, Application Id, File")
      %endif
  %elseif (sequence == "Upgrade")
      %if (orderBy == "DPUPDT,DPAPID,DPDDFL")
          @DTW_ASSIGN(orderBy, "DPUPDT DESC,DPAPID,DPDDFL")
          @DTW_ASSIGN(orderByDisplay, "Update In Upgrade (descending), Application Id, File")
      %else
          @DTW_ASSIGN(orderBy, "DPUPDT,DPAPID,DPDDFL")
          @DTW_ASSIGN(orderByDisplay, "Update In Upgrade, Application Id, File")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "GLDDPGMSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Application Id</td>
                              @dtw_assign(operNbr, "operApId")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchApId" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">File</td>
                              @dtw_assign(operNbr, "operFile")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchFile" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Program</td>
                              @dtw_assign(operNbr, "operPgm")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchPgm" size="10" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Title</td>
                              @dtw_assign(operNbr, "operTitle")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchTitle" size="10" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Update In Upgrade</td>
                              @dtw_assign(operNbr, "operUpgrade")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchUpgrade" size="1" maxlength="1"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchApId.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("DPAPID", "Application Id", $(srchApId), "U", $(operApId), "A")
  @Build_WildCard ("DPDDFL", "File", $(srchFile), "U", $(operFile), "A")
  @Build_WildCard ("upper(DPPGM)", "Program", $(srchPgm), "U", $(operPgm), "A")
  @Build_WildCard ("upper(DPTITL)", "Title", $(srchTitle), "U", $(operTitle), "A")
  @Build_WildCard ("DPUPDT", "Update In Upgrade", $(srchUpgrade), "U", $(operUpgrade), "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
