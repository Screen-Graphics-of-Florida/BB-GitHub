%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Product Structure Maintenance"
  d2wName                 = "ProductStructureMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;SVPPLT=@dtw_rurlescseq(SVPPLT)&amp;SVPPN=@dtw_rurlescseq(SVPPN)&amp;SVSEQN=@dtw_rurlescseq(SVSEQN)&amp;SVCPN=@dtw_rurlescseq(SVCPN)&amp;SVREFN=@dtw_rurlescseq(SVREFN)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;sequenceNumber=@dtw_rurlescseq(sequenceNumber)&amp;componentNumber=@dtw_rurlescseq(componentNumber)&amp;engineeringReference=@dtw_rurlescseq(engineeringReference)&amp;plrsf=@dtw_rurlescseq(plrsf)&amp;rtgExists=@dtw_rurlescseq(rtgExists)&amp;plrseq=@dtw_rurlescseq(plrseq)&amp;maintenanceCode=D"
  programName             = "HPD010"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @ItemUserView(profileHandle, dataBaseID, userPass, itemNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              @dtw_assign(formName, "Chg")
              <script TYPE="text/javascript">
                  %INCLUDE "calendar.icl"
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "dateedit.icl"
                  %INCLUDE "Menu.js"
                  %INCLUDE "numedit.icl"
                  function confirmDelete() {return confirm("$(delRecordConf)")}
                  function validate(chgForm) {
                      if (
                          %if (plrsf == "Y")
                              document.Chg.sequenceNumber.value =="" ||
                          %endif
                          document.Chg.componentNumber.value =="" ||
                          document.Chg.quantityper.value =="")
                             {alert("$(reqFieldError)");
                              return false;}
                      if (
                          %if (plrsf == "Y")
                              editNum(document.Chg.sequenceNumber, 3, 0) &&
                          %endif
                          editNum(document.Chg.quantityper, 4, 5) &&
                          editNum(document.Chg.scrappercent, 1, 2) &&
                          editNum(document.Chg.effstartdate, 6, 0) &&
                          editdate(document.Chg.effstartdate) &&
                          editNum(document.Chg.effstopdate, 6, 0))
                          return true;
                  }
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "PRODUCTSTRUCTUREMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "SELECT * FROM HDMPSM WHERE PSPPLT=$(plantNumber) and PSPPN='$(itemNumber)' and PSSEQN=$(sequenceNumber) and PSCPN='$(componentNumber)' and PSREFN='$(engineeringReference)'", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLRSF", plrsf)
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "CHAR(PLRSEQ)", plrseq)
      @RtvFldDesc("RTPLT=$(plantNumber) and RTPN='$(itemNumber)'", "HDMRTM", "CHAR(COUNT(RTPN))", rtgExists)
      %INCLUDE "MaintainTop.icl"

      <table $(contentTable)>
          @Format_Header("Plant", $(plantName), $(plantNumber))
          @Format_Header("Item", $(itemDescription), $(itemNumber))
      </table>

      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          %if (plrsf == "Y"  && rtgExists>"0")
                              @dtw_assign(focusField, "sequenceNumber")
                          %else
                              @dtw_assign(focusField, "componentNumber")
                          %endif
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@plt@", "plantNumber")        @dtw_assign(Err_PSPPLT, fieldValue)
                          @DecatErr_Field("@@pn@@", "itemNumber")         @dtw_assign(Err_PSPPN, fieldValue)
                          @DecatErr_Field("@@seqn", "sequenceNumber")     @dtw_assign(Err_PSSEQN, fieldValue)
                          @DecatErr_Field("@@cpn@", "componentNumber")    @dtw_assign(Err_PSCPN,  fieldValue)
                          %if (Err_PSCPN == "")
                              @DecatErr_Field("@@368@", "componentNumber")         @dtw_assign(Err_PSCPN,  fieldValue)
                              %if (Err_PSCPN != "")
                                 @dtw_assign(Err368, "Y")
                              %else
                                 @dtw_assign(Err368, "")
                              %endif
                          %endif
                          %if (Err_PSCPN == "")
                              @DecatErr_Field("@@369@", "componentNumber")         @dtw_assign(Err_PSCPN,  fieldValue)
                              %if (Err_PSCPN != "")
                                 @dtw_assign(Err369, "Y")
                              %else
                                 @dtw_assign(Err369, "")
                              %endif
                          %endif
                          @DecatErr_Field("@@refn", "engineeringReference")         @dtw_assign(Err_PSREFN, fieldValue)
                          @DecatErr_Field("@@qper", "quantityper")    @dtw_assign(Err_PSQPER,  fieldValue)
                          @DecatErr_Field("@@fstk", "backflushcode")        @dtw_assign(Err_PSFSTK, fieldValue)
                          @DecatErr_Field("@@scpp", "scrappercent") @dtw_assign(Err_PSSCPP, fieldValue)
                          @DecatErr_Field("@@stdt", "effstartdate")      @dtw_assign(Err_PSSTDT, fieldValue)
                          @DecatErr_Field("@@dsdt", "effstopdate")      @dtw_assign(Err_PSDSDT, fieldValue)
                          @DecatErr_Field("@@itmr", "itemtoreplace")   @dtw_assign(Err_PSITMR, fieldValue)
                          @DecatErr_Field("@@itmb", "itembeingreplaced")           @dtw_assign(Err_PSITMB, fieldValue)
                      %endif
                      @Decat_Field("@@plt@")   @dtw_assign(V_PSPPLT, fieldValue)
                      @Decat_Field("@@pn@@")   @dtw_assign(V_PSPPN, fieldValue)
                      @Decat_Field("@@seqn")   @dtw_assign(V_PSSEQN, fieldValue)
                      @Decat_Field("@@cpn@")   @dtw_assign(V_PSCPN, fieldValue)
                      @Decat_Field("@@refn")   @dtw_assign(V_PSREFN,  fieldValue)
                      @Decat_Field("@@qper")   @dtw_assign(V_PSQPER, fieldValue)
                      @Decat_Field("@@fstk")   @dtw_assign(V_PSFSTK,  fieldValue)
                      @Decat_Field("@@scpp")   @dtw_assign(V_PSSCPP, fieldValue)
                      @Decat_Field("@@stdt")   @dtw_assign(V_PSSTDT, fieldValue)
                      @Decat_Field("@@dsdt")   @dtw_assign(V_PSDSDT, fieldValue)
                      @Decat_Field("@@itmr")   @dtw_assign(V_PSITMR, fieldValue)
                      @Decat_Field("@@itmb")   @dtw_assign(V_PSITMB, fieldValue)
                      @dtw_assign(decat, "Y")


                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          %if (plrsf == "Y" && rtgExists > "0")
                              @dtw_assign(V_PSSEQN, "")
                              @dtw_assign(focusField, "sequenceNumber")
                          %else
                              @dtw_assign(V_PSSEQN, $(plrseq))
                              @dtw_assign(focusField, "componentNumber")
                          %endif
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      %if (plrsf == "Y" && rtgExists > "0")
                          @dtw_assign(V_PSSEQN, "")
                          @dtw_assign(focusField, "sequenceNumber")
                      %else
                          @dtw_assign(V_PSSEQN, $(plrseq))
                          @dtw_assign(focusField, "componentNumber")
                      %endif
                  %else
                      @dtw_assign(focusField, "componentNumber")
                  %endif

                  %if (plrsf == "Y")
                      @SetTextOvr(Err_PSSEQN)
                      <tr><td class="dsphdr"><span $(textOvr)>Routing Sequence</span></td>
                          %if (rtgExists > "0")
                              <td class="inputnmbr"><input name="sequenceNumber" type="text" value="$(V_PSSEQN)" size="3" maxlength="3"> $(reqFieldChar) </td>
                          %else
                              <td class="inputnmbr"><input name="sequenceNumber" type="hidden" value="$(V_PSSEQN)" size="3" maxlength="3">$(V_PSSEQN)</td>
                          %endif
                      </tr>
                      @DspErrMsg(Err_PSSEQN)
                  %else
                      <tr><td class="inputnmbr"><input name="sequenceNumber" type="hidden" value="$(plrseq)"></td></tr>
                  %endif

                  <tr><td><input type="hidden" name="plrsf" value="$(plrsf)" </td></tr>

                  @RtvFldDesc("IMITEM='$(V_PSCPN)'", "HDIMST", "IMIMDS", compdesc)
                  @SetTextOvr(Err_PSCPN)
                  <tr><td class="dsphdr"><span $(textOvr)>Component Item Number</span></td>
                      <td class="inputalph"><input name="componentNumber" value="$(V_PSCPN)" type="text" size="15" maxlength="15"> $(reqFieldChar) <a href="$(homeURL)$(cGIPath)itemplantsearch.d2w/ENTRY$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;docName=Chg&amp;fldName=componentNumber&amp;fldDesc=compdesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input disabled name="compdesc" value="$(compdesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_PSCPN)

                  %if (Err368 == "Y")
                      @dtw_assign(noMenu, "Y")
                      @dtw_assign(itemNumber, $(V_PSCPN))
                      <tr>
                         <td>&nbsp;</td>
                         <td><a href="$(homeURL)$(cGIPath)itemplantmaintain.d2w/Edit_Plant$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;noMenu=@dtw_rurlescseq(noMenu)&amp;maintenanceCode=A" onclick="$(searchWinVar)">Click Here For Item/Plant</a></td>
                      </tr>
                  %endif

                  %if (Err369 == "Y")
                      @RetWhsNbr(profileHandle, dataBaseID, "RetWhsNbr", plantNumber, itemNumber, ReturnWarehouse)
                      %if (ReturnWarehouse != "")
                          @dtw_assign(noMenu, "Y")
                          @dtw_assign(itemNumber, $(V_PSCPN))
                         <tr>
                            <td>&nbsp;</td>
                            <td><a href="$(homeURL)$(cGIPath)itemwarehousemaintain.d2w/Edit_Warehouse$(genericVarBase)&amp;fromItemNumber=@dtw_rurlescseq(itemNumber)&amp;fromWarehouse=@dtw_rurlescseq(ReturnWarehouse)&amp;noMenu=@dtw_rurlescseq(noMenu)&amp;maintenanceCode=A" onclick="$(searchWinVar)">Click Here For Item/Warehouse</a></td>
                         </tr>
                      %endif
                  %endif

                  @SetTextOvr(Err_PSREFN)
                  <tr><td class="dsphdr"><span $(textOvr)>Engineering Reference</span></td>
                      <td class="inputalph"><input name="engineeringReference" value="$(V_PSREFN)" type="text" size="8" maxlength="8"></td>
                  </tr>
                  @DspErrMsg(Err_PSREFN)

    	           @RtvFldDesc("IMITEM='$(V_PSCPN)'", "HDIMST", "IMUOMS", uoms)
    	           @RtvFldDesc("UMUOM='$(uoms)'", "HDUOM", "UMUMLD", umld)
                  <tr><td class="dsphdr"><span >Component Unit Of Measure</span></td> <td class="dspalph">$(uoms) &nbsp; &nbsp;  $(umld)</td></tr>

                  @SetTextOvr(Err_PSQPER)
                  <tr><td class="dsphdr"><span $(textOvr)>Quantity Per</span></td>
                      <td class="inputnmbr"><input type="text" name="quantityper" value="$(V_PSQPER)" size="10" maxlength="10"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_PSQPER)
    	   		
    	           @RtvFldDesc("FLTYPE='BACKFLUSH' and FLVALU='$(V_PSFSTK)'", "SYFLAG", "FLDESC", codedesc)
                  @SetTextOvr(Err_PSFSTK)
                  <tr><td class="dsphdr"><span $(textOvr)>Backflush Code</span></td>
                      <td class="inputalph"><input type="text" name="backflushcode" value="$(V_PSFSTK)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=BACKFLUSH&amp;flagSrchHdr=@dtw_rurlescseq("Backflush Code")&amp;docName=Chg&amp;fldName=backflushcode&amp;fldDesc=codedesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="codedesc" value="$(codedesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_PSFSTK)

                  @SetTextOvr(Err_PSSCPP)
                  <tr><td class="dsphdr"><span $(textOvr)>Scrap Percent</span></td>
                      <td class="inputnmbr"><input type="text" name="scrappercent" value="$(V_PSSCPP)" size="4" maxlength="4"></td>
                  </tr>
                  @DspErrMsg(Err_PSSCPP)
    	   		
                  %if (decat != "Y")		
                      @DateInputFromCYMD(V_PSSTDT)
                  %endif

                  @SetTextOvr(Err_PSSTDT)
                  <tr><td class="dsphdr"><span $(textOvr)>Effectivity Date In</span></td>
                      <td class="inputnmbr"><input type="text" name="effstartdate" value="$(V_PSSTDT)" size="6" maxlength="6"> <a href="javascript:calWindow('effstartdate');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_PSSTDT)

                  %if (decat != "Y")		
                      %if (V_PSDSDT == "9999999")
                          @dtw_assign(V_PSDSDT, "999999")
                      %else
                          @DateInputFromCYMD(V_PSDSDT)
                      %endif
                  %endif
                  @dtw_assign(decat, "")

                  @SetTextOvr(Err_PSDSDT)
                  <tr><td class="dsphdr"><span $(textOvr)>Effectivity Date Out</span></td>
                      <td class="inputnmbr"><input type="text" name="effstopdate" value="$(V_PSDSDT)" size="6" maxlength="6"> <a href="javascript:calWindow('effstopdate');">$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_PSDSDT)
    	   		
                  %if (V_PSITMR != "")
                      @RtvFldDesc("IMITEM='$(V_PSITMR)'", "HDIMST", "IMIMDS", todesc)
                  %endif

                  @SetTextOvr(Err_PSITMR)
                  <tr><td class="dsphdr"><span $(textOvr)>ECN Item To Replace</span></td>
                      <td class="inputalph"><input type="text" name="itemtoreplace" value="$(V_PSITMR)" size="15" maxlength="15"> <a href="$(homeURL)$(cGIPath)itemplantsearch.d2w/ENTRY$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;docName=Chg&amp;fldName=itemtoreplace&amp;fldDesc=todesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input disabled name="todesc" value="$(todesc)"  type="text" size="30" maxlength="30"></td></td>
                  </tr>
                  @DspErrMsg(Err_PSITMR)
    	   		
                  %if (V_PSITMB != "")
                      @RtvFldDesc("IMITEM='$(V_PSITMB)'", "HDIMST", "IMIMDS", replacedesc)
                  %endif
                  @SetTextOvr(Err_PSITMB)
                  <tr><td class="dsphdr"><span $(textOvr)>ECN Item Being Replaced</span></td>
                      <td class="inputalph"><input type="text" name="itembeingreplaced" value="$(V_PSITMB)" size="15" maxlength="15"> <a href="$(homeURL)$(cGIPath)itemplantsearch.d2w/ENTRY$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;docName=Chg&amp;fldName=itembeingreplaced&amp;fldDesc=replacedesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input disabled name="replacedesc" value="$(replacedesc)"  type="text" size="30" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_PSITMB)

              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @dtw_assign(SVPPLT, $(plantNumber))
      @dtw_assign(SVPPN, $(itemNumber))
      @dtw_assign(SVSEQN, $(sequenceNumber))
      @dtw_assign(SVCPN, $(componentNumber))
      @dtw_assign(SVREFN, $(engineeringReference))
      @Set_SQL(stmtSQL)
  %endif
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,
                                        INOUT CHAR(32000) errVar,
                                        INOUT CHAR(10) SUBR)
{%EXEC {HPD010_W.PGM %}
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(itemNumber)
  @dtw_mUPPERCASE(componentNumber)
  @dtw_mUPPERCASE(engineeringReference)
  @dtw_mUPPERCASE(backflushcode)
  @dtw_mUPPERCASE(itemtoreplace)
  @dtw_mUPPERCASE(itembeingreplaced)
  @dtw_mUPPERCASE(SVPPN)
  @dtw_mUPPERCASE(SVCPN)
  @dtw_mUPPERCASE(SVREFN)

  @dtw_assign(plantNumber,@dtw_rstrip(plantNumber))
  @dtw_assign(sequenceNumber,@dtw_rstrip(sequenceNumber))
  @dtw_assign(quantityper,@dtw_rstrip(quantityper))
  @dtw_assign(scrappercent,@dtw_rstrip(scrappercent))
  @dtw_assign(effstartdate,@dtw_rstrip(effstartdate))
  @dtw_assign(effstopdate,@dtw_rstrip(effstopdate))
  @dtw_assign(SVPPLT,@dtw_rstrip(SVPPLT))
  @dtw_assign(SVSEQN,@dtw_rstrip(SVSEQN))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@pn@@", itemNumber)
  @Concat_Field("@@seqn", sequenceNumber)
  @Concat_Field("@@cpn@", componentNumber)
  @Concat_Field("@@refn", engineeringReference)
  @Concat_Field("@@qper", quantityper)
  @Concat_Field("@@fstk", backflushcode)
  @Concat_Field("@@scpp", scrappercent)
  @Concat_Field("@@stdt", effstartdate)
  @Concat_Field("@@dsdt", effstopdate)
  @Concat_Field("@@itmr", itemtoreplace)
  @Concat_Field("@@itmb", itembeingreplaced)
  @Concat_Field("@@svpp", SVPPLT)
  @Concat_Field("@@svpn", SVPPN)
  @Concat_Field("@@svsq", SVSEQN)
  @Concat_Field("@@svcp", SVCPN)
  @Concat_Field("@@svrf", SVREFN)
  @dtw_concat(edtVar, "}{", edtVar)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(SUBR, "SRC2E")

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar, SUBR)

  @RtvFldDesc("IMITEM='$(componentNumber)'", "HDIMST", "IMIMDS", compdesc)
  %if (errFound == "")
      %if (plrsf == "Y" && engineeringReference != "")
          @Format_ConfMsg_Desc(maintenanceCode, "Routing Sequence", $(sequenceNumber), ",$(compdesc)", $(componentNumber), ",Engineering Reference", $(engineeringReference), confMessage)
      %elif (plrsf == "Y")
          @Format_ConfMsg_Desc(maintenanceCode, "Routing Sequence", $(sequenceNumber), ",$(compdesc)", $(componentNumber), "", "", confMessage)
      %elif (engineeringReference != "")
          @Format_ConfMsg_Desc(maintenanceCode, ",$(compdesc)", $(componentNumber), ",Engineering Reference", $(engineeringReference), "", "", confMessage)
      %else
          @Format_ConfMsg_Desc(maintenanceCode, ",$(compdesc)", $(componentNumber), "", "", "", "", confMessage)
      %endif
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ProductStructure.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;sequenceNumber=@dtw_rurlescseq(sequenceNumber)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@cpn@", "componentNumber")
      @Format_ConfMsg_Desc("", "$(compdesc)", $(componentNumber), "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ProductStructure.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;componentNumber=@dtw_rurlescseq(componentNumber)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(SVPPLT)&amp;itemNumber=@dtw_rurlescseq(SVPPN)&amp;sequenceNumber=@dtw_rurlescseq(SVSEQN)&amp;componentNumber=@dtw_rurlescseq(SVCPN)&amp;engineeringReference=@dtw_rurlescseq(SVREFN)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}

%HTML(COPYALL) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "NewWindowOpen.icl"
              function validate(chgForm) {
                 if (document.Chg.toplantNumber.value =="" ||
                     document.Chg.toitemNumber.value =="")
                       {alert("$(reqFieldError)");
                           return false;}
                 if (editNum(document.Chg.toplantNumber, 3, 0))
                          return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PRODUCTSTRUCTUREMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      <table $(baseTable)>
                          <colgroup>
                              <col width="80%">
                              <col width="15%">
                          <tr><td><h1> Copy Product Structure</h1></td>
                          <td class="toolbar">
                              %INCLUDE "MaintainTopNoTable.icl"
                          </td></tr>
                      </table>
                      <table $(contentTable)>
                          @Format_Header("Plant", $(plantName), $(plantNumber))
                          @Format_Header("Item", $(itemDescription), $(itemNumber))
                      </table>

                      $(hrTagAttr)
                      %INCLUDE "RequiredField.icl"
                      %INCLUDE "ErrorDisplay.icl"

                      <form class="formClass" METHOD=POST name=Chg onSubmit="return (editNum(toplantNumber, 3, 0) &&
                                                                                     editChg())"
                          ACTION="$(homeURL)$(cGIPath)$(d2wName)/EDIT_COPYALL$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "toplantNumber")
                              %if (errFound != "" || maintenanceCode == "A")
                                  %if (errFound == "" && maintenanceCode == "A")
                                      @dtw_assign(edtVar, "")
                                  %else
                                      @EdtVarErr(profileHandle, typeValue, edtVar)
                                      @ErrVarErr(profileHandle, typeError, errVar)
                                      @DecatErr_Field("@@tplt", "toplantNumber")   @dtw_assign(Err_TOPLT,  fieldValue)
                                      @DecatErr_Field("@@titm", "toitemNumber")   @dtw_assign(Err_TOPN,  fieldValue)
                                  %endif

                                  @Decat_Field("@@tplt")   @dtw_assign(V_PSPPLT,  fieldValue)
                                  @Decat_Field("@@titm")   @dtw_assign(V_PSPPN,  fieldValue)
                                  %if (V_PSPPLT == "")
                                      @dtw_assign(V_PSPPLT, "0")
                                  %endif

                                  @dtw_assign(errFound, "")

                              %elif (maintenanceCode == "Z")
                                  @dtw_assign(V_PSPPN, "")
                                  @dtw_assign(V_PSPPLT, "")
                              %endif

                              %if (V_PSPPLT != "")
                                  @RtvFldDesc("PLPLNT=$(V_PSPPLT)", "HDPLNT", "PLNAME", toplantName)
                              %endif

                              @SetTextOvr(Err_TOPLT)
                              <tr><td class="dsphdr"><span $(textOvr)>To Plant Number</span></td>
                                  <td class="inputnmbr"><input name="toplantNumber" value="$(V_PSPPLT)" type="text" size="3" maxlength="3""><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toplantNumber&amp;fldDesc=toplantName" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input name="toplantName" value="$(toplantName)" type="text" size="30" maxlength="30"></td>
                              </tr>
                              @DspErrMsg(Err_TOPLT)

                              @RtvFldDesc("IMITEM='$(V_PSPPN)'", "HDIMST", "IMIMDS", toitemdescription)
                              @SetTextOvr(Err_TOPN)
	                           <tr><td class="dsphdr"><span $(textOvr)>To Item Number</span></td>
                                  <td class="inputalph"><input name="toitemNumber" value="$(V_PSPPN)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(cGIPath)itemplantsearch.d2w/ENTRY$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(toplantNumber)&amp;docName=Chg&amp;fldPlant=toplantNumber&amp;fldPltName=toplantName&amp;fldName=toitemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input name="toitemDescription" value="$(toitemdescription)" type="text" size="30" maxlength="30"></td>
                              </tr>
                              @DspErrMsg(Err_TOPN)

                          </table>
                          %INCLUDE "MaintainBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </form>
                  </td>
              </tr>
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(EDIT_COPYALL) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(toitemNumber)
  @dtw_assign(toplantNumber,@dtw_rstrip(toplantNumber))
  @dtw_assign(SUBR, "SRCpyAll")

  @dtw_assign(edtVar, "")
  @Concat_Field("@@fplt", plantNumber)
  @Concat_Field("@@fitm", itemNumber)
  @Concat_Field("@@tplt", toplantNumber)
  @Concat_Field("@@titm", toitemNumber)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, maintCode, errFound, edtVar, errVar, SUBR)

  %if (errFound == "")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)ProductStructure.d2w/REPORT$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(toitemNumber)&amp;plantNumber=@dtw_rurlescseq(toplantNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/COPYALL$(d2wVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;toitemNumber=@dtw_rurlescseq(toitemNumber)&amp;toplantNumber=@dtw_rurlescseq(toplantNumber)&amp;plantName=@dtw_rurlescseq(plantName)&amp;itemDescription=@dtw_rurlescseq(itemDescription)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}

%HTML(DELETEALL) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(SUBR, "SRDelAll")

  @dtw_assign(edtVar, "")
  @Concat_Field("@@fplt", plantNumber)
  @Concat_Field("@@fitm", itemNumber)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, maintCode, errFound, edtVar, errVar, SUBR)

  %if (errFound == "")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)ProductStructure.d2w/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
  %else
      @DecatErr_Field("@@plt@", "sequenceNumber")
      @Format_ConfMsg_Desc("", $(fieldValue), "", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ProductStructure.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;sequenceNumber=@dtw_rurlescseq(sequenceNumber)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %endif
%}
