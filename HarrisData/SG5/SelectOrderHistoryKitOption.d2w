%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Kit Options Inquiry"
  d2wName                 = "SelectOrderHistoryKitOption.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;salesmanNumber=@dtw_rurlescseq(salesmanNumber)&amp;salesmanName=@dtw_rurlescseq(salesmanName)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;orderSequence=@dtw_rurlescseq(orderSequence)&amp;noMenu=@dtw_rurlescseq(noMenu)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "1000"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "1000"
  prtMaxRows              = "1000"
  rowIndexNext            = "1"
  totalPages              = "0"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onLoad="window.focus()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select OEKTDH.*, OEORDH.* ", stmtSQL)
                      @dtw_concat(fileSQL, " OEKTDH inner join OEORDH on HKORD#=DHORD# and HKSEQ#=DHSEQ# and HKORL#=DHORL# ", fileSQL)
                      @dtw_concat(selectSQL, "HKORD#=$(orderNumber) and HKSEQ#=$(orderSequence) and HKORL#=$(lineNumber) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Kit_Option_History(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Kit_Option_History (IN CHAR(64)    profileHandle,
                                          CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
          %INCLUDE "PageTitle.icl"
          $(inquiryhrTagAttr)
          @dtw_assign(saveKit, "")
		
          %ROW{
              %if (saveKit == "")
                  <table $(contentTable)>
                      <tr>
                          <td class="colhdr">Order Number</td>
                          <td class="colhdr">Ln</td>
                          <td class="colhdr">Item Number</td>
                          <td class="colhdr">Description</td>
                          <td class="colhdr">Quantity</td>
                          <td class="colhdr">Price</td>
                          <td class="colhdr">Extended Price</td>
                      </tr>
                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          <td class="colnmbr">$(V_DHORD#)</td>		
                          <td class="colnmbr">$(V_DHORL#)</td>		
                          <td class="colalph">$(V_DHITEM)</td>		
                          <td class="colalph">$(V_DHIMDS)</td>		
                          @Format_Nbr(V_DHQORD, F_DHQORD, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                          <td class="colnmbr">$(F_DHQORD)</td>
                          @Format_Nbr(V_DHSLPR, F_DHSLPR, $(prcNbrDec), $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_DHSLPR)</td>
                          @Format_Nbr("@dtw_rmultiply(V_DHQORD, V_DHSLPR)", ExtendedPrice, "2", $(amtEditCode), "Y", "$", "")
                          <td class="colnmbr">$(ExtendedPrice)</td>
                      </tr>
                  </table>
                  <table $(contentTable)>
                      <tr>
                          <td class="colhdr">Component</td>
                          <td class="colhdr">Option</td>
                          <td class="colhdr">Description</td>
                          <td class="colhdr">Quantity</td>
                          <td class="colhdr">Extra Charge</td>
                      </tr>
              %endif

              %if (V_HKOITM != "")
                  @RtvFldDesc("IMITEM='$(V_HKOITM)'", "HDIMST", "IMIMDS", optionDesc)
              %endif

              %if (saveKit != V_HKCITM)
                  @RtvFldDesc("IMITEM='$(V_HKCITM)'", "HDIMST", "IMIMDS", compDesc)
                  %INCLUDE "SetRowClass.icl"
                  @dtw_assign(saveKit, V_HKCITM)
                  @dtw_assign(newKit, V_HKCITM)
                  %if (V_HKOITM != "")
                      <tr class="$(rowClass)">
                          <td class="colalph">$(newKit)</td>
                          <td class="colalph">&nbsp;</td>
                          <td class="colalph">$(compDesc)</td>
                          <td class="colnmbr">&nbsp;</td>
                          <td class="colnmbr">&nbsp;</td>
                      </tr>
                  %endif
              %else
                  @dtw_assign(newKit, "")
              %endif

              <tr class="$(rowClass)">
                  %if (V_HKOITM != "")
                      <td class="colalph">&nbsp;</td>
                  %else
                      <td class="colalph">$(newKit)</td>
                  %endif
                  <td class="colalph">$(V_HKOITM)</td>
                  %if (V_HKOITM != "")
                      <td class="colalph">$(optionDesc)</td>
                  %else
                      <td class="colalph">$(compDesc)</td>
                  %endif
                  @Format_Nbr(V_HKQORD, F_HKQORD, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  <td class="colnmbr">$(F_HKQORD)</td>
                  @Format_Nbr(V_HKXCHG, F_HKXCHG, $(prcNbrDec), $(amtEditCode), "", "$", "")
                  <td class="colnmbr">$(F_HKXCHG)</td>
              </tr>
          %}
      </table>
      $(inquiryhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}