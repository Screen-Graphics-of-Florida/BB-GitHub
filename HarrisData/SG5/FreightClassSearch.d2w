%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Freight Class Search"
  d2wName                 = "FreightClassSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  novcf                   = ""
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function selectFreightClass(freightClass, desc){
                      window.opener.document.$(docName).$(fldName).value = freightClass;
                      window.opener.document.$(docName).$(fldDesc).value = desc;
                      window.opener.document.$(docName).$(fldName).focus();
                      window.close();
                  }
                  %INCLUDE "CheckEnterSearch.icl"
                  %INCLUDE "NoFormValidate.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "$(searchBanner)"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      <td class="content">

                      %INCLUDE "stmtSQLClear.icl"
                      %if (moreInfo == "Y")
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      %else
                          @dtw_concat(stmtSQL, " Select FTCLAS, FTLD01, upper(FTLD01) as FTLD01U, FTHAZM, FTNMFC ", stmtSQL)
                      %endif
                      @dtw_concat(fileSQL, " HDFTCL ", fileSQL)
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, " FTCLAS='$(frtClass)' ", selectSQL)
                      %elif (wildCardSearch!="")
                          @dtw_concat(selectSQL, " FTCLAS<>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"

                      @FreightClass_Search(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "$(searchTrailer)"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}
%FUNCTION(dtw_sql) FreightClass_Search (IN CHAR(64)    profileHandle,
     	                                    CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Description</th></tr>
                  <tr>
                      <td class="inputalph">
                          <input type="text" name="srchDesc" size="15" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>
	
          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("FTCLAS", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=class" title="Sequence By Freight Class"> Freight<br>Class</a></th>
                  @OrderBy_Sort("FTLD01U", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=desc" title="Sequence By Description, Freight Class"> Description</a></th>
                  @OrderBy_Sort("FTHAZM", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=hazMat" title="Sequence By Hazardous Material, Freight Class"> Hazardous<br>Material</a></th>
                  @OrderBy_Sort("FTNMFC", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=carrier" title="Sequence By Carrier Class, Freight Class"> Carrier<br>Class</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %else
          <table $(contentTable)>
      %endif		

              %ROW{
                  %INCLUDE "SetRowClass.icl"
                   @Format_Quote(V_FTCLAS, F_FTCLAS)
                   @Format_Quote(V_FTLD01, F_FTLD01)

    	      %if (moreInfo != "Y")	
                      <tr class="$(rowClass)">
                          <td class="colalph">$(V_FTCLAS)</td>

                          <td class="colalph"><a href="javascript:selectFreightClass('$(F_FTCLAS)', '$(F_FTLD01)')" title="Select Freight Class">$(V_FTLD01)</a></td>

                          <td class="colcode">$(V_FTHAZM)</td>
                          <td class="colalph">$(V_FTNMFC)</td>
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;frtClass=@dtw_rurlescseq(V_FTCLAS)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                      </tr>

                  %else
                      %{ More Information Page %}

                      <tr><td><a href="javascript:selectFreightClass('$(F_FTCLAS)','$(F_FTLD01)')" title="Select Freight Class">$(selectImageLrg)</a>
                          </td>
                      </tr>

                      <tr><td class="dsphdr">Freight Class</td>
                          <td class="dspalph">$(V_FTCLAS)</td>
                      </tr>

                      <tr><td class="dsphdr">Short Description</td>
                          <td class="dspalph">$(V_FTCLSD)</td>
                      </tr>

      	               <tr><td class="dsphdr">Long Description One</td>
                          <td class="dspalph">$(V_FTLD01)</td>
                      </tr>

                      <tr><td class="dsphdr">Long Description Two</td>
                          <td class="dspalph">$(V_FTLD02)</td>
                      </tr>

                      <tr><td class="dsphdr">Long Description Three</td>
                          <td class="dspalph">$(V_FTLD03)</td>
                      </tr>

                      <tr><td class="dsphdr">Carrier Freight Class</td>
                          <td class="dspalph">$(V_FTNMFC)</td>
                      </tr>

                      @RtvYNDesc($(V_FTHAZM), fieldDesc)
                      <tr><td class="dsphdr">Hazardous Material Code</td>
                          <td>$(fieldDesc)</td>
                      </tr>

                      %if (V_FTHAZM == "Y")
                          @Format_Nbr(V_FTRPQT, F_FTRPQT, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                          <tr><td class="dsphdr">HM Reportable Quantity</td>
                              <td class="inputnmbr">$(F_FTRPQT)</td>
                          </tr>

                          @RtvFldDesc("UMUOM='$(V_FTRQUM)'", "HDUOM", "UMUMLD", fieldDesc)
                          <tr><td class="dsphdr">Reportable Quantity U/M</td>
                              <td class="dspalph">$(V_FTRQUM) - $(fieldDesc)</td>
                          </tr>
                      %endif

                  %endif
              %}
          </table>
	   %if (moreInfo != "Y")	
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
	   %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "FTLD01U,FTCLAS")
      @DTW_ASSIGN(orderByDisplay, "Description, Freight Class")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(orderBy, "FTCLAS")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY)
{
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "class")
      %if (orderBy == "FTCLAS")
          @DTW_ASSIGN(orderBy, "FTCLAS DESC")
          @DTW_ASSIGN(orderByDisplay, "Freight Class (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FTCLAS")
          @DTW_ASSIGN(orderByDisplay, "Freight Class")
      %endif
  %elif (sequence == "desc")
      %if (orderBy == "FTLD01U,FTCLAS")
          @DTW_ASSIGN(orderBy, "FTLD01U DESC,FTCLAS")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Freight Class")
      %else
          @DTW_ASSIGN(orderBy, "FTLD01U,FTCLAS")
          @DTW_ASSIGN(orderByDisplay, "Description, Freight Class")
      %endif
  %elif (sequence == "hazMat")
      %if (orderBy == "FTHAZM,FTCLAS")
          @DTW_ASSIGN(orderBy, "FTHAZM DESC,FTCLAS")
          @DTW_ASSIGN(orderByDisplay, "Hazardous Material (descending), Freight Class")
      %else
          @DTW_ASSIGN(orderBy, "FTHAZM,FTCLAS")
          @DTW_ASSIGN(orderByDisplay, "Hazardous Material, Freight Class")
      %endif
  %elif (sequence == "carrier")
      %if (orderBy == "FTNMFC,FTCLAS")
          @DTW_ASSIGN(orderBy, "FTNMFC DESC,FTCLAS")
          @DTW_ASSIGN(orderByDisplay, "Carrier Class (descending), Freight Class")
      %else
          @DTW_ASSIGN(orderBy, "FTNMFC,FTCLAS")
          @DTW_ASSIGN(orderByDisplay, "Carrier Class, Freight Class")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH)
{
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchDesc" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Freight Class</td>
                              @dtw_assign(operNbr, "operClass")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchClass" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">Hazardous Material</td>
                              @dtw_assign(operNbr, "operHaz")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchHaz" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Carrier Class</td>
                              @dtw_assign(operNbr, "operCarrier")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCarrier" size="5" maxlength="5"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDesc.focus();
                          </script>
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD)
{
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("upper(FTLD01)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("FTCLAS", "Freight Class", $(srchClass), "U", operClass, "A")
  @Build_WildCard ("FTHAZM", "Hazardous Material", $(srchHaz), "U", operHaz, "A")
  @Build_WildCard ("FTNMFC", "Carrier Class", $(srchCarrier), "U", operCarrier, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}