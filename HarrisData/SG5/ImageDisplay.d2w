%INCLUDE "$(baseVar)"

%Define {
  page_title              = "Image Display"
  DATABASE                = "*LOCAL"
%}

%HTML(DISPLAY) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
      </head>

      <body $(bodyTagAttr) onLoad="window.focus()" onBlur="window.close()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(imageBanner)"
          <!-- End Of Banner Code -->

          %if (imageDesc !="")
              <h2 align="center">$(imageDesc)</h2>
          %endif

          $(hrTagAttr)

          <table $(contentTable)>
              <tr><td><img src="$(imageDisplayPath)" hspace="25%" alt="No Picture Found"></td></tr>
	   </table>

          $(hrTagAttr)

	   <table $(contentTable)>
              <tr><td>%INCLUDE "CloseWindow.icl"</td></tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(imageTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}