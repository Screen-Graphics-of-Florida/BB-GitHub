%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Routing Notes"
  d2wName                 = "RoutingNotesInquiry.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;sequenceNumber=@dtw_rurlescseq(sequenceNumber)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      @dtw_concat(stmtSQL, " Select ODDOCT, ODDESC From HDMODM ", stmtSQL)
                      @dtw_concat(stmtSQL, " Where (ODPLT=$(plantNumber) and ODPN='$(itemNumber)' ", stmtSQL)
                      @dtw_concat(stmtSQL, " and ODSEQN=$(sequenceNumber)) ", stmtSQL)
                      @dtw_concat(stmtSQL, " Order By ODDOCT, ODLINE ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Routing_Notes_Inquiry(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Routing_Notes_Inquiry (IN CHAR(64)    profileHandle,
				              CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"

      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
      <table $(contentTable)>
          @Format_Header("Plant", $(plantName), $(plantNumber))
          @Format_Header("Item", $(itemDescription), $(itemNumber))
          @Format_Header("Sequence", $(sequenceNumber), "")
      </table>

      $(inquiryhrTagAttr)

      <table $(contentTable)>
          @dtw_assign(previousDocType,"")

          %ROW{
              %if (V_ODDOCT != previousDocType)
                  @RtvFldDesc("DODOCT='$(V_ODDOCT)'", "HDDOCT", "DODESC", fieldDesc)
                  @Format_Code(V_ODDOCT, F_ODDOCT)
                  <tr><td class="colhdr">$(fieldDesc) $(F_ODDOCT)</td></tr>
              %endif
              @dtw_assign(previousDocType, V_ODDOCT)
              <tr><td class="colalph">$(V_ODDESC)</td></tr>
          %}
      </table>
      $(inquiryhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}