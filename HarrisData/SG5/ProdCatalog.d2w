%INCLUDE "$(baseVar)"
%INCLUDE "$(catalogVarName)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "OrderEntry.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Catalog"
  d2wName                 = "ProdCatalog.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;catalogVarName=@dtw_rurlescseq(catalogVarName)&amp;catalog=@dtw_rurlescseq(catalog)&amp;catalogDesc=@dtw_rurlescseq(catalogDesc)&amp;cntr=@dtw_rurlescseq(cntr)&amp;pcnt=@dtw_rurlescseq(pcnt)&amp;prnt=@dtw_rurlescseq(prnt)&amp;chld=@dtw_rurlescseq(chld)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  START_ROW_NUM           = "1"
  DTW_SET_TOTAL_ROWS      = "YES"
  RPT_MAX_ROWS            = "10"
  PARENT_MAX_ROWS         = "@dtw_rmultiply($(catParentPerRow), $(catNbrOfRows))"
  CHILD_MAX_ROWS          = "@dtw_rmultiply($(catChildPerRow), $(catNbrOfRows))"
  ITEM_MAX_ROWS           = "@dtw_rmultiply($(catItemsPerRow), $(catNbrOfRows))"
  ROW_NUM                 = "0"
  rowIndexNext            = "1"
  cntr	                   = "000000000"
  pcnt	                   = "000000000"
  svcntr                  = ""
  svpcnt                  = ""
  svprnt                  = ""
  svchld                  = ""
  svcscn                  = ""
  retrieveCode            = "R"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "headcat.icl"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "numzero.icl"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "$(catBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (dspMenuOptions != "N")
                      @dtw_assign(pageID, "CATALOGORDERENTRY")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %if (dspHdrCat=="Y")
                          @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                          @dtw_assign(START_ROW_NUM, "1")
                          @dtw_assign(SAVE_MAX_ROWS, RPT_MAX_ROWS)
                          @dtw_assign(RPT_MAX_ROWS, "9999")
                          @Header_Query(profileHandle, dataBaseID, catalog, "000000000", "000000000", "", "", "")
                          @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                          @dtw_assign(RPT_MAX_ROWS, SAVE_MAX_ROWS)
                      %endif
                      %if (dspHdrCat!="Y" || (dspHdrCat=="Y" && cntr!="000000000"))
                          @Check_Level(profileHandle, dataBaseID, catalog, cntr, pcnt, prnt, chld, itemLevel)
                          %if (prnt=="")
                               @dtw_assign(RPT_MAX_ROWS, PARENT_MAX_ROWS)
                          %elif (itemLevel=="Y")
                               @dtw_assign(RPT_MAX_ROWS, ITEM_MAX_ROWS)
                          %elif (chld!="")
                               @dtw_assign(RPT_MAX_ROWS, CHILD_MAX_ROWS)
                          %endif

                          @Catalog_Query(profileHandle, dataBaseID, catalog, cntr, pcnt, prnt, chld, cscn)
                      %else
                          $(cathrTagAttr)
                          %INCLUDE "Copyright.icl"
                      %endif
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(catTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Header_Query  (IN  CHAR(64)  profileHandle,
				       CHAR(2)   dataBaseID,
				       CHAR(15)  catalog,
				       DEC(9,0)  cntr,
				       DEC(9,0)  pcnt,
				       CHAR(40)  prnt,
				       CHAR(40)  chld,
				       CHAR(1)   cscn)
{CALL $(pgmLibrary)HOECTD_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="50%">
              <col width="10%">
              <col width="35%">
          <tr><td><h1>$(catalogDesc)</h1></td>
              <td nowrap>
                  <a href="$(homeURL)$(cGIPath)ProdCatalogItems.d2w/REPORT$(genericVarBase)&amp;catalogVarName=@dtw_rurlescseq(catalogVarName)&amp;catalog=@dtw_rurlescseq(catalog)&amp;catalogDesc=@dtw_rurlescseq(catalogDesc)&amp;catalogHeaderPage=@dtw_rurlescseq(blank)&amp;srchCatalog=Y&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;cscn=@dtw_rurlescseq(cscn)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))" onclick="$(catItemWinVar)">$(goSearchImageLrg)</a>
                  %if (catSeqOrderQty > "0")
                      <a href="$(homeURL)$(cGIPath)ProdCatalogViewCart.d2w/VIEW$(d2wVarBase)" onclick="$(viewCartWinVar)">$(viewCartImage)</a>
                  %endif
                  %INCLUDE "HelpPage.icl"
              </td>
              %if (catSeqOrderQty > "0")
                  @dtw_assign(edtVar, "")
                  @Order_Control(profileHandle, dataBaseID, orderControlNumber, retrieveCode, dropShip, edtVar)
                  @RtvFldDesc("O1OCTL=$(orderControlNumber) and O1BLN#=0", "OEDTWK", " char(count(O1ITEM))", numberOfItems)
                  @Format_Nbr(numberOfItems, F_numberOfItems, "0", "3", "", "", "")
                  <td>
                      <table $(contentTable)>
                          @Format_Header("Item Count", $(F_numberOfItems), "")
                          %if (allowInquiryOnly != "Y")
                              @RtvFldDesc("H1OCTL=$(orderControlNumber)", "OEHDWK", "char(H1OTOT)", orderTotal)
                              @Format_Nbr(orderTotal, F_orderTotal, "2", $(amtEditCode), "", "$", "")
                              @Format_Header("Order Total", $(F_orderTotal), "")
                          %endif
                      </table>
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(cathrTagAttr)

      @dtw_add(START_ROW_NUM, RPT_MAX_ROWS, rowIndexNext)
      @dtw_assign(groupCount, "0")
      <table $(contentTable)>

          %ROW{
              @dtw_assign(cntr, "$(V_CXCNTR)")
              @dtw_assign(pcnt, "$(V_CXPCNT)")
              @dtw_assign(prnt, "$(V_CXPRNT)")
              @dtw_assign(chld, "$(V_CXCHLD)")
              @dtw_assign(cscn, "$(V_CXCSCN)")
              %INCLUDE "SetRowClass.icl"
              @dtw_assign(x, "1")
              @dtw_assign(indent, "")
              %while(x < V_CXINDT) {@dtw_add(x, "1", x)
                  @dtw_concat($(catIndentChar), indent, indent)
              %}

              @dtw_assign(desc, $(V_CXDESC))
              @dtw_assign(catalogHeaderPage, "")
              @dtw_assign(hdrExists, "")
              %if (V_CXUHTM!="")
                  @dtw_assign(checkHdr, "$(V_CXUHTM)")
                  @dtwf_exists(checkHdr, hdrExists)
              %endif

              %if (hdrExists == "Y")
                   @dtw_assign(catalogHeaderPage, "$(V_CXUHTM)")
              %else
                   @dtw_assign(catalogHeaderPage, "$(blank)")
              %endif

              %if (firstItem == "N")
                  @dtw_assign(firstItem, "Y")
                  </table>
                  <table $(contentTable)>
              %endif

              %if (groupCount=="0")
                  <tr class="$(rowClass)">
              %endif

              @dtw_assign(imageExists, "")
              %if (V_CXIMG!="")
                  @dtw_assign(chldImage, "$(V_CXIMG)")
                  @dtwf_exists(chldImage, imageExists)
              %endif
              @dtw_add(groupCount, "1", groupCount)
              %if (cntr==svcntr && pcnt==svpcnt && prnt==svprnt && chld==svchld)
                  %if (V_CXIMG!="" && imageExists == "Y")
                      <td><img src="$(homeURL)$(chldImage)" alt="" title="Select $(desc)" $(catParentImgSize) $(catImgBorder)>
                       %if (dspParentDesc == "Y")
                          <br>$(selLeftImage)$(desc)$(selRightImage)
                      %endif
                      </td>
                 %else
                      <td>$(selLeftImage)$(desc)$(selRightImage)</td>
                  %endif
              %else
                  %if (V_CXCSCN=="I")
                      %if (V_CXIMG!="" && imageExists == "Y")
                          <td><a href="$(homeURL)$(cGIPath)ProdCatalogItems.d2w/REPORT$(genericVarBase)&amp;catalogVarName=@dtw_rurlescseq(catalogVarName)&amp;catalog=@dtw_rurlescseq(catalog)&amp;catalogDesc=@dtw_rurlescseq(catalogDesc)&amp;catalogHeaderPage=@dtw_rurlescseq(catalogHeaderPage)&amp;chldDesc=@dtw_rurlescseq(desc)&amp;chldImage=@dtw_rurlescseq(chldImage)&amp;cntr=@dtw_rurlescseq(cntr)&amp;pcnt=@dtw_rurlescseq(pcnt)&amp;prnt=@dtw_rurlescseq(prnt)&amp;chld=@dtw_rurlescseq(chld)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;cscn=@dtw_rurlescseq(cscn)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))" onclick="$(catItemWinVar)"><img src="$(homeURL)$(chldImage)" alt="" title="Display Items For $(desc)" $(catParentImgSize) $(catImgBorder)></a>
                      %if (dspParentDesc == "Y")
                          <br>$(desc)
                      %endif
                      </td>
                      %else
                          <td><a href="$(homeURL)$(cGIPath)ProdCatalogItems.d2w/REPORT$(genericVarBase)&amp;catalogVarName=@dtw_rurlescseq(catalogVarName)&amp;catalog=@dtw_rurlescseq(catalog)&amp;catalogDesc=@dtw_rurlescseq(catalogDesc)&amp;catalogHeaderPage=@dtw_rurlescseq(catalogHeaderPage)&amp;chldDesc=@dtw_rurlescseq(desc)&amp;chldImage=@dtw_rurlescseq(chldImage)&amp;cntr=@dtw_rurlescseq(cntr)&amp;pcnt=@dtw_rurlescseq(pcnt)&amp;prnt=@dtw_rurlescseq(prnt)&amp;chld=@dtw_rurlescseq(chld)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;cscn=@dtw_rurlescseq(cscn)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))" onclick="$(catItemWinVar)">$(desc)</a></td>
                      %endif
                  %else
                      %if (V_CXIMG!="" && imageExists == "Y")
                          <td><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;item=@dtw_rurlescseq(V_CXITEM)&amp;cscn=@dtw_rurlescseq(V_CXCSCN)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))"><img src="$(homeURL)$(chldImage)" alt="" title="Select $(desc)" $(catParentImgSize) $(catImgBorder)></a>
                      %if (dspParentDesc == "Y")
                          <br>$(desc)
                      %endif
                      </td>
                      %else
                          <td><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;item=@dtw_rurlescseq(V_CXITEM)&amp;cscn=@dtw_rurlescseq(V_CXCSCN)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">$(desc)</a></td>
                      %endif
                  %endif
              %endif
              %if (groupCount=="$(catParentPerRow)")
                  </tr>
                  @dtw_assign(groupCount, "0")
              %endif
          %}
      </table>
          %if (START_ROW_NUM > RPT_MAX_ROWS)
              <a href="input$(genericVarBase)&amp;START_ROW_NUM=@DTW_RSUBTRACT(START_ROW_NUM, RPT_MAX_ROWS)&amp;RPT_MAX_ROWS=@dtw_rurlescseq(RPT_MAX_ROWS)&amp;catalogVarName=@dtw_rurlescseq(catalogVarName)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;catalog=@dtw_rurlescseq(catalog)&amp;catalogDesc=@dtw_rurlescseq(catalogDesc)&amp;cntr=@dtw_rurlescseq(svcntr)&amp;pcnt=@dtw_rurlescseq(svpcnt)&amp;prnt=@dtw_rurlescseq(svprnt)&amp;chld=@dtw_rurlescseq(svchld)&amp;cscn=@dtw_rurlescseq(svcscn)">$(previousImage)</a>
          %endif

          %if (TOTAL_ROWS >= rowIndexNext)
              <a href="input$(genericVarBase)&amp;START_ROW_NUM=$(rowIndexNext)&amp;RPT_MAX_ROWS=@dtw_rurlescseq(RPT_MAX_ROWS)&amp;catalogVarName=@dtw_rurlescseq(catalogVarName)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;catalog=@dtw_rurlescseq(catalog)&amp;catalogDesc=@dtw_rurlescseq(catalogDesc)&amp;cntr=@dtw_rurlescseq(svcntr)&amp;pcnt=@dtw_rurlescseq(svpcnt)&amp;prnt=@dtw_rurlescseq(svprnt)&amp;chld=@dtw_rurlescseq(svchld)&amp;cscn=@dtw_rurlescseq(svcscn)">$(nextImage)</a>
          %endif
  %}
%}
%FUNCTION(dtw_sql) Catalog_Query (IN  CHAR(64)  profileHandle,
				       CHAR(2)   dataBaseID,
				       CHAR(15)  catalog,
				       DEC(9,0)  cntr,
				       DEC(9,0)  pcnt,
				       CHAR(40)  prnt,
				       CHAR(40)  chld,
				       CHAR(1)   cscn)
{CALL $(pgmLibrary)HOECTD_W

  %REPORT{
      %if (dspHdrCat=="N")
          <table $(contentTable)>
              <colgroup>
                  <col width="50%">
                  <col width="10%">
                  <col width="35%">
              <tr><td><h1>$(catalogDesc)</h1></td>
                  <td>
                      <a href="$(homeURL)$(cGIPath)ProdCatalogItems.d2w/REPORT$(genericVarBase)&amp;catalogVarName=@dtw_rurlescseq(catalogVarName)&amp;catalog=@dtw_rurlescseq(catalog)&amp;catalogDesc=@dtw_rurlescseq(catalogDesc)&amp;catalogHeaderPage=@dtw_rurlescseq(blank)&amp;srchCatalog=Y&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;cscn=@dtw_rurlescseq(cscn)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))" onclick="$(catItemWinVar)">$(goSearchImageLrg)</a>
                      %if (catSeqOrderQty > "0")
                          <a href="$(homeURL)$(cGIPath)ProdCatalogViewCart.d2w/VIEW$(d2wVarBase)" onclick="$(viewCartWinVar)">$(viewCartImage)</a>
                      %endif
                      %INCLUDE "HelpPage.icl"
                  </td>
                  %if (catSeqOrderQty > "0")
                      @dtw_assign(edtVar, "")
                      @Order_Control(profileHandle, dataBaseID, orderControlNumber, retrieveCode, dropShip, edtVar)
                      @RtvFldDesc("O1OCTL=$(orderControlNumber) and O1BLN#=0", "OEDTWK", " char(count(O1ITEM))", numberOfItems)
                      @RtvFldDesc("H1OCTL=$(orderControlNumber)", "OEHDWK", "char(H1OTOT)", orderTotal)
                      @Format_Nbr(numberOfItems, F_numberOfItems, "0", "3", "", "", "")
                      @Format_Nbr(orderTotal, F_orderTotal, "2", $(amtEditCode), "", "$", "")
                      <td>
                          <table $(contentTable)>
                              @Format_Header("Item Count", $(F_numberOfItems), "")
                              @Format_Header("Order Total", $(F_orderTotal), "")
                          </table>
                      </td>
                  %endif
              </tr>
          </table>

          $(cathrTagAttr)
      %endif

      @Order_Control(profileHandle, dataBaseID, orderControlNumber, retrieveCode, dropShip, edtvar)

      @dtw_add(START_ROW_NUM, RPT_MAX_ROWS, rowIndexNext)

      @dtw_assign(groupCount, "0")
      @dtw_assign(firstItem, "Y")
      <table $(contentTable)>

          %ROW{
              @dtw_assign(cntr, "$(V_CXCNTR)")
              @dtw_assign(pcnt, "$(V_CXPCNT)")
              @dtw_assign(prnt, "$(V_CXPRNT)")
              @dtw_assign(chld, "$(V_CXCHLD)")
              @dtw_assign(cscn, "$(V_CXCSCN)")
              %INCLUDE "SetRowClass.icl"
              @dtw_assign(x, "1")
              @dtw_assign(indent, "")
              %while(x < V_CXINDT) {@dtw_add(x, "1", x)
                  @dtw_concat($(catIndentChar), indent, indent)
              %}

              @dtw_assign(desc, $(V_CXDESC))

              @dtw_assign(catalogHeaderPage, "")
              @dtw_assign(imageExists, "")
              %if (V_CXUHTM!="")
                  @dtw_assign(checkHdr, "$(V_CXUHTM)")
                  @dtwf_exists(checkHdr, imageExists)
              %endif

              %if (imageExists == "Y")
                   @dtw_assign(catalogHeaderPage, "$(V_CXUHTM)")
              %else
                   @dtw_assign(catalogHeaderPage, "$(blank)")
              %endif

              %if (firstItem == "N")
                  @dtw_assign(firstItem, "Y")
                  </table>
                  <table $(contentTable)>
              %endif
              %if (groupCount=="0")
                  <tr class="$(rowClass)">
              %endif
                  @dtw_assign(imageExists, "")
                  %if (V_CXIMG!="")
                      @dtw_assign(chldImage, "$(V_CXIMG)")
                      @dtwf_exists(chldImage, imageExists)
                  %endif
                  @dtw_add(groupCount, "1", groupCount)

                  %if (V_CXIMG!="" && imageExists == "Y")
                      %if (V_CXCSCN=="I")
                          <td align="center">$(indent)<a href="$(homeURL)$(cGIPath)ProdCatalogItems.d2w/REPORT$(genericVarBase)&amp;catalogVarName=@dtw_rurlescseq(catalogVarName)&amp;catalog=@dtw_rurlescseq(catalog)&amp;catalogDesc=@dtw_rurlescseq(catalogDesc)&amp;catalogHeaderPage=@dtw_rurlescseq(catalogHeaderPage)&amp;chldDesc=@dtw_rurlescseq(desc)&amp;chldImage=@dtw_rurlescseq(chldImage)&amp;cntr=@dtw_rurlescseq(cntr)&amp;pcnt=@dtw_rurlescseq(pcnt)&amp;prnt=@dtw_rurlescseq(prnt)&amp;chld=@dtw_rurlescseq(chld)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;cscn=@dtw_rurlescseq(cscn)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))" onclick="$(catItemWinVar)"><img src="$(homeURL)$(chldImage)" alt="" title="Display Items For $(desc)" $(catChildImgSize) $(catImgBorder)></a>
                      %else
                          <td align="center">$(indent)<a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;item=@dtw_rurlescseq(V_CXITEM)&amp;cscn=@dtw_rurlescseq(V_CXCSCN)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))"><img src="$(homeURL)$(chldImage)" alt="" title="Select $(desc)" $(catChildImgSize) $(catImgBorder)></a>
                      %endif
                      %if (dspChildDesc == "Y")
                          <br>$(desc)
                      %endif
                      </td>
                  %else
                      %if (V_CXCSCN=="I")
                          <td>$(indent)<a href="$(homeURL)$(cGIPath)ProdCatalogItems.d2w/REPORT$(genericVarBase)&amp;catalogVarName=@dtw_rurlescseq(catalogVarName)&amp;catalog=@dtw_rurlescseq(catalog)&amp;catalogDesc=@dtw_rurlescseq(catalogDesc)&amp;catalogHeaderPage=@dtw_rurlescseq(catalogHeaderPage)&amp;chldDesc=@dtw_rurlescseq(desc)&amp;chldImage=@dtw_rurlescseq(chldImage)&amp;cntr=@dtw_rurlescseq(cntr)&amp;pcnt=@dtw_rurlescseq(pcnt)&amp;prnt=@dtw_rurlescseq(prnt)&amp;chld=@dtw_rurlescseq(chld)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;cscn=@dtw_rurlescseq(cscn)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))" onclick="$(catItemWinVar)"  title="Display Items For $(desc)">$(desc)</a></td>
                      %else
                          <td>$(indent)<a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;item=@dtw_rurlescseq(V_CXITEM)&amp;cscn=@dtw_rurlescseq(V_CXCSCN)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))" title="Display Items For $(desc)">$(desc)</a></td>
                      %endif
                  %endif

              %if (groupCount=="$(catChildPerRow)")
                  </tr>
                  @dtw_assign(groupCount, "0")
              %endif
          %}
      </table>
      %if (START_ROW_NUM > RPT_MAX_ROWS)
          <a href="input$(genericVarBase)&amp;START_ROW_NUM=@DTW_RSUBTRACT(START_ROW_NUM, RPT_MAX_ROWS)&amp;catalogVarName=@dtw_rurlescseq(catalogVarName)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;catalog=@dtw_rurlescseq(catalog)&amp;catalogDesc=@dtw_rurlescseq(catalogDesc)&amp;cntr=@dtw_rurlescseq(svcntr)&amp;pcnt=@dtw_rurlescseq(svpcnt)&amp;prnt=@dtw_rurlescseq(svprnt)&amp;chld=@dtw_rurlescseq(svchld)&amp;cscn=@dtw_rurlescseq(svcscn)">$(previousImage)</a>
      %endif

      %if (TOTAL_ROWS >= rowIndexNext)
          <a href="input$(genericVarBase)&amp;START_ROW_NUM=$(rowIndexNext)&amp;catalogVarName=@dtw_rurlescseq(catalogVarName)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;catalog=@dtw_rurlescseq(catalog)&amp;catalogDesc=@dtw_rurlescseq(catalogDesc)&amp;cntr=@dtw_rurlescseq(svcntr)&amp;pcnt=@dtw_rurlescseq(svpcnt)&amp;prnt=@dtw_rurlescseq(svprnt)&amp;chld=@dtw_rurlescseq(svchld)&amp;cscn=@dtw_rurlescseq(svcscn)">$(nextImage)</a>
      %endif
      $(cathrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Check_Level (IN   CHAR(64)  profileHandle,
				             CHAR(2)   dataBaseID,
				             CHAR(15)  catalog,
				             DEC(9,0)  cntr,
				             DEC(9,0)  pcnt,
				             CHAR(40)  prnt,
				             CHAR(40)  chld,
				       INOUT CHAR(1)   itemLevel)
{%EXEC {HOECTI_W.PGM %}
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(svcntr, cntr)
  @dtw_assign(svpcnt, pcnt)
  @dtw_assign(svprnt, prnt)
  @dtw_assign(svchld, chld)
  @dtw_assign(svcscn, cscn)
  @Set_SQL(stmtSQL)
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(svcntr, cntr)
  @dtw_assign(svpcnt, pcnt)
  @dtw_assign(svprnt, prnt)
  @dtw_assign(svchld, chld)
  @dtw_assign(svcscn, cscn)
  @Set_SQL(stmtSQL)
%}