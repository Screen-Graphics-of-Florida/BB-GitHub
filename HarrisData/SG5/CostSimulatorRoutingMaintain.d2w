%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Cost Simulation Routing Maintenance"
  d2wName                 = "CostSimulatorRoutingMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(fromPlant)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;department=@dtw_rurlescseq(department)&amp;workCenter=@dtw_rurlescseq(workCenter)&amp;maintenanceCode=D"
  programName             = "HSCSIM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  function validate(chgForm) {
                      if (document.Chg.department.value =="" ||
                          document.Chg.workCenter.value =="" ||
                          document.Chg.measuredHours.value == "")
                             {alert("$(reqFieldError)");
                              return false;}
                      if (editNum(document.Chg.measuredHours, 3, 6) &&
                          editNum(document.Chg.laborRate, 3, 2) &&
                          editNum(document.Chg.variableRate, 4, 3) &&
                          editNum(document.Chg.fixedRate, 4, 3))
                          return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
	           %INCLUDE "numedit.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "COSTSIMULATORROUTINGMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "SELECT * FROM WRKRTM WHERE WKXHND='$(profileHandle)' and WKDEPT='$(department)' and WKWC='$(workCenter)'", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMIMDS", itemDescription)
      @RtvFldDesc("WKXHND='$(profileHandle)'", "WRKSIM", "WKCSET", costSet)
      @RtvFldDesc("WKXHND='$(profileHandle)'", "WRKSIM", "WKCUST", customerNumber)
      @RtvFldDesc("WKXHND='$(profileHandle)'", "WRKSIM", "WKQTY", orderQuantity)
      @RtvFldDesc("STCSET=$(costSet)", "SCMSTM", "STCSLD", costSetDesc)
      <table $(contentTable)>
    	   <colgroup>
    	       <col width="80%">
    	       <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  <a href="javascript:check(document.Chg)">$(acceptImageMed)</a>
                  <a href="javascript:history.back()">$(cancelImageMed)</a>
                  %if (maintenanceCode == "C")
                      <a onClick="return confirmDelete()" href="$(deleteURL)">$(deleteImageMed)</a>
                  %endif
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>

      <table $(contentTable)>
          @Format_Header("Plant", $(plantName), $(plantNumber))
          @Format_Header("Item", $(itemDescription), $(itemNumber))
          @Format_Header("Cost Set", "$(costSetDesc)", $(costSet))
          %if (customerNumber != "0")
              @RtvFldDesc("CMCUST=$(customerNumber)", "HDCUST", "CMCNA1", customerName)
              @Format_Header("Customer Number", "$(customerName)", $(customerNumber))
          %endif
          @Format_Header("Quantity", "$(orderQuantity)", "")
      </table>

      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "department")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@dept", "department")    @dtw_assign(Err_WKDEPT, fieldValue)
                          @DecatErr_Field("@@wc@@", "workCenter")    @dtw_assign(Err_WKWC,   fieldValue)
                          @DecatErr_Field("@@mhrs", "measuredHours") @dtw_assign(Err_WKMHRS, fieldValue)
                          @DecatErr_Field("@@slr@", "laborRate")     @dtw_assign(Err_WKSLR,  fieldValue)
                          @DecatErr_Field("@@var@", "variableRate")  @dtw_assign(Err_WKVAR,  fieldValue)
                          @DecatErr_Field("@@fix@", "fixedRate")     @dtw_assign(Err_WKFIX,  fieldValue)
                      %endif

                      @Decat_Field("@@dept")   @dtw_assign(V_WKDEPT, fieldValue)
                      @Decat_Field("@@wc@@")   @dtw_assign(V_WKWC,  fieldValue)
                      @Decat_Field("@@mhrs")   @dtw_assign(V_WKMHRS, fieldValue)
                      @Decat_Field("@@slr@")   @dtw_assign(V_WKSLR,  fieldValue)
                      @Decat_Field("@@var@")   @dtw_assign(V_WKVAR, fieldValue)
                      @Decat_Field("@@fix@")   @dtw_assign(V_WKFIX, fieldValue)

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_WKDEPT, "")
                      @dtw_assign(V_WKWC, "")
                      @dtw_assign(focusField, "department")
                  %else
                      @dtw_assign(focusField, "measuredHours")
                  %endif

                  @dtw_assign(deptwcDesc, "")
                  @RtvFldDesc("WCPLT=$(plantNumber) and WCDEPT='$(V_WKDEPT)' and WCWC='$(V_WKWC)'", "HDMWCM", "WCDESC", deptwcDesc)
                  @SetTextOvr(Err_WKDEPT)
                  <tr><td class="dsphdr"><span $(textOvr)>Department / Work Center</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="department" type="text" value="$(V_WKDEPT)" size="5" maxlength="5"> / <input name="workCenter" type="text" value="$(V_WKWC)" size="5" maxlength="5"> $(reqFieldChar) <a href="$(homeURL)$(phpPath)DeptWCSearch.php$(altVarBase)&amp;forPlant=@dtw_rurlescseq(plantNumber)&amp;docName=Chg&amp;flddept=department&amp;fldWC=workCenter&amp;fldDesc=WCDesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input disabled name="WCDesc" value="$(deptwcDesc)"  type="text" size="30"></td>
                      %else
                          @dtw_assign(F_DPWC, "$(V_WKDEPT) / $(V_WKWC)")
                          @Format_Code(F_DPWC, F_DPWC)
                          <td class="inputalph"><input name="department" type="hidden" value="$(V_WKDEPT)" size="5" maxlength="5"> <input name="workCenter" type="hidden" value="$(V_WKWC)" size="5" maxlength="5">$(deptwcDesc) &nbsp; $(F_DPWC)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_WKDEPT)

                  @SetTextOvr(Err_WKMHRS)
                  <tr><td class="dsphdr"><span $(textOvr)>Hours Per Piece</span></td>
                      <td class="inputnmbr"><input type="text" name="measuredHours" value="$(V_WKMHRS)" size="10" maxlength="10"> $(reqFieldChar) </td>
                  </tr>
                  @DspErrMsg(Err_WKMHRS)

                  @SetTextOvr(Err_WKSLR)
                  <tr><td class="dsphdr"><span $(textOvr)>Rate Per Hour</span></td>
                      <td class="inputnmbr"><input type="text" name="laborRate" value="$(V_WKSLR)" size="6" maxlength="6"></td>
                  </tr>
                  @DspErrMsg(Err_WKSLR)

                  @SetTextOvr(Err_WKVAR)
                  <tr><td class="dsphdr"><span $(textOvr)>Variable Rate</span></td>
                      <td class="inputnmbr"><input type="text" name="variableRate" value="$(V_WKVAR)" size="8" maxlength="8"></td>
                  </tr>
                  @DspErrMsg(Err_WKVAR)

                  @SetTextOvr(Err_WKFIX)
                  <tr><td class="dsphdr"><span $(textOvr)>Fixed Rate</span></td>
                      <td class="inputnmbr"><input type="text" name="fixedRate" value="$(V_WKFIX)" size="8" maxlength="8"></td>
                  </tr>
                  @DspErrMsg(Err_WKFIX)

              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>

      <table $(contentTable)>
          <tr>
              <td class="toolbar">
                  <a href="javascript:check(document.Chg)">$(acceptImageMed)</a>
                  <a href="javascript:history.back()">$(cancelImageMed)</a>
                  %if (maintenanceCode == "C")
                      <a onClick="return confirmDelete()" href="$(deleteURL)">$(deleteImageMed)</a>
                  %endif
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)      profileHandle,
                                        INOUT CHAR(10)      callSubr,
                                        INOUT CHAR(1)       maintenanceCode,
                                        INOUT CHAR(32000)   edtVar,                             	
                                        INOUT CHAR(32000)   errVar,
                                        INOUT CHAR(1)       errFound)

{%EXEC {HSCSIM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(itemNumber)
  @dtw_mUPPERCASE(department)
  @dtw_mUPPERCASE(workCenter)

  @dtw_assign(plantNumber,@dtw_rstrip(plantNumber))
  @dtw_assign(measuredHours,@dtw_rstrip(measuredHours))
  @dtw_assign(laborRate,@dtw_rstrip(laborRate))
  @dtw_assign(variableRate,@dtw_rstrip(variableRate))
  @dtw_assign(fixedRate,@dtw_rstrip(fixedRate))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@item", itemNumber)
  @Concat_Field("@@dept", department)
  @Concat_Field("@@wc@@", workCenter)
  @Concat_Field("@@mhrs", measuredHours)
  @Concat_Field("@@slr@", laborRate)
  @Concat_Field("@@var@", variableRate)
  @Concat_Field("@@fix@", fixedRate)
  @dtw_concat(edtVar, "}{", edtVar)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(callSubr, "Routing")

  @Validate_Data(profileHandle, callSubr, maintenanceCode, edtVar, errVar, errFound)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(deptwcDesc), "$(department) / $(workCenter)", "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)CostSimulatorDisplay.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@dept", "department")
      @Format_ConfMsg_Desc("", $(deptwcDesc), "$(department) / $(workCenter)", "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)CostSimulatorDisplay.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;department=@dtw_rurlescseq(department)&amp;workCenter=@dtw_rurlescseq(workCenter)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
