%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Manufacturing Order Search"
  d2wName                 = "MfgOrderSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;forPlant=@dtw_rurlescseq(forPlant)&amp;docName=@dtw_rurlescseq(docName)&amp;fldorder=@dtw_rurlescseq(fldorder)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  novcf                   = ""
  docName                 = ""
  fldOrder                = ""
  advanceSearch           = "N"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectPltOrder(order){
              window.opener.document.$(docName).$(fldorder).value = order;
              window.opener.document.$(docName).$(fldorder).focus();
              window.close();
                  }
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  %if (forPlant == "")
                      if (editNum(document.Search.srchPlant, 3, 0))
                          return true;
                  %else
                      return true;
                  %endif
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(uv_PlantName, "OHPLT")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select OHSTC, OHPLT, OHORD, OHPN, OHOTYP, OHCSDT, OHCDDT, OHCQTY, OHDWGR, OHRORD, OHPAPS, OHMGTP, OHUNIT, OHBAC, OHPRIC, OHORD#, OHORL#, OHBLN# ", stmtSQL)
                      @dtw_concat(fileSQL, " HDMOHM ", fileSQL)
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, " OHPLT=$(plant) and OHORD='$(order)' ", selectSQL)
                      %elseif (forPlant != "")
                          @dtw_concat(selectSQL, " OHPLT=$(forPlant) and OHSTC<>'C'", selectSQL)
                      %elseif (wildCardSearch!="" || uv_Sql!="")
                          @dtw_concat(selectSQL, " OHPLT>0 and OHSTC<>'C' ", selectSQL)
                      %else
                          @dtw_concat(selectSQL, " OHSTC<>'C' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @MfgOrder_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) MfgOrder_Search (IN CHAR(64)    profileHandle,
     	                              CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{

      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Plant</th>
                      <th class="colhdr">Mfg Order</th>
                      <th class="colhdr">Item Number</th>
                      <th class="colhdr">Reference Number</th>
                  </tr>
                  <tr>
                      %if (forPlant != "")
                          <td class="colnmbr">$(forPlant)
                          <input type="hidden" name="operPlant" value="=">
                          </td>
                      %else
                          <td class="inputnmbr"><input type="text" name="srchPlant" size="3" maxlength="3" value=$(forPlant)>
                          <input type="hidden" name="operPlant" value="=">
                          </td>
                      %endif
                      <td class="inputalph"><input type="text" name="srchOrder" size="9" maxlength="9">
                          <input type="hidden" name="operOrder" value="LIKE">
                      </td>
                      <td class="inputalph"><input type="text" name="srchItem" size="15" maxlength="15">
                          <input type="hidden" name="operItem" value="LIKE">
                      </td>
                      <td class="inputalph"><input type="text" name="srchReference" size="20" maxlength="20">
                          <input type="hidden" name="operReference" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  %if (forPlant != "")
                      document.Search.srchOrder.focus();
                  %else
                      document.Search.srchPlant.focus();
                  %endif
              </script>
          </form>
	
          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("OHPLT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=plant" title="Sequence By Plant"> Plant</a></th>
                  @OrderBy_Sort("OHORD", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=dept" title="Sequence By Mfg Order"> Mfg Order</a></th>
                  @OrderBy_Sort("OHPN", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=item" title="Sequence By Item Number"> Item Number</a></th>
                  @OrderBy_Sort("OHRORD", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=reference" title="Sequence By Reference Number">Reference Number</a></th>
                  <th class="colhdr">Order Quantity</th
              </tr>
               %INCLUDE "NoRecordsFound.icl"
      %else
          <table $(contentTable)>
      %endif		

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Nbr($(V_OHCQTY), F_OHCQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")

              %if (moreInfo != "Y")	
                  <tr class="$(rowClass)">
                      <td class="colnmbr">$(V_OHPLT)</td>
                      <td class="colalph"><a href="javascript:selectPltOrder('$(V_OHORD)')" title="Select Order Number">$(V_OHORD)</td>
                      <td class="colalph">$(V_OHPN)</td>
                      <td class="colalph">$(V_OHRORD)</td>
                      <td class="colalph">$(F_OHCQTY)</td>
                      <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;plant=@dtw_rurlescseq(V_OHPLT)&amp;order=@dtw_rurlescseq(V_OHORD)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                  </tr>

              %else
                  %{ More Information Screen %}

                  <tr><td>

                          <a href="javascript:selectPltOrder('$(V_OHORD)')" title="Select Order">$(selectImageLrg)</a>
                      </td>
                  </tr>

                  <tr><td class="dsphdr">Order Number</td>
                      <td class="dspalph">$(V_OHORD)</td>
                  </tr>

                  @dtw_assign(plantName, "")
                  @RtvFldDesc("PLPLNT=$(V_OHPLT)", "HDPLNT", "PLNAME", plantName)
                  <tr><td class="dsphdr">Plant Number</td>
                      <td class="dspnmbr">$(V_OHPLT)</td>
                      <td class="dspalph">$(plantName)</td>
                  </tr>
	      		
                  @dtw_assign(itemDesc, "")
                  @RtvFldDesc("IMITEM='$(V_OHPN)'", "HDIMST", "IMIMDS", itemDesc)
                  <tr><td class="dsphdr">Item Number</td>
                      <td class="dspalph">$(V_OHPN)</td>
                      <td class="dspalph">$(itemDesc)</td>
                  </tr>
	      		
                  <tr><td class="dsphdr">Order Type</td>
                      <td class="dspalph">$(V_OHOTYP)</td>
                  </tr>

                  @Format_Date_ISO($(V_OHCDDT), "H", F_OHCDDT)
                  <tr><td class="dsphdr">Due Date</td>
                      <td class="dspnmbr">$(F_OHCDDT)</td>
                  </tr>

                  @Format_Date_ISO($(V_OHCSDT), "H", F_OHCSDT)
                  <tr><td class="dsphdr">Start Date</td>
                      <td class="dspnmbr">$(F_OHCSDT)</td>
                  </tr>

	      	   @Format_Nbr($(V_OHCQTY), F_OHCQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  <tr><td class="dsphdr">Order Quantity</td>
                      <td class="dspalph">$(F_OHCQTY)</td>
                  </tr>
	      		
	      	    @Format_Nbr($(V_OHPRIC), F_OHPRIC, $(prcNbrDec), $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Unit Price</td>
                      <td class="dspnmbr">$(F_OHPRIC)</td>
                  </tr>
	      		
	      	    @Format_Nbr($(V_OHUNIT), F_OHUNIT, $(cstNbrDec), $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Unit Cost</td>
                      <td class="dspnmbr">$(F_OHUNIT)</td>
                  </tr>
	      		
                  <tr><td class="dsphdr">Reference Order Number</td>
                      <td class="dspalph">$(V_OHRORD)</td>
                  </tr>
	      		
                  <tr><td class="dsphdr">Drawing Revision Number</td>
                      <td class="dspalph">$(V_OHDWGR)</td>
                  </tr>
	      		

	      	   @Format_Nbr($(V_OHMGTP), F_OHMHTP, "1", "1", "", "", "")
                  <tr><td class="dsphdr">Management Priority</td>
                      <td class="dspnmbr">$(F_OHMGTP)</td>
                  </tr>

                  @Format_Nbr($(V_OHBAC), F_OHBAC, "0", "", "", "", "")
                  <tr><td class="dsphdr">Buyer Analyst</td>
                      <td class="dspnmbr">$(F_OHBAC)</td>
                  </tr>
	      		
                  <tr><td class="dsphdr">Paper Switch</td>
                      <td class="dspalph">$(V_OHPAPS)</td>
                  </tr>

                  @Format_Nbr($(V_OHORD#), F_OHORD#, "0", "", "", "", "")
                  <tr><td class="dsphdr">Sales Order Number</td>
                      <td class="dspnmbr">$(F_OHORD#)</td>
                  </tr>

                  @Format_Nbr($(V_OHORL#), F_OHORL#, "0", "", "", "", "")
                  <tr><td class="dsphdr">Sales Line Number</td>
                      <td class="dspnmbr">$(F_OHORL#)</td>
                  </tr>

                  @Format_Nbr($(V_OHBLN#), F_OHBLN#, "0", "", "", "", "")
                  <tr><td class="dsphdr">Sales Release #</td>
                      <td class="dspnmbr">$(F_OHBLN#)</td>
                  </tr>

              %endif
          %}
      </table>
      %if (moreInfo != "Y")	
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
      %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "OHORD,OHPN,OHRORD")
      @DTW_ASSIGN(orderByDisplay, "Order Number, Item Number, Reference Number")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(orderBy, "OHORD")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "plant")
      %if (orderBy == "OHPLT")
          @DTW_ASSIGN(orderBy, "OHPLT DESC")
          @DTW_ASSIGN(orderByDisplay, "Plant (descending)")
      %else
          @DTW_ASSIGN(orderBy, "OHPLT")
          @DTW_ASSIGN(orderByDisplay, "Plant")
      %endif
  %elseif (sequence == "order")
      %if (orderBy == "OHORD")
          @DTW_ASSIGN(orderBy, "OHORD DESC")
          @DTW_ASSIGN(orderByDisplay, "Order Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "OHORD")
          @DTW_ASSIGN(orderByDisplay, "Order Number")
      %endif
  %elseif (sequence == "item")
      %if (orderBy == "OHPN")
          @DTW_ASSIGN(orderBy, "OHPN DESC")
          @DTW_ASSIGN(orderByDisplay, "Item Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "OHPN")
          @DTW_ASSIGN(orderByDisplay, "Item Number")
      %endif
  %elseif (sequence == "reference")
      %if (orderBy == "OHRORD")
          @DTW_ASSIGN(orderBy, "OHRORD DESC")
          @DTW_ASSIGN(orderByDisplay, "Reference Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "OHRORD")
          @DTW_ASSIGN(orderByDisplay, "Reference Number")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("OHPLT", "Plant", $(srchPlant), "", operPlant, "N")
  @Build_WildCard ("OHORD", "Order Number", $(srchOrder), "U", operOrder, "A")
  @Build_WildCard ("OHPN", "Item Number", $(srchItem), "U", operItem, "A")
  @Build_WildCard ("OHRORD", "Reference Number", $(srchReference), "U", operReference, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}