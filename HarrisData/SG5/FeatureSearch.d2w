%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Feature Search"
  d2wName                 = "FeatureSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;forPlant=@dtw_rurlescseq(forPlant)&amp;includeBiLevels=@dtw_rurlescseq(includeBiLevels)&amp;docName=@dtw_rurlescseq(docName)&amp;fldPlant=@dtw_rurlescseq(fldPlant)&amp;fldPltName=@dtw_rurlescseq(fldPltName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
  docName                 = ""
  fldPlant                = ""
  fldPltName              = ""
  fldName                 = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %if (forPlant == "")
                  function selectFeature(plant, pltname, feature, desc){
                      window.opener.document.$(docName).$(fldPlant).value = plant;
                      window.opener.document.$(docName).$(fldPltName).value = pltname;
                      window.opener.document.$(docName).$(fldName).value = feature;
                      window.opener.document.$(docName).$(fldDesc).value = desc;
                      window.opener.document.$(docName).$(fldName).focus();
                      window.close();
                  }
              %else
                  function selectFeature(feature, desc){
                      window.opener.document.$(docName).$(fldName).value = feature;
                      window.opener.document.$(docName).$(fldDesc).value = desc;
                      window.opener.document.$(docName).$(fldName).focus();
                      window.close();
                  }
              %endif
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  %if (forPlant == "")
                      if (editNum(document.Search.srchPlant, 3, 0))
                          return true;
                  %else
                      return true;
                  %endif
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(uv_PlantName, "FOPLT")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_assign(withSQL, " With Temp_BILEVEL as (Select c.FOPLT as TMPPLT,c.FOOPTN as TMPOPTN, c.FOBLOP as TMPBLOP from HDMFOP c Where c.FOBLOP='Y' Group By c.FOPLT,c.FOOPTN,C.FOBLOP), ")
                      @dtw_concat(withSQL, " Temp_HDMFOP as (Select a.FOPLT as FOPLT,a.FOFEAT as FOFEAT,a.FOFPRT as FOFPRT,a.FOFDSC as FOFDSC,coalesce(TMPBLOP,' ') as FOBLOP from HDMFOP a left join Temp_BILEVEL b on a.FOPLT=TMPPLT and a.FOFEAT=TMPOPTN Group By a.FOPLT, a.FOFEAT, a.FOFPRT, a.FOFDSC, coalesce(TMPBLOP,' ') ", withSQL)
                      %if (V_CIUVCT == "Y")
                          @dtw_concat(withSQL, " Union Select VCPLT as FOPLT, VCFEAT as FOFEAT, ' ' as FOFPRT, ' ' as FOFDSC, ' ' as FOBLOP from HDVCAT Where VCFEAT<>' ' and VCITEM= ' ' Group By VCPLT, VCFEAT,' ', ' ', ' ' ", withSQL)
                      %endif
                      @dtw_concat(withSQL, " ) ", withSQL)
                      @dtw_concat(stmtSQL, withSQL, stmtSQL)
                      @dtw_concat(stmtSQL, " Select FOPLT, FOFEAT, FOFPRT, FOFDSC, FOBLOP, upper(FOFDSC) as FOFDSCU", stmtSQL)
                      @dtw_concat(stmtSQL, " , coalesce(PLNAME,' ') as PLNAME, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(upper(PLNAME),' ') as PLNAMEU ", stmtSQL)
                      @dtw_concat(fileSQL, " Temp_HDMFOP", fileSQL)
                      @dtw_concat(fileSQL, " left join HDPLNT on FOPLT=PLPLNT ", fileSQL)
                      %if (wildCardSearch!="" || forPlant>"0" || uv_Sql!="" || includeBiLevels=="N")
                          @dtw_concat(selectSQL, "FOFEAT>' ' ", selectSQL)
                      %endif
                      %if (forPlant > "0")
                         @dtw_concat(selectSQL, " and FOPLT=$(forPlant)", selectSQL)
                      %endif
                      %if (includeBiLevels == "N")
                         @dtw_concat(selectSQL, " and FOBLOP<>'Y'", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"

                      @dtw_assign(countSQL, "distinct char(FOPLT) concat FOFEAT concat FOFPRT concat FOFDSC concat FOBLOP")
                      @RtvFldDescWith("$(withSQL)", "$(selectSQL)", "$(fileSQL)", "char(count(*))", sql_Record_Count)
                      %if (sql_Record_Count == "0")
                          @dtw_assign(stmtSQL, "Select FLTYPE From SYFLAG Where FLTYPE='NoRecFnd'")
                      %else
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Feature_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Feature_Search (IN CHAR(64)    profileHandle,
     	                              CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr>
                  <th class="colhdr">Feature</th>
                  <th class="colhdr">Featured Item/<br>Family</th>
                  <th class="colhdr">Description</th>
                  <th class="colhdr">Plant</th>
              </tr>
              <tr>
                  <td><input type="text" class="inputalph"  name="srchFeature" size="15" maxlength="15">
                      <input type="hidden" name="operFeature" value="LIKE">
                  </td>
                  <td><input type="text" class="inputalph"  name="srchItem" size="15" maxlength="15">
                      <input type="hidden" name="operItem" value="LIKE">
                  </td>
                  <td><input type="text" class="inputalph"  name="srchDesc" size="15" maxlength="30">
                      <input type="hidden" name="operDesc" value="LIKE">
                  </td>
                  %if (forPlant != "")
                      <td class="colnmbr">$(forPlant)
                          <input type="hidden" name="operPlant" value="=">
                      </td>
                  %else
                      <td class="inputnmbr"><input type="text" name="srchPlant" size="5" maxlength="3" value=$(forPlant)>
                          <input type="hidden" name="operPlant" value="=">
                      </td>
                  %endif
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
          <script TYPE="text/javascript">
              document.Search.srchFeature.focus();
          </script>
      </form>
	
      %INCLUDE "WildCardPage.icl"

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              @OrderBy_Sort("FOFEAT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=feature" title="Sequence By Feature">Feature</a></th>
              @OrderBy_Sort("FOFPRT", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=featuredItem" title="Sequence By Featured Item">Featured Item/<br>Family</a></th>
              @OrderBy_Sort("FOFDSCU", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=featureDesc" title="Sequence By Description">Description</a></th>
              @OrderBy_Sort("FOPLT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlantNumber" title="Sequence By Plant">Plant</a></th>
              @OrderBy_Sort("PLNAMEU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlantName" title="Sequence By Plant Name">Plant Name</a></th>
              @OrderBy_Sort("FOBLOP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=biLevel" title="Sequence By Bi-Level">B/L</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

      %ROW{
          %INCLUDE "SetRowClass.icl"
          @Format_Quote(V_FOFEAT, F_FOFEAT)
          @Format_Quote(V_FOFPRT, F_FOFPRT)
          @Format_Quote(V_FOFDSC, F_FOFDSC)
          @Format_Quote(V_PLNAME, F_PLNAME)

          <tr class="$(rowClass)">
              <td class="colalph">$(V_FOFEAT)</td>
              <td class="colalph">$(V_FOFPRT)</td>
              <td class="colalph">
                  %if (forPlant == "")
                      <a href="javascript:selectFeature($(V_FOPLT), '$(F_PLNAME)', '$(F_FOFEAT)', '$(F_FOFDSC)')" title="Select Feature">$(V_FOFDSC)</a>
                  %else
                      <a href="javascript:selectFeature('$(F_FOFEAT)', '$(F_FOFDSC)')" title="Select Feature">$(V_FOFDSC)</a>
                  %endif
              </td>
              <td class="colnmbr">$(V_FOPLT)</td>
              <td class="colalph">$(V_PLNAME)</td>
              <td class="colcode">$(V_FOBLOP)</td>
          </tr>
      %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "FOFEAT, FOFPRT")
      @DTW_ASSIGN(orderByDisplay, "Feature")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "feature")
      %if (orderBy == "FOFEAT, FOFPRT")
          @DTW_ASSIGN(orderBy, "FOFEAT DESC, FOFPRT")
          @DTW_ASSIGN(orderByDisplay, "Feature (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FOFEAT, FOFPRT")
          @DTW_ASSIGN(orderByDisplay, "Feature")
      %endif
  %elseif (sequence == "featuredItem")
      %if (orderBy == "FOFPRT, FOFEAT")
          @DTW_ASSIGN(orderBy, "FOFPRT DESC, FOFEAT")
          @DTW_ASSIGN(orderByDisplay, "Featured Item/Family (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FOFPRT, FOFEAT")
          @DTW_ASSIGN(orderByDisplay, "Featured Item/Family")
      %endif
  %elseif (sequence == "featureDesc")
      %if (orderBy == "FOFDSCU, FOFEAT, FOFPRT")
          @DTW_ASSIGN(orderBy, "FOFDSCU DESC, FOFEAT, FOFPRT")
          @DTW_ASSIGN(orderByDisplay, "Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FOFDSCU, FOFEAT, FOFPRT")
          @DTW_ASSIGN(orderByDisplay, "Description")
      %endif
  %elseif (sequence == "PlantNumber")
      %if (orderBy == "FOPLT,FOFEAT,FOFPRT")
          @DTW_ASSIGN(orderBy, "FOPLT DESC,FOFEAT,FOFPRT")
          @DTW_ASSIGN(orderByDisplay, "Plant Number (descending), Feature, Featured Item")
      %else
          @DTW_ASSIGN(orderBy, "FOPLT,FOFEAT,FOFPRT")
          @DTW_ASSIGN(orderByDisplay, "Plant Number, Feature, Featured Item")
      %endif
  %elseif (sequence == "PlantName")
      %if (orderBy == "PLNAMEU,FOFEAT,FOFPRT")
          @DTW_ASSIGN(orderBy, "PLNAMEU DESC,FOFEAT,FOFPRT")
          @DTW_ASSIGN(orderByDisplay, "Plant Name (descending), Feature, Featured Item")
      %else
          @DTW_ASSIGN(orderBy, "PLNAMEU,FOFEAT,FOFPRT")
          @DTW_ASSIGN(orderByDisplay, "Plant Name, Feature, Featured Item")
      %endif
  %elseif (sequence == "biLevel")
      %if (orderBy == "FOBLOP,FOFEAT,FOFPRT")
          @DTW_ASSIGN(orderBy, "FOBLOP DESC,FOFEAT,FOFPRT")
          @DTW_ASSIGN(orderByDisplay, "Bi-Level (descending), Feature, Featured Item")
      %else
          @DTW_ASSIGN(orderBy, "FOBLOP,FOFEAT,FOFPRT")
          @DTW_ASSIGN(orderByDisplay, "Bi-Level, Feature, Featured Item")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("FOFEAT", "Feature", $(srchFeature), "U", operFeature, "A")
  @Build_WildCard ("FOFPRT", "Featured Item/Family", $(srchItem), "U", operItem, "A")
  @Build_WildCard ("upper(FOFDSC)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("FOPLT", "Plant Number", $(srchPlant), "", operPlant, "N")
  @Build_WildCard ("upper(PLNAME)", "Plant Name", $(srchName), "U", operName, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}