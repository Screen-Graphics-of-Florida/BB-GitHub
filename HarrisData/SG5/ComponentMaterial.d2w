%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Component Material"
  d2wName                 = "ComponentMaterial.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;mfgOrder=@dtw_rurlescseq(mfgOrder)&amp;plrsf=@dtw_rurlescseq(plrsf)&amp;laborExists=@dtw_rurlescseq(laborExists)&amp;plrseq=@dtw_rurlescseq(plrseq)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HSI203"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
                  %INCLUDE "Menu.js"
                  %INCLUDE "NumEdit.icl"
                  %INCLUDE "CheckEnterSearch.icl"
                  %if (plrsf == "Y" && laborExists > "0")
                      function validate(searchForm) {
                          if (editNum(document.Search.srchSeq, 3, 0))
                              return true;
                      }
                  %else
                      %INCLUDE "NoFormValidate.icl"
                  %endif
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "COMPONENTMATERIAL")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " HDMCRM", fileSQL)
                          @dtw_concat(selectSQL, " CRPPLT=$(plantNumber) and CRORD='$(mfgOrder)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By CRPPLT,CRORD,$(orderBy)", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @ComponentMaterial_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) ComponentMaterial_Query (IN CHAR(64)    profileHandle,
				                CHAR(2)     dataBaseID,
                                               CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)ComponentMaterialMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      <table $(contentTable)>
          @Format_Header_URL("Plant", $(plantName), $(plantNumber), "$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(d2wVarBase)")
          @Format_Header_URL("Mfg Order", $(mfgOrder), "", "")
      </table>
      %INCLUDE "ConfMessageDisplay.icl"
	
      $(hrTagAttr)	

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      %if (plrsf == "Y")
                          <th class="colhdr">Rtg<br>Seq</th>
                      %endif
                      <th class="colhdr">Component<br>Item</th>
                  </tr>

                  <tr>
                      %if (plrsf == "Y")
                          %if (laborExists > "0")
                              <td><input type="text" class="inputnmbr" name="srchSeq" size="3" maxlength="3">
                                  <input type="hidden" name="operseq" value="=">
                          %else
                              <td class="colnmbr">$(plrseq) </td>
                              <input type="hidden" name="operseq" value="=">
                          %endif
                      </td>
                      %endif
                      <td><input type="text" class="inputalph" name="srchcomponent" size="15" maxlength="15">
                          <input type="hidden" name="opercomponent" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  %if (plrsf == "Y" && laborExists > "0")
                      document.Search.srchSeq.focus();
                  %else
                      document.Search.srchcomponent.focus();
                  %endif
              </script>
          </form>
	
          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("CRREAS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=REAS" title="Sequence By Reason Code"> R<br>C</a></th>	
              %if (plrsf == "Y")
                  @OrderBy_Sort("CRSEQN", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SEQN" title="Sequence By Routing Sequence"> Rtg<br>Seq</a></th>
              %endif
              @OrderBy_Sort("CRCPN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CPN" title="Sequence By Component Item"> Component<br>Item</a></th>	
              <th class="colhdr">Component Description</th>
              @OrderBy_Sort("CRQPER", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=QPER" title="Sequence By Quantity Per">Quantity<br>Per</a></th>
              @OrderBy_Sort("CRECN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ECN" title="Sequence By Engineering Change Notice">ECN</a></th>
              @OrderBy_Sort("CRDWGR", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DWGR" title="Sequence By Drawing Revision">Dwg<br>Rev</a></th>
              @OrderBy_Sort("CRFSTK", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FSTK" title="Sequence By Backflush Code">Bkf<br>Code</a></th>
              @OrderBy_Sort("CRSCPP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SCPP" title="Sequence By Scrap Percent">Scrap<br>%</a></th>
              @OrderBy_Sort("CRRQTY", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RQTY" title="Sequence By Quantity Required">Quantity<br>Required</a></th>
              @OrderBy_Sort("CRQTYI", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=QTYI" title="Sequence By Quantity Issued">Quantity<br>Issued</a></th>
              @OrderBy_Sort("CRQTYS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=QTYS" title="Sequence By Quantity Scrapped">Quantity<br>Scrapped</a></th>
          </tr>		
          %INCLUDE "NoRecordsFound.icl"

      %ROW{
              %INCLUDE "SetRowClass.icl"
              %if (plrsf == "Y")
                  @Format_Confirm_Desc("Routing Sequence", $(V_CRSEQN), "Component Item", $(V_CRCPN), "", "", confirmDesc)
              %else
                  @Format_Confirm_Desc("Component Item", $(V_CRCPN), "", "", "", "", confirmDesc)
              %endif
              @dtw_replace(confirmDesc, "'", "\'", "1", "a", confirmDesc)
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;fromSequence=@dtw_rurlescseq(V_CRSEQN)&amp;fromComponent=@dtw_rurlescseq(V_CRCPN)")
              @dtw_assign(deleteVar, "$(maintainVar)&amp;sequenceNumber=@dtw_rurlescseq(V_CRSEQN)&amp;componentNumber=@dtw_rurlescseq(V_CRCPN)&amp;maintenanceCode=D")
	       <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)ComponentMaterialMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)ComponentMaterialMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)ComponentMaterialMaintain.d2w/Edit_Data$(deleteVar)">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  @RtvFldDesc("IMITEM='$(V_CRCPN)'", "HDIMST", "IMIMDS", compDesc)
                  @Format_Nbr($(V_CRQPER), F_CRQPER, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @Format_Nbr($(V_CRSCPP), F_CRSCPP, "2", $(pctEditCode), "", "", "")
                  @Format_Nbr($(V_CRRQTY), F_CRRQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @Format_Nbr($(V_CRQTYI), F_CRQTYI, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @Format_Nbr($(V_CRQTYS), F_CRQTYS, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @RtvFldDesc("(FLTYPE='BACKFLUSH' and FLVALU='$(V_CRFSTK)')", "SYFLAG", "FLDESC", backFlushDesc)
                  <td class="colalph"> $(V_CRREAS)</td>
                  %if (plrsf == "Y")
                      <td class="colnmbr"> $(V_CRSEQN)</td>
                  %endif
                  <td class="colalph">$(V_CRCPN)</td>
                  <td class="colalph">$(compDesc)</td>
                  <td class="colnmbr">$(F_CRQPER)</td>
                  <td class="colnmbr">$(V_CRECN)</td>
                  <td class="colcode">$(V_CRDWGR)</td>
                  <td class="colcode" $(helpCursor)><span title="$(backFlushDesc)">$(V_CRFSTK)</span></td>
                  <td class="colnmbr">$(F_CRSCPP)</td>
                  <td class="colnmbr">$(F_CRRQTY)</td>
                  <td class="colnmbr">$(F_CRQTYI)</td>
                  <td class="colnmbr">$(F_CRQTYS)</td>
	       </tr>
	   %}
      </table>
      %if (sql_Record_Count != "1")
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
          $(hrTagAttr)
          %INCLUDE "Copyright.icl"
      %endif
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLRSF", plrsf)
  @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "CHAR(PLRSEQ)", plrseq)
  @RtvFldDesc("LPPLT=$(plantNumber) and LPORD='$(mfgOrder)'", "HDMLPM", "CHAR(COUNT(LPORD))", laborExists)
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          %if (plrsf == "Y")
              @DTW_ASSIGN(orderBy, "CRSEQN,CRCPN")
              @DTW_ASSIGN(orderByDisplay, "Routing Sequence, Component Item")
          %else
              @DTW_ASSIGN(orderBy, "CRCPN,CRSEQN")
              @DTW_ASSIGN(orderByDisplay, "Component Item, Routing Sequence")
          %endif
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "REAS")
      %if (orderBy == "CRREAS,CRCPN")
          @DTW_ASSIGN(orderBy, "CRREAS DESC,CRCPN")
          @DTW_ASSIGN(orderByDisplay, "Reason Code (descending), Component Item")
      %else
          @DTW_ASSIGN(orderBy, "CRREAS,CRCPN")
          @DTW_ASSIGN(orderByDisplay, "Reason Code, Component Item")
      %endif
  %elif (sequence == "SEQN")
      %if (orderBy == "CRSEQN,CRCPN")
          @DTW_ASSIGN(orderBy, "CRSEQN DESC,CRCPN")
          @DTW_ASSIGN(orderByDisplay, "Routing Sequence (descending), Component Item")
      %else
          @DTW_ASSIGN(orderBy, "CRSEQN,CRCPN")
          @DTW_ASSIGN(orderByDisplay, "Routing Sequence, Component Item")
      %endif
  %elif (sequence == "CPN")
      %if (orderBy == "CRCPN,CRSEQN")
          @DTW_ASSIGN(orderBy, "CRCPN DESC,CRSEQN")
          @DTW_ASSIGN(orderByDisplay, "Component Item (descending), Routing Sequence")
      %else
          @DTW_ASSIGN(orderBy, "CRCPN,CRSEQN")
          @DTW_ASSIGN(orderByDisplay, "Component Item, Routing Sequence")
      %endif
  %elif (sequence == "QPER")
      %if (orderBy == "CRQPER,CRCPN")
          @DTW_ASSIGN(orderBy, "CRQPER DESC,CRCPN")
          @DTW_ASSIGN(orderByDisplay, "Quantity Per (descending), Component Item")
      %else
          @DTW_ASSIGN(orderBy, "CRQPER,CRCPN")
          @DTW_ASSIGN(orderByDisplay, "Quantity Per, Component Item")
      %endif
  %elif (sequence == "ECN")
      %if (orderBy == "CRECN,CRCPN")
          @DTW_ASSIGN(orderBy, "CRECN DESC,CRCPN")
          @DTW_ASSIGN(orderByDisplay, "Engineering Change Notice (descending), Component Item")
      %else
          @DTW_ASSIGN(orderBy, "CRECN,CRCPN")
          @DTW_ASSIGN(orderByDisplay, "Engineering Change Notice, Component Item")
      %endif
  %elif (sequence == "DWGR")
      %if (orderBy == "CRDWGR,CRCPN")
          @DTW_ASSIGN(orderBy, "CRDWGR DESC,CRCPN")
          @DTW_ASSIGN(orderByDisplay, "Drawing Revision Letter (descending), Component Item")
      %else
          @DTW_ASSIGN(orderBy, "CRDWGR,CRCPN")
          @DTW_ASSIGN(orderByDisplay, "Drawing Revision Letter, Component Item")
      %endif
  %elif (sequence == "FSTK")
      %if (orderBy == "CRFSTK,CRCPN")
          @DTW_ASSIGN(orderBy, "CRFSTK DESC,CRCPN")
          @DTW_ASSIGN(orderByDisplay, "Backflush Code (descending), Component Item")
      %else
          @DTW_ASSIGN(orderBy, "CRFSTK,CRCPN")
          @DTW_ASSIGN(orderByDisplay, "Backflush Code, Component Item")
      %endif
  %elif (sequence == "SCPP")
      %if (orderBy == "CRSCPP,CRCPN")
          @DTW_ASSIGN(orderBy, "CRSCPP DESC,CRCPN")
          @DTW_ASSIGN(orderByDisplay, "Scrap Percent (descending), Component Item")
      %else
          @DTW_ASSIGN(orderBy, "CRSCPP,CRCPN")
          @DTW_ASSIGN(orderByDisplay, "Scrap Percent, Component Item")
      %endif
  %elif (sequence == "RQTY")
      %if (orderBy == "CRRQTY,CRCPN")
          @DTW_ASSIGN(orderBy, "CRRQTY DESC,CRCPN")
          @DTW_ASSIGN(orderByDisplay, "Quantity Required (descending), Component Item")
      %else
          @DTW_ASSIGN(orderBy, "CRRQTY,CRCPN")
          @DTW_ASSIGN(orderByDisplay, "Quantity Required, Component Item")
      %endif
  %elif (sequence == "QTYI")
      %if (orderBy == "CRQTYI,CRCPN")
          @DTW_ASSIGN(orderBy, "CRQTYI DESC,CRCPN")
          @DTW_ASSIGN(orderByDisplay, "Quantity Issued (descending), Component Item")
      %else
          @DTW_ASSIGN(orderBy, "CRQTYI,CRCPN")
          @DTW_ASSIGN(orderByDisplay, "Quantity Issued, Component Item")
      %endif
  %elif (sequence == "QTYS")
      %if (orderBy == "CRQTYS,CRCPN")
          @DTW_ASSIGN(orderBy, "CRQTYS DESC,CRCPN")
          @DTW_ASSIGN(orderByDisplay, "Quantity Scrapped (descending), Component Item")
      %else
          @DTW_ASSIGN(orderBy, "CRQTYS,CRCPN")
          @DTW_ASSIGN(orderByDisplay, "Quantity Scrapped, Component Item")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (
                      %if (plrsf == "Y" && laborExists > "0")
                          editNum(document.Search.srchSeq, 3, 0) &&
                      %endif
                      editNum(document.Search.srchQper, 4, 5) &&
                      editNum(document.Search.srchScpp, 1, 2) &&
                      editNum(document.Search.srchRqty, 9, 4) &&
                      editNum(document.Search.srchQtyi, 9, 4) &&
                      editNum(document.Search.srchQtys, 9, 4))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "COMPONENTMATERIALSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Reason Code</td>
                              @dtw_assign(operNbr, "operReas")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchReas" size="2" maxlength="1"></td>
                          </tr>

                          %if (plrsf == "Y" && laborExists > "0")
                              <tr><td class="dsphdr">Routing Sequence</td>
                                  @dtw_assign(operNbr, "operseq")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchSeq" size="3" maxlength="3"></td>
                              </tr>
                          %endif

                          <tr><td class="dsphdr">Component Item</td>
                              @dtw_assign(operNbr, "opercomponent")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchcomponent" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">Quantity Per</td>
                              @dtw_assign(operNbr, "operQper")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchQper" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Engineering Change Notice</td>
                              @dtw_assign(operNbr, "operEcn")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchEcn" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">Drawing Revision</td>
                              @dtw_assign(operNbr, "operDwgr")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchDwgr" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Backflush Code</td>
                              @dtw_assign(operNbr, "operFstk")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchFstk" size="2" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Scrap Percent</td>
                              @dtw_assign(operNbr, "operScpp")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchScpp" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Quantity Required</td>
                              @dtw_assign(operNbr, "operRqty")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchRqty" size="14" maxlength="14"></td>
                          </tr>

                          <tr><td class="dsphdr">Quantity Issued</td>
                              @dtw_assign(operNbr, "operQtyi")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchQtyi" size="14" maxlength="14"></td>
                          </tr>

                          <tr><td class="dsphdr">Quantity Scrapped</td>
                              @dtw_assign(operNbr, "operQtys")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchQtys" size="14" maxlength="14"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchReas.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("CRREAS", "Reason Code", $(srchReas), "U", operReas, "A")
  %if (plrsf == "Y" && laborExists > "0")
      @Build_WildCard ("CRSEQN", "Routing Sequence", $(srchSeq), "", operseq, "N")
  %endif
  @Build_WildCard ("CRCPN", "Component Item", $(srchcomponent), "U", opercomponent, "A")
  @Build_WildCard ("CRQPER", "Quantity Per", $(srchQper), "", operQper, "N")
  @Build_WildCard ("CRECN", "Engineering Change Notice", $(srchEcn), "U", operEcn, "A")
  @Build_WildCard ("CRDWGR", "Drawing Revision", $(srchDwgr), "U", operDwgr, "A")
  @Build_WildCard ("CRFSTK", "Backflush Code", $(srchFstk), "U", operFstk, "A")
  @Build_WildCard ("CRSCPP", "Scrap Percent", $(srchScpp), "", operScpp, "N")
  @Build_WildCard ("CRRQTY", "Quantity Required", $(srchRqty), "", operRqty, "N")
  @Build_WildCard ("CRQTYI", "Quantity Issued", $(srchQtyi), "", operQtyi, "N")
  @Build_WildCard ("CRQTYS", "Quantity Scrapped", $(srchQtys), "", operQtys, "N")
		
  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}