%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "storedProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title 	        = "Applicants"
  d2wName              = "Applicants.d2w"
  d2wVarBase           = "$(genericVarBase)&amp;hrCompany=@dtw_rurlescseq(hrCompany)&amp;inclNotHired=@dtw_rurlescseq(inclNotHired)&amp;inclHired=@dtw_rurlescseq(inclHired)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar          = "$(d2wVarBase)"
  wildDftVar           = "REPORT$(d2wVarBase)"
  programName          = "HPEAPU"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  DTW_PRINT_HEADER     = "NO"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  country              = "US"
  facilityZero         = "0000"
  inclNotHired         = ""
  inclHired            = ""
  rowIndexNext		= "1"
  totalPages		= "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@hrCompany", "@dtw_rurlescseq(hrCompany)", "1", "a", workURL)
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
	    %INCLUDE "$(headInclude)"
           <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
           </script>
           %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "APPLICANTS")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      @dtw_assign(uv_HRCompanyName, "APCOMP")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " SELECT APCOMP, APAPDT, APAPSQ, APLNAM, APFNAM, APMIDI, APRNAM, APADR1, APADR2, APCITY, APST, APZIP, APPHON, APETID, APGNDR, APJBCD, APPSTN, APEEO, APLCTN, APEMPL, APSTTS, APSKIL, APMILT, APLNAMU, APFNAMU", stmtSQL)
                      @dtw_concat(fileSQL, " PEAPPL ", fileSQL)
                      %if ((inclNotHired == "Y") && (inclHired != "Y"))
                          @dtw_concat(selectSQL, " APCOMP = $(hrCompany) and APEMPL = 0", selectSQL)
                      %elseif ((inclNotHired != "Y") && (inclHired == "Y"))
                          @dtw_concat(selectSQL, " APCOMP = $(hrCompany) and APEMPL <> 0", selectSQL)
                      %elseif ((inclNotHired == "Y") && (inclHired == "Y"))
                          @dtw_concat(selectSQL, " APCOMP = $(hrCompany)", selectSQL)
                      %elseif ((inclNotHired != "Y") && (inclHired != "Y"))
                          @dtw_concat(selectSQL, " APCOMP = $(hrCompany) and APEMPL = 0 and APEMPL<> 0", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Applicant_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) Applicant_Query (IN CHAR(64)    profileHandle,
				        CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
  {CALL $(pgmLibrary)HSYSQL_W

    %REPORT{
        %if (sql_Record_Count != "1")
            <table $(contentTable)>
                <colgroup>
                    <col width="80%">
                    <col width="15%">
                <tr><td><h1> $(page_title)</h1></td>
                    %if (formatToPrint != "Y")
                        <td class="toolbar">
                            %if ((backHome != "$(d2wName)/report") && (backHome != ""))
                               <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                            %endif
                            %INCLUDE "XMLFormat.icl"
                            %INCLUDE "FormatToPrint.icl"
                            %INCLUDE "HelpPage.icl"
                        </td>
                    %endif
                </tr>
                @RetHrCompNam(profileHandle, dataBaseID, hrCompany, facilityZero, coFacName)
                <tr><td><h2>$(coFacName)</h2></td></tr>
            </table>
            %INCLUDE "ConfMessageDisplay.icl"

            $(hrTagAttr)

            %if (formatToPrint != "Y")
                <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                    <table $(quickSearchTable)>
	   	         <tr><th class="colhdr">Last Name</th></tr>
                        <tr><td><input type="text" class="inputalph" name="srchLast" size="18" maxlength="18">
                                <input type="hidden" name="operLast" Value="LIKE">
                            </td>
                            <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                        </tr>
	             </table>
                    <script TYPE="text/javascript">
                        document.Search.srchLast.focus();
                    </script>
                </form>

                %if (inclNotHired == "Y")
                    @dtw_assign(NotHiredChecked, "CHECKED")
                %else
                    @dtw_assign(NotHiredChecked, "")
                %endif
                %if (inclHired == "Y")
                    @dtw_assign(HiredChecked, "CHECKED")
                %else
                    @dtw_assign(HiredChecked, "")
                %endif

                @dtw_assign(viewCheckBox, d2wName)
                %INCLUDE "WildCardPage.icl"
            %endif

            <table $(contentTable)>
                <tr>
                    @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                    @OrderBy_Sort("APAPDT", sortVar)
                    <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplDate" title="Sequence By Application Date, Sequence Number">Application<br>Date</a></th>
                    @OrderBy_Sort("APAPSQ", sortVar)
                    <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplSeq" title="Sequence By Sequence Number, Application Date (descending)">Seq</a></th>
                    %if (inclHired == "Y")
                        @OrderBy_Sort("APEMPL", sortVar)
                        <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=EmplSeq" title="Sequence By Employee Number">Employee <br>Number</a></th>
                    %endif
                    @OrderBy_Sort("APLNAMU", sortVar)
                    <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplLast" title="Sequence By Last Name, First Name">Name</a></th>
                    @OrderBy_Sort("APSKIL", sortVar)
                    <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplSkill" title="Sequence By Skill, Last Name">Main Skill</a></th>
                    @OrderBy_Sort("APCITY", sortVar)
                    <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplCity" title="Sequence By City, State">City</a></th>
                    @OrderBy_Sort("APST ", sortVar)
                    <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplState" title="Sequence By State, City">State</a></th>
                    @OrderBy_Sort("APZIP", sortVar)
                    <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplZip" title="Sequence By Zip Code, City">Zip Code</a></th>
                    @OrderBy_Sort("APPHON", sortVar)
                    <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplPhone" title="Sequence By Phone Number">Phone<br>Number</a></th>
                    @OrderBy_Sort("APLCTN", sortVar)
                    <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplLoc" title="Sequence By Location Applied For">Location<br>Applied For</a></th>
                    @OrderBy_Sort("APJBCD", sortVar)
                    <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplJob" title="Sequence By Job Code Applied For">Job Code<br>Applied For</a></th>
                    @OrderBy_Sort("APPSTN", sortVar)
                    <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplPos" title="Sequence By Position Applied For">Position<br>Applied For</a></th>
                    @OrderBy_Sort("APSTTS", sortVar)
                    <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ApplSts" title="Sequence By Status">Status</a></th>
                </tr>
            %INCLUDE "NoRecordsFound.icl"
        %endif
		
                %ROW{
                    @dtw_assign(maintainVar, "$(d2wVarBase)&amp;applDate=@dtw_rurlescseq(V_APAPDT)&amp;applSeq=@dtw_rurlescseq(V_APAPSQ)")
                    %if (sql_Record_Count == "1")
                        @Save_WebReg(webRegCurFile, profileHandle, d2wName, "", orderBy, orderByDisplay, "")
                        <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)applicantselect.d2w/report$(maintainVar)">
                    %else
                        %INCLUDE "SetRowClass.icl"
                        @Format_EmplName(V_APFNAM, V_APLNAM, V_APMIDI, V_APRNAM, "", "D", F_EmpName)
                        <tr class="$(rowClass)">
                           %if (V_APAPDT != "0")
                               @Format_Date(V_APAPDT, "D", F_APAPDT)
                               <td class="coldate">$(F_APAPDT)</td>
                           %else
                               <td class="colcode"></td>
                           %endif
                           <td class="colnmbr">$(V_APAPSQ)</td>
                           %if (inclHired == "Y")
                               <td class="colnmbr">$(V_APEMPL)</td>
                           %endif
                           %if (formatToPrint != "Y")
                               <td class="colalph"><a href="$(homeURL)$(cGIPath)applicantselect.d2w/REPORT$(maintainVar)" title="View Applicant">$(F_EmpName)</a></td>
                           %else
                               <td class="colalph">$(F_EmpName)</td>
                           %endif
                           <td class="colalph">$(V_APSKIL)</td>
                           <td class="colalph">$(V_APCITY)</td>
                           <td class="colcode">$(V_APST)</td>
                           <td class="colcode">$(V_APZIP)</td>
                           %if (V_APPHON > "0")
                               @EditPhoneNumber(V_APPHON)
                           %endif
                           <td class="colcode">$(V_APPHON)</td>
                           <td class="colcode">$(V_APLCTN)</td>
                           <td class="colalph">$(V_APJBCD)</td>
                           <td class="colalph">$(V_APPSTN)</td>
                           <td class="colalph">$(V_APSTTS)</td>
                        </tr>
                    %endif
       	 %}
	     </table>
            %if (sql_Record_Count != "1")
                %INCLUDE "PageBottom.icl"
                %INCLUDE "WildCardPrint.icl"
                $(hrTagAttr)
                %INCLUDE "Copyright.icl"
            %endif
    %}
%}
%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  @dtw_assign(uv_HRCompanyName, "APCOMP")
  %INCLUDE "userview.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " SELECT APCOMP, APAPDT, APAPSQ, APLNAM, APFNAM, APMIDI, APRNAM, APADR1, APADR2, APCITY, APST, APZIP, APPHON, APETID, APGNDR, APJBCD, APPSTN, APEEO, APLCTN, APEMPL, APSTTS, APSKIL, APMILT, APLNAMU, APFNAMU", stmtSQL)
  @dtw_concat(fileSQL, " PEAPPL ", fileSQL)
  %if ((inclNotHired == "Y") && (inclHired != "Y"))
      @dtw_concat(selectSQL, " APCOMP = $(hrCompany) and APEMPL = 0", selectSQL)
  %elseif ((inclNotHired != "Y") && (inclHired == "Y"))
      @dtw_concat(selectSQL, " APCOMP = $(hrCompany) and APEMPL <> 0", selectSQL)
  %elseif ((inclNotHired == "Y") && (inclHired == "Y"))
      @dtw_concat(selectSQL, " APCOMP = $(hrCompany)", selectSQL)
  %elseif ((inclNotHired != "Y") && (inclHired != "Y"))
      @dtw_concat(selectSQL, " APCOMP = $(hrCompany) and APEMPL = 0 and APEMPL<> 0", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @Applicant_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) Applicant_XMLQuery (IN CHAR(64)    profileHandle,
				           CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
       @XMLBeginTag("ApplicantList")
           %ROW{
               @DateFromCYMD(V_APAPDT)
               @EditPhoneNumber(V_APPHON)

                   @XMLIDTag(@DTW_rCONCAT(V_APCOMP, @DTW_rCONCAT("/", @DTW_rCONCAT(V_APAPDT, @DTW_rCONCAT("/", V_APAPSQ)))), "Applicant ID")
                   @XMLTag(V_APAPDT, "ApplicationDate")
               @XMLBeginTag("PersonName")
                   @XMLTag(V_APRNAM, "FormattedName")
                   @XMLTag(V_APFNAM, "GivenName")
                   @XMLTag(V_APMIDI, "MiddleName")
                   @XMLTag(V_APLNAM, "FamilyName")
               @XMLEndTag("PersonName")

	   	        @XMLBeginTag("PostalAddress")
                           @XMLTag(country, "CountryCode")
                           @XMLTag(V_APZIP, "PostalCode")
                           @XMLTag(V_APST, "Region")
                           @XMLTag(V_APCITY, "Municipality")

	   	            @XMLBeginTag("DeliveryAddress")
                               @XMLTag(V_APADR1, "AddressLine")
                               @XMLTag(V_APADR2, "AddressLine")
	   	            @XMLEndTag("DeliveryAddress")

	                 @XMLEndTag("PostalAddress")

                       @XMLTag(V_APPHON, "PhoneNumber")
                       @XMLTag(V_APLCTN, "LocationAppliedFor")
                       @XMLTag(V_APJBCD, "JobCodeAppliedFor")
                       @XMLTag(V_APPSTN, "PositionAppliedfor")
                       @XMLTag(V_APETID, "EthnicID")
                       @XMLTag(V_APGNDR, "Gender")
                       @XMLTag(V_APEEO, "EEOCategory")
                       @XMLTag(V_APMILT, "MilitaryStatusCode")
                   @XMLEndTag("Applicant")
           %}
       @XMLEndTag("ApplicantList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (sec_05 == "N")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)progOptSecError.d2w/DISPLAY$(genericVarBase)&amp;page_title=@dtw_rurlescseq(page_title)">
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "APAPDT,APAPSQ")
              @DTW_ASSIGN(orderByDisplay, "Application Date, Sequence Number")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %elseif (chgNotHired == "Y" && inclNotHired == "Y")
              @dtw_assign(inclNotHired, "")
          %elseif (chgNotHired == "Y")
              @dtw_assign(inclNotHired, "Y")
          %elseif (chgHired == "Y" && inclHired == "Y")
              @dtw_assign(inclHired, "")
          %elseif (chgHired == "Y")
              @dtw_assign(inclHired, "Y")
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)

      %endif
      %if (inclNotHired == "" && inclHired == "" && chgNotHired != "Y" && chgHired != "Y")
          @dtw_assign(inclNotHired, "Y")
          @dtw_assign(inclHired, "")
      %endif
      %INCLUDE "SearchReturn.icl"
  %endif
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit ()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}
%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "ApplDate")
      %if (orderBy == "APAPDT,APAPSQ")
          @DTW_ASSIGN(orderBy, "APAPDT DESC, APAPSQ")
          @DTW_ASSIGN(orderByDisplay, "Application Date (descending), Sequence Number")
      %else
          @DTW_ASSIGN(orderBy, "APAPDT,APAPSQ")
          @DTW_ASSIGN(orderByDisplay, "Application Date, Sequence Number")
      %endif
  %elseif (sequence == "ApplSeq")
      %if (orderBy == "APAPSQ,APAPDT DESC")
          @DTW_ASSIGN(orderBy, "APAPSQ DESC,APAPDT DESC")
          @DTW_ASSIGN(orderByDisplay, "Sequence Number (descending), Application Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "APAPSQ,APAPDT DESC")
          @DTW_ASSIGN(orderByDisplay, "Sequence Number, Application Date (descending)")
      %endif
  %elseif (sequence == "ApplLast")
      %if (orderBy == "APLNAMU,APFNAMU")
          @DTW_ASSIGN(orderBy, "APLNAMU DESC, APFNAMU")
          @DTW_ASSIGN(orderByDisplay, "Last Name (descending), First Name")
      %else
          @DTW_ASSIGN(orderBy, "APLNAMU,APFNAMU")
          @DTW_ASSIGN(orderByDisplay, "Last Name, First Name")
      %endif
  %elseif (sequence == "ApplSkill")
      %if (orderBy == "APSKIL,APLNAMU")
          @DTW_ASSIGN(orderBy, "APSKIL DESC, APLNAMU")
          @DTW_ASSIGN(orderByDisplay, "Skill (descending), Last Name")
      %else
          @DTW_ASSIGN(orderBy, "APSKIL,APLNAMU")
          @DTW_ASSIGN(orderByDisplay, "Skill, Last Name")
      %endif
  %elseif (sequence == "ApplCity")
      %if (orderBy == "APCITY,APST")
          @DTW_ASSIGN(orderBy, "APCITY DESC, APST")
          @DTW_ASSIGN(orderByDisplay, "City (descending), State")
      %else
          @DTW_ASSIGN(orderBy, "APCITY,APST")
          @DTW_ASSIGN(orderByDisplay, "City, State")
      %endif
  %elseif (sequence == "ApplState")
      %if (orderBy == "APST ,APCITY")
          @DTW_ASSIGN(orderBy, "APST DESC,APCITY")
          @DTW_ASSIGN(orderByDisplay, "State (descending), City")
      %else
          @DTW_ASSIGN(orderBy, "APST ,APCITY")
          @DTW_ASSIGN(orderByDisplay, "State, City")
      %endif
  %elseif (sequence == "ApplZip")
      %if (orderBy == "APZIP,APCITY")
          @DTW_ASSIGN(orderBy, "APZIP DESC,APCITY")
          @DTW_ASSIGN(orderByDisplay, "Zip Code (descending), City")
      %else
          @DTW_ASSIGN(orderBy, "APZIP,APCITY")
          @DTW_ASSIGN(orderByDisplay, "Zip Code, City")
      %endif
  %elseif (sequence == "ApplPhone")
      %if (orderBy == "APPHON")
          @DTW_ASSIGN(orderBy, "APPHON DESC")
          @DTW_ASSIGN(orderByDisplay, "Phone Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "APPHON")
          @DTW_ASSIGN(orderByDisplay, "Phone Number")
      %endif
  %elseif (sequence == "ApplJob")
      %if (orderBy == "APJBCD")
          @DTW_ASSIGN(orderBy, "APJBCD DESC")
          @DTW_ASSIGN(orderByDisplay, "Job Code Applied For (descending)")
      %else
          @DTW_ASSIGN(orderBy, "APJBCD")
          @DTW_ASSIGN(orderByDisplay, "Job Code Applied For")
      %endif
  %elseif (sequence == "ApplPos")
      %if (orderBy == "APPSTN")
          @DTW_ASSIGN(orderBy, "APPSTN DESC")
          @DTW_ASSIGN(orderByDisplay, "Position Applied For (descending)")
      %else
          @DTW_ASSIGN(orderBy, "APPSTN")
          @DTW_ASSIGN(orderByDisplay, "Position Applied For")
      %endif
  %elseif (sequence == "ApplLoc")
      %if (orderBy == "APLCTN")
          @DTW_ASSIGN(orderBy, "APLCTN DESC")
          @DTW_ASSIGN(orderByDisplay, "Location Applied For (descending)")
      %else
          @DTW_ASSIGN(orderBy, "APLCTN")
          @DTW_ASSIGN(orderByDisplay, "Location Applied For")
      %endif
  %elseif (sequence == "ApplSts")
      %if (orderBy == "APSTTS")
          @DTW_ASSIGN(orderBy, "APSTTS DESC")
          @DTW_ASSIGN(orderByDisplay, "Status (descending)")
      %else
          @DTW_ASSIGN(orderBy, "APSTTS")
          @DTW_ASSIGN(orderByDisplay, "Status")
      %endif
  %elseif (sequence == "EmplSeq")
      %if (orderBy == "APEMPL")
          @DTW_ASSIGN(orderBy, "APEMPL DESC")
          @DTW_ASSIGN(orderByDisplay, "Employee Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "APEMPL")
          @DTW_ASSIGN(orderByDisplay, "Employee Number")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javaScript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchDate, 6, 0) &&
                      editNum(document.Search.srchPhone, 10, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(contentTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ORGSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      @RetHrCompNam(profileHandle, dataBaseID, hrCompany, facilityZero, coFacName)
                      <H2> $(coFacName)</H2>
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"
                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Application Date</td>
                              @dtw_assign(operNbr, "operDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchDate" size="6 maxlength="6">
                              <a href="javascript:calWindow('srchDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Skill</td>
                              @dtw_assign(operNbr, "operSkill")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchSkill" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">City</td>
                              @dtw_assign(operNbr, "operCity")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCity" size="16" maxlength="16"></td>
                          </tr>

                          <tr><td class="dsphdr">State</td>
                              @dtw_assign(operNbr, "operState")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchState" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)StateSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Search&amp;fldName=srchState&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stateDesc" value="$(fieldDesc)" type="text" size="35" disabled></td></tr>

                          <tr><td class="dsphdr">Zip Code</td>
                              @dtw_assign(operNbr, "operZip")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchZip" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Phone Number</td>
                              @dtw_assign(operNbr, "operPhone")
                              <td>&nbsp;</td>
                              <td class="inputnmbr"> <input type="text" name="srchPhone" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Location Applied For</td>
                              @dtw_assign(operNbr, "operLocation")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputnmbr"><input name="srchLoc" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(cGIPath)HRCodeSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Search&amp;hrCodeType=O&amp;fldName=srchLoc&amp;fldDesc=locCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="locCodeDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Job Code Applied For</td>
                              @dtw_assign(operNbr, "operJobCode")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputnmbr"><input name="srchJob" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(cGIPath)HRCodeSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Search&amp;hrCodeType=J&amp;fldName=srchJob&amp;fldDesc=jobCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="jobCodeDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Position Applied For</td>
                              @dtw_assign(operNbr, "operPos")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchPos" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Status</td>
                              @dtw_assign(operNbr, "operStatus")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchStts" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(cGIPath)HRCodeSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Search&amp;hrCodeType=A&amp;fldName=srchStts&amp;fldDesc=stsCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="stsCodeDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Last Name</td>
                              @dtw_assign(operNbr, "operLast")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchLast" size="18" maxlength="18"></td>
                          </tr>

                          <tr><td class="dsphdr">First Name</td>
                              @dtw_assign(operNbr, "operFirst")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchFirst" size="18" maxlength="18"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDate.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("APAPDT", "Application Date", $(srchDate), "", operDate, "D")
  @Build_WildCard ("upper(APSKIL)", "Skill", $(srchSkill), "U", operSkill, "A")
  @Build_WildCard ("upper(APCITY)", "City", $(srchCity), "U", operCity, "A")
  @Build_WildCard ("APST", "State", $(srchState), "U", operState, "A")
  @Build_WildCard ("APZIP", "Zip Code", $(srchZip), "U", operZip, "A")
  @Build_WildCard ("APPHON", "Phone Number", $(srchPhone), "", "", "P")
  @Build_WildCard ("APLCTN", "Location Applied For", $(srchLoc), "U", operLocation, "A")
  @Build_WildCard ("APJBCD", "Job Code Applied For", $(srchJob), "U", operJobCode, "A")
  @Build_WildCard ("upper(APPSTN)", "Position Applied For", $(srchPos), "U", operPos, "A")
  @Build_WildCard ("APSTTS", "Status", $(srchStts), "U", operStatus, "A")
  @Build_WildCard ("APFNAMU", "First Name", $(srchFirst), "U", operFirst, "A")
  @Build_WildCard ("APLNAMU", "Last Name", $(srchLast), "U", operLast, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
  %}