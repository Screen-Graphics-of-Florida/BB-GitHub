%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Deduction History"
  d2wName                 = "EmplDedHistory.d2w"
  d2wVarBase              = "$(genericVarBase)$(employeeVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPRCHI"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  inclActive              = ""
  inclTerminated          = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "EmployeeURL.icl"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "DateEdit.icl"
              %INCLUDE "Menu.js"
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editdate(document.Search.srchCheckDate) &&
                      editNum(document.Search.srchDeduction, 3, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "EMPLDEDHIST ")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "UserViewEmpl.icl"
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select EHCOMP, EHFACL, EHEMPL, EHRCCD, EHCKTY, EHPPDT, EHCKDT, EHCKNO, ", stmtSQL)
                      @dtw_concat(stmtSQL, " EHPREF, VHREF, VHDDNO, VHAMT, ", stmtSQL)
                      @dtw_concat(stmtSQL, " EMCOMP, EMFACL, EMEMPL, EMPECP, EMPEMP, EMLNAM, EMFNAM, EMMIDI, EMRNAM, ", stmtSQL)
                      @dtw_concat(stmtSQL, " EMTYPE, EMLOC,  EMDEPT, EMJOB, EMPRAC, EMTRDT, EMTRCD, EMLNAMU, EMFNAMU ", stmtSQL)
                      @dtw_concat(fileSQL, " PRCKHS inner join PRDEDH on EHPREF=VHREF ", fileSQL)
                      @dtw_concat(fileSQL, "        inner join HREMPL on EHCOMP=EMCOMP and EHFACL=EMFACL and EHEMPL=EMEMPL", fileSQL)
                      @dtw_concat(selectSQL, " EHCOMP=$(prCompany) and EHFACL=$(prFacility) and EHEMPL=$(prEmployee) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @DedHistory_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) DedHistory_Query (IN CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

          @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>

              @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
              <tr><td><h2>$(F_EmpName)</h2></td></tr>

          </table>
          %INCLUDE "ConfMessageDisplay.icl"

          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Check<br>Date</th>
                          <th class="colhdr">Deduction<br>Number</th>
                      </tr>
                      <tr><td><input type="text" class="inputnmbr" name="srchCheckDate" size="6" maxlength="6">
                              <input type="hidden" name="operCheckDate" value="=">
                          </td>
                          <td><input type="text" class="inputnmbr" name="srchDeduction" size="3" maxlength="3">
                              <input type="hidden" name="operDeduction" value="=">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchCheckDate.focus();
                  </script>
              </form>

              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("EHCKNO", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CheckNumber" title="Sequence By Check Number, Check Date (descending)">Check<br>Number</a></th>
                  @OrderBy_Sort("EHCKDT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CheckDate" title="Sequence By Check Date, Check Number">Check<br>Date</a></th>
                  @OrderBy_Sort("EHRCCD", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CheckType" title="Sequence By Check Type, Check Date (descending), Check Number">Check<br>Type</a></th>	
                  @OrderBy_Sort("VHDDNO", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DedNumber" title="Sequence By Deduction Number, Check Date (descending)">Deduction<br>Number</a></th>
                  @OrderBy_Sort("VHAMT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DedAmount" title="Sequence By Deduction Amount, Deduction Number">Deduction<br>Amount</a></th>
                  <th class="colhdr">Long<br>Description</th>
              </tr>
          %INCLUDE "NoRecordsFound.icl"
          %ROW{
              @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;processingReference=@dtw_rurlescseq(V_EHPREF)&amp;detailSequence=@dtw_rurlescseq(V_SHSEQ)")
              %if (sql_Record_Count > "0")
                  @Format_Date(V_EHCKDT, "D", F_EHCKDT)
                  @Format_Nbr($(V_VHAMT), F_VHAMT, "2", $(amtEditCode), "", "", "")
                  @RtvFldDesc("HVDDNO=$(V_VHDDNO)", "HRDEDM", "HVLDSC", dedLongDesc)
                  @RtvFldDesc("FLTYPE='PRCHKTYPE' and FLVALU='$(V_EHRCCD)'", "SYFLAG", "FLDESC", checkTypeDesc)
                  %INCLUDE "SetRowClass.icl"

                  <tr class="$(rowClass)">
                      %if ((V_EMTYPE == "H" && sec_06 == "N") || (V_EMTYPE != "H" && sec_07 == "N"))
                          <td class="colnmbr">$(V_EHCKNO)</td>
                      %else
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)EmployeeCheckSelect.d2w/REPORT$(maintainVar)" title="View Check Information">$(V_EHCKNO)</a></td>
                      %endif
	               <td class="coldate">$(F_EHCKDT)</td>
                      <td class="colcode" $(helpCursor)><span title="$(checkTypeDesc)">$(V_EHRCCD)</span></td>
	               <td class="colcode">$(V_VHDDNO)</td>
	               <td class="colnmbr">$(F_VHAMT)</td>
	               <td class="colalph">$(dedLongDesc)</td>
                  </tr>
              %endif
          %}
          </table>
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "UserViewEmpl.icl"
  %INCLUDE "userview.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "Select EHCOMP, EHFACL, EHEMPL, EHRCCD, EHCKTY, EHPPDT, EHCKDT, EHCKNO, ", stmtSQL)
  @dtw_concat(stmtSQL, " EHPREF, VHREF, VHDDNO, VHAMT, ", stmtSQL)
  @dtw_concat(stmtSQL, " EMCOMP, EMFACL, EMEMPL, EMPECP, EMPEMP, EMLNAM, EMFNAM, EMMIDI, EMRNAM, ", stmtSQL)
  @dtw_concat(stmtSQL, " EMTYPE, EMLOC,  EMDEPT, EMJOB, EMPRAC, EMTRDT, EMTRCD, EMLNAMU, EMFNAMU ", stmtSQL)
  @dtw_concat(fileSQL, " PRCKHS inner join PRDEDH on EHPREF=VHREF ", fileSQL)
  @dtw_concat(fileSQL, "        inner join HREMPL on EHCOMP=EMCOMP and EHFACL=EMFACL and EHEMPL=EMEMPL", fileSQL)
  @dtw_concat(selectSQL, " EHCOMP=$(prCompany) and EHFACL=$(prFacility) and EHEMPL=$(prEmployee) ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @DedHistory_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) DedHistory_XMLQuery (IN CHAR(64)    profileHandle,
			                    CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("DeductionHistoryList")
          %ROW{
               %if (V_EHRCCD == "H")
		    @dtw_assign(checkType, "Regular")
               %elif (V_EHRCCD == "M")
		    @dtw_assign(checkType, "Manual/Adjustment")
               %elif (V_EHRCCD == "V")
		    @dtw_assign(checkType, "Void")
               %endif
               @RtvFldDesc("HVDDNO=$(V_VHDDNO)", "HRDEDM", "HVLDSC", dedLongDesc)
               @DateFromCYMD(V_EHCKDT)

		@XMLIDTag(@DTW_rCONCAT(V_EHCOMP, @DTW_rCONCAT("/", @DTW_rCONCAT(V_EHFACL, @DTW_rCONCAT("/", @DTW_rCONCAT(V_EHEMPL, @DTW_rCONCAT("/", @DTW_rCONCAT(V_EHCKNO, @DTW_rCONCAT("/", V_VHDDNO)))))))), "EmployeeDeduction ID")
                   @XMLTag(V_EHCOMP, "CompanyNumber")
                   @XMLTag(V_EHFACL, "FacilityNumber")
                   @XMLTag(V_EHEMPL, "EmployeeNumber")
                       @XMLBeginTag("PersonName")
                           @XMLTag(V_EMRNAM, "FormattedName")
                           @XMLTag(V_EMFNAM, "GivenName")
                           @XMLTag(V_EMMIDI, "MiddleName")
                           @XMLTag(V_EMLNAM, "FamilyName")
                       @XMLEndTag("PersonName")
                   @XMLTag(V_EMDEPT, "HomeDepartment")
                   @XMLTag(V_EHCKNO, "CheckNumber")
                   @XMLTag(V_EHCKDT, "CheckDate")
                   @XMLTag(checkType, "CheckType")
                   @XMLTag(V_VHDDNO, "DeductionNumber")
                   @XMLTag(dedLongDesc, "DeductionDescription")
                   @XMLTag(V_VHAMT, "DeductionAmount")
               @XMLEndTag("EmployeeDeduction")
          %}
      @XMLEndTag("DeductionHistoryList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "EHCKDT DESC,EHCKNO")
              @DTW_ASSIGN(orderByDisplay, "Check Date (descending), Check Number")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      %INCLUDE "SearchReturn.icl"
  %endif
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "CheckNumber")
      %if (orderBy == "EHCKNO,EHCKDT DESC")
          @DTW_ASSIGN(orderBy, "EHCKNO DESC,EHCKDT DESC")
          @DTW_ASSIGN(orderByDisplay, "Check Number (descending), Check Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "EHCKNO,EHCKDT DESC")
          @DTW_ASSIGN(orderByDisplay, "Check Number, Check Date (descending)")
      %endif
  %elif (sequence == "CheckDate")
      %if (orderBy == "EHCKDT,EHCKNO")
          @DTW_ASSIGN(orderBy, "EHCKDT DESC,EHCKNO")
          @DTW_ASSIGN(orderByDisplay, "Check Date (descending), Check Number")
      %else
          @DTW_ASSIGN(orderBy, "EHCKDT,EHCKNO")
          @DTW_ASSIGN(orderByDisplay, "Check Date, Check Number")
      %endif
  %elif (sequence == "CheckType")
      %if (orderBy == "EHRCCD,EHCKDT DESC,EHCKNO")
          @DTW_ASSIGN(orderBy, "EHRCCD DESC,EHCKDT DESC,EHCKNO")
          @DTW_ASSIGN(orderByDisplay, "Check Type (descending), Check Date (descending), Check Number")
      %else
          @DTW_ASSIGN(orderBy, "EHRCCD,EHCKDT DESC,EHCKNO")
          @DTW_ASSIGN(orderByDisplay, "Check Type, Check Date (descending), Check Number")
      %endif

  %elif (sequence == "DedNumber")
      %if (orderBy == "VHDDNO,EHCKDT DESC")
          @DTW_ASSIGN(orderBy, "VHDDNO DESC,EHCKDT DESC")
          @DTW_ASSIGN(orderByDisplay, "Deduction Number (descending), Check Date (descending)")
      %else
          @DTW_ASSIGN(orderBy, "VHDDNO,EHCKDT DESC")
          @DTW_ASSIGN(orderByDisplay, "Deduction Number, Check Date (descending)")
      %endif
  %elif (sequence == "DedAmount")
      %if (orderBy == "VHAMT,VHDDNO")
          @DTW_ASSIGN(orderBy, "VHAMT DESC,VHDDNO")
          @DTW_ASSIGN(orderByDisplay, "Deduction Amount (descending), Deduction Number")
      %else
          @DTW_ASSIGN(orderBy, "VHAMT,VHDDNO")
          @DTW_ASSIGN(orderByDisplay, "Deduction Amount, Deduction Number")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              @dtw_assign(formName, "Search")
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
	       %INCLUDE "numedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchCheck, 6, 0) &&
                      editdate(document.Search.srchFromDate) &&
                      editdate(document.Search.srchToDate) &&
                      editNum(document.Search.srchDeduction, 3, 0) &&
                      editNum(document.Search.srchAmount, 9, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "EMDEDHISTSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"

                      @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
                      <h2>$(F_EmpName)</h2>

                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Check Number</td>
                              @dtw_assign(operNbr, "operCheck")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchCheck" size="6" maxlength="6"></td>
                          </tr>

                          <tr><td class="dsphdr">From Check Date</td>
                              @dtw_assign(operNbr, "operFromDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchFromDate" size="6" maxlength="6"> 		
                                  <a href="javascript:calWindow('srchFromDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">To Check Date</td>
                              @dtw_assign(operNbr, "operToDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchToDate" size="6" maxlength="6"> 		
                                  <a href="javascript:calWindow('srchToDate');">$(calendarImage)</a></td>
                          </tr>
                          <tr><td class="dsphdr">Deduction Number</td>
                              @dtw_assign(operNbr, "operDeduction")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input name="srchDeduction" type="text" size="3" maxlength="3"> <a href="$(homeURL)$(cGIPath)DeductionSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Search&amp;fldName=srchDeduction&amp;fldDesc=dedDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="dedDesc" value="$(dedDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Deduction Amount</td>
                              @dtw_assign(operNbr, "operAmount")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchAmount" size="9" maxlength="9"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchCheck.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("EHCKNO", "Check Number", $(srchCheck), "", operCheck, "N")
  @Build_WildCard ("EHCKDT", "From Check Date", $(srchFromDate), "", operFromDate, "D")
  @Build_WildCard ("EHCKDT", "To Check Date", $(srchToDate), "", operToDate, "D")
  @Build_WildCard ("EHCKDT", "Check Date", $(srchCheckDate), "", operCheckDate, "D")
  @Build_WildCard ("VHDDNO", "Deduction Number", $(srchDeduction), "", operDeduction, "N")
  @Build_WildCard ("VHAMT", "Deduction Amount", $(srchAmount), "", operAmount, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}