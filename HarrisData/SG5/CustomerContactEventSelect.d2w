*  Job: Customer Contact Event Select                               *
*********************************************************************
%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Customer Contact Event"
  d2wName                 = "CustomerContactEventSelect.d2w"
  attachFolder            = "CustomerContactEvent"
  d2wVarBase              = "$(genericVarBase)&amp;contactNumber=@dtw_rurlescseq(contactNumber)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;eventSequence=@dtw_rurlescseq(eventSequence)"
  programName             = "HCRCEM_E"
  fileName                = "CRCEVU"	
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "1000"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
  saveOrigSeq             = "0"	
  contactCustomer         = ""	
  evtsec_01               = ""	
  evtsec_02               = ""	
  evtsec_03               = ""	
  quickLinkByUser         = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- Start Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "CUSTCONTEVENTSELECT")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif

                      <td class="content">

%{ QuickLink Table %}     %INCLUDE "QuickLinkTable.icl"

%{ QuickLink By User %}   %INCLUDE "QuickLinkByUser.icl"

%{ Selected Event %}
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " CRCEVM ", fileSQL)
                          @dtw_concat(selectSQL, "EMCONT = $(contactNumber) and EMESEQ = $(eventSequence) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                          @Contact_Event_Selected(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Begin %}     %INCLUDE "QuickLinkBegLoop.icl"

        %{ Related Event %}
                              %if (quicklinkRef == "relatedevents")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " CRCEVM ", fileSQL)
                                  @dtw_concat(selectSQL, "EMCONT = $(contactNumber) ", selectSQL)
                                  %if (saveOrigSeq == "0")
                                      @dtw_concat(selectSQL, " AND EMOSEQ = $(eventSequence) ", selectSQL)
                                  %else
                                      @dtw_concat(selectSQL, " AND (EMESEQ = $(saveOrigSeq) or EMOSEQ = $(eventSequence)) ", selectSQL)
                                  %endif
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_concat(stmtSQL, " Order By EMEVTD desc, EMEVNT ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Contact_Event_Related(profileHandle, dataBaseID, stmtSQL)

        %{ Contact Information %}
                              %elif (quicklinkRef == "contactinformation")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " CRCNTM ", fileSQL)
                                  @dtw_concat(selectSQL, "CRCONT = $(contactNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Contact_Event_ContactInfo(profileHandle, dataBaseID, stmtSQL)

        %{ Customer Information %}
	   		       %elif (quicklinkRef == "customerinformation" && contactCustomer != "0")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "Select CMCNA1, CMCCTY, CMST, CMZIP, CMCUST, CMPHON", stmtSQL)
                                  @dtw_concat(stmtSQL, ", CMUDF1, CMUDF2, CMUDF3, CMUDF4, CMUDF5, CMCHLD", stmtSQL)
                                  @dtw_concat(fileSQL, " HDCUST ", fileSQL)
                                  @dtw_concat(selectSQL, "CMCUST = $(contactCustomer) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Contact_Event_CustomerInfo(profileHandle, dataBaseID, stmtSQL)

        %{ Related Contacts %}
	   		       %elif (quicklinkRef == "relatedcontacts" && contactCustomer != "0")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " CRCNTM ", fileSQL)
                                  @dtw_concat(selectSQL, "CRCONT <> $(contactNumber) and CRCUST = $(contactCustomer) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Contact_Event_Related_Contacts(profileHandle, dataBaseID, stmtSQL)
	   		       %endif

        %{ Attachments %}     %INCLUDE "AttachmentSQL.icl"

%{ Quicklink End %}       %INCLUDE "QuickLinkEndLoop.icl"

                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Contact_Event_Selected (IN CHAR(64)    profileHandle,
				               CHAR(2)     dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %ROW {
          @pgmOptSecurity(profileHandle, dataBaseID, programName, evtsec_01, evtsec_02, evtsec_03, evtsec_04, evtsec_05, evtsec_06, evtsec_07, evtsec_08, evtsec_09, evtsec_10, evtsec_11, evtsec_12, evtsec_13, evtsec_14, evtsec_15)
          @RtvCustCont(profileHandle, dataBaseID, contactNumber, lastName, firstName, salutation, companyName)
          @Format_EmplName(firstName, lastName, "", "", "", "H", F_Name)
          @RtvFldDesc("ECFILN='$(fileName)' and ECEVNT='$(V_EMEVNT)' ", "SYEVNT", "ECDESC", eventDesc)
          @UserDefined_Query(profileHandle, dataBaseID, "CRCEVU    ", V_EMEVNT, userDefinedTable)	
          @dtw_assign(contactNumberFilled, $(contactNumber))
          %while(@dtw_rlength(contactNumberFilled) != "7") {@dtw_insert("0", contactNumberFilled, contactNumberFilled)%}
          @dtw_assign(eventSequenceFilled, $(eventSequence))
          %while(@dtw_rlength(eventSequenceFilled) != "7") {@dtw_insert("0", eventSequenceFilled, eventSequenceFilled)%}
          @dtw_assign(attachVarKey, "$(contactNumberFilled)$(V_EMEVNT)$(eventSequenceFilled)")
          @dtw_assign(attachForDesc, "$(F_Name) - $(eventDesc)")
          @dtw_assign(attachPrg1, "CRCEVM Where EMCONT=$(contactNumber) and EMESEQ=$(eventSequence)")

          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
                  <tr><td><h1> $(page_title)</h1></td>
                      %if (formatToPrint != "Y")
                          <td class="toolbar">
                              <a href="$(homeURL)$(cGIPath)CustomerContactEvent.d2w/REPORT$(d2wVarBase)&amp;confMessage=" title="Return To Contact Events">$(portalHome)</a>
                              %INCLUDE "Attachment.icl"
                              %if (contactNumber <= "0")
                                  @dtw_assign(vendCustNumber, $(customerNumber))
                                  @dtw_assign(vendCustName, $(customerName))
                              %endif
                              %if (evtsec_01 == "Y")
                                  <a href="$(homeURL)$(cGIPath)EventCodeSelection.d2w/REPORT$(genericVarBase)&amp;fileName=@dtw_rurlescseq(fileName)&amp;contactNumber=@dtw_rurlescseq(contactNumber)&amp;vendCustNumber=@dtw_rurlescseq(vendCustNumber)&amp;vendCustName=@dtw_rurlescseq(vendCustName)&amp;fromContactNumber=@dtw_rurlescseq(contactNumber)&amp;origSequence=0&amp;fromD2w=@dtw_rurlescseq(d2wName)" onclick="$(searchWinVar)">$(addEventImageLrg)</a>
                              %endif
                              %INCLUDE "FormatToPrint.icl"
                              %INCLUDE "HelpPage.icl"
                          </td>
                      %endif
                  </tr>
          </table>

          <table $(contentTable)>
              @Format_Header_URL("Contact", $(F_Name), $(contactNumber), "$(homeURL)$(cGIPath)CustomerContactSelect.d2w/REPORT$(d2wVarBase)")
          </table>
          %INCLUDE "ConfMessageDisplay.icl"

          $(hrTagAttr)

          %INCLUDE "QuickLinkDisplay.icl"

          <fieldset class="legendBody">
              <legend class="legendTitle">Selected Event</legend>
              %if (formatToPrint != "Y")
                  @RtvFldDesc("EMCONT=$(V_EMCONT) and EMESEQ=$(V_EMESEQ) and EMOSEQ>0 or EMCONT=$(V_EMCONT) and EMOSEQ=$(V_EMESEQ) ", "CRCEVM", "count(*)", relCount)
                  <table $(contentTable)>
                      <tr>
                          <td>
                              %if (evtsec_02 == "Y" || evtsec_03 == "Y")
                                  <a href="$(homeURL)$(cGIPath)CustomerContactEventMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;eventCode=@dtw_rurlescseq(V_EMEVNT)&amp;fromContactNumber=@dtw_rurlescseq(contactNumber)&amp;fromD2w=&amp;maintenanceCode=C">$(changeImageSml)</a>
                              %endif
                              %if (evtsec_01 == "Y")
                                  <a href="$(homeURL)$(cGIPath)EventCodeSelection.d2w/REPORT$(genericVarBase)&amp;fileName=@dtw_rurlescseq(fileName)&amp;contactNumber=@dtw_rurlescseq(contactNumber)&amp;vendCustNumber=@dtw_rurlescseq(vendCustNumber)&amp;vendCustName=@dtw_rurlescseq(vendCustName)&amp;fromContactNumber=@dtw_rurlescseq(contactNumber)&amp;origSequence=@dtw_rurlescseq(eventSequence)&amp;fromD2w=@dtw_rurlescseq(d2wName)" onclick="$(searchWinVar)">$(addEventImageSml)</a>
                              %endif
                              %if (relCount > "0")
                                  @dtw_assign(relImg, relatedColumns)
                                  @dtw_replace(relImg , "Click here to maintain the related columns", "View All Related Events", relImg)
                                  <a href="$(homeURL)$(cGIPath)CustomerContactRelatedEvents.d2w/REPORT$(genericVarBase)&amp;contactNumber=@dtw_rurlescseq(V_EMCONT)&amp;eventSequence=@dtw_rurlescseq(V_EMESEQ)">$(relImg)</a>
                              %endif
                          </td>
                      </tr>
                  </table>
              %endif
              <table $(contentTable)>

              @dtw_assign(saveOrigSeq, V_EMOSEQ)
              @retrieveUserRole(profileHandle, dataBaseID, V_EMUSER, userCustomer, userVendor, userSalesman, userBadge, userCatalog, newsLink, profileName)

              <tr>
                  @RtvFldDesc("ECFILN='$(fileName)' and ECEVNT='$(V_EMEVNT)' ", "SYEVNT", "ECDESC", eventDesc)
                  @Format_Code(V_EMEVNT, F_EMEVNT)
                  <td class="dsphdr">Event</td>
                  <td class="dspalph">$(eventDesc)</td>
                  <td class="dspalph">$(F_EMEVNT)</td>
              </tr>
              <tr>
                  <td class="dsphdr">Description</td>
                  @dtw_assign(condCnt, "1")
                  %if (V_EMURLA != "" && V_EMURLC != "")
                      @RtvFldDesc("$(V_EMURLC)", "$(V_EMURLF)", "char(count(*))", condCnt)
                  %endif
                  %if (V_EMURLA != "" && condCnt > "0")
                      @dtw_replace(V_EMURLA, "@@genericVarBase", $(genericVarBase), V_EMURLA)
                      <td class="dspalph"><a href="$(homeURL)$(cGIPath)$(V_EMURLA)" title="$(V_EMURLT)">$(V_EMDESC)</a></td>
                  %else
                      <td class="dspalph">$(V_EMDESC)</td>
                  %endif
              </tr>
              <tr>
                  @Format_Code(V_EMUSER, F_EMUSER)
                  <td class="dsphdr">User Profile</td>
                  <td class="dspalph">$(profileName)</td>
                  <td class="dspalph">$(F_EMUSER)</td>
              </tr>
              <tr>
                  @Date_FromISO_ToCYMD(V_EMEVTD, F_CYMD)
                  @Format_Date(F_CYMD, "H", F_EMEVTD)
                  <td class="dsphdr">Event Date</td>
                  @dtw_assign(calYear, @dtw_rsubstr(V_EMEVTD, "1", "4"))
                  @dtw_assign(calMonth, @dtw_rsubstr(V_EMEVTD, "6", "2"))
                  <td class="dspalph"> <a href="$(homeURL)$(cGIPath)EventCalendarSelect.d2w/Edit_Data$(genericVarBase)&amp;calYear=@dtw_rurlescseq(calYear)&amp;calMonth=@dtw_rurlescseq(calMonth)&amp;calWeek=0&amp;calView=M&amp;reload=Y&amp;user=@dtw_rurlescseq(V_EMUSER)&amp;dspCustomer=CHECKED&amp;dspOpen=CHECKED&amp;dspTime=CHECKED&amp;dspCompleted=CHECKED" title="View Calendar">$(F_EMEVTD)</a></td>
              </tr>
              <tr>
                  @EditHrsMinSec(V_EMEVTT)
                  <td class="dsphdr">Event Time</td>
                  <td class="dspalph">$(V_EMEVTT)</td>
              </tr>
              <tr>
                  @Date_FromISO_ToCYMD(V_EMCMPD, F_CYMD)
                  @Format_Date(F_CYMD, "H", F_EMCMPD)
                  <td class="dsphdr">Completion Date</td>
                  <td class="dspalph">$(F_EMCMPD)</td>
              </tr>
          %}

              @dtw_tb_rows(userDefinedTable, userMaxRows)
              @dtw_assign(ux, "1")
              %while(ux <= userMaxRows){
                  %INCLUDE "UserDefined.icl"
                  @dtw_tb_rows(custContactEventTable, maxRows)
                  @dtw_assign(x, "1")
                  %while((@dtw_tb_rgetv(custContactEventTable, x, @dtw_tb_rQuerycolnonj(custContactEventTable, "EUFLDN")) != V_UFFLDN) && (x <= maxRows))
                      {@dtw_add(x, "1", x)%}
                  %if (x <=maxRows)
                      @dtw_tb_getv(custContactEventTable, x, @dtw_tb_rQuerycolnonj(custContactEventTable, "EUFLDD"), V_EUFLDD)
                      @dtw_tb_getv(custContactEventTable, x, @dtw_tb_rQuerycolnonj(custContactEventTable, "EUFLDV"), V_EUFLDV)
                      @dtw_tb_getv(custContactEventTable, x, @dtw_tb_rQuerycolnonj(custContactEventTable, "EUFLDR"), V_EUFLDR)
                  %else
                      @dtw_assign(V_EUFLDD, "")
                      @dtw_assign(V_EUFLDV, "")
                      @dtw_assign(V_EUFLDR, "")
                  %endif

        	       <tr><td class="dsphdr">$(V_UFDESC)</td>
                      %if (V_UFTYPE == "A")
                          %if (V_UFFFMT == "U")
                              <td class="dspalph"><a href="$(V_EUFLDV)" target=_blank>$(V_EUFLDV)</a></td>
                          %elif (V_UFFFMT == "E")
                              <td class="dspalph"><a href="mailto:$(V_EUFLDV)" target=_blank title="Click here to send e-mail">$(V_EUFLDV)</a></td>
                          %else
                              <td class="dspalph">$(V_EUFLDV)
                          %endif
                      %elif (V_UFTYPE == "C")
                          %if (formatToPrint != "Y")
                              <td colspan="3"><textarea name="$(V_UFFLDN)" readonly ROWS=$(V_UFBOXS) COLS=60 >$(V_EUFLDV)</textarea>
                          %else
                              @dtw_chartohex(V_EUFLDV, hexValue)
                              @dtw_length(hexValue, fldLength)
                              @dtw_assign(printRows, "1")
                              @dtw_assign(x, "1")
                              %while(x <= fldLength){
                                  @dtw_pos("0D25", hexValue, x, y)
                                  %if (y > "0")
                                      @dtw_add(printRows, "1", printRows)
                                      @dtw_add(y, "4", x)
                                  %else
                                      @dtw_add(fldLength, "1", x)
                                  %endif
                              %}
                              <td colspan="3"><textarea name="$(V_UFFLDN)" readonly ROWS=$(printRows) COLS=60 >$(V_EUFLDV)</textarea>
                          %endif
                      %elif (V_UFTYPE == "N")
                          @dtw_add(V_UFSIZE, V_UFDECM, V_UFSIZE)
                          %if (V_UFDECM != "0")
                              @dtw_add(V_UFSIZE, "2", V_UFSIZE)
                          %endif
                          @dtw_assign(Precision, @dtw_radd(V_UFSIZE, V_UFDECM))
                          @dtw_format(V_EUFLDR, V_UFSIZE, V_UFDECM, "", "", Precision, V_EUFLDR)
                          %if (V_UFFFMT == "P")
                              @EditPhoneNumber(V_EUFLDR)
                          %endif
                          <td class="dspnmbr">$(V_EUFLDR)
                      %elif (V_UFTYPE == "D")
                          @Date_FromISO_ToCYMD(V_EUFLDD, F_CYMD)
                          @Format_Date(F_CYMD, "H", F_EUFLDD)
                          <td class="dspnmbr">$(F_EUFLDD)
                      %endif
                  </td></tr>
                  @dtw_add(ux, "1", ux)
              %}
          </table>
      </fieldset>
  %}
%}


%FUNCTION(dtw_sql) Contact_Event_Related (IN CHAR(64)    profileHandle,
				              CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
          <a name="relatedevents"></a>
          @dtw_assign(moreURL, "")
          %INCLUDE "QuickLinkTopOfForm.icl"

          <table $(contentTable)>
              %if (sql_Record_Count == "0")
                  %INCLUDE "QuickLinkNoInfoMsg.icl"
              %else
                  <tr>
                      %if (formatToPrint != "Y" && (evtsec_01 == "Y" || evtsec_02 == "Y" || evtsec_03 == "Y"))
                          <th class="colhdr">$(optionHeading)</th>
                      %endif
                      <th class="colhdr">Event<br>Code</th>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">User Profile</th>
                      <th class="colhdr">Event<br>Date</th>
                      <th class="colhdr">Event<br>Time</th>
                      <th class="colhdr">Completion<br>Date</th>
                  </tr>
              %endif

              %ROW {
                  %INCLUDE "SetRowClass.icl"
                  @Date_FromISO_ToCYMD(V_EMEVTD, F_CYMD)
                  @Format_Date(F_CYMD, "D", F_EMEVTD)
                  @EditHrsMinSec(V_EMEVTT)
                  @Date_FromISO_ToCYMD(V_EMCMPD, F_CYMD)
                  @Format_Date(F_CYMD, "D", F_EMCMPD)

                  @retrieveUserRole(profileHandle, dataBaseID, V_EMUSER, userCustomer, userVendor, userSalesman, userBadge, userCatalog, newsLink, profileName)
                  @RtvFldDesc("ECFILN='$(fileName)' and ECEVNT='$(V_EMEVNT)' ", "SYEVNT", "ECDESC", eventDesc)

                  <tr class="$(rowClass)">
                      %if (formatToPrint != "Y" && (evtsec_01 == "Y" || evtsec_02 == "Y" || evtsec_03 == "Y"))
                          <td class="opticon">
                              %if (evtsec_02 == "Y" || evtsec_03 == "Y")
                                  <a href="$(homeURL)$(cGIPath)CustomerContactEventMaintain.d2w/MAINTAIN$(genericVarBase)&amp;eventSequence=@dtw_rurlescseq(V_EMESEQ)&amp;eventCode=@dtw_rurlescseq(V_EMEVNT)&amp;contactNumber=@dtw_rurlescseq(contactNumber)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;fromContactNumber=@dtw_rurlescseq(contactNumber)&amp;fromD2w=&amp;maintenanceCode=C">$(changeImageSml)</a>
                              %endif
                              %if (evtsec_01 == "Y")
                                  <a href="$(homeURL)$(cGIPath)EventCodeSelection.d2w/REPORT$(genericVarBase)&amp;fileName=@dtw_rurlescseq(fileName)&amp;contactNumber=@dtw_rurlescseq(contactNumber)&amp;vendCustNumber=@dtw_rurlescseq(vendCustNumber)&amp;vendCustName=@dtw_rurlescseq(vendCustName)&amp;fromContactNumber=@dtw_rurlescseq(contactNumber)&amp;origSequence=@dtw_rurlescseq(V_EMESEQ)&amp;fromD2w=@dtw_rurlescseq(d2wName)" onclick="$(searchWinVar)">$(addEventImageSml)</a>
                              %endif
                          </td>
                      %endif
                      %if (contactNumber == "0")
                          <td class="colnmbr"> $(V_EMCONT)</td>                                      	
                      %endif
                      <td class="colalph" $(helpCursor)><span title="$(eventDesc)">$(V_EMEVNT)</span></td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(genericVarBase)&amp;eventSequence=@dtw_rurlescseq(V_EMESEQ)&amp;eventCode=@dtw_rurlescseq(V_EMEVNT)&amp;contactNumber=@dtw_rurlescseq(contactNumber)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)" title="View Event">$(V_EMDESC)</a></td>
                      <td class="colalph" $(helpCursor)><span title="$(profileName)">$(V_EMUSER)</span></td>
                      @dtw_assign(calYear, @dtw_rsubstr(V_EMEVTD, "1", "4"))
                      @dtw_assign(calMonth, @dtw_rsubstr(V_EMEVTD, "6", "2"))
                      <td class="coldate"> <a href="$(homeURL)$(cGIPath)EventCalendarSelect.d2w/Edit_Data$(genericVarBase)&amp;calYear=@dtw_rurlescseq(calYear)&amp;calMonth=@dtw_rurlescseq(calMonth)&amp;calWeek=0&amp;calView=M&amp;reload=Y&amp;user=@dtw_rurlescseq(V_EMUSER)&amp;dspCustomer=CHECKED&amp;dspOpen=CHECKED&amp;dspTime=CHECKED&amp;dspCompleted=CHECKED" title="View Calendar">$(F_EMEVTD)</a></td>
                      <td class="colcode">$(V_EMEVTT)</td>
                      <td class="coldate">$(F_EMCMPD)</td>
                  </tr>
              %}
          </table>
      </fieldset>
  %}
%}
%FUNCTION(dtw_sql) Contact_Event_ContactInfo (IN CHAR(64)    profileHandle,
				                  CHAR(2)     dataBaseID,
                                                 CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="contactinformation"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      @UserDefined_Query(profileHandle, dataBaseID, "CRCNTU    ", "          ", userDefinedTable)	
      @CustContactUser_Query(profileHandle, dataBaseID, contactNumber, custContactUserTable)	
      <table $(contentTable)>
          <colgroup>
              <col width="5%">
              <col width="60%">
              <col width="20%">
          %ROW {
              @Format_EmplName(V_CRFNAM, V_CRLNAM, "", "", "", "H", F_Name)
              <tr><td>&nbsp;</td>
                  <td rowspan="7" class="dspalph">
                       %if (V_CRCNAM != "")
                           $(V_CRCNAM) <br>
                       %endif
                       $(F_Name)<br>
                       %if (V_CRTITL != "")
                           $(V_CRTITL) <br>
                       %endif
                       %if (V_CRADR1 != "")
                           $(V_CRADR1) <br>
                       %endif
                       %if (V_CRADR2 != "")
                           $(V_CRADR2) <br>
                       %endif
                       %if (V_CRADR3 != "")
                           $(V_CRADR3) <br>
                       %endif
                       $(V_CRCITY), $(V_CRST) $(V_CRZIP)
                  </td>
              </tr>
              <tr><td>&nbsp;</td>
                  <td class="dsphdr">Contact Number</td>
                  <td class="dspnmbr">$(V_CRCONT)</td>
              </tr>

              <tr><td>&nbsp;</td>
                  @Date_FromISO_ToCYMD(V_CRDATI, F_CYMD)
                  @Format_Date(F_CYMD, "H", F_CRDATI)
                  <td class="dsphdr">Date Inactive</td>
                  <td class="dspalph">$(F_CRDATI)</td>
              </tr>

              <tr>
                  <td>&nbsp;</td>
                  <td class="dsphdr">Last Updated</td>
                  <td class="dspalph">$(V_CRTSTP)</td>
              </tr>
          %}
      </table>

      <table $(contentTable)>
          @dtw_tb_rows(userDefinedTable, userMaxRows)
          @dtw_assign(ux, "1")
          %while(ux <= userMaxRows){
              %INCLUDE "UserDefined.icl"
              @dtw_tb_rows(custContactUserTable, maxRows)
              @dtw_assign(x, "1")
              %while((@dtw_tb_rgetv(custContactUserTable, x, @dtw_tb_rQuerycolnonj(custContactUserTable, "CUFLDN")) != V_UFFLDN) && (x <= maxRows))
                  {@dtw_add(x, "1", x)%}
              %if (x <=maxRows)
                  @dtw_tb_getv(custContactUserTable, x, @dtw_tb_rQuerycolnonj(custContactUserTable, "CUFLDD"), V_CUFLDD)
                  @dtw_tb_getv(custContactUserTable, x, @dtw_tb_rQuerycolnonj(custContactUserTable, "CUFLDV"), V_CUFLDV)
                  @dtw_tb_getv(custContactUserTable, x, @dtw_tb_rQuerycolnonj(custContactUserTable, "CUFLDR"), V_CUFLDR)
              %else
                  @dtw_assign(V_CUFLDD, "")
                  @dtw_assign(V_CUFLDV, "")
                  @dtw_assign(V_CUFLDR, "")
              %endif

    	       <tr><td class="dsphdr">$(V_UFDESC)</td>
                  %if (V_UFTYPE == "A")
                      %if (V_UFFFMT == "U")
                          <td class="dspalph"><a href="$(V_CUFLDV)" target=_blank>$(V_CUFLDV)</a></td>
                      %elif (V_UFFFMT == "E")
                          <td class="dspalph"><a href="mailto:$(V_CUFLDV)" target=_blank title="Click here to send e-mail">$(V_CUFLDV)</a></td>
                      %else
                          <td class="dspalph">$(V_CUFLDV)
                      %endif
                  %elif (V_UFTYPE == "C")
                      %if (formatToPrint != "Y")
                          <td><textarea name="$(V_UFFLDN)" readonly ROWS=$(V_UFBOXS) COLS=60 >$(V_CUFLDV)</textarea>
                      %else
                          @dtw_chartohex(V_CUFLDV, hexValue)
                          @dtw_length(hexValue, fldLength)
                          @dtw_assign(printRows, "1")
                          @dtw_assign(x, "1")
                          %while(x <= fldLength){
                              @dtw_pos("0D25", hexValue, x, y)
                              %if (y > "0")
                                  @dtw_add(printRows, "1", printRows)
                                  @dtw_add(y, "4", x)
                              %else
                                  @dtw_add(fldLength, "1", x)
                              %endif
                          %}
                          <td><textarea name="$(V_UFFLDN)" readonly ROWS=$(printRows) COLS=60>$(V_CUFLDV)</textarea>
                      %endif
                  %elif (V_UFTYPE == "N")
                      @dtw_add(V_UFSIZE, V_UFDECM, V_UFSIZE)
                      %if (V_UFDECM != "0")
                          @dtw_add(V_UFSIZE, "2", V_UFSIZE)
                      %endif
                      @dtw_assign(Precision, @dtw_radd(V_UFSIZE, V_UFDECM))
                      @dtw_format(V_CUFLDR, V_UFSIZE, V_UFDECM, "", "", Precision, V_CUFLDR)
                      %if (V_UFFFMT == "P")
                          @EditPhoneNumber(V_CUFLDR)
                      %endif
                      <td class="dspnmbr">$(V_CUFLDR)
                  %elif (V_UFTYPE == "D")
                      @Date_FromISO_ToCYMD(V_CUFLDD, F_CYMD)
                      @Format_Date(F_CYMD, "H", F_CUFLDD)
                      <td class="dspnmbr">$(F_CUFLDD)
                  %endif
              </td></tr>
              @dtw_add(ux, "1", ux)
          %}
      </table>
      </fieldset>	
  %}
%}

%FUNCTION(dtw_sql) Contact_Event_CustomerInfo (IN CHAR(64)    profileHandle,
				                   CHAR(2)     dataBaseID,
                                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="customerinformation"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"
      	
      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <colgroup>
                  <col width="10%">
                  <col width="50%">
                  <col width="40%">
              </colgroup>
              <tr><th class="colhdr">Number</th>
                  <th class="colhdr">Customer </th>
                  <th class="colhdr">Location</th>
              </tr>
          %endif

          %ROW {
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_CMCUST)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)CustomerSelect.d2w/REPORT?baseVar=@dtw_rurlescseq(baseVar)&amp;eID=@dtw_rurlescseq(eID)&amp;portal=CUSTOMER&amp;customerNumber=@dtw_rurlescseq(V_CMCUST)&amp;customerName=@dtw_rurlescseq(V_CMCNA1)" title="View Related Entity">$(V_CMCNA1)</a></td>
                  <td class="colalph">$(V_CMCCTY), $(V_CMST) $(V_CMZIP)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Contact_Event_Related_Contacts (IN CHAR(64)    profileHandle,
				                       CHAR(2)     dataBaseID,
                                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="relatedcontacts"></a>
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <colgroup>
                  <col width="5%">
                  <col width="10%">
                  <col width="35%">
                  <col width="10%">
                  <col width="25%">

              <tr><th class="colhdr">Number</th>
                  <th class="colhdr">Contact</th>
                  <th class="colhdr">Company</th>
                  <th class="colhdr">Title</th>
                  <th class="colhdr">Location</th>
              </tr>
          %endif

          %ROW {
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_CRCONT)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)CustomerContactselect.d2w/REPORT$(genericVarBase)&amp;contactNumber=@dtw_rurlescseq(V_CRCONT)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)" title="View Related Entity">$(V_CRFNAM) $(V_CRLNAM)</a></td>
                  <td class="colalph">$(V_CRCNAM)</td>
                  <td class="colalph">$(V_CRTITL)</td>
                  <td class="colalph">$(V_CRCITY), $(V_CRST) $(V_CRZIP)</td>
              </tr>
          %}
      </table>
      </fieldset>	
  %}
%}

%INCLUDE "AttachmentSelect.icl"

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @CustContactEvent_Query(profileHandle, dataBaseID, contactNumber, eventSequence, custContactEventTable)	
  @RtvFldDesc("CRCONT=$(contactNumber)", "CRCNTM", "char(CRCUST)", contactCustomer)

  @Set_SQL(stmtSQL)
%}
