%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Feature"
  d2wName                 = "Feature.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPD021"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
  plantNumber             = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @dtw_assign(userPass, "")
  %if (plantNumber > "0")
      @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %endif
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
             %INCLUDE "$(headInclude)"
             <script TYPE="text/javascript">
                 %INCLUDE "CheckEnterSearch.icl"
                 %INCLUDE "Menu.js"
                 %INCLUDE "NoFormValidate.icl"
             </script>
             %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
             <!-- Start Of Banner Code -->
             %INCLUDE "banner.icl"
             <!-- End Of Banner Code -->
             <table $(baseTable)>
                 <tr valign="top">
                     %if (formatToPrint == "")
                         @dtw_assign(pageID, "FEATURE")
                         <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                     %endif
                     <td class="content">
                         @dtw_assign(uv_PlantName, "FIPLT")
                         %INCLUDE "userview.icl"

                         %INCLUDE "stmtSQLClear.icl"
                         @dtw_concat(stmtSQL, "Select FIPLT, FIFEAT, FIFDSC, FIFPRT, ", stmtSQL)
                         @dtw_concat(stmtSQL, " upper(FIFDSC) as FIFDSCU " , stmtSQL)
                         %if (plantNumber == "")
                             @dtw_concat(stmtSQL, " , coalesce(PLNAME,' ') as PLNAME, ", stmtSQL)
                             @dtw_concat(stmtSQL, " coalesce(upper(PLNAME),' ') as PLNAMEU ", stmtSQL)
                         %endif
                         @dtw_concat(fileSQL, " HDMFIT ", fileSQL)
                         %if (plantNumber == "")
                             @dtw_concat(fileSQL, " left join HDPLNT on FIPLT=PLPLNT ", fileSQL)
                         %endif
                         %if (wildCardSearch!="" || plantNumber>"0" || uv_Sql!="")
                             @dtw_concat(selectSQL, "FIFEAT>' ' ", selectSQL)
                         %endif
                         %if (plantNumber > "0")
                             @dtw_concat(selectSQL, " and FIPLT=$(plantNumber)", selectSQL)
                         %endif
                         %INCLUDE "stmtSQLSelect.icl"
                         @RtvFldDesc("$(selectSQL)", "$(fileSQL)", "char(count(*))", sql_Record_Count)
                         %if (@dtw_rpos("FIFPRT", wildCardSearch) == "0")
                             @RtvFldDesc("$(selectSQL)", "$(fileSQL)", "char(count(distinct digits(FIPLT) concat FIFEAT))", my_sql_Record_Count)
                             %if (my_sql_Record_Count > "0")
                                 @dtw_add(sql_Record_Count, my_sql_Record_Count, sql_Record_Count)
                                 @dtw_concat(stmtSQL, "Union ", stmtSQL)
                                 @dtw_concat(stmtSQL, "Select FIPLT, FIFEAT, Max(FIFDSC) as FIFDSC, ' ' as FIFPRT, ", stmtSQL)
                                 @dtw_concat(stmtSQL, " upper(Max(FIFDSC)) as FIFDSCU " , stmtSQL)
                                 %if (plantNumber == "")
                                     @dtw_concat(stmtSQL, " , Max(coalesce(PLNAME,' ')) as PLNAME, ", stmtSQL)
                                     @dtw_concat(stmtSQL, " Max(coalesce(upper(PLNAME),' ')) as PLNAMEU ", stmtSQL)
                                 %endif
                                 @dtw_concat(stmtSQL, " From HDMFIT", stmtSQL)
                                 %if (plantNumber == "")
                                     @dtw_concat(stmtSQL, " left join HDPLNT on FIPLT=PLPLNT ", stmtSQL)
                                 %endif
                                 %if (wildCardSearch!="" || plantNumber>"0" || uv_Sql!="")
                                     @dtw_concat(stmtSQL, " Where FIFEAT>' ' ", stmtSQL)
                                 %endif
                                 %if (plantNumber > "0")
                                     @dtw_concat(stmtSQL, " and FIPLT=$(plantNumber)", stmtSQL)
                                 %endif
                                 %if (uv_Sql != "")
                                     @dtw_concat(stmtSQL, " and ($(uv_Sql))", stmtSQL)
                                 %endif
                                 @dtw_concat(stmtSQL, " $(wildCardSearch) ", stmtSQL)
                                 @dtw_concat(stmtSQL, " Group By FIPLT, FIFEAT", stmtSQL)
                             %endif
                         %endif
                         %if (sql_Record_Count > "0")
                             @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                         %else
                             @dtw_assign(stmtSQL, "Select FLTYPE From SYFLAG Where FLTYPE='NoRecFnd'")
                         %endif
                         %INCLUDE "stmtSQLEnd.icl"
                         @Feature_Query(profileHandle, dataBaseID, stmtSQL)
                     </td>
                 </tr>
             </table>
             <!-- Start Of Trailer Code -->
             %INCLUDE "trailer.icl"
             <!-- End Of Trailer Code -->
        </body>
     </html>
  %endif
%}

%FUNCTION(dtw_sql) Feature_Query (IN CHAR(64)    profileHandle,
                                     CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      <a href="$(homeURL)$(cGIPath)Option.d2w/REPORT$(d2wVarBase)">$(optionsImage)</a>
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      %if (plantNumber > "0")
          @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
          <table $(contentTable)>
              @Format_Header_URL("Plant", $(plantName), $(plantNumber), "$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(d2wVarBase)")
          </table>
      %endif
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search"   onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr"> Feature </th>
                      <th class="colhdr"> Description </th>
                      <th class="colhdr"> Featured Item/<br>Family </th>
                      %if (plantNumber == "")
                          <th class="colhdr">Plant</th>
                      %endif
                  </tr>
                  <tr><td><input type="text" class="inputalph"  name="srchFeature" size="15" maxlength="15">
                          <input type="hidden" name="operFeature" value="LIKE">
                      </td>
                      <td align=center><input type="text" class="inputalph"  name="srchDesc" size="15" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph"  name="srchItem" size="15" maxlength="15">
                          <input type="hidden" name="operItem" value="LIKE">
                      </td>
                      %if (plantNumber == "")
                          <td><input type="text" class="inputnmbr" name="srchPlant" size="5" maxlength="3">
                              <input type="hidden" name="operPlant" value="=">
                          </td>
                      %endif
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchFeature.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              @OrderBy_Sort("2", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=feature" title="Sequence By Feature"> Feature</a></th>
              @OrderBy_Sort("5", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=featureDesc" title="Sequence By Description"> Description</a></th>
              @OrderBy_Sort("4", sortVar)
              <th class="colhdr$(sortVar)"> <a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=featuredItem" title="Sequence By Featured Item/Family"> Featured Item/Family</a></th>
              %if (plantNumber == "")
                  @OrderBy_Sort("1", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlantNumber" title="Sequence By Plant">Plant</a></th>
                  @OrderBy_Sort("7", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlantName" title="Sequence By Plant Name">Plant Name</a></th>
              %endif
              <th class="colhdr">Routings</th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(plantNumber)&amp;plantNumber=@dtw_rurlescseq(V_FIPLT)&amp;feature=@dtw_rurlescseq(V_FIFEAT)&amp;featuredItem=@dtw_rurlescseq(V_FIFPRT)&amp;featureDesc=@dtw_rurlescseq(V_FIFDSC)")
              %INCLUDE "SetRowClass.icl"
              @RtvFldDesc("FRPLT=$(V_FIPLT) and FRFEAT='$(V_FIFEAT)' and FRFITM='$(V_FIFPRT)'", "HDMFRM","FRDEPT", dept)
              %if (dept != "")
                  @dtw_assign(rtgExists, "Y")
              %else
                  @dtw_assign(rtgExists, "")
              %endif
              <tr class="$(rowClass)">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)FeatureRouting.d2w/REPORT$(maintainVar)" title="View Routing">$(V_FIFEAT)</a></td>
                  <td class="colalph">$(V_FIFDSC)</td>
                  <td class="colalph">$(V_FIFPRT)</td>
                  %if (plantNumber == "")
                      <td class="colnmbr">$(V_FIPLT)</td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(V_FIPLT)&amp;plantName=@dtw_rurlescseq(V_PLNAME)" title="View Plant">$(V_PLNAME)</a></td>
                  %endif
                  <td class="colcode">$(rtgExists)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (plantNumber > "0" && orderBy == "7, 2")
          @dtw_assign(orderBy, "")
      %endif
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "2, 4")
          @DTW_ASSIGN(orderByDisplay, "Feature")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "feature")
      %if (orderBy == "2, 4")
          @DTW_ASSIGN(orderBy, "2 DESC, 4")
          @DTW_ASSIGN(orderByDisplay, "Feature (descending)")
      %else
          @DTW_ASSIGN(orderBy, "2, 4")
          @DTW_ASSIGN(orderByDisplay, "Feature")
      %endif
  %elif (sequence == "featureDesc")
      %if (orderBy == "5, 2, 4")
          @DTW_ASSIGN(orderBy, "5 DESC, 2, 4")
          @DTW_ASSIGN(orderByDisplay, "Feature Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "5, 2, 4")
          @DTW_ASSIGN(orderByDisplay, "Feature Description")
      %endif
  %elif (sequence == "featuredItem")
      %if (orderBy == "4, 2")
          @DTW_ASSIGN(orderBy, "4 DESC, 2")
          @DTW_ASSIGN(orderByDisplay, "Featured Item/Family (descending)")
      %else
          @DTW_ASSIGN(orderBy, "4, 2")
          @DTW_ASSIGN(orderByDisplay, "Featured Item/Family")
      %endif
  %elif (sequence == "PlantNumber")
      %if (orderBy == "1, 2")
          @DTW_ASSIGN(orderBy, "1 DESC, 2")
          @DTW_ASSIGN(orderByDisplay, "Plant Number (descending), Feature")
      %else
          @DTW_ASSIGN(orderBy, "1, 2")
          @DTW_ASSIGN(orderByDisplay, "Plant Number, Feature")
      %endif
  %elif (sequence == "PlantName")
      %if (orderBy == "7, 2")
          @DTW_ASSIGN(orderBy, "7 DESC, 2")
          @DTW_ASSIGN(orderByDisplay, "Plant Name (descending), Feature")
      %else
          @DTW_ASSIGN(orderBy, "7, 2")
          @DTW_ASSIGN(orderByDisplay, "Plant Name, Feature")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("FIFEAT", "Feature", $(srchFeature), "U", operFeature, "A")
  @Build_WildCard ("upper(FIFDSC)", "Feature Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("FIFPRT", "Featured Item/Family", $(srchItem), "U", operItem, "A")
  %if (plantNumber == "")
      @Build_WildCard ("FIPLT", "Plant Number", $(srchPlant), "", operPlant, "N")
      @Build_WildCard ("upper(PLNAME)", "Plant Name", $(srchName), "U", operName, "A")
  %endif

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
