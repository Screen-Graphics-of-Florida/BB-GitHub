                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemPlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(V_IPPLT)&amp;itemNumber=@dtw_rurlescseq(itemNumber)" title="View Item/Plant"> $(V_PLNAME)</a></td>
                  <td class="colalph">
                      %if (V_BMBNA1 != "")
