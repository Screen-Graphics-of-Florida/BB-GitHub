              @Format_Nbr(V_IPCMTO, F_IPCMTO, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_IPQMRL, F_IPQMRL, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_PLANTOH, F_PLANTOH, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              %if (V_IPABCC > "0")
                  @RtvFldDesc("BMBUYR=$(V_IPABCC)", "HDBUYR", "CHAR(COUNT(*))", buyerCnt)
              %else
                  @dtw_assign(buyerCnt, "0")
