              </tr>

              <tr><td class="dsphdr">ABC Class Code</td>
                  <td class="dspalph">$(V_IWABCC)</td>
              </tr>

              @RtvFldDesc("FLTYPE='ABCOVERRID' AND FLVALU='$(V_IWABCO)'", "SYFLAG", "FLDESC", fieldDesc)
              @Format_Code(V_IWABCO, F_IWABCO)
              <tr><td class="dsphdr">ABC Class Code Override</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_IWABCC)</td>
              </tr>

              <tr><td class="dsphdr">Override Cycle Days</td>
