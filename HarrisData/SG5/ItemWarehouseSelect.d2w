                  @Format_Column_Header("IHQREC", "Quantity<br>Received")
                  @Format_Column_Header("IHQAMT", "Quantity<br>Adjusted")
                  @Format_Column_Header("IHQTRF", "Quantity<br>Transferred")
                  @Format_Column_Header("IHQTYI", "Quantity<br>Issued")
                  @Format_Column_Header("IHQKTI", "Quantity<br>Kit Issued")
                  @Format_Column_Header("IHQRTV", "Quantity<br>Returned<br>To Vendor")
                  @Format_Column_Header("IHQSCR", "Quantity<br>Scrapped")
                  @Format_Column_Header("IHQDSH", "Quantity<br>Drop Shipped")
                  @Format_Column_Header("IHSTOT", "Number Of<br>Stockouts")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @PeriodFromCYP(V_IHPERD)
              @Format_Nbr(V_IHQREC, F_IHQREC, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_IHQAMT, F_IHQAMT, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_IHQTRF, F_IHQTRF, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_IHQTYI, F_IHQTYI, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_IHQRTV, F_IHQRTV, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_IHQSCR, F_IHQSCR, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_IHQSLD, F_IHQSLD, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_IHQDSH, F_IHQDSH, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_IHDLRS, F_IHDLRS, "2", $(amtEditCode), "Y", "", "")

              <tr class="$(rowClass)">
                  <td class="colcode">$(V_IHPERD)</td>
                  <td class="colnmbr">$(V_IHDLRS)</td>
                  <td class="colnmbr">$(F_IHQSLD)</td>
                  <td class="colnmbr">$(F_IHQREC)</td>
                  <td class="colnmbr">$(F_IHQAMT)</td>
                  <td class="colnmbr">$(F_IHQTRF)</td>
                  <td class="colnmbr">$(F_IHQTYI)</td>
                  @Format_Nbr(V_IHQKTI, F_IHQKTI, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                  <td class="colnmbr">$(F_IHQKTI)</td>
                  <td class="colnmbr">$(F_IHQRTV)</td>
                  <td class="colnmbr">$(F_IHQSCR)</td>
                  <td class="colnmbr">$(F_IHQDSH)</td>
                  <td class="colnmbr">$(V_IHSTOT)</td>
              </tr>
	   %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) ItemWarehouse_Select_Usage_ByYear (IN CHAR(64)    profileHandle,
				                          CHAR(2)     dataBaseID,
                                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="usagebyyear"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMKIT", kitIssued)

              <tr>
                  @Format_Column_Header("IHCYR", "Transaction<br>Year")
                  @Format_Column_Header("IHDLRS", "Sales<br>Amount")
                  @Format_Column_Header("IHQSLD", "Quantity<br>Sold")
                  @Format_Column_Header("IHQREC", "Quantity<br>Received")
                  @Format_Column_Header("IHQAMT", "Quantity<br>Adjusted")
                  @Format_Column_Header("IHQTRF", "Quantity<br>Transferred")
                  @Format_Column_Header("IHQTYI", "Quantity<br>Issued")
                  @Format_Column_Header("IHQKTI", "Quantity<br>Kit Issued")
                  @Format_Column_Header("IHQRTV", "Quantity<br>Returned<br>To Vendor")
                  @Format_Column_Header("IHQSCR", "Quantity<br>Scrapped")
                  @Format_Column_Header("IHQDSH", "Quantity<br>Drop Shipped")
                  @Format_Column_Header("IHSTOT", "Number Of<br>Stockouts")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              %if (V_IHCYR > "99")
                  @dtw_assign(transYear, "20@dtw_rsubstr(V_IHCYR, "2", "2")")
              %else
                  @dtw_assign(transYear, "19@dtw_rsubstr(V_IHCYR, "1", "2")")
              %endif

              @Format_Nbr(V_S_QREC, F_QREC, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_S_QAMT, F_QAMT, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_S_QTRF, F_QTRF, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_S_QTYI, F_QTYI, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_S_QRTV, F_QRTV, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_S_QSCR, F_QSCR, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_S_QSLD, F_QSLD, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_S_QDSH, F_QDSH, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_S_DLRS, F_DLRS, "2", $(amtEditCode), "Y", "", "")

              <tr class="$(rowClass)">
                  <td class="colcode">$(transYear)</td>
                  <td class="colnmbr">$(V_S_DLRS)</td>
                  <td class="colnmbr">$(F_QSLD)</td>
                  <td class="colnmbr">$(F_QREC)</td>
                  <td class="colnmbr">$(F_QAMT)</td>
                  <td class="colnmbr">$(F_QTRF)</td>
                  <td class="colnmbr">$(F_QTYI)</td>
                  @Format_Nbr(V_S_QKTI, F_QKTI, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                  <td class="colnmbr">$(F_QKTI)</td>
                  <td class="colnmbr">$(F_QRTV)</td>
                  <td class="colnmbr">$(F_QSCR)</td>
                  <td class="colnmbr">$(F_QDSH)</td>
                  <td class="colnmbr">$(V_S_STOT)</td>
              </tr>
	   %}
      </table>
      </fieldset>
  %}
%}

