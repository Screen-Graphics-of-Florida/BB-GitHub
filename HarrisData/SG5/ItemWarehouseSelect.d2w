                  <td class="dsphdr">Last Cycle Count</td>
                  <td class="dspnmbr">$(F_IWDLCY)</td>
              </tr>

              <tr>
                  <td class="dsphdr">Times Cycle Counted</td>
                  <td class="dspnmbr">$(V_IWTCY)</td>
              </tr>

              <tr>
                  <td class="dsphdr">Times Within Variance Limit</td>
                  <td class="dspnmbr">$(V_IWTIV)</td>
              </tr>

              <tr>
                  <td class="dsphdr">Average Accuracy</td>
                  <td class="dspnmbr">@dtw_rformat(@dtw_rmultiply(V_IWACPA, "100"),"","2")%</td>
              </tr>

              <tr>
                  <td class="dsphdr">Last Cycle Count Accuracy</td>
                  <td class="dspnmbr">@dtw_rformat(@dtw_rmultiply(V_IWLCPA, "100"),"","2")%</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

